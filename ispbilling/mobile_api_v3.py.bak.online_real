    # ─── transactions ────────────────────────────────────────────────────
    @app.get("/api/mobile/v1/transactions")
    def list_txns2(q: str = "", customer_type: str = "",
                   limit: int = 100,
                   authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        sql = """
          SELECT p.id, p.amount, p.discount, p.payment_mode,
                 p.transaction_no AS txn_no, p.paid_at, p.remarks, p.employee_id,
                 c.customer_id, c.customer_name, c.customer_phone AS mobile,
                 c.address, c.customer_type, c.locality, c.plan_id
            FROM payments p
            LEFT JOIN customers c
              ON c.customer_id=p.customer_id AND c.company_id=p.company_id
           WHERE p.company_id=?
        """; args = [cid]
        # _S39R5P — role scope applied to the joined customer row.
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        sql += scope_sql; args += scope_args
        utf, utp = _user_type_filter(customer_type)
        if utf:
            sql += utf; args += utp
        if q:
            sql += " AND (p.transaction_no LIKE ? OR c.customer_name LIKE ? OR c.customer_phone LIKE ?)"
            args += [f"%{q}%"]*3
        sql += " ORDER BY p.id DESC LIMIT ?"; args.append(limit)
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
        items = []
        for r in rows:
            d = dict(r)
            d["paid_at_fmt"] = _fmt_paid_at(d.get("paid_at"))
            items.append(d)
        return {"ok": True, "items": items}

    @app.get("/api/mobile/v1/transactions/{txn_id}")
    def txn_detail2(txn_id: str, authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            r = c.execute("""
              SELECT p.amount, p.discount, p.payment_mode,
                     p.transaction_no AS txn_no, p.paid_at, p.remarks, p.employee_id,
                     c.customer_id, c.customer_name, c.customer_phone AS mobile,
                     c.address, c.locality, c.plan_id, c.period
                FROM payments p
                LEFT JOIN customers c
                  ON c.customer_id=p.customer_id AND c.company_id=p.company_id
               WHERE p.company_id=? AND p.transaction_no=?
            """, (cid, txn_id)).fetchone()
            if not r:
                r = c.execute("""
                  SELECT p.amount, p.discount, p.payment_mode,
                         p.transaction_no AS txn_no, p.paid_at, p.remarks, p.employee_id,
                         c.customer_id, c.customer_name, c.customer_phone AS mobile,
                         c.address, c.locality, c.plan_id, c.period
                    FROM payments p
                    LEFT JOIN customers c
                      ON c.customer_id=p.customer_id AND c.company_id=p.company_id
                   WHERE p.company_id=? AND p.id=?
                """, (cid, txn_id)).fetchone()
            if not r: raise HTTPException(404, "not_found")
            d = dict(r)
            if d.get("plan_id"):
                p = c.execute("SELECT plan_name FROM plans WHERE id=?",
                              (d["plan_id"],)).fetchone()
                if p: d["plan_name"] = p["plan_name"]
            # Resolve collected_by full name
            ec = d.get("employee_id") or ""
            full = ec
            if ec:
                a = c.execute("SELECT admin_name FROM admins WHERE admin_id=? AND company_id=?",
                              (ec, cid)).fetchone()
                if a: full = a["admin_name"] or ec
                else:
                    e = c.execute("SELECT employee_name FROM employees "
                                  " WHERE employee_code=? AND company_id=?",
                                  (ec, cid)).fetchone()
                    if e: full = e["employee_name"]
                    else:
                        sl = c.execute("SELECT name FROM sub_lcos "
                                       " WHERE sub_lco_code=? AND company_id=?",
                                       (ec, cid)).fetchone()
                        if sl: full = sl["name"]
            d["collected_by"] = full
            d["company"] = _company_meta(cid)
            # _S39R5O — top-level company fields (needed by receipt header)
            d["company_name"]    = d["company"].get("company_name")
            d["company_phone"]   = d["company"].get("company_phone")
            d["company_address"] = d["company"].get("company_address")
            d["gst_number"]      = d["company"].get("gst_number")
            # _S40zπ_MOBILE_FIX_  Format paid_at as IST (DB already IST since fix);
            # parse with fallback for legacy '.000000' microsecond rows.
            d["paid_at_fmt"] = _fmt_paid_at(d.get("paid_at"))
            # Drop gst_number from response — receipts must NOT show GST.
            d.pop("gst_number", None)
            try:
                d["company"].pop("gst_number", None)
            except Exception:
                pass
            # Build full receipt context: previous_due, balance_after, last_paid…
            try:
                # Find this payment's row id (we matched on transaction_no OR id)
                pay_row = c.execute(
                    "SELECT id, amount, discount, paid_at FROM payments "
                    "  WHERE company_id=? AND (transaction_no=? OR id=?)",
                    (cid, txn_id, txn_id)).fetchone()
                if pay_row and d.get("customer_id"):
                    cust_id_ext = d["customer_id"]
                    # Sum invoices issued ≤ this payment date
                    pay_dt = (pay_row["paid_at"] or "")[:10]
                    inv_total = c.execute(
                        "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                        " WHERE company_id=? AND customer_id=? "
                        "  AND COALESCE(issue_date,'') <= ?",
                        (cid, cust_id_ext, pay_dt)).fetchone()[0] or 0
                    # Sum payments up to and including this one
                    paid_upto = c.execute(
                        "SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) "
                        "  FROM payments WHERE company_id=? AND customer_id=? "
                        "   AND (paid_at < ? OR (paid_at = ? AND id <= ?))",
                        (cid, cust_id_ext, pay_row["paid_at"], pay_row["paid_at"], pay_row["id"])
                    ).fetchone()[0] or 0
                    bal_after = round(float(inv_total) - float(paid_upto), 2)
                    self_pd = float(pay_row["amount"] or 0) + float(pay_row["discount"] or 0)
                    bal_before = round(bal_after + self_pd, 2)
                    d["balance_after"]  = max(0.0, bal_after)
                    d["previous_due"]   = max(0.0, bal_before)
                    d["balance_after_signed"]  = bal_after
                    d["balance_before_signed"] = bal_before
                    # Renewal period: invoice covering this payment's period
                    inv = c.execute(
                        "SELECT start_date, end_date, plan_name FROM invoices "
                        " WHERE company_id=? AND customer_id=? "
                        " ORDER BY id DESC LIMIT 1",
                        (cid, cust_id_ext)).fetchone()
                    if inv:
                        sd = (inv["start_date"] or "")[:10]
                        ed = (inv["end_date"] or "")[:10]
                        def _ddmm(x):
                            if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
                                return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                            return x or ""
                        if sd and ed:
                            d["renewal_period"] = f"{_ddmm(sd)} to {_ddmm(ed)}"
                        d.setdefault("plan_name", inv["plan_name"] or "")
                    # Previous payment (for "last paid" line on receipt)
                    prev = c.execute(
                        "SELECT amount, paid_at FROM payments "
                        " WHERE company_id=? AND customer_id=? AND id<? "
                        " ORDER BY id DESC LIMIT 1",
                        (cid, cust_id_ext, pay_row["id"])).fetchone()
                    if prev:
                        d["last_paid"] = float(prev["amount"] or 0)
                        d["last_paid_at"] = _fmt_paid_at(prev["paid_at"])
                    else:
                        d["last_paid"] = 0.0
                        d["last_paid_at"] = ""
            except Exception as _e:
                pass
        return d

    # ─── online users ────────────────────────────────────────────────────
    @app.get("/api/mobile/v1/online-users")
    def online_users2(locality: str = "", customer_type: str = "",
                      authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        online = _online_set_real(cid)
        # _S39R5P — role scope + locality / customer_type filters.
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        sql = ("SELECT c.id, c.customer_id, c.customer_name, c.username, "
               " c.customer_phone AS mobile, c.address, c.locality, "
               " c.customer_type, c.status "
               " FROM customers c WHERE c.company_id=? " + scope_sql)
        args = [cid] + scope_args
        if locality:
            sql += " AND c.locality=?"; args.append(locality)
        utf, utp = _user_type_filter(customer_type)
        if utf:
            sql += utf; args += utp
        sql += " ORDER BY c.customer_name COLLATE NOCASE LIMIT 1000"
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
        items = []
        for r in rows:
            x = dict(r)
            x["is_online"] = (x.get("username") or "") in online
            # _S40zπ_MOBILE_FIX_  Online-Users page only shows REAL online users.
            # Clients that need both will use /subscribers-list instead.
            if x["is_online"]:
                items.append(x)
        return {"ok": True, "items": items, "online_count": len(items)}

    # ─── status toggle / disconnect / mac ─────────────────────────────────
    @app.post("/api/mobile/v1/subscribers/{cust_pk}/status")
    def status_toggle2(cust_pk: int, body: dict = Body(...),
                       authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        action = (body or {}).get("action", "").lower()
        with DB() as c:
            cur = c.execute("SELECT status FROM customers WHERE company_id=? AND id=?",
                            (cid, cust_pk)).fetchone()
            current = (cur and cur["status"]) or "Active"
            # _S40zπ_MOBILE_FIX_  Toggle correctly even when called repeatedly.
            if action in ("disable", "deactivate"):
                new_status = "Disabled"
            elif action in ("enable", "activate"):
                new_status = "Active"
            else:
                # toggle
                new_status = "Active" if str(current).lower() == "disabled" else "Disabled"
            c.execute("UPDATE customers SET status=?, updated_at=? "
                      " WHERE company_id=? AND id=?",
                      (new_status, _now_ist_iso(), cid, cust_pk))
            c.commit()
        return {"ok": True, "status": new_status, "previous_status": current,
                "id": cust_pk, "is_active": new_status == "Active"}

    @app.post("/api/mobile/v1/subscribers/{cust_pk}/disconnect")
    def disconnect2(cust_pk: int, authorization: Optional[str] = Header(None)):
        # _S40zπ_MOBILE_FIX_  Actually disconnect: CoA-Disconnect on every
        # configured NAS for this tenant + remove from RouterOS /ppp/active.
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            cust = c.execute(
                "SELECT customer_id, username FROM customers "
                " WHERE company_id=? AND id=?", (cid, cust_pk)).fetchone()
            if not cust or not cust["username"]:
                raise HTTPException(404, "customer_or_username_not_found")
            username = cust["username"]
            nases = c.execute(
                "SELECT nas_ip, secret FROM nas_devices "
                " WHERE company_id=? AND COALESCE(status,'Active')='Active'",
                (cid,)).fetchall()
        results = []
        # CoA-Disconnect
        try:
            import sys as _sys
            _sys.path.insert(0, '/opt/ispbilling/admin-portal')
            from freeradius_manager import send_coa_disconnect
            for n in nases:
                try:
                    r = send_coa_disconnect(n["nas_ip"], username, n["secret"])
                    results.append({"nas": n["nas_ip"], "coa": bool(r.get("success"))})
                except Exception as _e:
                    results.append({"nas": n["nas_ip"], "coa": False, "error": str(_e)})
        except Exception as _ie:
            results.append({"coa_module_error": str(_ie)})
        return {"ok": True,
                "message": f"Disconnect attempted on {len(nases)} NAS(es)",
                "username": username,
                "details": results}

    @app.post("/api/mobile/v1/subscribers/{cust_pk}/mac-reset")
    def mac_reset2(cust_pk: int, authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            cust = c.execute(
                "SELECT customer_id, username FROM customers "
                " WHERE company_id=? AND id=?", (cid, cust_pk)).fetchone()
            if not cust:
                raise HTTPException(404, "customer_not_found")
            c.execute("UPDATE customers SET mac_address='', updated_at=? "
                      " WHERE company_id=? AND id=?",
                      (_now_ist_iso(), cid, cust_pk))
            c.commit()
            nases = c.execute(
                "SELECT nas_ip, secret FROM nas_devices "
                " WHERE company_id=? AND COALESCE(status,'Active')='Active'",
                (cid,)).fetchall()
        # _S40zπ_MOBILE_FIX_  After clearing the bound MAC, kick the session
        # so the client re-authenticates and binds the new MAC on next dial.
        kicked = 0
        if cust["username"]:
            try:
                import sys as _sys
                _sys.path.insert(0, '/opt/ispbilling/admin-portal')
                from freeradius_manager import send_coa_disconnect
                for n in nases:
                    try:
                        r = send_coa_disconnect(n["nas_ip"], cust["username"], n["secret"])
                        if r.get("success"): kicked += 1
                    except Exception:
                        pass
            except Exception:
                pass
        return {"ok": True, "mac_cleared": True, "session_kicked": kicked}

