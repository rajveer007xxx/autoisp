    # ─── Complaints ──────────────────────────────────────────────────────
    @app.get("/api/mobile/v1/complaints-list")
    def complaints_list(status: str = "", priority: str = "",
                        complaint_type: str = "", q: str = "",
                        authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        # _S40zπ_MOBILE_FIX_  Server-side filtering for status/priority/type/q.
        sql = """
              SELECT cp.id, cp.ticket_no AS ticket_id, cp.complaint_type, cp.priority,
                     cp.subject, cp.description, cp.status, cp.created_at,
                     cp.updated_at, cp.resolved_by AS assigned_to,
                     cu.customer_id, cu.customer_name, cu.username,
                     cu.address, cu.locality, cu.customer_phone AS mobile,
                     cu.customer_type
                FROM complaints cp
                LEFT JOIN customers cu
                  ON cu.customer_id=cp.customer_id AND cu.company_id=cp.company_id
               WHERE cp.company_id=?
              """
        args = [cid]
        if status:
            sql += " AND LOWER(IFNULL(cp.status,''))=LOWER(?)"
            args.append(status)
        if priority:
            sql += " AND LOWER(IFNULL(cp.priority,''))=LOWER(?)"
            args.append(priority)
        if complaint_type:
            sql += " AND LOWER(IFNULL(cp.complaint_type,''))=LOWER(?)"
            args.append(complaint_type)
        if q:
            sql += (" AND (cp.ticket_no LIKE ? OR cp.subject LIKE ? OR "
                    " cu.customer_name LIKE ? OR cu.customer_id LIKE ?)")
            args += [f"%{q}%"] * 4
        sql += " ORDER BY cp.id DESC LIMIT 300"
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
        items = []
        for r in rows:
            d = dict(r)
            d["created_at_fmt"] = _fmt_paid_at(d.get("created_at"))
            d["updated_at_fmt"] = _fmt_paid_at(d.get("updated_at"))
            items.append(d)
        return {"ok": True, "items": items}

    @app.get("/api/mobile/v1/complaints/{cid_pk}")
    def complaint_detail(cid_pk: int, authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            r = c.execute("""
              SELECT cp.*, cu.customer_id AS cust_code, cu.customer_name,
                     cu.username, cu.address, cu.locality,
                     cu.customer_phone AS mobile
                FROM complaints cp
                LEFT JOIN customers cu
                  ON cu.customer_id=cp.customer_id AND cu.company_id=cp.company_id
               WHERE cp.id=? AND cp.company_id=?
            """, (cid_pk, cid)).fetchone()
            if not r: raise HTTPException(404, "not_found")
        d = dict(r); d["ticket_id"] = d.get("ticket_no")
        d["assigned_to"] = d.get("resolved_by")
        d["comments"] = []  # simple list (extension point)
        return d

    @app.post("/api/mobile/v1/complaints/{cid_pk}/update")
    def complaint_update(cid_pk: int, body: dict = Body(...),
                         authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            if body.get("delete"):
                c.execute("DELETE FROM complaints WHERE id=? AND company_id=?",
                          (cid_pk, cid)); c.commit()
                return {"ok": True, "deleted": True}
            sets = []; args = []
            if body.get("status"):
                sets.append("status=?"); args.append(body["status"])
            if body.get("assigned_to"):
                sets.append("resolved_by=?"); args.append(body["assigned_to"])
            if sets:
                args += [cid_pk, cid]
                c.execute(f"UPDATE complaints SET {', '.join(sets)}, "
                          " updated_at=CURRENT_TIMESTAMP "
                          " WHERE id=? AND company_id=?", args); c.commit()
        return {"ok": True}

    # ─── Bill Dues ───────────────────────────────────────────────────────
    @app.get("/api/mobile/v1/dues")
    def dues(q: str = "", customer_type: str = "", locality: str = "",
             authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        # _S39R5P — role scope applied.
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        # _S40zπ_MOBILE_FIX_  Pull all in-scope active customers; balance
        # filtering happens after via the real ledger (invoices - payments).
        sql = ("SELECT c.id, c.customer_id, c.customer_name, c.username, "
               " c.customer_phone AS mobile, c.address, c.locality, c.customer_type, "
               " c.status, c.plan_id, c.period, c.start_date, c.end_date, "
               " c.monthly_amount "
               " FROM customers c WHERE c.company_id=? "
               " AND COALESCE(c.status,'') NOT IN ('Deleted','deleted') " + scope_sql)
        args = [cid] + scope_args
        utf, utp = _user_type_filter(customer_type)
        if utf:
            sql += utf; args += utp
        if locality:
            sql += " AND c.locality=?"; args.append(locality)
        if q:
            sql += " AND (c.customer_name LIKE ? OR c.customer_phone LIKE ? OR c.customer_id LIKE ?)"
            args += [f"%{q}%"]*3
        sql += " ORDER BY c.customer_name COLLATE NOCASE"
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
            plans = {p["id"]: dict(p) for p in c.execute(
                "SELECT id, plan_name FROM plans").fetchall()}
            lps = {r["customer_id"]: dict(r) for r in c.execute(
                "SELECT customer_id, MAX(paid_at) AS paid_at, amount FROM payments "
                " WHERE company_id=? GROUP BY customer_id", (cid,)).fetchall()}
            items = []
            for r in rows:
                d = dict(r)
                signed = _balance_signed(c, cid, d.get("customer_id"))
                cur_inv = _latest_invoice_amount(c, cid, d.get("customer_id"))
                due_pos = max(0.0, round(signed, 2))
                if due_pos <= 0:
                    continue   # not actually a "due"
                d["due_amount"]  = due_pos
                d["balance"]     = due_pos
                d["balance_signed"] = round(signed, 2)
                d["current_charge"] = round(cur_inv if cur_inv else float(d.get("monthly_amount") or 0), 2)
                d["current_due"] = round(min(due_pos, d["current_charge"]), 2)
                d["prev_due"]    = round(max(0.0, due_pos - d["current_charge"]), 2)
                d["plan_name"]   = (plans.get(d.get("plan_id")) or {}).get("plan_name")
                lp = lps.get(d.get("customer_id")) or {}
                d["last_paid"]    = float(lp.get("amount") or 0)
                d["last_paid_at"] = _fmt_paid_at(lp.get("paid_at"))
                # Format period dates for UI: DD-MM-YYYY to DD-MM-YYYY
                def _ddmm(x):
                    x = (x or "")[:10]
                    if len(x) == 10 and x[4] == "-" and x[7] == "-":
                        return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                    return x
                if d.get("start_date") and d.get("end_date"):
                    d["formatted_period"] = f"{_ddmm(d['start_date'])} to {_ddmm(d['end_date'])}"
                else:
                    d["formatted_period"] = ""
                items.append(d)
        items.sort(key=lambda x: x.get("due_amount", 0), reverse=True)
        return {"ok": True, "items": items, "total_count": len(items)}

    # ─── Reports — collections summary ──────────────────────────────────
    @app.get("/api/mobile/v1/reports/collections")
    def report_collections(duration: str = "this_month",
                           employee_id: str = "",
                           location: str = "",
                           customer_type: str = "",
                           authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        # Date range
        now = datetime.now(_IST).replace(tzinfo=None)
        if duration == "today":      d0 = now.strftime("%Y-%m-%d 00:00:00")
        elif duration == "yesterday":d0 = (now - timedelta(days=1)).strftime("%Y-%m-%d 00:00:00")
        elif duration == "this_week":d0 = (now - timedelta(days=now.weekday())).strftime("%Y-%m-%d 00:00:00")
        elif duration == "last_month":
            first = now.replace(day=1) - timedelta(days=1)
            d0 = first.strftime("%Y-%m-01 00:00:00")
        elif duration == "this_year":d0 = now.strftime("%Y-01-01 00:00:00")
        else:                        d0 = now.strftime("%Y-%m-01 00:00:00")
        d1 = (now + timedelta(days=1)).strftime("%Y-%m-%d 00:00:00")
        sql = """
          SELECT p.amount, p.discount, p.payment_mode, p.transaction_no AS txn_no,
                 p.paid_at, p.employee_id,
                 c.customer_id, c.customer_name, c.customer_type, c.locality
            FROM payments p
            LEFT JOIN customers c
              ON c.customer_id=p.customer_id AND c.company_id=p.company_id
           WHERE p.company_id=? AND p.paid_at>=? AND p.paid_at<?
        """; args = [cid, d0, d1]
        # _S39R5P — role scope
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        sql += scope_sql; args += scope_args
        if employee_id:
            sql += " AND p.employee_id=?"; args.append(employee_id)
        if location:
            sql += " AND c.locality=?"; args.append(location)
        utf, utp = _user_type_filter(customer_type)
        if utf:
            sql += utf; args += utp
        sql += " ORDER BY p.id DESC"
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
        items = [dict(r) for r in rows]
        ONLINE_MODES = {"upi", "card", "netbanking", "phonepe", "gpay", "paytm"}
        total = round(sum(float(x["amount"] or 0) for x in items))
        online_total = round(sum(float(x["amount"] or 0) for x in items
                                  if (x.get("payment_mode") or "").lower() in ONLINE_MODES))
        offline_total = total - online_total
        # group for chart by day
        chart = {}
        for x in items:
            day = (x.get("paid_at") or "")[:10]
            chart.setdefault(day, 0); chart[day] += float(x["amount"] or 0)
        chart_arr = [{"day": k, "amount": round(v)} for k, v in sorted(chart.items())]
        return {"ok": True, "summary": {
                "total": total, "online": online_total, "offline": offline_total,
                "count": len(items), "duration": duration,
                "employee_id": employee_id, "location": location,
                "customer_type": customer_type,
            },
            "chart": chart_arr, "items": items}

    # ─── OLT/ONU live wiring (real, DB-backed) ────────────────────────────
    @app.get("/api/mobile/v1/olts")
    def olts2(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='olts'").fetchone()
            if not t:
                return {"ok": True, "items": []}
            rows = c.execute(
                "SELECT id, name, host, vendor, model, location, status, "
                "       total_onus, online_onus, cpu_pct, mem_pct, temp_c, "
                "       last_polled FROM olts WHERE company_id=? "
                "ORDER BY name", (cid,)
            ).fetchall()
        return {"ok": True, "items": [dict(r) for r in rows]}

    @app.get("/api/mobile/v1/olt/dashboard")
    def olt_dashboard_m(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='olts'").fetchone()
            if not t:
                return {"ok": True, "kpis": {}, "olts": [],
                        "recent_alerts": [], "worst_rx": []}
            olts = [dict(r) for r in c.execute(
                "SELECT id, name, host, vendor, model, location, status, "
                "total_onus, online_onus, cpu_pct, mem_pct, temp_c, "
                "last_polled FROM olts WHERE company_id=? ORDER BY name",
                (cid,)).fetchall()]
            online_olts = sum(1 for o in olts if o["status"] == "online")
            total_onus = sum(int(o["total_onus"] or 0) for o in olts)
            online_onus = sum(int(o["online_onus"] or 0) for o in olts)
            offline_onus = max(0, total_onus - online_onus)
            ac = c.execute(
                "SELECT COUNT(*), SUM(CASE WHEN level='critical' THEN 1 "
                "ELSE 0 END) FROM olt_alerts WHERE company_id=? AND acked=0",
                (cid,)).fetchone()
            alerts = [dict(r) for r in c.execute(
                "SELECT a.id, a.olt_id, o.name AS olt_name, a.kind, a.level, "
                "a.title, a.message, a.acked, a.created_at FROM olt_alerts a "
                "LEFT JOIN olts o ON o.id=a.olt_id WHERE a.company_id=? "
                "ORDER BY a.id DESC LIMIT 20", (cid,)).fetchall()]
            worst = [dict(r) for r in c.execute(
                "SELECT id, olt_id, pon_port_index, onu_index, serial, "
                "rx_power, status FROM onus WHERE company_id=? "
                "AND status='online' AND rx_power IS NOT NULL "
                "AND rx_power > -90 ORDER BY rx_power ASC LIMIT 10",
                (cid,)).fetchall()]
        return {"ok": True, "kpis": {
                    "olts_total": len(olts), "olts_online": online_olts,
                    "olts_offline": len(olts) - online_olts,
                    "onus_total": total_onus, "onus_online": online_onus,
                    "onus_offline": offline_onus,
                    "alerts_open": int((ac or [0])[0] or 0),
                    "alerts_critical": int((ac or [0, 0])[1] or 0)},
                "olts": olts, "recent_alerts": alerts, "worst_rx": worst}

    @app.get("/api/mobile/v1/olts/{olt_id}")
    def olt2(olt_id: int, authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='olts'").fetchone()
            if not t:
                raise HTTPException(404, "OLT not found")
            row = c.execute(
                "SELECT * FROM olts WHERE id=? AND company_id=?",
                (olt_id, cid)).fetchone()
            if not row:
                raise HTTPException(404, "OLT not found")
            d = dict(row)
            # PON port aggregation from ONUs
            ports = c.execute(
                "SELECT pon_port_index, COUNT(*) AS total, "
                "SUM(CASE WHEN status='online' THEN 1 ELSE 0 END) AS online "
                "FROM onus WHERE olt_id=? GROUP BY pon_port_index "
                "ORDER BY pon_port_index", (olt_id,)).fetchall()
        d["pon_ports"] = [{"port": int(p[0] or 0), "total": int(p[1] or 0),
                           "online": int(p[2] or 0)} for p in ports]
        d["health"] = d.get("status") or "unknown"
        d["uptime"] = (str(d.get("uptime_sec") or 0) + "s")
        return d

    @app.get("/api/mobile/v1/olts/{olt_id}/onus")
    def olt_onus2(olt_id: int, q: str = "", status: Optional[str] = None,
                  pon_port_index: Optional[int] = None,
                  rx_max: Optional[float] = None,
                  authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        sql = ("SELECT id, olt_id, pon_port_index, onu_index, serial, mac, "
               "vendor, model, name, customer_id, status, rx_power, "
               "tx_power, distance_m, uptime_sec, last_seen, last_offline "
               "FROM onus WHERE company_id=? AND olt_id=?")
        args: list = [cid, olt_id]
        if status:
            sql += " AND status=?"; args.append(status)
        if pon_port_index is not None:
            sql += " AND pon_port_index=?"; args.append(pon_port_index)
        if rx_max is not None:
            sql += " AND rx_power IS NOT NULL AND rx_power<=?"
            args.append(rx_max)
        if q:
            sql += (" AND (serial LIKE ? OR mac LIKE ? OR name LIKE ? "
                    "OR customer_id LIKE ?)")
            like = f"%{q}%"; args += [like, like, like, like]
        sql += " ORDER BY pon_port_index, onu_index LIMIT 500"
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='onus'").fetchone()
            if not t:
                return {"ok": True, "items": []}
            rows = c.execute(sql, args).fetchall()
        return {"ok": True, "items": [dict(r) for r in rows]}

