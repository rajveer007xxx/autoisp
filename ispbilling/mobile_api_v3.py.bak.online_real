            r = c.execute(
                "SELECT id, plan_name, speed, validity, "
                "       base_amount, after_tax_amount, service AS plan_type "
                "  FROM plans WHERE (company_id=? OR company_id IS NULL OR company_id='') "
                " ORDER BY after_tax_amount", (cid,)).fetchall()
