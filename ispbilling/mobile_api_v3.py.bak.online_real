"""
mobile_api_v3.py — v3.1  (S39R5j_v3p1)

Fixes the data-shape bugs reported on the Android v3 APK and adds the new
endpoints the rebuilt screens need.

Endpoint matrix added/overridden:
  GET  /api/mobile/v1/me                       (full profile + company)
  GET  /api/mobile/v1/subscribers/normalized   (list w/ unified fields)
  GET  /api/mobile/v1/subscriber/{id}          (canonical detail w/ all derived fields)
  POST /api/mobile/v1/pay                      (records payment + returns full receipt)
  GET  /api/mobile/v1/localities               (real DB localities)
  GET  /api/mobile/v1/locations                (locations FK)
  GET  /api/mobile/v1/employees-list           (sub-lcos + employees for assign/report)
  GET  /api/mobile/v1/plans-list               (real plans + speeds + amounts)
  GET  /api/mobile/v1/transactions             (cross-customer, with name/mobile)
  GET  /api/mobile/v1/transactions/{id}
  GET  /api/mobile/v1/online-users             (real-time RADIUS)
  POST /api/mobile/v1/subscribers/{id}/disconnect
  POST /api/mobile/v1/subscribers/{id}/mac-reset
  POST /api/mobile/v1/subscribers/{id}/status
  GET  /api/mobile/v1/olts                     (Mikrotik scan: PPPoE secrets/active = synthetic ONUs)
  GET  /api/mobile/v1/olts/{id}                (live health)
  GET  /api/mobile/v1/olts/{id}/onus           (live ONU list)
  GET  /api/mobile/v1/onus/{id}/remote-config  (live)
  POST /api/mobile/v1/onus/{id}/{ztp/deploy,activate,wifi,reboot,factory-reset}
  GET  /api/mobile/v1/nas/list                 (full NAS detail)
  GET  /api/mobile/v1/complaints-list          (proper shape)
  POST /api/mobile/v1/complaints/{id}/update
  GET  /api/mobile/v1/dues                     (Bill Dues page)
  GET  /api/mobile/v1/reports/collections      (total/online/offline split)
"""
from __future__ import annotations
import sqlite3, time
from datetime import datetime, timedelta
from typing import Optional
from fastapi import APIRouter, HTTPException, Header, Body, Query


def install(app, *, _conn, _require_auth):
    DB = _conn

    # ─── company info helper ─────────────────────────────────────────────

    # ─── _S40zπ_MOBILE_FIX_  Centralised IST timestamp + ledger helpers ───
    from zoneinfo import ZoneInfo as _ZI
    _IST = _ZI("Asia/Kolkata")

    def _now_ist_iso() -> str:
        """Return current IST naive 'YYYY-MM-DD HH:MM:SS' (matches web payments)."""
        return datetime.now(_IST).strftime("%Y-%m-%d %H:%M:%S")

    def _fmt_paid_at(raw, fmt: str = "%d-%m-%Y %H:%M") -> str:
        """Parse a paid_at string (with or without microseconds) and format
        for receipt display.  No timezone shift — the DB now always stores IST."""
        if not raw:
            return ""
        raw = str(raw).strip()
        for parse_fmt in ("%Y-%m-%d %H:%M:%S.%f", "%Y-%m-%d %H:%M:%S",
                          "%Y-%m-%dT%H:%M:%S.%f", "%Y-%m-%dT%H:%M:%S"):
            try:
                return datetime.strptime(raw[:26], parse_fmt).strftime(fmt)
            except Exception:
                continue
        return raw

    def _balance_signed(cur, cid: str, customer_id: str) -> float:
        """Real ledger balance = SUM(invoices) - SUM(payments + discounts).
        Positive = customer owes; zero = clear; negative = credit/advance."""
        try:
            inv = cur.execute(
                "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                " WHERE company_id=? AND customer_id=?",
                (cid, customer_id)).fetchone()[0] or 0
        except Exception:
            inv = 0
        try:
            pay = cur.execute(
                "SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) "
                "  FROM payments WHERE company_id=? AND customer_id=?",
                (cid, customer_id)).fetchone()[0] or 0
        except Exception:
            pay = 0
        return round(float(inv) - float(pay), 2)

    def _latest_invoice_amount(cur, cid: str, customer_id: str) -> float:
        """Amount of the most recent invoice — used as 'current period charge'."""
        r = cur.execute(
            "SELECT total_amount FROM invoices "
            " WHERE company_id=? AND customer_id=? "
            " ORDER BY issue_date DESC, id DESC LIMIT 1",
            (cid, customer_id)).fetchone()
        return float(r[0] or 0) if r else 0.0

    def _online_set_real(cid: str) -> set:
        """Online usernames from radacct, scoped to THIS company's customers."""
        try:
            with DB() as _c:
                # Only count NON-deleted customers from this tenant
                names = [r[0] for r in _c.execute(
                    "SELECT username FROM customers "
                    " WHERE company_id=? AND IFNULL(username,'')!='' "
                    "  AND COALESCE(status,'') NOT IN ('Deleted','deleted','Terminated','terminated')",
                    (cid,)).fetchall()]
            name_set = set(names)
            if not name_set:
                return set()
            ra = sqlite3.connect("file:/var/lib/freeradius/radacct.db?mode=ro",
                                 uri=True, timeout=5)
            ra.row_factory = sqlite3.Row
            online = set()
            chunk = 400
            names_list = list(name_set)
            for i in range(0, len(names_list), chunk):
                batch = names_list[i:i+chunk]
                ph = ",".join("?" * len(batch))
                rows = ra.execute(
                    f"SELECT DISTINCT username FROM radacct "
                    f" WHERE acctstoptime IS NULL AND username IN ({ph})",
                    batch).fetchall()
                online.update(r["username"] for r in rows)
            ra.close()
            # Final intersect (defensive — radacct is shared across tenants)
            return online & name_set
        except Exception:
            return set()



    # _S40zπ_MOBILE_FIX_  Smart user-type filter — routes 'broadband'/'cable'
    # /'fiber'/'wireless' to service_type; 'prepaid'/'postpaid' stay on
    # customer_type. The mobile UI's single 'User Type' dropdown sends mixed
    # values, so the API has to be liberal about both columns.
    _SVC_TYPES = {"broadband", "cable", "fiber", "wireless", "wifi", "leased_line"}
    _BILL_TYPES = {"prepaid", "postpaid"}
    def _user_type_filter(val: str):
        """Return (sql_fragment, params) — joined with AND. Empty if val falsy."""
        v = (val or "").strip().lower().replace(" ", "_")
        if not v or v == "all":
            return "", []
        if v in _SVC_TYPES:
            return (" AND LOWER(REPLACE(IFNULL(c.service_type,''),' ','_'))=? ", [v])
        if v in _BILL_TYPES:
            return (" AND LOWER(REPLACE(IFNULL(c.customer_type,''),' ','_'))=? ", [v])
        # Unknown value — match either column for forward-compat
        return (" AND (LOWER(REPLACE(IFNULL(c.service_type,''),' ','_'))=? "
                "  OR LOWER(REPLACE(IFNULL(c.customer_type,''),' ','_'))=?) ",
                [v, v])

    def _company_meta(cid: str) -> dict:
        if not cid: return {}
        with DB() as c:
            r = c.execute(
                "SELECT company_name, company_phone, company_email, "
                "       company_address, gst_number, upi_id, logo_path "
                "  FROM companies WHERE company_id=?", (cid,)).fetchone()
        return dict(r) if r else {}

    # ─── Push Notifications (Expo) ───────────────────────────────────────
    # _S39R5Q — Send via Expo Push API. Tokens stored in `push_tokens`.
    def _push_send(tokens: list, title: str, body: str, data: dict = None):
        if not tokens: return
        try:
            import urllib.request, json as _json
            payload = [{
                "to": tk, "title": title, "body": body, "sound": "default",
                "data": data or {}, "priority": "high",
            } for tk in tokens]
            req = urllib.request.Request(
                "https://exp.host/--/api/v2/push/send",
                data=_json.dumps(payload).encode(),
                headers={"Content-Type": "application/json",
                         "Accept": "application/json",
                         "Accept-encoding": "gzip, deflate"},
                method="POST")
            urllib.request.urlopen(req, timeout=10).read()
        except Exception as e:
            try:
                import logging as _lg; _lg.warning(f"push_send_error: {e}")
            except Exception: pass

    def _tokens_for(cid: str, user_type: str = None,
                    user_pk: int = None) -> list:
        with DB() as c:
            sql = "SELECT expo_token FROM push_tokens WHERE company_id=?"
            args = [cid]
            if user_type:
                sql += " AND user_type=?"; args.append(user_type)
            if user_pk:
                sql += " AND user_pk=?"; args.append(user_pk)
            return [r["expo_token"] for r in c.execute(sql, args).fetchall()]

    @app.post("/api/mobile/v1/push/register")
    def push_register(body: dict = Body(...),
                      authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        token = (body.get("expo_token") or "").strip()
        if not token: raise HTTPException(400, "missing_expo_token")
        ut  = s.get("user_type") or ""
        upk = s.get("user_pk") or s.get("user_id")
        with DB() as c:
            now = _now_ist_iso()
            c.execute(
                "INSERT INTO push_tokens(company_id, user_type, user_pk, "
                "  expo_token, device_id, platform, app_version, created_at, updated_at) "
                "VALUES (?,?,?,?,?,?,?,?,?) "
                "ON CONFLICT(expo_token) DO UPDATE SET "
                "  company_id=excluded.company_id, user_type=excluded.user_type, "
                "  user_pk=excluded.user_pk, device_id=excluded.device_id, "
                "  platform=excluded.platform, app_version=excluded.app_version, "
                "  updated_at=excluded.updated_at",
                (cid, ut, upk, token,
                 body.get("device_id"), body.get("platform"),
                 body.get("app_version"), now, now))
            c.commit()
        return {"ok": True}

    @app.post("/api/mobile/v1/push/unregister")
    def push_unregister(body: dict = Body(...),
                        authorization: Optional[str] = Header(None)):
        _require_auth(authorization)
        token = (body.get("expo_token") or "").strip()
        if not token: return {"ok": True}
        with DB() as c:
            c.execute("DELETE FROM push_tokens WHERE expo_token=?", (token,))
            c.commit()
        return {"ok": True}

    # ─── Due alert dispatcher (cron-callable) ────────────────────────────
    # _S39R5Q — Sends push to every customer whose end_date is within
    # `days_before` days. Designed to be hit daily from systemd timer.
    # Auth: requires X-Internal-Key matching env AUTOISPB_INTERNAL_KEY.
    @app.post("/api/mobile/v1/internal/dispatch-due-alerts")
    def dispatch_due_alerts(days_before: int = 3,
                            x_internal_key: Optional[str] = Header(None,
                                alias="X-Internal-Key")):
        import os as _os
        expected = _os.environ.get("AUTOISPB_INTERNAL_KEY", "autoispb-internal-key")
        if x_internal_key != expected:
            raise HTTPException(401, "internal_key_required")
        from datetime import date as _date, timedelta as _td
        target = (_date.today() + _td(days=days_before)).strftime("%Y-%m-%d")
        sent = 0; failed = 0
        with DB() as c:
            rows = c.execute(
                "SELECT c.id AS pk, c.company_id, c.customer_name, "
                "       c.total_bill_amount, c.received_amount, "
                "       c.discount_credit, c.end_date, "
                "       co.company_name "
                "  FROM customers c "
                "  LEFT JOIN companies co ON co.company_id=c.company_id "
                " WHERE substr(c.end_date,1,10)=? "
                "   AND COALESCE(c.status,'Active')='Active'", (target,)).fetchall()
            for r in rows:
                due = max(0, round(
                    float(r["total_bill_amount"] or 0) -
                    float(r["received_amount"] or 0) -
                    float(r["discount_credit"] or 0)))
                if due <= 0: continue
                tokens = _tokens_for(r["company_id"], "customer", r["pk"])
                if not tokens: continue
                try:
                    _push_send(
                        tokens,
                        f"Bill due in {days_before} days · ₹{due:.0f}",
                        f"Hi {r['customer_name']}, your AutoISP plan expires "
                        f"on {r['end_date'][:10]}. Pay ₹{due:.0f} to stay online.",
                        {"type": "due_alert", "customer_pk": r["pk"],
                         "amount": due})
                    sent += 1
                except Exception:
                    failed += 1
        return {"ok": True, "target_date": target, "sent": sent,
                "failed": failed}

    # ─── Role-scope helper (sub_lco / employee) ──────────────────────────
    # Returns (WHERE-fragment starting with " AND ...", params) intended to
    # be appended to a customer query that already has a base "WHERE
    # company_id=?" clause. Admin / superadmin pass through unscoped.
    def _scope_and(s: dict, cust_alias: str = "c") -> tuple:
        ut  = s.get("user_type") or ""
        pk  = s.get("user_pk") or s.get("user_id")
        cid = s.get("company_id") or ""
        if ut == "sub_lco":
            return (
                f" AND ({cust_alias}.sub_lco_id=?) ",
                [pk],
            )
        if ut == "employee":
            try:
                with DB() as cx:
                    allowed = [r[0] for r in cx.execute(
                        "SELECT location_id FROM employee_locality_assignments "
                        " WHERE employee_id=? AND company_id=?", (pk, cid)
                    ).fetchall()]
            except Exception:
                allowed = []
            if allowed:
                qm = ",".join("?" * len(allowed))
                return (f" AND ({cust_alias}.location_id IN ({qm})) ",
                        list(allowed))
            return (f" AND ({cust_alias}.sub_lco_id=-1) ", [])   # empty
        return ("", [])

    # ─── /me ─────────────────────────────────────────────────────────────
    @app.get("/api/mobile/v1/me")
    def me(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization)
        cid = s.get("company_id") or ""
        role = s.get("user_type") or ""
        uid  = s.get("user_pk") or s.get("user_id")
        full_name = ""; mobile = ""; email = ""; image_path = ""
        with DB() as c:
            if role == "admin":
                r = c.execute(
                    "SELECT admin_name, admin_id, admin_mobile AS mobile, "
                    "       admin_email AS email, profile_image_path AS img "
                    "  FROM admins WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["admin_name"] or r["admin_id"]
                    mobile = r["mobile"] or ""
                    email = r["email"] or ""
                    image_path = r["img"] or ""
            elif role == "sub_lco":
                r = c.execute(
                    "SELECT name, mobile, email, profile_image AS img "
                    "  FROM sub_lcos WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["name"]
                    mobile = r["mobile"] or ""
                    email = r["email"] or ""
                    image_path = r["img"] or ""
            elif role == "employee":
                r = c.execute(
                    "SELECT employee_name, mobile, email, profile_image_path AS img "
                    "  FROM employees WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["employee_name"]
                    mobile = r["mobile"] or ""
                    email = r["email"] or ""
                    image_path = r["img"] or ""
            elif role == "customer":
                r = c.execute(
                    "SELECT customer_name, customer_phone, customer_email, "
                    "       photograph_path AS img "
                    "  FROM customers WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["customer_name"]
                    mobile = r["customer_phone"] or ""
                    email = r["customer_email"] or ""
                    image_path = r["img"] or ""
        # Build absolute image URL
        img_url = None
        if image_path:
            p = image_path.strip()
            if p.startswith("http"):
                img_url = p
            else:
                if not p.startswith("/"):
                    p = "/" + p
                img_url = f"https://www.autoispbilling.com{p}"
        # _S40zπ_MOBILE_FIX_  Dashboard tiles: real counts excluding Deleted.
        # _S40zπ_MOBILE_FIX_  Schema-correct role scoping for /me counters
        scope_extra = ""
        sx_args = []
        if role == "sub_lco":
            # sub_lcos.id is what customers.sub_lco_id stores; uid here is the
            # sub_lco's PK id (string). No `parent_sub_lco_id` column exists.
            scope_extra = " AND sub_lco_id=?"
            sx_args = [uid]
        elif role == "employee":
            # Employees see customers in any locality they're assigned to OR
            # any customer they personally created.
            try:
                with DB() as _cx:
                    locs = [r[0] for r in _cx.execute(
                        "SELECT location_id FROM employee_locality_assignments "
                        " WHERE company_id=? AND employee_id=? AND COALESCE(active,1)=1",
                        (cid, uid)).fetchall()]
                if locs:
                    ph = ",".join("?" * len(locs))
                    scope_extra = f" AND (location_id IN ({ph}) OR created_by_employee_id=?)"
                    sx_args = list(locs) + [uid]
                else:
                    scope_extra = " AND created_by_employee_id=?"
                    sx_args = [uid]
            except Exception:
                scope_extra = " AND created_by_employee_id=?"
                sx_args = [uid]
        cnt = {"subscribers_total": 0, "subscribers_active": 0,
               "online_now": 0, "complaints_open": 0,
               "bill_dues_count": 0, "bill_dues_amount": 0.0,
               "notifications_unread": 0}
        try:
            with DB() as _cm:
                base = (" WHERE company_id=? AND COALESCE(status,'') NOT IN "
                        " ('Deleted','deleted','Terminated','terminated') ")
                cnt["subscribers_total"] = _cm.execute(
                    "SELECT COUNT(*) FROM customers" + base + scope_extra,
                    [cid] + sx_args).fetchone()[0]
                cnt["subscribers_active"] = _cm.execute(
                    "SELECT COUNT(*) FROM customers" + base
                    + " AND status='Active'" + scope_extra,
                    [cid] + sx_args).fetchone()[0]
                cnt["complaints_open"] = _cm.execute(
                    "SELECT COUNT(*) FROM complaints "
                    " WHERE company_id=? AND IFNULL(status,'')!='Resolved'",
                    (cid,)).fetchone()[0]
            cnt["online_now"] = len(_online_set_real(cid))
            with DB() as _cm:
                # Bill dues: count + sum via real ledger
                rows = _cm.execute(
                    "SELECT customer_id FROM customers " + base + scope_extra,
                    [cid] + sx_args).fetchall()
                tot = 0.0; n = 0
                for rr in rows:
                    bal = _balance_signed(_cm, cid, rr[0])
                    if bal > 0:
                        tot += bal; n += 1
                cnt["bill_dues_count"]  = n
                cnt["bill_dues_amount"] = round(tot, 2)
                # Notifications = open complaints + unack alerts
                try:
                    cnt["notifications_unread"] = (
                        cnt["complaints_open"]
                        + (_cm.execute("SELECT COUNT(*) FROM olt_alerts "
                            " WHERE company_id=? AND COALESCE(acked,0)=0",
                            (cid,)).fetchone()[0] or 0))
                except Exception:
                    cnt["notifications_unread"] = cnt["complaints_open"]
        except Exception:
            pass
        return {
            "ok": True,
            "user": {
                "id": uid, "role": role,
                "company_id": cid, "username": s.get("username"),
                "full_name": full_name, "mobile": mobile, "email": email,
                "profile_image_url": img_url,
            },
            "company": _company_meta(cid),
            "counters": cnt,
            **cnt,
        }

    def _normalize_subscriber(row, plan_lookup, online_set, last_pay_lookup,
                              cid: str = "") -> dict:
        # _S40zπ_MOBILE_FIX_  Real ledger:
        #   balance     = SUM(invoices) - SUM(payments + discounts)  [signed]
        #   current_due = latest invoice amount (this period's bill)
        #   prev_due    = balance - current_due  (carry-forward)
        d = dict(row)
        plan = plan_lookup.get(d.get("plan_id")) or {}
        d["plan_name"]   = plan.get("plan_name")
        d["plan_amount"] = float(plan.get("after_tax_amount") or d.get("monthly_amount") or 0)
        d["period_months"] = d.get("period")
        d["mobile"]      = d.get("customer_phone")
        d["is_online"]   = (d.get("username") or "") in online_set
        try:
            with DB() as _c:
                signed = _balance_signed(_c, cid, d.get("customer_id"))
                cur_inv = _latest_invoice_amount(_c, cid, d.get("customer_id"))
        except Exception:
            signed = 0.0; cur_inv = float(d.get("monthly_amount") or 0)
        due_pos = max(0.0, round(signed, 2))   # what the customer OWES; credits → 0
        d["due_amount"]   = due_pos
        d["balance"]      = due_pos
        d["balance_signed"] = round(signed, 2)
        d["current_charge"] = round(cur_inv if cur_inv else float(d.get("monthly_amount") or 0), 2)
        d["current_due"]  = round(min(due_pos, d["current_charge"]), 2) if due_pos > 0 else 0.0
        d["prev_due"]     = round(max(0.0, due_pos - d["current_charge"]), 2)
        lp = last_pay_lookup.get(d.get("customer_id")) or {}
        d["last_paid"]    = float(lp.get("amount") or 0)
        d["last_paid_at"] = _fmt_paid_at(lp.get("paid_at"))
        d["status"]       = d.get("status") or "Active"
        # _S39R5O — formatted period DD-MM-YYYY to DD-MM-YYYY
        try:
            sd = (d.get("start_date") or "").strip()
            ed = (d.get("end_date") or "").strip()
            def _fmtd(x):
                if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
                    return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                if x and len(x) >= 10 and x[2] == "-" and x[5] == "-":
                    return x[:10]
                return x or ""
            if sd and ed:
                d["formatted_period"] = f"{_fmtd(sd)} to {_fmtd(ed)}"
            elif ed:
                d["formatted_period"] = _fmtd(ed)
            else:
                d["formatted_period"] = ""
        except Exception:
            d["formatted_period"] = ""
        return d

    _CUST_COLS = (
        "id, customer_id, username, customer_name, customer_email, "
        "customer_phone, alt_mobile, address, locality, city, state, pincode, "
        "plan_id, monthly_amount, customer_type, status, period, "
        "start_date, end_date, total_bill_amount, received_amount, "
        "mac_address, ip_address, vendor, modem_no, sub_lco_id, location_id, "
        "auth_type, customer_gst_no, gst_invoice_needed, "
        "auto_renew, security_deposit, installation_charges, router_charges, "
        "discount_credit, payment_mode, transaction_id, "
        "service_type, registration_type"
    )

    @app.get("/api/mobile/v1/subscriber-detail/{cust_pk}")
    def subscriber_canonical(cust_pk: int,
                             authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        # _S39R5P — enforce role scope: sub_lco/employee can only open
        # customers in their scope.
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        with DB() as c:
            row = c.execute(
                f"SELECT {_CUST_COLS} FROM customers c "
                f" WHERE c.id=? AND c.company_id=? {scope_sql}",
                [cust_pk, cid] + scope_args).fetchone()
            if not row: raise HTTPException(404, "not_found")
            plans = {p["id"]: dict(p) for p in c.execute(
                "SELECT id, plan_name, after_tax_amount FROM plans").fetchall()}
            lp_row = c.execute(
                "SELECT amount, paid_at FROM payments "
                " WHERE company_id=? AND customer_id=? "
                " ORDER BY paid_at DESC LIMIT 1",
                (cid, row["customer_id"])).fetchone()
            lp_lookup = {row["customer_id"]: dict(lp_row) if lp_row else {}}
        return _normalize_subscriber(row, plans, _online_set_real(cid), lp_lookup, cid)

    # Subscribers list with normalized fields (use plural-only path to avoid collision)
    @app.get("/api/mobile/v1/subscribers-list")
    def subs_norm(q: str = "", customer_type: str = "", locality: str = "",
                  only_unpaid: bool = False,
                  authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        sql = f"SELECT {_CUST_COLS} FROM customers c WHERE c.company_id=? AND COALESCE(c.status,'') NOT IN ('Deleted','deleted')"; args = [cid]
        # _S39R5P — role scope: sub_lco / employee see only their own
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        sql += scope_sql; args += scope_args
        if q:
            sql += " AND (c.customer_name LIKE ? OR c.customer_id LIKE ? OR c.username LIKE ? OR c.customer_phone LIKE ?)"
            args += [f"%{q}%"]*4
        utf, utp = _user_type_filter(customer_type)
        if utf:
            sql += utf; args += utp
        if locality:
            sql += " AND c.locality=?"; args.append(locality)
        sql += " ORDER BY c.customer_name COLLATE NOCASE LIMIT 500"
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
            plans = {p["id"]: dict(p) for p in c.execute(
                "SELECT id, plan_name, after_tax_amount FROM plans").fetchall()}
            lps = {r["customer_id"]: {"amount": r["amount"], "paid_at": r["paid_at"]}
                   for r in c.execute(
                       "SELECT customer_id, MAX(paid_at) AS paid_at, amount FROM payments "
                       " WHERE company_id=? GROUP BY customer_id", (cid,)).fetchall()}
        online = _online_set_real(cid)
        items = [_normalize_subscriber(r, plans, online, lps, cid) for r in rows]
        if only_unpaid: items = [x for x in items if x.get("due_amount", 0) > 0]
        return {"ok": True, "items": items}

    # ─── pay ─────────────────────────────────────────────────────────────
    @app.post("/api/mobile/v1/pay")
    def pay(body: dict = Body(...),
            authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        cust_pk = int(body.get("customer_pk") or 0)
        amount  = float(body.get("amount") or 0)
        discount= float(body.get("discount") or 0)
        mode    = body.get("payment_mode") or "Cash"
        remarks = body.get("remarks") or body.get("note") or ""
        txn_no  = body.get("txn_no") or f"{mode[:3].upper()}-{int(time.time()*1000)}"
        if cust_pk <= 0 or amount <= 0:
            raise HTTPException(400, "missing_amount_or_customer")
        # Resolve collector full name from session role
        with DB() as c:
            cust = c.execute(
                "SELECT * FROM customers WHERE id=? AND company_id=?",
                (cust_pk, cid)).fetchone()
            if not cust: raise HTTPException(404, "customer_not_found")
            # collector full name
            role = s.get("user_type") or ""
            collector_full = s.get("username") or ""
            collector_code = collector_full
            if role == "admin":
                r = c.execute("SELECT admin_name, admin_id FROM admins "
                              " WHERE id=? AND company_id=?",
                              (s.get("user_pk") or s.get("user_id"), cid)).fetchone()
                if r: collector_full = r["admin_name"] or r["admin_id"]; collector_code = r["admin_id"]
            elif role == "sub_lco":
                r = c.execute("SELECT name, sub_lco_code FROM sub_lcos "
                              " WHERE id=? AND company_id=?",
                              (s.get("user_pk") or s.get("user_id"), cid)).fetchone()
                if r: collector_full = r["name"]; collector_code = r["sub_lco_code"]
            elif role == "employee":
                r = c.execute("SELECT employee_name, employee_code FROM employees "
                              " WHERE id=? AND company_id=?",
                              (s.get("user_pk") or s.get("user_id"), cid)).fetchone()
                if r: collector_full = r["employee_name"]; collector_code = r["employee_code"]
            now_iso = _now_ist_iso()
            # _S39R5O — Discount-as-credit semantics:
            #   Cash collected (payments.amount) = amount user entered (no
            #     reduction by discount). discount stored on the row.
            #   customers.received_amount   += amount   (what cash entered)
            #   customers.discount_credit   += discount (grace credit)
            #   So total balance reduction  = amount + discount.
            cash_paid = round(amount, 2)
            disc      = round(discount, 2)
            credit    = round(cash_paid + disc, 2)
            c.execute("""
                INSERT INTO payments(company_id, customer_id, employee_id, amount,
                       discount, payment_mode, transaction_no, paid_at, remarks,
                       created_at, updated_at)
                VALUES (?,?,?,?,?,?,?,?,?,?,?)
            """, (cid, cust["customer_id"], collector_code, cash_paid, disc, mode,
                  txn_no, now_iso, remarks, now_iso, now_iso))
            # Update customer received_amount + discount_credit
            c.execute("UPDATE customers "
                      "   SET received_amount = COALESCE(received_amount,0) + ?, "
                      "       discount_credit = COALESCE(discount_credit,0) + ? "
                      " WHERE id=? AND company_id=?",
                      (cash_paid, disc, cust_pk, cid))
            c.commit()
            # _S40zM_ Auto-email receipt (best-effort; HTTP to admin helper).
            try:
                _pay_id_r = c.execute(
                    "SELECT id FROM payments WHERE transaction_no=?",
                    (txn_no,)).fetchone()
                if _pay_id_r:
                    import httpx as _httpx_R3
                    _httpx_R3.post(
                        f"http://127.0.0.1:8001/api/internal/payments/{_pay_id_r['id']}/send-receipt-email",
                        params={"company_id": cid}, timeout=8,
                    )
            except Exception as _eR3:
                print(f"[mobile-v3 receipt-email auto] txn={txn_no}: {_eR3}")

            company = _company_meta(cid)
            # Compute fresh balance after this txn
            row2 = c.execute("SELECT total_bill_amount, received_amount, "
                             " discount_credit, plan_id, "
                             " customer_name, customer_id, customer_phone, address, "
                             " locality, period, start_date, end_date "
                             " FROM customers WHERE id=?", (cust_pk,)).fetchone()
            # _S40zπ_MOBILE_FIX_  Use real invoice/payment ledger
            _signed_after = _balance_signed(c, cid, cust["customer_id"])
            balance_after = max(0, round(_signed_after, 2))
            previous_due  = round(_signed_after + cash_paid + disc, 2)
            # If the customer has overpayment, surface it as a credit (negative
            # balance_after_signed) so the receipt template can show "Credit ₹X".
            balance_after_signed = round(_signed_after, 2)
            plan = c.execute("SELECT plan_name FROM plans WHERE id=?",
                             (row2["plan_id"],)).fetchone()
            # Previous payment to this one
            prev = c.execute("SELECT amount, paid_at FROM payments "
                             " WHERE company_id=? AND customer_id=? AND transaction_no!=? "
                             " ORDER BY paid_at DESC LIMIT 1",
                             (cid, cust["customer_id"], txn_no)).fetchone()

        # _S39R5O — Format dates and period for receipt display
        def _to_ddmm(x):
            if not x:
                return ""
            x = str(x).strip()
            if len(x) >= 10 and x[4] == "-" and x[7] == "-":
                return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
            if len(x) >= 10 and x[2] == "-" and x[5] == "-":
                return x[:10]
            return x
        # Receipt-friendly DD-MM-YYYY HH:MM (UTC iso → IST shift +5:30)
        try:
            from datetime import datetime as _dt, timedelta as _td
            paid_at_fmt = _fmt_paid_at(now_iso)
        except Exception:
            paid_at_fmt = now_iso
        sd, ed = row2["start_date"], row2["end_date"]
        if sd and ed:
            period_str = f"{_to_ddmm(sd)} to {_to_ddmm(ed)}"
        elif row2["period"]:
            period_str = f"{row2['period']} mo"
        else:
            period_str = ""
        # Last paid datetime → IST DD-MM-YYYY HH:MM
        last_paid_at_fmt = ""
        if prev and prev["paid_at"]:
            try:
                from datetime import datetime as _dt, timedelta as _td
                last_paid_at_fmt = _fmt_paid_at(prev["paid_at"])
            except Exception:
                last_paid_at_fmt = prev["paid_at"]

        # _S39R5Q — Push notify customer (and the collector who recorded it).
        try:
            cust_tokens = _tokens_for(cid, "customer", cust_pk)
            staff_tokens = _tokens_for(
                cid, role, s.get("user_pk") or s.get("user_id"))
            company = _company_meta(cid)
            cname = company.get("company_name") or "AutoISP Billing"
            push_data = {"type": "payment", "txn_no": txn_no,
                         "customer_pk": cust_pk}
            if cust_tokens:
                _push_send(
                    cust_tokens,
                    f"Payment received · ₹{cash_paid:.0f}",
                    f"Receipt {txn_no} · Bal ₹{balance_after:.0f}. — {cname}",
                    push_data)
            if staff_tokens:
                _push_send(
                    staff_tokens,
                    f"Receipt logged · ₹{cash_paid:.0f}",
                    f"{row2['customer_name']} · Bal ₹{balance_after:.0f}",
                    push_data)
        except Exception:
            pass

        return {
            "ok": True,
            "receipt": {
                "company_name":    company.get("company_name") or "AutoISP Billing",
                "company_phone":   company.get("company_phone"),
                "company_address": company.get("company_address"),
                "receipt_no":      txn_no,
                "txn_no":          txn_no,
                "paid_at":         paid_at_fmt,
                "customer_id":     row2["customer_id"],
                "customer_name":   row2["customer_name"],
                "mobile":          row2["customer_phone"],
                "address":         row2["address"],
                "locality":        row2["locality"],
                "plan_name":       plan["plan_name"] if plan else "",
                "period":          period_str,
                "amount":          cash_paid,
                "discount":        disc,
                "net_paid":        cash_paid,
                "total_credit":    credit,
                "payment_mode":    mode,
                "remarks":         remarks,
                "collected_by":    collector_full,
                "collector_code":  collector_code,
                "previous_due":    previous_due,
                "balance_after":   balance_after,
                "last_paid":       float(prev["amount"]) if prev else 0,
                "last_paid_at":    last_paid_at_fmt,
            },
        }

    # ─── localities, locations, employees, plans ─────────────────────────
    @app.get("/api/mobile/v1/localities")
    def localities2(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            rows = c.execute(
                "SELECT DISTINCT TRIM(locality) AS x FROM customers "
                " WHERE company_id=? AND locality IS NOT NULL AND TRIM(locality)!='' "
                " ORDER BY x COLLATE NOCASE", (cid,)).fetchall()
        return {"ok": True, "items": [r["x"] for r in rows]}

    @app.get("/api/mobile/v1/locations")
    def locations(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            rows = c.execute(
                "SELECT id, name, city, state, pincode FROM locations "
                " WHERE company_id=? ORDER BY name", (cid,)).fetchall()
        return {"ok": True, "items": [dict(r) for r in rows]}

    @app.get("/api/mobile/v1/employees-list")
    def employees_list(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            emps = c.execute(
                "SELECT id, employee_code AS code, employee_name AS name, mobile "
                "  FROM employees WHERE company_id=?", (cid,)).fetchall()
            slcs = c.execute(
                "SELECT id, sub_lco_code AS code, name, mobile FROM sub_lcos "
