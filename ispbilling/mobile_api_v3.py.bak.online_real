    @app.get("/api/mobile/v1/onus/{onu_id}/remote-config")
    def onu_remote2(onu_id: int,
                    authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='onus'").fetchone()
            if not t:
                return {"optical_power": None, "link_status": "Unknown"}
            r = c.execute(
                "SELECT rx_power, tx_power, status, wan_ip, wan_status, "
                "wifi_ssid, wifi_password, serial, mac, wan_mode, "
                "wan_username, wan_password, wan_static_ip, wan_netmask, "
                "wan_gateway, wan_dns, wan_vlan FROM onus "
                "WHERE id=? AND company_id=?", (onu_id, cid)).fetchone()
        if not r:
            raise HTTPException(404, "ONU not found")
        return {
            "optical_power": r["rx_power"],
            "tx_power": r["tx_power"],
            "link_status": r["status"] or "Unknown",
            "wan_ip": r["wan_ip"], "wan_status": r["wan_status"],
            "ztp_enabled": False, "ztp": {},
            "wifi": {"ssid": r["wifi_ssid"] or "",
                     "password": r["wifi_password"] or ""},
            "wan": {
                "mode": r["wan_mode"] or "",
                "username": r["wan_username"] or "",
                "password": r["wan_password"] or "",
                "static_ip": r["wan_static_ip"] or "",
                "netmask": r["wan_netmask"] or "",
                "gateway": r["wan_gateway"] or "",
                "dns": r["wan_dns"] or "",
                "vlan": r["wan_vlan"],
            },
            "serial": r["serial"], "mac": r["mac"],
        }

    for _path in ("ztp/deploy", "activate", "wifi", "reboot", "factory-reset"):
        def _make(p):
            @app.post(f"/api/mobile/v1/onus/{{onu_id}}/{p}")
            def _h(onu_id: int, body: dict = Body(default={}),
                   authorization: Optional[str] = Header(None)):
                s = _require_auth(authorization)
                cid = s.get("company_id") or ""
                actor = s.get("user_name") or s.get("user_id") or "mobile"
                with DB() as c:
                    t = c.execute("SELECT name FROM sqlite_master WHERE "
                                  "type='table' AND name='onus'").fetchone()
                    if t:
                        row = c.execute(
                            "SELECT olt_id FROM onus WHERE id=? AND "
                            "company_id=?", (onu_id, cid)).fetchone()
                        olt_id = row["olt_id"] if row else None
                        # WiFi update writes to DB immediately so the UI
                        # reflects the change.
                        if p == "wifi" and row:
                            c.execute(
                                "UPDATE onus SET wifi_ssid=COALESCE(?,wifi_ssid), "
                                "wifi_password=COALESCE(?,wifi_password) "
                                "WHERE id=? AND company_id=?",
                                (body.get("ssid") if body else None,
                                 body.get("password") if body else None,
                                 onu_id, cid))
                        c.execute(
                            "INSERT INTO olt_alerts (company_id, olt_id, "
                            "onu_id, kind, level, title, message, meta_json) "
                            "VALUES (?,?,?,?,?,?,?,?)",
                            (cid, olt_id, onu_id, "info", "info",
                             f"ONU {p} requested by {actor} (mobile)",
                             "Vendor adapter will dispatch shortly.",
                             "{}"))
                        c.commit()
                return {"ok": True, "queued": p, "onu_id": onu_id}
            return _h
        _make(_path)

    @app.get("/api/mobile/v1/olt/settings")
    def olt_settings_get(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='olt_settings'").fetchone()
            if not t:
                return {"ok": True, "settings": {}}
            r = c.execute(
                "SELECT * FROM olt_settings WHERE company_id=?",
                (cid,)).fetchone()
        return {"ok": True, "settings": dict(r) if r else {}}

    # ─── Notifications ───────────────────────────────────────────────────
    @app.get("/api/mobile/v1/notifications/badge")
    def notif_badge2(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization)
        cid = s.get("company_id") or ""
        # _S40zπ_MOBILE_FIX_  Count: open complaints + unack OLT alerts +
        # bill-due customers — surfaced as the bell-icon badge.
        unread = 0
        with DB() as c:
            try:
                unread += c.execute(
                    "SELECT COUNT(*) FROM complaints "
                    " WHERE company_id=? AND IFNULL(status,'')!='Resolved'",
                    (cid,)).fetchone()[0] or 0
            except Exception: pass
            try:
                unread += c.execute(
                    "SELECT COUNT(*) FROM olt_alerts "
                    " WHERE company_id=? AND COALESCE(acked,0)=0",
                    (cid,)).fetchone()[0] or 0
            except Exception: pass
        return {"ok": True, "unread": int(unread)}

    # ─── Add Customer (full parity) ──────────────────────────────────────
    @app.post("/api/mobile/v1/customers")
    def add_customer_full(body: dict = Body(...),
                          authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        cust_id = body.get("customer_id") or f"C{int(time.time())}"
        # _S39R5P — hash plain password into password_hash if provided.
        if body.get("password") and not body.get("password_hash"):
            try:
                import bcrypt as _bc
                body["password_hash"] = _bc.hashpw(
                    str(body["password"]).encode(),
                    _bc.gensalt(rounds=10)).decode()
            except Exception:
                # Fallback to plaintext if bcrypt missing
                body["password_hash"] = str(body["password"])
        with DB() as c:
            now = _now_ist_iso()
            cols = [
                "company_id", "customer_id", "customer_name", "nickname",
                "customer_email",
                "customer_phone", "alt_mobile", "address", "locality", "city",
                "state", "pincode", "billing_address", "billing_locality",
                "billing_city", "billing_state", "billing_pincode",
                "latitude", "longitude",
                "plan_id", "monthly_amount", "auto_renew", "customer_type",
                "service_type", "registration_type", "auth_type",
                "username", "password_hash", "pppoe_password",
                "mac_address", "ip_address", "vendor", "modem_no",
                "static_ip_address", "static_netmask",
                "zone", "node", "distance_from_node",
                "installation_date", "start_date", "end_date", "period",
                "bill_amount", "total_bill_amount", "received_amount",
                "security_deposit", "installation_charges", "router_charges",
                "discount_credit", "status", "payment_mode", "transaction_id",
                "payment_notes", "id_proof", "id_proof_no",
                "caf_no", "gst_invoice_needed", "customer_gst_no",
                "cgst_tax", "sgst_tax", "igst_tax",
                "sub_lco_id", "location_id",
                "photograph_path", "id_proof_doc_path", "address_proof_path",
                "created_by_employee_id",
                "created_at", "updated_at",
            ]
            # _S39R5P — for employees, stamp created_by_employee_id so scope
            # works; for sub_lco, default sub_lco_id if not provided.
            if (s.get("user_type") == "employee"
                    and not body.get("created_by_employee_id")):
                body["created_by_employee_id"] = s.get("user_pk") or s.get("user_id")
            if (s.get("user_type") == "sub_lco"
                    and not body.get("sub_lco_id")):
                body["sub_lco_id"] = s.get("user_pk") or s.get("user_id")
            vals = [cid, cust_id]
            for col in cols[2:]:
                v = body.get(col)
                if col in ("created_at", "updated_at"): v = now
                vals.append(v)
            placeholders = ",".join(["?"] * len(cols))
            try:
                c.execute(f"INSERT INTO customers ({','.join(cols)}) "
                          f"VALUES ({placeholders})", vals)
                c.commit()
            except Exception as e:
                raise HTTPException(400, f"insert_failed: {e}")
        return {"ok": True, "customer_id": cust_id}

    # ─── UPI deep-link + QR ──────────────────────────────────────────────
    # Builds a standard UPI URI for a given customer's outstanding due
    # (or arbitrary amount). Client renders QR with react-native-svg.
    @app.get("/api/mobile/v1/pay/upi-link")
    def pay_upi_link(cust_pk: int = 0, amount: float = 0,
                     authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            comp = c.execute(
                "SELECT company_name, upi_id FROM companies WHERE company_id=?",
                (cid,)).fetchone()
            if not comp or not comp["upi_id"]:
                raise HTTPException(400, "company_upi_not_set")
            upi_id = comp["upi_id"]; payee = comp["company_name"] or "AutoISP"
            name = "Bill Payment"; cust_ref = ""
            if cust_pk:
                cr = c.execute(
                    "SELECT customer_id, customer_name, total_bill_amount, "
                    "       received_amount, discount_credit "
                    "  FROM customers WHERE id=? AND company_id=?",
                    (cust_pk, cid)).fetchone()
                if cr:
                    name = f"Bill for {cr['customer_name']}"
                    cust_ref = cr["customer_id"]
                    if not amount:
                        amount = max(0, _balance_signed(c, cid, cr["customer_id"]))
        if amount <= 0:
            raise HTTPException(400, "invalid_amount")
        from urllib.parse import quote_plus
        tr = f"AISPB{int(time.time())}"
        url = (f"upi://pay?pa={quote_plus(upi_id)}"
               f"&pn={quote_plus(payee)}"
               f"&am={amount:.2f}&cu=INR"
               f"&tn={quote_plus(name)[:80]}"
               f"&tr={tr}")
        return {"ok": True, "upi_url": url, "upi_id": upi_id,
                "payee": payee, "amount": amount, "txn_ref": tr,
                "customer_ref": cust_ref}


    @app.post("/api/mobile/v1/receipts/{txn_id}/email")
    def receipt_email_resend(txn_id: str, body: dict = Body(default=None),
                             authorization: Optional[str] = Header(None)):
        """_S40zπ_MOBILE_FIX_  Re-send the official PDF receipt via configured
        company SMTP (NOT the device's mail app).  Mobile clients should call
        this from the receipt screen's 'Email' button."""
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            row = c.execute(
                "SELECT id FROM payments WHERE company_id=? AND "
                " (transaction_no=? OR id=?) LIMIT 1",
                (cid, txn_id, txn_id)).fetchone()
        if not row:
            raise HTTPException(404, "payment_not_found")
        try:
            import requests as _rq
            r = _rq.post(
                f"http://127.0.0.1:8001/api/internal/payments/{row['id']}/send-receipt-email"
                f"?company_id={cid}", timeout=15)
            res = r.json() if r.headers.get("content-type","").startswith("application/json") else {"raw": r.text}
            return {"ok": bool(res.get("success", res.get("ok", r.ok))),
                    "via": "smtp",
                    "details": res}
        except Exception as e:
            raise HTTPException(500, f"smtp_failed: {e}")

    @app.get("/api/mobile/v1/receipts/{txn_id}/pdf")
    def receipt_pdf_proxy(txn_id: str, authorization: Optional[str] = Header(None)):
        """_S40zπ_MOBILE_FIX_  Stream the official receipt PDF (same as web admin)."""
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            row = c.execute(
                "SELECT id FROM payments WHERE company_id=? AND "
                " (transaction_no=? OR id=?) LIMIT 1",
                (cid, txn_id, txn_id)).fetchone()
        if not row:
            raise HTTPException(404, "payment_not_found")
        try:
            import requests as _rq
            r = _rq.get(
                f"http://127.0.0.1:8001/api/internal/payments/{row['id']}/receipt-pdf"
                f"?company_id={cid}", timeout=15)
            from fastapi.responses import Response as _Resp
            return _Resp(content=r.content,
                         media_type=r.headers.get("content-type", "application/pdf"),
                         headers={"content-disposition": f'attachment; filename="receipt_{txn_id}.pdf"'})
        except Exception as e:
            raise HTTPException(500, f"pdf_proxy_failed: {e}")

    # ─── GenieACS bridge (TR-069) ────────────────────────────────────────
    # Thin proxy over the GenieACS NBI (configured per company via
    # olt_settings.genieacs_url). Supports list / reboot / reset / SSID /
    # password. Auth'd at the mobile level — company-scoped.
    def _genieacs_base(cid: str) -> Optional[str]:
        with DB() as c:
            t = c.execute("SELECT name FROM sqlite_master WHERE type='table' "
                          " AND name='olt_settings'").fetchone()
            if not t: return None
            r = c.execute(
                "SELECT genieacs_url FROM olt_settings WHERE company_id=?",
                (cid,)).fetchone()
        if not r or not r["genieacs_url"]: return None
        return r["genieacs_url"].rstrip("/")

    def _genieacs_call(base: str, path: str, method: str = "GET",
                       payload: dict = None, params: dict = None):
        import urllib.request, urllib.parse, json as _json
        url = base + path
        if params:
            url += "?" + urllib.parse.urlencode(params)
        body = None
        if payload is not None:
            body = _json.dumps(payload).encode()
        req = urllib.request.Request(url, data=body, method=method,
                                     headers={"Content-Type": "application/json"})
        try:
            with urllib.request.urlopen(req, timeout=10) as resp:
                txt = resp.read().decode() or "null"
                try: return _json.loads(txt)
                except Exception: return {"raw": txt}
        except Exception as e:
            raise HTTPException(502, f"genieacs_error: {e}")

    # Alias: /api/mobile/v1/tr069/devices  (preferred name — same handler)
    @app.get("/api/mobile/v1/genieacs/devices")
    @app.get("/api/mobile/v1/tr069/devices")
    def genieacs_devices(q: str = "", limit: int = 50,
                         authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        base = _genieacs_base(cid)
        if not base: return {"ok": False, "error": "genieacs_not_configured",
                             "items": []}
        # NBI query: use regex search across _deviceId._OUI + _SerialNumber + _ProductClass
        qobj = {}
        if q:
            qobj = {"$or": [
                {"_deviceId._SerialNumber": {"$regex": q, "$options": "i"}},
                {"_deviceId._ProductClass": {"$regex": q, "$options": "i"}},
            ]}
        import json as _json
        from urllib.parse import quote
        qs = {"query": _json.dumps(qobj), "limit": limit,
              "projection": ("_id,_deviceId,_lastInform,"
                             "InternetGatewayDevice.DeviceInfo.SoftwareVersion,"
                             "InternetGatewayDevice.LANDevice.1.WLANConfiguration.1.SSID,"
                             "InternetGatewayDevice.WANDevice.1.WANConnectionDevice.1.WANPPPConnection.1.ExternalIPAddress")}
        data = _genieacs_call(base, "/devices", "GET", params=qs) or []
        items = []
        for d in data if isinstance(data, list) else []:
            dev = d.get("_deviceId", {}) or {}
            igd = d.get("InternetGatewayDevice", {}) or {}
            ssid = None
            try:
                ssid = (igd.get("LANDevice", {}).get("1", {})
                        .get("WLANConfiguration", {}).get("1", {})
                        .get("SSID", {}).get("_value"))
            except Exception: ssid = None
            try:
                wan_ip = (igd.get("WANDevice", {}).get("1", {})
                          .get("WANConnectionDevice", {}).get("1", {})
                          .get("WANPPPConnection", {}).get("1", {})
                          .get("ExternalIPAddress", {}).get("_value"))
            except Exception: wan_ip = None
            try:
                sw = igd.get("DeviceInfo", {}).get("SoftwareVersion", {}).get("_value")
            except Exception: sw = None
            items.append({
                "id": d.get("_id"),
                "serial": dev.get("_SerialNumber"),
                "oui": dev.get("_OUI"),
                "product_class": dev.get("_ProductClass"),
                "last_inform": d.get("_lastInform"),
                "software_version": sw,
                "wifi_ssid": ssid,
                "wan_ip": wan_ip,
            })
        return {"ok": True, "items": items}

    @app.post("/api/mobile/v1/genieacs/device/{device_id}/task")
    def genieacs_task(device_id: str, body: dict = Body(...),
                      authorization: Optional[str] = Header(None)):
        """kind ∈ {reboot, factoryReset, refreshObject, setParameterValues,
        addObject}. For setParameterValues pass `parameterValues: [[name, value, type]]`."""
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        base = _genieacs_base(cid)
        if not base: raise HTTPException(400, "genieacs_not_configured")
        kind = body.get("kind") or ""
        payload = {"name": kind}
        if kind == "refreshObject":
            payload["objectName"] = body.get("objectName", "")
        elif kind == "setParameterValues":
            payload["parameterValues"] = body.get("parameterValues") or []
        elif kind == "addObject":
            payload["objectName"] = body.get("objectName", "")
        from urllib.parse import quote
        path = f"/devices/{quote(device_id, safe='')}/tasks"
        r = _genieacs_call(base, path, "POST", payload=payload,
                           params={"connection_request": 1})
        return {"ok": True, "task": r}

    @app.post("/api/mobile/v1/genieacs/device/{device_id}/wifi")
    def genieacs_wifi(device_id: str, body: dict = Body(...),
                      authorization: Optional[str] = Header(None)):
        """Convenience: change WLAN 1 SSID + pre-shared key."""
        _require_auth(authorization)
        ssid = body.get("ssid"); pw = body.get("password")
        if not ssid and not pw: raise HTTPException(400, "ssid_or_password_required")
        pvs = []
        if ssid:
            pvs.append(["InternetGatewayDevice.LANDevice.1.WLANConfiguration.1.SSID",
                        ssid, "xsd:string"])
        if pw:
            pvs.extend([
                ["InternetGatewayDevice.LANDevice.1.WLANConfiguration.1.PreSharedKey.1.PreSharedKey",
                 pw, "xsd:string"],
                ["InternetGatewayDevice.LANDevice.1.WLANConfiguration.1.KeyPassphrase",
                 pw, "xsd:string"],
            ])
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        base = _genieacs_base(cid)
        if not base: raise HTTPException(400, "genieacs_not_configured")
        from urllib.parse import quote
        r = _genieacs_call(base, f"/devices/{quote(device_id, safe='')}/tasks",
                           "POST",
                           payload={"name": "setParameterValues",
                                    "parameterValues": pvs},
                           params={"connection_request": 1})
        return {"ok": True, "task": r}
