        .info-item p{font-size:.9rem;color:var(--ink-500)}
        .info-item a{color:var(--ink-900);font-weight:500}
        .info-item a:hover{color:var(--brand-500)}

        .callout{background:linear-gradient(135deg,rgba(61,90,254,.07),rgba(0,212,180,.07));border:1px solid rgba(61,90,254,.15);border-left:3px solid var(--brand-500);border-radius:12px;padding:16px 18px;margin-top:18px}
        .callout h4{font-family:'Inter',sans-serif;font-size:.95rem;margin-bottom:8px;display:inline-flex;align-items:center;gap:8px}
        .callout ul{margin:0;padding-left:18px;font-size:.88rem;color:var(--ink-700)}
        .callout ul li{margin-bottom:4px}

        .quick-links{list-style:none;padding:0;margin:0;display:grid;gap:8px}
        .quick-links a{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border-radius:10px;border:1px solid var(--line);color:var(--ink-900);font-weight:500;font-size:.92rem;transition:all .15s ease}
        .quick-links a:hover{border-color:var(--brand-500);color:var(--brand-500);transform:translateX(2px)}
        .quick-links a i{color:var(--ink-300)}
        .quick-links a:hover i{color:var(--brand-500)}

        /* Form */
        label{font-size:.85rem;font-weight:600;color:var(--ink-700);margin-bottom:6px;display:block}
        .req{color:#e11d48}
        .form-control,.form-select,textarea.form-control{border:1.5px solid var(--line);border-radius:12px;padding:12px 14px;font-size:.95rem;background:#fff}
        .form-control:focus,.form-select:focus,textarea.form-control:focus{border-color:var(--brand-500);box-shadow:0 0 0 4px rgba(61,90,254,.15)}
        .form-group{margin-bottom:14px}
        .btn-block{width:100%;padding:14px 20px;font-size:1rem}
        .alert{margin-top:14px;padding:12px 14px;border-radius:10px;font-size:.9rem;display:none}
        .alert.show{display:block}
        .alert-ok{background:#e7fbf4;color:#066a4e;border:1px solid #bdf0dc}
        .alert-err{background:#fff1f2;color:#b42330;border:1px solid #fecdd3}

        /* Support tiles */
        .tiles{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:36px}
        @media (max-width:900px){.tiles{grid-template-columns:1fr}}
        .tile{background:#fff;border:1px solid var(--line);border-radius:var(--radius-lg);padding:26px;text-align:center;box-shadow:var(--shadow-sm);transition:transform .2s ease,box-shadow .2s ease}
        .tile:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
        .tile .tile-ico{width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;display:grid;place-items:center;font-size:1.5rem;margin:0 auto 14px}
        .tile h4{font-size:1.05rem;margin-bottom:6px}
        .tile p{font-size:.9rem;color:var(--ink-500);margin-bottom:14px}

        /* FOOTER */
        footer{background:#0b1224;color:#cbd3e9;padding:56px 0 20px;margin-top:40px}
        .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:28px}
