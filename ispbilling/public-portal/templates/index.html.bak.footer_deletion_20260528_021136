        p{margin:0;color:var(--ink-700);line-height:1.65}
        a{text-decoration:none;color:inherit}
        img{max-width:100%;display:block}
        .container-xxl{max-width:1240px;margin:0 auto;padding:0 20px}
        .btn{border-radius:999px;padding:.85rem 1.6rem;font-weight:600;letter-spacing:.01em;border:0;transition:transform .15s ease,box-shadow .2s ease,background .2s ease,color .2s ease;display:inline-flex;align-items:center;gap:.5rem}
        .btn-primary-g{background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;box-shadow:0 12px 28px rgba(61,90,254,.35)}
        .btn-primary-g:hover{transform:translateY(-2px);box-shadow:0 18px 40px rgba(61,90,254,.45);color:#fff}
        .btn-ghost{background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.25);backdrop-filter:blur(6px)}
        .btn-ghost:hover{background:rgba(255,255,255,.18);color:#fff}

        /* NAV */
        .site-nav{position:fixed;top:0;left:0;right:0;z-index:50;padding:10px 0;background:#fff;border-bottom:1px solid rgba(11,18,36,.06);box-shadow:0 4px 18px rgba(11,18,36,.06);transition:box-shadow .25s ease}
        .site-nav.solid{background:#fff;box-shadow:0 6px 22px rgba(11,18,36,.10)}
        .nav-wrap{display:flex;align-items:center;justify-content:space-between;gap:24px;position:relative}
        .brand{display:flex;align-items:center;gap:10px;color:var(--ink-900);font-weight:700;font-size:1.15rem;text-decoration:none}
        .brand-img{height:42px;width:auto;max-width:230px;object-fit:contain;display:block}
        .brand-img-footer{height:46px;width:auto;max-width:240px;object-fit:contain;display:block;filter:brightness(0) invert(1) opacity(.92)}
        .site-nav.solid .brand{color:var(--ink-900)}
        .brand-logo{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--brand-500),#7c3aff);display:grid;place-items:center;color:#fff;box-shadow:var(--shadow-md)}
        .nav-links{display:flex;align-items:center;gap:28px;list-style:none;padding:0;margin:0}
        .nav-links a{color:var(--ink-700);font-weight:500;font-size:.95rem;text-decoration:none}
        .site-nav.solid .nav-links a{color:var(--ink-700)}
        .nav-links a:hover{color:var(--brand-500)}
        .site-nav.solid .nav-links a:hover{color:var(--brand-500)}
        .nav-cta{display:flex;gap:10px;align-items:center}
        .nav-login{color:var(--ink-900);font-weight:600;padding:.5rem 1rem;border-radius:999px;border:1px solid rgba(11,18,36,.18);text-decoration:none}
        .site-nav.solid .nav-login{color:var(--ink-900);border-color:rgba(11,18,36,.18)}
        .nav-login:hover{background:rgba(11,18,36,.06)}
        .site-nav.solid .nav-login:hover{background:rgba(11,18,36,.06)}
        .nav-toggle{display:none;background:none;border:0;color:var(--ink-900);font-size:1.5rem}
        .site-nav.solid .nav-toggle{color:var(--ink-900)}
        .mobile-menu{display:none}
        @media (max-width:991px){
            .nav-links,.nav-cta .btn-primary-g{display:none}
            .nav-toggle{display:inline-block}
            .mobile-menu{display:none;position:absolute;top:100%;left:20px;right:20px;background:#fff;border-radius:var(--radius-md);box-shadow:var(--shadow-md);padding:16px 20px;flex-direction:column;gap:12px;margin-top:10px}
            .mobile-menu.open{display:flex}
            .mobile-menu a{color:var(--ink-900);font-weight:500;padding:10px 4px;border-bottom:1px solid #eef0f7}
            .mobile-menu a:last-child{border-bottom:0}
        }

        /* HERO */
        .hero{position:relative;min-height:100vh;padding:140px 0 80px;color:#fff;overflow:hidden;background:radial-gradient(1100px 600px at 85% 15%,rgba(124,58,255,.35),transparent 60%),radial-gradient(800px 500px at 10% 80%,rgba(0,212,180,.25),transparent 60%),linear-gradient(135deg,#06102e 0%,#0b1a4a 45%,#1a2d7d 100%)}
        .hero::before{content:"";position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=60');background-size:cover;background-position:center;opacity:.2;mix-blend-mode:screen;pointer-events:none}
        .hero::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 0%,rgba(6,16,46,.0) 30%,rgba(6,16,46,.6) 100%);pointer-events:none}
        .hero-grid{position:relative;z-index:2;display:grid;grid-template-columns:1.1fr 1fr;gap:56px;align-items:center}
        .eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#d5dcff;padding:.4rem .9rem;border-radius:999px;font-size:.82rem;font-weight:500;letter-spacing:.02em}
        .eyebrow .dot{width:8px;height:8px;background:var(--accent-400);border-radius:50%;box-shadow:0 0 0 4px rgba(34,225,194,.18)}
        .hero h1{font-size:clamp(2.2rem,4.6vw,3.7rem);line-height:1.08;margin-top:22px;background:linear-gradient(180deg,#fff,#cfd6ff);-webkit-background-clip:text;background-clip:text;color:transparent}
        .hero .lead{color:rgba(255,255,255,.82);font-size:1.1rem;margin:22px 0 32px;max-width:52ch}
        .hero-cta{display:flex;flex-wrap:wrap;gap:12px}
        .hero-stats{margin-top:44px;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px;max-width:540px}
        .hero-stat{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius-md);padding:14px 16px;backdrop-filter:blur(6px)}
        .hero-stat strong{display:block;font-size:1.5rem;color:#fff;font-family:'Space Grotesk'}
        .hero-stat span{font-size:.82rem;color:rgba(255,255,255,.7)}
        .hero-visual{position:relative;height:520px}
        .hv-card{position:absolute;background:rgba(17,24,60,.75);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius-lg);backdrop-filter:blur(14px);box-shadow:var(--shadow-lg);overflow:hidden}
        .hv-main{top:20px;left:8%;right:0;width:92%;height:340px}
        .hv-main img{width:100%;height:100%;object-fit:cover;opacity:.9}
        .hv-main::after{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(61,90,254,.25),rgba(0,212,180,.15))}
        .hv-badge{position:absolute;background:#fff;color:var(--ink-900);border-radius:16px;padding:14px 16px;box-shadow:var(--shadow-md);display:flex;gap:12px;align-items:center}
        .hv-badge .ico{width:40px;height:40px;border-radius:10px;display:grid;place-items:center;color:#fff;flex:none}
        .hv-badge .t{font-size:.78rem;color:var(--ink-500)}
        .hv-badge .v{font-weight:700;font-size:1.05rem}
        .hv-badge.a{bottom:20px;left:-10px;animation:float 6s ease-in-out infinite}
        .hv-badge.a .ico{background:linear-gradient(135deg,#00d4b4,#19a8ff)}
        .hv-badge.b{top:0;right:-8px;animation:float 7s ease-in-out -2s infinite}
        .hv-badge.b .ico{background:linear-gradient(135deg,#7c3aff,#ff4fb6)}
        .hv-badge.c{bottom:90px;right:-20px;animation:float 8s ease-in-out -4s infinite}
        .hv-badge.c .ico{background:linear-gradient(135deg,#ff9133,#ffd700);color:#1b1200}
        @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
        @media (max-width:991px){.hero{padding-top:120px}.hero-grid{grid-template-columns:1fr;gap:40px}.hero-visual{height:380px;max-width:520px;margin:0 auto}.hv-main{height:270px}.hero-stats{max-width:100%}}
        @media (max-width:560px){.hero-stats{grid-template-columns:repeat(3,1fr);gap:10px}.hero-stat{padding:10px}.hero-stat strong{font-size:1.15rem}}

        /* TRUST */
        .trust{padding:40px 0;border-bottom:1px solid #eef0f7;background:#fff}
        .trust-title{text-align:center;font-size:.9rem;color:var(--ink-500);text-transform:uppercase;letter-spacing:.14em;margin-bottom:22px}
        .trust-logos{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:40px}
        .trust-logo{font-family:'Space Grotesk';font-weight:700;color:#8b95ad;font-size:1.2rem;letter-spacing:-.02em;opacity:.8}
        .trust-logo i{margin-right:8px;color:var(--brand-500)}

        /* SECTIONS */
        section{padding:100px 0}
        .s-head{text-align:center;max-width:760px;margin:0 auto 56px}
        .s-head .eyebrow-dark{display:inline-flex;gap:8px;align-items:center;background:#eef1ff;color:var(--brand-500);padding:.4rem .9rem;border-radius:999px;font-size:.82rem;font-weight:600;margin-bottom:18px}
        .s-head h2{font-size:clamp(1.9rem,3.4vw,2.6rem);line-height:1.15}
        .s-head p{margin-top:14px;font-size:1.06rem}
        .features{background:var(--surface)}
        .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
        .feat{background:var(--card);border-radius:var(--radius-lg);padding:28px 26px;border:1px solid #ecf0f7;transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease}
        .feat:hover{transform:translateY(-4px);box-shadow:var(--shadow-md);border-color:#d9dff0}
        .feat-ico{width:52px;height:52px;border-radius:14px;display:grid;place-items:center;font-size:1.3rem;color:#fff;margin-bottom:18px;background:linear-gradient(135deg,var(--brand-500),#7c3aff)}
        .feat:nth-child(6n+2) .feat-ico{background:linear-gradient(135deg,#00d4b4,#19a8ff)}
        .feat:nth-child(6n+3) .feat-ico{background:linear-gradient(135deg,#ff4fb6,#7c3aff)}
        .feat:nth-child(6n+4) .feat-ico{background:linear-gradient(135deg,#ff9133,#ffd700);color:#1b1200}
        .feat:nth-child(6n+5) .feat-ico{background:linear-gradient(135deg,#19a8ff,#7c3aff)}
        .feat:nth-child(6n+6) .feat-ico{background:linear-gradient(135deg,#00d4b4,#3d5afe)}
        .feat h4{font-size:1.1rem;margin-bottom:8px}
        .feat p{font-size:.95rem;color:var(--ink-500)}
        @media (max-width:900px){.feat-grid{grid-template-columns:repeat(2,1fr)}}
        @media (max-width:560px){.feat-grid{grid-template-columns:1fr}}

        .split{display:grid;grid-template-columns:1.05fr 1fr;gap:60px;align-items:center}
        .split-visual{position:relative;border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-lg);background:#111;min-height:440px}
        .split-visual img{width:100%;height:100%;min-height:440px;object-fit:cover;opacity:.92}
        .split-visual::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(11,23,54,.1),rgba(11,23,54,.55))}
        .split-visual .tag{position:absolute;top:18px;left:18px;background:rgba(255,255,255,.92);color:var(--ink-900);font-weight:600;font-size:.8rem;padding:.4rem .8rem;border-radius:999px;z-index:2}
        .split h2{font-size:clamp(1.8rem,3.2vw,2.4rem)}
        .steps{margin-top:24px;display:flex;flex-direction:column;gap:18px}
        .step{display:flex;gap:16px;align-items:flex-start}
        .step-num{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;display:grid;place-items:center;font-weight:700;flex:none}
        .step h5{font-size:1.05rem;margin-bottom:4px}
        .step p{font-size:.95rem;color:var(--ink-500)}
        @media (max-width:900px){.split{grid-template-columns:1fr}.split-visual,.split-visual img{min-height:320px}}

        .integrations{background:linear-gradient(180deg,#0b1736 0%,#112050 100%);color:#fff;position:relative;overflow:hidden}
        .integrations::before{content:"";position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=60');background-size:cover;background-position:center;opacity:.12}
        .integrations .s-head h2{color:#fff}
        .integrations .s-head p{color:rgba(255,255,255,.78)}
        .int-grid{position:relative;display:grid;grid-template-columns:repeat(4,1fr);gap:18px;max-width:900px;margin:0 auto}/* _S39R5I_INT4COL */
        .int-tile{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:22px 10px;text-align:center;color:#e9ecf6;font-weight:600;font-family:'Space Grotesk';transition:background .2s ease,transform .2s ease}
        .int-tile i{display:block;font-size:1.6rem;color:var(--accent-400);margin-bottom:8px}
        .int-tile:hover{background:rgba(255,255,255,.12);transform:translateY(-3px)}
        @media (max-width:900px){.int-grid{grid-template-columns:repeat(3,1fr)}}
        @media (max-width:560px){.int-grid{grid-template-columns:repeat(2,1fr)}}

        .bene-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
        .bene{padding:30px 22px;border-radius:var(--radius-lg);background:#fff;border:1px solid #ecf0f7;text-align:center;transition:transform .2s ease,box-shadow .2s ease}
        .bene:hover{transform:translateY(-3px);box-shadow:var(--shadow-md)}
        .bene i{font-size:2rem;color:var(--brand-500);margin-bottom:10px;display:block}
        .bene strong{display:block;font-family:'Space Grotesk';font-size:2.1rem;color:var(--ink-900);letter-spacing:-.02em}
        .bene span{display:block;margin-top:4px;color:var(--ink-500);font-size:.95rem}
        @media (max-width:800px){.bene-grid{grid-template-columns:repeat(2,1fr)}}

        .demo{background:linear-gradient(135deg,#0b1736 0%,#1a2d7d 100%);color:#fff;position:relative;overflow:hidden}
        .demo::before{content:"";position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1920&q=60');background-size:cover;background-position:center;opacity:.1}
        .demo-grid{position:relative;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
        .demo h2{color:#fff;font-size:clamp(1.9rem,3.4vw,2.6rem)}
        .demo p{color:rgba(255,255,255,.8);margin-top:14px;margin-bottom:22px}
        .demo ul{list-style:none;padding:0;margin:0;display:grid;gap:10px}
        .demo ul li{display:flex;gap:10px;align-items:center;color:rgba(255,255,255,.9)}
        .demo ul li i{color:var(--accent-400)}
        .demo-form{background:#fff;color:var(--ink-900);border-radius:var(--radius-lg);padding:30px;box-shadow:var(--shadow-lg)}
        .demo-form .form-control,.demo-form .form-select{border-radius:12px;padding:14px 16px;border:1px solid #e4e8f3}
        .demo-form .form-control:focus,.demo-form .form-select:focus{border-color:var(--brand-500);box-shadow:0 0 0 4px rgba(61,90,254,.15)}
        .demo-form .form-label{font-weight:600;font-size:.88rem;color:var(--ink-700);margin-bottom:6px}
        @media (max-width:900px){.demo-grid{grid-template-columns:1fr;gap:32px}}

        footer{background:#08112a;color:#cbd3e6;padding:70px 0 24px}
        .f-grid{display:grid;grid-template-columns:1.3fr repeat(3,1fr);gap:40px}
        .f-brand p{color:rgba(203,211,230,.8);margin:16px 0 20px}
        .f-col h5{color:#fff;font-size:1rem;margin-bottom:18px;font-family:'Space Grotesk'}
        .f-col a,.f-col li{color:rgba(203,211,230,.8);display:block;padding:4px 0;font-size:.94rem}
        .f-col a:hover{color:#fff}
        .f-col ul{list-style:none;padding:0;margin:0}
        .socials{display:flex;gap:10px;margin-top:10px}
        .socials a{width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,.06);display:grid;place-items:center;color:#fff;transition:background .2s ease}
        .socials a:hover{background:var(--brand-500)}
        .f-bottom{border-top:1px solid rgba(255,255,255,.08);margin-top:40px;padding-top:20px;text-align:center;color:rgba(203,211,230,.6);font-size:.88rem}
        @media (max-width:900px){.f-grid{grid-template-columns:1fr 1fr;gap:30px}}
        @media (max-width:560px){.f-grid{grid-template-columns:1fr}}
    </style>
