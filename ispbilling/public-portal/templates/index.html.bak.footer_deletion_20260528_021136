        *{box-sizing:border-box}
        html,body{margin:0;padding:0;font-family:'Inter',system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:var(--ink-900);background:#fff;-webkit-font-smoothing:antialiased;scroll-behavior:smooth}
