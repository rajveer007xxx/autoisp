<script>
$(function(){
  $('.faq-q').on('click', function(){
    var $a = $(this).next('.faq-a');
    $(this).toggleClass('active');
    $a.toggleClass('show');
  });
  $('.faq-cat').on('click', function(){
    $('.faq-cat').removeClass('active');
    $(this).addClass('active');
    var cat = $(this).data('category');
    if (cat === 'all') $('.faq-sec').show();
    else { $('.faq-sec').hide(); $('.faq-sec[data-category="' + cat + '"]').show(); }
    $('#faqSearch').val(''); $('#clearSearch').removeClass('show'); $('#noResults').removeClass('show');
    $('.faq-item').show();
  });
  function runSearch(){
    var q = $('#faqSearch').val().toLowerCase().trim();
    $('#clearSearch').toggleClass('show', q.length > 0);
    if (!q){
      $('.faq-sec').each(function(){
        var activeCat = $('.faq-cat.active').data('category');
        if (activeCat === 'all' || $(this).data('category') === activeCat) $(this).show(); else $(this).hide();
      });
      $('.faq-item').show();
      $('#noResults').removeClass('show');
      return;
    }
    var anyVisible = false;
    $('.faq-item').each(function(){
      var text = $(this).text().toLowerCase();
      if (text.indexOf(q) > -1){ $(this).show(); anyVisible = true; } else $(this).hide();
    });
    $('.faq-sec').each(function(){
      $(this).toggle($(this).find('.faq-item:visible').length > 0);
    });
    $('#noResults').toggleClass('show', !anyVisible);
  }
  $('#faqSearch').on('input', runSearch);
  $('#clearSearch').on('click', function(){ $('#faqSearch').val(''); runSearch(); });
});
</script>
