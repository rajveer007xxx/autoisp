<style>
/* Pricing tiles */
.price-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;}
.price-card{position:relative;padding:32px 28px;border-radius:20px;background:var(--surface);border:1px solid var(--border-1);backdrop-filter:blur(20px) saturate(140%);box-shadow:var(--shadow-2);transition:transform .25s ease,border-color .25s ease,box-shadow .25s ease;}
.price-card:hover{transform:translateY(-6px);border-color:var(--border-strong);box-shadow:0 24px 60px rgba(99,102,241,.25);}
.price-card.popular{border-color:rgba(34,211,238,.5);background:linear-gradient(165deg,rgba(34,211,238,.08),rgba(20,30,48,.85));}
.price-card.popular::before{content:"MOST POPULAR";position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#22d3ee,#06b6d4);color:#0a1f23;padding:5px 14px;border-radius:999px;font-size:10.5px;font-weight:800;letter-spacing:.12em;font-family:'JetBrains Mono',monospace;box-shadow:var(--glow-cyan);}
.price-ico{width:54px;height:54px;border-radius:14px;background:linear-gradient(135deg,var(--c-indigo),var(--c-violet));display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px;margin-bottom:18px;box-shadow:0 8px 22px rgba(99,102,241,.45);}
.price-card.popular .price-ico{background:linear-gradient(135deg,var(--c-cyan),var(--c-indigo));box-shadow:var(--glow-cyan);}
.price-name{font-family:'Plus Jakarta Sans',sans-serif;font-size:22px;font-weight:800;color:#fff;margin-bottom:6px;}
.price-desc{font-size:13.5px;color:var(--t-fg-mute);margin-bottom:18px;min-height:42px;line-height:1.55;}
.price-amt{display:flex;align-items:baseline;gap:8px;margin-bottom:6px;}
.price-amt .num{font-family:'Plus Jakarta Sans',sans-serif;font-size:42px;font-weight:800;background:linear-gradient(135deg,#fff,#94a3b8);-webkit-background-clip:text;background-clip:text;color:transparent;line-height:1;}
.price-amt .per{color:var(--t-fg-mute);font-size:14px;}
.price-gst{font-size:11.5px;color:var(--t-fg-mute);margin-bottom:24px;font-family:'JetBrains Mono',monospace;}
.price-feats{list-style:none;padding:0;margin:0 0 26px;border-top:1px dashed var(--border-1);padding-top:20px;}
.price-feats li{display:flex;gap:10px;align-items:flex-start;font-size:13.5px;color:var(--t-fg-soft);padding:6px 0;}
.price-feats li i{color:var(--c-green);flex-shrink:0;font-size:16px;margin-top:2px;}
.price-cta{display:block;text-align:center;padding:13px 18px;border-radius:11px;background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff!important;font-weight:700;font-size:13.5px;text-decoration:none;box-shadow:0 8px 22px rgba(99,102,241,.45),inset 0 1px 0 rgba(255,255,255,.18);transition:transform .15s ease,box-shadow .15s ease;}
.price-cta:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(99,102,241,.55);}
.price-card.popular .price-cta{background:linear-gradient(135deg,#22d3ee,#06b6d4);color:#0a1f23!important;box-shadow:var(--glow-cyan);}

/* Contact 2-col */
.cx-grid{display:grid;grid-template-columns:1.05fr 1.4fr;gap:30px;}
@media(max-width:991px){.cx-grid{grid-template-columns:1fr;}}
.cx-card{padding:32px;border-radius:20px;background:var(--surface);border:1px solid var(--border-1);backdrop-filter:blur(20px) saturate(140%);box-shadow:var(--shadow-2);}
.cx-card h3{font-family:'Plus Jakarta Sans',sans-serif;font-size:20px;color:#fff;font-weight:700;margin:0 0 18px;display:flex;align-items:center;gap:10px;}
.cx-card h3 .icobox{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--c-indigo),var(--c-violet));display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;box-shadow:0 6px 18px rgba(99,102,241,.4);}
.cx-info{display:flex;gap:14px;padding:14px 0;border-bottom:1px dashed var(--border-1);}
.cx-info:last-child{border-bottom:none;}
.cx-info .ico{width:42px;height:42px;border-radius:12px;background:rgba(99,102,241,.15);border:1px solid var(--border-1);color:var(--c-cyan);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.cx-info h4{font-size:14px;font-weight:700;color:#fff;margin:0 0 2px;}
.cx-info p{font-size:13px;color:var(--t-fg-soft);margin:0;line-height:1.5;}
.cx-info p a{color:var(--c-cyan);}
.cx-info p.muted{color:var(--t-fg-mute);font-size:12px;}
.cx-callout{margin-top:18px;padding:16px 18px;border-radius:14px;background:linear-gradient(135deg,rgba(34,211,238,.08),rgba(99,102,241,.08));border:1px solid rgba(34,211,238,.25);}
.cx-callout h4{font-size:13px;color:var(--c-cyan);margin:0 0 8px;text-transform:uppercase;letter-spacing:.08em;font-family:'JetBrains Mono',monospace;}
.cx-callout ul{margin:0;padding-left:18px;color:var(--t-fg-soft);font-size:13.5px;}
.cx-quick{margin-top:20px;}
.cx-quick a{display:flex;justify-content:space-between;align-items:center;padding:13px 16px;border-radius:12px;border:1px solid var(--border-1);background:rgba(255,255,255,.02);color:var(--t-fg-soft);font-size:14px;margin-bottom:10px;transition:all .15s ease;text-decoration:none;}
.cx-quick a:hover{border-color:var(--border-strong);background:rgba(99,102,241,.08);color:#fff;transform:translateX(3px);}
.cx-quick a i.bi-chevron-right{color:var(--c-cyan);}
.cx-form .form-group{margin-bottom:14px;}
.cx-form label{display:block;font-size:12.5px;color:var(--t-fg-soft);font-weight:600;margin-bottom:6px;}
.cx-form .req{color:var(--c-rose);}
.cx-form .form-control,.cx-form .form-select,.cx-form textarea{width:100%;padding:12px 14px;border-radius:11px;background:rgba(8,12,22,.6);border:1px solid var(--border-1);color:#fff;font-size:14px;font-family:inherit;transition:border-color .15s ease,box-shadow .15s ease;}
.cx-form .form-control::placeholder,.cx-form textarea::placeholder{color:var(--t-fg-faint);}
.cx-form .form-control:focus,.cx-form .form-select:focus,.cx-form textarea:focus{outline:none;border-color:var(--c-cyan);box-shadow:0 0 0 4px rgba(34,211,238,.18);}
.cx-form .form-select option{background:#0a0f1c;color:#fff;}
.cx-form button[type=submit]{display:flex;justify-content:center;align-items:center;gap:8px;width:100%;padding:14px;border-radius:12px;background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;font-weight:700;font-size:14px;border:none;cursor:pointer;box-shadow:0 8px 22px rgba(99,102,241,.45);transition:transform .15s ease;}
.cx-form button[type=submit]:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(99,102,241,.55);}
.cx-form .alert{margin-top:14px;padding:12px 14px;border-radius:11px;font-size:13.5px;display:none;}
.cx-form .alert.show{display:block;}
.cx-form .alert-ok{background:rgba(52,211,153,.12);color:#86efac;border:1px solid rgba(52,211,153,.3);}
.cx-form .alert-err{background:rgba(248,113,113,.12);color:#fda4af;border:1px solid rgba(248,113,113,.3);}

/* FAQ */
.faq-search{max-width:640px;margin:0 auto 28px;position:relative;}
.faq-search input{width:100%;padding:16px 50px;border-radius:999px;background:var(--surface-elev);border:1px solid var(--border-2);color:#fff;font-size:15px;backdrop-filter:blur(20px);box-shadow:var(--shadow-2);}
.faq-search input::placeholder{color:var(--t-fg-mute);}
.faq-search input:focus{outline:none;border-color:var(--c-cyan);box-shadow:0 0 0 4px rgba(34,211,238,.18);}
.faq-search .bi-search{position:absolute;left:20px;top:50%;transform:translateY(-50%);color:var(--c-cyan);font-size:18px;}
.faq-search .clr{position:absolute;right:18px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:var(--t-fg-mute);font-size:18px;cursor:pointer;display:none;}
.faq-search .clr.show{display:block;}
.faq-cats{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:36px;}
.faq-cat{padding:10px 18px;border-radius:999px;background:rgba(255,255,255,.04);border:1px solid var(--border-1);color:var(--t-fg-soft);font-size:13.5px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:8px;transition:all .2s ease;}
.faq-cat:hover{border-color:var(--border-strong);color:#fff;background:rgba(99,102,241,.10);}
.faq-cat.active{background:linear-gradient(135deg,#6366f1,#4f46e5);border-color:transparent;color:#fff;box-shadow:0 8px 22px rgba(99,102,241,.45);}
.faq-sec{margin-bottom:36px;}
.faq-sec h3{display:flex;align-items:center;gap:14px;font-family:'Plus Jakarta Sans',sans-serif;font-size:22px;color:#fff;margin:0 0 18px;}
.faq-sec h3 .ico{width:38px;height:38px;border-radius:11px;background:linear-gradient(135deg,var(--c-indigo),var(--c-violet));display:flex;align-items:center;justify-content:center;font-size:16px;color:#fff;box-shadow:0 6px 18px rgba(99,102,241,.4);}
.faq-item{background:var(--surface);border:1px solid var(--border-1);border-radius:14px;margin-bottom:10px;overflow:hidden;backdrop-filter:blur(20px);transition:border-color .2s ease;}
.faq-item:hover{border-color:var(--border-2);}
.faq-q{padding:18px 22px;display:flex;justify-content:space-between;align-items:center;gap:14px;cursor:pointer;color:#fff;font-size:15px;font-weight:600;line-height:1.4;}
.faq-q .chev{color:var(--c-cyan);transition:transform .25s ease;flex-shrink:0;}
.faq-q.active .chev{transform:rotate(180deg);}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease,padding .25s ease;color:var(--t-fg-soft);font-size:14px;line-height:1.7;}
.faq-a.show{max-height:1500px;padding:0 22px 18px;}
.faq-a p{color:var(--t-fg-soft);}
.faq-a ul{padding-left:22px;margin:8px 0;}
.faq-a strong{color:#fff;}
.faq-a a{color:var(--c-cyan);}
.faq-a code{background:rgba(99,102,241,.18);color:#C7D2FE;padding:2px 8px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:12.5px;}
.faq-a h5{color:var(--c-cyan)!important;font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.04em;margin:16px 0 8px!important;text-transform:uppercase;}
.faq-noresults{text-align:center;padding:50px 20px;color:var(--t-fg-mute);display:none;}
.faq-noresults.show{display:block;}
.faq-noresults i{font-size:48px;color:var(--c-indigo);margin-bottom:14px;}
.faq-cta{margin-top:50px;text-align:center;padding:50px 30px;border-radius:20px;background:linear-gradient(135deg,rgba(99,102,241,.12),rgba(34,211,238,.08));border:1px solid var(--border-2);backdrop-filter:blur(20px);}
.faq-cta h3{font-family:'Plus Jakarta Sans',sans-serif;font-size:24px;color:#fff;margin:0 0 10px;}
.faq-cta p{color:var(--t-fg-soft);margin:0 0 22px;}
.faq-cta-row{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;}

/* Policy / TOC */
.policy-grid{display:grid;grid-template-columns:280px 1fr;gap:40px;align-items:flex-start;}
@media(max-width:991px){.policy-grid{grid-template-columns:1fr;}}
.policy-toc{position:sticky;top:120px;padding:24px;border-radius:16px;background:var(--surface);border:1px solid var(--border-1);backdrop-filter:blur(20px);}
.policy-toc h4{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--c-cyan);text-transform:uppercase;letter-spacing:.12em;margin:0 0 14px;}
.policy-toc ol{margin:0;padding-left:18px;display:grid;gap:7px;color:var(--t-fg-soft);font-size:13px;}
.policy-toc ol a{color:var(--t-fg-soft);}
.policy-toc ol a:hover{color:var(--c-cyan);}
.policy-body{padding:36px;border-radius:20px;background:var(--surface);border:1px solid var(--border-1);backdrop-filter:blur(20px);box-shadow:var(--shadow-2);}
@media(max-width:600px){.policy-body{padding:24px 20px;}}
.policy-body .last-updated{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:999px;background:rgba(34,211,238,.10);border:1px solid rgba(34,211,238,.30);color:var(--c-cyan);font-size:12px;font-family:'JetBrains Mono',monospace;margin-bottom:24px;}
.policy-section{margin-bottom:34px;padding-bottom:24px;border-bottom:1px dashed var(--border-1);}
.policy-section:last-child{border-bottom:none;}
.policy-section h3{font-family:'Plus Jakarta Sans',sans-serif;font-size:22px;color:#fff;margin:0 0 14px;display:flex;align-items:baseline;gap:14px;}
.policy-section h3 .num{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--c-cyan);background:rgba(34,211,238,.08);padding:4px 10px;border-radius:8px;border:1px solid rgba(34,211,238,.25);}
.policy-section h4{font-family:'Plus Jakarta Sans',sans-serif;font-size:16px;color:#fff;margin:18px 0 8px;}
.policy-section p,.policy-section li{color:var(--t-fg-soft);font-size:14.5px;line-height:1.75;}
.policy-section p{margin:0 0 12px;}
.policy-section ul{padding-left:22px;margin:8px 0 14px;}
.policy-section a{color:var(--c-cyan);}
.policy-section code{background:rgba(99,102,241,.18);color:#C7D2FE;padding:2px 8px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:13px;}
.policy-section strong{color:#fff;}

/* Sitemap */
.sm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;}
.sm-col{padding:24px;border-radius:16px;background:var(--surface);border:1px solid var(--border-1);backdrop-filter:blur(20px);}
.sm-col h5{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--c-cyan);text-transform:uppercase;letter-spacing:.12em;margin:0 0 14px;}
.sm-col ul{list-style:none;margin:0;padding:0;display:grid;gap:8px;}
.sm-col a{color:var(--t-fg-soft);font-size:14px;display:flex;align-items:center;gap:8px;transition:color .15s ease,transform .15s ease;}
.sm-col a:hover{color:var(--c-cyan);transform:translateX(3px);}
.sm-col a i{color:var(--c-indigo);font-size:13px;}
