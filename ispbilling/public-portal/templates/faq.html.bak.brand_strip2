<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FAQ / Help Center &middot; Auto ISP Billing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Space+Grotesk:wght@500;600;700&amp;display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root{--brand-900:#0b1736;--brand-700:#1a2d7d;--brand-500:#3d5afe;--brand-400:#5b7bff;--accent-500:#00d4b4;--accent-400:#22e1c2;--ink-900:#0b1224;--ink-700:#2b3552;--ink-500:#5c6785;--ink-300:#aab2c8;--surface:#f6f8fc;--card:#fff;--line:#e4e8f3;--radius-lg:18px;--radius-md:12px;--shadow-sm:0 2px 10px rgba(11,18,36,.06);--shadow-md:0 10px 30px rgba(11,18,36,.08)}
        *{box-sizing:border-box}
        html,body{margin:0;padding:0;font-family:'Inter',system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:var(--ink-900);background:var(--surface);-webkit-font-smoothing:antialiased}
        a{text-decoration:none;color:inherit}
        h1,h2,h3,h4,h5,h6{font-family:'Space Grotesk','Inter',sans-serif;font-weight:700;letter-spacing:-.01em;margin:0}
        p{margin:0;line-height:1.65;color:var(--ink-700)}
        ul{margin:0;padding-left:20px}
        ul li{line-height:1.7}
        .container-xxl{max-width:1100px;margin:0 auto;padding:0 22px}

        /* NAV */
        .site-nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.9);backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--line)}
        .nav-wrap{display:flex;align-items:center;justify-content:space-between;height:70px}
        .brand{display:flex;align-items:center;gap:10px;font-weight:700;color:var(--ink-900);font-size:1.08rem}
        .brand-logo{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--brand-500),#7c3aff);display:grid;place-items:center;color:#fff;box-shadow:0 8px 22px rgba(61,90,254,.35)}
        .nav-links{display:flex;gap:28px;list-style:none;padding:0;margin:0}
        .nav-links a{color:var(--ink-700);font-weight:500;font-size:.95rem}
        .nav-links a:hover{color:var(--brand-500)}
        .nav-cta{display:flex;gap:10px;align-items:center}
        .btn{display:inline-flex;gap:8px;align-items:center;justify-content:center;border:0;cursor:pointer;font-weight:600;border-radius:999px;padding:10px 18px;font-size:.92rem;transition:transform .15s ease,box-shadow .2s ease,background .2s ease,color .2s ease}
        .btn-ghost{background:transparent;color:var(--ink-900);border:1px solid var(--line)}
        .btn-ghost:hover{border-color:var(--brand-500);color:var(--brand-500)}
        .btn-primary{background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;box-shadow:0 12px 26px rgba(61,90,254,.32)}
        .btn-primary:hover{transform:translateY(-1px);color:#fff}
        .nav-burger{display:none;border:0;background:transparent;font-size:1.4rem;color:var(--ink-700)}
        @media (max-width:900px){.nav-links,.nav-cta .btn-ghost{display:none}.nav-burger{display:inline-flex}}

        /* HERO */
        .page-hero{position:relative;overflow:hidden;color:#fff;padding:70px 0 80px;background:radial-gradient(900px 500px at 85% 0%,rgba(124,58,255,.35),transparent 60%),radial-gradient(700px 400px at 0% 100%,rgba(0,212,180,.28),transparent 60%),linear-gradient(135deg,#06102e 0%,#0b1a4a 45%,#1a2d7d 100%)}
        .page-hero::before{content:"";position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1551808525-51a94da548ce?auto=format&fit=crop&w=1600&q=70');background-size:cover;background-position:center;opacity:.12;mix-blend-mode:screen;pointer-events:none}
        .page-hero .container-xxl{position:relative;z-index:2;text-align:center}
        .eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);padding:.4rem .9rem;border-radius:999px;font-size:.82rem;font-weight:500;color:#d5dcff}
        .eyebrow .dot{width:8px;height:8px;background:var(--accent-400);border-radius:50%;box-shadow:0 0 0 4px rgba(34,225,194,.18)}
        .page-hero h1{font-size:clamp(2rem,4vw,3rem);margin-top:16px;background:linear-gradient(180deg,#fff,#cfd6ff);-webkit-background-clip:text;background-clip:text;color:transparent}
        .page-hero p{max-width:680px;margin:14px auto 0;color:rgba(255,255,255,.78)}

        /* SEARCH */
        .search-wrap{max-width:640px;margin:-34px auto 32px;position:relative;z-index:5}
        .search-wrap .search-box{background:#fff;border-radius:999px;box-shadow:0 20px 50px rgba(11,18,36,.14);border:1px solid var(--line);display:flex;align-items:center;padding:6px 8px 6px 22px}
        .search-wrap input{flex:1;border:0;outline:0;padding:14px 6px;font-size:1rem;background:transparent;color:var(--ink-900)}
        .search-wrap .s-ico{color:var(--ink-300);margin-right:6px;font-size:1.1rem}
        .search-wrap .clear-btn{border:0;background:transparent;color:var(--ink-500);padding:10px;display:none;cursor:pointer}
        .search-wrap .clear-btn.show{display:inline-block}

        /* CATEGORIES */
        .categories{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin:0 auto 40px;max-width:900px}
        .cat-btn{border:1.5px solid var(--line);background:#fff;color:var(--ink-700);padding:9px 18px;border-radius:999px;font-weight:500;font-size:.9rem;cursor:pointer;transition:all .15s ease;display:inline-flex;align-items:center;gap:6px}
        .cat-btn:hover{border-color:var(--brand-500);color:var(--brand-500)}
        .cat-btn.active{background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;border-color:transparent;box-shadow:0 10px 20px rgba(61,90,254,.25)}

        /* FAQ SECTION */
        main{padding:0 0 60px}
        .faq-section{background:#fff;border:1px solid var(--line);border-radius:var(--radius-lg);padding:30px;margin-bottom:22px;box-shadow:var(--shadow-sm)}
        .faq-section h3{font-size:1.3rem;margin-bottom:22px;display:flex;align-items:center;gap:12px;padding-bottom:14px;border-bottom:1px solid var(--line)}
        .faq-section h3 .sec-ico{width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;display:grid;place-items:center;font-size:1.05rem}
        .faq-item{border-bottom:1px solid var(--line)}
        .faq-item:last-child{border-bottom:0}
        .faq-question{display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;padding:18px 4px;font-weight:600;font-size:1rem;color:var(--ink-900);transition:color .15s ease}
        .faq-question:hover{color:var(--brand-500)}
        .faq-question .chev{color:var(--ink-500);transition:transform .25s ease;flex-shrink:0}
        .faq-question.active .chev{transform:rotate(180deg);color:var(--brand-500)}
        .faq-answer{max-height:0;overflow:hidden;transition:max-height .3s ease;color:var(--ink-700);font-size:.95rem;line-height:1.75}
        .faq-answer.show{max-height:1500px;padding:0 4px 22px}
        .faq-answer ul{margin-top:8px;padding-left:22px}
        .faq-answer a{color:var(--brand-500);font-weight:600}
        .faq-answer a:hover{text-decoration:underline}

        .no-results{text-align:center;padding:60px 20px;color:var(--ink-500);display:none}
        .no-results.show{display:block}
        .no-results i{font-size:3rem;color:var(--ink-300);margin-bottom:12px;display:block}

        /* CTA CARD */
        .cta-card{background:linear-gradient(135deg,rgba(61,90,254,.08),rgba(0,212,180,.08));border:1px solid rgba(61,90,254,.2);border-radius:var(--radius-lg);padding:36px;text-align:center;margin-top:30px}
        .cta-card h3{font-size:1.4rem;margin-bottom:10px}
        .cta-card p{margin-bottom:22px}
        .cta-card .btn-row{display:flex;flex-wrap:wrap;gap:10px;justify-content:center}

        /* FOOTER */
        footer{background:#0b1224;color:#cbd3e9;padding:56px 0 20px;margin-top:40px}
        .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:28px}
        @media (max-width:900px){.foot-grid{grid-template-columns:1fr 1fr}}
        @media (max-width:560px){.foot-grid{grid-template-columns:1fr}}
        footer h5{color:#fff;font-size:1rem;margin-bottom:12px}
        footer ul{list-style:none;padding:0;margin:0}
        footer ul li{margin-bottom:8px;font-size:.9rem;color:#aab2c8}
        footer ul li a{color:#aab2c8}
        footer ul li a:hover{color:#fff}
        .foot-brand{display:flex;align-items:center;gap:10px;color:#fff;font-weight:700;font-size:1.08rem;margin-bottom:10px}
        .foot-brand .brand-logo{box-shadow:none}
        .foot-brand-desc{font-size:.9rem;color:#9aa3bd}
        .foot-bottom{border-top:1px solid rgba(255,255,255,.08);margin-top:36px;padding-top:18px;display:flex;justify-content:space-between;align-items:center;color:#8088a8;font-size:.82rem;flex-wrap:wrap;gap:10px}
        .foot-social a{display:inline-grid;place-items:center;width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);color:#cbd3e9;margin-right:8px;font-size:1rem}
        .foot-social a:hover{background:var(--brand-500);border-color:var(--brand-500);color:#fff}
    
    /* _S39R5I_CONTACT — restore broken nav typography */
    .site-nav .brand-img { height: 36px !important; width: auto !important;
        max-width: 200px; display: block; }
    .site-nav .nav-wrap { display: flex; align-items: center; gap: 28px;
        padding: 12px 24px; }
    .site-nav .nav-links { display: flex; align-items: center; gap: 24px;
        list-style: none; margin: 0 auto 0 0; padding: 0; }
    .site-nav .nav-links a { font-size: 14px; font-weight: 500; color: var(--ink-700);
        text-decoration: none; padding: 6px 0; transition: color .15s; }
    .site-nav .nav-links a:hover { color: var(--brand-500); }
    .site-nav .nav-cta { display: flex; align-items: center; gap: 10px; }
    .site-nav .nav-cta .btn { font-size: 13px; font-weight: 600; padding: 8px 16px;
        border-radius: 9px; text-decoration: none; display: inline-flex;
        align-items: center; gap: 6px; }
    .site-nav .nav-cta .btn-ghost { background: transparent; border: 1px solid var(--line);
        color: var(--ink-700); }
    .site-nav .nav-cta .btn-primary { background: linear-gradient(135deg, var(--brand-500), #7c3aff);
        color: #fff; border: 0; }

    /* _S39R5U_MOBILE_NAV_ — mobile hamburger + slide-down menu */
    @media (max-width: 900px){
      .site-nav .nav-links, .nav-bar .nav-links,
      .site-nav .nav-cta, .nav-bar .cta { display: none !important; }
      .nav-toggle-mobile { display: inline-flex !important; }
    }
    .nav-toggle-mobile { display: none; background: transparent; border: 0;
      color: #2b3552; font-size: 1.6rem; padding: 6px 10px; cursor: pointer;
      align-items: center; }
    .mobile-menu-public { display: none; position: absolute; top: 100%;
      left: 16px; right: 16px; background: #fff; border-radius: 12px;
      box-shadow: 0 14px 32px rgba(11,18,36,.12); padding: 14px 18px;
      flex-direction: column; gap: 10px; margin-top: 8px; z-index: 60;
      border: 1px solid #e4e8f3; }
    .mobile-menu-public.open { display: flex; }
    .mobile-menu-public a { color: #2b3552; font-weight: 500; padding: 10px 4px;
      border-bottom: 1px solid #eef0f7; text-decoration: none; font-size: 14px; }
    .mobile-menu-public a:last-child { border-bottom: 0; }
</style>
    <link rel="stylesheet" href="/static/css/site-header.css"> <!-- _S39R5K_GLOBAL_ -->
    <style>/* _S39R5K_GLOBAL_ 80% desktop zoom */
      @media (min-width: 992px){ html { zoom: 0.8; } }
    </style>
<!-- _S40zμ_  Profanity shield -->
<script src="/static/js/profanity-shield.js?v=1" defer></script>
</head>
