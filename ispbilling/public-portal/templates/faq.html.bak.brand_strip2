<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
$(function(){
    // Accordion
    $('.faq-question').on('click', function(){
        var $a = $(this).next('.faq-answer');
        $(this).toggleClass('active');
        $a.toggleClass('show');
    });

    // Category filter
    $('.cat-btn').on('click', function(){
        $('.cat-btn').removeClass('active');
        $(this).addClass('active');
        var cat = $(this).data('category');
        if (cat === 'all') $('.faq-section').show();
        else { $('.faq-section').hide(); $('.faq-section[data-category="' + cat + '"]').show(); }
        $('#faqSearch').val(''); $('#clearSearch').removeClass('show'); $('#noResults').removeClass('show');
        $('.faq-item').show();
    });

    // Search
    function runSearch(){
        var q = $('#faqSearch').val().toLowerCase().trim();
        $('#clearSearch').toggleClass('show', q.length > 0);
        if (!q){
            $('.faq-section').each(function(){
                var activeCat = $('.cat-btn.active').data('category');
                if (activeCat === 'all' || $(this).data('category') === activeCat) $(this).show(); else $(this).hide();
            });
            $('.faq-item').show();
            $('#noResults').removeClass('show');
            return;
        }
        var anyVisible = false;
        $('.faq-item').each(function(){
            var text = $(this).text().toLowerCase();
            if (text.indexOf(q) > -1){ $(this).show(); anyVisible = true; } else $(this).hide();
        });
        $('.faq-section').each(function(){
            $(this).toggle($(this).find('.faq-item:visible').length > 0);
        });
        $('#noResults').toggleClass('show', !anyVisible);
    }
    $('#faqSearch').on('input', runSearch);
    $('#clearSearch').on('click', function(){ $('#faqSearch').val(''); runSearch(); });
});
</script>

<script data-tag="_S39R5U_MOBILE_NAV_">
(function(){
  var sfx = "E_NAV_";
  var btn = document.getElementById('navToggleMobile' + sfx);
  var menu = document.getElementById('mobileMenuPublic' + sfx);
  if (btn && menu) {
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      menu.classList.toggle('open');
    });
    menu.querySelectorAll('a').forEach(function(a){
      a.addEventListener('click', function(){ menu.classList.remove('open'); });
    });
    document.addEventListener('click', function(ev){
      if (!menu.contains(ev.target) && !btn.contains(ev.target)) menu.classList.remove('open');
    });
  }
})();
</script>
</body>
</html>
