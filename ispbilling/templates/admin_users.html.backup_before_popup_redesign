            $('#edit_igst_tax').val('');
            $('#edit_total_bill_amount').val('');
            updateEditPaymentSummary();
        }
    });
    
    // Helper function to calculate end date with proper month-boundary handling
    function calculateEndDate(startDateStr, period) {
        if (!startDateStr || !period) return '';
        
        var parts = startDateStr.split('-');
        if (parts.length !== 3) return '';
        
        var day = parseInt(parts[0]);
        var month = parseInt(parts[1]) - 1;
        var year = parseInt(parts[2]);
        
        var targetMonth = (month + period) % 12;
        var targetYear = year + Math.floor((month + period) / 12);
        
        var lastDayOfTargetMonth = new Date(targetYear, targetMonth + 1, 0).getDate();
        
        var endDay;
        if (day === 1) {
            endDay = lastDayOfTargetMonth;
        } else {
            endDay = day - 1;
        }
        
        var endDate = new Date(targetYear, targetMonth, endDay);
        var endDayStr = String(endDate.getDate()).padStart(2, '0');
        var endMonthStr = String(endDate.getMonth() + 1).padStart(2, '0');
        var endYearStr = endDate.getFullYear();
        
        return endDayStr + '-' + endMonthStr + '-' + endYearStr;
    }
    
    // Period change handler - only recalculate if period actually changed
    $(document).on('change', '#edit_period', function() {
        var currentPeriod = $(this).val();
        var originalPeriod = $('#edit_original_period').val();
        
        var startDate = $('#edit_start_date').val();
        if (startDate && currentPeriod) {
            var endDate = calculateEndDate(startDate, parseInt(currentPeriod));
            $('#edit_end_date').val(endDate);
        }
        
        if (currentPeriod !== originalPeriod) {
            calculateEditBilling();
        } else {
            $('#edit_bill_amount').val('');
            $('#edit_cgst_tax').val('');
            $('#edit_sgst_tax').val('');
            $('#edit_igst_tax').val('');
            $('#edit_total_bill_amount').val('');
            updateEditPaymentSummary();
        }
    });
    
    // Start date change handler - update end date and carry amount if changed
