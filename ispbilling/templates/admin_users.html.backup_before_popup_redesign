    // Auto-generate transaction number when amount or discount is entered
    function generateTransactionNumber() {
        if (transactionNoGenerated) return; // Only generate once
        
        var payingAmount = parseFloat($('#payment_paying_amount').val()) || 0;
        var discount = parseFloat($('#payment_discount').val()) || 0;
        
        if (payingAmount > 0 || discount > 0) {
            var paymentMode = $('#payment_payment_mode').val() || 'Cash';
            
            $.ajax({
                url: '/api/payments/transaction-no?payment_mode=' + encodeURIComponent(paymentMode),
                method: 'GET',
