        var originalStartDate = $('#edit_original_start_date').val();
        var period = parseInt($('#edit_period').val());
        
        if (currentStartDate && period) {
            var endDate = calculateEndDate(currentStartDate, period);
            $('#edit_end_date').val(endDate);
        }
        
        if (currentStartDate !== originalStartDate) {
            calculateEditBilling();
        } else {
            $('#edit_bill_amount').val('');
            $('#edit_cgst_tax').val('');
            $('#edit_sgst_tax').val('');
            $('#edit_igst_tax').val('');
            $('#edit_total_bill_amount').val('');
            updateEditPaymentSummary();
        }
    });
    
    // Calculate billing for edit form
    function calculateEditBilling() {
        var startDate = $('#edit_start_date').val();
        var period = parseInt($('#edit_period').val());
        var monthlyAmount = parseFloat($('#edit_monthly_amount').val()) || 0;
        
        if (!startDate || !period || monthlyAmount === 0) {
            // Clear billing fields when inputs are incomplete
            $('#edit_bill_amount').val('');
            $('#edit_cgst_tax').val('');
            $('#edit_sgst_tax').val('');
            $('#edit_igst_tax').val('');
            $('#edit_total_bill_amount').val('');
            updateEditPaymentSummary();
            return;
        }
        
        // Calculate end date using helper function
        var endDate = calculateEndDate(startDate, period);
        $('#edit_end_date').val(endDate);
        
        // Calculate billing amounts WITHOUT tax
        var billAmount = monthlyAmount * period;
        
        $('#edit_bill_amount').val(billAmount.toFixed(2));
        $('#edit_cgst_tax').val('');
        $('#edit_sgst_tax').val('');
        $('#edit_igst_tax').val('');
        $('#edit_total_bill_amount').val(billAmount.toFixed(2));
        
        // Update payment summary after billing calculation
        updateEditPaymentSummary();
    }
    
    // Update payment summary (Total Due Balance calculation)
    function updateEditPaymentSummary() {
        var planRaw = $('#edit_total_bill_amount').val();
        var discountRaw = $('#edit_discount_credit').val();
        
        // Calculate total due balance
        var planTotal = parseFloat(planRaw) || 0;
        var prevDue = parseFloat($('#edit_previous_due').val()) || 0;
        var discount = parseFloat(discountRaw) || 0;
        var totalDue = planTotal + prevDue - discount;
        $('#edit_total_due_balance').val(totalDue.toFixed(2));
    }
    
