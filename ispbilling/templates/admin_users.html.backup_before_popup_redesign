                url: '/api/customers/' + customerId + '/renew',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    start_from: 'today',
                    period_months: months,
                    with_invoice: false
                }),
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        $('#renew_start_date').text(response.start_date);
                        $('#renew_end_date').text(response.end_date);
                        loadCustomers();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Failed to renew customer';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    alert(errorMsg);
                }
            });
        });
        
        // Handle Instant Renew with Invoice (chosen date)
        $('#btn_instant_renew_with_invoice').off('click').on('click', function() {
            var startDate = $('#renew_instant_date').val();
            var months = parseInt($('#renew_instant_months').val());
            
            if (!startDate) {
                alert('Please select a start date');
                return;
            }
            if (!months) {
                alert('Please select number of months');
                return;
            }
            
            if (!confirm('Renew customer from ' + startDate + ' for ' + months + ' month(s) with invoice?')) {
                return;
            }
            
            $.ajax({
                url: '/api/customers/' + customerId + '/renew',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    start_from: 'date',
                    start_date: startDate,
                    period_months: months,
                    with_invoice: true
                }),
                success: function(response) {
                    if (response.success) {
                        alert(response.message + '\nInvoice No: ' + (response.invoice_no || 'N/A'));
                        $('#renew_start_date').text(response.start_date);
                        $('#renew_end_date').text(response.end_date);
                        loadCustomers();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Failed to renew customer';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    alert(errorMsg);
                }
            });
        });
        
        // Handle Instant Renew without Invoice (chosen date)
        $('#btn_instant_renew_without_invoice').off('click').on('click', function() {
            var startDate = $('#renew_instant_date').val();
            var months = parseInt($('#renew_instant_months').val());
            
            if (!startDate) {
                alert('Please select a start date');
                return;
            }
            if (!months) {
                alert('Please select number of months');
                return;
            }
            
            if (!confirm('Renew customer from ' + startDate + ' for ' + months + ' month(s) without invoice?')) {
                return;
            }
            
            $.ajax({
                url: '/api/customers/' + customerId + '/renew',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    start_from: 'date',
                    start_date: startDate,
                    period_months: months,
                    with_invoice: false
                }),
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        $('#renew_start_date').text(response.start_date);
                        $('#renew_end_date').text(response.end_date);
                        loadCustomers();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Failed to renew customer';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    alert(errorMsg);
                }
            });
        });
    });
});
