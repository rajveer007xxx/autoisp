    // Save payment
    $('#savePayment').on('click', function() {
        // Validate required fields
        if (!$('#payment_customer_id').val()) {
            alert('Customer ID is required');
            return;
        }
        if (!$('#payment_paying_amount').val() || parseFloat($('#payment_paying_amount').val()) < 0) {
            alert('Please enter a valid paying amount');
            return;
        }
        if (!$('#payment_discount').val() || parseFloat($('#payment_discount').val()) < 0) {
            alert('Please enter a valid discount (0 or greater)');
            return;
        }
        if (!$('#payment_employee_id').val()) {
            alert('Please select an employee');
            return;
        }
        if (!$('#payment_payment_mode').val()) {
            alert('Please select a payment mode');
            return;
        }
        
        var payingAmount = parseFloat($('#payment_paying_amount').val()) || 0;
        var discount = parseFloat($('#payment_discount').val()) || 0;
        
        if (payingAmount + discount <= 0) {
            alert('Total payment (amount + discount) must be greater than zero');
            return;
        }
        
        // Convert DD-MM-YYYY HH:MM to ISO format
        var paidAtStr = $('#payment_paid_at').val();
        var paidAtISO = paidAtStr; // Default to original value
        
        if (paidAtStr && paidAtStr.match(/^\d{2}-\d{2}-\d{4} \d{2}:\d{2}$/)) {
            // Parse DD-MM-YYYY HH:MM format
            var parts = paidAtStr.split(' ');
            var dateParts = parts[0].split('-');
            var timeParts = parts[1].split(':');
            var day = dateParts[0];
            var month = dateParts[1];
            var year = dateParts[2];
            var hours = timeParts[0];
            var minutes = timeParts[1];
            
            // Convert to ISO format (YYYY-MM-DDTHH:MM:SS)
            paidAtISO = year + '-' + month + '-' + day + 'T' + hours + ':' + minutes + ':00';
        }
        
        var formData = {
            customer_id: $('#payment_customer_id').val(),
            paying_amount: payingAmount,
            discount: discount,
            paid_at: paidAtISO,
            employee_id: $('#payment_employee_id').val(),
            payment_mode: $('#payment_payment_mode').val(),
            remarks: $('#payment_remarks').val()
        };
        
        $.ajax({
            url: '/api/payments/create',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(formData),
            success: function(response) {
                if (response.success) {
                    alert('Payment added successfully!\nTransaction No: ' + response.transaction_no);
                    $('#addPaymentModal').modal('hide');
                    location.reload();
                } else {
                    alert('Error: ' + response.message);
                }
            },
            error: function(xhr) {
                var errorMsg = 'Failed to add payment';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMsg = xhr.responseJSON.message;
                }
                alert(errorMsg);
            }
        });
    });

