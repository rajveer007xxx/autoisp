                            html += '<td>₹' + txn.amount.toFixed(2) + '</td>';
                            html += '<td>₹' + txn.discount.toFixed(2) + '</td>';
                            html += '<td><strong>₹' + txn.balance_after.toFixed(2) + '</strong></td>';
                            html += '<td><span class="label label-primary">' + txn.payment_mode + '</span></td>';
                            html += '<td>' + txn.employee_id + '</td>';
                            html += '<td>' + (txn.remarks || '-') + '</td>';
                            html += '<td style="white-space: nowrap;">';
                            html += '<a href="/api/payments/' + txn.id + '/receipt" target="_blank" class="btn btn-xs btn-success" title="Download PDF"><i class="fa fa-download"></i></a> ';
                            html += '<button class="btn btn-xs btn-info send-email-btn" data-payment-id="' + txn.id + '" data-customer-email="' + (response.customer.customer_email || '') + '" title="Send Email"><i class="fa fa-envelope"></i></button> ';
                            html += '<button type="button" class="btn btn-xs btn-success send-whatsapp-btn" data-payment-id="' + txn.id + '" data-customer-phone="' + (response.customer.customer_phone || '') + '" data-transaction-no="' + txn.transaction_no + '" title="Send WhatsApp"><i class="fa fa-whatsapp"></i></button>';
                            html += '</td>';
                            html += '</tr>';
                        });
                        
                        html += '</tbody></table></div>';
                        
                        var totalAmount = response.transactions.reduce(function(sum, txn) { return sum + txn.amount; }, 0);
                        var totalDiscount = response.transactions.reduce(function(sum, txn) { return sum + txn.discount; }, 0);
                        var totalNet = totalAmount + totalDiscount;
                        
                        html += '<div class="row" style="margin-top: 15px;"><div class="col-md-12"><div class="alert alert-success"><strong>Summary:</strong> Total Transactions: ' + response.transactions.length + ' | Total Amount Received: ₹' + totalAmount.toFixed(2) + ' | Total Discount: ₹' + totalDiscount.toFixed(2) + ' | Total Paid: ₹' + totalNet.toFixed(2) + '</div></div></div>';
                        
                        $('#transactionHistoryContent').html(html);
                        
                        var monthOptions = '<option value="">All Months</option>';
                        var sortedMonths = Array.from(monthsSet).sort(function(a, b) { return a - b; });
                        sortedMonths.forEach(function(monthIdx) {
                            monthOptions += '<option value="' + monthIdx + '">' + monthNames[monthIdx] + '</option>';
                        });
                        $('#txnMonthFilter').html(monthOptions);
                        
                        if ($.fn.DataTable.isDataTable('#txnTable')) {
