{% extends "base_admin.html" %}

{% block title %}User Management - Auto ISP Billing{% endblock %}

{% block extra_css %}
<!-- DataTables 1.10.25 -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.10.25/css/dataTables.bootstrap.min.css">
<!-- Bootstrap Datepicker -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.9.0/css/bootstrap-datepicker.min.css">
<style>
    .content-header {
        padding: 15px;
        background: #fff;
        border-bottom: 1px solid #d2d6de;
    }
    .btn-add-cable {
        background-color: #d9534f;
        color: white;
        border: none;
        padding: 4px 8px;
        font-size: 11px;
    }
    .btn-add-cable:hover {
        background-color: #c9302c;
        color: white;
    }
    .btn-add-broadband {
        background-color: #337ab7;
        color: white;
        border: none;
        padding: 4px 8px;
        font-size: 11px;
    }
    .btn-add-broadband:hover {
        background-color: #286090;
        color: white;
    }
    .filters-section {
        background: #fff;
        padding: 10px;
        margin-bottom: 0;
        border: 1px solid #d2d6de;
    }
    .filter-row {
        margin-bottom: 0;
    }
    .filter-row [class*="col-"] {
        padding-left: 1px;
        padding-right: 1px;
    }
    .filter-row .form-control,
    .filter-row .input-group {
        font-size: 11px;
        height: 28px;
    }
    .filter-row .form-control {
        padding: 4px 6px;
    }
    .az-navigation {
        margin: 0;
        padding: 8px 10px;
        text-align: center;
        background: #fff;
        border: 1px solid #d2d6de;
        border-top: none;
    }
    .az-navigation .btn {
        margin: 1px;
        padding: 4px 8px;
        font-size: 11px;
    }
    .az-navigation .btn.active {
        background-color: #337ab7;
        color: white;
    }
    .table-container {
        background: #fff;
        padding: 15px;
        border: 1px solid #d2d6de;
    }
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        padding: 5px 10px;
    }
    .action-icons a {
        margin: 0 3px;
        color: #337ab7;
        font-size: 16px;
    }
    .action-icons a:hover {
        color: #23527c;
    }
    .action-icons img {
        width: 20px;
        height: 20px;
        margin: 0 3px;
        cursor: pointer;
        vertical-align: middle;
    }
    /* Align all table cells to middle vertically */
    table.dataTable tbody td {
        vertical-align: middle !important;
        text-align: center !important;
    }
    table.dataTable thead th {
        vertical-align: middle !important;
        text-align: center !important;
    }
    /* Remove extra horizontal padding from Amount, Received, Balance columns */
    table.dataTable tbody td:nth-child(7),
    table.dataTable tbody td:nth-child(8),
    table.dataTable tbody td:nth-child(9) {
        padding-left: 4px !important;
        padding-right: 4px !important;
    }
    table.dataTable {
        border: 1px solid #000 !important;
        border-collapse: collapse !important;
    }
    table.dataTable thead th {
        background-color: #f4f4f4;
        font-weight: bold;
        border: 1px solid #000 !important;
        padding: 8px;
    }
    table.dataTable tbody td {
        padding: 8px;
        vertical-align: middle;
        border: 1px solid #000 !important;
    }
    table.dataTable tbody tr:hover {
        background-color: #f9f9f9;
    }
    .status-active {
        color: #00a65a;
        font-weight: bold;
    }
    .status-deactive {
        color: #dd4b39;
        font-weight: bold;
    }
    .status-suspended {
        color: #f39c12;
        font-weight: bold;
    }
    .text-primary {
        color: #337ab7;
    }
    .text-primary:hover {
        color: #23527c;
        text-decoration: underline;
    }
    /* Hide the search box above table */
    .dataTables_filter {
        display: none !important;
    }
    /* Style the length menu and info to be inline in one line */
    .dataTables_length {
        display: inline-block !important;
        margin-right: 10px;
        float: left;
    }
    .dataTables_info {
        display: inline-block !important;
        float: left;
        margin-left: 10px;
    }
    /* Move pagination to right on same line */
    .dataTables_paginate {
        float: right !important;
        margin-top: 0 !important;
    }
    /* Custom styling for bottom controls - all in one line */
    .bottom {
        padding: 10px 0;
        clear: both;
        overflow: hidden;
    }
    
    /* Mobile Responsive Styles */
    @media (max-width: 767px) {
        /* Stack buttons vertically on mobile */
        .filter-row .col-xs-3 {
            width: 100%;
            margin-bottom: 5px;
        }
        
        .btn-group {
            flex-wrap: wrap !important;
        }
        
        .btn-group .btn {
            white-space: normal !important;
            flex: 1 1 48% !important;
        }
        
        /* Make filters take full width on mobile */
        .filter-row .col-xs-1,
        .filter-row .col-xs-2,
        .filter-row .col-xs-4 {
            width: 50%;
            margin-bottom: 5px;
        }
        
        /* Search field takes full width */
        .filter-row .col-xs-4 {
            width: 100%;
        }
        
        /* Hide less important columns on mobile */
        #usersTable th:nth-child(6),
        #usersTable td:nth-child(6),
        #usersTable th:nth-child(7),
        #usersTable td:nth-child(7),
        #usersTable th:nth-child(8),
        #usersTable td:nth-child(8),
        #usersTable th:nth-child(9),
        #usersTable td:nth-child(9),
        #usersTable th:nth-child(10),
        #usersTable td:nth-child(10),
        #usersTable th:nth-child(11),
        #usersTable td:nth-child(11) {
            display: none;
        }
        
        /* Make A-Z navigation wrap on mobile */
        .az-navigation .btn {
            margin: 2px;
        }
    }
    
    /* Tablet and small desktop - adjust column widths */
    @media (min-width: 768px) and (max-width: 991px) {
        .filter-row .col-xs-3 {
            width: 30%;
        }
        .filter-row .col-xs-1 {
            width: 10%;
        }
        .filter-row .col-xs-2 {
            width: 15%;
        }
        .filter-row .col-xs-4 {
            width: 25%;
        }
    }
    
    /* Desktop - shrink search field to prevent overlap */
    @media (min-width: 992px) {
        .filter-row .col-xs-4 {
            width: 30%;
        }
        #searchBox {
            max-width: 250px;
        }
    }
    
    /* Make table horizontally scrollable on all devices */
    .table-container {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
    
    /* Reduce spacing in edit customer modal to fit without scrolling */
    #editCustomerModal .modal-dialog {
        margin: 1vh auto;
    }
    
    #editCustomerModal .modal-content {
        max-height: 96vh;
        overflow: hidden;
    }
    
    #editCustomerModal .modal-header {
        padding: 8px 15px;
    }
    
    #editCustomerModal .modal-body {
        padding: 10px 15px;
        max-height: 86vh;
        overflow-y: auto;
    }
    
    #editCustomerModal .nav-tabs {
        margin-bottom: 10px !important;
    }
    
    #editCustomerModal .form-group {
        margin-bottom: 8px !important;
    }
    
    #editCustomerModal .form-group label {
        margin-bottom: 3px !important;
        font-size: 13px;
    }
    
    #editCustomerModal .form-control {
        height: 32px !important;
        padding: 5px 10px !important;
        font-size: 13px;
    }
    
    #editCustomerModal .row {
        margin-left: -5px;
        margin-right: -5px;
    }
    
    #editCustomerModal .row [class*="col-"] {
        padding-left: 5px;
        padding-right: 5px;
    }
    
    #editCustomerModal .modal-footer {
        padding: 8px 15px;
    }
    
    #editCustomerModal .btn {
        padding: 6px 12px;
        font-size: 13px;
    }
</style>
{% endblock %}

{% block content %}
<!-- Main content -->
<section class="content">
    <!-- Filters Section with Action Buttons in One Line -->
    <div class="filters-section">
        <div class="row filter-row">
            <!-- Action Buttons -->
            <div class="col-xs-3">
                <div class="btn-group" style="display: flex; gap: 2px;">
                    <a href="/admin/add-customer" class="btn btn-success" style="flex: 1; white-space: nowrap; padding: 4px 8px; font-size: 11px;">
                        <i class="fa fa-plus"></i> Add Customer
                    </a>
                </div>
            </div>
            
            <!-- Filters -->
            <div class="col-xs-1">
                <select class="form-control" id="filterStatus">
                    <option value="">Status</option>
                    <option value="Active">Active</option>
                    <option value="Deactive">Deactive</option>
                    <option value="Suspended">Suspended</option>
                    <option value="Auto Renew">Auto Renew</option>
                </select>
            </div>
            <div class="col-xs-2">
                <select class="form-control" id="filterLocality">
                    <option value="">Loading...</option>
                </select>
            </div>
            <div class="col-xs-1">
                <select class="form-control" id="filterSubscriberType">
                    <option value="Both">Both</option>
                    <option value="Cable Tv">Cable Tv</option>
                    <option value="Broadband" selected>Broadband</option>
                </select>
            </div>
            <div class="col-xs-1">
                <div class="input-group">
                    <input type="text" class="form-control" id="filterEndDate" placeholder="End Date" readonly>
                    <span class="input-group-addon" id="clearEndDate" style="padding: 4px 8px; cursor: pointer;" title="Clear date">
                        <i class="fa fa-times"></i>
                    </span>
                </div>
            </div>
            <div class="col-xs-4">
                <div class="input-group">
                    <input type="text" class="form-control" id="searchBox" placeholder="Search by name or id">
                    <span class="input-group-btn">
                        <button class="btn btn-primary" type="button" style="padding: 4px 10px;">
                            <i class="fa fa-search"></i>
                        </button>
                    </span>
                </div>
            </div>
        </div>
    </div>
    
    <!-- A-Z Navigation -->
    <div class="az-navigation">
        <button class="btn btn-default btn-sm active" data-letter="all">All</button>
        <button class="btn btn-default btn-sm" data-letter="A">A</button>
        <button class="btn btn-default btn-sm" data-letter="B">B</button>
        <button class="btn btn-default btn-sm" data-letter="C">C</button>
        <button class="btn btn-default btn-sm" data-letter="D">D</button>
        <button class="btn btn-default btn-sm" data-letter="E">E</button>
        <button class="btn btn-default btn-sm" data-letter="F">F</button>
        <button class="btn btn-default btn-sm" data-letter="G">G</button>
        <button class="btn btn-default btn-sm" data-letter="H">H</button>
        <button class="btn btn-default btn-sm" data-letter="I">I</button>
        <button class="btn btn-default btn-sm" data-letter="J">J</button>
        <button class="btn btn-default btn-sm" data-letter="K">K</button>
        <button class="btn btn-default btn-sm" data-letter="L">L</button>
        <button class="btn btn-default btn-sm" data-letter="M">M</button>
        <button class="btn btn-default btn-sm" data-letter="N">N</button>
        <button class="btn btn-default btn-sm" data-letter="O">O</button>
        <button class="btn btn-default btn-sm" data-letter="P">P</button>
        <button class="btn btn-default btn-sm" data-letter="Q">Q</button>
        <button class="btn btn-default btn-sm" data-letter="R">R</button>
        <button class="btn btn-default btn-sm" data-letter="S">S</button>
        <button class="btn btn-default btn-sm" data-letter="T">T</button>
        <button class="btn btn-default btn-sm" data-letter="U">U</button>
        <button class="btn btn-default btn-sm" data-letter="V">V</button>
        <button class="btn btn-default btn-sm" data-letter="W">W</button>
        <button class="btn btn-default btn-sm" data-letter="X">X</button>
        <button class="btn btn-default btn-sm" data-letter="Y">Y</button>
        <button class="btn btn-default btn-sm" data-letter="Z">Z</button>
    </div>
    
    <!-- Data Table -->
    <div class="table-container">
        <table id="usersTable" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Cust ID</th>
                    <th>Cust Name</th>
                    <th>User Name</th>
                    <th>Address</th>
                    <th>Mobile No</th>
                    <th>Status</th>
                    <th>Amount</th>
                    <th>Received</th>
                    <th>Balance</th>
                    <th>Exp. Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td><a href="#" class="text-primary edit-customer-link" data-customer-id="{{ user.cust_id }}" style="cursor: pointer;">{{ user.cust_id }}</a></td>
                    <td>{{ user.cust_name }}</td>
                    <td>{{ user.user_name }}</td>
                    <td>{{ user.address }}</td>
                    <td><a href="tel:{{ user.mobile }}" class="text-primary">{{ user.mobile }}</a></td>
                    <td class="status-{{ user.status|lower }}">{{ user.status }}</td>
                    <td><a href="#" class="text-primary">₹ {{ user.amount }}</a></td>
                    <td>{{ user.received }}</td>
                    <td><a href="#" class="text-primary">₹ {{ user.balance }}</a></td>
                    <td>{{ user.exp_date }}</td>
                    <td class="action-icons">
                        <a href="#" title="Add Payment"><i class="fa fa-money"></i></a>
                        <a href="#" title="Transactions"><i class="fa fa-exchange"></i></a>
                        <a href="#" title="Renew"><i class="fa fa-refresh"></i></a>
                        <a href="#" title="Send Payment Link"><i class="fa fa-send"></i></a>
                        <a href="#" title="Create Complaint"><i class="fa fa-phone"></i></a>
                        <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" title="WhatsApp" alt="WhatsApp">
                        <a href="#" title="Addon Bill"><i class="fa fa-file-text"></i></a>
                        <a href="/api/customers/{{ user.cust_id }}/download-caf" title="Download CAF" target="_blank"><i class="fa fa-download"></i></a>
                        <a href="#" title="Delete" style="color: #dd4b39;"><i class="fa fa-trash"></i></a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <!-- Edit Customer Modal -->
    <div class="modal fade" id="editCustomerModal" tabindex="-1" role="dialog" aria-labelledby="editCustomerModalLabel">
        <div class="modal-dialog modal-lg" role="document" style="width: 90%; max-width: 1200px;">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h4 class="modal-title" id="editCustomerModalLabel">
                        <i class="fa fa-edit"></i> Edit Customer
                    </h4>
                </div>
                <div class="modal-body">
                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 20px;">
                        <li role="presentation" class="active">
                            <a href="#edit-general" aria-controls="edit-general" role="tab" data-toggle="tab">
                                <i class="fa fa-info-circle"></i> General Information
                            </a>
                        </li>
                        <li role="presentation">
                            <a href="#edit-address" aria-controls="edit-address" role="tab" data-toggle="tab">
                                <i class="fa fa-map-marker"></i> Address Detail
                            </a>
                        </li>
                        <li role="presentation">
                            <a href="#edit-billing" aria-controls="edit-billing" role="tab" data-toggle="tab">
                                <i class="fa fa-file-text"></i> Billing Detail
                            </a>
                        </li>
                        <li role="presentation">
                            <a href="#edit-payment" aria-controls="edit-payment" role="tab" data-toggle="tab">
                                <i class="fa fa-credit-card"></i> Payment Detail
                            </a>
                        </li>
                    </ul>

                    <!-- Tab Content -->
                    <form id="editCustomerForm">
                        <input type="hidden" id="edit_original_customer_id" name="original_customer_id">
                        <input type="hidden" id="edit_original_plan_id" name="original_plan_id">
                        <input type="hidden" id="edit_original_start_date" name="original_start_date">
                        <input type="hidden" id="edit_original_period" name="original_period">
                        
                        <div class="tab-content">
                            <!-- General Information Tab -->
                            <div role="tabpanel" class="tab-pane active" id="edit-general">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Service Type *</label>
                                            <select class="form-control" name="service_type" id="edit_service_type">
                                                <option value="Broadband">Broadband</option>
                                                <option value="Cable">Cable</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Customer ID *</label>
                                            <input type="text" class="form-control" name="customer_id" id="edit_customer_id" readonly>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Name *</label>
                                            <input type="text" class="form-control" name="name" id="edit_name" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>User Name *</label>
                                            <input type="text" class="form-control" name="username" id="edit_username" required>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Email *</label>
                                            <input type="email" class="form-control" name="email" id="edit_email" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Mobile *</label>
                                            <input type="tel" class="form-control" name="mobile" id="edit_mobile" required>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Alternate Mobile</label>
                                            <input type="tel" class="form-control" name="alt_mobile" id="edit_alt_mobile">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>GST Invoice Needed *</label>
                                            <select class="form-control" name="gst_invoice_needed" id="edit_gst_invoice_needed">
                                                <option value="NO">NO</option>
                                                <option value="YES">YES</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Customer GST No.</label>
                                            <input type="text" class="form-control" name="customer_gst_no" id="edit_customer_gst_no">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>ID Proof *</label>
                                            <select class="form-control" name="id_proof" id="edit_id_proof">
                                                <option value="">Select ID Proof</option>
                                                <option>Voter ID</option>
                                                <option>Passport</option>
                                                <option>Driving license</option>
                                                <option>Service ID card</option>
                                                <option>Aadhar card</option>
                                                <option>Passbook of Govt bank</option>
                                                <option>Other</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>ID Proof No *</label>
                                            <input type="text" class="form-control" name="id_proof_no" id="edit_id_proof_no">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Installation/Creation Date</label>
                                            <input type="text" class="form-control" name="installation_date" id="edit_installation_date" readonly>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Tab Navigation Buttons -->
                                <div class="row" style="margin-top: 20px;">
                                    <div class="col-md-12 text-right">
                                        <button type="button" class="btn btn-default" data-dismiss="modal">
                                            <i class="fa fa-times"></i> Cancel
                                        </button>
                                        <button type="button" class="btn btn-primary" id="edit_general_next">
                                            Next <i class="fa fa-arrow-right"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Address Detail Tab -->
                            <div role="tabpanel" class="tab-pane" id="edit-address">
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="form-group">
                                            <label>Address *</label>
                                            <textarea class="form-control" name="address" id="edit_address" rows="3" required></textarea>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Locality *</label>
                                            <select class="form-control" name="locality" id="edit_locality" required>
                                                <option value="">Loading locations...</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>State *</label>
                                            <select class="form-control" name="state" id="edit_state" required>
                                                <option value="">Select State</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>District/City *</label>
                                            <input type="text" class="form-control" name="city" id="edit_city" required>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>PIN Code *</label>
                                            <input type="text" class="form-control" name="pincode" id="edit_pincode" required>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Tab Navigation Buttons -->
                                <div class="row" style="margin-top: 20px;">
                                    <div class="col-md-12 text-right">
                                        <button type="button" class="btn btn-default" id="edit_address_back">
                                            <i class="fa fa-arrow-left"></i> Back
                                        </button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal">
                                            <i class="fa fa-times"></i> Cancel
                                        </button>
                                        <button type="button" class="btn btn-primary" id="edit_address_next">
                                            Next <i class="fa fa-arrow-right"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Billing Detail Tab -->
                            <div role="tabpanel" class="tab-pane" id="edit-billing">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Plan *</label>
                                            <select class="form-control" name="plan" id="edit_plan" required>
                                                <option value="">Select Plan</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
