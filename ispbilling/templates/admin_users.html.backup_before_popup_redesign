                $('#renew_deposit_amount').text('-');
                $('#renew_installation_amount').text('-');
                $('#renew_start_date').text('-');
                
                // Initialize toggle switches with default values
                if ($.fn.bootstrapToggle) {
                    $('#renew_auto_renew').prop('checked', false);
                    $('#renew_activate_customer').prop('checked', false);
                    
                    $('#renew_auto_renew, #renew_activate_customer').bootstrapToggle({
                        size: 'small',
                        on: 'ON',
                        off: 'OFF',
                        onstyle: 'primary',
                        offstyle: 'default'
                    });
                }
            }
        });
        
        // Handle Update End Date button
        $('#btn_update_end_date').off('click').on('click', function() {
            var endDate = $('#renew_grace_date').val();
            if (!endDate) {
                alert('Please select an end date');
                return;
            }
            
            $.ajax({
                url: '/api/customers/' + customerId + '/end-date',
                method: 'PATCH',
                contentType: 'application/json',
                data: JSON.stringify({ end_date: endDate }),
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        $('#renew_end_date').text(response.end_date);
                        loadCustomers();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('Failed to update end date');
                }
            });
        });
        
        // Handle Renew with Invoice (current date)
        $('#btn_renew_with_invoice').off('click').on('click', function() {
            var months = parseInt($('#renew_with_months').val());
            if (!months) {
                alert('Please select number of months');
                return;
            }
            
            if (!confirm('Renew customer for ' + months + ' month(s) with invoice?')) {
                return;
            }
            
            $.ajax({
                url: '/api/customers/' + customerId + '/renew',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    start_from: 'today',
                    period_months: months,
                    with_invoice: true
                }),
                success: function(response) {
                    if (response.success) {
                        alert(response.message + '\nInvoice No: ' + (response.invoice_no || 'N/A'));
                        $('#renew_start_date').text(response.start_date);
                        $('#renew_end_date').text(response.end_date);
                        loadCustomers();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function(xhr) {
                    var errorMsg = 'Failed to renew customer';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    alert(errorMsg);
                }
            });
        });
        
        // Handle Renew without Invoice (current date)
        $('#btn_renew_without_invoice').off('click').on('click', function() {
            var months = parseInt($('#renew_with_months').val());
            if (!months) {
                alert('Please select number of months');
                return;
            }
            
