    // Handle Send WhatsApp button click
    $(document).on('click', '.send-whatsapp-btn', function(e) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        
        if ($(this).data('opening')) {
            return;
        }
        $(this).data('opening', true);
        var $btn = $(this);
        setTimeout(function() { $btn.removeData('opening'); }, 2000);
        
        var paymentId = $(this).data('payment-id');
        var customerPhone = String($(this).attr('data-customer-phone') || '');
        var transactionNo = $(this).data('transaction-no');
        
        if (!customerPhone || !/\d/.test(customerPhone)) {
            alert('Customer phone number not available');
            $(this).removeData('opening');
            return;
        }
        
        var cleanPhone = customerPhone.replace(/[^0-9]/g, '');
        if (cleanPhone.length === 10) {
            cleanPhone = '91' + cleanPhone;
        }
        
        var receiptUrl = window.location.origin + '/api/payments/' + paymentId + '/receipt';
        var msg = 'Dear Customer\n\nYour payment receipt (Transaction: ' + transactionNo + ') is ready.\n\nDownload: ' + receiptUrl + '\n\nThank you for your payment!';
        var encodedMsg = encodeURIComponent(msg);
        
        var ua = navigator.userAgent || '';
        var isMobile = /Android|iPhone|iPad|iPod|Windows Phone/i.test(ua);
        var isIOS = /iPhone|iPad|iPod/i.test(ua);
        
        var whatsappUrl;
        if (isMobile) {
            if (isIOS) {
                whatsappUrl = 'whatsapp://send?phone=' + cleanPhone + '&text=' + encodedMsg;
            } else {
                whatsappUrl = 'https://wa.me/' + cleanPhone + '?text=' + encodedMsg;
            }
            window.location.href = whatsappUrl;
        } else {
            whatsappUrl = 'https://web.whatsapp.com/send?phone=' + cleanPhone + '&text=' + encodedMsg;
            window.open(whatsappUrl, '_blank', 'noopener');
        }
    });
    
