                            lengthChange: false,
                            searching: false,
                            ordering: true,
                            order: [[0, 'desc']],
                            info: true,
                            paging: true,
                            pagingType: 'simple_numbers',
                            dom: 't<"row"<"col-sm-12"p>>'
                        });
                    }
                } else {
                    $('#transactionHistoryContent').html('<div class="alert alert-danger"><i class="fa fa-exclamation-triangle"></i> Error: ' + response.message + '</div>');
                }
            },
            error: function(xhr) {
                var errorMsg = 'Failed to load transactions';
                if (xhr.responseJSON && xhr.responseJSON.message) {
                    errorMsg = xhr.responseJSON.message;
                }
                $('#transactionHistoryContent').html('<div class="alert alert-danger"><i class="fa fa-exclamation-triangle"></i> ' + errorMsg + '</div>');
            }
        });
    });
    
