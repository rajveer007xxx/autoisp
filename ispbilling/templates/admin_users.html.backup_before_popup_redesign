                    if (response.success) {
                        $('#payment_transaction_no').val(response.transaction_no);
                        transactionNoGenerated = true;
                    }
                },
                error: function() {
                    console.log('Failed to generate transaction number');
                }
            });
        }
    }
    
    $('#payment_paying_amount, #payment_discount').on('input change', function() {
        calculateBalanceAfterPayment();
        generateTransactionNumber();
    });
    
    // Regenerate transaction number when payment mode changes
