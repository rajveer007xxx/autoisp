    // Live calculation of Balance after payment
    function calculateBalanceAfterPayment() {
        var totalDueStr = $('#payment_total_due').val().replace('₹', '').replace(',', '').trim();
        var totalDue = parseFloat(totalDueStr) || 0;
        var payingAmount = parseFloat($('#payment_paying_amount').val()) || 0;
        var discount = parseFloat($('#payment_discount').val()) || 0;
        
        // Allow negative balances (credit/advance payments)
        var balanceAfter = totalDue - (payingAmount + discount);
        
        // Display with visual cue for negative (credit)
        if (balanceAfter < 0) {
            $('#payment_balance_after').val('₹' + balanceAfter.toFixed(2) + ' (Credit)').css('color', 'red');
        } else {
            $('#payment_balance_after').val('₹' + balanceAfter.toFixed(2)).css('color', '');
        }
    }
    
