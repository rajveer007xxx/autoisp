                            var dateStr = txn.paid_at;
                            var timestamp = 0;
                            var monthIndex = -1;
                            
                            var ddmmyyyyMatch = dateStr.match(/^(\d{2})-(\d{2})-(\d{4})\s+(\d{2}):(\d{2})$/);
                            if (ddmmyyyyMatch) {
                                var day = parseInt(ddmmyyyyMatch[1]);
                                var month = parseInt(ddmmyyyyMatch[2]) - 1;
                                var year = parseInt(ddmmyyyyMatch[3]);
                                var hour = parseInt(ddmmyyyyMatch[4]);
                                var minute = parseInt(ddmmyyyyMatch[5]);
                                timestamp = new Date(year, month, day, hour, minute).getTime();
                                monthIndex = month;
                                monthsSet.add(monthIndex);
                            }
                            
                            txn._timestamp = timestamp;
                            txn._monthIndex = monthIndex;
                        });
                        
                        response.transactions.sort(function(a, b) {
                            return b._timestamp - a._timestamp;
                        });
                        
                        var html = '<div class="table-responsive"><table id="txnTable" class="table table-bordered table-striped" style="font-size: 12px;"><thead><tr><th>Date & Time</th><th>Transaction No</th><th>Total Due Balance</th><th>Amount</th><th>Discount</th><th>Balance After Payment</th><th>Payment Mode</th><th>Employee</th><th>Remarks</th><th>Actions</th></tr></thead><tbody>';
                        
