    if company_ids:
        rows = db.query(
            Customer.company_id,
            _func.count(Customer.id)
        ).filter(
            Customer.company_id.in_(company_ids),
            (Customer.status == None) | (_func.lower(Customer.status) != 'deleted')
        ).group_by(Customer.company_id).all()
        counts_by_company = {cid: int(cnt or 0) for cid, cnt in rows}

    data = []
