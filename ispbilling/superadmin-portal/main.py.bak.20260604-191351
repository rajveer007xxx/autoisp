def _payment_prefix(method):
    if not method:
        return 'TXN'
    return PAYMENT_METHOD_PREFIX.get(str(method).strip().lower(), 'TXN')

def _generate_payment_reference(payment_method, db):
    """Generate a unique payment reference number with a prefix based on the
    payment method (e.g. CSH4434 for Cash, PPY9812 for PhonePay)."""
    from database import Transaction
    prefix = _payment_prefix(payment_method)
    for _ in range(20):
        ref = f"{prefix}{random.randint(1000, 9999)}"
        exists = db.query(Transaction).filter(Transaction.reference_no == ref).first()
        if not exists:
            return ref
    # Fall back to a longer random suffix if we keep colliding
    return f"{prefix}{random.randint(100000, 999999)}"

def _generate_superadmin_receipt_pdf(transaction, company, db):
    """Render and save a PDF receipt for an admin-subscription payment so the
    per-admin transaction history popup can download it and the email endpoint
    can attach it."""
    from reportlab.lib.pagesizes import A4
    from reportlab.pdfgen import canvas
