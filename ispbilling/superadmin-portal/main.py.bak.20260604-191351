# # __s56r_sa_wg_laptop__
#  Remote Mikrotik access — SuperAdmin only.
#  Mint a per-session WireGuard peer config the SuperAdmin imports
#  into the WireGuard app on their laptop / phone. Once connected they
#  are on 10.50.0.0/16 and can WinBox / WebFig / SSH any onboarded
#  Mikrotik at its tunnel IP (e.g. 10.50.128.2).
# ─────────────────────────────────────────────────────────────────────
import subprocess as _sa_wg_sp
import secrets as _sa_wg_sec
import ipaddress as _sa_wg_ip
import threading as _sa_wg_th
import re as _sa_wg_re
import os as _sa_wg_os
from fastapi import Response as _SaWgResponse

_SA_WG_LOCK = _sa_wg_th.Lock()
_SA_WG_CONF = "/etc/wireguard/wg0.conf"
_SA_WG_POOL = "10.50.250.0/24"
_SA_WG_SERVER_PUB = "/etc/wireguard/server_public.key"
_SA_WG_ENDPOINT = "185.199.53.93:51820"


def _sa_wg_genkeys():
    priv = _sa_wg_sp.run(["wg", "genkey"], capture_output=True, text=True,
                         check=True).stdout.strip()
    pub  = _sa_wg_sp.run(["wg", "pubkey"], input=priv, capture_output=True,
                         text=True, check=True).stdout.strip()
    return priv, pub


def _sa_wg_used_ips():
    used = set()
    try:
        for m in _sa_wg_re.finditer(
                r"AllowedIPs\s*=\s*([\d./, ]+)",
                open(_SA_WG_CONF).read()):
            for tok in m.group(1).split(","):
                ip = tok.strip().split("/")[0]
                if ip: used.add(ip)
    except Exception:
        pass
    try:
        out = _sa_wg_sp.run(["wg", "show", "wg0", "allowed-ips"],
                            capture_output=True, text=True, timeout=5).stdout
        for line in out.splitlines():
            for tok in line.strip().split()[1:]:
                ip = tok.split("/")[0]
                if ip: used.add(ip)
    except Exception:
        pass
    return used


def _sa_wg_next_ip():
    pool = _sa_wg_ip.ip_network(_SA_WG_POOL)
    used = _sa_wg_used_ips()
    for host in pool.hosts():
        s = str(host)
        if s.endswith(".0") or s.endswith(".1"):
            continue
        if s not in used:
            return s
    raise RuntimeError("Admin WG pool exhausted")


def _sa_wg_persist(pubkey, addr, label):
    with open(_SA_WG_CONF, "a") as f:
        f.write(f"\n# {label}\n[Peer]\nPublicKey = {pubkey}\n"
                f"AllowedIPs = {addr}/32\n")


def _sa_wg_live_add(pubkey, addr):
    _sa_wg_sp.run(["wg", "set", "wg0", "peer", pubkey,
                   "allowed-ips", f"{addr}/32"],
                  check=True, capture_output=True)


def _sa_wg_live_remove(pubkey):
    _sa_wg_sp.run(["wg", "set", "wg0", "peer", pubkey, "remove"],
                  check=False, capture_output=True)


def _sa_wg_persist_remove(pubkey):
    """Remove the peer block from wg0.conf so it doesn't come back on
    `wg-quick down/up`. Idempotent."""
    try:
        conf = open(_SA_WG_CONF).read()
    except Exception:
        return
    # Strip the comment-line + [Peer] block whose PublicKey matches.
    pat = _sa_wg_re.compile(
        r"\n# admin-laptop-[^\n]*\n\[Peer\]\nPublicKey = "
        + _sa_wg_re.escape(pubkey)
        + r"\nAllowedIPs = [0-9./]+\n",
        _sa_wg_re.MULTILINE,
    )
    new = pat.sub("\n", conf)
    if new != conf:
        open(_SA_WG_CONF, "w").write(new)


@app.get("/api/sa/wg-laptop-peer")
def api_sa_wg_laptop_peer(request: Request):
    """Issue a fresh WireGuard config the SuperAdmin imports into their
    laptop / phone. SUPERADMIN ONLY — tenant admins cannot reach this.
    Server keeps only the public key; the private key is never persisted."""
    auth = require_superadmin(request)
    if auth is not None:
        return auth
    actor = (request.session.get("user_id") or
             request.session.get("user_name") or "superadmin")
    label = (f"admin-laptop-SA-{actor}-"
             f"{int(__import__('time').time())}")
    label = _sa_wg_re.sub(r"[^A-Za-z0-9._-]+", "-", label)[:60]
    try:
        server_pub = open(_SA_WG_SERVER_PUB).read().strip()
    except Exception:
        raise HTTPException(500, "WireGuard server public key not found")
    if not server_pub:
        raise HTTPException(500, "Empty server public key")
    with _SA_WG_LOCK:
        priv, pub = _sa_wg_genkeys()
        addr = _sa_wg_next_ip()
        _sa_wg_live_add(pub, addr)
        _sa_wg_persist(pub, addr, label)
    conf = (
        f"# {label}\n"
        f"# Issued: {__import__('datetime').datetime.utcnow().isoformat()}Z\n"
        f"# SuperAdmin laptop access — reach any onboarded Mikrotik on 10.50.x.x.\n"
        f"# After connecting, point WinBox / WebFig / SSH at e.g. 10.50.128.2:8291.\n"
        f"\n"
        f"[Interface]\n"
        f"PrivateKey = {priv}\n"
        f"Address = {addr}/32\n"
        f"DNS = 1.1.1.1\n"
        f"\n"
        f"[Peer]\n"
        f"PublicKey = {server_pub}\n"
        f"AllowedIPs = 10.50.0.0/16\n"
        f"Endpoint = {_SA_WG_ENDPOINT}\n"
        f"PersistentKeepalive = 25\n"
    )
    headers = {"Content-Disposition":
               f'attachment; filename="ispbilling-sa-laptop-{addr}.conf"'}
    return _SaWgResponse(content=conf, media_type="text/plain", headers=headers)


@app.get("/api/sa/wg-laptop-peers")
def api_sa_wg_laptop_peers_list(request: Request):
    """List active SuperAdmin laptop peer addresses in 10.50.250.0/24."""
    auth = require_superadmin(request)
    if auth is not None:
        return auth
    peers = []
    try:
        cur_label = None
        cur_pub = None
        for line in open(_SA_WG_CONF):
            line = line.rstrip("\n")
            if line.startswith("# admin-laptop-SA-"):
                cur_label = line.lstrip("# ")
                cur_pub = None
            elif line.startswith("PublicKey") and cur_label:
                cur_pub = line.split("=", 1)[1].strip()
            elif line.startswith("AllowedIPs") and cur_label and cur_pub:
                m = _sa_wg_re.search(r"10\.50\.250\.\d+", line)
                if m:
                    peers.append({"label": cur_label,
                                  "address": m.group(0),
                                  "pubkey": cur_pub})
                cur_label = None
                cur_pub = None
    except Exception:
        pass
    return {"peers": peers}


@app.post("/api/sa/wg-laptop-peer/revoke")
def api_sa_wg_laptop_peer_revoke(request: Request):
    """Revoke a previously-issued SuperAdmin laptop peer by public key."""
    auth = require_superadmin(request)
    if auth is not None:
        return auth
    import json as _j
    try:
        body = _j.loads(request._body if hasattr(request, "_body") else b"{}")
    except Exception:
        body = {}
    pubkey = (body.get("pubkey") or "").strip()
    if not pubkey:
        raise HTTPException(400, "pubkey required")
    with _SA_WG_LOCK:
        _sa_wg_live_remove(pubkey)
        _sa_wg_persist_remove(pubkey)
    return {"success": True, "revoked": pubkey}
