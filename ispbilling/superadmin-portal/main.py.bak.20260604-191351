@app.post("/api/auth/login")
async def login(
    request: Request,
    userType: str = Form(...),
    userId: str = Form(...),
    password: str = Form(...),
    companyId: str = Form(None),
    db: Session = Depends(get_db)
):
    user = None
    
    if userType == "superadmin":
        user = authenticate_superadmin(db, userId, password)
        if user:
            request.session["user_id"] = user.superadmin_id
            request.session["user_type"] = "superadmin"
            request.session["user_name"] = user.superadmin_name or "Super Administrator"
            request.session["superadmin_id"] = user.id
            return JSONResponse({"success": True, "redirect": "/superadmin/dashboard"})
    
    elif userType == "admin":
        if not companyId:
            return JSONResponse({"success": False, "message": "Company ID is required for Admin login"}, status_code=400)
        user = authenticate_admin(db, companyId, userId, password)
        if user:
            from database import Company, SuperAdminSettings, SuperAdmin as _SA
            company = db.query(Company).filter(Company.company_id == user.company_id).first()
            balance = float(company.balance_amount or 0) if company else 0.0
            status_val = (company.status or "Active") if company else "Active"
            # Only block when the account is NOT Active. Admins with due but still Active can log in.
            if status_val.lower() != "active":
                has_due = balance > 0
                settings = db.query(SuperAdminSettings).filter(SuperAdminSettings.id == 1).first()
                sa = db.query(_SA).filter(_SA.id == 1).first()
                reasons = [f"Account status is {status_val}"]
                if has_due:
                    reasons.append(f"Due amount pending: \u20b9{balance:,.2f}")
                if has_due:
                    message = "Your admin account has been deactivated due to a pending due amount. Clear the outstanding balance to regain access."
                else:
                    message = f"Your admin account has been {status_val}. Please contact the superadmin support team for assistance."
                return JSONResponse({
                    "success": False,
                    "blocked": True,
                    "has_due": has_due,
                    "message": message,
                    "reasons": reasons,
                    "status": status_val,
                    "due_amount": round(balance, 2),
                    "company_id": user.company_id,
                    "company_name": company.company_name if company else None,
                    "admin_name": user.admin_name,
                    "admin_email": user.admin_email,
                    "upi_id": (settings.upi_id if settings else None),
                    "qr_code_path": (settings.qr_code_path if settings else None),
                    "bank_name": (settings.bank_name if settings else None),
                    "branch_code": (settings.branch_code if settings else None),
                    "account_no": (settings.account_no if settings else None),
                    "branch_location": (settings.branch_location if settings else None),
                    "ifsc_code": (settings.ifsc_code if settings else None),
                    "superadmin_contact_email": (settings.contact_email if settings else (sa.email if sa else None)),
                    "superadmin_contact_phone": (settings.contact_number if settings else (sa.mobile if sa else None)),
                })
            request.session["user_id"] = user.admin_id
            request.session["user_type"] = "admin"
            request.session["user_name"] = user.admin_name
            request.session["company_id"] = user.company_id
            return JSONResponse({"success": True, "redirect": "/admin/dashboard"})
    
    elif userType == "employee":
        if not companyId:
            return JSONResponse({"success": False, "message": "Company ID is required for Employee login"}, status_code=400)
        user = authenticate_employee(db, companyId, userId, password)
        if user:
            request.session["user_id"] = user.employee_code
            request.session["user_type"] = "employee"
            request.session["user_name"] = user.employee_name
            request.session["company_id"] = user.company_id
            request.session["employee_id"] = user.id
            return JSONResponse({"success": True, "redirect": "/employee/dashboard"})
    
    elif userType == "customer":
        user = authenticate_customer(db, userId, password)
        if user:
            request.session["user_id"] = user.customer_id
            request.session["user_type"] = "customer"
            request.session["user_name"] = user.customer_name
            return JSONResponse({"success": True, "redirect": "/customer/dashboard"})
    
    return JSONResponse({"success": False, "message": "Invalid credentials"}, status_code=401)

