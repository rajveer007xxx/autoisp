async def sa_bulk_send_admin_pay_reminder(request: Request,
                                           background_tasks: BackgroundTasks,
                                           db: Session = Depends(get_db)):
    """Send WhatsApp renewal reminders to ALL non-Active admin accounts
    (Suspended / Deactive / Deactivated / Expired) with a mobile number."""
    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "unauthorized"}, status_code=401)
    from database import Admin, Company
    bad_status = ["Suspended", "Deactive", "Deactivated", "Expired"]
    companies = db.query(Company).filter(Company.status.in_(bad_status)).all()
    host = os.environ.get("MAIN_DOMAIN", "autoispbilling.com")
    items = []
    skipped = 0
    for c in companies:
        admin = db.query(Admin).filter(Admin.company_id == c.company_id).first()
        if not admin or not (admin.admin_mobile or "").strip():
            skipped += 1
            continue
        items.append({
            "phone":  admin.admin_mobile,
            "name":   admin.admin_name or admin.admin_id,
            "company_name": c.company_name or c.company_id,
            "status": c.status,
            "amount": float(c.balance_amount or 0.0),
            "url":    f"https://{host}/admin/renew?company={c.company_id}",
        })
    queued = len(items)
    def _runner(batch):
        import time
        from twilio_whatsapp import send_admin_reminder
        ok = fail = 0
        per_sec = float(os.environ.get("TWILIO_RATE_LIMIT_PER_SEC", "1") or 1)
        gap = 1.0 / per_sec if per_sec > 0 else 0
        for it in batch:
            reason_map = {"Suspended": "suspended",
                          "Deactive": "deactivated",
                          "Deactivated": "deactivated",
                          "Expired": "expired"}
            r = send_admin_reminder(
                phone=it["phone"], admin_name=it["name"],
                company_name=it["company_name"], pay_url=it["url"],
                amount_due=it.get("amount") or 0,
                reason=reason_map.get(it.get("status") or "", "inactive"))
            if r.get("success"): ok += 1
            else: fail += 1
            if gap: time.sleep(gap)
        print(f"[s27-sa-bulk-wa] ok={ok} failed={fail} total={ok+fail}")
    background_tasks.add_task(_runner, items)
    return {"success": True, "queued": queued, "skipped": skipped,
            "total_inactive": len(companies),
            "message": f"Queued {queued} admin-reminder WhatsApp messages."}
