        f_method = (request.query_params.get("payment_method") or "").strip()

        query = db.query(
            Transaction,
            Company.company_name,
            Company.company_id,
            Admin.admin_name,
            Admin.admin_mobile,
            Invoice.invoice_no.label('invoice_number')
        ).outerjoin(
            Invoice, Transaction.invoice_id == Invoice.id
        ).outerjoin(
            Company, Transaction.customer_id == Company.company_id
        ).outerjoin(
            Admin, Transaction.customer_id == Admin.company_id
        ).filter(
            Transaction.company_id == "SUPERADMIN"
        )

        if search_value:
            like = f"%{search_value}%"
            query = query.filter(or_(
                Company.company_name.ilike(like),
                Company.company_id.ilike(like),
                Admin.admin_name.ilike(like),
                Admin.admin_mobile.ilike(like),
                cast(Invoice.invoice_no, String).ilike(like),
                Transaction.reference_no.ilike(like),
                Transaction.remarks.ilike(like),
            ))

        if f_type and f_type != "all":
            query = query.filter(func.lower(Transaction.transaction_type) == f_type)

        if f_admin:
            alike = f"%{f_admin}%"
            query = query.filter(or_(
                Company.company_name.ilike(alike),
                Company.company_id.ilike(alike),
                Admin.admin_name.ilike(alike),
            ))

        if f_method:
            query = query.filter(Transaction.payment_method == f_method)

        def _parse_date(s):
            for fmt in ("%Y-%m-%d", "%d/%m/%Y", "%d-%m-%Y"):
                try:
                    return _dt.strptime(s, fmt)
                except ValueError:
                    pass
            return None

        if f_from:
            dt = _parse_date(f_from)
            if dt is not None:
                query = query.filter(Transaction.transaction_date >= dt)
        if f_to:
            dt = _parse_date(f_to)
            if dt is not None:
                dt = dt.replace(hour=23, minute=59, second=59)
                query = query.filter(Transaction.transaction_date <= dt)

        try:
            if f_min:
                query = query.filter(Transaction.amount >= float(f_min))
            if f_max:
                query = query.filter(Transaction.amount <= float(f_max))
        except ValueError:
            pass

        total_records = query.count()
        
        transactions = query.order_by(Transaction.created_at.desc()).offset(start).limit(length).all()
        
        data = []
        for t, company_name, company_id, admin_name, admin_mobile, invoice_number in transactions:
            trans_date = t.transaction_date or t.created_at
            if hasattr(trans_date, 'isoformat'):
                date_str = trans_date.isoformat()
            elif isinstance(trans_date, str):
                date_str = trans_date
            else:
                date_str = 'N/A'
            
            data.append({
                "invoice_number": str(invoice_number) if invoice_number else "N/A",
                "admin_name": admin_name or "N/A",
                "company_name": company_name or "N/A",
                "company_id": company_id or "",
                "mobile_number": admin_mobile or "N/A",
                "transaction_type": t.transaction_type or "Payment",
                "amount": float(t.amount) if t.amount else 0.0,
                "transaction_date": date_str,
                "invoice_id": t.invoice_id
            })
        
        return JSONResponse({
            "draw": draw,
            "recordsTotal": total_records,
            "recordsFiltered": total_records,
            "data": data
        })
    except Exception as e:
        import traceback
        error_detail = traceback.format_exc()
        print(f"Error in get_all_transactions_api: {error_detail}")
        return JSONResponse({"error": str(e), "detail": error_detail}, status_code=500)

@app.post("/api/superadmin/admins/{company_id}/renew")
async def renew_admin_subscription_api(company_id: str, request: Request, background_tasks: BackgroundTasks, db: Session = Depends(get_db)):
    """Renew admin subscription: extend end_date, create invoice + transaction,
    generate PDF and email it to the admin."""
    from database import Company, Admin, Invoice, Transaction, SuperAdminPackage, SuperAdminSettings
    from datetime import datetime
    from dateutil.relativedelta import relativedelta
    import os

    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"error": "Unauthorized"}, status_code=401)

    try:
        data = await request.json()
        period_months = int(data.get("period_months", data.get("months", 1)))
        gst_invoice_needed = bool(data.get("gst_invoice_needed", False))
        start_date_str = (data.get("start_date") or "").strip()
        package_name_posted = (data.get("package_name") or "").strip()

        company = db.query(Company).filter(Company.company_id == company_id).first()
        if not company:
            return JSONResponse({"success": False, "message": "Company not found"}, status_code=404)

        admin = db.query(Admin).filter(Admin.company_id == company_id).first()
        if not admin:
            return JSONResponse({"success": False, "message": "Admin not found"}, status_code=404)

        package_lookup = package_name_posted or company.package
        package = db.query(SuperAdminPackage).filter(SuperAdminPackage.package_name == package_lookup).first()
        if not package:
            return JSONResponse({"success": False, "message": f"Package not found: {package_lookup}"}, status_code=404)

        # Persist the selected package on the company so the invoice/UI reflect it
        if package_name_posted and package_name_posted != company.package:
            company.package = package_name_posted

        now = datetime.now()
        if start_date_str:
            try:
                start_date = datetime.strptime(start_date_str, '%Y-%m-%d')
            except ValueError:
                start_date = now
        else:
            existing_end = company.end_date if company.end_date else now
            start_date = existing_end if existing_end > now else now
        end_date = start_date + relativedelta(months=period_months)

        price = float(package.package_price) * period_months

        # Use configurable per-package tax rates and apply them on top of the
        # base price. Intra-state (admin in same state as superadmin) uses
        # CGST + SGST; inter-state uses IGST. This mirrors create_admin logic.
        cgst_rate = float(package.cgst_rate) if package.cgst_rate is not None else 9.0
        sgst_rate = float(package.sgst_rate) if package.sgst_rate is not None else 9.0
        igst_rate = float(package.igst_rate) if package.igst_rate is not None else 18.0

        sa_settings_for_state = db.query(SuperAdminSettings).first()
        superadmin_state = (sa_settings_for_state.state if sa_settings_for_state and sa_settings_for_state.state else "") or ""
        sa_state_name, _ = get_state_info(superadmin_state)
        ad_state_name, _ = get_state_info(company.state or "")
        intra_state = bool(sa_state_name) and bool(ad_state_name) and (sa_state_name.strip().lower() == ad_state_name.strip().lower())

        if gst_invoice_needed:
            if intra_state:
                cgst = round(price * cgst_rate / 100.0, 2)
                sgst = round(price * sgst_rate / 100.0, 2)
                igst = 0.0
            else:
                cgst = 0.0
                sgst = 0.0
                igst = round(price * igst_rate / 100.0, 2)
            base_amt = round(price, 2)
            total_amt = round(base_amt + cgst + sgst + igst, 2)
        else:
            base_amt = round(price, 2)
            cgst = 0.0
            sgst = 0.0
            igst = 0.0
            total_amt = base_amt

        # Generate sequential invoice number under the SUPERADMIN namespace
        from sqlalchemy import text
        invoice_counter = db.execute(
            text("SELECT COUNT(*) FROM invoices WHERE company_id = :cid"),
            {"cid": "SUPERADMIN"}
        ).scalar()
        invoice_no = f"SA-INV-{(invoice_counter or 0) + 1:06d}"

        issue_date = now
        due_date = issue_date + relativedelta(days=7)

        invoice = Invoice(
            company_id="SUPERADMIN",
            customer_id=company_id,
            invoice_no=invoice_no,
            issue_date=issue_date.strftime('%Y-%m-%d'),
            due_date=due_date.strftime('%Y-%m-%d'),
            start_date=start_date.strftime('%Y-%m-%d'),
            end_date=end_date.strftime('%Y-%m-%d'),
            period_months=period_months,
            plan_id=None,
            plan_name=company.package,
            base_amount=base_amt,
            cgst_tax=cgst,
            sgst_tax=sgst,
            igst_tax=igst,
            total_amount=total_amt,
            status='generated'
        )
        db.add(invoice)
        db.flush()

        transaction = Transaction(
            company_id="SUPERADMIN",
            customer_id=company_id,
            transaction_type='renewal',
            amount=total_amt,
            invoice_id=invoice.id,
            start_date=start_date.strftime('%Y-%m-%d'),
            end_date=end_date.strftime('%Y-%m-%d'),
            period_months=period_months,
            remarks=f"Renewal - {period_months} month(s)",
            payment_method=None,
            reference_no=invoice_no,
            note=f"Admin renewal: {invoice_no}",
            transaction_date=now,
            created_at=now
        )
        db.add(transaction)

        # Update company end_date, balance, and status
        company.end_date = end_date
        company.balance_amount = float(company.balance_amount or 0.0) + total_amt
        company.status = 'Deactivated'

        # Build PDF
        settings = db.query(SuperAdminSettings).first()
        superadmin_gst = settings.gst_number if (settings and gst_invoice_needed) else ""

        invoice_data = {
            'invoice_no': invoice_no,
            'issue_date': issue_date.strftime('%Y-%m-%d'),
            'due_date': due_date.strftime('%Y-%m-%d'),
            'start_date': start_date.strftime('%Y-%m-%d'),
            'end_date': end_date.strftime('%Y-%m-%d'),
            'plan_name': company.package,
            'period_months': period_months,
            'base_amount': base_amt,
            'cgst_tax': cgst,
            'sgst_tax': sgst,
            'igst_tax': 0.0,
            'total_amount': total_amt,
            'customer_name': admin.admin_name,
            'prev_due_total': 0.0,
        }
        company_data = {
            'company_name': 'AUTO ISP BILLING',
            'company_address': 'India',
            'company_phone': '+91-8085868114',
            'company_email': 'support@autoispbilling.com',
            'state': 'Madhya Pradesh',
            'gst_number': superadmin_gst,
            'bank_name': (settings.bank_name if settings else '') or '',
            'account_number': (settings.account_no if settings else '') or '',
            'branch_ifsc': (settings.ifsc_code if settings else '') or '',
            'upi_id': (settings.upi_id if settings else '') or '',
            'declaration': (settings.declaration if settings else '') or 'Thank you for choosing Auto ISP Billing.',
            'terms_conditions': (settings.terms_conditions if settings else '') or 'Payment is due within 7 days of invoice date.'
        }
        customer_data = {
            'customer_name': admin.admin_name or '',
            'username': admin.admin_id or '',
            'address': company.company_address or '',
            'customer_gst_no': (company.gst_number or '') if gst_invoice_needed else '',
            'state': company.state or '',
            'city': company.city or '',
            'mobile': admin.admin_mobile or '',
            'billing_type': 'PREPAID',
            'category': 'ISP Management Software',
            'gst_invoice_needed': 'Yes' if gst_invoice_needed else 'No'
        }

        pdf_data = None
        try:
            pdf_data = generate_invoice_pdf(invoice_data, company_data, customer_data, [])
            pdf_dir = "/var/lib/autoispbilling/invoices/SUPERADMIN"
            os.makedirs(pdf_dir, exist_ok=True)
            pdf_path = f"{pdf_dir}/{invoice_no}.pdf"
            with open(pdf_path, 'wb') as f:
                f.write(pdf_data)
            invoice.pdf_path = pdf_path
        except Exception as pdf_err:
            print(f"Warning: PDF generation failed during renew for {company_id}: {pdf_err}")
            import traceback
            print(traceback.format_exc())

        db.commit()

        # Email the renewal invoice to the admin in the background
        if admin.admin_email and pdf_data:
            admin_info = {
                'name': admin.admin_name,
                'email': admin.admin_email,
                'mobile': admin.admin_mobile,
                'company_id': company_id,
                'admin_id': admin.admin_id,
            }
            invoice_info = {
                'invoice_no': invoice_no,
                'issue_date': invoice_data['issue_date'],
                'due_date': invoice_data['due_date'],
                'start_date': invoice_data['start_date'],
                'end_date': invoice_data['end_date'],
                'package_name': company.package,
                'total_amount': total_amt,
            }
            background_tasks.add_task(
                send_admin_welcome_email_background,
                db,
                admin_info,
                False,
                invoice_info,
                pdf_data,
                True,
            )

        return JSONResponse({
            "success": True,
            "message": "Subscription renewed successfully. Invoice email is being sent.",
            "invoice_no": invoice_no,
            "end_date": end_date.strftime('%Y-%m-%d'),
            "new_end_date": end_date.strftime('%Y-%m-%d'),
            "balance_amount": company.balance_amount,
            "new_balance": company.balance_amount,
            "status": company.status,
        })

    except Exception as e:
        db.rollback()
        import traceback
        return JSONResponse({
            "success": False,
            "message": f"Failed to renew subscription: {str(e)}",
            "detail": traceback.format_exc()
        }, status_code=400)

@app.post("/api/superadmin/admins/{company_id}/record-payment")
async def record_admin_payment_api(company_id: str, request: Request, db: Session = Depends(get_db)):
    """Record payment for admin subscription"""
    from database import Company, Transaction
    from datetime import datetime
    
    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"error": "Unauthorized"}, status_code=401)
    
    try:
        data = await request.json()
        amount = float(data.get("amount", 0))
        payment_method = data.get("payment_method", "Cash")
        reference_no = data.get("reference_no", "")
        note = data.get("note", "")
        
        company = db.query(Company).filter(Company.company_id == company_id).first()
        if not company:
            return JSONResponse({"success": False, "message": "Company not found"}, status_code=404)
        
        new_balance = (company.balance_amount or 0.0) - amount
        company.balance_amount = new_balance

        # Auto-generate payment-mode-prefixed reference number when not supplied
        if not reference_no:
            reference_no = _generate_payment_reference(payment_method, db)

        transaction = Transaction(
            company_id="SUPERADMIN",
            customer_id=company_id,
            transaction_type="Payment",
            amount=amount,
            payment_method=payment_method,
            reference_no=reference_no,
            note=note,
            remarks=f"Payment received - {payment_method}",
            transaction_date=datetime.now(),
            created_at=datetime.now()
        )
        db.add(transaction)
        db.flush()

        # Generate a receipt PDF so the download/resend endpoints work
        try:
            _generate_superadmin_receipt_pdf(transaction, company, db)
        except Exception as _rcp_err:
            print(f"Warning: receipt PDF generation failed for txn {transaction.id}: {_rcp_err}")

        # Auto-reactivate admin when due is cleared: any non-Active status -> Active.
        status_changed = False
        if new_balance <= 0 and (company.status or "").strip().lower() != "active":
            company.status = "Active"
            status_changed = True

        db.commit()

        return JSONResponse({
            "success": True,
            "message": "Payment recorded successfully",
            "new_balance": float(company.balance_amount),
            "status": company.status,
            "status_changed": status_changed,
        })
        
    except Exception as e:
        db.rollback()
        return JSONResponse({
            "success": False,
            "message": f"Failed to record payment: {str(e)}"
        }, status_code=400)

