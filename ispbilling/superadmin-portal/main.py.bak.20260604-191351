@app.post("/api/superadmin/admins/{company_id}/change-password")
async def change_admin_password(company_id: str, request: Request, db: Session = Depends(get_db)):
    """Session 25.13 - superadmin force-resets an admin's login password."""
    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "unauthorized"}, status_code=401)
    from database import Admin
    try:
        body = await request.json()
    except Exception:
        body = {}
    new_pw = (body.get("new_password") or "").strip()
    confirm = (body.get("confirm_password") or "").strip()
    if not new_pw or len(new_pw) < 4:
        return {"success": False, "message": "Password must be at least 4 characters."}
    if new_pw != confirm:
        return {"success": False, "message": "Passwords do not match."}
    admin = db.query(Admin).filter(Admin.company_id == company_id).first()
    if not admin:
        return JSONResponse({"success": False, "message": "admin not found"}, status_code=404)
    from auth import get_password_hash as _gph
    admin.password_hash = _gph(new_pw)
    db.commit()
    return {"success": True, "admin_id": admin.admin_id,
            "message": f"Password updated for {admin.admin_id}."}

