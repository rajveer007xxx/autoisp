        package = db.query(SuperAdminPackage).filter(SuperAdminPackage.package_name == package_name).first()

        gst_invoice_needed = int(form_data.get("gst_invoice_needed", 1))

        # Compute GST on top of the package base price. The package's CGST/SGST/IGST
        # rates are configurable in the superadmin packages UI. Intra-state (admin
        # in the same state as the superadmin) = CGST + SGST; inter-state = IGST.
        base_price_total = float(package.package_price) * period_months if package else 0.0
        cgst_rate = float(package.cgst_rate) if (package and package.cgst_rate is not None) else 9.0
        sgst_rate = float(package.sgst_rate) if (package and package.sgst_rate is not None) else 9.0
        igst_rate = float(package.igst_rate) if (package and package.igst_rate is not None) else 18.0

        _sa_settings_for_state = db.query(SuperAdminSettings).first()
        superadmin_state = (_sa_settings_for_state.state if _sa_settings_for_state and _sa_settings_for_state.state else "") or ""
