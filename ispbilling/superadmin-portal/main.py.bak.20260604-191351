@app.post("/api/superadmin/profile/smtp/test")
async def test_smtp_connection(request: Request):
    """Test SMTP connection"""
    import smtplib
    
    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"error": "Unauthorized"}, status_code=401)
    
    try:
        data = await request.json()
        
        # Validate required fields
        if not all(key in data for key in ["smtp_server", "smtp_port", "smtp_username", "smtp_password"]):
            return JSONResponse({"error": "Missing required SMTP fields"}, status_code=400)
        
        smtp_server = data["smtp_server"]
        smtp_port = int(data["smtp_port"])
        smtp_username = data["smtp_username"]
        smtp_password = data["smtp_password"]
        
        try:
            if smtp_port == 465:
                server = smtplib.SMTP_SSL(smtp_server, smtp_port, timeout=10)
            else:
                server = smtplib.SMTP(smtp_server, smtp_port, timeout=10)
                server.starttls()
            
            server.login(smtp_username, smtp_password)
            server.quit()
            
            return JSONResponse({"success": True, "message": "SMTP connection test successful"})
            
        except smtplib.SMTPAuthenticationError:
            return JSONResponse({"success": False, "message": "SMTP authentication failed. Please check username and password."}, status_code=200)
        except smtplib.SMTPConnectError:
            return JSONResponse({"success": False, "message": "Failed to connect to SMTP server. Please check server and port."}, status_code=200)
        except Exception as smtp_error:
            return JSONResponse({"success": False, "message": f"SMTP test failed: {str(smtp_error)}"}, status_code=200)
        
    except Exception as e:
        return JSONResponse({"error": str(e)}, status_code=500)


@app.post("/api/superadmin/profile/password")
async def change_superadmin_password(request: Request, db: Session = Depends(get_db)):
    """Change superadmin password"""
    from database import SuperAdmin
    import bcrypt
    
    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"error": "Unauthorized"}, status_code=401)
    
    try:
        data = await request.json()
        
        # Validate required fields
        if not all(key in data for key in ["current_password", "new_password"]):
            return JSONResponse({"error": "Missing required fields"}, status_code=400)
        
        current_password = data["current_password"]
        new_password = data["new_password"]
        
        # Validate new password length
        if len(new_password) < 8:
            return JSONResponse({"error": "New password must be at least 8 characters long"}, status_code=400)
        
        superadmin = db.query(SuperAdmin).filter(SuperAdmin.id == 1).first()
        if not superadmin:
            return JSONResponse({"error": "Superadmin not found"}, status_code=404)
        
        if not bcrypt.checkpw(current_password.encode('utf-8'), superadmin.password_hash.encode('utf-8')):
            return JSONResponse({"error": "Current password is incorrect"}, status_code=400)
        
        # Hash new password
        new_password_hash = bcrypt.hashpw(new_password.encode('utf-8'), bcrypt.gensalt()).decode('utf-8')
        
        # Update password
        superadmin.password_hash = new_password_hash
        superadmin.updated_at = datetime.utcnow()
        db.commit()
        
        return JSONResponse({"success": True, "message": "Password changed successfully"})
        
    except Exception as e:
        db.rollback()
        return JSONResponse({"error": str(e)}, status_code=500)


# =====================================================================
#  SuperAdmin → Admin-portal NAS proxy
# =====================================================================
# Runs NAS-critical operations (sync-all-freeradius, RADIUS diagnose,
# PPPoE secrets, .rsc download, fix-pppoe-profile, sync-radius-secret,
# emergency-unblock, unprovision, etc.) against a specific tenant's
# NAS Devices WITHOUT the superadmin having to log in as that tenant.
# Forwards each request to the admin-portal service bound on localhost
# port 8001, adding an `X-Internal-Token` header + `X-Company-Id` so
# admin-portal can authorise the call for that tenant.
#
# Called by the "NAS" icon + modal on /superadmin/admins.
# =====================================================================
import httpx as _httpx_sa   # httpx is already a FastAPI dep

_ADMIN_API = os.environ.get("ISP_ADMIN_API", "http://127.0.0.1:8001")
_INTERNAL_TOKEN_SA = os.environ.get("ISP_INTERNAL_TOKEN", "isp-bill-internal-sa-token-v1")


def _sa_proxy_headers(company_id: str, request=None):
    h = {
        "X-Internal-Token": _INTERNAL_TOKEN_SA,
        "X-Company-Id": str(company_id),
        "Content-Type": "application/json",
    }
    # s37p: propagate superadmin identity so admin-side audit rows
    # can record actor_type='superadmin' + real actor name/id.
    try:
        if request is not None:
            sess = request.session or {}
            aid = str(sess.get("superadmin_id") or sess.get("user_id") or "")
            an  = str(sess.get("superadmin_name") or sess.get("user_name") or aid or "superadmin")
            if aid: h["X-Actor-Id"] = aid[:64]
            if an:  h["X-Actor-Name"] = an[:64]
            h["X-Actor-Type"] = "superadmin"
    except Exception:
        pass
    return h


async def _sa_admin_call(method: str, path: str, company_id: str,
                           json_body: dict | None = None,
                           timeout: float = 35.0,
                           request=None):
    """Forward `method path` to admin-portal on behalf of `company_id`.
    If `request` is passed, the SuperAdmin's actor identity is forwarded
    via X-Actor-* headers so admin-side audit rows can attribute the
    action to the real superadmin (not just 'internal proxy')."""
    url = f"{_ADMIN_API}{path}"
    headers = _sa_proxy_headers(company_id, request=request)
    try:
        async with _httpx_sa.AsyncClient(timeout=timeout) as client:
            if method.upper() == "GET":
                r = await client.get(url, headers=headers)
            else:
                r = await client.request(method, url,
                                           headers=headers,
                                           json=json_body or {})
        # Pass through status code + JSON
        try:
            body = r.json()
        except Exception:
            body = {"success": False, "message": r.text[:500]}
        return JSONResponse(body, status_code=r.status_code)
    except Exception as e:
        return JSONResponse({"success": False,
                               "message": f"Proxy to admin-portal failed: {e}"},
                              status_code=502)


