        Company.balance_amount,
        Admin.admin_name,
        Admin.admin_email,
        Admin.admin_mobile
    ).join(Admin, Company.company_id == Admin.company_id).filter(
        Company.deleted_at == None  # Exclude deleted companies
    )
    
    total_records = query.count()
    
    # Pagination
    admins_query = query.offset(start).limit(length).all()
    
