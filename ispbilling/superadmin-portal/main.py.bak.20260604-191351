@app.post("/api/superadmin/admins/{company_id}/nas/{nas_id}/rsc-fix-policy")
async def api_sa_nas_rsc_fix_policy(company_id: str, nas_id: int, kind: str = "",
                                     request: Request = None,
                                     db: Session = Depends(get_db)):
    """Generate copy-paste RouterOS .rsc for one of: universal_nat, parking_pool, bruteforce, all."""
    _require_superadmin(request)
    if kind not in ("universal_nat", "parking_pool", "bruteforce", "all"):
        return {"success": False, "message": "Invalid kind"}

    wan_hint = "combo1"
    try:
        from radius_network import NasDevice as _NAS
        row = db.query(_NAS).filter(_NAS.id == nas_id,
                                    _NAS.company_id == company_id).first()
        if row:
            for fld in ("wan_interface", "wan", "uplink_interface"):
                v = getattr(row, fld, None)
                if v:
                    wan_hint = str(v).strip() or wan_hint
                    break
    except Exception:
        pass

    CLOUD_IP = "185.199.53.93"
    # __s56m_captive_no_scheme__ — Mikrotik /ip/proxy/access redirect-to
    # expects host+path WITHOUT scheme; RouterOS auto-prepends http://. If we
    # passed https://www... the device showed http://https//www... and the
    # captive page failed with ERR_NAME_NOT_RESOLVED. Strip the scheme here.
    CAPTIVE  = "www.autoispbilling.com/pay/captive"

    SCRIPT_UNIV = (
        "# ---- Universal NAT (XceedNet-style address-list pattern) ----\n"
        "# Adds your PPPoE pools to the MASQUERADE+ALLOW lists.\n"
        "# Edit __POOLS__ below to match your real pool subnets.\n"
        ":foreach pool in={__POOLS_LIST__} do={\n"
        "    /ip firewall address-list add address=$pool list=MASQUERADE comment=\"auto-isp-pool-nat\";\n"
        "    /ip firewall address-list add address=$pool list=ALLOW comment=\"auto-isp-pool-allow\"\n"
        "}\n"
        "# If the master srcnat rule doesn't exist yet, create it:\n"
        ":if ([:len [/ip firewall nat find where src-address-list=MASQUERADE]]=0) do={\n"
        "    /ip firewall nat add chain=srcnat action=masquerade src-address-list=MASQUERADE comment=\"auto-isp-master-masquerade\"\n"
        "}\n"
    )

    SCRIPT_PARK = (
        "# ---- Parking Pool ----\n"
        "/ip pool add name=pool-parking ranges=10.99.99.10-10.99.99.250\n"
        "/ip address add address=10.99.99.1/24 interface=ether3 comment=\"Parking gateway\"\n"
        "/ppp profile add name=parking-prof local-address=10.99.99.1 remote-address=pool-parking dns-server=10.99.99.1 rate-limit=512k/512k comment=\"auto-isp-parking-profile\"\n"
        "/ip firewall address-list add list=parked-customers address=10.99.99.0/24 comment=\"auto-isp-parked\"\n"
        "/ip firewall filter add chain=forward src-address-list=parked-customers dst-address-type=!local action=drop place-before=0 comment=\"auto-isp-parking-block\"\n"
        "/ip firewall filter add chain=forward src-address-list=parked-customers dst-address=__CLOUD__ action=accept place-before=0 comment=\"auto-isp-parking-allow-cloud\"\n"
        "/ip firewall filter add chain=forward src-address-list=parked-customers protocol=udp dst-port=53 action=accept place-before=0 comment=\"auto-isp-parking-allow-dns\"\n"
        "/ip firewall nat add chain=dstnat src-address-list=parked-customers protocol=tcp dst-port=80 action=redirect to-ports=8089 place-before=0 comment=\"auto-isp-park-http\"\n"
        "/ip firewall nat add chain=dstnat src-address-list=parked-customers protocol=tcp dst-port=443 action=redirect to-ports=8089 place-before=0 comment=\"auto-isp-park-https\"\n"
        "/ip proxy set enabled=yes port=8089\n"
        # __s56m_captive_repair__ — drop any prior broken redirect rule so re-runs self-heal
        "/ip proxy access remove [find where comment=\"auto-isp-park-redir\"]\n"
        "/ip proxy access add action=deny redirect-to=__CAPTIVE__ comment=\"auto-isp-park-redir\"\n"
    )

    SCRIPT_BF = (
        "# ---- Anti-Brute-Force ----\n"
        "/ip firewall address-list add list=allowed-mgmt address=__CLOUD__ comment=\"auto-isp-cloud\"\n"
        ":if ([:len [/interface list find name=WAN]] = 0) do={ /interface list add name=WAN; /interface list member add list=WAN interface=__WAN__ }\n"
        "/ip firewall filter add chain=input protocol=tcp dst-port=22,80,443,8291,8728,8729 in-interface-list=WAN src-address-list=!allowed-mgmt action=add-src-to-address-list address-list=auto-banned address-list-timeout=1d place-before=0 comment=\"auto-isp-bf-add\"\n"
        "/ip firewall filter add chain=input src-address-list=auto-banned in-interface-list=WAN action=drop place-before=0 comment=\"auto-isp-bf-drop\"\n"
        "/ip service set api address=__CLOUD__/32\n"
        "/ip service set api-ssl address=__CLOUD__/32\n"
        "/ip service set winbox address=__CLOUD__/32,192.168.0.0/16\n"
        "/ip service set ssh address=__CLOUD__/32,192.168.0.0/16\n"
        "/ip service disable www\n"
        "/ip service disable www-ssl\n"
        "/ip service disable telnet\n"
        "/ip service disable ftp\n"
    )

    chunks = []
    if kind in ("universal_nat", "all"): chunks.append(SCRIPT_UNIV)
    if kind in ("parking_pool",   "all"): chunks.append(SCRIPT_PARK)
    if kind in ("bruteforce",     "all"): chunks.append(SCRIPT_BF)

    # --- Build pools list from this company's active IP pools ---
    pools_list = ""
    try:
        rows = db.execute(text(
            "SELECT network FROM ip_pools WHERE company_id=:cid "
            "AND (role IS NULL OR role IN ('PPPoE','Static','Static-IP','Hotspot')) "
            "AND (status IS NULL OR LOWER(status)='active')"
        ), {"cid": company_id}).fetchall()
        nets = [r[0] for r in rows if r and r[0]]
        if nets:
            pools_list = ";".join(f'"{n}"' for n in nets)
    except Exception:
        pools_list = ""
    if not pools_list:
        pools_list = '"10.10.20.0/24";"10.10.30.0/24"'
    script = "\n".join(chunks)
    script = script.replace("__POOLS_LIST__", pools_list)
    script = script.replace("__WAN__", wan_hint)
    script = script.replace("__CLOUD__", CLOUD_IP)
    script = script.replace("__CAPTIVE__", CAPTIVE)

    return {"success": True, "kind": kind, "wan": wan_hint, "script": script}


