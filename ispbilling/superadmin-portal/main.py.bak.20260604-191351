@app.get("/api/superadmin/invoices/{invoice_id}/download")
async def download_superadmin_invoice(invoice_id: int, request: Request, db: Session = Depends(get_db)):
    """Download invoice PDF for superadmin (admin subscription invoices)"""
    from database import Invoice
    from fastapi.responses import FileResponse
    import os
    import logging
    
    logger = logging.getLogger("uvicorn")
    
    auth_check = require_superadmin(request)
    if auth_check:
        return JSONResponse({"error": "Unauthorized"}, status_code=401)
    
    try:
        invoice = db.query(Invoice).filter(
            Invoice.id == invoice_id,
            Invoice.company_id == "SUPERADMIN"
        ).first()
        
        if not invoice:
            return JSONResponse({"error": "Invoice not found"}, status_code=404)
        
        # If the PDF file is missing (older invoice, or generation failed at
        # creation time), regenerate it on-the-fly from the stored invoice row
        # and related Company/Admin data so the download always works.
        if not invoice.pdf_path or not os.path.exists(invoice.pdf_path):
            try:
                from database import Company, Admin, SuperAdminSettings

                company = db.query(Company).filter(Company.company_id == invoice.customer_id).first()
                admin = db.query(Admin).filter(Admin.company_id == invoice.customer_id).first()
                settings = db.query(SuperAdminSettings).first()

                gst_needed = bool(getattr(company, 'gst_invoice_needed', 0))

                def _fmt_date(d):
                    try:
                        return d.strftime('%Y-%m-%d') if hasattr(d, 'strftime') else str(d)
                    except Exception:
                        return str(d) if d else ''

                invoice_data = {
                    'invoice_no': invoice.invoice_no,
                    'issue_date': _fmt_date(invoice.issue_date),
                    'due_date': _fmt_date(invoice.due_date),
                    'start_date': _fmt_date(invoice.start_date),
                    'end_date': _fmt_date(invoice.end_date),
                    'plan_name': invoice.plan_name or '',
                    'period_months': invoice.period_months or 1,
                    'base_amount': float(invoice.base_amount or 0),
                    'cgst_tax': float(invoice.cgst_tax or 0),
                    'sgst_tax': float(invoice.sgst_tax or 0),
                    'igst_tax': float(invoice.igst_tax or 0),
                    'total_amount': float(invoice.total_amount or 0),
                    'customer_name': admin.admin_name if admin else (company.company_name if company else ''),
                    'prev_due_total': 0.0
                }

                company_data = {
                    'company_name': 'AUTO ISP BILLING',
                    'company_address': 'India',
                    'company_phone': '+91-8085868114',
                    'company_email': 'support@autoispbilling.com',
                    'state': 'Madhya Pradesh',
                    'gst_number': (settings.gst_number if settings and gst_needed else '') or '',
                    'bank_name': (settings.bank_name if settings else '') or '',
                    'account_number': (settings.account_no if settings else '') or '',
                    'branch_ifsc': (settings.ifsc_code if settings else '') or '',
                    'upi_id': (settings.upi_id if settings else '') or '',
                    'declaration': (settings.declaration if settings else '') or 'Thank you for choosing Auto ISP Billing.',
                    'terms_conditions': (settings.terms_conditions if settings else '') or 'Payment is due within 7 days of invoice date.'
                }

                customer_data = {
                    'customer_name': admin.admin_name if admin else (company.company_name if company else ''),
                    'username': admin.admin_id if admin else '',
                    'address': (company.company_address if company else '') or '',
                    'customer_gst_no': (company.gst_number if company and gst_needed else '') or '',
                    'state': (company.state if company else '') or '',
                    'city': (company.city if company else '') or '',
                    'mobile': (admin.admin_mobile if admin else '') or '',
                    'billing_type': 'PREPAID',
                    'category': 'ISP Management Software',
                    'gst_invoice_needed': 'Yes' if gst_needed else 'No'
                }

                pdf_bytes = generate_invoice_pdf(invoice_data, company_data, customer_data, [])

                pdf_dir = "/var/lib/autoispbilling/invoices/SUPERADMIN"
                os.makedirs(pdf_dir, exist_ok=True)
                pdf_path = f"{pdf_dir}/{invoice.invoice_no}.pdf"
                with open(pdf_path, 'wb') as f:
                    f.write(pdf_bytes)

                invoice.pdf_path = pdf_path
                db.commit()
            except Exception as regen_err:
                logger.error(f"Error regenerating invoice PDF: {regen_err}", exc_info=True)
                return JSONResponse(
                    {"error": f"Invoice PDF not found and regeneration failed: {regen_err}"},
                    status_code=500
                )

        return FileResponse(
            invoice.pdf_path,
            media_type='application/pdf',
            filename=f'invoice_{invoice.invoice_no}.pdf'
        )

    except Exception as e:
        logger.error(f"Error downloading invoice: {str(e)}", exc_info=True)
        return JSONResponse({"error": str(e)}, status_code=500)

