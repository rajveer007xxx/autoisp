def _log_sa_nas_action(request, company_id: str, nas_id: int,
                        action: str, profile: str, dry_run: bool,
                        success: bool, summary_extra: str = "",
                        payload: dict | None = None) -> None:
    """s37o: one row in admin_activity_log per NAS mutation fired from
    SuperAdmin console. Fire-and-forget — never breaks the real mutation.

    Uses raw SQL because the superadmin portal's database.py doesn't
    define AdminActivityLog (it lives in admin-portal/database.py, and
    we deliberately don't couple the two modules)."""
    try:
        from database import SessionLocal
        from sqlalchemy import text as _sql
        import json as _json
        db = SessionLocal()
        try:
            nas_row = db.execute(_sql(
                "SELECT name FROM nas_devices WHERE id=:i AND company_id=:c"
            ), {'i': nas_id, 'c': company_id}).first()
            nas_name = nas_row[0] if nas_row else f"NAS#{nas_id}"
            run_mode = "DRY-RUN" if dry_run else "RUN"
            verb = (f"Quick Setup → {profile}" if action == "quick-setup"
                    else "One-Click Hotspot Setup")
            sym = "OK" if success else "FAIL"
            summary = f"[{sym}] {verb} on {nas_name} ({run_mode})"
            if summary_extra:
                summary += f" · {summary_extra}"

            actor_id   = (request.session.get("superadmin_id")
                          or request.session.get("user_id") or "")
            actor_name = (request.session.get("superadmin_name")
                          or request.session.get("user_name")
                          or actor_id or "superadmin")
            payload_json = _json.dumps({
                "profile":   profile,
                "dry_run":   dry_run,
                "success":   success,
                "nas_name":  nas_name,
                "extra":     summary_extra,
                "payload":   payload or {},
            }, default=str)[:10000]

            db.execute(_sql("""
                INSERT INTO admin_activity_log
                   (company_id, actor_id, actor_name, actor_type, action,
                    target_type, target_id, summary, payload_json, ip_address)
                VALUES
                   (:co, :aid, :an, 'superadmin', :ac,
                    'nas_device', :tid, :sm, :pj, :ip)
            """), {
                "co": company_id,
                "aid": str(actor_id)[:64],
                "an":  str(actor_name)[:64],
                "ac":  (action or "nas-setup")[:32],
                "tid": str(nas_id)[:64],
                "sm":  summary[:255],
                "pj":  payload_json,
                "ip":  (request.client.host if request and request.client else ""),
            })
            db.commit()
        finally:
            db.close()
    except Exception as _e:
