    c.drawCentredString(width / 2, y, f"{contact_email}   {contact_phone}")
    y -= 10 * mm

    c.setLineWidth(0.5)
    c.line(20 * mm, y, width - 20 * mm, y)
    y -= 8 * mm

    def _row(label, value):
        nonlocal y
        c.setFont("Helvetica-Bold", 10)
