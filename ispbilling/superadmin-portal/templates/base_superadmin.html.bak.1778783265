<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0f172a">
    <title>{% block title %}Superadmin - Auto ISP Billing{% endblock %}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">

    <!-- Bootstrap 3.3.7 (kept for compatibility with existing modals/grids/forms) -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css">
    <!-- Font Awesome 4.7.0 (keep for existing fa-* icons used across pages) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <!-- Bootstrap Icons (modern extra icon set for new UI bits) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- AdminLTE 2.4.18 (still loaded so existing .box/.small-box widgets render; we override heavily below) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/admin-lte/2.4.18/css/AdminLTE.min.css">

    {% block extra_css %}{% endblock %}

    <style>
        :root {
            --bg: #f4f6fb;
            --surface: #ffffff;
            --surface-2: #f8fafc;
            --sidebar-bg: #0f172a;
            --sidebar-bg-2: #111827;
            --sidebar-fg: #cbd5e1;
            --sidebar-muted: #94a3b8;
            --sidebar-active: #1e293b;
            --sidebar-accent: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            --primary: #4f46e5;
            --primary-dark: #4338ca;
            --primary-soft: #eef2ff;
            --success: #10b981;
            --success-soft: #ecfdf5;
            --warning: #f59e0b;
            --warning-soft: #fffbeb;
            --danger: #ef4444;
            --danger-soft: #fef2f2;
            --info: #0ea5e9;
            --info-soft: #f0f9ff;
            --border: #e5e7eb;
            --border-strong: #d1d5db;
            --text: #0f172a;
            --text-2: #334155;
            --muted: #64748b;
            --radius-sm: 8px;
            --radius: 14px;
            --radius-lg: 20px;
            --shadow-xs: 0 1px 2px rgba(15,23,42,.04);
            --shadow-sm: 0 2px 6px rgba(15,23,42,.05);
            --shadow: 0 10px 30px rgba(15,23,42,.06);
            --shadow-lg: 0 20px 40px rgba(15,23,42,.1);
            --sidebar-w: 260px;
            --sidebar-w-mini: 72px;
            --topbar-h: 64px;
        }

        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 14px;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            margin: 0;
        }
        body.hold-transition { overflow-x: hidden; }
        a { color: var(--primary); text-decoration: none; }
        a:hover { color: var(--primary-dark); text-decoration: none; }
        h1,h2,h3,h4,h5,h6 { color: var(--text); font-weight: 700; letter-spacing: -0.01em; }

        /* ==== Layout shell ==== */
        .wrapper { min-height: 100vh; background: var(--bg); }
        .main-header { background: transparent !important; border: 0 !important; position: fixed; top: 0; left: 0; right: 0; z-index: 1040; height: var(--topbar-h); }
        .main-header .logo, .main-header .navbar { height: var(--topbar-h); line-height: 1; }
        .main-header .logo {
            width: var(--sidebar-w);
            background: var(--sidebar-bg) !important;
            color: #f8fafc !important;
            font-weight: 800;
            font-size: 18px;
            letter-spacing: 0.02em;
            display: flex; align-items: center; justify-content: center;
            border-bottom: 0 !important;
            padding: 0 16px;
        }
        .main-header .logo b { color: #f8fafc; font-weight: 800; }
        .main-header .logo .logo-lg span, .main-header .logo .logo-lg b { background: var(--sidebar-accent); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .main-header .logo .logo-mini { display: none; }
        .main-header .logo .logo-lg { display: flex; align-items: center; gap: 8px; }
        .main-header .logo .logo-lg::before { content: ''; width: 28px; height: 28px; border-radius: 8px; background: var(--sidebar-accent); flex: 0 0 28px; box-shadow: 0 6px 16px rgba(99,102,241,.45); }

        .main-header .navbar {
            margin-left: var(--sidebar-w);
            background: var(--surface) !important;
            border-bottom: 1px solid var(--border) !important;
            box-shadow: var(--shadow-xs);
            display: flex; align-items: center; padding: 0 24px;
        }
        .main-header .sidebar-toggle {
            color: var(--text-2) !important;
            padding: 8px 12px !important;
            margin: 0 !important;
            font-size: 18px;
            border-radius: var(--radius-sm);
            background: transparent;
            transition: background .15s;
        }
        .main-header .sidebar-toggle:hover { background: var(--primary-soft); color: var(--primary) !important; }
        .main-header .sidebar-toggle::before { font-family: 'bootstrap-icons'; content: '\F479'; /* list */ }

        .navbar-custom-menu { margin-left: auto; }
        .navbar-custom-menu .nav > li > a { padding: 8px 12px !important; color: var(--text-2) !important; }
        .navbar-custom-menu .user-menu .dropdown-toggle {
            display: flex; align-items: center; gap: 10px;
            padding: 6px 10px !important;
            border-radius: 999px;
            background: var(--surface-2);
            border: 1px solid var(--border);
        }
        .navbar-custom-menu .user-menu .dropdown-toggle:hover { background: var(--primary-soft); border-color: #c7d2fe; }
        .navbar-custom-menu .user-menu .user-image {
            width: 32px !important; height: 32px !important; border-radius: 50%;
            margin: 0 !important; object-fit: cover; background: var(--sidebar-accent);
        }
        .navbar-custom-menu .user-menu .dropdown-menu {
            border: 1px solid var(--border); border-radius: var(--radius);
            box-shadow: var(--shadow-lg); padding: 0; overflow: hidden; margin-top: 8px;
        }
        .navbar-custom-menu .user-menu .user-header {
            background: linear-gradient(135deg, var(--sidebar-bg) 0%, #1e293b 100%) !important;
            padding: 20px !important; height: auto !important;
            color: #f8fafc;
        }
        .navbar-custom-menu .user-menu .user-header p { color: #f8fafc; margin-top: 8px; }
        .navbar-custom-menu .user-menu .user-header img { border: 3px solid rgba(255,255,255,.3); width: 64px; height: 64px; }
        .navbar-custom-menu .user-menu .user-footer { padding: 12px; background: var(--surface); }
        .navbar-custom-menu .user-menu .user-footer .btn { border-radius: var(--radius-sm); font-weight: 600; font-size: 13px; }
        .navbar-custom-menu .user-menu .user-footer .btn-default { background: var(--surface-2); border-color: var(--border); color: var(--text-2); }
        .navbar-custom-menu .user-menu .user-footer .btn-default:hover { background: var(--primary-soft); color: var(--primary); border-color: #c7d2fe; }

        /* ==== Sidebar ==== */
        .main-sidebar {
            background: var(--sidebar-bg) !important;
            width: var(--sidebar-w);
            padding-top: var(--topbar-h);
            position: fixed; top: 0; left: 0; bottom: 0;
            z-index: 1030;
            overflow: hidden;
            box-shadow: 2px 0 20px rgba(15,23,42,.08);
        }
        .main-sidebar .sidebar {
            height: calc(100vh - var(--topbar-h));
            overflow-y: auto; overflow-x: hidden;
            padding: 16px 12px;
            scrollbar-width: thin; scrollbar-color: #334155 transparent;
        }
        .main-sidebar .sidebar::-webkit-scrollbar { width: 6px; }
        .main-sidebar .sidebar::-webkit-scrollbar-thumb { background: #334155; border-radius: 6px; }
        .sidebar-menu { padding: 0; margin: 0; list-style: none; }
        .sidebar-menu > li.header {
            color: var(--sidebar-muted) !important;
            font-size: 10px; font-weight: 700;
            letter-spacing: 0.12em; text-transform: uppercase;
            padding: 16px 14px 8px !important;
            background: transparent !important;
        }
        .sidebar-menu > li > a {
            display: flex !important; align-items: center; gap: 12px;
            color: var(--sidebar-fg) !important;
            padding: 11px 14px !important;
            border-radius: var(--radius-sm);
            margin: 2px 0; font-weight: 500; font-size: 14px;
            border-left: 0 !important;
            transition: background .15s, color .15s;
        }
        .sidebar-menu > li > a > i {
            font-size: 16px; width: 22px; text-align: center;
            color: var(--sidebar-muted);
            transition: color .15s;
        }
        .sidebar-menu > li > a:hover { background: rgba(99,102,241,.10) !important; color: #fff !important; }
        .sidebar-menu > li > a:hover > i { color: #a5b4fc; }
        .sidebar-menu > li.active > a {
            background: var(--sidebar-active) !important;
            color: #fff !important;
            position: relative;
            border-left: 0 !important;
        }
        .sidebar-menu > li.active > a::before {
            content: ''; position: absolute; left: -12px; top: 8px; bottom: 8px;
            width: 4px; border-radius: 0 4px 4px 0;
            background: var(--sidebar-accent);
        }
        .sidebar-menu > li.active > a > i { color: #a5b4fc; }

        /* ==== Content area ==== */
        .content-wrapper {
            margin-left: var(--sidebar-w) !important;
            padding-top: calc(var(--topbar-h) + 8px);
            background: var(--bg) !important;
            min-height: 100vh;
        }
        .main-footer {
            margin-left: var(--sidebar-w) !important;
            background: transparent !important;
            border-top: 1px solid var(--border) !important;
            color: var(--muted); font-size: 13px;
            padding: 16px 24px !important;
        }

        /* ==== Page header ==== */
        .content-header {
            padding: 20px 24px 8px !important;
            background: transparent !important;
            border: 0 !important;
            position: relative;
        }
        .content-header > h1 {
            margin: 0 !important;
            font-size: 24px !important; font-weight: 800 !important;
            color: var(--text) !important;
            letter-spacing: -0.015em;
            display: flex; align-items: baseline; flex-wrap: wrap; gap: 10px;
        }
        .content-header > h1 > small {
            color: var(--muted) !important;
            font-weight: 500; font-size: 13px !important;
            letter-spacing: 0;
        }
        .content-header .breadcrumb {
            background: transparent; padding: 0; margin: 8px 0 0;
            font-size: 12px;
        }

        .content { padding: 12px 24px 24px !important; }

        /* ==== Modern card system (overrides AdminLTE .box) ==== */
        .box {
            background: var(--surface) !important;
            border: 1px solid var(--border) !important;
            border-radius: var(--radius) !important;
            box-shadow: var(--shadow-xs) !important;
            margin-bottom: 20px !important;
            border-top: 1px solid var(--border) !important;
            overflow: hidden;
        }
        .box.box-primary, .box.box-success, .box.box-info, .box.box-warning, .box.box-danger { border-top-width: 1px !important; }
        .box.box-primary { border-top: 3px solid var(--primary) !important; }
        .box.box-success { border-top: 3px solid var(--success) !important; }
        .box.box-info    { border-top: 3px solid var(--info) !important; }
        .box.box-warning { border-top: 3px solid var(--warning) !important; }
        .box.box-danger  { border-top: 3px solid var(--danger) !important; }
        .box .box-header {
            padding: 16px 20px !important;
            border-bottom: 1px solid var(--border) !important;
            background: var(--surface) !important;
            color: var(--text) !important;
            display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
        }
        .box .box-header.with-border { border-bottom: 1px solid var(--border) !important; }
        .box .box-header .box-title {
            font-size: 16px !important; font-weight: 700 !important;
            color: var(--text) !important;
            margin: 0 !important; line-height: 1.3;
        }
        .box .box-header .box-tools { margin-left: auto; }
        .box .box-body { padding: 20px !important; background: var(--surface) !important; color: var(--text-2); }
        .box .box-footer { padding: 14px 20px !important; background: var(--surface-2) !important; border-top: 1px solid var(--border) !important; }

        /* ==== Stat cards (.small-box modernized) ==== */
        .small-box {
            position: relative; overflow: hidden;
            border-radius: var(--radius) !important;
            background: var(--surface) !important;
            color: var(--text) !important;
            box-shadow: var(--shadow-xs) !important;
            border: 1px solid var(--border) !important;
            margin-bottom: 20px !important;
            transition: transform .15s ease, box-shadow .15s ease;
        }
        .small-box:hover { transform: translateY(-2px); box-shadow: var(--shadow) !important; }
        .small-box > .inner { padding: 20px 24px !important; position: relative; z-index: 2; }
        .small-box h3 {
            font-size: 32px !important; font-weight: 800 !important;
            margin: 0 0 4px !important; color: var(--text) !important;
            letter-spacing: -0.02em;
        }
        .small-box p { color: var(--muted) !important; font-weight: 600; font-size: 13px; margin: 0; letter-spacing: 0.01em; }
        .small-box > .icon {
            position: absolute; top: 18px; right: 18px; z-index: 1;
            width: 52px; height: 52px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; color: #fff;
        }
        .small-box > .icon > i { font-size: 22px !important; top: auto !important; right: auto !important; position: static !important; }
        .small-box > .small-box-footer {
            position: relative; z-index: 2;
            background: var(--surface-2) !important;
            color: var(--text-2) !important;
            border-top: 1px solid var(--border) !important;
            padding: 10px 24px !important;
            font-weight: 600; font-size: 12.5px;
            display: flex; align-items: center; justify-content: space-between; gap: 6px;
        }
        .small-box > .small-box-footer:hover { background: var(--primary-soft) !important; color: var(--primary) !important; }
        .small-box.bg-aqua > .icon { background: linear-gradient(135deg, #06b6d4, #0ea5e9); box-shadow: 0 10px 20px rgba(14,165,233,.25); }
        .small-box.bg-green > .icon { background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 10px 20px rgba(16,185,129,.25); }
        .small-box.bg-yellow > .icon { background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 10px 20px rgba(245,158,11,.25); }
        .small-box.bg-red > .icon { background: linear-gradient(135deg, #ef4444, #dc2626); box-shadow: 0 10px 20px rgba(239,68,68,.25); }
        .small-box.bg-blue > .icon { background: linear-gradient(135deg, #6366f1, #8b5cf6); box-shadow: 0 10px 20px rgba(99,102,241,.25); }
        .small-box.bg-aqua, .small-box.bg-green, .small-box.bg-yellow, .small-box.bg-red, .small-box.bg-blue { background: var(--surface) !important; color: var(--text) !important; }

        /* ==== Forms ==== */
        .form-control {
            border-radius: var(--radius-sm) !important;
            border: 1px solid var(--border-strong) !important;
            box-shadow: none !important;
            padding: 8px 12px !important;
            height: 40px;
            font-size: 14px;
            background: var(--surface);
            color: var(--text);
            transition: border-color .15s, box-shadow .15s;
        }
        textarea.form-control { height: auto; min-height: 80px; }
        select.form-control { padding-right: 28px !important; }
        .form-control:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(79,70,229,.15) !important;
        }
        .form-group > label { font-weight: 600; color: var(--text-2); margin-bottom: 6px; font-size: 13px; }
        .input-group-addon {
            background: var(--surface-2) !important;
            border-color: var(--border-strong) !important;
            color: var(--text-2);
            border-radius: var(--radius-sm) !important;
        }

        /* ==== Buttons ==== */
        .btn {
            border-radius: var(--radius-sm) !important;
            font-weight: 600; font-size: 13px;
            padding: 8px 16px !important;
            border: 1px solid transparent;
            transition: background .15s, color .15s, border-color .15s, box-shadow .15s, transform .05s;
            letter-spacing: 0.01em;
            line-height: 1.4;
        }
        .btn:active { transform: translateY(1px); }
        .btn-sm { padding: 6px 12px !important; font-size: 12px; }
        .btn-xs { padding: 4px 8px !important; font-size: 11px; }
        .btn-lg { padding: 10px 20px !important; font-size: 15px; }
        .btn-primary { background: var(--primary) !important; border-color: var(--primary) !important; color: #fff !important; }
        .btn-primary:hover, .btn-primary:focus { background: var(--primary-dark) !important; border-color: var(--primary-dark) !important; box-shadow: 0 6px 14px rgba(79,70,229,.28); color: #fff !important; }
        .btn-success { background: var(--success) !important; border-color: var(--success) !important; color: #fff !important; }
        .btn-success:hover { background: #059669 !important; border-color: #059669 !important; color: #fff !important; }
        .btn-info { background: var(--info) !important; border-color: var(--info) !important; color: #fff !important; }
        .btn-info:hover { background: #0284c7 !important; border-color: #0284c7 !important; color: #fff !important; }
        .btn-warning { background: var(--warning) !important; border-color: var(--warning) !important; color: #fff !important; }
        .btn-warning:hover { background: #d97706 !important; border-color: #d97706 !important; color: #fff !important; }
        .btn-danger { background: var(--danger) !important; border-color: var(--danger) !important; color: #fff !important; }
        .btn-danger:hover { background: #dc2626 !important; border-color: #dc2626 !important; color: #fff !important; }
        .btn-default {
            background: var(--surface) !important; color: var(--text-2) !important;
            border: 1px solid var(--border-strong) !important;
        }
        .btn-default:hover { background: var(--surface-2) !important; border-color: var(--primary) !important; color: var(--primary) !important; }
        .btn-flat { border-radius: var(--radius-sm) !important; }

        /* ==== Tables ==== */
        .table {
            margin-bottom: 0;
            background: var(--surface);
            border-radius: var(--radius-sm); overflow: hidden;
        }
        .table > thead > tr > th {
            background: var(--surface-2);
            color: var(--muted);
            font-weight: 700;
            font-size: 11.5px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border-bottom: 1px solid var(--border) !important;
            border-top: 0 !important;
            padding: 12px 16px !important;
            white-space: nowrap;
        }
        .table > tbody > tr > td {
            padding: 14px 16px !important;
            border-top: 1px solid var(--border) !important;
            color: var(--text-2);
            font-size: 13.5px;
            vertical-align: middle;
        }
        .table-striped > tbody > tr:nth-of-type(odd) { background: #fafbfd; }
        .table-hover > tbody > tr:hover { background: #f1f5f9 !important; }
        .table-bordered { border: 1px solid var(--border) !important; }
        .table-bordered > thead > tr > th, .table-bordered > tbody > tr > td { border: 1px solid var(--border) !important; }
        .table-responsive { border: 0 !important; }

        /* DataTables tweaks */
        .dataTables_wrapper .dataTables_length select,
        .dataTables_wrapper .dataTables_filter input {
            border: 1px solid var(--border-strong) !important;
            border-radius: var(--radius-sm) !important;
            padding: 6px 10px !important;
            font-size: 13px;
            background: var(--surface);
        }
        .dataTables_wrapper .dataTables_length, .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info, .dataTables_wrapper .dataTables_paginate {
            padding: 8px 0 !important; font-size: 13px; color: var(--muted);
        }
        .dataTables_wrapper .paginate_button {
            border-radius: var(--radius-sm) !important;
            padding: 6px 10px !important; border: 1px solid var(--border) !important;
            background: var(--surface) !important; color: var(--text-2) !important;
            margin-left: 2px; font-size: 12.5px;
        }
        .dataTables_wrapper .paginate_button.current,
        .dataTables_wrapper .paginate_button.current:hover {
            background: var(--primary) !important; border-color: var(--primary) !important; color: #fff !important;
        }
        .dataTables_wrapper .paginate_button:hover {
            background: var(--primary-soft) !important; border-color: #c7d2fe !important; color: var(--primary) !important;
        }

        /* ==== Labels / Badges ==== */
        .label {
            font-weight: 600; padding: 4px 10px !important;
            border-radius: 999px !important;
            font-size: 11.5px; letter-spacing: 0.02em;
            display: inline-block;
        }
        .label-default { background: #e5e7eb !important; color: #374151 !important; }
        .label-primary { background: var(--primary-soft) !important; color: var(--primary) !important; }
        .label-success { background: var(--success-soft) !important; color: #047857 !important; }
        .label-info    { background: var(--info-soft) !important; color: #0369a1 !important; }
        .label-warning { background: var(--warning-soft) !important; color: #b45309 !important; }
        .label-danger  { background: var(--danger-soft) !important; color: #b91c1c !important; }

        /* ==== Modals ==== */
        .modal-content {
            border: 0 !important;
            border-radius: var(--radius) !important;
            box-shadow: 0 30px 60px rgba(15,23,42,.3) !important;
            overflow: hidden;
        }
        .modal-header {
            background: var(--surface);
            border-bottom: 1px solid var(--border) !important;
            padding: 18px 24px !important;
        }
        .modal-header .modal-title { font-weight: 700; font-size: 17px; color: var(--text); }
        .modal-header .close { font-size: 22px; opacity: 0.6; }
        .modal-header .close:hover { opacity: 1; }
        .modal-body { padding: 20px 24px !important; color: var(--text-2); }
        .modal-footer { background: var(--surface-2); border-top: 1px solid var(--border) !important; padding: 14px 24px !important; }

        /* ==== Alerts ==== */
        .alert { border-radius: var(--radius-sm); border: 1px solid transparent; padding: 12px 16px; font-size: 13px; }
        .alert-success { background: var(--success-soft); border-color: #bbf7d0; color: #047857; }
        .alert-info    { background: var(--info-soft); border-color: #bae6fd; color: #0369a1; }
        .alert-warning { background: var(--warning-soft); border-color: #fde68a; color: #b45309; }
        .alert-danger  { background: var(--danger-soft); border-color: #fecaca; color: #b91c1c; }

        /* Nav tabs */
        .nav-tabs { border-bottom: 1px solid var(--border); }
        .nav-tabs > li > a {
            border: 0 !important; border-radius: 0 !important;
            color: var(--muted) !important; font-weight: 600; font-size: 13px;
            padding: 10px 14px !important;
            border-bottom: 2px solid transparent !important;
        }
        .nav-tabs > li.active > a, .nav-tabs > li > a:hover {
            color: var(--primary) !important;
            background: transparent !important;
            border-bottom: 2px solid var(--primary) !important;
        }

        /* Utility */
        .info-row { background: var(--surface-2) !important; border-left: 3px solid var(--primary) !important; border-radius: var(--radius-sm); padding: 10px 14px !important; margin-bottom: 10px; }
        .info-label { color: var(--muted) !important; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: .04em; margin-right: 6px; }

        /* ==== Mobile responsiveness ==== */
        @media (max-width: 991px) {
            .main-header .navbar { margin-left: 0 !important; padding-left: 12px; }
            .main-header .logo { position: absolute; left: 0; right: 0; width: auto; text-align: center; }
            .main-header .navbar .sidebar-toggle { margin-left: 0 !important; }
            .content-wrapper, .main-footer { margin-left: 0 !important; }
            .main-sidebar {
                width: var(--sidebar-w);
                transform: translateX(-100%);
                transition: transform .25s ease;
                box-shadow: 4px 0 24px rgba(0,0,0,.3);
            }
            body.sidebar-open .main-sidebar { transform: translateX(0); }
            body.sidebar-open::after {
                content: ''; position: fixed; inset: 0; background: rgba(15,23,42,.45);
                z-index: 1025; backdrop-filter: blur(2px);
            }
            .content-header > h1 { font-size: 20px !important; }
            .content { padding: 8px 16px 16px !important; }
        }
        @media (max-width: 575px) {
            .content-header { padding: 16px 16px 4px !important; }
            .box .box-header, .box .box-body { padding: 14px 16px !important; }
            .small-box > .inner { padding: 16px 18px !important; }
            .small-box h3 { font-size: 26px !important; }
            .btn { padding: 8px 12px !important; font-size: 12.5px; }
        }

        /* Keep sidebar width consistent even if AdminLTE adds collapse classes */
        .sidebar-mini.sidebar-collapse .main-header .logo { width: var(--sidebar-w) !important; }
        .sidebar-mini.sidebar-collapse .main-sidebar { width: var(--sidebar-w) !important; }
        .sidebar-mini.sidebar-collapse .content-wrapper,
        .sidebar-mini.sidebar-collapse .main-footer { margin-left: var(--sidebar-w) !important; }
    </style>

