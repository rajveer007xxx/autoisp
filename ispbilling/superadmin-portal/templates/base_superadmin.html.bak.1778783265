                                    <img src="{{ profile_image if profile_image else '/static/images/default-avatar.png' }}" class="img-circle" alt="User Image" onerror="this.onerror=null;this.src='/static/images/default-avatar.png';">{# P0_PROFILE_IMG_BADGE #}
                                    <p>{{ user_name }}<small>Superadmin</small></p>
                                </li>
                                <li class="user-footer">
                                    <div class="pull-left">
                                        <a href="/superadmin/profile" class="btn btn-default btn-flat"><i class="bi bi-person-circle"></i> Profile</a>
                                    </div>
                                    <div class="pull-right">
                                        <a href="/logout" class="btn btn-default btn-flat"><i class="bi bi-box-arrow-right"></i> Sign out</a>
                                    </div>
                                </li>
                            </ul>
                        </li>
                    </ul>
