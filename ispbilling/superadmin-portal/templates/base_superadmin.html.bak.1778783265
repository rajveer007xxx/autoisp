                    <span class="sr-only">Toggle navigation</span>
                </a>

                <div class="navbar-custom-menu">
                    <ul class="nav navbar-nav">
                        <li class="dropdown user user-menu">
                            <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                                <img src="{{ profile_image if profile_image else '/static/images/default-avatar.png' }}" class="user-image" alt="User Image" onerror="this.onerror=null;this.src='/static/images/default-avatar.png';">{# P0_PROFILE_IMG_BADGE #}
                                <span class="hidden-xs">{{ user_name }}</span>
                                <i class="bi bi-chevron-down" style="font-size: 11px; margin-left: 4px; color: var(--muted);"></i>
                            </a>
                            <ul class="dropdown-menu">
