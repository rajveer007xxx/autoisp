                    <li class="{% if active_page == 'backups' %}active{% endif %}">
                        <a href="/superadmin/backups" data-testid="sa-nav-backups">
                            <i class="bi bi-shield-check"></i> <span>DB Backups</span>
                        </a>
                    </li>
                </ul>
            </section>
        </aside>

        <!-- Content Wrapper -->
        <div class="content-wrapper">
            {% block content %}{% endblock %}
