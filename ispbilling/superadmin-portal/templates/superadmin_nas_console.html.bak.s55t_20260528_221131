                      +   '<td>' + actorBadge + ' ' + esc(r.actor_name || r.actor_id || '') + '</td>'
                      +   '<td>' + actionPill + '</td>'
                      +   '<td>' + esc(r.summary) + '</td>'
                      +   '<td style="font-family:monospace;font-size:11px;">' + esc(r.ip_address) + '</td>'
                      + '</tr>';
            });
