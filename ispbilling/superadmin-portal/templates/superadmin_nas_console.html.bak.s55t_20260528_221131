var __axp = { nasId: null, nasName: '' };
function ncAddExtraPool(nasId, name) {
    __axp = { nasId: nasId, nasName: name };
    document.getElementById('axp_nas_name').textContent = name || ('NAS ' + nasId);
    ['axp_name','axp_network','axp_range','axp_gateway'].forEach(function(id){ document.getElementById(id).value=''; });
    document.getElementById('axp_dns').value = '8.8.8.8,1.1.1.1';
    document.getElementById('axp_role').value = 'PPPoE';
    document.getElementById('axp_output').style.display = 'none';
    document.getElementById('axp_interface').innerHTML = '<option value="">(none — create pool only)</option>';
    $('#addExtraPoolModal').modal('show');
    // auto-load interfaces on open
    axpLoadInterfaces();
}
function axpLoadInterfaces() {
    if (!__axp.nasId) return;
    var sel = document.getElementById('axp_interface');
    var status = document.getElementById('axp_if_status');
    status.innerHTML = '<i class="fa fa-spinner fa-spin"></i> loading from router…';
    fetch(cfgApiBase() + '/nas/' + __axp.nasId + '/interfaces').then(r => r.json()).then(function(d){
        sel.innerHTML = '<option value="">(none — create pool only)</option>';
        if (!d || d.success === false) {
            status.innerHTML = '<span style="color:#b91c1c;">' + ((d && d.message) || 'router unreachable') + '</span>';
            return;
        }
        var list = d.interfaces || [];
        list.forEach(function(iface){
            if (iface && iface.name) {
                var label = iface.name + (iface.type ? (' · ' + iface.type) : '') + (iface.running ? ' ✓' : '');
                var opt = document.createElement('option');
                opt.value = iface.name; opt.textContent = label;
                sel.appendChild(opt);
            }
        });
        status.textContent = list.length + ' interfaces loaded';
    }).catch(function(e){
        status.innerHTML = '<span style="color:#b91c1c;">error: ' + (e && e.message || e) + '</span>';
    });
}
function axpSave() {
    var payload = {
        name:      (document.getElementById('axp_name').value || '').trim(),
        // s26.15: axp-network-field
        network:   (document.getElementById('axp_network').value || '').trim(),
        ranges:    (document.getElementById('axp_range').value || '').trim(),
        gateway:   (document.getElementById('axp_gateway').value || '').trim(),
        interface: (document.getElementById('axp_interface').value || '').trim(),
        role:      document.getElementById('axp_role').value,
        dns_servers: (document.getElementById('axp_dns').value || '').trim(),
        status: 'Active'
    };
    if (!payload.name || !payload.network || !payload.ranges) {
        alert('Name, Network (CIDR) and Range are all required.'); return;
    }
    if (!/^\d+\.\d+\.\d+\.\d+\/\d+$/.test(payload.network)) {
        alert('Network must be in CIDR format, e.g. 192.168.21.0/24'); return;
    }
    var out = document.getElementById('axp_output');
    out.style.display = 'block';
    out.textContent = 'Saving + pushing to router…';
    fetch('/api/superadmin/admins/' + encodeURIComponent(__nc.companyId)
        + '/nas/' + __axp.nasId + '/add-extra-pool', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify(payload)
    }).then(r => r.json()).then(function(d){
        out.textContent = JSON.stringify(d, null, 2);
        if (d && d.success) {
            setTimeout(function(){
                $('#addExtraPoolModal').modal('hide');
                if (typeof ncReloadNasList === 'function') ncReloadNasList();
            }, 900);
        }
    }).catch(function(e){
        out.textContent = 'Network error: ' + (e && e.message || e);
    });
}
</script>


