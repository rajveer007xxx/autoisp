        firewall_nat_baseline: $('#ec_cfg_firewall_nat').is(':checked'),
        with_audit_log: $('#ec_cfg_with_audit_log').is(':checked'),
        with_wan_drop: $('#ec_cfg_with_wan_drop').is(':checked'),
        parking_pool: $('#ec_cfg_parking_pool').is(':checked'),
        hotspot: $('#ec_cfg_hotspot').is(':checked'),
        enable_pppoe_server: $('#ec_cfg_enable_pppoe').is(':checked'),
        enable_hotspot: $('#ec_cfg_enable_hotspot').is(':checked'),
        dry_run: $('#ec_cfg_dry_run').is(':checked'),
        pppoe_interface: $('#ec_cfg_pppoe_if').val(),
        hotspot_interface: $('#ec_cfg_hotspot_if').val(),
        wan_interface: $('#ec_cfg_wan_if').val(),
        pppoe_pool_name: $('#ec_cfg_pppoe_pool_name').val(),
        pppoe_pool_ranges: $('#ec_cfg_pppoe_pool_ranges').val(),
        pppoe_pool_id: ($('#ec_cfg_pppoe_pool_source').val() === '__custom__' ? null : $('#ec_cfg_pppoe_pool_source').val()),
        pppoe_local_address: $('#ec_cfg_pppoe_local').val(),
