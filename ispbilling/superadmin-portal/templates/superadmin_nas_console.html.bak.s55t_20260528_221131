        parking_landing_ip: $('#ec_cfg_parking_landing').val(),
        selected_pools: collectSelectedPools(),
    };
    return Object.assign(b, extra || {});
}

function runConfigure(force) {
    var body = buildConfigureBody(force ? {force: true} : null);

    // Client-side pre-flight mirror for immediate feedback (server enforces anyway)
    if (!body.dry_run && !force) {
        var wanIf = (body.wan_interface || '').trim();
        var conflicts = [];
        if (body.pppoe_server && body.pppoe_interface === wanIf && wanIf) {
            conflicts.push('PPPoE interface "' + body.pppoe_interface + '" is the WAN interface.');
        }
        if (body.hotspot && body.hotspot_interface === wanIf && wanIf) {
            conflicts.push('Hotspot interface "' + body.hotspot_interface + '" is the WAN interface.');
        }
        if (conflicts.length) {
            var msg = '⚠ Pre-flight client-side check failed:\n\n• ' + conflicts.join('\n• ') +
                '\n\nExecuting would take the router offline. Click OK to let the server decide (it will refuse unless you Force).';
            if (!confirm(msg)) return;
        }
    }

    $('#ec_cfg_output').text('Running…').show();
    $('#ec_cfg_recovery').hide();
    fetch(cfgApiBase() + '/nas/' + currentNasId + '/auto-configure', {
        method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body)
    }).then(r => r.json()).then(d => {
        var text = '';
        if (d.preflight_blocked) {
            text += '[BLOCKED BY PRE-FLIGHT]\n';
            text += (d.message || '') + '\n';
            (d.conflicts || []).forEach(function(c){ text += '  • ' + c + '\n'; });
            text += '\nDetected WAN: ' + ((d.preflight || {}).detected_wan || '?') +
                    '  via gw ' + ((d.preflight || {}).gateway || '?') + '\n';
            $('#ec_cfg_output').text(text);
            if (confirm('Pre-flight refused the run:\n\n' + (d.message || '') +
                        '\n\nRe-run with FORCE=true? This WILL likely knock the router offline.')) {
                runConfigure(true);
            }
            return;
        }
        text += (d.dry_run ? '[DRY-RUN] ' : '[EXECUTED] ') + 'transport=' + (d.transport || 'n/a') + '\n';
        text += 'success: ' + d.success + (d.message ? ('  msg: ' + d.message) : '') + '\n';
        if (d.preflight && !d.preflight.skipped) {
            text += '[pre-flight] detected WAN=' + (d.preflight.detected_wan || '?') +
                    ' gateway=' + (d.preflight.gateway || '?') +
                    ' source=' + (d.preflight.source || '?') + '\n';
            (d.preflight.warnings || []).forEach(function(w){ text += '   warn: ' + w + '\n'; });
        }
        text += '\n--- Commands ---\n';
        (d.commands || []).forEach(function(c){ text += '> ' + c + '\n'; });
        if (d.task_errors && Object.keys(d.task_errors).length) {
            text += '\n--- ⚠ Per-task errors (other tasks still ran) ---\n';
            Object.keys(d.task_errors).forEach(function(k){
                text += '  • ' + k + ': ' + d.task_errors[k] + '\n';
            });
        }
        if (d.permission_hint) {
            text += '\n--- 🔑 RouterOS permission fix needed ---\n';
            text += d.permission_hint.issue + '\n';
            text += 'Missing policies: ' + (d.permission_hint.missing_policies || []).join(', ') + '\n';
            text += 'Run this ON THE MIKROTIK (Winbox/terminal):\n';
            text += '  ' + d.permission_hint.fix + '\n';
        }
        text += '\n--- Results ---\n' + JSON.stringify(d.tasks || {}, null, 2);
        $('#ec_cfg_output').text(text);
        lastCommands.configure = d.commands || [];
        $('#ec_cfg_export_btn').toggle((d.commands || []).length > 0);

        if (d.unprovision_commands && d.unprovision_commands.length) {
            $('#ec_cfg_recovery_cmds').text(d.unprovision_commands.join('\n'));
            $('#ec_cfg_recovery').show();
        }
        // Refresh router pool snapshot after a real execution so next run shows current state
        if (!d.dry_run && d.success) {
            refreshRouterPools(true);
        }
    }).catch(e => { $('#ec_cfg_output').text('Error: ' + e); });
}

