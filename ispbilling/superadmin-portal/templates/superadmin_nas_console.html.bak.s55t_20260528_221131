// S38g: sync /radius secret from router into DB + clients.conf
function saSyncSecretFromRouter() {  /* __S38G_SYNC_SECRET_FROM_ROUTER__ */
    if (!currentNasId) { alert('Open the Edit NAS popup on a specific NAS first.'); return; }
    if (!confirm('Copy the /radius shared secret from the router into the DB + Radius clients.conf ?\n\nThis overrides the current DB value with whatever the router reports.')) return;
    var btn = document.querySelector('[data-testid="sa-sync-secret-from-router"]');
    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Fetching...'; }
    fetch(cfgApiBase() + '/nas/' + currentNasId + '/sync-secret-from-router', {
        method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}',
    }).then(function(r){ return r.json().then(function(d){ return {status: r.status, d: d}; }); })
      .then(function(o){
        var d = o.d || {};
        if (o.status === 200 && d.success) {
            var el = document.getElementById('nc_edit_secret');
            if (el && d.secret) el.value = d.secret;
            var hint = document.getElementById('nc_edit_secret_hint');
            if (hint) {
                hint.innerHTML = d.changed
                    ? '<i class="fa fa-check-circle" style="color:#10b981"></i> Copied from router ('+d.router_address+') · DB updated · clients.conf reloaded.'
                    : '<i class="fa fa-check-circle" style="color:#10b981"></i> Already in sync with router.';
            }
        } else {
            alert('Sync failed: ' + (d.message || ('HTTP '+o.status)));
        }
      })
      .catch(function(e){ alert('Request failed: ' + e); })
      .then(function(){
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-arrow-down"></i> Copy router -> DB'; }
      });
}

