function escapeHtml(s) {
    return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// Parse "a.b.c.d-e.f.g.h" or CIDR into [startInt, endInt]; null if unparseable.
function parseRange(str) {
    if (!str) return null;
    str = String(str).trim();
    var ip2int = function(ip) {
        var p = ip.split('.').map(Number);
        if (p.length !== 4 || p.some(function(x){ return isNaN(x) || x < 0 || x > 255; })) return null;
        return (p[0] << 24 >>> 0) + (p[1] << 16) + (p[2] << 8) + p[3];
    };
    if (str.indexOf('/') !== -1) {
        var parts = str.split('/');
        var base = ip2int(parts[0]); var mask = parseInt(parts[1], 10);
        if (base === null || isNaN(mask)) return null;
        var hosts = Math.pow(2, 32 - mask);
        var net = (base >>> (32 - mask)) << (32 - mask);
        return [net, net + hosts - 1];
    }
    if (str.indexOf('-') !== -1) {
        var seg = str.split(',')[0].trim().split('-');
        if (seg.length !== 2) return null;
        var a = ip2int(seg[0].trim()); var b = ip2int(seg[1].trim());
        if (a === null || b === null) return null;
        return [Math.min(a,b), Math.max(a,b)];
    }
    var single = ip2int(str);
    return single === null ? null : [single, single];
}

function checkPoolConflict() {
    var mine = parseRange($('#ec_cfg_pppoe_pool_ranges').val());
    var myName = ($('#ec_cfg_pppoe_pool_name').val() || '').trim();
    var warn = [];
    if (mine) {
        lastRouterPools.forEach(function(p) {
            if (!p || !p.ranges) return;
            if (p.name && p.name === myName) return; // same-name = overwrite, not a clash
            var other = parseRange(p.ranges);
            if (!other) return;
            if (mine[0] <= other[1] && other[0] <= mine[1]) {
                warn.push('Range overlaps with router pool <code>' + escapeHtml(p.name) + '</code> (' + escapeHtml(p.ranges) + ')');
            }
        });
    }
    // Check duplicate name with different range
    var named = lastRouterPools.filter(function(p){ return p && p.name === myName; });
    if (named.length && mine) {
        var existing = parseRange(named[0].ranges);
        if (existing && (existing[0] !== mine[0] || existing[1] !== mine[1])) {
            warn.unshift('A pool named <code>' + escapeHtml(myName) + '</code> already exists on the router with a different range — Auto-Configure will skip it (not overwrite).');
        }
    }
    if (warn.length) {
        $('#ec_cfg_pool_conflict_warn').html('<strong>⚠ Pool conflict check:</strong><br>' + warn.join('<br>')).show();
    } else {
        $('#ec_cfg_pool_conflict_warn').hide().empty();
    }
}
$(document).on('input change', '#ec_cfg_pppoe_pool_ranges, #ec_cfg_pppoe_pool_name, #ec_cfg_pppoe_pool_source', function() {
