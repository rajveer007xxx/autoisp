                $('#ec_cfg_iface_fetch_status').html('<span style="color:#b91c1c;">could not fetch live interfaces: ' + ((d && d.message) || 'unreachable') + ' — type names manually.</span>');
                return;
            }
            var ifaces = d.interfaces || [];
            // Sort: running + not-disabled first
            ifaces.sort(function(a, b) {
                var ar = (a.running === true || a.running === 'true') ? 0 : 1;
                var br = (b.running === true || b.running === 'true') ? 0 : 1;
                if (ar !== br) return ar - br;
                return (a.name || '').localeCompare(b.name || '');
            });
            ifaces.forEach(function(i) {
                if (!i.name) return;
                var opt = document.createElement('option');
                opt.value = i.name;
