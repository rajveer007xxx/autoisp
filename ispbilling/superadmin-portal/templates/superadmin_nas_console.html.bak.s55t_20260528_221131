<script>
// Session 39F — SuperAdmin One-Click handlers
var __ncOneClick = { nasId: null, name: '' };

function ncOneclickPools(id, name) {
    __ncOneClick.nasId = id; __ncOneClick.name = name;
    document.getElementById('nc_ocp_name').textContent = name;
    document.getElementById('nc_ocp_status').innerHTML = '';
    var out = document.getElementById('nc_ocp_output'); out.style.display = 'none'; out.textContent = '';
    document.getElementById('nc_ocp_summary').textContent = '0 pools selected';
    $('#ncOneclickPoolsModal').modal('show');
    ncOcpReloadPools();
    ncOcpReloadIfs(true);
}

var __ncOcpInterfaces = [];
var __ncOcpPools = [];

function ncOcpReloadPools() {
    var tb = $('#nc_ocp_tbody');
    tb.html('<tr><td colspan="7" class="text-muted text-center" style="padding:14px;">Loading pools…</td></tr>');
    var url = '/api/superadmin/admins/' + encodeURIComponent(__nc.companyId) + '/ip-pools/list';
    fetch(url, {credentials:'same-origin'}).then(function(r){return r.json();}).then(function(d){
        var pools = (d && d.ip_pools) || [];
        __ncOcpPools = pools;
        if (!pools.length) {
            tb.html('<tr><td colspan="7" class="text-muted text-center" style="padding:14px;">No IP Pools defined for this admin. Create them in the admin portal first (IP Pools page).</td></tr>');
            return;
        }
        tb.empty();
        pools.forEach(function(p){
            var range = (p.start_ip && p.end_ip) ? (p.start_ip + '-' + p.end_ip) : (p.network || '');
            var tr = $('<tr>').attr('data-pool-id', p.id);
            tr.append('<td style="text-align:center;"><input type="checkbox" class="nc-ocp-cb" data-testid="sa-ocp-cb-' + p.id + '"></td>');
            tr.append('<td><code>' + (p.name || '').replace(/[<>]/g,'') + '</code></td>');
            tr.append('<td><input type="text" class="form-control input-sm nc-ocp-range" value="' + (range || '').replace(/"/g,'&quot;') + '" placeholder="173.10.10.10-173.10.10.250" style="height:26px; font-size:11px; padding:2px 6px; font-family:monospace;"></td>');
            tr.append('<td><input type="text" class="form-control input-sm nc-ocp-gateway" value="' + (p.gateway || '').replace(/"/g,'&quot;') + '" placeholder="173.10.10.1" style="height:26px; font-size:11px; padding:2px 6px; font-family:monospace;"></td>');
            tr.append('<td><select class="form-control input-sm nc-ocp-iface" style="height:28px; font-size:12px; padding:2px 6px;"><option value="">(none — create pool only)</option></select></td>');
            tr.append('<td><select class="form-control input-sm nc-ocp-next" style="height:28px; font-size:12px; padding:2px 6px;"><option value="">— None (no overflow) —</option></select></td>');
            tr.append('<td style="text-align:center;"><input type="radio" name="nc_ocp_pppoe_radio" class="nc-ocp-pppoe" disabled></td>');
            tb.append(tr);
        });
        // Populate Next Pool
        $('#nc_ocp_tbody tr').each(function(){
            var myId = $(this).data('pool-id');
            var $sel = $(this).find('.nc-ocp-next');
            pools.forEach(function(np){
                if (np.id === myId) return;
                $sel.append($('<option>').val(np.id).text(
                    np.name + ' (' + (np.network || ((np.start_ip||'') + '-' + (np.end_ip||''))) + ')'));
            });
        });
        ncOcpFillIfs();
        ncOcpUpdateSummary();
    }).catch(function(e){
        tb.html('<tr><td colspan="7" class="text-muted text-center" style="padding:14px;color:#b91c1c;">Could not load pools: ' + e + '</td></tr>');
    });
}

function ncOcpReloadIfs(silent) {
    if (!__ncOneClick.nasId) return;
    if (!silent) $('#nc_ocp_ifs_status').html('<i class="fa fa-spinner fa-spin"></i> loading…');
    var url = '/api/superadmin/admins/' + encodeURIComponent(__nc.companyId)
            + '/nas/' + __ncOneClick.nasId + '/interfaces';
    fetch(url, {credentials:'same-origin'}).then(function(r){return r.json();}).then(function(d){
        if (!d || d.success === false) {
            $('#nc_ocp_ifs_status').html('<span style="color:#b91c1c;">' + ((d && d.message) || 'unreachable') + '</span>');
            __ncOcpInterfaces = []; ncOcpFillIfs(); return;
        }
        __ncOcpInterfaces = d.interfaces || [];
        $('#nc_ocp_ifs_status').text(__ncOcpInterfaces.length + ' ifs');
        ncOcpFillIfs();
    }).catch(function(e){
        $('#nc_ocp_ifs_status').html('<span style="color:#b91c1c;">error</span>');
        __ncOcpInterfaces = []; ncOcpFillIfs();
    });
}

function ncOcpFillIfs() {
    $('.nc-ocp-iface').each(function(){
        var $sel = $(this);
        var current = $sel.val() || '';
        $sel.empty().append('<option value="">(none — create pool only)</option>');
        if (!__ncOcpInterfaces.length) {
            $sel.append('<option value="__manual__">— Type manually —</option>');
        } else {
            __ncOcpInterfaces.forEach(function(iface){
                if (iface && iface.name) {
                    var label = iface.name + (iface.type ? (' · ' + iface.type) : '') + (iface.running ? ' ✓' : '');
                    $sel.append($('<option>').val(iface.name).text(label));
                }
            });
        }
        if (current) $sel.val(current);
    });
}

$(document).on('change', '.nc-ocp-cb', function(){
    var $row = $(this).closest('tr');
    var on = $(this).is(':checked');
    $row.find('.nc-ocp-pppoe').prop('disabled', !on);
    if (!on) $row.find('.nc-ocp-pppoe').prop('checked', false);
    ncOcpUpdateSummary();
});

function ncOcpUpdateSummary() {
    var n = $('.nc-ocp-cb:checked').length;
    var pp = $('.nc-ocp-pppoe:checked').length;
    document.getElementById('nc_ocp_summary').textContent = n + ' pools selected' + (pp ? ' • PPPoE pool set' : '');
}
$(document).on('change', '.nc-ocp-pppoe', ncOcpUpdateSummary);

function ncOcpSubmit() {
    if (!__ncOneClick.nasId) return;
    var rows = [];
    $('#nc_ocp_tbody tr').each(function(){
        if (!$(this).find('.nc-ocp-cb').is(':checked')) return;
        var pid = $(this).data('pool-id');
        var p = (__ncOcpPools || []).filter(function(x){return x.id === pid;})[0] || {};
        var range = $(this).find('.nc-ocp-range').val().trim();
        var gateway = $(this).find('.nc-ocp-gateway').val().trim();
        var iface = $(this).find('.nc-ocp-iface').val().trim();
        var nextPool = $(this).find('.nc-ocp-next').val().trim();
        var isPppoe = $(this).find('.nc-ocp-pppoe').is(':checked');
        var sIp = '', eIp = '', network = p.network || '';
        if (range.indexOf('-') > 0) { var parts = range.split('-'); sIp = parts[0].trim(); eIp = parts[1].trim(); }
        rows.push({
            id: pid, name: p.name, network: network,
            start_ip: sIp, end_ip: eIp,
            gateway: gateway, interface: iface,
            next_pool_id: nextPool || null,
            is_pppoe_pool: isPppoe
        });
    });
    if (!rows.length) {
        $('#nc_ocp_status').html('<span style="color:#b91c1c;">Tick at least one pool with Use.</span>'); return;
    }
    $('#nc_ocp_status').html('<i class="fa fa-spinner fa-spin"></i> pushing to router…');
    var url = '/api/superadmin/admins/' + encodeURIComponent(__nc.companyId)
            + '/nas/' + __ncOneClick.nasId + '/oneclick-pools';
    fetch(url, {method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({pools: rows}), credentials:'same-origin'})
      .then(function(r){return r.json();}).then(function(d){
        if (d.ok) {
            $('#nc_ocp_status').html('<span style="color:#065f46;"><i class="fa fa-check-circle"></i> Pushed ' + rows.length + ' pool(s) successfully.</span>');
            var out = document.getElementById('nc_ocp_output'); out.style.display='block'; out.textContent = JSON.stringify(d.report, null, 2);
        } else {
            $('#nc_ocp_status').html('<span style="color:#b91c1c;"><i class="fa fa-exclamation-triangle"></i> Error: ' + (d.error || 'unknown') + '</span>');
        }
      }).catch(function(e){
        $('#nc_ocp_status').html('<span style="color:#b91c1c;">Network error: ' + e + '</span>');
      });
}

function ncOneclickAuth(id, name) {
    __ncOneClick.nasId = id; __ncOneClick.name = name;
    document.getElementById('nc_oca_name').textContent = name;
    document.getElementById('nc_oca_status').innerHTML = '';
    var out = document.getElementById('nc_oca_output'); out.style.display = 'none'; out.textContent = '';
    $('#nc_oca_pppoe, #nc_oca_static, #nc_oca_hotspot').prop('checked', false);
    $('#nc_oca_pppoe_box, #nc_oca_static_box, #nc_oca_hotspot_box').hide();
    $('#ncOneclickAuthModal').modal('show');
}

$(document).on('change', '#nc_oca_pppoe',   function(){ $('#nc_oca_pppoe_box').toggle(this.checked); });
$(document).on('change', '#nc_oca_static',  function(){ $('#nc_oca_static_box').toggle(this.checked); });
$(document).on('change', '#nc_oca_hotspot', function(){ $('#nc_oca_hotspot_box').toggle(this.checked); });

function ncOcaSubmit() {
    if (!__ncOneClick.nasId) return;
    var body = {
        pppoe: !$('#nc_oca_pppoe').is(':checked') ? null : {
            enabled: true,
            interface:    $('#nc_oca_pppoe_if').val().trim(),
            service_name: $('#nc_oca_pppoe_svc').val().trim(),
            vlan_id:      parseInt($('#nc_oca_pppoe_vlan').val() || '0', 10)
        },
        static_ip: !$('#nc_oca_static').is(':checked') ? null : {enabled: true},
        hotspot:   !$('#nc_oca_hotspot').is(':checked') ? null : {
            enabled: true,
            interface: $('#nc_oca_hs_if').val().trim(),
            pool_name: $('#nc_oca_hs_pool').val().trim(),
            branded_html: true
        }
    };
    if (!body.pppoe && !body.static_ip && !body.hotspot) {
        $('#nc_oca_status').html('<span style="color:#b91c1c;">Select at least one auth mode.</span>'); return;
    }
    $('#nc_oca_status').html('<i class="fa fa-spinner fa-spin"></i> configuring router (may take 10–20 s)…');
    var url = '/api/superadmin/admins/' + encodeURIComponent(__nc.companyId)
            + '/nas/' + __ncOneClick.nasId + '/oneclick-auth';
    fetch(url, {method:'POST', headers:{'Content-Type':'application/json'},
                body:JSON.stringify(body), credentials:'same-origin'})
      .then(function(r){return r.json();}).then(function(d){
        if (d.ok) {
            var msg = '<span style="color:#065f46;"><i class="fa fa-check-circle"></i> Auth setup complete. ';
            msg += 'auth_modes=' + (d.auth_modes || 'n/a') + ', WAN=' + (d.wan_interface || '?');
            if ((d.lan_subnets || []).length) msg += ', LAN: ' + d.lan_subnets.join(', ');
            msg += '</span>';
            $('#nc_oca_status').html(msg);
            var out=document.getElementById('nc_oca_output'); out.style.display='block'; out.textContent=JSON.stringify(d, null, 2);
        } else {
            $('#nc_oca_status').html('<span style="color:#b91c1c;"><i class="fa fa-exclamation-triangle"></i> Error: ' + (d.error || 'unknown') + '</span>');
        }
      }).catch(function(e){
        $('#nc_oca_status').html('<span style="color:#b91c1c;">Network error: ' + e + '</span>');
      });
}
</script>



<script>
// Session 39G — RouterOS user provisioning handlers
function ncAddStdUsers(id, name) {
    var apiPwd = prompt(
        'Add 2 standard RouterOS users on "' + name + '"?\n\n' +
        '  • api      → group=read   (read-only)\n' +
        '  • autoisp  → group=full   (read/write)\n\n' +
        'Enter password for `api` user (read-only):',
        'autoispbilling@121212'
    );
    if (apiPwd === null) return;
    var autoispPwd = prompt('Enter password for `autoisp` user (full):',
                             'autoispbilling@121212');
    if (autoispPwd === null) return;
    fetch('/api/superadmin/admins/' + encodeURIComponent(__nc.companyId)
          + '/nas/' + id + '/add-default-users', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({api_password: apiPwd, autoisp_password: autoispPwd}),
        credentials: 'same-origin'
    }).then(function(r){return r.json();}).then(function(d){
        if (d.ok) {
            var r = d.result || {};
            alert('✓ Done.\nCreated: ' + (r.created || []).join(', ') +
                  '\nUpdated: ' + (r.updated || []).join(', ') +
                  ((r.errors||[]).length ? '\nErrors: ' + r.errors.join('; ') : ''));
        } else {
            alert('✗ Failed: ' + (d.error || JSON.stringify(d)));
        }
    }).catch(function(e){ alert('Network error: ' + e); });
}

function ncAddApiAdmin(id, name) {
    if (!confirm('Add dedicated `api-admin` user (group=full) on "' + name + '"?\n\n' +
                 'Restricted to the billing server\'s IP only — security best practice ' +
                 'over using the master `admin` account.\n\nProceed?')) return;
    var pwd = prompt('Enter password for `api-admin`:', 'autoispbilling@121212');
    if (pwd === null) return;
    var promote = confirm(
        'Also PROMOTE `api-admin` to be the API user this NAS uses?\n\n' +
        'OK  → after creation, this NAS row\'s api_username/password will be\n' +
        '       switched to api-admin (a quick login test runs first; if it\n' +
        '       fails, the switch is aborted so you don\'t get locked out).\n\n' +
        'Cancel → just create the user, leave NAS row unchanged.'
    );
    fetch('/api/superadmin/admins/' + encodeURIComponent(__nc.companyId)
          + '/nas/' + id + '/add-api-admin-user', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({password: pwd, promote: !!promote}),
        credentials: 'same-origin'
    }).then(function(r){return r.json();}).then(function(d){
        if (d.ok) {
            var msg = '✓ ' + (d.action || 'done') + ' api-admin\n' +
                      'Restricted to: ' + (d.address || '(none)') + '\n';
            if (d.promoted)         msg += 'NAS row promoted ✓ — billing now uses api-admin.';
            else if (d.promote_error) msg += 'Promotion failed: ' + d.promote_error +
                                              '\nUser created, but NAS still uses ' +
                                              'previous credentials.';
            else                     msg += 'NAS row unchanged (no promotion requested).';
            alert(msg);
        } else {
            alert('✗ Failed: ' + (d.error || JSON.stringify(d)));
        }
    }).catch(function(e){ alert('Network error: ' + e); });
}

</script>

