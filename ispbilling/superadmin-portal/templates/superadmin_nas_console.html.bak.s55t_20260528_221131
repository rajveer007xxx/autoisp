function ncRunSetupHotspot(dry) {
    var out = document.getElementById('nc_hs_out');
    if (!__ncHotspot.nasId) { out.innerHTML = '<span class="text-danger">No NAS selected</span>'; return; }
    var payload = {
        interface:     $('#nc_hs_iface').val().trim() || 'ether3',
        address:       $('#nc_hs_addr').val().trim()  || '10.10.10.1/24',
        wan_interface: $('#nc_hs_wan').val().trim()   || 'ether1',
        dry_run:       !!dry,
        enable:        true
    };
    out.innerHTML = '<i class="fa fa-hourglass-half"></i> ' + (dry ? 'Previewing…' : 'Running setup on NAS…');
    $.ajax({
        url: cfgApiBase() + '/nas/' + __ncHotspot.nasId + '/setup-hotspot',
        method: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: function(j) {
            if (j && j.ok) {
                var cmds = (j.all_commands || []).slice(0, 30).map(function(c) {
                    return '<code style="display:block;padding:4px 8px;background:#f3f4f6;margin:2px 0;">' + c + '</code>';
                }).join('');
                out.innerHTML = '<div class="alert alert-success" style="margin:8px 0;">'
                              + '<b>' + (j.dry_run ? 'Preview' : 'Setup complete') + ' on ' + j.nas + '</b>'
                              + '<div style="max-height:260px;overflow:auto;margin-top:6px;">' + cmds + '</div>'
                              + (j.dry_run ? '<button class="btn btn-xs btn-success" onclick="ncRunSetupHotspot(false)">Now run for real</button>' : '')
                              + '</div>';
            } else {
                out.innerHTML = '<div class="alert alert-danger">' + ((j && j.error) || 'failed') + '</div>';
            }
        },
        error: function(xhr) {
            out.innerHTML = '<div class="alert alert-danger">Request error: ' + xhr.status + '</div>';
        }
