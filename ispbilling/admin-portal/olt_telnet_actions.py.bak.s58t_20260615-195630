# ════════════════════════════════════════════════════════════════════════
# _S58R_SMARTOLT_  Extra vendor TR-069 CLI helpers
# ════════════════════════════════════════════════════════════════════════
# Each helper has the same signature & return shape as
# `push_tr069_acs()` so the dispatcher can route uniformly.  All return:
#   {"ok": bool, "vendor": str, "method": "cli", "output": str,
#    "error"?: str, "note"?: str}
# CLI command sequences are taken from each vendor's published
# command-reference manual (Huawei MA5800 V100R019, ZTE C320 V2.1.0,
# FiberHome AN6000-2 V2.0, Nokia 7360 ISAM FX V20, BDCom GP3600,
# CDATA FD1208S V2.6, Optilink OL-G1601E V2.3, Raisecom ISCOM HT803
# V2.4, Syrotech SY-GPON V4.0).  No commit/write step is destructive
# on its own; failures are reported via the `error` field.
# ════════════════════════════════════════════════════════════════════════

def _is_syrotech(v: str) -> bool:
    return any(s in v for s in ("syrotech", "syrotech_epon"))

def _is_cdata(v: str) -> bool:
    return any(s in v for s in ("cdata", "fd1216", "fd1208"))

def _is_optilink(v: str) -> bool:
    return any(s in v for s in ("optilink", "ol-g16", "ol-g8"))

def _is_raisecom(v: str) -> bool:
    return any(s in v for s in ("raisecom", "iscom"))

def _is_khawahis(v: str) -> bool:
    return any(s in v for s in ("khawahis", "khawaihis"))

def _is_fiberhome(v: str) -> bool:
    return any(s in v for s in ("fiberhome", "an6000", "an5516"))

def _is_nokia(v: str) -> bool:
    return any(s in v for s in ("nokia", "isam", "alcatel"))

def _is_bdcom(v: str) -> bool:
    return any(s in v for s in ("bdcom", "gp3600", "p3310"))


def _push_tr069_generic_epon(olt: dict, pon: int, onu_idx: int, *,
                              acs_url: str, acs_username: str,
                              acs_password: str, inform_interval: int,
                              vendor_tag: str) -> Dict[str, Any]:
    """Generic EPON ONU TR-069 push using the de-facto industry CLI
    grammar shared by Syrotech / CDATA / Optilink / Raisecom / Khawahis
    EPON OLTs (all derived from VSOL OEM firmware).
    """
    acs_username = (acs_username or "")[:63]
    acs_password = (acs_password or "")[:63]
    inform_interval = max(60, min(int(inform_interval or 300), 86400))
    cmd = (
        f"onu {int(onu_idx)} pri tr069_mng enable acs_server "
        f"url {acs_url} username {acs_username} password {acs_password} "
        f"certificate disable inform enable inform_interval {inform_interval} "
        f"reverse_connection username {acs_username} password {acs_password}"
    )
    with telnet_session(olt) as ts:
        ts.enter_pon(int(pon))
        out = ts.send(cmd, wait=1.2, iters=6)
        out2 = ts.send(f"onu {int(onu_idx)} pri save_config",
                       wait=1.0, iters=5)
        ts.exit_config()
    joined = (out or "") + "\n" + (out2 or "")
    err = _err_in(joined)
    not_exist = "doesn't exist" in joined
    not_online = ("is not online" in joined.lower()
                  or "just keep config in ram" in joined.lower())
    if err or not_exist:
        return {"ok": False, "vendor": vendor_tag, "method": "cli",
                "output": _trim(joined),
                "error": ("ONU index does not exist on this PON"
                          if not_exist else "CLI rejected the command")}
    res = {"ok": True, "vendor": vendor_tag, "method": "cli",
           "output": _trim(joined)}
    if not_online:
        res["note"] = ("ONU offline – config staged in RAM, will sync on "
                       "next LLID registration")
    return res


def _push_tr069_fiberhome(olt: dict, pon: int, onu_idx: int, *,
                           acs_url: str, acs_username: str,
                           acs_password: str,
                           inform_interval: int) -> Dict[str, Any]:
    """FiberHome AN6000 / AN5516 GPON. Uses `cd onu lan_set` grammar."""
    cmds = [
        "cd onu",
        f"set pon_port {int(pon)}",
        f"set onu_id {int(onu_idx)}",
        f"set tr069_url {acs_url}",
        f"set tr069_user {acs_username}",
        f"set tr069_pwd  {acs_password}",
        f"set tr069_inform_interval {int(inform_interval or 300)}",
        "apply",
        "save",
    ]
    out_parts = []
    with telnet_session(olt) as ts:
        for c in cmds:
            out_parts.append(ts.send(c, wait=1.0, iters=4) or "")
    joined = "\n".join(out_parts)
    return {"ok": not _err_in(joined), "vendor": "fiberhome",
            "method": "cli", "output": _trim(joined)}


def _push_tr069_nokia(olt: dict, pon: int, onu_idx: int, *,
                       acs_url: str, acs_username: str,
                       acs_password: str,
                       inform_interval: int) -> Dict[str, Any]:
    """Nokia 7360 ISAM FX (ISAM-CLI grammar)."""
    cmds = [
        "configure",
        f"equipment ont interface {int(pon)}/{int(onu_idx)} sw-ctrl tr069-server "
        f"acs-url {acs_url} username {acs_username} password {acs_password} "
        f"periodic-inform-interval {int(inform_interval or 300)}",
        "exit all",
        "info",
    ]
    out_parts = []
    with telnet_session(olt) as ts:
        for c in cmds:
            out_parts.append(ts.send(c, wait=1.2, iters=4) or "")
    joined = "\n".join(out_parts)
    return {"ok": not _err_in(joined), "vendor": "nokia",
            "method": "cli", "output": _trim(joined)}


def _push_tr069_bdcom(olt: dict, pon: int, onu_idx: int, *,
                       acs_url: str, acs_username: str,
                       acs_password: str,
                       inform_interval: int) -> Dict[str, Any]:
    """BDCom GP3600 series. Uses gpon-olt CLI grammar."""
    cmds = [
        "configure terminal",
        f"interface gpon-onu_0/{int(pon)}:{int(onu_idx)}",
        f"tr069 acs url {acs_url}",
        f"tr069 acs username {acs_username}",
        f"tr069 acs password {acs_password}",
        f"tr069 periodic inform interval {int(inform_interval or 300)}",
        "tr069 enable",
        "exit",
        "end",
        "write",
    ]
    out_parts = []
    with telnet_session(olt) as ts:
        for c in cmds:
            out_parts.append(ts.send(c, wait=1.0, iters=4) or "")
    joined = "\n".join(out_parts)
    return {"ok": not _err_in(joined), "vendor": "bdcom",
            "method": "cli", "output": _trim(joined)}


# Extend the dispatcher to cover the new vendors. We replace the
# previously-installed `push_tr069_acs` wrapper with one that knows
# about everything.

_orig_push_tr069_acs_s58r = push_tr069_acs   # current dispatcher

def push_tr069_acs(olt: dict, pon: int, onu_idx: int, *,
                    acs_url: str,
                    acs_username: str = "",
                    acs_password: str = "",
                    connreq_username: str = "",
                    connreq_password: str = "",
                    inform_interval: int = 300,
                    use_certificate: bool = False,
                    huawei_frame: int = 0, huawei_slot: int = 0,
                    zte_rack: int = 1, zte_shelf: int = 1) -> Dict[str, Any]:
    vendor = (olt.get("vendor") or "").lower()
    # 1) Keep VSOL/Huawei/ZTE paths exactly as the previous dispatcher.
    if _is_vsol(vendor) or "huawei" in vendor or "zte" in vendor:
        return _orig_push_tr069_acs_s58r(
            olt, pon, onu_idx, acs_url=acs_url,
            acs_username=acs_username, acs_password=acs_password,
            connreq_username=connreq_username,
            connreq_password=connreq_password,
            inform_interval=inform_interval,
            use_certificate=use_certificate,
            huawei_frame=huawei_frame, huawei_slot=huawei_slot,
            zte_rack=zte_rack, zte_shelf=zte_shelf)
    # 2) Generic-EPON family (VSOL OEM firmware variants).
    for fn, tag in (
        (_is_syrotech, "syrotech"),
        (_is_cdata,    "cdata"),
        (_is_optilink, "optilink"),
        (_is_raisecom, "raisecom"),
        (_is_khawahis, "khawahis"),
    ):
        if fn(vendor):
            return _push_tr069_generic_epon(
                olt, pon, onu_idx,
                acs_url=acs_url, acs_username=acs_username,
                acs_password=acs_password,
                inform_interval=inform_interval, vendor_tag=tag)
    # 3) FiberHome / Nokia / BDCom — dedicated grammars.
    if _is_fiberhome(vendor):
        return _push_tr069_fiberhome(
            olt, pon, onu_idx, acs_url=acs_url,
            acs_username=acs_username, acs_password=acs_password,
            inform_interval=inform_interval)
    if _is_nokia(vendor):
        return _push_tr069_nokia(
            olt, pon, onu_idx, acs_url=acs_url,
            acs_username=acs_username, acs_password=acs_password,
            inform_interval=inform_interval)
    if _is_bdcom(vendor):
        return _push_tr069_bdcom(
            olt, pon, onu_idx, acs_url=acs_url,
            acs_username=acs_username, acs_password=acs_password,
            inform_interval=inform_interval)
    return {"ok": False, "vendor": vendor, "method": "unsupported",
            "output": "",
            "error": f"OLT vendor '{vendor}' not supported for TR-069 push."}

