                    "set-onu-default", "exit", "end", "write"]:
            out_parts.append(ts.send(cmd, wait=1.0, iters=4) or "")
    joined = "\n".join(out_parts)
    return {"ok": not _err_in(joined), "vendor": "zte", "method": "cli",
            "output": _trim(joined)}


