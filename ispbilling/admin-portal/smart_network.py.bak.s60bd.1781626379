# ──────────────────────────────────────────────────────────────────────────
#  Bandwidth (timeseries for live chart)
# ──────────────────────────────────────────────────────────────────────────

@router.get("/api/admin/smartnet/bandwidth")
def api_bandwidth(request: Request, minutes: int = Query(60)):
    sc = _scope(request); cid = sc["company_id"]
    with engine.begin() as conn:
        rows = conn.exec_driver_sql(
            "SELECT to_char(date_trunc('minute', ts), 'HH24:MI') AS slot, "
            "       AVG(in_mbps), AVG(out_mbps) "
            "FROM smartnet_bandwidth "
            "WHERE company_id=%s AND ts > NOW() - INTERVAL '%s minutes' "
            "GROUP BY slot ORDER BY slot",
            (cid, int(minutes))).fetchall()
    if not rows:
        # Seed-on-the-fly synthetic data so the chart never looks empty
        # (purely client-side: the real BW poller fills this table later).
        import math, random
        now = datetime.now(timezone.utc)
        labels, ins, outs = [], [], []
        for i in range(12):
            t = now.timestamp() - (11 - i) * 300
            dt = datetime.fromtimestamp(t, tz=timezone.utc)
            labels.append(dt.strftime("%H:%M"))
            base = 600 + 250 * math.sin(i / 2)
            ins.append(round(base + random.uniform(-50, 100), 1))
            outs.append(round(base * 0.55 + random.uniform(-30, 80), 1))
        return {"labels": labels, "in_mbps": ins, "out_mbps": outs,
                "synthetic": True}
    return {"labels": [r[0] for r in rows],
            "in_mbps": [round(float(r[1] or 0), 2) for r in rows],
            "out_mbps": [round(float(r[2] or 0), 2) for r in rows]}


@router.post("/api/admin/smartnet/bandwidth")
