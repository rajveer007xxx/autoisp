def _sync_freeradius_all_tenants(db: Session, restart: bool = True) -> dict:
    """Render `/etc/freeradius/3.0/clients.conf` + `isp-users` from the
    UNION of every tenant's data. The global FreeRADIUS daemon serves
    every tenant from a single file set, so partial renders (one
    tenant at a time) silently wipe the other tenants' users out.

    Called by:
      - `_auto_sync_after_nas_save` (every NAS create/update).
      - `api_fr_sync_all` (admin clicks Sync-All).
      - `api_fr_sync_global` (SuperAdmin / cron).
      - `nas_healthcheck.py` (every 5 min).

    Safe to call from any tenant context — the output is always global."""
    all_nas = []
    all_cust = []
    touched = []
    # Collect tenants from BOTH tables — a tenant may have customers but
    # no NAS rows (common when they physically share a partner ISP's
    # BNG), or NAS rows but no customers (fresh signup). Either way we
    # must visit them to produce a complete isp-users + clients.conf.
    tenant_ids = set()
    for (cid,) in db.query(NasDevice.company_id).distinct().all():
        if cid:
            tenant_ids.add(cid)
    from sqlalchemy import text as _text
    for (cid,) in db.execute(_text(
            "SELECT DISTINCT company_id FROM customers WHERE IFNULL(company_id,'')<>''")):
        if cid:
            tenant_ids.add(cid)
    # _S39NAS_TENANT_FILTER — only emit a tenant's customers into
    # FreeRADIUS isp-users when that tenant still has at least one
    # Active NAS. Otherwise admin A's customers keep authenticating
    # via admin B's router after a NAS reassignment.
    for cid in tenant_ids:
        nas_rows = db.query(NasDevice).filter(
            NasDevice.company_id == cid,
            NasDevice.status == "Active").all()
        if not nas_rows:
            cust_rows = []
        else:
            cust_rows = _build_customer_radius_rows_global(db, cid)
        if nas_rows:
            all_nas.extend(nas_rows)
        if cust_rows:
            all_cust.extend(cust_rows)
        if nas_rows or cust_rows:
            touched.append({"company_id": cid,
                             "nas": len(nas_rows),
                             "customers": len(cust_rows)})
    if not all_nas:
        return {"success": False,
                "message": "No Active NAS devices across any tenant — aborting global sync (would leave radiusd with empty clients.conf)."}
    res = fm.sync_all(all_nas, all_cust,
                       company_id="__global__", restart=restart)
    res["tenants"] = touched
    res["global"] = True
    # _S45_HARMONIZE_HOOK_SYNC — DISABLED (s45c rollback). Auto-running
    # the harmonizer on every Sync RADIUS was inserting /32 routes via
    # ether3 that conflicted with the dynamic /32 routes RouterOS creates
    # for active PPPoE sessions, breaking unrelated PPPoE customers'
    # internet. Harmonizer disabled here. It can still be triggered
    # manually via the /api/freeradius/harmonize-static-ips-all-nas endpoint.
    res["harmonize_static"] = "disabled (s45c rollback)"
    return res


def _resolve_public_ip() -> str:
    """Authoritative source for the PUBLIC IP that FreeRADIUS listens on.
    Used when we push `/radius address=...` to a customer's router.
    Chain:
      1. env `ISP_PUBLIC_IP` (set once at deploy time).
      2. outbound-interface first IPv4 (via `connect UDP to 8.8.8.8`
         trick — doesn't actually send a packet).
      3. empty string (caller must handle).
    NEVER derive from the HTTP request — an internal call from the
    SuperAdmin proxy returns 127.0.0.1 and silently corrupts routers."""
    ip = (os.environ.get("ISP_PUBLIC_IP") or "").strip()
    if ip and not ip.startswith("127."):
        return ip
    try:
        import socket as _sock
        s = _sock.socket(_sock.AF_INET, _sock.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        if ip and not ip.startswith("127."):
            return ip
    except Exception:
        pass
    return ""


def _build_customer_radius_rows_global(db, company_id):
    """Collect the billing-driven data FreeRADIUS needs for each active
    customer. DISPATCHES by `customers.auth_type`:

      • `pppoe`      (default) → Framed-Pool + Mikrotik-Rate-Limit +
                                  Mikrotik-Group + Service-Type=Framed.
      • `static_ip`  → Framed-IP-Address + Framed-IP-Netmask +
                      Mikrotik-Rate-Limit + Service-Type=Framed.
      • `hotspot`    → Session-Timeout + Idle-Timeout +
                      Mikrotik-Rate-Limit (no Framed-Pool; hotspot
                      issues its own DHCP).

    Each row emits the shape expected by `freeradius_manager._render_users_file`:
        {username, password, status, plan,
         nas_pool_name, parking_pool_name, auth_type,
         static_ip, static_netmask, session_timeout, idle_timeout}
    """
    from sqlalchemy import text as _text
    parking = db.query(IpPool).filter(IpPool.company_id == company_id,
                                       IpPool.role == "Parking").first()
    parking_name = parking.name if parking else "parking-pool"

    # --- Default pool name resolution (Session 19 revamp) -------------
    # FreeRADIUS is CASE-SENSITIVE on Framed-Pool and Mikrotik's /ip pool
    # lookup is also case-sensitive. A mismatch leaves sessions at
    # 0.0.0.0 or denies them outright.
    #
    # Priority order:
    #   1. Admin's explicit IpPool row (role=PPPoE) for THIS tenant —
    #      these are named with real casing (e.g. "PPPoE-Pool").
    #   2. Tenant's NAS pppoe_pool_name ONLY if that NAS was actually
    #      auto-provisioned (provisioned_at IS NOT NULL). Otherwise the
    #      column holds the lowercase default stub ("pppoe-pool") from
    #      NAS creation, which mismatches the real router pool name.
    #   3. Cross-tenant provisioned NAS pool name (wholesale setup).
    #   4. Lowercase stub "pppoe-pool" as absolute last resort.
    default_pool_name = None
    pppoe_ippool = (db.query(IpPool)
                      .filter(IpPool.company_id == company_id,
                              IpPool.role == "PPPoE",
                              IpPool.status == "Active",
                              IpPool.network != "",
                              IpPool.network.isnot(None))
                      .order_by(IpPool.id.asc())
                      .first())
    if pppoe_ippool and (pppoe_ippool.name or "").strip():
        default_pool_name = pppoe_ippool.name.strip()
    if not default_pool_name:
        prov_nas = (db.query(NasDevice)
                      .filter(NasDevice.company_id == company_id,
                              NasDevice.status == "Active",
                              NasDevice.pppoe_pool_name != "",
                              NasDevice.pppoe_pool_name.isnot(None),
                              NasDevice.provisioned_at.isnot(None))
                      .order_by(NasDevice.provisioned_at.desc()).first())
        if prov_nas and prov_nas.pppoe_pool_name:
            default_pool_name = prov_nas.pppoe_pool_name.strip()
    if not default_pool_name:
        cross_tenant = (db.query(NasDevice)
                          .filter(NasDevice.status == "Active",
                                  NasDevice.pppoe_pool_name != "",
                                  NasDevice.pppoe_pool_name.isnot(None),
                                  NasDevice.provisioned_at.isnot(None))
                          .order_by(NasDevice.provisioned_at.desc()).first())
        if cross_tenant and cross_tenant.pppoe_pool_name:
            default_pool_name = cross_tenant.pppoe_pool_name.strip()
    default_pool_name = default_pool_name or "pppoe-pool"

    # `auth_type` column added in Session 18 migration; COALESCE keeps us
    # safe on databases that haven't been migrated yet (rendered as PPPoE).
    sql = """
        SELECT c.id, c.username, c.pppoe_password, c.status,
               c.provisioned_nas_id,
               COALESCE(c.auth_type, 'pppoe')          AS auth_type,
               COALESCE(c.static_ip_address, '')       AS static_ip_address,
               COALESCE(c.static_netmask, '255.255.255.0') AS static_netmask,
               COALESCE(c.mac_address, '')             AS mac_address,
               COALESCE(c.bind_mac_address, 'No')      AS bind_mac_address,  -- __S38O_CONN_TAB__
               COALESCE(c.hotspot_session_timeout, 0)  AS hotspot_session_timeout,
               COALESCE(c.hotspot_idle_timeout, 600)   AS hotspot_idle_timeout,
               p.plan_name, p.download_speed, p.upload_speed,
               p.burst_enabled, p.burst_limit_up, p.burst_limit_down,
               p.burst_threshold_up, p.burst_threshold_down,
               p.burst_time_up, p.burst_time_down,
               n.pppoe_pool_name
          FROM customers c
          LEFT JOIN plans p ON p.id = c.plan_id
          LEFT JOIN nas_devices n ON n.id = c.provisioned_nas_id
         WHERE c.company_id = :cid AND IFNULL(c.username,'') <> ''
               AND IFNULL(c.pppoe_password,'') <> ''
               -- Session 20: skip cable-TV customers (no PPPoE), and
               -- skip admin-deactivated statuses so FreeRADIUS returns
               -- Access-Reject instead of parking them.
               AND LOWER(IFNULL(c.service_type,'')) <> 'cable'
               -- Session 25.3: per-company walled-garden toggle.
               -- When companies.walled_garden_enabled=1 (default) we keep
               -- Suspended/Disabled/Expired/Deactive users in the users file
               -- so they get parking attributes. When 0 we exclude them so
               -- FreeRADIUS returns Access-Reject (pre-s25.1 behaviour).
               AND IFNULL(c.status,'Active') NOT IN ('Terminated')
               AND (
                   (SELECT IFNULL(walled_garden_enabled,1) FROM companies
                    WHERE companies.company_id = :cid) = 1
                   OR IFNULL(c.status,'Active') = 'Active'
               )
    """
    rows = []
    for r in db.execute(_text(sql), {"cid": company_id}).mappings():
        plan = {
            "plan_name": r["plan_name"], "download_speed": r["download_speed"],
            "upload_speed": r["upload_speed"],
            "burst_enabled": r["burst_enabled"],
            "burst_limit_up": r["burst_limit_up"],
            "burst_limit_down": r["burst_limit_down"],
            "burst_threshold_up": r["burst_threshold_up"],
            "burst_threshold_down": r["burst_threshold_down"],
            "burst_time_up": r["burst_time_up"],
            "burst_time_down": r["burst_time_down"],
        }
        rows.append({
            "username": r["username"],
            "password": r["pppoe_password"],
            "status": r["status"] or "Active",
            "plan": plan,
            "nas_pool_name": r["pppoe_pool_name"] or default_pool_name,
            "parking_pool_name": parking_name,
            # NEW — per-customer auth-type dispatch.
            "auth_type": (r["auth_type"] or "pppoe").lower(),
            "static_ip": r["static_ip_address"] or "",
            "static_netmask": r["static_netmask"] or "255.255.255.0",
            "mac_address": r["mac_address"] or "",
            "bind_mac_address": (r["bind_mac_address"] or "No"),  # __S38O_CONN_TAB__
            "session_timeout": int(r["hotspot_session_timeout"] or 0),
            "idle_timeout": int(r["hotspot_idle_timeout"] or 600),
        })
    return rows


def _auto_sync_after_nas_save(db: Session, company_id: str, nas: "NasDevice") -> dict:
    """Invariant we want to hold after EVERY NAS row save:
      A. `/etc/freeradius/3.0/clients.conf` mentions this NAS with the
         current DB.secret (so FreeRADIUS validates router requests).
      B. Router's `/radius` entry has `address=<PUBLIC_IP>` AND
         `secret=<DB.secret>` (so router validates our replies).

    If the router is unreachable we PROCEED anyway (A will still be
    applied, B will be retried by the periodic health-check timer when
    the router next comes online).

    This single helper is the reason admins don't need to remember
    Sync-Secret / Sync-All after adding or editing a NAS. Runs on
    every NAS create + update; on delete we only do (A) with the NAS
    excluded."""
    report = {"clients_conf": None, "router": None}
    # A. Re-render clients.conf + isp-users GLOBALLY (union of every
    # tenant) so adding/editing one NAS does not silently wipe other
    # tenants' users out of the single shared isp-users file.
    try:
        r = _sync_freeradius_all_tenants(db, restart=True)
        report["clients_conf"] = {
            "success": r.get("success"),
            "clients_written": r.get("clients_written"),
            "users_written": r.get("users_written"),
            "restarted": r.get("restarted"),
            "tenants": r.get("tenants"),
        }
    except Exception as e:
        report["clients_conf"] = {"success": False, "error": str(e)}
    # B. Push to router (only if status=Active and we have creds)
    if (nas.status == "Active") and nas.ip_address and nas.api_password and nas.secret:
        public_ip = _resolve_public_ip()
        if not public_ip:
            report["router"] = {"success": False, "skipped": "no ISP_PUBLIC_IP env"}
        else:
            try:
                report["router"] = rp.sync_radius_secret(
                    nas, radius_server_ip=public_ip)
            except Exception as e:
                report["router"] = {"success": False, "error": str(e)}
    else:
        report["router"] = {"skipped": "nas not Active or missing creds"}
    return report


def _sync_static_ip_online_for_company(db, company_id, nas_rows=None,
                                         restart_radius: bool = False):
    """__S38T_STATIC_ONLINE__
    Update `online_users` for every Active auth_type=static_ip customer
    in `company_id`. Uses Mikrotik ARP + simple-queue counters to derive
    online state (no RADIUS/PPPoE for these customers).

    Returns: {"synced": <count>, "checked": <count>, "errors": [...]}.
    Safe to call repeatedly. Will NOT restart FreeRADIUS — purely a
    read-from-router + write-to-online_users operation.
    """
    # __S38T_STATIC_ONLINE__ — use raw SQL because the cron may import a
    # different `database` module than admin-portal (sys.path race —
    # /opt/ispbilling/database.py predates the multi-auth columns).
    from sqlalchemy import text as _text_st
    res = {"synced": 0, "checked": 0, "errors": []}
    try:
        if nas_rows is None:
            nas_rows = (db.query(NasDevice)
                          .filter(NasDevice.company_id == company_id,
                                  NasDevice.status == "Active").all())
        if not nas_rows:
            return res
        # Light-weight customer dict — only the fields we need below.
        static_rows = []
        for r in db.execute(_text_st("""
                SELECT id, customer_id, username,
                       COALESCE(static_ip_address,'') AS static_ip_address
                  FROM customers
                 WHERE company_id = :cid
                   AND COALESCE(auth_type,'pppoe') = 'static_ip'
                   AND COALESCE(status,'') = 'Active'
                   AND COALESCE(static_ip_address,'') <> ''
            """), {"cid": company_id}).mappings():
            static_rows.append(dict(r))
        res["checked"] = len(static_rows)
        if not static_rows:
            return res
        # Aggregate ARP + queue across every Active NAS.
        arp_by_ip, queue_by_target = {}, {}
        for nas in nas_rows:
            try:
                _ctx = rp.RouterOSClient(nas, dry_run=False)
                cc = _ctx.__enter__()
                for a in cc._api.path("ip/arp"):
                    ip = (a.get("address") or "").strip()
                    if ip and (ip not in arp_by_ip or a.get("mac-address")):
                        arp_by_ip[ip] = {"mac": a.get("mac-address") or "",
                                          "interface": a.get("interface"),
                                          "nas_ip": nas.ip_address}
                for q in cc._api.path("queue/simple"):
                    tgt = (q.get("target") or "").strip()
                    if tgt:
                        queue_by_target[tgt] = {"bytes": q.get("bytes") or "",
                                                "rate":  q.get("rate") or ""}
                _ctx.__exit__(None, None, None)
            except Exception as _ne:
                res["errors"].append(f"nas {getattr(nas,'name',nas.id)}: {_ne}")
                try: _ctx.__exit__(None, None, None)
                except Exception: pass
        for cust in static_rows:
            # cust is a plain dict from raw SQL
            sip = (cust.get("static_ip_address") or "").strip()
            if not sip:
                continue
            arp = arp_by_ip.get(sip)
            q = queue_by_target.get(f"{sip}/32")
            has_arp = bool(arp and (arp.get("mac") or "").strip())
            try:
                bytes_total_str = str((q or {}).get("bytes") or "0")
                # bytes is "<up>/<down>" — sum them
                if "/" in bytes_total_str:
                    bn = sum(int(x or 0) for x in bytes_total_str.split("/"))
                else:
                    bn = int(bytes_total_str or 0)
            except Exception:
                bn = 0
            is_up = has_arp or bn > 0
            username = (cust.get("username") or "").strip() or cust.get("customer_id") or ""
            ou = (db.query(OnlineUser)
                    .filter(OnlineUser.company_id == company_id,
                            OnlineUser.username == username).first())
            if not ou:
                if not is_up:
                    continue  # no need to create an Offline placeholder
                ou = OnlineUser(company_id=company_id, username=username,
                                started_at=datetime.utcnow())
                db.add(ou)
            # __S38T_TIMING__ — reset started_at on Offline -> Online flip
            # so the UI shows the actual session start, not when the
            # online_users row was first created weeks ago.
            _prev_status = (ou.status or "Offline")
            _new_status = "Online" if is_up else "Offline"
            if _new_status == "Online" and _prev_status != "Online":
                ou.started_at = datetime.utcnow()
                ou.uptime_seconds = 0
            ou.ip_address = sip
            ou.nas_ip = (arp or {}).get("nas_ip") or ou.nas_ip or ""
            ou.session_id = f"static-{sip}"
            ou.framed_protocol = "Static"
            ou.status = _new_status
            ou.mac_address = (arp or {}).get("mac", "") or ou.mac_address or ""
            ou.nas_port_id = (arp or {}).get("interface", "") or ou.nas_port_id or ""
            # uptime_seconds for static-IP = wall-clock since started_at
            try:
                if ou.started_at and _new_status == "Online":
                    ou.uptime_seconds = max(0, int(
                        (datetime.utcnow() - ou.started_at).total_seconds()))
            except Exception:
                pass
            try:
                raw = (q or {}).get("bytes") or ""
                if "/" in str(raw):
                    up_s, dn_s = str(raw).split("/", 1)
                    ou.bytes_in  = float(up_s or 0) / (1024.0 * 1024.0)
                    ou.bytes_out = float(dn_s or 0) / (1024.0 * 1024.0)
            except Exception:
                pass
            ou.updated_at = datetime.utcnow()
            if is_up:
                res["synced"] += 1
        try:
            db.commit()
        except Exception as _ce:
            db.rollback()
            res["errors"].append(f"commit: {_ce}")
    except Exception as e:
        res["errors"].append(f"top: {e}")
    return res



# _S45_STATIC_IP_HARMONIZER --------------------------------------------------
def harmonize_static_ip_on_nas(nas, username, static_ip, mac_address,
                                customer_id="", dry_run=False):
    """Make a customer's static IP work via BOTH PPPoE and raw-static config.

    Steps (each idempotent):
      A. /ppp secret      : set remote-address=<static_ip>  (PPPoE-mode pin)
      B. /ip arp          : static bind static_ip -> mac on the WAN-facing
                            interface (the iface holding an /ip address whose
                            network covers static_ip).
      C. /ip route        : add dst=<static_ip>/32 gateway=<wan-iface>
                            (lets the NAS route to the CPE even when no
                             PPPoE session is up).
      D. /ip firewall address-list : add <static_ip> to allowed-static.
      E. /ip firewall filter       : ensure ONE chain=forward src-list=
                                      allowed-static accept rule exists.
      F. /ip firewall nat          : ensure srcnat masquerade for static_ip.

    Returns a dict of per-step results. Failures on one step don't abort
    the others.
    """
    import ipaddress, routeros_provision as rp
    out = {"customer_id": customer_id, "username": username,
           "static_ip": static_ip, "mac": mac_address,
           "steps": {}, "dry_run": dry_run}
    if not static_ip:
        out["skipped"] = "no static_ip"; return out

    try:
        sip = ipaddress.ip_address(static_ip)
    except Exception as e:
        out["error"] = f"invalid static_ip: {e}"; return out

    try:
        with rp.RouterOSClient(nas, dry_run=dry_run) as c:
            api = c._api
            ssh = c._ssh
            if not api and not ssh:
                out["error"] = "no transport"; return out

            def _list(p):
                if api:
                    try: return list(api.path(p))
                    except Exception as e: return []
                return []

            # ---- Identify WAN-facing iface (the one holding the subnet) ----
            wan_iface = None
            for r in _list("ip/address"):
                if not isinstance(r, dict): continue
                addr = (r.get("address") or "").strip()
                if "/" not in addr: continue
                try:
                    net = ipaddress.ip_network(addr, strict=False)
                    if sip in net:
                        wan_iface = r.get("interface")
                        break
                except Exception:
                    pass
            out["wan_iface"] = wan_iface

            # A. /ppp secret remote-address pin -----------------------------
            if username:
                try:
                    sec_path = api.path("ppp/secret") if api else None
                    if sec_path is not None:
                        target = None
                        for s in list(sec_path):
                            if s.get("name") == username:
                                target = s; break
                        if target:
                            cur = target.get("remote-address") or ""
                            if cur != static_ip:
                                if not dry_run:
                                    sec_path.update(**{".id": target[".id"],
                                                       "remote-address": static_ip})
                                out["steps"]["ppp_secret_pin"] = {
                                    "from": cur or None, "to": static_ip}
                            else:
                                out["steps"]["ppp_secret_pin"] = "already_set"
                        else:
                            out["steps"]["ppp_secret_pin"] = "no_local_secret"
                    elif ssh:
                        if not dry_run:
                            ssh.exec(f"/ppp secret set [find name={username}] "
                                     f"remote-address={static_ip}")
                        out["steps"]["ppp_secret_pin"] = "ssh_applied"
                except Exception as e:
                    out["steps"]["ppp_secret_pin"] = f"error: {e}"

            # B. /ip arp static binding (needs MAC + interface) -------------
            # _S45_ARP_BIND — RouterOS rejects updates to DYNAMIC arp entries
            # with "can not change dynamic entry". The fix: detect dynamic
            # entries for our IP, remove them, then add a clean static one.
            if wan_iface and mac_address:
                try:
                    arp_path = api.path("ip/arp") if api else None
                    if arp_path is not None:
                        norm_mac = (mac_address or "").upper().replace("-", ":")
                        static_match = None
                        dynamic_match = None
                        for r in list(arp_path):
                            if (r.get("address") == static_ip
                                    and r.get("interface") == wan_iface):
                                is_dyn = (str(r.get("dynamic", "")).lower()
                                            in ("true", "yes", "1"))
                                if is_dyn:
                                    dynamic_match = r
                                else:
                                    static_match = r
                        if static_match:
                            existing_mac = (static_match.get("mac-address") or "").upper()
                            if existing_mac != norm_mac:
                                if not dry_run:
                                    arp_path.update(**{".id": static_match[".id"],
                                                       "mac-address": norm_mac})
                                out["steps"]["arp_bind"] = {
                                    "from": existing_mac, "to": norm_mac}
                            else:
                                out["steps"]["arp_bind"] = "already_set"
                            # If a stray dynamic entry exists alongside, drop it
                            if dynamic_match and not dry_run:
                                try:
                                    arp_path.remove(dynamic_match[".id"])
                                except Exception:
                                    pass
                        else:
                            # No static yet. Remove dynamic first if present.
                            if dynamic_match and not dry_run:
                                try:
                                    arp_path.remove(dynamic_match[".id"])
                                except Exception as _e:
                                    out["steps"]["arp_bind_pre"] = (
                                        f"could not drop dynamic: {_e}")
                            if not dry_run:
                                arp_path.add(address=static_ip,
                                             **{"mac-address": norm_mac},
                                             interface=wan_iface,
                                             comment=f"cust:{customer_id}")
                            out["steps"]["arp_bind"] = (
                                "added (after dynamic removed)" if dynamic_match
                                else "added")
                except Exception as e:
                    out["steps"]["arp_bind"] = f"error: {e}"
            else:
                out["steps"]["arp_bind"] = (
                    "skipped: no_wan_iface" if not wan_iface
                    else "skipped: no_mac")

            # C. /ip route <static_ip>/32 -> wan_iface ----------------------
            if wan_iface:
                try:
                    route_path = api.path("ip/route") if api else None
                    if route_path is not None:
                        dst_target = f"{static_ip}/32"
                        existing = None
                        for r in list(route_path):
                            if r.get("dst-address") == dst_target:
                                existing = r; break
                        if not existing:
                            if not dry_run:
                                route_path.add(**{"dst-address": dst_target},
                                               gateway=wan_iface,
                                               comment=f"cust:{customer_id}")
                            out["steps"]["static_route"] = "added"
                        else:
                            out["steps"]["static_route"] = "already_set"
                except Exception as e:
                    out["steps"]["static_route"] = f"error: {e}"

            # D. /ip firewall address-list -> allowed-static ---------------
            try:
                al_path = api.path("ip/firewall/address-list") if api else None
                if al_path is not None:
                    already = False
                    for r in list(al_path):
                        if (r.get("list") == "allowed-static"
                                and r.get("address") == static_ip):
                            already = True; break
                    if not already:
                        if not dry_run:
                            al_path.add(list="allowed-static",
                                        address=static_ip,
                                        comment=f"cust:{customer_id}")
                        out["steps"]["allowed_static"] = "added"
                    else:
                        out["steps"]["allowed_static"] = "already_set"
            except Exception as e:
                out["steps"]["allowed_static"] = f"error: {e}"

            # E. forward accept rule (one-time per NAS) --------------------
            try:
                ff_path = api.path("ip/firewall/filter") if api else None
                if ff_path is not None:
                    rule_exists = False
                    for r in list(ff_path):
                        if (r.get("chain") == "forward"
                                and r.get("src-address-list") == "allowed-static"
                                and r.get("action") == "accept"):
                            rule_exists = True; break
                    if not rule_exists:
                        if not dry_run:
                            ff_path.add(chain="forward",
                                        **{"src-address-list": "allowed-static",
                                           "place-before": "0"},
                                        action="accept",
                                        comment="allow-static-ips")
                        out["steps"]["forward_accept"] = "added"
                    else:
                        out["steps"]["forward_accept"] = "already_set"
            except Exception as e:
                out["steps"]["forward_accept"] = f"error: {e}"

            # F. srcnat masquerade per static IP ---------------------------
            try:
                nat_path = api.path("ip/firewall/nat") if api else None
                if nat_path is not None:
                    exists = False
                    for r in list(nat_path):
                        if (r.get("chain") == "srcnat"
                                and r.get("src-address") == static_ip
                                and r.get("action") == "masquerade"):
                            exists = True; break
                    if not exists:
                        if not dry_run:
                            nat_path.add(chain="srcnat",
                                         **{"src-address": static_ip},
                                         action="masquerade",
                                         comment=f"cust:{customer_id}")
                        out["steps"]["srcnat_masquerade"] = "added"
                    else:
                        out["steps"]["srcnat_masquerade"] = "already_set"
            except Exception as e:
                out["steps"]["srcnat_masquerade"] = f"error: {e}"

    except Exception as e:
        out["error"] = f"transport: {e}"
    return out


def harmonize_static_ips_for_tenant(db, company_id, dry_run=False,
                                     usernames=None):
    """Run harmonize_static_ip_on_nas for every static-IP-bearing customer
    in `company_id`, against each ACTIVE NAS in that tenant.

    `usernames` (optional) restricts to specific usernames — used by the
    provision hook to harmonize just the customer that was provisioned.

    Returns aggregate per-customer / per-NAS results.
    """
    from sqlalchemy import text as _text
    sql = """
        SELECT customer_id, username, static_ip_address, mac_address,
                provisioned_nas_id
          FROM customers
         WHERE company_id = :cid
           AND IFNULL(static_ip_address,'') <> ''
           AND IFNULL(username,'') <> ''
           AND IFNULL(status,'Active') NOT IN ('Terminated','Deleted')
    """
    cust_rows = list(db.execute(_text(sql), {"cid": company_id}).mappings())
    if usernames:
        wanted = {u.lower() for u in usernames}
        cust_rows = [r for r in cust_rows
                      if (r["username"] or "").lower() in wanted]
    nas_rows = db.query(NasDevice).filter(
        NasDevice.company_id == company_id,
        NasDevice.status == "Active").all()
    if not nas_rows:
        return {"company_id": company_id, "nas_count": 0,
                "customer_count": len(cust_rows),
                "results": [], "message": "no Active NAS in tenant"}
    results = []
    for nas in nas_rows:
        for r in cust_rows:
            res = harmonize_static_ip_on_nas(
                nas=nas,
                username=r["username"],
                static_ip=r["static_ip_address"],
                mac_address=r["mac_address"] or "",
                customer_id=r["customer_id"] or "",
                dry_run=dry_run,
            )
            res["nas_id"] = nas.id
            res["nas_name"] = nas.name
            results.append(res)
    return {"company_id": company_id, "nas_count": len(nas_rows),
             "customer_count": len(cust_rows), "results": results,
             "dry_run": dry_run}


def register_network_routes(app, templates, require_admin, require_auth, get_admin_context, require_admin_or_internal=None):

    # ===== Online Users =====
    # _BUG12_THROTTLE_ : per-company in-memory cooldown (25s) for NAS-refresh
    _ou_nas_refresh_at = {}

    @app.get("/admin/online-users")
    async def page_online_users(request: Request, db: Session = Depends(get_db)):
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        _ensure_seeded(db, company_id)
        # _BUG12_BGTHREAD_ : kick off the background refresher
        # the first time anyone visits this page, then render from DB.
        _bug12_start_thread_once()
        # _BUG12_THROTTLE_ : skip NAS-refresh if it ran in the last 25s
        import time as _t12; _now12 = _t12.time()
        _skip_nas_refresh_bug12 = True  # _BUG12_BGTHREAD_ owns refresh
        if not _skip_nas_refresh_bug12:
            _ou_nas_refresh_at[company_id] = _now12
        try:
            if _skip_nas_refresh_bug12:
                raise _BUG12_Skip("throttled")
            nas_rows = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").all()
            seen = set()
            for nas in nas_rows:
                try:
                    _ctx = rp.RouterOSClient(nas, dry_run=False)
                    c = _ctx.__enter__()
                    active = c.list_pppoe_active()
                    for row in active:
                        u = (row.get("name") or "").strip()
                        if not u:
                            continue
                        b_in = row.get("bytes-in") or row.get("rx-byte") or 0
                        b_out = row.get("bytes-out") or row.get("tx-byte") or 0
                        if (not b_in) and (not b_out):
                            try:
                                iname = "<pppoe-" + u + ">"
                                for i in c._api.path("interface"):
                                    if i.get("name") == iname:
                                        b_in  = int(i.get("rx-byte") or 0)
                                        b_out = int(i.get("tx-byte") or 0)
                                        break
                            except Exception:
                                pass
                        ou = db.query(OnlineUser).filter(
                            OnlineUser.company_id == company_id,
                            OnlineUser.username == u).first()
                        _was_online_p = bool(ou and (ou.status or "") == "Online")
                        if not ou:
                            ou = OnlineUser(company_id=company_id, username=u,
                                            started_at=datetime.utcnow())
                            db.add(ou)
                        ou.ip_address = row.get("address") or ou.ip_address or ""
                        ou.nas_ip = nas.ip_address
                        # s26.5: walled-garden-excluded — only mark as Online
                        # if the customer is actually an Active subscriber.
                        # Suspended/Expired/Disabled/Deactive users are parked
                        # in the walled-garden pool and must NOT appear in
                        # the Online Users dashboard / count badge.
                        try:
                            from database import Customer as _CC
                            _cust = db.query(_CC).filter(
                                _CC.company_id == company_id,
                                _CC.username == u).first()
                            _status = ((_cust.status if _cust else "") or "").strip().lower()
                        except Exception:
                            _status = "active"
                        ou.status = "Online" if _status == "active" else "WalledGarden"
                        ou.mac_address = row.get("caller-id") or ou.mac_address or ""
                        ou.nas_port_id = row.get("service") or ou.nas_port_id or ""
                        ou.updated_at = datetime.utcnow()
                        try:
                            ou.bytes_in  = float(b_in)  / (1024.0 * 1024.0)
                            ou.bytes_out = float(b_out) / (1024.0 * 1024.0)
                        except Exception:
                            pass
                        try:
                            import re as _re
                            up = row.get("uptime") or "0s"
                            secs = 0
                            for num, unit in _re.findall(r"(\d+)([dhms])", up):
                                secs += int(num) * {"d": 86400, "h": 3600, "m": 60, "s": 1}[unit]
                            ou.uptime_seconds = secs or ou.uptime_seconds or 0
                            # __S38T_TIMING__ — derive started_at from live PPPoE
                            # uptime so the "Connected since" matches the actual
                            # session, not when the row was first created.
                            from datetime import timedelta as _td
                            if secs is not None:
                                ou.started_at = datetime.utcnow() - _td(seconds=int(secs))
                        except Exception:
                            pass
                        seen.add(u)

                    # __page_hotspot_active__ — also include /ip/hotspot/active
                    try:
                        for hrow in c.list_hotspot_active():
                            u = (hrow.get("user") or hrow.get("name") or "").strip()
                            if not u:
                                continue
                            ou = db.query(OnlineUser).filter(
                                OnlineUser.company_id == company_id,
                                OnlineUser.username == u).first()
                            if not ou:
                                ou = OnlineUser(company_id=company_id, username=u,
                                                started_at=datetime.utcnow())
                                db.add(ou)
                            ou.ip_address = hrow.get("address") or ou.ip_address or ""
                            ou.nas_ip = nas.ip_address
                            ou.framed_protocol = "Hotspot"
                            ou.mac_address = hrow.get("mac-address") or hrow.get("caller-id") or ou.mac_address or ""
                            ou.nas_port_id = hrow.get("server") or ou.nas_port_id or ""
                            ou.updated_at = datetime.utcnow()
                            try:
                                from database import Customer as _CCh, HotspotVoucher as _HV2
                                _cu = db.query(_CCh).filter(
                                    _CCh.company_id == company_id,
                                    _CCh.username == u).first()
                                _st = ((_cu.status if _cu else "") or "").strip().lower()
                                if not _cu:
                                    _v2 = db.query(_HV2).filter(_HV2.code == u).first()
                                    if _v2:
                                        _st = "active"
                            except Exception:
                                _st = "active"
                            ou.status = "Online" if _st == "active" else "WalledGarden"
                            try:
                                ou.bytes_in  = float(hrow.get("bytes-in")  or 0) / (1024.0 * 1024.0)
                                ou.bytes_out = float(hrow.get("bytes-out") or 0) / (1024.0 * 1024.0)
                            except Exception:
                                pass
                            try:
                                import re as _reh
                                up = hrow.get("uptime") or "0s"
                                secs = 0
                                for num, unit in _reh.findall(r"(\d+)([dhms])", up):
                                    secs += int(num) * {"d": 86400, "h": 3600, "m": 60, "s": 1}[unit]
                                ou.uptime_seconds = secs or ou.uptime_seconds or 0
                                from datetime import timedelta as _tdh
                                if secs is not None and secs > 0:
                                    ou.started_at = datetime.utcnow() - _tdh(seconds=int(secs))
                            except Exception:
                                pass
                            seen.add(u)
                    except Exception as _hex:
                        print(f"[warn] hotspot-active page sync failed: {_hex}")
                    _ctx.__exit__(None, None, None)
                except Exception:
                    pass
            # Mark users not seen as Offline
            for ou in db.query(OnlineUser).filter(
                    OnlineUser.company_id == company_id,
                    OnlineUser.status == "Online").all():
                if ou.username not in seen:
                    ou.status = "Offline"
            db.commit()
        except _BUG12_Skip:
            pass  # rendered from DB only this turn
        except Exception:
            db.rollback()
        # __S38T_STATIC_ONLINE__ — also refresh static-IP customers'''
        # online state (no PPPoE session, so they need ARP+queue probe).
        # _BUG12B_STATIC_THROTTLE_ : honour the same 25s throttle
        if not _skip_nas_refresh_bug12:
            try:
                _sync_static_ip_online_for_company(db, company_id)
            except Exception as _se:
                print(f"[warn] static-IP online sync (page) failed: {_se}")
        context = get_admin_context(request, db, "online_users")
        # S42L — Online Users page MUST only show truly-Active customers
        # on a usable IP pool. Parked / Expired / Disabled / Suspended /
        # Cancelled / Terminated / Deactivated rows are filtered out
        # (regardless of their `online_users.status`) so the page stays
        # noise-free. Parked sessions remain visible on the per-subscriber
        # Current Session / Current Usage page.
        _EXCLUDED_CUST_STATUSES = (
            "Expired", "expired",
            "Disabled", "disabled",
            "Deactivated", "deactivated",
            "Suspended", "suspended",
            "Parked", "parked",
            "Cancelled", "cancelled", "Canceled", "canceled",
            "Terminated", "terminated",
            "Deleted", "deleted",
        )
        from database import Customer as _CFilt
        _excluded_unames = {
            c.username for c in db.query(_CFilt).filter(
                _CFilt.company_id == company_id,
                _CFilt.username.isnot(None),
                _CFilt.status.in_(_EXCLUDED_CUST_STATUSES),
            ).all() if c.username
        }
        # __S43ZK__ Exclude parked-status customers at SQL level
        # __S43ZL__ + exclude users whose ip_address is in any parking pool.
        from database import Customer as _Cust_zk
        from sqlalchemy import func as _func_zk, text as _text_zk
        try:
            _parked_prefixes = []
            for _r in db.execute(_text_zk(
                "SELECT network FROM ip_pools WHERE company_id=:c "
                " AND LOWER(COALESCE(role,''))='parking'"
            ), {"c": company_id}).fetchall():
                _net = (_r[0] or "")
                if "/" in _net:
                    _net = _net.split("/", 1)[0]
                # Convert CIDR base (e.g. 10.99.99.0) to LIKE prefix '10.99.99.%'
                _parts = _net.split(".")
                if len(_parts) == 4:
                    _pref = ".".join(_parts[:3]) + "."
                    _parked_prefixes.append(_pref)
        except Exception as _e_zl:
            print(f"[admin/online-users] s43zl prefix load failed: {_e_zl}")
            _parked_prefixes = []
        rows = (db.query(OnlineUser)
                  .outerjoin(_Cust_zk,
                             (OnlineUser.username == _Cust_zk.username) &
                             (OnlineUser.company_id == _Cust_zk.company_id))
                  .filter(OnlineUser.company_id == company_id,
                          OnlineUser.status == "Online",
                          _func_zk.lower(_func_zk.coalesce(_Cust_zk.status, "")).notin_(
                              ["expired","disabled","deactivated","deactive",
                               "suspended","parked","cancelled","canceled",
                               "terminated","deleted"]))
                  .order_by(OnlineUser.updated_at.desc().nullslast(),
                            OnlineUser.started_at.desc())
                  .all())
        if _parked_prefixes:
            rows = [r for r in rows
                    if not any((r.ip_address or "").startswith(p) for p in _parked_prefixes)]
        # Drop rows whose customer is in an excluded status.
        rows = [r for r in rows if r.username not in _excluded_unames]
        nas_list = db.query(NasDevice).filter(
            NasDevice.company_id == company_id).all()
        nas_by_ip = {n.ip_address: n for n in nas_list}
        # Attach resolved NAS name + customer name for each row.
        from database import Customer as _C
        cust_map = {c.username: c for c in db.query(_C).filter(
            _C.company_id == company_id).all() if c.username}
        # __VLAN_LIVE__: build username -> (vlan_enabled, expected_vlan_id) lookup
        _vlan_lookup = {}
        try:
            from sqlalchemy import text as _t_vl
            for _vr in db.execute(_t_vl(
                "SELECT username, COALESCE(vlan_enabled,0), vlan_id "
                "  FROM customers WHERE company_id=:c AND username IS NOT NULL"
            ), {"c": company_id}).fetchall():
                _vlan_lookup[_vr[0]] = (int(_vr[1] or 0),
                                        int(_vr[2]) if _vr[2] is not None else None)
        except Exception as _vex:
            print(f"[admin/online-users] vlan lookup failed: {_vex}")
            _vlan_lookup = {}
        enriched = []
        for r in rows:
            nas = nas_by_ip.get(r.nas_ip)
            cust = cust_map.get(r.username)
            _v_enabled, _v_expected = _vlan_lookup.get(r.username, (0, None))
            # S42K-PARKED-VIS: enrich row dict with `status` so the template
            # can show a "Parked" pill next to WalledGarden sessions.
            enriched.append({
                "id": r.id, "username": r.username,
                "ip_address": r.ip_address or "",
                "nas_ip": r.nas_ip or "",
                "nas_name": (nas.name if nas else r.nas_ip or ""),
                "nas_id": (nas.id if nas else ""),
                "nas_port_id": r.nas_port_id or "",
                "mac_address": r.mac_address or "",
                "session_id": r.session_id or "",
                "framed_protocol": r.framed_protocol or "",
                "uptime_seconds": r.uptime_seconds or 0,
                "bytes_in": r.bytes_in or 0,
                "bytes_out": r.bytes_out or 0,
                "started_at": r.started_at,
                "customer_id": (cust.customer_id if cust else ""),
                "customer_pk": (cust.id if cust else 0),
                "customer_name": (cust.customer_name if cust else ""),
                "status": r.status or "Online",
                "vlan_enabled": _v_enabled,
                "expected_vlan_id": _v_expected,
                "live_vlan_id": getattr(r, "live_vlan_id", None),
                "live_vlan_iface": getattr(r, "live_vlan_iface", "") or "",
            })
        context["online_users"] = enriched
        context["nas_list"] = nas_list
        return templates.TemplateResponse("admin_online_users.html", context)

