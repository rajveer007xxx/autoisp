    @app.post("/api/public-ips/{row_id}/assign")
    async def api_publicip_assign(row_id: int, request: Request, db: Session = Depends(get_db)):
        """Assign a public IP to a PPPoE secret on a specific NAS (remote-address override)."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        row = db.query(PublicIpAddress).filter(PublicIpAddress.id == row_id,
                                                PublicIpAddress.company_id == company_id).first()
        if not row:
            return JSONResponse({"success": False, "message": "Not found"}, status_code=404)
        data = await request.json()
        nas_id = int(data.get("nas_id") or 0)
        username = (data.get("username") or "").strip()
        dry_run = bool(data.get("dry_run", True))
        if not nas_id or not username:
            return JSONResponse({"success": False, "message": "nas_id and username required"}, status_code=400)
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)

        # Push to the router: update PPPoE secret's remote-address
        try:
            with rp.RouterOSClient(nas, dry_run=dry_run) as c:
                cli = c._cli("ppp/secret", "set", **{"where": f"name={username}",
                                                     "remote-address": row.ip_address})
                c.commands.append(cli)
                if not dry_run:
                    if c._ssh:
                        out, err, rc = c._ssh.exec(f"/ppp secret set [find name={username}] remote-address={row.ip_address}")
                    else:
                        path_obj = c._api.path("ppp/secret")
                        found = False
                        for r in list(path_obj):
                            if r.get("name") == username:
                                path_obj.update(**{".id": r[".id"],
                                                   "remote-address": row.ip_address})
                                found = True
                                break
                        if not found:
                            return JSONResponse({"success": False,
                                                 "message": f"PPPoE secret '{username}' not found on NAS"},
                                                 status_code=404)
                commands = c.commands
        except Exception as e:
            return JSONResponse({"success": False, "message": str(e)}, status_code=500)

        if not dry_run:
            row.status = "Assigned"
            row.assigned_to = username
            row.assigned_nas_id = nas_id
            db.commit()
        return {"success": True, "dry_run": dry_run, "commands": commands,
                "ip_address": row.ip_address, "username": username}

