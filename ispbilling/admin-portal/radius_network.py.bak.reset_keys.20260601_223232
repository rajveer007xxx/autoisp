    def _log_nas_audit(request, company_id, nas, action, old_snapshot=None,
                        new_snapshot=None, summary_extra=""):
        """s37p: audit-log admin-initiated NAS mutations. Fire-and-forget.

        Skipped when the caller is the internal-token proxy (i.e. SuperAdmin
        acting via _sa_admin_call) — that path audits separately with
        actor_type='superadmin' via s37o._log_sa_nas_action to avoid
        duplicate rows."""
        try:
            tok = request.headers.get("X-Internal-Token") or \
                  request.headers.get("x-internal-token")
            # s37p: if this is a SuperAdmin proxy call, don't skip — log
            # with the forwarded X-Actor-* identity so the audit trail
            # captures BOTH admin- and superadmin-initiated changes.
            _sa_actor = None
            if tok:
                _sa_actor = {
                    "id":   request.headers.get("X-Actor-Id")   or request.headers.get("x-actor-id")   or "",
                    "name": request.headers.get("X-Actor-Name") or request.headers.get("x-actor-name") or "superadmin (via proxy)",
                    "type": request.headers.get("X-Actor-Type") or request.headers.get("x-actor-type") or "superadmin",
                }
            from sqlalchemy import text as _sql
            import json as _json
            nas_name = getattr(nas, "name", f"NAS#{getattr(nas,'id','?')}")
            # Build diff string if we have old+new snapshots.
            diff_parts = []
            if old_snapshot and new_snapshot:
                for k, old_v in old_snapshot.items():
                    new_v = new_snapshot.get(k)
                    if str(old_v or "") != str(new_v or ""):
                        # Hide sensitive values in the human summary.
                        if k in ("api_password", "secret"):
                            diff_parts.append(f"{k}:***")
                        else:
                            ov = str(old_v or "")[:40]
                            nv = str(new_v or "")[:40]
                            diff_parts.append(f"{k}:{ov}→{nv}")
            diff_txt = ", ".join(diff_parts[:8])
            if len(diff_parts) > 8:
                diff_txt += f" (+{len(diff_parts)-8} more)"
            act_label = {"create": "Created NAS",
                         "update": "Updated NAS",
                         "delete": "Deleted NAS"}.get(action, f"{action} NAS")
            summary = f"[OK] {act_label} {nas_name}"
            if diff_txt:
                summary += f" — {diff_txt}"
            if summary_extra:
                summary += f" · {summary_extra}"

            if _sa_actor:
                actor_id   = _sa_actor["id"]
                actor_name = _sa_actor["name"]
                actor_type = _sa_actor["type"]
            else:
                actor_id   = request.session.get("user_id", "")
                actor_name = request.session.get("user_name") or actor_id or "admin"
                actor_type = "admin"
            payload = _json.dumps({
                "action":   action,
                "nas_id":   getattr(nas, "id", None),
                "nas_name": nas_name,
                "diff":     {k: {"old": old_snapshot.get(k) if old_snapshot else None,
                                 "new": new_snapshot.get(k) if new_snapshot else None}
                             for k in (diff_parts and [p.split(":",1)[0] for p in diff_parts] or [])
                             if k not in ("api_password", "secret")},
            }, default=str)[:10000]

            db2 = request.state.db if hasattr(request.state, "db") else None
            # We don't have direct access to the session's db here — grab fresh.
            from database import SessionLocal
            _db = SessionLocal()
            try:
                _db.execute(_sql("""
                    INSERT INTO admin_activity_log
                       (company_id, actor_id, actor_name, actor_type, action,
                        target_type, target_id, summary, payload_json, ip_address)
                    VALUES
                       (:co, :aid, :an, :at, :ac,
                        'nas_device', :tid, :sm, :pj, :ip)
                """), {
                    "co":  company_id,
                    "aid": str(actor_id)[:64],
                    "an":  str(actor_name)[:64],
                    "at":  str(actor_type)[:32],
                    "ac":  action[:32],
                    "tid": str(getattr(nas, "id", ""))[:64],
                    "sm":  summary[:255],
                    "pj":  payload,
                    "ip":  (request.client.host if request and request.client else ""),
                })
                _db.commit()
            finally:
                _db.close()
        except Exception as _e:
            print(f"[nas-audit WARN] {_e}")

