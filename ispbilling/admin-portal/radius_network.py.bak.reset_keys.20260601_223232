    def _pool_rows(db, company_id, ids=None, iface_by_id=None, overrides_by_id=None):
        """Return pools scoped to company, optionally filtered by `ids` and
        enriched with a per-pool `interface` (from iface_by_id dict) so the
        provisioning helper can bind each pool's gateway to its interface.
        Parking-role pools are skipped — they're handled by the separate
        `configure_parking_pool` task so admins don't accidentally bind
        them as LAN address on a regular interface.

        s26.10: editable-pool-range-gateway — `overrides_by_id` is a dict
        mapping pool_id -> {"ranges": str, "gateway": str}. When present,
        the per-pool entry's `ranges`, `network`, `start_ip`, `end_ip`,
        and `gateway` are overridden (DB row stays untouched) so the
        same pool can be pushed with different IP ranges to different
        NAS devices.
        """
        q = db.query(IpPool).filter(IpPool.company_id == company_id)
        if ids is not None:
            ids = [int(x) for x in ids if str(x).isdigit()]
            if not ids:
                return []
            q = q.filter(IpPool.id.in_(ids))
        iface_by_id = iface_by_id or {}
        overrides_by_id = overrides_by_id or {}
        out = []
        for p in q.all():
            role = getattr(p, "role", "PPPoE") or "PPPoE"
            if role == "Parking":
                continue
            iface = (iface_by_id.get(str(p.id)) or iface_by_id.get(p.id) or "").strip()

            # Baseline from DB
            start_ip = p.start_ip
            end_ip   = p.end_ip
            network  = p.network
            gateway  = getattr(p, "gateway", "") or ""
            ranges   = (f"{start_ip}-{end_ip}" if (start_ip and end_ip) else network)

            ov = overrides_by_id.get(p.id) or overrides_by_id.get(str(p.id)) or {}
            ov_ranges  = (ov.get("ranges")  or "").strip()
            ov_gateway = (ov.get("gateway") or "").strip()
            if ov_ranges:
                ranges = ov_ranges
                # Reflect override back into start_ip/end_ip/network heuristically
                if "-" in ov_ranges:
                    a, _, b = ov_ranges.partition("-")
                    start_ip = a.strip() or None
                    end_ip   = b.strip() or None
                    network  = None
                elif "/" in ov_ranges:
                    network  = ov_ranges
                    start_ip = None
                    end_ip   = None
            if ov_gateway:
                gateway = ov_gateway

            # s26.12 + s26.14: resolve next_pool_id -> name
            # Override from UI row takes precedence over stored value
            _np_id = None
            _ov_np = (ov.get("next_pool_id") if ov else None)
            if _ov_np not in (None, "", "null"):
                try: _np_id = int(_ov_np)
                except (TypeError, ValueError): _np_id = None
            if _np_id is None:
                _np_id = getattr(p, "next_pool_id", None)
            _np_name = ""
            if _np_id:
                try:
                    _np = db.query(IpPool).filter(IpPool.id == int(_np_id),
                                                   IpPool.company_id == company_id).first()
                    if _np:
                        _np_name = _np.name or ""
                except Exception:
                    pass
            out.append({
                "id": p.id,
                "name": p.name, "network": network,
                "start_ip": start_ip, "end_ip": end_ip,
                "gateway": gateway,
                "interface": iface,
                "role": role,
                "ranges": ranges,
                "next_pool": _np_name,
            })
        return out

    @app.post("/api/nas-devices/{nas_id}/test-connection")
    async def api_nas_test(nas_id: int, request: Request, db: Session = Depends(get_db)):
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)
        res = rp.test_connection(nas)
        # # __s56w_friendly_nas_test__
        # Translate cryptic socket errors into actionable diagnostics.
        # If this NAS is reached over a WireGuard tunnel and the tunnel
        # peer has no handshake yet, the kernel returns ENETUNREACH (101)
        # or EHOSTUNREACH (113). Tell the operator exactly what to fix.
        if not res.get("success"):
            # __s56AG_diag_v3__ — broaden gate to include socket.timeout
            # ("timed out" / ETIMEDOUT 110) and ECONNREFUSED 111. These
            # cover the case where the WG tunnel exists but never
            # completed handshake, so TCP/8728 connect just times out.
            msg_lc = str(res.get("message") or "").lower()
            ip = (nas.ip_address or "").strip()
            looks_tunnel = ip.startswith("10.50.")
            no_route = ("no route to host" in msg_lc
                        or "errno 113" in msg_lc
                        or "errno 101" in msg_lc
                        or "network is unreachable" in msg_lc)
            timed_out = ("timed out" in msg_lc
                         or "timeout" in msg_lc
                         or "errno 110" in msg_lc)
            refused   = ("connection refused" in msg_lc
                         or "errno 111" in msg_lc)
            tunnel_fault = looks_tunnel and (no_route or timed_out or refused)
            # # __s56w_friendly_nas_test_v2__
            # Raw-SQL lookup of wg_peer_pubkey (column added post-model).
            _wg_pub = ""
            try:
                import sqlite3 as _sql
                _con = _sql.connect("/var/lib/autoispbilling/autoispbilling.db",
                                    timeout=5)
                _row = _con.execute(
                    "SELECT COALESCE(wg_peer_pubkey,'') FROM nas_devices "
                    "WHERE id=?", (nas.id,)).fetchone()
                _wg_pub = (_row[0] if _row else "") or ""
                _con.close()
            except Exception:
                _wg_pub = ""
            if tunnel_fault and _wg_pub:
                import subprocess as _sp
                hs = 0
                try:
                    out = _sp.run(["wg", "show", "wg0", "latest-handshakes"],
                                  capture_output=True, text=True, timeout=5).stdout
                    for line in out.splitlines():
                        parts = line.split()
                        if len(parts) >= 2 and parts[0] == _wg_pub:
                            hs = int(parts[1] or 0)
                            break
                except Exception:
                    pass
                if hs == 0:
                    # __s56AE_stale_paste_diag__ : if peer has RX traffic
                    # but no completed handshake, it almost always means
                    # the Mikrotik is running a STALE script (keys do not
                    # match what the cloud has recorded after a rotation).
                    _rx_seen = False; _ep_seen = ""
                    try:
                        _r2 = _sp.run([
                            "wg","show","wg0","dump"
                        ], capture_output=True, text=True, timeout=4)
                        for _ln in (_r2.stdout or "").splitlines():
                            _p = _ln.split("\t")
                            if len(_p) >= 6 and _p[0] == _wg_pub:
                                _ep_seen = _p[2] if _p[2] != "(none)" else ""
                                _rx_seen = (int(_p[5]) if _p[5].isdigit() else 0) > 0
                                break
                    except Exception: pass
                    if _rx_seen and _ep_seen:
                        res["message"] = (
                            f"MikroTik @ {ip} IS reaching the cloud "
                            f"(seen from {_ep_seen}) but the WireGuard "
                            f"handshake never completes. This means the "
                            f"Mikrotik has a STALE script (old keys). "
                            f"FIX: open NAS Devices -> click 'Tunnel' "
                            f"(or 'UDP/443') -> Copy the FRESH script -> "
                            f"paste on the Mikrotik (it replaces the old "
                            f"cloud-tun config in place). Do NOT click "
                            f"'Cloud Tunnel (1-click)' again -- that "
                            f"only matters when you want to rotate keys."
                        )
                        res["wg_handshake"] = "stale_keys"
                        res["peer_endpoint"] = _ep_seen
                    else:
                        res["message"] = (
                            f"MikroTik @ {ip} has NOT dialed in to the cloud "
                            f"WireGuard tunnel yet. If you already pasted the "
                            f"primary script (UDP/51820) and got no handshake, "
                            f"the customer's ISP is most likely blocking "
                            f"UDP/51820 outbound. FIX: open NAS Devices -> "
                            f"click the purple 'UDP/443' button on this NAS "
                            f"and paste THAT script on the Mikrotik. UDP/443 "
                            f"is rarely blocked. Same server, same keys, only "
                            f"the port differs."
                        )
                        res["wg_handshake"] = "never"
                        res["fallback_available"] = True
                        res["fallback_endpoint"] = "185.199.53.93:443"
                else:
                    import time as _t
                    age = int(_t.time()) - hs
                    res["message"] = (
                        f"WireGuard handshake last seen {age}s ago but the "
                        f"MikroTik isn't replying on the API port. Check "
                        f"that /ip service api is enabled and reachable "
                        f"from 10.50.0.0/16 on this router."
                    )
                    res["wg_handshake_age_sec"] = age
            elif tunnel_fault and not _wg_pub:
                # Tunnel-shaped IP but no WG peer ever provisioned.
                res["message"] = (
                    f"{ip} is a Cloud Tunnel address but this NAS has no "
                    f"WireGuard peer provisioned yet. FIX: ask your "
                    f"SuperAdmin to open NAS Console -> 'Cloud Tunnel "
                    f"(1-click)' for this NAS, then paste the generated "
                    f"script on the Mikrotik. Until then the cloud has "
                    f"no way to reach the Mikrotik."
                )
                res["wg_handshake"] = "unprovisioned"
        nas.last_status = "ok" if res.get("success") else "error"
        nas.last_status_msg = res.get("message") or res.get("identity") or ""
        db.commit()
        return res

    @app.post("/api/nas-devices/{nas_id}/auto-configure")
    async def api_nas_auto_cfg(nas_id: int, request: Request, db: Session = Depends(get_db)):
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)
        body = await request.json()
        options = {
            "queue_types": bool(body.get("queue_types", True)),
            "ip_pools": bool(body.get("ip_pools", True)),
            "pppoe_server": bool(body.get("pppoe_server", True)),
            "hotspot": bool(body.get("hotspot", False)),
            "simple_queues_from_plans": bool(body.get("simple_queues_from_plans", False)),
            "radius_client": bool(body.get("radius_client", True)),
            "firewall_nat_baseline": bool(body.get("firewall_nat_baseline", True)),
            "parking_pool": bool(body.get("parking_pool", True)),
        }
        dry_run = body.get("dry_run", True)
        # NAS row carries the tenant-specific defaults (service name, VLAN,
        # interface). Body can override; if neither is set, fall back.
        pppoe_if = (body.get("pppoe_interface") or nas.pppoe_interface or "ether2").strip()
        hotspot_if = (body.get("hotspot_interface") or nas.hotspot_interface or "ether3").strip()
        wan_if = (body.get("wan_interface") or "ether1").strip()
        pppoe_service_name = (body.get("pppoe_service_name")
                               if "pppoe_service_name" in body
                               else (nas.pppoe_service_name or "isp-pppoe"))
        try:
            pppoe_vlan_id = int(body.get("pppoe_vlan_id", nas.pppoe_vlan_id or 0) or 0)
        except Exception:
            pppoe_vlan_id = 0
        enable_pppoe = bool(body.get("enable_pppoe_server", False))
        enable_hotspot = bool(body.get("enable_hotspot", False))
        force = bool(body.get("force", False))

        # ---- PRE-FLIGHT SAFETY CHECK -----------------------------------
        # Refuse to push PPPoE / Hotspot onto the same interface that carries
        # the default route — doing so would hijack the router's own uplink.
        # Skipped for dry-runs (we still want to preview), honoured for real
        # executions unless `force=true` is explicitly passed.
        preflight = {"skipped": True}
        if not dry_run:
            try:
                wan_detect = rp.detect_wan(nas)
                detected = (wan_detect or {}).get("interface")
                preflight = {"skipped": False, "detected_wan": detected,
                             "gateway": (wan_detect or {}).get("gateway"),
                             "source": (wan_detect or {}).get("source")}
                # Pre-flight is *advisory* — if the router is briefly busy we
                # don't want to block a legitimate auto-config. Only HARD
                # block if we positively detect a conflict with high
                # confidence (success=True on the detect call).
                if not (wan_detect or {}).get("success", True):
                    preflight["skipped_due_to_detect_error"] = True
                    preflight["note"] = ("Pre-flight WAN detection could not complete — "
                                         "continuing without guard (router may be busy).")
                conflicts = []
                confident = bool(detected) and (wan_detect or {}).get("success") is not False
                if confident:
                    if options["pppoe_server"] and pppoe_if == detected:
                        conflicts.append(f"PPPoE interface '{pppoe_if}' is the WAN/default-route interface")
                    if options["hotspot"] and hotspot_if == detected:
                        conflicts.append(f"Hotspot interface '{hotspot_if}' is the WAN/default-route interface")
                    if options["firewall_nat_baseline"] and wan_if != detected:
                        preflight.setdefault("warnings", []).append(
                            f"WAN in form is '{wan_if}' but router's default route uses '{detected}'. "
                            f"NAT masquerade will attach to '{wan_if}'."
                        )
                if conflicts and not force:
                    return JSONResponse({
                        "success": False,
                        "preflight_blocked": True,
                        "message": "Pre-flight check refused execution: " + "; ".join(conflicts),
                        "conflicts": conflicts,
                        "preflight": preflight,
                        "hint": "Re-run with force=true to override (NOT recommended — will knock the router offline).",
                    }, status_code=400)
                preflight["conflicts"] = conflicts
            except Exception as _e:  # noqa: BLE001
                preflight = {"skipped": False, "error": str(_e),
                             "note": "Pre-flight detection failed — proceeding without guard."}

        pppoe_local = (body.get("pppoe_local_address") or "192.168.100.1").strip()
        pppoe_pool_name = (body.get("pppoe_pool_name") or "pppoe-pool").strip()
        pppoe_pool_ranges = (body.get("pppoe_pool_ranges") or "192.168.100.10-192.168.100.250").strip()

        # ---- NEW: multi-pool checkbox list with per-pool interface ------
        # Body shape:
        #   selected_pools: [{ "pool_id": 3, "interface": "ether2",
        #                       "is_pppoe_pool": true }, ...]
        # Falls back to the legacy single `pppoe_pool_id` if not provided.
        selected_pools = body.get("selected_pools") or []
        iface_by_id = {str(sp.get("pool_id")): (sp.get("interface") or "").strip()
                       for sp in selected_pools if sp.get("pool_id") is not None}
        # s26.10: editable-pool-range-gateway — per-pool override map
        # s26.14: flow-next-pool-override
        overrides_by_id = {
            str(sp.get("pool_id")): {
                "ranges":  (sp.get("ranges")  or "").strip(),
                "gateway": (sp.get("gateway") or "").strip(),
                "next_pool_id": sp.get("next_pool_id"),
            }
            for sp in selected_pools if sp.get("pool_id") is not None
        }
        pppoe_pool_id = body.get("pppoe_pool_id")
        pppoe_pool_override_range = ""
        pppoe_pool_override_gateway = ""
        if selected_pools:
            pppoe_entry = next(
                (sp for sp in selected_pools if sp.get("is_pppoe_pool")),
                selected_pools[0] if selected_pools else None,
            )
            if pppoe_entry and pppoe_entry.get("pool_id") is not None:
                pppoe_pool_id = pppoe_entry["pool_id"]
                if pppoe_entry.get("interface"):
                    pppoe_if = pppoe_entry["interface"].strip() or pppoe_if
                # s26.10: pull per-NAS overrides from the selected PPPoE pool row
                pppoe_pool_override_range   = (pppoe_entry.get("ranges")  or "").strip()
                pppoe_pool_override_gateway = (pppoe_entry.get("gateway") or "").strip()

        if pppoe_pool_id:
            try:
                _p = db.query(IpPool).filter(IpPool.id == int(pppoe_pool_id),
                                              IpPool.company_id == company_id).first()
                if _p:
                    pppoe_pool_name = _p.name
                    # Override takes precedence over DB values
                    if pppoe_pool_override_range:
                        pppoe_pool_ranges = pppoe_pool_override_range
                    elif _p.start_ip and _p.end_ip:
                        pppoe_pool_ranges = f"{_p.start_ip}-{_p.end_ip}"
                    elif _p.network:
                        pppoe_pool_ranges = _p.network
                    if pppoe_pool_override_gateway:
                        pppoe_local = pppoe_pool_override_gateway
                    elif _p.gateway and not body.get("pppoe_local_address_override"):
                        pppoe_local = _p.gateway
            except (TypeError, ValueError):
                pass

        # Build the list of pools to sync. When `selected_pools` is present,
        # honour that selection (filter by pool_id + attach per-pool interface).
        if selected_pools:
            pool_ids = [sp.get("pool_id") for sp in selected_pools]
            pools = _pool_rows(db, company_id, ids=pool_ids,
                               iface_by_id=iface_by_id,
                               overrides_by_id=overrides_by_id)
        else:
            pools = _pool_rows(db, company_id)
        plans = _plan_rows_for_queues(db, company_id)
        radius_server_ip = body.get("radius_server_ip") or request.url.hostname or ""
        radius_secret = body.get("radius_secret") or (nas.secret or "testing123")
        dns_servers = (body.get("dns_servers") or "8.8.8.8,1.1.1.1").strip()
        enable_ppp_use_radius = bool(body.get("enable_ppp_use_radius", False))
        lan_subnets = body.get("lan_subnets")  # list | None
        parking_pool_name = (body.get("parking_pool_name") or "").strip()
        parking_pool_ranges = (body.get("parking_pool_ranges") or "").strip()
        parking_landing_ip = (body.get("parking_landing_ip") or "").strip()
        management_sources = body.get("management_sources")
        if not management_sources:
            # Auto-whitelist our billing server's public IP so the WAN-drop
            # rule can never lock US out (even if admin forgets to set it).
            our_ip = (request.url.hostname or "").strip() or "185.199.53.93"
            management_sources = [our_ip]
        management_ports = body.get("management_ports") or [8728, 8729, 22]
        # Real-ISP audit flags — audit-log defaults ON (matches live CCR1009
        # which ships with the two `action=log` forward rules). WAN-drop
        # defaults OFF (real ISP has no DROP rules; opt-in only).
        with_wan_drop = bool(body.get("with_wan_drop", False))
        with_audit_log = bool(body.get("with_audit_log", True))
        # If admin defined a `Parking` role pool in IP Pools, use it as the
        # authoritative source (name + ranges). This keeps one source of
        # truth — the pool they see on the IP Pools page is exactly what
        # RouterOS sees AND what FreeRADIUS hands out as Framed-Pool.
        if not parking_pool_name or not parking_pool_ranges:
            parking_row = db.query(IpPool).filter(IpPool.company_id == company_id,
                                                   IpPool.role == "Parking").first()
            if parking_row:
                parking_pool_name = parking_pool_name or parking_row.name
                parking_pool_ranges = parking_pool_ranges or (
                    f"{parking_row.start_ip}-{parking_row.end_ip}"
                    if (parking_row.start_ip and parking_row.end_ip)
                    else parking_row.network
                )
        parking_pool_name = parking_pool_name or "parking-pool"
        parking_pool_ranges = parking_pool_ranges or "10.255.0.0/16"

        report = rp.auto_configure(
            nas=nas, options=options, ip_pools=pools, plans=plans,
            radius_server_ip=radius_server_ip, radius_secret=radius_secret,
            dry_run=dry_run, pppoe_interface=pppoe_if, hotspot_interface=hotspot_if,
            wan_interface=wan_if,
            enable_pppoe_server=enable_pppoe, enable_hotspot=enable_hotspot,
            pppoe_pool_name=pppoe_pool_name,
            pppoe_pool_ranges=pppoe_pool_ranges,
            pppoe_local_address=pppoe_local,
            dns_servers=dns_servers,
            enable_ppp_use_radius=enable_ppp_use_radius,
            lan_subnets=lan_subnets,
            parking_pool_name=parking_pool_name,
            parking_pool_ranges=parking_pool_ranges,
            parking_landing_ip=parking_landing_ip,
            management_sources=management_sources,
            management_ports=management_ports,
            with_wan_drop=with_wan_drop,
            with_audit_log=with_audit_log,
            pppoe_service_name=pppoe_service_name,
            pppoe_vlan_id=pppoe_vlan_id,
        )
        if not dry_run and report.get("success"):
            nas.provisioned_at = datetime.utcnow()
            nas.last_status = "ok"
            nas.last_status_msg = "Auto-configured"
            try:
                nas.pppoe_pool_name = pppoe_pool_name
            except Exception:
                pass
            # s26.11: persist-pool-overrides
            # Write the UI-edited per-pool range/gateway back into the
            # `ip_pools` DB rows so (a) the admin's own IP Pools page
            # shows the actual values on the router, and (b) future
            # auto-config runs default to the corrected values.
            try:
                for sp in (selected_pools or []):
                    pid = sp.get("pool_id")
                    ov_range = (sp.get("ranges") or "").strip()
                    ov_gw    = (sp.get("gateway") or "").strip()
                    if not (pid and (ov_range or ov_gw)):
                        continue
                    try:
                        pid_int = int(pid)
                    except (TypeError, ValueError):
                        continue
                    _prow = db.query(IpPool).filter(
                        IpPool.id == pid_int,
                        IpPool.company_id == company_id).first()
                    if not _prow:
                        continue
                    changed = False
                    if ov_range:
                        if "-" in ov_range:
                            a, _, b = ov_range.partition("-")
                            a, b = a.strip(), b.strip()
                            if (_prow.start_ip or "") != a:
                                _prow.start_ip = a or None; changed = True
                            if (_prow.end_ip or "") != b:
                                _prow.end_ip = b or None; changed = True
                            # v13 — keep network non-NULL: derive a /24 supernet
                            # from start_ip so the NOT NULL constraint is satisfied.
                            try:
                                import ipaddress as _ipa
                                _net = str(_ipa.ip_network((a or '0.0.0.0') + '/24',
                                                           strict=False))
                            except Exception:
                                _net = (_prow.network or '0.0.0.0/0')
                            if (_prow.network or '') != _net:
                                _prow.network = _net; changed = True
                        elif "/" in ov_range:
                            if (_prow.network or "") != ov_range:
                                _prow.network = ov_range; changed = True
                            if _prow.start_ip or _prow.end_ip:
                                _prow.start_ip = None; _prow.end_ip = None; changed = True
                    if ov_gw and (getattr(_prow, "gateway", "") or "") != ov_gw:
                        try:
                            _prow.gateway = ov_gw; changed = True
                        except Exception:
                            pass
                    # s26.14: flow-next-pool-override — persist next_pool_id
                    _ov_np = sp.get("next_pool_id")
                    if _ov_np in (None, "", "null"):
                        _ov_np_val = None
                    else:
                        try: _ov_np_val = int(_ov_np)
                        except (TypeError, ValueError): _ov_np_val = None
                    # Only write when UI sent a next_pool_id key
                    if "next_pool_id" in sp and getattr(_prow, "next_pool_id", None) != _ov_np_val:
                        try:
                            _prow.next_pool_id = _ov_np_val; changed = True
                        except Exception:
                            pass
                    if changed:
                        try:
                            _prow.updated_at = datetime.utcnow()
                        except Exception:
                            pass
            except Exception as _pe:
                # Don't fail the whole auto-configure if the write-back errors.
                print(f"[warn] pool-override writeback: {_pe}")
            db.commit()
        elif not dry_run:
            nas.last_status = "error"
            nas.last_status_msg = report.get("message", "")[:250]
            db.commit()
        report["preflight"] = preflight
        return report

