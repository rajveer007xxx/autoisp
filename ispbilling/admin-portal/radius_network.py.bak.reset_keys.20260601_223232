    @app.get("/api/customers/{customer_id}/diagnose-radius-nas")
    async def api_customer_diagnose_radius_nas(customer_id: str, request: Request,
                                                db: Session = Depends(get_db)):
        import subprocess, ipaddress, re
        from database import Customer as _CDiag
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        cust = db.query(_CDiag).filter(_CDiag.customer_id == customer_id,
                                        _CDiag.company_id == company_id).first()
        if not cust:
            return JSONResponse({"success": False, "message": "Customer not found"},
                                 status_code=404)
        username = (cust.username or "").strip()
        password = (cust.pppoe_password or "").strip()
        mac = (cust.mac_address or "").strip().upper().replace("-", ":")
        static_ip = (cust.static_ip_address or "").strip()
        auth_type = (cust.auth_type or "pppoe").lower()
        status = (cust.status or "Active")

        report = {
            "success": True,
            "customer": {
                "customer_id": customer_id,
                "username": username,
                "auth_type": auth_type,
                "mac": mac,
                "static_ip": static_ip,
                "status": status,
            },
            "radius": {},
            "nas": {},
            "issues": [],
            "fix_commands": [],
        }

        # ---- 1. RADIUS reply check via radclient ------------------------
        if not username or not password:
            report["radius"] = {
                "skipped": True,
                "reason": "Customer has no username/pppoe_password set"
            }
            report["issues"].append({
                "severity": "high",
                "code": "no_creds",
                "msg": "Customer is missing username or PPPoE password — "
                        "RADIUS auth will always fail."
            })
        elif auth_type in ("static_ip", "static-ip", "static"):
            # Static-IP customers are intentionally OMITTED from the RADIUS
            # users file (Mikrotik authenticates them by source-IP).
            report["radius"] = {
                "skipped": True,
                "reason": "Static-IP customers do not authenticate via RADIUS — "
                            "they are matched at the Mikrotik firewall by source IP."
            }
        else:
            try:
                req = (
                    f'User-Name = "{username}", '
                    f'User-Password = "{password}", '
                    f'NAS-IP-Address = 127.0.0.1, '
                    f'Service-Type = Framed-User, '
                    f'Framed-Protocol = PPP'
                )
                if mac:
                    req += f', Calling-Station-Id = "{mac}"'
                p = subprocess.run(
                    ["radclient", "-x", "127.0.0.1:1812", "auth", "testing123"],
                    input=req, capture_output=True, text=True, timeout=8,
                )
                out = (p.stdout or "") + (p.stderr or "")
                accepted = "Access-Accept" in out
                # Extract reply attributes (lines after Access-Accept)
                reply_attrs = {}
                if accepted:
                    for line in out.splitlines():
                        m = re.match(r"\s*([A-Za-z][\w-]+)\s*=\s*(.+?)\s*$", line)
                        if m and m.group(1) not in ("Sent", "Received", "Id"):
                            reply_attrs[m.group(1)] = m.group(2).strip().strip('"')
                report["radius"] = {
                    "accepted": accepted,
                    "rejected": not accepted,
                    "framed_ip_address": reply_attrs.get("Framed-IP-Address"),
                    "framed_pool": reply_attrs.get("Framed-Pool"),
                    "mikrotik_rate_limit": reply_attrs.get("Mikrotik-Rate-Limit"),
                    "mikrotik_group": reply_attrs.get("Mikrotik-Group"),
                    "all_attrs": reply_attrs,
                    "raw_tail": out[-1500:],
                }
                if not accepted:
                    report["issues"].append({
                        "severity": "critical",
                        "code": "radius_reject",
                        "msg": "FreeRADIUS rejected this customer. Most common "
                                "cause: stale users-file (run Sync RADIUS) or "
                                "MAC-binding mismatch (Calling-Station-Id check)."
                    })
                else:
                    # PPPoE with static_ip set → must NOT have Framed-Pool
                    pppoe_static = (auth_type == "pppoe" and static_ip)
                    if pppoe_static and reply_attrs.get("Framed-Pool"):
                        report["issues"].append({
                            "severity": "high",
                            "code": "framed_pool_overrides_static",
                            "msg": (f"Customer has static_ip={static_ip} but RADIUS "
                                    f"still returns Framed-Pool={reply_attrs.get('Framed-Pool')}. "
                                    f"RouterOS will allocate a dynamic IP from the pool. "
                                    f"Re-render users file (Sync RADIUS).")
                        })
                    if pppoe_static and reply_attrs.get("Framed-IP-Address") != static_ip:
                        report["issues"].append({
                            "severity": "high",
                            "code": "static_ip_not_in_reply",
                            "msg": (f"Expected Framed-IP-Address={static_ip} in reply but got "
                                    f"{reply_attrs.get('Framed-IP-Address') or 'none'}. "
                                    f"Re-sync RADIUS to regenerate the users file.")
                        })
            except FileNotFoundError:
                report["radius"] = {"error": "radclient not installed (apt install freeradius-utils)"}
            except Exception as e:  # noqa: BLE001
                report["radius"] = {"error": f"radclient failed: {e}"}

        # ---- 2. NAS-side probe via RouterOS API ------------------------
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(NasDevice.id == cust.provisioned_nas_id,
                                              NasDevice.company_id == company_id).first()
        if not nas:
            # Fall back to any active NAS in the tenant
            nas = db.query(NasDevice).filter(NasDevice.company_id == company_id,
                                              NasDevice.status == "Active").first()
        if not nas:
            report["nas"] = {"skipped": True,
                              "reason": "No NAS device configured for this tenant"}
        else:
            report["nas"]["device"] = {"id": nas.id, "name": nas.name,
                                         "ip": nas.ip_address}
            try:
                import routeros_provision as rp
                with rp.RouterOSClient(nas, dry_run=False) as c:
                    api = c._api
                    ssh = c._ssh

                    def _list(path):
                        if api:
                            try:
                                return list(api.path(path))
                            except Exception as e:  # noqa: BLE001
                                return [{"_error": str(e)}]
                        if ssh:
                            o, _, _ = ssh.exec(f"/{path.replace('/', ' ')} print")
                            return [{"_raw": o}]
                        return []

                    # A. /ppp aaa — use-radius flag
                    aaa_rows = _list("ppp/aaa")
                    use_radius = "unknown"
                    accounting = "unknown"
                    if aaa_rows and isinstance(aaa_rows[0], dict):
                        use_radius = aaa_rows[0].get("use-radius", "unknown")
                        accounting = aaa_rows[0].get("accounting", "unknown")
                    report["nas"]["ppp_aaa"] = {"use-radius": use_radius,
                                                  "accounting": accounting}
                    if use_radius not in ("yes", "true", True):
                        report["issues"].append({
                            "severity": "critical",
                            "code": "ppp_aaa_no_radius",
                            "msg": ("`/ppp aaa use-radius` is NOT enabled — the "
                                    "Mikrotik will not consult FreeRADIUS at all. "
                                    "Enable it.")
                        })
                        report["fix_commands"].append("/ppp aaa set use-radius=yes accounting=yes")

                    # B. Local /ppp secret override
                    if username:
                        secrets = _list("ppp/secret")
                        match = None
                        for s in secrets:
                            if isinstance(s, dict) and s.get("name") == username:
                                match = s
                                break
                        report["nas"]["local_ppp_secret"] = match
                        if match:
                            local_remote = match.get("remote-address")
                            local_profile = match.get("profile")
                            # _S44_LOCAL_SECRET_SHADOWS_RADIUS — RouterOS
                            # always matches LOCAL /ppp secret before falling
                            # through to RADIUS. If a local secret exists for
                            # `username`, RADIUS is never consulted — the
                            # secret's profile decides the IP. This is THE
                            # cause of PPPoE returning a pool IP even though
                            # RADIUS would have replied Framed-IP-Address=
                            # <static_ip>. Always flag + suggest removal when
                            # use-radius=yes.
                            # _S44_LOCAL_VS_RADIUS — classify the local secret state:
                            #   aligned : local.remote-address == customer.static_ip
                            #   mismatch: local.remote-address != customer.static_ip
                            #   shadow  : local has NO remote-address -> falls through to
                            #             profile's pool (dynamic), so customer never gets
                            #             their assigned IP.
                            if static_ip and local_remote == static_ip:
                                report["issues"].append({
                                    "severity": "info",
                                    "code": "local_secret_aligned",
                                    "msg": (f"Local /ppp secret pin matches the customer's "
                                            f"static IP ({static_ip}). On next reconnect the "
                                            f"client will receive this IP. No action required.")
                                })
                            elif static_ip and local_remote and local_remote != static_ip:
                                report["issues"].append({
                                    "severity": "high",
                                    "code": "local_secret_remote_mismatch",
                                    "msg": (f"Local /ppp secret has remote-address="
                                            f"{local_remote} but customer record says "
                                            f"{static_ip}. Sync the secret.")
                                })
                                report["fix_commands"].insert(0,
                                    f"/ppp secret set [find name={username}] "
                                    f"remote-address={static_ip}"
                                )
                            elif static_ip and not local_remote:
                                report["issues"].append({
                                    "severity": "critical",
                                    "code": "local_secret_no_pin",
                                    "msg": (f"Local /ppp secret '{username}' has NO "
                                            f"remote-address — it will fall through to "
                                            f"profile '{local_profile or '?'}' which "
                                            f"hands out a dynamic pool IP. RADIUS reply "
                                            f"is ignored because LOCAL matches first. "
                                            f"Pin remote-address={static_ip} on the secret "
                                            f"OR remove the secret so RADIUS owns the IP.")
                                })
                                report["fix_commands"].insert(0,
                                    f"/ppp secret set [find name={username}] "
                                    f"remote-address={static_ip}"
                                )
                            elif not static_ip and use_radius in ("yes", "true", True):
                                # No static IP — local secret should defer to RADIUS pool.
                                report["issues"].append({
                                    "severity": "medium",
                                    "code": "local_secret_shadows_radius",
                                    "msg": (f"Local /ppp secret '{username}' exists with "
                                            f"profile={local_profile or '?'}. RADIUS reply "
                                            f"will be ignored because LOCAL matches first. "
                                            f"If RADIUS is meant to be authoritative, remove "
                                            f"the local secret.")
                                })

                    # C. Static-IP route-coverage & firewall checks
                    if static_ip:
                        try:
                            sip = ipaddress.ip_address(static_ip)
                        except Exception:
                            sip = None
                        # Check /ip pool ranges
                        pools = _list("ip/pool")
                        in_pool = None
                        for p in pools:
                            if not isinstance(p, dict):
                                continue
                            rng = p.get("ranges") or ""
                            for chunk in rng.replace(" ", "").split(","):
                                if "-" in chunk and sip:
                                    try:
                                        lo, hi = chunk.split("-", 1)
                                        if (ipaddress.ip_address(lo) <= sip
                                                <= ipaddress.ip_address(hi)):
                                            in_pool = p.get("name")
                                            break
                                    except Exception:
                                        pass
                            if in_pool:
                                break
                        report["nas"]["static_ip_in_pool"] = in_pool
                        if in_pool:
                            report["issues"].append({
                                "severity": "medium",
                                "code": "static_ip_in_pool",
                                "msg": (f"Static IP {static_ip} is INSIDE pool '{in_pool}'. "
                                        f"Risk: same IP could be re-handed-out to another "
                                        f"user. Exclude it from the pool range.")
                            })
                        # Check route coverage
                        routes = _list("ip/route")
                        covering = None
                        for r in routes:
                            if not isinstance(r, dict):
                                continue
                            dst = r.get("dst-address") or ""
                            try:
                                net = ipaddress.ip_network(dst, strict=False)
                                if sip and sip in net:
                                    covering = dst
                                    break
                            except Exception:
                                pass
                        report["nas"]["static_ip_route"] = covering
                        # _S44_FW_REJECT_FORWARD — only rules in `forward`
                        # chain can blackhole this customer's traffic. Hotspot
                        # chains (hs-*) only fire on captive-portal sessions.
                        try:
                            filters = _list("ip/firewall/filter")
                        except Exception:
                            filters = []
                        forward_rejects = []
                        for f in filters:
                            if not isinstance(f, dict):
                                continue
                            act = (f.get("action") or "").lower()
                            reject_with = (f.get("reject-with") or "").lower()
                            chain = (f.get("chain") or "").lower()
                            if act == "reject" and "prohibit" in reject_with and chain == "forward":
                                forward_rejects.append({
                                    "src": f.get("src-address"),
                                    "dst": f.get("dst-address"),
                                    "src_addr_list": f.get("src-address-list"),
                                    "reject_with": reject_with,
                                    "comment": f.get("comment"),
                                })
                        report["nas"]["forward_reject_rules"] = forward_rejects
                        # Is the customer's IP in allowed-static?
                        try:
                            al_rows = _list("ip/firewall/address-list")
                        except Exception:
                            al_rows = []
                        in_allowed = any(
                            (isinstance(r, dict)
                                and r.get("list") == "allowed-static"
                                and r.get("address") == static_ip)
                            for r in al_rows)
                        report["nas"]["in_allowed_static"] = in_allowed
                        if forward_rejects and not in_allowed:
                            report["issues"].append({
                                "severity": "high",
                                "code": "net_prohibited_filter",
                                "msg": (f"Firewall has {len(forward_rejects)} reject rule(s) "
                                        f"in chain=forward emitting icmp-net-prohibited and "
                                        f"static IP {static_ip} is NOT in allowed-static. "
                                        f"Add it to allowed-static + ensure an accept rule "
                                        f"matches before the rejects.")
                            })
                        elif not in_allowed and (forward_rejects or True):
                            # No reject rules visible but we still want to ensure
                            # the IP is explicitly allowed for predictable routing.
                            if not in_allowed:
                                report["issues"].append({
                                    "severity": "medium",
                                    "code": "static_ip_not_whitelisted",
                                    "msg": (f"Static IP {static_ip} is not in the "
                                            f"`allowed-static` address-list. Add it so "
                                            f"future deny-by-default rules don't catch it.")
                                })

                        # Suggest copy-paste commands for fixing common cases
                        # 1) Add static IP to allowed address-list
                        report["fix_commands"].append(
                            f"/ip firewall address-list add list=allowed-static "
                            f"address={static_ip} comment=\"cust:{customer_id}\""
                        )
                        # 2) Ensure forward accept rule for allowed-static
                        report["fix_commands"].append(
                            "/ip firewall filter add chain=forward "
                            "src-address-list=allowed-static action=accept "
                            "place-before=0 comment=\"allow-static-ips\""
                        )
                        # 3) Ensure NAT masquerade
                        report["fix_commands"].append(
                            f"/ip firewall nat add chain=srcnat src-address={static_ip} "
                            f"action=masquerade comment=\"cust:{customer_id}\""
                        )
            except Exception as e:  # noqa: BLE001
                report["nas"]["error"] = f"NAS probe failed: {e}"

        # Tidy: dedup fix_commands while preserving order
        seen = set(); deduped = []
        for c in report["fix_commands"]:
            if c not in seen:
                seen.add(c); deduped.append(c)
        report["fix_commands"] = deduped
        return report

    # _S44_APPLY_FIX — Push the per-customer NAS fix commands surfaced by
    # the diagnostic endpoint. Supports two narrowly-scoped, idempotent
    # actions so admins can resolve common static-IP routing problems
    # without copy-pasting RouterOS CLI by hand. Each action is independent
    # and returns the commands actually executed for audit.
    @app.post("/api/customers/{customer_id}/apply-nas-fix")
    async def api_customer_apply_nas_fix(customer_id: str, request: Request,
                                          db: Session = Depends(get_db)):
        from database import Customer as _CFix
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        try:
            data = await request.json()
        except Exception:
            data = {}
        actions = data.get("actions") or []
        if isinstance(actions, str):
            actions = [actions]
        if not actions:
            return JSONResponse({"success": False,
                                  "message": "actions[] required"},
                                 status_code=400)

        cust = db.query(_CFix).filter(_CFix.customer_id == customer_id,
                                        _CFix.company_id == company_id).first()
        if not cust:
            return JSONResponse({"success": False, "message": "Customer not found"},
                                 status_code=404)
        username = (cust.username or "").strip()
        static_ip = (cust.static_ip_address or "").strip()
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(NasDevice.id == cust.provisioned_nas_id,
                                              NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(NasDevice.company_id == company_id,
                                              NasDevice.status == "Active").first()
        if not nas:
            return JSONResponse({"success": False,
                                  "message": "No active NAS for this tenant"},
                                 status_code=400)

        import routeros_provision as rp
        results = []
        try:
            with rp.RouterOSClient(nas, dry_run=False) as c:
                api = c._api
                ssh = c._ssh

                def _ssh_exec(cli):
                    o, e, rc = ssh.exec(cli)
                    return {"cli": cli, "rc": rc, "out": o[-800:], "err": e[-300:]}

                # Action: sync static IP onto local /ppp secret -------------
                if "sync_static_ip_on_secret" in actions:
                    if not username:
                        results.append({"action": "sync_static_ip_on_secret",
                                          "skipped": "no username"})
                    elif not static_ip:
                        results.append({"action": "sync_static_ip_on_secret",
                                          "skipped": "no static_ip on customer"})
                    else:
                        applied = []
                        if api:
                            sec_path = api.path("ppp/secret")
                            target = None
                            for r in list(sec_path):
                                if r.get("name") == username:
                                    target = r
                                    break
                            if target:
                                sec_path.update(**{".id": target[".id"],
                                                   "remote-address": static_ip})
                                applied.append(
                                    f"/ppp/secret set [find name={username}] "
                                    f"remote-address={static_ip}")
                            else:
                                applied.append(
                                    f"(skip) no local /ppp secret named {username}")
                        elif ssh:
                            applied.append(_ssh_exec(
                                f"/ppp secret set [find name={username}] "
                                f"remote-address={static_ip}"))
                        results.append({"action": "sync_static_ip_on_secret",
                                          "username": username,
                                          "static_ip": static_ip,
                                          "applied": applied})

                # Action: allow static IP through firewall -----------------
                if "allow_static_ip_firewall" in actions:
                    if not static_ip:
                        results.append({"action": "allow_static_ip_firewall",
                                          "skipped": "no static_ip on customer"})
                    else:
                        applied = []
                        comment = f"cust:{customer_id}"
                        if api:
                            # 1. address-list entry (idempotent on address+list)
                            al_path = api.path("ip/firewall/address-list")
                            already = False
                            for r in list(al_path):
                                if (r.get("list") == "allowed-static"
                                        and r.get("address") == static_ip):
                                    already = True; break
                            if not already:
                                al_path.add(list="allowed-static",
                                              address=static_ip, comment=comment)
                                applied.append(
                                    f"/ip/firewall/address-list add "
                                    f"list=allowed-static address={static_ip}")
                            else:
                                applied.append(
                                    f"(already in allowed-static): {static_ip}")
                            # 2. forward accept rule (idempotent on comment)
                            ff_path = api.path("ip/firewall/filter")
                            rule_exists = False
                            for r in list(ff_path):
                                if (r.get("chain") == "forward"
                                        and r.get("src-address-list") == "allowed-static"
                                        and r.get("action") == "accept"):
                                    rule_exists = True; break
                            if not rule_exists:
                                ff_path.add(chain="forward",
                                              **{"src-address-list": "allowed-static"},
                                              action="accept",
                                              comment="allow-static-ips",
                                              **{"place-before": "0"})
                                applied.append(
                                    "/ip/firewall/filter add chain=forward "
                                    "src-address-list=allowed-static action=accept")
                            else:
                                applied.append("(forward accept rule already present)")
                            # 3. masquerade for static IP (idempotent)
                            nat_path = api.path("ip/firewall/nat")
                            nat_exists = False
                            for r in list(nat_path):
                                if (r.get("chain") == "srcnat"
                                        and r.get("src-address") == static_ip
                                        and r.get("action") == "masquerade"):
                                    nat_exists = True; break
                            if not nat_exists:
                                nat_path.add(chain="srcnat",
                                              **{"src-address": static_ip},
                                              action="masquerade", comment=comment)
                                applied.append(
                                    f"/ip/firewall/nat add chain=srcnat "
                                    f"src-address={static_ip} action=masquerade")
                            else:
                                applied.append("(masquerade already present)")
                        elif ssh:
                            applied.append(_ssh_exec(
                                f'/ip firewall address-list add '
                                f'list=allowed-static address={static_ip} '
                                f'comment="{comment}"'))
                            applied.append(_ssh_exec(
                                '/ip firewall filter add chain=forward '
                                'src-address-list=allowed-static action=accept '
                                'place-before=0 comment="allow-static-ips"'))
                            applied.append(_ssh_exec(
                                f'/ip firewall nat add chain=srcnat '
                                f'src-address={static_ip} action=masquerade '
                                f'comment="{comment}"'))
                        results.append({"action": "allow_static_ip_firewall",
                                          "static_ip": static_ip,
                                          "applied": applied})

                # Action: remove local /ppp secret (force RADIUS) ---------
                if "remove_local_secret" in actions:
                    if not username:
                        results.append({"action": "remove_local_secret",
                                          "skipped": "no username"})
                    else:
                        applied = []
                        if api:
                            sec_path = api.path("ppp/secret")
                            removed = 0
                            for r in list(sec_path):
                                if r.get("name") == username:
                                    sec_path.remove(r[".id"])
                                    removed += 1
                            applied.append(
                                f"/ppp/secret remove [find name={username}] "
                                f"({removed} entries)")
                        elif ssh:
                            applied.append(_ssh_exec(
                                f"/ppp secret remove [find name={username}]"))
                        results.append({"action": "remove_local_secret",
                                          "username": username,
                                          "applied": applied})

                # Action: kick active session so reconnect picks up changes
                if "kick_active_session" in actions:
                    if not username:
                        results.append({"action": "kick_active_session",
                                          "skipped": "no username"})
                    else:
                        applied = []
                        if api:
                            act_path = api.path("ppp/active")
                            killed = 0
                            for r in list(act_path):
                                if r.get("name") == username:
                                    act_path.remove(r[".id"])
                                    killed += 1
                            applied.append(
                                f"/ppp/active remove [find name={username}] "
                                f"({killed} sessions)")
                        elif ssh:
                            applied.append(_ssh_exec(
                                f"/ppp active remove [find name={username}]"))
                        results.append({"action": "kick_active_session",
                                          "username": username,
                                          "applied": applied})

        except Exception as e:  # noqa: BLE001
            return JSONResponse({"success": False,
                                  "message": f"NAS apply-fix failed: {e}",
                                  "results": results}, status_code=500)

        return {"success": True, "customer_id": customer_id,
                "nas": {"id": nas.id, "name": nas.name, "ip": nas.ip_address},
                "results": results}

    # _S45_HARMONIZE_NAS_BULK — Run the global static-IP harmonizer for the
    # entire tenant. Iterates every active customer with static_ip set and
    # applies the 6-step harmonization (ppp secret pin, arp bind, /32 route,
    # allowed-static, forward accept, srcnat masquerade) against EACH active
    # NAS. Idempotent; safe to re-run.
    @app.post("/api/nas-devices/{nas_id}/harmonize-static-ips")
    async def api_nas_harmonize_static_ips(nas_id: int, request: Request,
                                            db: Session = Depends(get_db)):
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        try:
            data = await request.json()
        except Exception:
            data = {}
        dry_run = bool(data.get("dry_run", False))
        usernames = data.get("usernames") or None
        # Validate the NAS belongs to this tenant
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"},
                                 status_code=404)
        res = harmonize_static_ips_for_tenant(db, company_id,
                                                dry_run=dry_run,
                                                usernames=usernames)
        # Filter results to just this NAS for the response
        res["results"] = [r for r in res["results"] if r.get("nas_id") == nas.id]
        res["success"] = True
        return res

    # _S45_HARMONIZE_TENANT_BULK — same but across ALL the tenant's NAS.
    @app.post("/api/freeradius/harmonize-static-ips-all-nas")
    async def api_harmonize_static_ips_all_nas(request: Request,
                                                  db: Session = Depends(get_db)):
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        try:
            data = await request.json()
        except Exception:
            data = {}
        dry_run = bool(data.get("dry_run", False))
        usernames = data.get("usernames") or None
        res = harmonize_static_ips_for_tenant(db, company_id,
                                                dry_run=dry_run,
                                                usernames=usernames)
        res["success"] = True
        return res


# _S39POOL_MOD_EXPORT — module-level wrapper for tests / cron jobs.
# _S39POOL_ENRICH — also pulls /ip/address to populate gateway + network.
def _ipv4_to_int(ip):
    try:
        a, b, c, d = [int(x) for x in ip.split(".")]
        return (a << 24) | (b << 16) | (c << 8) | d
    except Exception:
        return None

def _int_to_ipv4(n):
    return ".".join(str((n >> shift) & 0xFF) for shift in (24, 16, 8, 0))

def _smallest_cidr_for_range(start_ip, end_ip):
    """Smallest IPv4 CIDR that contains [start, end]. Used when /ip/pool
    stored a range like 10.10.20.10-10.10.20.250 — we derive 10.10.20.0/24.
    Falls back to /24 of the first IP when both ends share the third octet."""
    a, b = _ipv4_to_int(start_ip), _ipv4_to_int(end_ip)
    if a is None or b is None or a > b:
        return ""
    diff = a ^ b
    plen = 32
    while diff:
        diff >>= 1; plen -= 1
    plen = max(plen, 0)
    mask = (0xFFFFFFFF << (32 - plen)) & 0xFFFFFFFF if plen else 0
    net = a & mask
    return f"{_int_to_ipv4(net)}/{plen}"

def _classify_role(name):
    n = (name or "").lower()
    if "hotspot" in n: return "Hotspot"
    if "parking" in n or "park"    in n: return "Parking"
    if "static"  in n: return "Static-IP"
    if "ppp"     in n or "pppoe" in n:   return "PPPoE"
    return "PPPoE"

def _gateway_for_network(addresses, network_cidr):
    """Find the /ip/address row whose CIDR overlaps `network_cidr` and return
    its address (the interface IP) as the gateway. Otherwise default to .1
    of the network — which is the convention the platform's auto-configure
    helper writes on /ip/pool creation."""
    if not network_cidr or "/" not in network_cidr:
        return ""
    net_ip, _, plen = network_cidr.partition("/")
    try: plen = int(plen)
    except ValueError: return ""
    n_int = _ipv4_to_int(net_ip);
    if n_int is None: return ""
    n_mask = (0xFFFFFFFF << (32 - plen)) & 0xFFFFFFFF if plen else 0
    n_net = n_int & n_mask
    for a in addresses or []:
        addr_full = (a.get("address") or "")
        if "/" not in addr_full: continue
        ip, _, ap = addr_full.partition("/")
        try: ap = int(ap)
        except ValueError: continue
        ip_int = _ipv4_to_int(ip)
        if ip_int is None: continue
        a_mask = (0xFFFFFFFF << (32 - ap)) & 0xFFFFFFFF if ap else 0
        a_net = ip_int & a_mask
        # overlap if either side's network contains the other's ip
        if (a_net & n_mask) == n_net or (n_net & a_mask) == a_net:
            return ip
    # Default: first usable IP of the pool's network (X.Y.Z.1 for /24)
    if plen <= 30:
        return _int_to_ipv4(n_net + 1)
    return ""

def pull_pools_from_router(db, company_id):
    """Reconcile DB ip_pools with live router /ip/pool, enriched with
    derived network CIDR + gateway lookup from /ip/address. Returns
    {ok, used_nas, created, updated, archived, errors}."""
    import routeros_provision as rp
    NasD = globals()["NasDevice"]
    IpP  = globals()["IpPool"]
    nas_list = db.query(NasD).filter(
        NasD.company_id == company_id,
        NasD.status == "Active",
    ).order_by(NasD.id.asc()).all()
    out = {"ok": False, "used_nas": None, "created": 0,
           "updated": 0, "archived": 0, "errors": []}
    if not nas_list:
        out["errors"].append("no_active_nas"); return out
    live = None; addresses = []; last_err = None
    for n in nas_list:
        try:
            with rp.RouterOSClient(n, dry_run=False) as rc:
                live = rc.list_ip_pools() or []
                try:
                    addresses = [dict(a) for a in rc._api.path("ip/address")]
                except Exception:
                    addresses = []
                out["used_nas"] = n.id; break
        except Exception as e:
            last_err = str(e)
    if live is None:
        out["errors"].append(f"router_unreachable: {last_err}"); return out
    live_by_name = {(r.get("name") or "").strip(): r
                     for r in live if isinstance(r, dict) and r.get("name")}
    db_rows = db.query(IpP).filter(IpP.company_id == company_id).all()
    db_by_name = {r.name: r for r in db_rows}
    for nm, lp in live_by_name.items():
        ranges = (lp.get("ranges") or "").strip()
        next_pool = (lp.get("next-pool") or "").strip()
        start_v = end_v = network_v = ""
        if "-" in ranges:
            a, _, b = ranges.partition("-")
            start_v, end_v = a.strip(), b.strip()
            network_v = _smallest_cidr_for_range(start_v, end_v)
        elif "/" in ranges:
            network_v = ranges
        gateway_v = _gateway_for_network(addresses, network_v)
        role_v = _classify_role(nm)
        row = db_by_name.get(nm)
        if row:
            chg = False
            if start_v   and row.start_ip != start_v: row.start_ip = start_v; chg=True
            if end_v     and row.end_ip   != end_v:   row.end_ip   = end_v;   chg=True
            if network_v and row.network  != network_v: row.network  = network_v; chg=True
            if gateway_v and (row.gateway or "") != gateway_v: row.gateway = gateway_v; chg=True
            if role_v    and (row.role or "")    != role_v:    row.role    = role_v;    chg=True
            if (row.status or "") == "Removed":
                row.status = "Active"; chg = True
            if chg: out["updated"] += 1
        else:
            row = IpP(company_id=company_id, name=nm, network=network_v,
                       gateway=gateway_v, start_ip=start_v, end_ip=end_v,
                       status="Active", role=role_v,
                       dns_servers="8.8.8.8,1.1.1.1",
                       comment="imported from Mikrotik /ip/pool")
            db.add(row); out["created"] += 1
    for nm, row in db_by_name.items():
        if nm not in live_by_name and (row.status or "") != "Removed":
            row.status = "Removed"
            row.comment = (row.comment or "") + " | not on router"
            out["archived"] += 1
    try:
        db.commit(); out["ok"] = True
    except Exception as e:
        db.rollback(); out["errors"].append(f"commit_failed: {e}")
    return out

