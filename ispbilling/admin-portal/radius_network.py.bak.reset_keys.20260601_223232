                    "status": status,
                    "reason": row["reason"],
                    "source": "radius",
                    "row_id": row["id"],
                    "row_key": f"radius:{row['id']}",
                })
        except Exception:
            pass

        # Sort newest first
        merged.sort(key=lambda e: (e.get("ts") or datetime.min), reverse=True)
        context["access_logs"] = merged[:500]
        return templates.TemplateResponse("admin_access_logs.html", context)

