    @app.post("/api/nas-devices/{nas_id}/provision-customer")
    async def api_nas_provision_customer(nas_id: int, request: Request, db: Session = Depends(get_db)):
        """Create a PPPoE profile matching the customer's plan speeds, and a
        PPPoE secret with their username + given password on the router."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)

        data = await request.json()
        customer_id = (data.get("customer_id") or "").strip()
        password = (data.get("password") or "").strip()
        remote_address = (data.get("remote_address") or "").strip() or None
        dry_run = bool(data.get("dry_run", False))
        if not customer_id or not password:
            return JSONResponse({"success": False, "message": "customer_id and password required"}, status_code=400)

        from database import Customer, Plan
        cust = db.query(Customer).filter(Customer.customer_id == customer_id,
                                          Customer.company_id == company_id).first()
        if not cust:
            return JSONResponse({"success": False, "message": "Customer not found"}, status_code=404)
        if not cust.username:
            return JSONResponse({"success": False, "message": "Customer has no PPPoE username"}, status_code=400)
        if not cust.plan_id:
            return JSONResponse({"success": False, "message": "Customer has no active plan"}, status_code=400)
        plan = db.query(Plan).filter(Plan.id == cust.plan_id,
                                      Plan.company_id == company_id).first()
        if not plan:
            return JSONResponse({"success": False, "message": "Assigned plan not found"}, status_code=404)
        if plan.service != "Broadband":
            return JSONResponse({"success": False, "message": "Plan is not a Broadband plan — PPPoE not applicable"}, status_code=400)

        plan_dict = {
            "plan_name": plan.plan_name,
            "download_speed": plan.download_speed,
            "upload_speed": plan.upload_speed,
            "priority": plan.priority,
            "queue_type": plan.queue_type,
        }
        customer_dict = {"username": cust.username}

        # Session 19 — dispatch on the customer's `auth_type` column so
        # Hotspot and Static-IP customers get their own flow instead of
        # being forced through the PPPoE secret path.
        _auth_type = (getattr(cust, "auth_type", None) or "pppoe").strip().lower()
        _static_ip = (getattr(cust, "static_ip_address", None) or "").strip()
        _mac = (getattr(cust, "mac_address", None) or "").strip()
        # `remote_address` from the request body still wins (manual override
        # from the Provision Customer dialog); else use customer's stored
        # static IP when auth_type=static_ip.
        # _S44_PPPOE_STATIC_PIN — REVERTED (s45c rollback). PPPoE-with-
        # static now relies on RADIUS Framed-IP-Address only; pinning
        # remote-address on the local secret risks shadowing RADIUS in ways
        # the operator did not intend.
        _effective_remote = remote_address or (
            _static_ip if _auth_type in ("static_ip", "static-ip", "static") else None)
        res = rp.provision_customer(
            nas=nas, customer=customer_dict, plan=plan_dict,
            password=password,
            auth_type=_auth_type,
            static_ip=_static_ip,
            mac_address=_mac,
            remote_address=_effective_remote,
            dry_run=dry_run,
            pool_name=(nas.pppoe_pool_name or "pppoe-pool"),
        )
        res.setdefault("customer", {"customer_id": cust.customer_id, "username": cust.username,
                                     "plan_name": plan.plan_name,
                                     "download_speed": plan.download_speed,
                                     "upload_speed": plan.upload_speed})

        # Remember provisioning so future plan-changes can auto-reprovision
        if res.get("success") and not dry_run:
            try:
                cust.provisioned_nas_id = nas.id
                cust.pppoe_password = password
                db.commit()
            except Exception:
                db.rollback()
            # _S45_HARMONIZE_HOOK_PROVISION — DISABLED (s45c rollback)
            # Harmonizer auto-run on provision was creating conflicting /32
            # routes vs dynamic PPPoE routes. Disabled — manual trigger only.
        return res

