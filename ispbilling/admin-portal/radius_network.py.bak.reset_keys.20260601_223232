    id = Column(Integer, primary_key=True, index=True)
    company_id = Column(String, index=True, nullable=False)
    name = Column(String, nullable=False)
    ip_address = Column(String, nullable=False)
    secret = Column(String, nullable=True, default="")
    type = Column(String, nullable=True, default="Mikrotik")  # Mikrotik/Cisco/Other
    location = Column(String, nullable=True, default="")
    status = Column(String, nullable=True, default="Active")  # Active/Inactive

    # RouterOS API / SSH credentials + transport options
    api_username = Column(String, nullable=True, default="admin")
    api_password = Column(String, nullable=True, default="")
    port = Column(Integer, nullable=True, default=8728)
    use_tls = Column(Boolean, nullable=True, default=False)
    use_ssh = Column(Boolean, nullable=True, default=False)
    ssh_port = Column(Integer, nullable=True, default=22)
    provisioned_at = Column(DateTime, nullable=True)
    last_status = Column(String, nullable=True, default="unknown")
    last_status_msg = Column(String, nullable=True, default="")
    # Name of the /ip/pool that the PPPoE server hands IPs from. Recorded
    # during auto-configure so per-customer provisioning uses the SAME pool
    # as `remote-address` on the PPP profile (fixes "connected but no IP").
    pppoe_pool_name = Column(String, nullable=True, default="pppoe-pool")

    # -----------------------------------------------------------------
    # Multi-scenario deployment fields (Session 18) — each NAS can run
    # PPPoE, Hotspot, Static-IP auth, or a mix. All optional — existing
    # rows keep their legacy PPPoE-only behaviour.
    # -----------------------------------------------------------------
    # Which auth modes this NAS serves. Comma-separated subset of
    # {pppoe,hotspot,static}. Controls what Auto-Configure pushes and
    # which customers are rendered to RADIUS against this NAS.
    auth_modes = Column(String, nullable=True, default="pppoe")
    # PPPoE service-name advertised in PADI replies. Empty = accept-any
    # (router answers to any PPPoE dial-up regardless of service name).
    # Real-world ISPs who run multiple brands on one BNG set this to
    # distinguish sessions.
    pppoe_service_name = Column(String, nullable=True, default="")
    # Base LAN interface that PPPoE listens on. Default `ether2`;
    # ISPs with VLAN-separated downstream aggregation set this to
    # the VLAN-parent physical port.
    pppoe_interface = Column(String, nullable=True, default="ether2")
    # If set (non-zero), PPPoE is bound to `/interface/vlan name=isp-pppoe-vlan`
    # with this tag, created over `pppoe_interface` as parent. Useful
    # for tagged-ethernet BNG deployments (one switch trunk carries
    # multiple customer VLANs).
    pppoe_vlan_id = Column(Integer, nullable=True, default=0)
    # Hotspot interface (captive-portal). Default ether3.
    hotspot_interface = Column(String, nullable=True, default="ether3")
    # Hotspot DNS name for captive redirect. Empty = use server IP.
    hotspot_dns_name = Column(String, nullable=True, default="")
    # Name of the /ip/pool that the Hotspot server hands IPs from.
    hotspot_pool_name = Column(String, nullable=True, default="hotspot-pool")
    # s36e per-NAS walled-garden override (comma/newline separated).
    # Empty => fall back to CaptivePortalSettings.walled_garden_hosts.
    walled_garden_hosts = Column(String, nullable=True, default="")
    # s39: pinned WAN interface for the /api/admin/wan-speed/snapshot
    # endpoint. Empty => auto-detect via default-route walk (legacy).
    # When set, the snapshot always reads this iface's rx/tx bytes,
    # so failover testing or multi-WAN setups don't flip the graph
    # to the wrong port. Also used to surface a "PINNED" badge in
    # the WAN Live Speed modal for transparency.
    pinned_wan_iface = Column(String, nullable=True, default="")

    created_at = Column(DateTime, default=datetime.utcnow)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)

    __table_args__ = (
        Index("idx_nas_company", "company_id"),
    )


