    @app.post("/api/public-ips/create")
    async def api_publicip_create(request: Request, db: Session = Depends(get_db)):
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        data = await request.json()
        raw = (data.get("ip_address") or "").strip()
        label = (data.get("label") or "").strip()
        notes = (data.get("notes") or "").strip()
        pool_name = (data.get("pool_name") or "Default").strip() or "Default"  # s37
        if not raw:
            return JSONResponse({"success": False, "message": "ip_address required"}, status_code=400)

        # Accept: single IP, CIDR (e.g. 203.0.113.0/29), dash-range (a-b)
        ips_to_add = []
        try:
            if "/" in raw:
                net = ipaddress.ip_network(raw, strict=False)
                hosts = list(net.hosts()) if net.num_addresses > 2 else list(net)
                ips_to_add = [str(ip) for ip in hosts]
            elif "-" in raw:
                start_s, end_s = [p.strip() for p in raw.split("-", 1)]
                start_ip = ipaddress.ip_address(start_s)
                end_ip = ipaddress.ip_address(end_s)
                if int(end_ip) < int(start_ip):
                    raise ValueError("end < start")
                if int(end_ip) - int(start_ip) > 1024:
                    return JSONResponse({"success": False, "message": "Range too large (> 1024 addresses)"}, status_code=400)
                ips_to_add = [str(ipaddress.ip_address(i))
                              for i in range(int(start_ip), int(end_ip) + 1)]
            else:
                ipaddress.ip_address(raw)
                ips_to_add = [raw]
        except ValueError as e:
            return JSONResponse({"success": False, "message": f"Invalid IP/CIDR/range: {e}"}, status_code=400)

        existing = {r.ip_address for r in db.query(PublicIpAddress.ip_address).filter(
            PublicIpAddress.company_id == company_id).all()}
        added = []
        for ip in ips_to_add:
            if ip in existing:
                continue
            row = PublicIpAddress(
                company_id=company_id, ip_address=ip,
                label=label, notes=notes, status="Free",
                pool_name=pool_name,  # s37
            )
            db.add(row)
            added.append(ip)
        db.commit()
        return {"success": True, "added": added, "count": len(added),
                "skipped_duplicates": len(ips_to_add) - len(added)}

    @app.post("/api/public-ips/bulk-delete")
    async def api_publicip_bulk_delete(request: Request, db: Session = Depends(get_db)):
        """Bulk-delete public IPs by ids. Skips IPs currently assigned to a
        PPPoE secret (safety) and ignores ids belonging to a different company."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        try:
            payload = await request.json()
        except Exception:
            return JSONResponse({"success": False, "message": "Invalid JSON"}, status_code=400)
        ids = payload.get("ids") or []
        if not isinstance(ids, list) or not ids:
            return JSONResponse({"success": False, "message": "No ids supplied"}, status_code=400)
        # Hard cap to prevent runaway deletes
        if len(ids) > 5000:
            return JSONResponse({"success": False, "message": "Too many ids (max 5000)"}, status_code=400)
        try:
            ids = [int(x) for x in ids]
        except Exception:
            return JSONResponse({"success": False, "message": "Non-numeric id supplied"}, status_code=400)

        rows = (db.query(PublicIpAddress)
                  .filter(PublicIpAddress.id.in_(ids),
                          PublicIpAddress.company_id == company_id)
                  .all())
        deleted = 0
        skipped_assigned = 0
        for r in rows:
            if (r.status or "Free") == "Assigned" or (r.assigned_to or "").strip():
                skipped_assigned += 1
                continue
            db.delete(r)
            deleted += 1
        db.commit()
        return {"success": True, "deleted": deleted, "skipped_assigned": skipped_assigned}

