    @app.post("/api/customers/bulk-generate-pppoe")
    async def api_bulk_gen_pppoe(request: Request, db: Session = Depends(get_db)):
        """Bulk-populate `pppoe_password` for every customer missing one.
        Returns the list of (username,password) pairs so admin can hand them
        out. Idempotent — existing passwords never overwritten unless
        `overwrite:true`. Auto-triggers FreeRADIUS sync-all at the end."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        from sqlalchemy import text as _text
        import secrets, string
        body = {}
        try:
            body = await request.json()
        except Exception:
            pass
        overwrite = bool(body.get("overwrite", False))
        alphabet = string.ascii_letters + string.digits
        rows = list(db.execute(_text("""
            SELECT id, username, pppoe_password
              FROM customers
             WHERE company_id = :cid AND IFNULL(username,'') <> ''
        """), {"cid": company_id}).mappings())
        generated = []
        skipped = 0
        for r in rows:
            has = bool((r["pppoe_password"] or "").strip())
            if has and not overwrite:
                skipped += 1
                continue
            pw = "".join(secrets.choice(alphabet) for _ in range(12))
            db.execute(_text("UPDATE customers SET pppoe_password = :pw WHERE id = :id"),
                        {"pw": pw, "id": r["id"]})
            generated.append({"username": r["username"], "password": pw})
        db.commit()
        nas_rows = db.query(NasDevice).filter(NasDevice.company_id == company_id,
                                               NasDevice.status == "Active").all()
        cust_rows = _build_customer_radius_rows(db, company_id)
        sync_res = fm.sync_all(nas_rows, cust_rows, company_id=company_id, restart=True)
        return {
            "success": True,
            "generated_count": len(generated),
            "skipped_existing": skipped,
            "total_customers": len(rows),
            "generated": generated,
            "sync": sync_res,
        }


