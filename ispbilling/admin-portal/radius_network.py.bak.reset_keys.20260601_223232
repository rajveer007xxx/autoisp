    # s26.13: add-extra-pool-endpoint
    @app.post("/api/nas-devices/{nas_id}/add-extra-pool")
    async def api_nas_add_extra_pool(nas_id: int, request: Request, db: Session = Depends(get_db)):
        """One-click: create an ip_pools row + push /ip/pool on the NAS.
        Accepts internal-token from superadmin proxy."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)
        data = await request.json()
        name = (data.get("name") or "").strip()
        # s26.15: axp-explicit-network
        # Separate `network` (CIDR) and `ranges` (usable slice) fields.
        # Legacy: if only `ranges` was sent (old clients), fall back to
        # deriving `network_v` from it like before.
        network_in = (data.get("network") or "").strip()
        ranges_in  = (data.get("ranges") or "").strip() or network_in
        gateway = (data.get("gateway") or "").strip()
        iface   = (data.get("interface") or "").strip()
        role    = (data.get("role") or "PPPoE").strip()
        dns     = (data.get("dns_servers") or "8.8.8.8,1.1.1.1").strip()
        status  = (data.get("status") or "Active").strip()
        try:
            _np = data.get("next_pool_id")
            _np = int(_np) if _np not in (None, "", "null") else None
        except (TypeError, ValueError):
            _np = None
        if not name or not ranges_in:
            return JSONResponse({"success": False,
                "message": "name and range/network are required"}, status_code=400)

        # Normalise: explicit network (if given) is authoritative.
        network_v = ""
        start_v = ""
        end_v = ""
        if network_in:
            try:
                import ipaddress as _ip
                _ip.ip_network(network_in, strict=False)
            except Exception:
                return JSONResponse({"success": False,
                    "message": f"Invalid Network (CIDR): {network_in}"},
                    status_code=400)
            network_v = network_in
        if "-" in ranges_in:
            a, _, b = ranges_in.partition("-")
            start_v = a.strip()
            end_v = b.strip()
        elif "/" in ranges_in:
            # No explicit network given — use this as both network & range
            if not network_v:
                try:
                    import ipaddress as _ip
                    _ip.ip_network(ranges_in, strict=False)
                except Exception:
                    return JSONResponse({"success": False,
                        "message": "Invalid CIDR"}, status_code=400)
                network_v = ranges_in
        else:
            return JSONResponse({"success": False,
                "message": "Range must be either a-b or x.x.x.x/N"}, status_code=400)

        # Dup-guard: same (company, name)
        dup = db.query(IpPool).filter(IpPool.company_id == company_id,
                                      IpPool.name == name).first()
        if dup:
            return JSONResponse({"success": False,
                "message": f"Pool '{name}' already exists for this admin. Edit or pick a different name."},
                status_code=409)

        row = IpPool(
            company_id=company_id, name=name,
            network=network_v,
            gateway=gateway, start_ip=start_v, end_ip=end_v,
            status=status, role=role, dns_servers=dns, comment="added via superadmin NAS console",
            next_pool_id=_np,
        )
        db.add(row); db.commit(); db.refresh(row)

        # Push to router
        pool_dict = {
            "id": row.id, "name": name,
            "ranges": (f"{start_v}-{end_v}" if start_v and end_v else network_v),
            "start_ip": start_v, "end_ip": end_v, "network": network_v,
            "gateway": gateway, "interface": iface, "role": role,
        }
        # next_pool resolution
        if _np:
            np_row = db.query(IpPool).filter(IpPool.id == _np,
                                              IpPool.company_id == company_id).first()
            if np_row:
                pool_dict["next_pool"] = np_row.name

        pushed = False
        router_msg = ""
        try:
            with rp.RouterOSClient(nas, dry_run=False) as rc:
                res = rc.sync_ip_pools_to_router([pool_dict])
                pushed = True
                router_msg = "; ".join(
                    str((x or {}).get("status") or (x or {}).get("message") or "ok")
                    for x in (res or [])
                )
        except Exception as e:
            router_msg = f"router push failed: {e}"

        return {"success": True, "id": row.id,
                "pushed": pushed, "router_msg": router_msg,
                "message": f"Pool '{name}' created" + (" and pushed to router." if pushed else " but router push failed — fix connection and rerun Auto-Configure.")}

