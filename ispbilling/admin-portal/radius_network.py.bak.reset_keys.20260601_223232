    @app.post("/api/nas-devices/{nas_id}/switch-to-radius-only")
    async def api_nas_switch_radius_only(nas_id: int, request: Request, db: Session = Depends(get_db)):
        """One-click RADIUS-only migration (Session 25 Phase 0).

        Body:
          dry_run      : bool (default True)  -- preview only
          clear_local  : bool (default False) -- also purge every /ppp/secret row
                          (backup is returned in secrets_before)
        """
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)
        body = {}
        try:
            body = await request.json()
        except Exception:
            pass
        dry_run = bool(body.get("dry_run", True))
        clear_local = bool(body.get("clear_local", False))

        our_ip = (body.get("radius_server_ip") or "").strip()
        if not our_ip:
            our_ip = (os.environ.get("ISP_PUBLIC_IP") or "").strip()
        if not our_ip:
            try:
                import socket as _sock
                s = _sock.socket(_sock.AF_INET, _sock.SOCK_DGRAM)
                s.connect(("8.8.8.8", 80))
                our_ip = s.getsockname()[0]
                s.close()
            except Exception:
                our_ip = ""
        secret = (nas.secret or "").strip() or "testing123"

        try:
            with rp.RouterOSClient(nas, dry_run=False) as c:
                res = c.switch_to_radius_only(
                    radius_server_ip=our_ip,
                    radius_secret=secret,
                    clear_local=clear_local,
                    dry_run_internal=dry_run,
                )
        except Exception as e:
            return {"success": False, "message": f"router err: {e}"}

        # Persist a text backup of the secrets if we purged them for real.
        if (res.get("success") and clear_local and not dry_run
                and res.get("secrets_before")):
            try:
                import os as _os, json as _json, time as _t
                bk_dir = "/opt/ispbilling/backups"
                _os.makedirs(bk_dir, exist_ok=True)
                bk = f"{bk_dir}/nas_{nas.id}_{_t.strftime('%Y%m%d_%H%M%S')}_secrets.json"
                with open(bk, "w") as _f:
                    _json.dump({"nas": nas.name, "ip": nas.ip_address,
                                "secrets": res["secrets_before"]}, _f, indent=2)
                res["backup_path"] = bk
            except Exception as _e:
                res["stages"].append(f"backup err: {_e}")

        # Friendly single-line message
        if res.get("success"):
            kind = "DRY-RUN" if dry_run else "EXECUTED"
            count = res.get("cleared_count", 0)
            total = len(res.get("secrets_before", []))
            res["message"] = (
                f"{kind}: /ppp/aaa use-radius=yes; "
                f"/radius row: {res.get('radius_row',{}).get('address','(to-be-added)')}; "
                f"secrets total={total}, "
                + (f"removed={count}" if clear_local else "kept (not cleared)")
            )
        return res

