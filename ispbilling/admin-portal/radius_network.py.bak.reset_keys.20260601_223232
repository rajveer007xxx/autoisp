    async def api_nas_deploy_walled_garden(nas_id: int, request: Request, db: Session = Depends(get_db)):
        """Deploy (or re-deploy) the parking pool + firewall walled-garden
        rules on a router. After this + FreeRADIUS users file regen,
        Suspended/Disabled/Expired subscribers will PPPoE-connect into
        the parking pool and only be able to reach the suspension page
        + DNS + whitelisted payment-gateway hostnames.

        Body (all optional):
