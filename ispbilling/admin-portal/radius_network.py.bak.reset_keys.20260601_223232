        if not landing_page_ip:
            landing_page_ip = (os.environ.get("ISP_PUBLIC_IP") or "").strip()
        if not landing_page_ip:
            try:
                import socket as _sock
                s = _sock.socket(_sock.AF_INET, _sock.SOCK_DGRAM)
                s.connect(("8.8.8.8", 80))
                landing_page_ip = s.getsockname()[0]; s.close()
            except Exception:
                landing_page_ip = ""
        if not landing_page_ip or landing_page_ip.startswith("127."):
            return {"success": False,
                    "message": ("Landing page IP required. Set ISP_PUBLIC_IP env "
