    @app.post("/api/customers/{customer_id}/suspend")
    async def api_customer_suspend(customer_id: str, request: Request, db: Session = Depends(get_db)):
        """One-click suspend: flip status → Suspended, auto-resync FreeRADIUS
        (customer's reply now carries Framed-Pool=<parking> + blocked tag),
        then send CoA Disconnect so the live session drops and reconnects
        straight into the parking pool. Reverse action: /resume."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        from sqlalchemy import text as _text
        body = {}
        try:
            body = await request.json()
        except Exception:
            pass
        action = (body.get("action") or "suspend").strip().lower()
        new_status = "Suspended" if action == "suspend" else "Active"

        row = db.execute(_text("""
            SELECT id, username, provisioned_nas_id FROM customers
             WHERE (id = :cid OR customer_id = :cidstr) AND company_id = :co LIMIT 1
        """), {"cid": customer_id if str(customer_id).isdigit() else -1,
              "cidstr": str(customer_id), "co": company_id}).mappings().first()
        if not row:
            return JSONResponse({"success": False, "message": "Customer not found"}, status_code=404)
        db.execute(_text("UPDATE customers SET status=:s WHERE id=:cid"),
                    {"s": new_status, "cid": row["id"]})
        db.commit()

        nas_rows = db.query(NasDevice).filter(NasDevice.company_id == company_id,
                                               NasDevice.status == "Active").all()
        cust_rows = _build_customer_radius_rows(db, company_id)
        sync_res = fm.sync_all(nas_rows, cust_rows, company_id=company_id, restart=True)

        # Kick the live session so new RADIUS attributes take effect NOW
        kick_res = {"skipped": True, "reason": "no provisioned NAS"}
        if row["provisioned_nas_id"]:
            nas = _get_nas(db, company_id, int(row["provisioned_nas_id"]))
            if nas:
                kick_res = fm.send_coa_disconnect(
                    nas_ip=nas.ip_address, username=row["username"],
                    secret=(nas.secret or "testing123"),
                )
        return {
            "success": True,
            "customer_id": customer_id,
            "username": row["username"],
            "new_status": new_status,
            "sync": sync_res,
            "kick": kick_res,
        }

    # --- PPPoE secrets proxy ---
    @app.post("/api/nas-devices/{nas_id}/sync-radius-secret")
    async def api_nas_sync_radius_secret(nas_id: int, request: Request, db: Session = Depends(get_db)):
        """Force the router's /radius entry secret + address to match our
        FreeRADIUS. Cures the classic two-way drift:

          1. **Secret drift** — router.secret != clients.conf.secret →
             router rejects our Access-Accept replies → PPPoE users
             bounce with "RADIUS timeout".
          2. **Address drift** — router.address != our PUBLIC IP →
             router sends Access-Request to the wrong host (commonly
             127.0.0.1, loopback; or an old VPS IP after migration) →
             no packets reach us → same timeout symptom.

        The RADIUS server IP resolution chain:
          1. Explicit `radius_server_ip` in request body (admin override).
          2. `ISP_PUBLIC_IP` env variable (set once at deploy time — the
             authoritative source).
          3. Fallback: the first IPv4 on our default outbound interface.

        We deliberately DO NOT use `request.url.hostname` or
        `request.client.host` as a fallback — those return `127.0.0.1`
        when the call originates from the SuperAdmin proxy and would
        silently corrupt the router's /radius.address. This bug bit us
        in session 15."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas = _get_nas(db, company_id, nas_id)
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)
        body = {}
        try:
            body = await request.json()
        except Exception:
            pass
        our_ip = (body.get("radius_server_ip") or "").strip()
        if not our_ip:
            our_ip = (os.environ.get("ISP_PUBLIC_IP") or "").strip()
        if not our_ip:
            try:
                import socket as _sock
                s = _sock.socket(_sock.AF_INET, _sock.SOCK_DGRAM)
                s.connect(("8.8.8.8", 80))
                our_ip = s.getsockname()[0]
                s.close()
            except Exception:
                our_ip = ""
        if not our_ip or our_ip.startswith("127."):
            return JSONResponse({
                "success": False,
                "message": "Could not resolve RADIUS server public IP. Set ISP_PUBLIC_IP env var or pass radius_server_ip in body.",
            }, status_code=400)
        return rp.sync_radius_secret(nas, radius_server_ip=our_ip)



