    @app.post("/api/nas-devices/{row_id}/delete")
    async def api_nas_delete(row_id: int, request: Request, db: Session = Depends(get_db)):
        # Session 19 — accept SuperAdmin internal-token proxy calls too so
        # the dedicated NAS Console page can delete NAS rows.
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        row = db.query(NasDevice).filter(NasDevice.id == row_id,
                                          NasDevice.company_id == company_id).first()
        if not row:
            return JSONResponse({"success": False, "message": "Not found"}, status_code=404)
        # _S39NAS_DELETE_PURGE — Before tossing the row, connect to the
        # physical Mikrotik and remove every customer's /ppp/secret +
        # blocked address-list entry that this NAS was provisioning.
        # Otherwise the router still has those secrets when it gets
        # reassigned to another tenant — admin A's customers would
        # keep authenticating against admin B's router.
        purge_log = {"secrets_removed": 0, "customers_affected": 0,
                       "router_reachable": False, "errors": []}
        try:
            from routeros_provision import RouterOSClient
            cust_q = db.execute(_text(
                "SELECT id, username FROM customers "
                " WHERE company_id=:cid AND "
                "       (provisioned_nas_id=:nid OR provisioned_nas_id IS NULL)"),
                {"cid": company_id, "nid": row.id}).fetchall()
            usernames = [r[1] for r in cust_q if r[1]]
            purge_log["customers_affected"] = len(usernames)
            if usernames:
                with RouterOSClient(row, dry_run=False) as rc:
                    purge_log["router_reachable"] = True
                    secrets = rc._api.path("ppp/secret")
                    for sec in list(secrets):
                        nm = sec.get("name")
                        if nm and nm in usernames:
                            try:
                                secrets.remove(sec[".id"])
                                purge_log["secrets_removed"] += 1
                            except Exception as _e:
                                purge_log["errors"].append(f"sec {nm}: {_e}")
                    # Also kick any open PPP sessions for those users
                    try:
                        actives = rc._api.path("ppp/active")
                        for ar in list(actives):
                            if ar.get("name") in usernames:
                                actives.remove(ar[".id"])
                    except Exception:
                        pass
                    # Remove their queues (best-effort)
                    try:
                        queues = rc._api.path("queue/simple")
                        for q in list(queues):
                            cmt = (q.get("name") or "") + " " + (q.get("comment") or "")
                            for un in usernames:
                                if un and un in cmt:
                                    queues.remove(q[".id"])
                                    break
                    except Exception:
                        pass
                # Clear the customers' provisioned_nas_id + pppoe_password
                # so the next provisioning round starts clean.
                db.execute(_text(
                    "UPDATE customers SET provisioned_nas_id=NULL, "
                    "  pppoe_password='' "
                    " WHERE company_id=:cid AND provisioned_nas_id=:nid"),
                    {"cid": company_id, "nid": row.id})
        except Exception as _e:
            purge_log["errors"].append(str(_e))
        # s37p: capture identity for audit log before deletion wipes it.
        _snap = type("NasSnap", (), {
            "id": row.id, "name": row.name,
        })
        _log_nas_audit(request, company_id, _snap, "delete",
                        summary_extra=f"ip={row.ip_address} "
                        f"purged_secrets={purge_log['secrets_removed']}")
        db.delete(row)
        db.commit()
        # Re-render clients.conf + users GLOBALLY so we don't wipe other
        # tenants' customers from isp-users when this NAS row is deleted.
        try:
            _sync_freeradius_all_tenants(db, restart=True)
        except Exception:
            pass
        return {"success": True}

