        # exactly one company at write/backfill time using a deterministic
        # cascade (unique username -> uname+MAC -> active customer -> orphan).
        # Cross-tenant leaks are now impossible by construction — filter
        # is on a single column, not on usernames/NAS-IPs.
        try:
            from radpostauth_tenant import fetch_tenant_radpostauth as _rp_fetch
            import datetime as _dt
            for row in _rp_fetch(db, company_id, limit=500):
                authdate = row["authdate"]
                try:
                    ts_obj = _dt.datetime.strptime(
                        (authdate or "").split(".")[0], "%Y-%m-%d %H:%M:%S")
                except Exception:
                    ts_obj = None
                status = ("Accept"
                          if (row["reply"] or "").lower().startswith("access-accept")
                          else "Reject")
                merged.append({
                    "ts_display": _tzu_ist_local_str_loc(authdate),
                    "ts": ts_obj, "username": row["username"],
