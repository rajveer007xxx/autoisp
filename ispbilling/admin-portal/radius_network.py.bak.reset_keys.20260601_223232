    @app.get("/api/nas-devices/{nas_id}/wg-script")
    async def api_nas_wg_script(nas_id: int, request: Request):
        """Re-render the existing peer's Mikrotik script WITHOUT rotating keys.

        Query param ?port=443 builds the script using the UDP/443 fallback
        endpoint (server has iptables DNAT 443->51820). Either port reaches
        the same wg0 instance with the same keys.
        """
        auth_check = require_auth(request)
        if auth_check:
            return auth_check
        company_id = request.session.get("company_id")
        import sys as _sys
        _RD = "/opt/ispbilling/superadmin-portal/routes"
        if _RD not in _sys.path: _sys.path.insert(0, _RD)
        import sa_wg_tunnel as _wg
        import sqlite3
        # Choose port from query string
        port_q = (request.query_params.get("port") or _wg.DEFAULT_LISTEN_PORT).strip()
        if port_q not in (_wg.DEFAULT_LISTEN_PORT, _wg.DEFAULT_FALLBACK_PORT):
            return JSONResponse({"ok": False,
                                 "error": f"port must be {_wg.DEFAULT_LISTEN_PORT} or {_wg.DEFAULT_FALLBACK_PORT}"},
                                status_code=400)
        with sqlite3.connect(_wg.DB_PATH, timeout=10) as con:
            con.row_factory = sqlite3.Row
            row = con.execute(
                "SELECT * FROM nas_devices WHERE id=? AND company_id=?",
                (nas_id, company_id)).fetchone()
            if not row:
                return JSONResponse({"ok": False, "error": "NAS not found"}, status_code=404)
            priv = row["wg_peer_privkey"]
            ip   = (row["wg_tunnel_ip"] or "").split("/")[0]
            if not priv or not ip:
                return JSONResponse({"ok": False, "error": "No tunnel provisioned for this NAS"}, status_code=404)
            server_pub = _wg._read_server_pubkey()
            radius_secret = row["secret"] or "changeme"
            script_primary = _wg._mikrotik_script(
                nas_priv=priv, nas_ip=ip, server_pub=server_pub,
                endpoint_host=_wg.DEFAULT_ENDPOINT_HOST,
                listen_port=port_q,
                radius_secret=radius_secret,
            )
            script_fallback = _wg._mikrotik_script(
                nas_priv=priv, nas_ip=ip, server_pub=server_pub,
                endpoint_host=_wg.DEFAULT_ENDPOINT_HOST,
                listen_port=_wg.DEFAULT_FALLBACK_PORT,
                radius_secret=radius_secret,
            )
            _peer_pub = row["wg_peer_pubkey"] or ""
            return {
                "ok": True, "nas_id": nas_id,
                "tunnel_ip": ip, "radius_ip": _wg.RADIUS_LISTEN,
                "server_pubkey": server_pub,
                "peer_pubkey": _peer_pub,
                "peer_pubkey_short": (_peer_pub[:8] + "..." + _peer_pub[-4:]) if _peer_pub else "",
                "endpoint": f"{_wg.DEFAULT_ENDPOINT_HOST}:{port_q}",
                "endpoint_fallback": f"{_wg.DEFAULT_ENDPOINT_HOST}:{_wg.DEFAULT_FALLBACK_PORT}",
                "mikrotik_script": script_primary,
                "mikrotik_script_fallback": script_fallback,
                "hint_when_to_use_fallback": (
                    f"If pasting the primary script (UDP/{port_q}) does not "
                    f"result in a handshake within 30 seconds, the customer's "
                    f"ISP is most likely blocking UDP/{port_q}. Paste the "
                    f"FALLBACK script instead -- it uses UDP/"
                    f"{_wg.DEFAULT_FALLBACK_PORT} which is rarely blocked. "
                    f"Same cloud server, same keys, only the port differs."
                ),
            }

