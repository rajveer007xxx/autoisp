    # =====================================================================
    # Provisioning / RouterOS API routes
    # =====================================================================
    import routeros_provision as rp
    import freeradius_manager as fm

    def _get_nas(db, company_id, nas_id):
        return db.query(NasDevice).filter(
            NasDevice.id == nas_id, NasDevice.company_id == company_id
        ).first()


    # _S39POOL_LIVE_SYNC ---------------------------------------------------
    def _all_active_nas(db, company_id):
        """Every Active Mikrotik NAS the company owns (preferred order:
        primary first, then by id)."""
        return db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active",
        ).order_by(NasDevice.id.asc()).all()

    def _pull_pools_from_router(db, company_id):
        """Reconcile the company's ip_pools table with the live /ip/pool of
        their first reachable NAS.

          - router-pool whose name matches a DB row: refresh start/end/network
          - router-pool missing from DB: INSERT (status='Active')
          - DB row whose name is no longer on the router: status='Removed'
            (we keep history rather than hard-delete to preserve plan
            references like Plan.ip_pool_id)
        Returns dict {ok, used_nas, created, updated, archived, errors}.
        Best-effort: returns ok=False with errors if router unreachable.
        """
        out = {"ok": False, "used_nas": None,
               "created": 0, "updated": 0, "archived": 0, "errors": []}
        nas_list = _all_active_nas(db, company_id)
        if not nas_list:
            out["errors"].append("no_active_nas")
            return out
        live = None
        last_err = None
        for n in nas_list:
            try:
                with rp.RouterOSClient(n, dry_run=False) as rc:
                    live = rc.list_ip_pools() or []
                    out["used_nas"] = n.id
                    break
            except Exception as e:
                last_err = str(e)
                continue
        if live is None:
            out["errors"].append(f"router_unreachable: {last_err or 'unknown'}")
            return out

        # Build name -> live-pool dict (filter out empty rows / SSH raw blobs)
        live_by_name = {}
        for r in live:
            nm = (r.get("name") or "").strip() if isinstance(r, dict) else ""
            if not nm: continue
            live_by_name[nm] = r

        # Build DB rows by name
        db_rows = db.query(IpPool).filter(IpPool.company_id == company_id).all()
        db_by_name = {r.name: r for r in db_rows}

        # Insert / update from router -> DB
        for nm, lp in live_by_name.items():
            ranges = (lp.get("ranges") or "").strip()
            start_v = end_v = network_v = ""
            if "-" in ranges:
                a, _, b = ranges.partition("-")
                start_v, end_v = a.strip(), b.strip()
            elif "/" in ranges:
                network_v = ranges
            row = db_by_name.get(nm)
            if row:
                changed = False
                if start_v and row.start_ip != start_v: row.start_ip = start_v; changed=True
                if end_v   and row.end_ip   != end_v:   row.end_ip   = end_v;   changed=True
                if network_v and row.network != network_v: row.network = network_v; changed=True
                if (row.status or "") == "Removed":
                    row.status = "Active"; changed = True
                if changed:
                    out["updated"] += 1
            else:
                row = IpPool(
                    company_id=company_id, name=nm,
                    network=network_v,
                    gateway="", start_ip=start_v, end_ip=end_v,
                    status="Active",
                    role=("Hotspot" if "hotspot" in nm.lower()
                           else "Static-IP" if ("static" in nm.lower())
                           else "PPPoE"),
                    dns_servers="8.8.8.8,1.1.1.1",
                    comment="imported from Mikrotik /ip/pool",
                )
                db.add(row); out["created"] += 1

        # Archive DB rows that no longer exist on the router
        for nm, row in db_by_name.items():
            if nm not in live_by_name and (row.status or "") != "Removed":
                row.status = "Removed"
                row.comment = (row.comment or "") + " | not on router"
                out["archived"] += 1

        try:
            db.commit()
        except Exception as e:
            db.rollback()
            out["errors"].append(f"commit_failed: {e}")
            return out
        out["ok"] = True
        return out


    def _looks_public_ipv4(network):
        """Crude heuristic: anything not in 10/8, 172.16/12, 192.168/16,
        169.254/16, 100.64/10 (CGNAT), 127/8 — treat as a public block
        and push /ip/address + default route plumbing."""
        if not network or "/" not in network: return False
        a = network.split(".")
        try:
            o1 = int(a[0]); o2 = int(a[1])
        except (IndexError, ValueError):
            return False
        if o1 == 10: return False
        if o1 == 127: return False
        if o1 == 169 and o2 == 254: return False
        if o1 == 172 and 16 <= o2 <= 31: return False
        if o1 == 192 and o2 == 168: return False
        if o1 == 100 and 64 <= o2 <= 127: return False
        return True

    def _push_public_block(db, company_id, name, network, gateway):
        """Best-effort: when admin saves a public-IP pool, also write the
        IP address + default route to all Active NAS routers."""
        if not _looks_public_ipv4(network):
            return None
        nas_list = _all_active_nas(db, company_id)
        results = []
        for n in nas_list:
            try:
                with rp.RouterOSClient(n, dry_run=False) as rc:
                    res = rc.apply_public_ip_block(
                        network=network, gateway=gateway or "",
                        wan_interface=getattr(n, "wan_interface", "")
                                       or "ether1",
                        upstream_gateway="",  # admin to fill in later
                        pool_name=name,
                    )
                    results.append({"nas": n.name, **(res or {})})
            except Exception as e:
                results.append({"nas": n.name, "status": "error",
                                 "message": str(e)})
        return results

    def _push_pool_to_all_nas(db, company_id, pool_dict, action="upsert"):
        """Best-effort push of a pool change to every Active NAS the company
        owns. action=upsert | delete."""
        nas_list = _all_active_nas(db, company_id)
        results = []
        for n in nas_list:
            try:
                with rp.RouterOSClient(n, dry_run=False) as rc:
                    if action == "delete":
                        results.append({"nas": n.name,
                                         **rc.delete_ip_pool(pool_dict["name"])})
                    else:
                        results.append({"nas": n.name,
                                         **rc.upsert_ip_pool(pool_dict)})
            except Exception as e:
                results.append({"nas": n.name, "status": "error",
                                 "message": str(e)})
        return results
    # _S39POOL_LIVE_SYNC end ----------------------------------------------

    def _plan_rows_for_queues(db, company_id):
        """Fetch Plan rows as plain dicts for the queue sync helper."""
        from database import Plan
        out = []
        for p in db.query(Plan).filter(Plan.company_id == company_id,
                                        Plan.service == "Broadband").all():
            out.append({
