    # --- Online Users live sync ---
    @app.post("/api/online-users/sync-from-nas")
    async def api_online_sync(request: Request, db: Session = Depends(get_db)):
        """_FAST_SYNC_FROM_NAS_V1_ : non-blocking sync.
        Returns CACHED counts immediately; spawns the standalone sync script
        (which talks to MikroTik directly via librouteros) in the background.
        Avoids tying up an admin uvicorn worker for 30-60 s per click."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        # Fire the standalone sync in the background. The lock file prevents
        # pile-up if another sync is already running (timer or another click).
        try:
            import subprocess as _sp_sync
            _sp_sync.Popen([
                "/opt/ispbilling/venv/bin/python3",
                "/opt/ispbilling/scripts/online_users_sync.py",
            ], stdout=_sp_sync.DEVNULL, stderr=_sp_sync.DEVNULL,
              start_new_session=True)
        except Exception as _e_sp:
            print(f"[sync-from-nas] spawn failed: {_e_sp}")
        # Return whatever is already in cache for this tenant so the UI has
        # something to show immediately.
        try:
            cnt = db.query(OnlineUser).filter(
                OnlineUser.company_id == company_id,
                OnlineUser.status == "Online").count()
        except Exception:
            cnt = 0
        return {"success": True, "synced": cnt, "marked_offline": 0,
                "per_nas": [], "background": True,
                "message": "Sync running in background — refresh in 2-3 s for fresh counts."}

    # ---- original blocking implementation kept below for reference / internal callers ----
    @app.post("/api/online-users/sync-from-nas-blocking")
    async def api_online_sync_blocking(request: Request, db: Session = Depends(get_db)):
        """Original synchronous implementation (~60 s).  Kept for internal
        loopback callers that need a guaranteed-fresh result.  Not called
        from the UI any more."""
        company_id = require_admin_or_internal(request)
        if not isinstance(company_id, str):
            return company_id
        nas_rows = db.query(NasDevice).filter(NasDevice.company_id == company_id,
                                               NasDevice.status == "Active").all()

        total_synced = 0
        per_nas = []
        seen_usernames = set()
        for nas in nas_rows:
            entry = {"nas_id": nas.id, "nas_name": nas.name, "ip": nas.ip_address,
                     "count": 0, "error": None}
            try:
                _router_ctx = rp.RouterOSClient(nas, dry_run=False)
                c = _router_ctx.__enter__()
                active = c.list_pppoe_active()
            except Exception as e:
                entry["error"] = str(e)
                per_nas.append(entry)
                try: _router_ctx.__exit__(None, None, None)
                except Exception: pass
                continue
            for row in active:
                username = (row.get("name") or "").strip()
                if not username:
                    continue
                addr = row.get("address") or ""
                caller_id = row.get("caller-id") or ""
                session_id = row.get(".id") or row.get("session-id") or ""
                uptime = row.get("uptime") or "0s"
                # Upsert by (company_id, username)
                ou = db.query(OnlineUser).filter(
                    OnlineUser.company_id == company_id,
                    OnlineUser.username == username).first()
                if not ou:
                    ou = OnlineUser(company_id=company_id, username=username,
                                    started_at=datetime.utcnow())
                    db.add(ou)
                ou.ip_address = addr
                ou.nas_ip = nas.ip_address
                ou.session_id = session_id
                ou.framed_protocol = "PPPoE"
                # s26.5: walled-garden-excluded (sync-from-nas variant)
                try:
                    from database import Customer as _CC
                    _cust = db.query(_CC).filter(
                        _CC.company_id == company_id,
                        _CC.username == username).first()
                    _status = ((_cust.status if _cust else "") or "").strip().lower()
                except Exception:
                    _status = "active"
                ou.status = "Online" if _status == "active" else "WalledGarden"
                ou.updated_at = datetime.utcnow()
                # Session 22 — MAC (caller-id) + NAS port (service) + bytes.
                ou.mac_address = caller_id
                ou.nas_port_id = row.get("service") or ou.nas_port_id or ""
                b_in = row.get("bytes-in") or row.get("rx-byte") or 0
                b_out = row.get("bytes-out") or row.get("tx-byte") or 0
                if (not b_in) and (not b_out):
                    try:
                        iface_name = "<pppoe-" + username + ">"
                        for i in c._api.path("interface"):
                            if i.get("name") == iface_name:
                                b_in  = int(i.get("rx-byte") or 0)
                                b_out = int(i.get("tx-byte") or 0)
                                break
                    except Exception:
                        pass
                try:
                    # bytes_in  = user UPLOAD   (rx-byte on pppoe iface)
                    # bytes_out = user DOWNLOAD (tx-byte on pppoe iface)
                    ou.bytes_in  = float(b_in)  / (1024.0 * 1024.0)  # MB
                    ou.bytes_out = float(b_out) / (1024.0 * 1024.0)
                except Exception:
                    pass
                # Parse uptime "1h2m3s" -> seconds roughly
                try:
                    import re as _re
                    secs = 0
                    for num, unit in _re.findall(r"(\d+)([dhms])", uptime):
                        secs += int(num) * {"d": 86400, "h": 3600, "m": 60, "s": 1}[unit]
                    ou.uptime_seconds = secs or ou.uptime_seconds or 0
                    # _LIVE_START_FROM_UPTIME_V1_ : refresh started_at from router uptime so
                    # Current Usage shows the TRUE session start, not the first
                    # time we ever observed this user online.
                    if (ou.uptime_seconds or 0) > 0:
                        from datetime import timedelta as _td_lup
                        ou.started_at = datetime.utcnow() - _td_lup(
                            seconds=int(ou.uptime_seconds))
                except Exception:
                    pass
                seen_usernames.add(username)
                entry["count"] += 1
                total_synced += 1

            # __hotspot_active_synced__ — also pull /ip/hotspot/active so
            # captive-portal-authenticated users appear in Online Users
            # alongside PPPoE sessions.
            try:
                hs_rows = c.list_hotspot_active()
            except Exception as _hse:
                hs_rows = []
                print(f"[warn] hotspot active fetch failed on NAS {nas.id}: {_hse}")
            for hrow in hs_rows:
                username = (hrow.get("user") or hrow.get("name") or "").strip()
                if not username:
                    continue
                addr = hrow.get("address") or ""
                mac = hrow.get("mac-address") or hrow.get("caller-id") or ""
                session_id = hrow.get(".id") or hrow.get("session-id") or ""
                uptime = hrow.get("uptime") or "0s"
                ou = db.query(OnlineUser).filter(
                    OnlineUser.company_id == company_id,
                    OnlineUser.username == username).first()
                if not ou:
                    ou = OnlineUser(company_id=company_id, username=username,
                                    started_at=datetime.utcnow())
                    db.add(ou)
                ou.ip_address = addr
                ou.nas_ip = nas.ip_address
                ou.session_id = session_id
                ou.framed_protocol = "Hotspot"
                try:
                    from database import Customer as _CC, HotspotVoucher as _HV
                    _cust = db.query(_CC).filter(
                        _CC.company_id == company_id,
                        _CC.username == username).first()
                    _status = ((_cust.status if _cust else "") or "").strip().lower()
                    # __voucher_online__ — username may be a voucher code, not
                    # a Customer.username. If RADIUS authed it, treat as Online.
                    if not _cust:
                        _v = db.query(_HV).filter(_HV.code == username).first()
                        if _v:
                            _status = "active"
                except Exception:
                    _status = "active"
                ou.status = "Online" if _status == "active" else "WalledGarden"
                ou.updated_at = datetime.utcnow()
                ou.mac_address = mac
                ou.nas_port_id = hrow.get("server") or ou.nas_port_id or ""
                b_in = hrow.get("bytes-in") or 0
                b_out = hrow.get("bytes-out") or 0
                try:
                    ou.bytes_in  = float(b_in)  / (1024.0 * 1024.0)
                    ou.bytes_out = float(b_out) / (1024.0 * 1024.0)
                except Exception:
                    pass
                try:
                    import re as _re
                    secs = 0
                    for num, unit in _re.findall(r"(\d+)([dhms])", uptime):
                        secs += int(num) * {"d": 86400, "h": 3600, "m": 60, "s": 1}[unit]
                    ou.uptime_seconds = secs or ou.uptime_seconds or 0
                    # _LIVE_START_FROM_UPTIME_V1_ : refresh started_at from router uptime so
                    # Current Usage shows the TRUE session start, not the first
                    # time we ever observed this user online.
                    if (ou.uptime_seconds or 0) > 0:
                        from datetime import timedelta as _td_lup
                        ou.started_at = datetime.utcnow() - _td_lup(
                            seconds=int(ou.uptime_seconds))
                except Exception:
                    pass
                seen_usernames.add(username)
                entry["count"] += 1
                total_synced += 1

            try: _router_ctx.__exit__(None, None, None)
            except Exception: pass
            per_nas.append(entry)

        # __S38T_STATIC_ONLINE__ — delegate to module-level helper
        try:
            _r = _sync_static_ip_online_for_company(db, company_id, nas_rows=nas_rows)
            total_synced += int(_r.get('synced') or 0)
            # v12 — also distribute static-IP online users into the per_nas
            # counts so the SuperAdmin NAS console shows them.  Match by nas_ip.
            _static_rows = db.query(OnlineUser).filter(
                    OnlineUser.company_id == company_id,
                    OnlineUser.framed_protocol == 'Static',
                    OnlineUser.status == 'Online').all()
            _entry_by_ip = {e.get('ip'): e for e in per_nas if e.get('ip')}
            for u in _static_rows:
                seen_usernames.add(u.username)
                _entry = _entry_by_ip.get(u.nas_ip)
                if _entry is not None:
                    _entry['count'] = int(_entry.get('count') or 0) + 1
                elif per_nas:
                    # Fallback — no exact match, put it on the first NAS row.
                    per_nas[0]['count'] = int(per_nas[0].get('count') or 0) + 1
        except Exception as _se:
            print(f'[warn] static-IP online sync (api) failed: {_se}')

        # Mark all company users not seen as Offline
        offline = db.query(OnlineUser).filter(
            OnlineUser.company_id == company_id,
            OnlineUser.status == "Online",
        ).all()
        for u in offline:
            if u.username not in seen_usernames:
                u.status = "Offline"
        db.commit()
        return {"success": True, "synced": total_synced,
                "marked_offline": sum(1 for u in offline if u.username not in seen_usernames),
                "per_nas": per_nas}

