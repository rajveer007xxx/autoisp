def setup_tables():
    """Create the 4 new tables if they do not exist. Idempotent.

    Also backfills seed markers for any company that already has rows in
    a module — so the seeder won't try to re-seed after an admin has
    deliberately cleared the dummy data."""
    Base.metadata.create_all(bind=engine, tables=[
        NasDevice.__table__,
        IpPool.__table__,
        OnlineUser.__table__,
        AccessRequestLog.__table__,
        PublicIpAddress.__table__,
        NetworkSeedMarker.__table__,
    ])

    # Backfill seed markers for existing data so we stop re-seeding.
    try:
        from sqlalchemy.orm import Session as _Session
        with _Session(bind=engine) as s:
            already = {(m.company_id, m.module) for m in s.query(NetworkSeedMarker).all()}
            backfill_pairs = set()
            for cid, in s.query(NasDevice.company_id).distinct().all():
                backfill_pairs.add((cid, "nas"))
            for cid, in s.query(IpPool.company_id).distinct().all():
                backfill_pairs.add((cid, "ippool"))
            for cid, in s.query(OnlineUser.company_id).distinct().all():
                backfill_pairs.add((cid, "online"))
            for cid, in s.query(AccessRequestLog.company_id).distinct().all():
                backfill_pairs.add((cid, "accesslog"))
            new_markers = [NetworkSeedMarker(company_id=cid, module=mod)
                           for (cid, mod) in backfill_pairs if (cid, mod) not in already]
            if new_markers:
                s.add_all(new_markers)
                s.commit()
                print(f"✓ Backfilled {len(new_markers)} seed markers (existing data preserved)")
    except Exception as _e:
        print(f"seed marker backfill skipped: {_e}")


def _seed_marker_exists(db: Session, company_id: str, module: str) -> bool:
    return db.query(NetworkSeedMarker).filter(
        NetworkSeedMarker.company_id == company_id,
        NetworkSeedMarker.module == module,
    ).first() is not None


def _mark_seeded(db: Session, company_id: str, module: str):
    db.add(NetworkSeedMarker(company_id=company_id, module=module))


def _seed_company(db: Session, company_id: str):
    """Seed mock data once per (company_id, module). Idempotent across restarts
    because completion is tracked in `network_seed_markers`, so deleting all
    rows will NOT trigger a re-seed."""
    if not company_id or company_id == "N/A":
        return

    # NAS Devices — NO auto-seeded mock data. Each admin explicitly adds
    # their own NAS device(s) so there's no "testing123" drift, no
    # unreachable 10.0.0.x placeholders polluting FreeRADIUS clients.conf,
    # and no confusion about which row points at a real router. At SaaS
    # scale this matters: 1 ghost NAS × 500 admins = 500 broken
    # clients.conf entries.
    if not _seed_marker_exists(db, company_id, "nas"):
        _mark_seeded(db, company_id, "nas")
        db.commit()

    # IP Pools — Session 39H: seed 4 baseline pools (one per role) for new
    # companies so the admin's NAS Configure modal shows a usable IP-Pools &
    # Interface Bindings section out of the box. Skipped if the company
    # already has any pools (prevents stomping on custom pools created by
    # admins of older tenants). Ranges deliberately avoid 192.168.x to
    # reduce LAN-collision risk and the parking pool matches what
    # FreeRADIUS hands out as Framed-Pool for parked customers.
    if not _seed_marker_exists(db, company_id, "ippool"):
        # _S39POOL_SKIP_SEED_WHEN_LIVE — prefer live pull from router.
        try:
            _live_nas = (db.query(NasDevice)
                           .filter(NasDevice.company_id == company_id,
                                   NasDevice.status == "Active").first())
            if _live_nas and _live_nas.api_password and _live_nas.ip_address:
                _live_res = pull_pools_from_router(db, company_id)
                if _live_res.get("ok") and _live_res.get("created", 0) > 0:
                    _mark_seeded(db, company_id, "ippool"); db.commit()
                    return
        except Exception:
            pass
        existing = (db.query(IpPool)
                      .filter(IpPool.company_id == company_id)
                      .count())
        if existing == 0:
            _defaults = [
                # (name, role, network, start_ip, end_ip, gateway, dns)
                ("pppoe-pool",     "PPPoE",   "10.10.20.0/24",
                  "10.10.20.10",  "10.10.20.250",  "10.10.20.1",
                  "8.8.8.8,1.1.1.1"),
                ("static-ip-pool", "Static",  "10.10.30.0/24",
                  "10.10.30.10",  "10.10.30.250",  "10.10.30.1",
                  "8.8.8.8,1.1.1.1"),
                ("hotspot-pool",   "Hotspot", "10.10.40.0/23",
                  "10.10.40.10",  "10.10.41.254",  "10.10.40.1",
                  "8.8.8.8,1.1.1.1"),
                # Parking pool MUST match auto_configure() default + the
                # Framed-Pool name FreeRADIUS sends for parked customers,
                # otherwise expired users get an unreachable IP.
                ("parking-pool",   "Parking", "10.255.0.0/16",
                  "10.255.0.10",  "10.255.255.254","10.255.0.1",
                  "8.8.8.8,1.1.1.1"),
            ]
            for nm, role, net, sip, eip, gw, dns in _defaults:
                db.add(IpPool(
                    company_id=company_id, name=nm, role=role,
                    network=net, start_ip=sip, end_ip=eip, gateway=gw,
                    dns_servers=dns, status="Active",
                    comment="auto-seeded default",
                ))
        _mark_seeded(db, company_id, "ippool")
        db.commit()

    # Online Users
    if not _seed_marker_exists(db, company_id, "online"):
        if db.query(OnlineUser).filter(OnlineUser.company_id == company_id).count() == 0:
            samples = [
                ("user001", "192.168.10.45", "10.0.0.1", 3600, 450.3, 1200.7),
                ("user002", "192.168.10.52", "10.0.0.1", 7200, 820.1, 2100.5),
                ("user003", "192.168.20.31", "10.0.0.2", 1800, 210.4, 540.2),
                ("user004", "192.168.20.88", "10.0.0.2", 14400, 1600.0, 4800.0),
                ("user005", "10.10.10.23", "10.0.0.1", 600, 80.5, 220.3),
            ]
            now = datetime.utcnow()
            rows = []
            for i, (u, ip, nas, up, bin_, bout) in enumerate(samples):
                rows.append(OnlineUser(
                    company_id=company_id,
                    username=u,
                    ip_address=ip,
                    nas_ip=nas,
                    session_id=f"SES{100000+i}",
                    framed_protocol="PPPoE",
                    started_at=now - timedelta(seconds=up),
                    uptime_seconds=up,
                    bytes_in=bin_,
                    bytes_out=bout,
                    status="Online",
                ))
            db.add_all(rows)
        _mark_seeded(db, company_id, "online")
        db.commit()

    # Access Request Logs
    if not _seed_marker_exists(db, company_id, "accesslog"):
        if db.query(AccessRequestLog).filter(AccessRequestLog.company_id == company_id).count() == 0:
            now = datetime.utcnow()
            statuses = [("Accept", ""), ("Accept", ""), ("Reject", "Invalid password"),
                        ("Accept", ""), ("Reject", "User not found"), ("Accept", "")]
            rows = []
            for i in range(12):
                st, reason = statuses[i % len(statuses)]
                rows.append(AccessRequestLog(
                    company_id=company_id,
                    username=f"user{(i % 5) + 1:03d}",
                    nas_ip=random.choice(["10.0.0.1", "10.0.0.2"]),
                    request_type="Auth" if i % 2 == 0 else "Accounting",
                    status=st,
                    reason=reason,
                    ip_address=f"192.168.{random.randint(10,20)}.{random.randint(2,250)}",
                    created_at=now - timedelta(minutes=i * 7),
                ))
            db.add_all(rows)
        _mark_seeded(db, company_id, "accesslog")
        db.commit()


def _ensure_seeded(db: Session, company_id: str):
    """Wrapper kept cheap on subsequent calls."""
    try:
        _seed_company(db, company_id)
    except Exception:
        db.rollback()


