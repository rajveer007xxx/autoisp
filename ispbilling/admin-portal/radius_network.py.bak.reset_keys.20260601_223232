        try:
            body = await request.json()
        except Exception:
            pass
        # Auto-resolve pool + gateway from the NAS's linked pool if not given.
        pool_name = (body.get("pool_name") or nas.pppoe_pool_name or "").strip()
        gateway = (body.get("gateway") or "").strip()

        # Prefer the LIVE router pool (so gateway is on the same subnet as
        # the IPs actually being handed out — avoids the classic
        # "local-address on 192.168.10.x but pool hands out 192.168.20.x"
        # routing bug that still shows "logged in 0.0.0.0" symptoms).
        if not gateway:
            try:
                live = rp.list_router_ip_pools(nas) or {}
                for p in (live.get("pools") or []):
                    if pool_name and p.get("name") != pool_name:
                        continue
                    ranges = (p.get("ranges") or "").split(",")[0].strip()
                    first_ip = ranges.split("-")[0].strip() if ranges else ""
                    if first_ip and first_ip.count(".") == 3:
                        octets = first_ip.split(".")
                        octets[3] = "1"           # assume /24 gateway = x.x.x.1
                        gateway = ".".join(octets)
                        if not pool_name:
                            pool_name = p.get("name")
                        break
            except Exception:
                pass

        # Second choice: DB IpPool row matching the NAS's pool name.
        if not pool_name or not gateway:
            pool_row = None
            if nas.pppoe_pool_name:
                pool_row = db.query(IpPool).filter(
                    IpPool.company_id == company_id,
                    IpPool.name == nas.pppoe_pool_name).first()
            if not pool_row:
                pool_row = db.query(IpPool).filter(
                    IpPool.company_id == company_id,
                    IpPool.role == "PPPoE").first()
            if pool_row:
                pool_name = pool_name or pool_row.name
                gateway = gateway or (pool_row.gateway or "")
        pool_name = pool_name or "pppoe-pool"
        gateway = gateway or "192.168.100.1"
        dns_servers = (body.get("dns_servers") or "8.8.8.8,1.1.1.1").strip()
        profile_name = (body.get("profile_name") or "isp-default").strip()
        return rp.ensure_pppoe_default_profile(
            nas, gateway=gateway, pool_name=pool_name,
            dns_servers=dns_servers, profile_name=profile_name,
        )

