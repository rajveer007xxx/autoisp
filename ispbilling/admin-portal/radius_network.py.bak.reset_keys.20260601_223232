# _BUG12_BGTHREAD_
class _BUG12_Skip(Exception): pass

_bug12_thread_started = False
_bug12_lock = None

def _bug12_refresh_company(db, company_id: str):
    """Inline NAS+static-IP refresh — kept short, exception-safe."""
    try:
        _sync_static_ip_online_for_company(db, company_id)
    except Exception as e:
        print(f'[bug12-bg] {company_id} static-IP: {e}')
    try:
        from librouteros import connect as _rconnect
        from librouteros.login import plain as _rplain
    except Exception:
        return
    try:
        nas_rows = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == 'Active').all()
    except Exception:
        return
    for nas in nas_rows:
        try:
            api = _rconnect(host=nas.ip_address,
                            username=(nas.api_username or 'admin'),
                            password=(nas.api_password or ''),
                            port=int(nas.port or 8728),
                            login_method=_rplain, timeout=8)
        except Exception as e:
            print(f'[bug12-bg] {nas.ip_address} connect: {e}')
            continue
        try:
            for ou in db.query(OnlineUser).filter(
                    OnlineUser.company_id == company_id,
                    OnlineUser.nas_ip == nas.ip_address,
                    OnlineUser.status == 'Online').all():
                if (ou.bytes_in or 0) and (ou.bytes_out or 0):
                    continue
                try:
                    iface = '<pppoe-' + (ou.username or '') + '>'
                    for ifc in api.path('/interface'):
                        if ifc.get('name') == iface:
                            # === S41Y-POLL-IFC-MB ===
                            # online_users.bytes_in/out store MB (per the
                            # column comment + all other polling paths).
                            # The previous code stored raw BYTES here, so
                            # interface-counter-based polls 1M× over-reported
                            # in MB. Convert to MB on write.
                            ou.bytes_in  = float(ifc.get('rx-byte') or 0) / (1024.0 * 1024.0)
                            ou.bytes_out = float(ifc.get('tx-byte') or 0) / (1024.0 * 1024.0)
                            break
                except Exception:
                    pass
            db.commit()
        except Exception:
            db.rollback()
        try: api.close()
        except Exception: pass

def _bug12_refresh_loop():
    import time as _t, traceback
    from database import SessionLocal as _SL
    while True:
        try:
            db = _SL()
            try:
                cids = [r[0] for r in db.query(NasDevice.company_id)
                                       .filter(NasDevice.status == 'Active')
                                       .distinct().all()]
                for cid in cids:
                    if not cid: continue
                    try:
                        _bug12_refresh_company(db, cid)
                    except Exception as e:
                        print(f'[bug12-bg] {cid}: {e}')
            finally:
                db.close()
        except Exception:
            traceback.print_exc()
        _t.sleep(30)

def _bug12_start_thread_once():
    global _bug12_thread_started
    if _bug12_thread_started: return
    _bug12_thread_started = True
    import threading
    threading.Thread(target=_bug12_refresh_loop,
                      name='bug12-online-users-refresh',
                      daemon=True).start()
    print('[bug12-bg] background online-users refresher started')

# s26.16: live-speed-connection-pool
# Small per-process pool that keeps RouterOS API sessions alive between
# successive /api/online-users/.../live-speed polls so the router's log
# stops filling with login/logout pairs every 2 seconds.
# Key: nas.id  -> (last_used_ts, RouterOSClient)
# Idle entries > _LIVE_SPEED_POOL_TTL are closed on the next call.
import threading as _s26_threading, time as _s26_time
_s26_live_pool = {}
_s26_live_pool_lock = _s26_threading.Lock()
_LIVE_SPEED_POOL_TTL = 60.0

def _s26_live_get_or_open(nas):
    """Return an already-open RouterOSClient for nas.id, or open+cache one."""
    now = _s26_time.time()
    with _s26_live_pool_lock:
        # Evict stale entries
        for k in list(_s26_live_pool.keys()):
            ts, _cli = _s26_live_pool[k]
            if now - ts > _LIVE_SPEED_POOL_TTL:
                try: _cli.__exit__(None, None, None)
                except Exception: pass
                _s26_live_pool.pop(k, None)
        entry = _s26_live_pool.get(nas.id)
        if entry:
            _, cli = entry
            _s26_live_pool[nas.id] = (now, cli)
            return cli
    # Open new OUTSIDE the lock (the underlying TCP handshake is slow
    # and we don't want to serialise concurrent admins viewing different
    # NAS devices).
    cli = rp.RouterOSClient(nas, dry_run=False).__enter__()
    with _s26_live_pool_lock:
        # Race-guard: another thread may have just opened one
        existing = _s26_live_pool.get(nas.id)
        if existing:
            try: cli.__exit__(None, None, None)
            except Exception: pass
            _s26_live_pool[nas.id] = (_s26_time.time(), existing[1])
            return existing[1]
        _s26_live_pool[nas.id] = (_s26_time.time(), cli)
    return cli

def _s26_live_drop(nas_id, cli):
    """Evict a client from the pool after an error so the next call reconnects."""
    with _s26_live_pool_lock:
        e = _s26_live_pool.get(nas_id)
        if e and e[1] is cli:
            try: cli.__exit__(None, None, None)
            except Exception: pass
            _s26_live_pool.pop(nas_id, None)


