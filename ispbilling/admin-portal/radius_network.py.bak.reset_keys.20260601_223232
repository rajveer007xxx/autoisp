        auth_check = require_auth(request)
        if auth_check:
            return auth_check
        company_id = request.session.get("company_id")
        row = db.query(IpPool).filter(IpPool.id == row_id,
                                       IpPool.company_id == company_id).first()
        if not row:
            return JSONResponse({"success": False, "message": "Not found"}, status_code=404)
        data = await request.json()
        if "network" in data and data["network"]:
            try:
                ipaddress.ip_network(data["network"], strict=False)
            except ValueError:
                return JSONResponse({"success": False, "message": "Invalid network CIDR"}, status_code=400)
        for k in ("name", "network", "gateway", "start_ip", "end_ip", "status",
                  "role", "dns_servers", "comment"):
            if k in data:
                setattr(row, k, data[k])
        # s26.12: next-pool-overflow
        if "next_pool_id" in data:
            v = data["next_pool_id"]
            try: row.next_pool_id = int(v) if v not in (None, "", "null") else None
            except (TypeError, ValueError): row.next_pool_id = None
        # If admin renamed the pool, we need to remember the OLD name so we
        # can also delete it on the router (RouterOS keys by name).
        old_name = data.get("__original_name") or row.name
        db.commit()
        # _S39POOL_LIVE_SYNC: push to all Active NAS routers
        push_log = []
        try:
            np_name = ""
            if row.next_pool_id:
                np_row = db.query(IpPool).filter(IpPool.id == row.next_pool_id).first()
                if np_row: np_name = np_row.name
            if old_name and old_name != row.name:
                # rename: remove old, then upsert new
                push_log += _push_pool_to_all_nas(db, company_id,
                    {"name": old_name}, action="delete")
            push_log += _push_pool_to_all_nas(db, company_id, {
                "name": row.name, "ranges": (
                    f"{row.start_ip}-{row.end_ip}" if (row.start_ip and row.end_ip)
                    else (row.network or "")
                ),
                "start_ip": row.start_ip, "end_ip": row.end_ip,
                "network": row.network, "next_pool": np_name,
            }, action="upsert")
        except Exception as _e:
            push_log = [{"status": "error", "message": str(_e)}]
        return {"success": True, "router_push": push_log}

