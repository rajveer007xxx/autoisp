            )
            db.add(row)
            db.commit()
            db.refresh(row)
            # Auto-push the new NAS to FreeRADIUS + router so admin does
            # NOT have to remember Sync-Secret / Sync-All-FreeRADIUS
            # after every Add. This is THE feature that keeps SaaS tenants
            # with 100s of NAS devices from accruing secret-drift bugs.
            auto_sync = _auto_sync_after_nas_save(db, company_id, row)
            _log_nas_audit(request, company_id, row, "create",
                             summary_extra=f"ip={row.ip_address}")
            # __s56f_admin_cloud_tunnel__ : provision WG tunnel inline if asked.
            cloud_tunnel = None
            if cm == "wireguard":
                try:
                    import sys as _sys
                    _SA_ROUTES = "/opt/ispbilling/superadmin-portal/routes"
                    if _SA_ROUTES not in _sys.path:
                        _sys.path.insert(0, _SA_ROUTES)
                    import sa_wg_tunnel as _wg
                    cloud_tunnel = _wg.provision_peer_for_nas(row.id, company_id)
                    # Use the assigned tunnel IP as the NAS's effective address.
                    new_ip = (cloud_tunnel.get("tunnel_ip") or "").strip()
                    if new_ip:
                        row.ip_address = new_ip
                        db.commit()
                except Exception as _wge:
                    # Don't fail the NAS creation if WG provision hits an
