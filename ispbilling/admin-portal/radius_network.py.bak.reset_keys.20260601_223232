    @app.post("/api/ip-pools/seed-defaults")
    async def api_pool_seed_defaults(request: Request, db: Session = Depends(get_db)):
        """Bulk-create IP pools (idempotent — skips by name).
        Body: {"pools": [{name, role, network, gateway, start_ip, end_ip, dns_servers}, ...]}
        """
        auth_check = require_auth(request)
        if auth_check:
            return auth_check
        company_id = request.session.get("company_id")
        body = await request.json() if request.headers.get("content-type", "").startswith("application/json") else {}
        seeds = body.get("pools") or []
        if not isinstance(seeds, list) or not seeds:
            return JSONResponse({"ok": False, "error": "pools list required"}, status_code=400)
        # Whitelist of column-safe names — never trust the client blindly.
        existing = {(r[0] or "").strip().lower()
                    for r in db.execute(_sa_text(
                        "SELECT name FROM ip_pools WHERE company_id=:c"),
                        {"c": company_id}).fetchall()}
        created = 0
        skipped = 0
        errors = []
        for s in seeds:
            name = (s.get("name") or "").strip()
            network = (s.get("network") or "").strip()
            if not name or not network:
                errors.append(f"missing name/network: {s}")
                continue
            if name.lower() in existing:
                skipped += 1
                continue
            try:
                ipaddress.ip_network(network, strict=False)
            except ValueError:
                errors.append(f"bad CIDR: {name}={network}")
                continue
            try:
                row = IpPool(
                    company_id=company_id, name=name, network=network,
                    gateway=(s.get("gateway") or "").strip(),
                    start_ip=(s.get("start_ip") or "").strip(),
                    end_ip=(s.get("end_ip") or "").strip(),
                    status="Active",
                    role=(s.get("role") or "PPPoE").strip(),
                    dns_servers=(s.get("dns_servers") or "8.8.8.8,1.1.1.1").strip(),
                    comment="auto-seeded default",
                )
                db.add(row)
                created += 1
                existing.add(name.lower())
            except Exception as e:
                errors.append(f"{name}: {e}")
        try:
            db.commit()
        except Exception as e:
            db.rollback()
            return JSONResponse({"ok": False, "error": f"commit failed: {e}"}, status_code=500)
        return {"ok": True, "created": created, "skipped": skipped, "errors": errors}

