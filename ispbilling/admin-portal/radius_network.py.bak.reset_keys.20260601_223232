    async def api_online_live_speed(username: str, request: Request, db: Session = Depends(get_db)):
        """Session 23 - return current byte counters for a PPPoE user so the UI can
        derive bps from the delta between two consecutive polls (2s interval).
        Reads /ppp/active on the user's NAS (resolved from online_users row OR
        nas_id query param).

        __S38T_LIVESPEED_ROLES__: accept admin / sub_lco / employee sessions.
        Tenant scoping comes from session.company_id; sub-LCOs additionally
        get auto-scoped by SQLAlchemy event listeners so they cannot probe
        usernames belonging to other Sub-LCOs of the same tenant.
        """
        # Internal-token path retains its own contract (used by SuperAdmin).
        tok = request.headers.get("X-Internal-Token") or request.headers.get("x-internal-token")
        if tok:
            company_id = require_admin_or_internal(request)
            if not isinstance(company_id, str):
                return company_id
        else:
            if "user_id" not in request.session:
                return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
            ut = request.session.get("user_type")
            if ut not in ("admin", "sub_lco", "employee"):
                return JSONResponse({"success": False, "message": "Forbidden"}, status_code=403)
            company_id = request.session.get("company_id") or ""
            if not company_id:
                return JSONResponse({"success": False, "message": "No company context"}, status_code=400)
            # Sub-LCO scope ctxvar so any ORM query inside is auto-filtered.
            if ut == "sub_lco":
                try:
                    import sub_lco as _slmod
                    sid = request.session.get("sub_lco_db_id")
                    if sid:
                        _slmod._SUB_LCO_CTX.set(int(sid))
                    # Hard guard — make sure the username belongs to this Sub-LCO.
                    from sqlalchemy import text as _t
                    own = db.execute(_t(
                        "SELECT 1 FROM customers WHERE company_id=:c "
                        "AND username=:u AND sub_lco_id=:s LIMIT 1"
                    ), {"c": company_id, "u": username, "s": int(sid or 0)}).fetchone()
                    if not own:
                        return JSONResponse(
                            {"success": False, "message": "Not your customer."},
                            status_code=403,
                        )
                except Exception as _e:
                    return JSONResponse(
                        {"success": False, "message": f"scope: {_e}"},
                        status_code=500,
                    )
        nas_id = request.query_params.get("nas_id")
        nas = None
        if nas_id and str(nas_id).isdigit() and int(nas_id) > 0:
            nas = _get_nas(db, company_id, int(nas_id))
        if not nas:
            ou = db.query(OnlineUser).filter(
                OnlineUser.company_id == company_id,
                OnlineUser.username == username).first()
            if ou and ou.nas_ip:
                nas = db.query(NasDevice).filter(
                    NasDevice.company_id == company_id,
                    NasDevice.ip_address == ou.nas_ip).first()
        if not nas:
            return JSONResponse({"success": False, "message": "NAS not found for user"},
                                status_code=404)
        # s26.16: live-speed-connection-pool — single pooled session;
        # do active-list AND interface-lookup from the SAME connection to
        # eliminate the login/logout flapping in /log info when admins
        # watch live-speed graphs.
        # __S38T_LIVESPEED_STATIC__ — static-IP customers have NO PPPoE
        # session, so we must read their byte counters from the matching
        # /queue/simple row instead of /ppp/active.
        from sqlalchemy import text as _t_ls
        is_static = False
        static_ip = ""
        try:
            crow = db.execute(_t_ls(
                "SELECT COALESCE(auth_type,'pppoe') AS at, "
                "       COALESCE(static_ip_address,'') AS sip "
                "  FROM customers WHERE company_id=:c AND username=:u LIMIT 1"
            ), {"c": company_id, "u": username}).fetchone()
            if crow and (crow[0] or "").strip().lower() in ("static_ip","static-ip","static"):
                is_static = True
                static_ip = (crow[1] or "").strip()
        except Exception:
            pass

        cli = None
        try:
            cli = _s26_live_get_or_open(nas)
            bi, bo = 0, 0
            if is_static and static_ip:
                # Read cumulative bytes (and instantaneous rate) from the
                # static-<username> queue. format: "<rx-bytes>/<tx-bytes>"
                # rate is also "<rx>/<tx>" in bps.
                tgt = f"{static_ip}/32"
                qrow = next((q for q in cli._api.path("queue/simple")
                              if (q.get("target") or "") == tgt), None)
                if not qrow:
                    return JSONResponse(
                        {"success": False, "message": "no live queue for static IP"},
                        status_code=404)
                try:
                    raw_b = (qrow.get("bytes") or "0/0")
                    if "/" in raw_b:
                        bi_s, bo_s = raw_b.split("/", 1)
                        bi = int(bi_s or 0)
                        bo = int(bo_s or 0)
                except Exception:
                    pass
                # If router exposes instantaneous rate, return it directly so
                # the client can plot without needing a delta sample.
                rate_bps_in = rate_bps_out = None
                try:
                    raw_r = qrow.get("rate") or "0/0"
                    if "/" in raw_r:
                        rin, rout = raw_r.split("/", 1)
                        rate_bps_in  = int(rin  or 0)
                        rate_bps_out = int(rout or 0)
                except Exception:
                    pass
                from datetime import datetime as _dt_ls
                return {"success": True, "ts": _dt_ls.utcnow().isoformat(),
                        "username": username, "static": True, "ip": static_ip,
                        "bytes_in": bi, "bytes_out": bo,
                        "rate_bps_in": rate_bps_in, "rate_bps_out": rate_bps_out}
            # Default: PPPoE path (unchanged).
            active = cli.list_pppoe_active()
            row = next((r for r in active if (r.get("name") or "").strip() == username), None)
            if not row:
                return JSONResponse({"success": False, "message": "session not active"},
                                    status_code=404)
            try:
                iface_name = "<pppoe-" + username + ">"
                for i in cli._api.path("interface"):
                    if i.get("name") == iface_name:
                        bi = int(i.get("rx-byte") or 0)
                        bo = int(i.get("tx-byte") or 0)
                        break
            except Exception:
                pass
        except Exception as e:
            if cli is not None:
                _s26_live_drop(nas.id, cli)
            return JSONResponse({"success": False,
                "message": f"router unreachable: {e}"}, status_code=502)
        # Fallback to whatever /ppp/active reported (rare)
        if bi == 0 and bo == 0:
            try:
                bi = int(row.get("bytes-in") or row.get("rx-byte") or 0)
                bo = int(row.get("bytes-out") or row.get("tx-byte") or 0)
            except Exception:
                pass
        return {"success": True, "bytes_in": bi, "bytes_out": bo,
                "ts": datetime.utcnow().isoformat() + "Z",
                "ip": row.get("address", ""), "uptime": row.get("uptime", "")}

