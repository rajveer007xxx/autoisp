@router.post("/api/admin/iptv-profiles")
def create_iptv(body: IPTVProfileIn, request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        cur = con.execute(
            "INSERT INTO iptv_profiles (company_id, name, mcast_vlan, "
            "igmp_version, mcast_group, description) VALUES (?,?,?,?,?,?)",
            (sc["company_id"], body.name, body.mcast_vlan,
             body.igmp_version or 2, body.mcast_group, body.description))
    return {"ok": True, "id": cur.lastrowid}


@router.patch("/api/admin/iptv-profiles/{pid}")
def update_iptv(pid: int, body: IPTVProfileIn, request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        r = con.execute(
            "UPDATE iptv_profiles SET name=?, mcast_vlan=?, igmp_version=?, "
            "mcast_group=?, description=? WHERE id=? AND company_id=?",
            (body.name, body.mcast_vlan, body.igmp_version, body.mcast_group,
             body.description, pid, sc["company_id"]))
        if r.rowcount == 0:
            raise HTTPException(404, "IPTV profile not found")
    return {"ok": True, "id": pid}


@router.delete("/api/admin/iptv-profiles/{pid}")
def delete_iptv(pid: int, request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.execute("DELETE FROM onu_iptv_assignments WHERE profile_id=? AND company_id=?",
                    (pid, sc["company_id"]))
        r = con.execute(
            "DELETE FROM iptv_profiles WHERE id=? AND company_id=?",
            (pid, sc["company_id"]))
        if r.rowcount == 0:
            raise HTTPException(404, "IPTV profile not found")
    return {"ok": True, "deleted": pid}


@router.post("/api/admin/onus/{onu_id}/iptv/{profile_id}/attach")
def attach_iptv(onu_id: int, profile_id: int, request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.row_factory = sqlite3.Row
        _own_onu(con, sc["company_id"], onu_id)
        p = con.execute(
            "SELECT * FROM iptv_profiles WHERE id=? AND company_id=?",
            (profile_id, sc["company_id"])).fetchone()
        if not p:
            raise HTTPException(404, "IPTV profile not found")
        try:
            con.execute("INSERT INTO onu_iptv_assignments (company_id, onu_id, profile_id) "
                        "VALUES (?,?,?)", (sc["company_id"], onu_id, profile_id))
        except sqlite3.IntegrityError:
            pass  # idempotent
        prof = dict(p)
    return _push_iptv_to_onu(onu_id, prof)


@router.post("/api/admin/onus/{onu_id}/iptv/{profile_id}/detach")
def detach_iptv(onu_id: int, profile_id: int, request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.execute(
            "DELETE FROM onu_iptv_assignments WHERE onu_id=? AND profile_id=? AND company_id=?",
            (onu_id, profile_id, sc["company_id"]))
        # Clear the queued IPTV block from notes.
        row = con.execute("SELECT notes FROM onus WHERE id=? AND company_id=?",
                          (onu_id, sc["company_id"])).fetchone()
        if row and row[0]:
            try:
                cur = json.loads(row[0]) if row[0] else {}
                if isinstance(cur, dict) and "triple_play" in cur:
                    cur["triple_play"].pop("iptv", None)
                    con.execute("UPDATE onus SET notes=? WHERE id=?",
                                (json.dumps(cur), onu_id))
            except Exception:
                pass
    return {"ok": True}


