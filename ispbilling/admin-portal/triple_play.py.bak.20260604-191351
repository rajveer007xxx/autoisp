        con.row_factory = sqlite3.Row
        _own_onu(con, sc["company_id"], onu_id)
        p = con.execute(
            "SELECT * FROM voip_profiles WHERE id=? AND company_id=?",
            (profile_id, sc["company_id"])).fetchone()
        if not p:
            raise HTTPException(404, "VoIP profile not found")
        try:
            con.execute(
                "INSERT INTO onu_voip_assignments (company_id, onu_id, profile_id, "
                "sip_username, sip_password) VALUES (?,?,?,?,?)",
                (sc["company_id"], onu_id, profile_id, body.sip_username, body.sip_password))
        except sqlite3.IntegrityError:
            con.execute(
                "UPDATE onu_voip_assignments SET sip_username=?, sip_password=? "
                "WHERE onu_id=? AND profile_id=? AND company_id=?",
                (body.sip_username, body.sip_password, onu_id, profile_id, sc["company_id"]))
        prof = dict(p)
    return _push_voip_to_onu(onu_id, prof,
                              {"sip_username": body.sip_username, "sip_password": body.sip_password})


