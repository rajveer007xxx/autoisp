from olt_routes import _require_scope, _require_admin  # type: ignore

DB_PATH = "/var/lib/autoispbilling/autoispbilling.db"
router = APIRouter()


def _ensure_schema() -> None:
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.executescript("""
        CREATE TABLE IF NOT EXISTS iptv_profiles (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id  TEXT NOT NULL,
            name        TEXT NOT NULL,
            mcast_vlan  INTEGER NOT NULL,
            igmp_version INTEGER DEFAULT 2,        -- 2 or 3
            mcast_group TEXT,                       -- e.g. 239.10.0.0/16
            description TEXT,
            created_at  TEXT DEFAULT (datetime('now')),
            UNIQUE(company_id, name)
        );

        CREATE TABLE IF NOT EXISTS voip_profiles (
            id           INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id   TEXT NOT NULL,
            name         TEXT NOT NULL,
            sip_server   TEXT NOT NULL,
            sip_port     INTEGER DEFAULT 5060,
            sip_proxy    TEXT,
            transport    TEXT DEFAULT 'UDP',       -- UDP|TCP|TLS
            codec        TEXT DEFAULT 'G.711a',
            description  TEXT,
            created_at   TEXT DEFAULT (datetime('now')),
            UNIQUE(company_id, name)
        );

        CREATE TABLE IF NOT EXISTS onu_iptv_assignments (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id  TEXT NOT NULL,
            onu_id      INTEGER NOT NULL,
            profile_id  INTEGER NOT NULL,
            attached_at TEXT DEFAULT (datetime('now')),
            UNIQUE(onu_id, profile_id)
        );

        CREATE TABLE IF NOT EXISTS onu_voip_assignments (
            id           INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id   TEXT NOT NULL,
            onu_id       INTEGER NOT NULL,
            profile_id   INTEGER NOT NULL,
            sip_username TEXT,
            sip_password TEXT,
            attached_at  TEXT DEFAULT (datetime('now')),
            UNIQUE(onu_id, profile_id)
        );

        CREATE TABLE IF NOT EXISTS api_keys (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id  TEXT NOT NULL,
            label       TEXT,
            key_hash    TEXT NOT NULL UNIQUE,      -- sha256 of key
            scopes      TEXT DEFAULT 'read',       -- comma-separated: read,write,onu_reboot
            enabled     INTEGER DEFAULT 1,
            created_by  TEXT,
            created_at  TEXT DEFAULT (datetime('now')),
            last_used   TEXT
        );
        CREATE INDEX IF NOT EXISTS idx_api_keys_company ON api_keys(company_id);
        """)
_ensure_schema()


# ─── Pydantic schemas ───────────────────────────────────────────────────
class IPTVProfileIn(BaseModel):
    name: str = Field(..., min_length=1, max_length=80)
    mcast_vlan: int = Field(..., ge=1, le=4094)
    igmp_version: Optional[int] = 2
    mcast_group: Optional[str] = None
    description: Optional[str] = None


class VoIPProfileIn(BaseModel):
    name: str = Field(..., min_length=1, max_length=80)
    sip_server: str = Field(..., min_length=1, max_length=200)
    sip_port: Optional[int] = 5060
    sip_proxy: Optional[str] = None
    transport: Optional[str] = "UDP"
    codec: Optional[str] = "G.711a"
    description: Optional[str] = None


class VoIPAttachIn(BaseModel):
    sip_username: str
    sip_password: str


# ─── Helpers ────────────────────────────────────────────────────────────
def _own_onu(con, cid: str, onu_id: int) -> dict:
    r = con.execute(
        "SELECT id, olt_id FROM onus WHERE id=? AND company_id=?",
        (onu_id, cid)).fetchone()
    if not r:
        raise HTTPException(404, "ONU not found")
    return {"id": r[0], "olt_id": r[1]}


def _push_iptv_to_onu(onu_id: int, profile: dict) -> dict:
    """Hook into the existing OMCI / Telnet provisioning. We avoid
    direct CLI here (each vendor differs) and instead annotate the ONU
    row so the existing ZTP/OMCI worker (in olt_telnet_actions.py)
    picks it up on next provisioning cycle. This is the same pattern the
    existing WiFi/WAN provisioning uses.
    """
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        # Store as a small JSON blob in onus.notes (preserves existing).
        row = con.execute("SELECT notes FROM onus WHERE id=?", (onu_id,)).fetchone()
        try:
            cur = json.loads(row[0]) if row and row[0] else {}
            if not isinstance(cur, dict): cur = {}
        except Exception:
            cur = {}
        cur.setdefault("triple_play", {})["iptv"] = profile
        con.execute("UPDATE onus SET notes=? WHERE id=?",
                    (json.dumps(cur), onu_id))
    return {"ok": True, "queued_for_provisioning": True}


def _push_voip_to_onu(onu_id: int, profile: dict, creds: dict) -> dict:
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        row = con.execute("SELECT notes FROM onus WHERE id=?", (onu_id,)).fetchone()
        try:
            cur = json.loads(row[0]) if row and row[0] else {}
            if not isinstance(cur, dict): cur = {}
        except Exception:
            cur = {}
        cur.setdefault("triple_play", {})["voip"] = {**profile, **creds}
        con.execute("UPDATE onus SET notes=? WHERE id=?",
                    (json.dumps(cur), onu_id))
    return {"ok": True, "queued_for_provisioning": True}


