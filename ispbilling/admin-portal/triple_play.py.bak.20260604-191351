import hashlib

def _hash_key(k: str) -> str:
    return hashlib.sha256(k.encode("utf-8")).hexdigest()


class ApiKeyIn(BaseModel):
    label: Optional[str] = "default"
    scopes: Optional[str] = "read"


@router.get("/api/admin/api-keys")
def list_api_keys(request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.row_factory = sqlite3.Row
        rows = con.execute(
            "SELECT id, label, scopes, enabled, created_by, created_at, last_used "
            "FROM api_keys WHERE company_id=? ORDER BY id DESC",
            (sc["company_id"],)).fetchall()
    return {"ok": True, "keys": [dict(r) for r in rows]}


@router.post("/api/admin/api-keys")
def create_api_key(body: ApiKeyIn, request: Request):
    sc = _require_scope(request)
    raw = "isp_" + secrets.token_urlsafe(28)
    h = _hash_key(raw)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.execute(
            "INSERT INTO api_keys (company_id, label, key_hash, scopes, created_by) "
            "VALUES (?,?,?,?,?)",
            (sc["company_id"], body.label or "default", h,
             body.scopes or "read", sc["actor"]))
    # Only returned ONCE — never stored in plain text.
    return {"ok": True, "api_key": raw,
            "warning": "Save this now. It will never be shown again."}


@router.delete("/api/admin/api-keys/{kid}")
def delete_api_key(kid: int, request: Request):
    sc = _require_scope(request)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        r = con.execute("DELETE FROM api_keys WHERE id=? AND company_id=?",
                        (kid, sc["company_id"]))
        if r.rowcount == 0:
            raise HTTPException(404, "API key not found")
    return {"ok": True, "deleted": kid}


def _auth_api_key(x_api_key: Optional[str], required_scope: str = "read") -> dict:
    if not x_api_key:
        raise HTTPException(401, "X-API-Key header required")
    h = _hash_key(x_api_key)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.row_factory = sqlite3.Row
        row = con.execute(
            "SELECT * FROM api_keys WHERE key_hash=? AND enabled=1", (h,)).fetchone()
        if not row:
            raise HTTPException(401, "Invalid API key")
        scopes = (row["scopes"] or "").split(",")
        if required_scope not in scopes and "write" not in scopes:
            raise HTTPException(403, f"API key lacks scope: {required_scope}")
        from datetime import datetime, timezone
        con.execute("UPDATE api_keys SET last_used=? WHERE id=?",
                    (datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"), row["id"]))
    return {"company_id": row["company_id"], "scopes": scopes}


@router.get("/api/v1/onus")
def public_list_onus(request: Request, x_api_key: Optional[str] = Header(None)):
    ctx = _auth_api_key(x_api_key, "read")
    olt_id = request.query_params.get("olt_id")
    try: limit = max(1, min(500, int(request.query_params.get("limit") or 200)))
    except Exception: limit = 200
    sql = ("SELECT id, olt_id, pon_port_index, onu_index, serial, status, "
           "rx_power, tx_power, customer_id, last_seen FROM onus WHERE company_id=?")
    params: List[Any] = [ctx["company_id"]]
    if olt_id:
        sql += " AND olt_id=?"; params.append(int(olt_id))
    sql += " ORDER BY id DESC LIMIT ?"; params.append(limit)
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.row_factory = sqlite3.Row
        rows = con.execute(sql, params).fetchall()
    return {"ok": True, "onus": [dict(r) for r in rows]}


@router.get("/api/v1/onus/{onu_id}")
def public_get_onu(onu_id: int, x_api_key: Optional[str] = Header(None)):
    ctx = _auth_api_key(x_api_key, "read")
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.row_factory = sqlite3.Row
        row = con.execute(
            "SELECT * FROM onus WHERE id=? AND company_id=?",
            (onu_id, ctx["company_id"])).fetchone()
        if not row:
            raise HTTPException(404, "ONU not found")
        d = dict(row)
        d.pop("notes", None)  # internal
    return {"ok": True, "onu": d}


@router.get("/api/v1/customers/{customer_id}")
def public_get_customer(customer_id: str, x_api_key: Optional[str] = Header(None)):
    ctx = _auth_api_key(x_api_key, "read")
    with sqlite3.connect(DB_PATH, timeout=10) as con:
        con.row_factory = sqlite3.Row
        row = con.execute(
            "SELECT customer_id, full_name, status, mobile_number, plan_id, "
            "expiry_date FROM customers WHERE customer_id=? AND company_id=?",
            (customer_id, ctx["company_id"])).fetchone()
        if not row:
            raise HTTPException(404, "Customer not found")
    return {"ok": True, "customer": dict(row)}


