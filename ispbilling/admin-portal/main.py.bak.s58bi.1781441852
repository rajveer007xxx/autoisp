templates = Jinja2Templates(directory="templates")

# s36g-mfa-jinja-global — compute MFA state per-request and expose to all templates.
def _s36g_compute_mfa_state(request):
    try:
        from database import Company as _Com, Admin as _Adm, SessionLocal
        import datetime as _dts
        if not hasattr(request, "session"): return None
        cid = request.session.get("company_id"); aid = request.session.get("user_id")
        if not cid or not aid: return None
        _db = SessionLocal()
        try:
            _com = _db.query(_Com).filter(_Com.company_id == cid).first()
            _adm = _db.query(_Adm).filter(_Adm.admin_id == aid, _Adm.company_id == cid).first()
            st = {"required": False, "enabled": False, "overdue": False, "days_left": None, "deadline": ""}
            if _com and int(getattr(_com, "mfa_required_for_admins", 0) or 0):
                st["required"] = True
                st["enabled"] = bool(_adm and getattr(_adm, "totp_enabled", 0))
                dl = (_adm.mfa_deadline if _adm and _adm.mfa_deadline else "") or ""
                if dl and not st["enabled"]:
                    try:
                        d = _dts.datetime.fromisoformat(dl)
                        delta = (d - _dts.datetime.utcnow()).days
                        st["days_left"] = delta
                        st["deadline"] = d.strftime("%d-%m-%Y")
                        if delta < 0: st["overdue"] = True
                    except Exception: pass
            return st
        finally:
            _db.close()
    except Exception:
        return None

templates.env.globals["mfa_state_for"] = _s36g_compute_mfa_state
