# __S39F__ Employee Portal full parity (ride on admin templates) -----------
@app.get("/employee/online-users", response_class=HTMLResponse)
async def employee_online_users(request: Request, db: Session = Depends(get_db)):
    """__S39I__ Online Users for employee — scoped to customers in his
    assigned localities. Mirrors the Sub-LCO pattern."""
    auth_check = require_employee(request)
    if auth_check: return auth_check
    gate = _emp_require_perm(request, db, 'feat.user_management')
    if gate: return gate
    ctx = _emp_admin_context(request, db, "online_users")
    company_id = request.session.get("company_id")
    try:
        from sqlalchemy import text as _t_ou
        # Resolve assigned location names → upper-trimmed for the IN()
        from employee_scope import resolve_locations as _rl
        from database import Employee as _Emp_ou
        emp_id = ctx.get("employee_id") or 0
        # __S43ZA_EMP_ID_FALLBACK__ — if ctx didn't carry it, look up via employee_code
        if not emp_id:
            _emp_code = request.session.get("user_id") or ""
            _e_row = db.query(_Emp_ou.id).filter(
                _Emp_ou.employee_code == _emp_code,
                _Emp_ou.company_id == company_id).first()
            emp_id = int(_e_row[0]) if _e_row else 0
        loc_names = _rl(db, company_id, int(emp_id) if emp_id else 0)
        # __S40_EMP_ONLINE_SLCO__ also gate by employee.sub_lco_id so
        # downstream-owned customers in the same locality don't leak.
        if emp_id:
            _emp_row = db.query(_Emp_ou.sub_lco_id).filter(_Emp_ou.id == int(emp_id)).first()
        else:
            _emp_row = None
        _emp_slco = int(_emp_row[0]) if _emp_row and _emp_row[0] is not None else None
        if _emp_slco is None:
            _slc_clause = " AND c.sub_lco_id IS NULL"
        else:
            _slc_clause = f" AND c.sub_lco_id = {int(_emp_slco)}"
        if not loc_names:
            ctx["online_users"] = []
        else:
            quoted = ",".join("'" + n.replace("'", "''") + "'" for n in loc_names)
            from datetime import datetime as _dt_ou
            def _parse_dt(v):
                if not v: return None
                if hasattr(v, "isoformat"): return v
                try: return _dt_ou.fromisoformat(str(v).replace(" ", "T").split(".")[0])
                except Exception: return None
            rows = []
            for r in db.execute(_t_ou(f"""
                SELECT ou.username, ou.ip_address, ou.nas_ip, ou.session_id,
                       ou.framed_protocol, ou.started_at, ou.uptime_seconds,
                       ou.bytes_in, ou.bytes_out, ou.status, ou.updated_at,
                       ou.mac_address, ou.nas_port_id,
                       COALESCE(c.customer_name, ou.customer_name, '') AS customer_name,
                       c.customer_id AS customer_id,
                       c.id          AS customer_pk,
                       n.id          AS nas_id,
                       COALESCE(n.name, ou.nas_ip, '') AS nas_name
                  FROM online_users ou
                  LEFT JOIN customers c
                       ON c.username = ou.username
                      AND c.company_id = ou.company_id
                  LEFT JOIN nas_devices n
                       ON n.ip_address = ou.nas_ip
                      AND n.company_id = ou.company_id
                 WHERE ou.company_id = :cid
                   AND ou.status = 'Online'
                   AND COALESCE(c.status,'') NOT IN ('Expired','expired','Disabled','disabled','Deactivated','deactivated','Suspended','suspended','Parked','parked','Cancelled','cancelled','Canceled','canceled','Terminated','terminated','Deleted','deleted')
                   AND (
                       c.created_by_employee_id = {int(emp_id)} OR
                       ( UPPER(TRIM(c.locality)) IN ({quoted}) {_slc_clause} )
                   )
                   AND NOT EXISTS (
                       SELECT 1 FROM ip_pools p
                        WHERE p.company_id = ou.company_id
                          AND LOWER(COALESCE(p.role,'')) = 'parking'
                          AND ou.ip_address LIKE substr(p.network,1,instr(p.network,'/')-1) || '%'
                   )
              ORDER BY ou.framed_protocol, ou.started_at DESC
            """), {"cid": company_id}).mappings():
                d = dict(r)
                d["started_at"] = _parse_dt(d.get("started_at"))
                d["updated_at"] = _parse_dt(d.get("updated_at"))
                rows.append(d)
            import types as _types_ou
            ctx["online_users"] = [_types_ou.SimpleNamespace(**r) for r in rows]
    except Exception as _ex:
        import traceback
        print(f"[employee] online-users fetch failed: {_ex}\n{traceback.format_exc()}")
        ctx.setdefault("online_users", [])
    return templates.TemplateResponse("admin_online_users.html", ctx)


