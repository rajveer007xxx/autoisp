@app.get("/api/employee-locations")
async def get_all_employee_locations(request: Request, db: Session = Depends(get_db)):
    """Get all employee locations for GPS tracking map"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Employee
    
    _s39_sid = _s39emp_sub_lco_id(request)
    _s39_code_map = (_s39emp_code_map(db, company_id) if _s39_sid is None else {})
    try:
        _q = db.query(Employee).filter(
            Employee.company_id == company_id,
            Employee.status == 'Active',
            Employee.is_deleted == False
        )
        if _s39_sid is not None:
            _q = _q.filter(Employee.sub_lco_id == _s39_sid)
        employees = _q.all()
        
        locations = []
        for emp in employees:
            _nm = emp.employee_name or ""
            if _s39_sid is None and getattr(emp, "sub_lco_id", None):
                _slc = _s39_code_map.get(int(emp.sub_lco_id))
                if _slc:
                    _nm = f"{_nm} (Sub-LCO: {_slc})"
            locations.append({
                "id": emp.id,
                "employee_code": emp.employee_code,
                "employee_name": _nm,
                "mobile": emp.mobile,
                "status": emp.status,
                "last_latitude": emp.last_latitude,
                "last_longitude": emp.last_longitude,
                "last_seen_at": emp.last_seen_at.isoformat() if emp.last_seen_at else None
            })
        
        return {"success": True, "locations": locations}
    
    except Exception as e:
        return {"success": False, "message": str(e)}

