# ────────────────────────────────────────────────────────────────────
# _S58M_ONLINE_SYNC_LOOP_  Periodic radacct → online_users sync
#
# The standalone `/opt/ispbilling/scripts/online_users_sync.py` works
# fine but was never scheduled. We run it inside the admin process on a
# 60-second tick guarded by a PostgreSQL advisory lock so exactly one
# uvicorn worker actually performs the sync.
# ────────────────────────────────────────────────────────────────────
import threading as _th_online, time as _tm_online, subprocess as _sub_online, os as _os_online
def _online_sync_loop():
    import logging as _lg
    log = _lg.getLogger("online_sync")
    interval = int(_os_online.environ.get("ONLINE_SYNC_INTERVAL", "60"))
    try:
        from database import engine as _eng_os
        from sqlalchemy import text as _t_os
        h = _eng_os.connect()
        got = h.execute(_t_os("SELECT pg_try_advisory_lock(:k)"), {"k": 0x5A18A5C0}).scalar()
        if not got:
            log.info("[online-sync] another worker holds the lock — exit")
            try: h.close()
            except Exception: pass
            return
    except Exception as e:
        log.warning(f"[online-sync] lock acquire failed, running anyway: {e}")
    script = "/opt/ispbilling/scripts/online_users_sync.py"
    python = "/opt/ispbilling/venv/bin/python3"
    while True:
        try:
            r = _sub_online.run([python, script], capture_output=True, text=True, timeout=120)
            tail = (r.stdout or "").strip().splitlines()
            if tail:
                log.info(f"[online-sync] {tail[-1]}")
        except Exception as e:
            log.exception(f"[online-sync] error: {e}")
        _tm_online.sleep(interval)

_th_online.Thread(target=_online_sync_loop, daemon=True,
                  name="online-users-sync").start()
print("[main] online-users-sync thread started")

