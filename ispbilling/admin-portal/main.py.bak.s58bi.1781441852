@app.get("/api/admin/nas/export-full")
async def api_nas_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from radius_network import NasDevice
    items = db.query(NasDevice).filter(NasDevice.company_id == company_id).order_by(NasDevice.id).all()
    headers = ['ID','Name','IP Address','Secret','Type','Location','Status',
               'Auth Modes','API Username','API Password','API Port','Use TLS','Use SSH','SSH Port',
               'PPPoE Pool','PPPoE Service Name','PPPoE Interface','PPPoE VLAN',
               'Hotspot Interface','Hotspot DNS','Hotspot Pool',
               'Last Status','Last Status Msg','Provisioned At','Created At']
    rows = []
    for n in items:
        rows.append([
            n.id, n.name or '', n.ip_address or '', n.secret or '', n.type or '',
            n.location or '', n.status or '',
            _s30_v(n, 'auth_modes', default='pppoe'),
            n.api_username or '', n.api_password or '',
            n.port or 8728,
            'Yes' if n.use_tls else 'No', 'Yes' if n.use_ssh else 'No',
            n.ssh_port or 22,
            _s30_v(n, 'pppoe_pool_name'), _s30_v(n, 'pppoe_service_name'),
            _s30_v(n, 'pppoe_interface'), _s30_v(n, 'pppoe_vlan_id', default=0),
            _s30_v(n, 'hotspot_interface'), _s30_v(n, 'hotspot_dns_name'),
            _s30_v(n, 'hotspot_pool_name'),
            n.last_status or '', n.last_status_msg or '',
            n.provisioned_at.isoformat() if n.provisioned_at else '',
            n.created_at.isoformat() if n.created_at else '',
        ])
    return _s30_send(headers, rows, fmt, 'nas_devices')


# ---------- IP Pools ----------
@app.get("/api/admin/ip-pools/export-full")
async def api_ippools_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from radius_network import IpPool
    items = db.query(IpPool).filter(IpPool.company_id == company_id).order_by(IpPool.id).all()
    pool_map = {p.id: p.name for p in items}
    headers = ['ID','Name','Network','Gateway','Start IP','End IP','Role','Status',
               'DNS Servers','Next Pool','Comment','Created At']
    rows = []
    for p in items:
        rows.append([
            p.id, p.name or '', p.network or '', p.gateway or '',
            p.start_ip or '', p.end_ip or '',
            _s30_v(p, 'role', default='PPPoE'),
            p.status or '', p.dns_servers or '',
            pool_map.get(p.next_pool_id, '') if getattr(p, 'next_pool_id', None) else '',
            p.comment or '',
            p.created_at.isoformat() if p.created_at else '',
        ])
    return _s30_send(headers, rows, fmt, 'ip_pools')


# ---------- Online Users ----------
@app.get("/api/admin/online-users/export-full")
async def api_online_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from radius_network import OnlineUser
    items = db.query(OnlineUser).filter(OnlineUser.company_id == company_id).order_by(OnlineUser.id.desc()).all()
    headers = ['ID','Username','Customer Name','IP Address','NAS IP','Session ID',
               'Protocol','MAC Address','NAS Port','Bytes In (MB)','Bytes Out (MB)',
               'Uptime (sec)','Status','Started At','Updated At']
    rows = []
    for o in items:
        rows.append([
            o.id, o.username or '', o.customer_name or '', o.ip_address or '',
            o.nas_ip or '', o.session_id or '', o.framed_protocol or '',
            o.mac_address or '', o.nas_port_id or '',
            round(o.bytes_in or 0, 2), round(o.bytes_out or 0, 2),
            o.uptime_seconds or 0, o.status or '',
            o.started_at.isoformat() if o.started_at else '',
            o.updated_at.isoformat() if o.updated_at else '',
        ])
    return _s30_send(headers, rows, fmt, 'online_users')


# ---------- Access Request Logs ----------
@app.get("/api/admin/access-logs/export-full")
async def api_access_logs_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from radius_network import AccessRequestLog
    q = db.query(AccessRequestLog).filter(AccessRequestLog.company_id == company_id)
    q = q.order_by(AccessRequestLog.id.desc()).limit(50000)
    items = q.all()
    headers = ['ID','Username','NAS IP','Request Type','Status','Reason','Client IP','Created At']
    rows = []
    for a in items:
        rows.append([
            a.id, a.username or '', a.nas_ip or '', a.request_type or '',
            a.status or '', a.reason or '', a.ip_address or '',
            a.created_at.isoformat() if a.created_at else '',
        ])
    return _s30_send(headers, rows, fmt, 'access_logs')


# ---------- Employees ----------
@app.get("/api/admin/employees/export-full")
async def api_employees_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
