# __S38S_REPORTS__ -- Reports dispatch ----------------------------------
from datetime import datetime as _dt_rpt, timedelta as _td_rpt

def _rpt_date_range(period: str, from_date: str, to_date: str):
    """Return (start_dt, end_dt) inclusive of both bounds."""
    today = _dt_rpt.now()
    if period == "today":
        s = today.replace(hour=0, minute=0, second=0, microsecond=0)
        e = today
    elif period == "7d":
        s = (today - _td_rpt(days=7)).replace(hour=0, minute=0, second=0, microsecond=0)
        e = today
    elif period == "month":
        s = today.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
        e = today
    elif period == "custom":
        try:
            s = _dt_rpt.strptime(from_date.strip(), "%Y-%m-%d")
        except Exception:
            s = today - _td_rpt(days=30)
        try:
            e = _dt_rpt.strptime(to_date.strip(), "%Y-%m-%d").replace(hour=23, minute=59, second=59)
        except Exception:
            e = today
    else:  # 30d default
        s = (today - _td_rpt(days=30)).replace(hour=0, minute=0, second=0, microsecond=0)
        e = today
    return s, e


@app.get("/api/admin/reports/run")
async def api_admin_reports_run(request: Request, db: Session = Depends(get_db)):
    """Single dispatch endpoint for the Reports page.  Returns
    { ok, title, columns[], rows[], summary{}, chart{} }.

    __S40_RPT_SCOPE__: Accepts admin, sub_lco, and employee sessions. For
    sub_lco / employee callers we seed the scope context-vars used by the
    SQLAlchemy event listeners so every Customer / Payment / Invoice ORM
    query is server-side filtered to that role's footprint."""
    if "user_id" not in request.session:
        return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    ut = (request.session.get("user_type") or "").lower()
    if ut not in ("admin", "superadmin", "sub_lco", "employee"):
        return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    # Seed sub-LCO scope context if needed
    if ut == "sub_lco":
        try:
            import sub_lco as _slmod
            sid = request.session.get("sub_lco_db_id")
            if sid:
                _slmod._SUB_LCO_CTX.set(int(sid))
        except Exception as _e:
            print(f"[reports] sub_lco scope set failed: {_e}")
    # Seed employee scope context (locality + sub_lco) if needed
    if ut == "employee":
        try:
            import employee_scope as _esmod
            _esmod.set_scope_from_session(request, db)
        except Exception as _e:
            print(f"[reports] employee scope set failed: {_e}")
    company_id = request.session.get("company_id")
    qp = request.query_params
    rtype = (qp.get("report_type") or "collection").strip()
    # __S43N_RPT_ALL_SERVICE__ accept '' or 'all' (case-insensitive) to
    # mean 'no filter'; default to '' so combined filters don't surprise.
    _st_raw = (qp.get("service_type") or "").strip()
    service_type = "" if _st_raw.lower() in ("", "all", "all services") else _st_raw
    period = (qp.get("period") or "30d").strip()
    from_date = qp.get("from_date") or ""
    to_date = qp.get("to_date") or ""
    emp_id = (qp.get("employee_id") or "").strip()
    loc_id = (qp.get("location_id") or "").strip()
    status_f = (qp.get("status") or "").strip()
    cstatus_f = (qp.get("complaint_status") or "").strip()
    days_ahead = int(qp.get("days_ahead") or 15)

    start_dt, end_dt = _rpt_date_range(period, from_date, to_date)

    from database import Customer, Payment, Plan, Invoice, Employee, Location
    try:
        from database import Complaint
    except Exception:
        Complaint = None

    # _S40zP_lock_filter_reports_ Sub-LCO lock: hide all locked customers across reports.
    try:
        _hide_p28r = _hidden_cust_ids(request, db)
    except Exception:
        _hide_p28r = set()

    # __S43H_LOC_FILTER__: most prod customers carry location_id=NULL but
    # have a `locality` text set; the original numeric-only filter returned
    # zero rows whenever a location was chosen. Resolve the location's name
    # once and match by name OR id.
    _loc_name_for_filter = ""
    if loc_id:
        try:
            from database import Location as _Loc_rpt
            _l = db.query(_Loc_rpt).filter(
                _Loc_rpt.id == int(loc_id),
                _Loc_rpt.company_id == company_id).first()
            _loc_name_for_filter = (_l.name or "").strip() if _l else ""
        except Exception:
            _loc_name_for_filter = ""

    # __S43T_EMP_OWNS__ pre-resolve emp_id once: is it a sub_lco code,
    # employee code, or admin code? Used by both _cust_q() and the payment
    # loop. None of the three branches require a JOIN.
    _emp_kind, _emp_sub_lco_pk = ("none", None)
    if emp_id:
        try:
            from sqlalchemy import text as _t_emp
            _r1 = db.execute(_t_emp(
                "SELECT id FROM sub_lcos WHERE sub_lco_code=:c AND company_id=:co LIMIT 1"
            ), {"c": emp_id, "co": company_id}).fetchone()
            if _r1:
                _emp_kind, _emp_sub_lco_pk = "sub_lco", int(_r1[0])
            else:
                _r2 = db.execute(_t_emp(
                    "SELECT employee_code FROM employees WHERE employee_code=:c AND company_id=:co LIMIT 1"
                ), {"c": emp_id, "co": company_id}).fetchone()
                if _r2:
                    _emp_kind = "employee"
                else:
                    _r3 = db.execute(_t_emp(
                        "SELECT admin_id FROM admins WHERE admin_id=:c AND company_id=:co LIMIT 1"
                    ), {"c": emp_id, "co": company_id}).fetchone()
                    if _r3:
                        _emp_kind = "admin"
        except Exception as _ee:
            print(f"[reports] emp_id classify failed: {_ee}")

    # Base customer filter
    def _cust_q():
        q = db.query(Customer).filter(Customer.company_id == company_id)
        if _hide_p28r:
            q = q.filter(~Customer.customer_id.in_(_hide_p28r))
        if service_type:
            q = q.filter(Customer.service_type == service_type)
        if status_f:
            q = q.filter(Customer.status == status_f)
        if loc_id:
            try:
                _lid = int(loc_id)
            except Exception:
                _lid = None
            if _loc_name_for_filter:
                from sqlalchemy import or_ as _or_rpt, func as _f_rpt
                q = q.filter(_or_rpt(
                    Customer.location_id == _lid,
                    _f_rpt.upper(_f_rpt.trim(Customer.locality)) ==
                        _loc_name_for_filter.strip().upper(),
                ))
            elif _lid is not None:
                q = q.filter(Customer.location_id == _lid)
        # __S43T_EMP_OWNS__ apply employee/sub-LCO ownership to customer-centric
        # reports. For admin codes, no ownership match exists → zero rows
        # (admins are reflected on collection reports via Payment.employee_id).
        if _emp_kind == "sub_lco" and _emp_sub_lco_pk is not None:
            q = q.filter(Customer.sub_lco_id == _emp_sub_lco_pk)
        elif _emp_kind == "employee":
            # __S43ZB__ hybrid: own-added OR (sub_lco_id=parent AND locality IN assigned)
            try:
                from database import Employee as _Emp_rpt, EmployeeLocalityAssignment as _ELA, Location as _Loc_rpt2
                from sqlalchemy import or_ as _or_z, and_ as _and_z, func as _f_z
                _e = db.query(_Emp_rpt).filter(
                    _Emp_rpt.employee_code == emp_id,
                    _Emp_rpt.company_id == company_id).first()
                if _e:
                    _eid_pk = int(_e.id)
                    _parent_slc = _e.sub_lco_id
                    _names = [r[0].strip().upper() for r in (
                        db.query(_Loc_rpt2.name)
                          .join(_ELA, _ELA.location_id == _Loc_rpt2.id)
                          .filter(_ELA.employee_id == _eid_pk,
                                  _ELA.company_id == company_id,
                                  _ELA.active == True).all()) if r[0]]
                    own_p = Customer.created_by_employee_id == _eid_pk
                    if not _names:
                        q = q.filter(own_p)
                    else:
                        loc_p = _f_z.upper(_f_z.trim(Customer.locality)).in_(_names)
                        if _parent_slc is None:
                            slc_p = _and_z(Customer.sub_lco_id.is_(None), loc_p)
                        else:
                            slc_p = _and_z(Customer.sub_lco_id == int(_parent_slc), loc_p)
                        q = q.filter(_or_z(own_p, slc_p))
                else:
                    q = q.filter(Customer.id == -1)
            except Exception as _e_zb:
                print(f"[reports] S43ZB emp scope failed: {_e_zb}")
                q = q.filter(Customer.created_by_employee_id == emp_id)
        elif _emp_kind == "admin":
            # __S43W_ADMIN_NOOP__: admins don't own customers (the
            # created_by_admin_id column doesn't exist). For customer-centric
            # reports an admin selecting their own code means "all customers
            # under my company" (already enforced by company_id). Skip the
            # filter so amount_dues / total_subscribers / etc keep working
            # when an admin combines themselves + a location filter.
            pass
        return q

    # ---- COLLECTION / RECHARGES / GENERAL LEDGER / TRANS HISTORY ------
    if rtype in ("collection", "recharges", "transaction_history", "general_ledger"):
        q = db.query(Payment).filter(
            Payment.company_id == company_id,
            Payment.paid_at >= start_dt,
            Payment.paid_at <= end_dt,
        )
        if emp_id:
            q = q.filter(Payment.employee_id == emp_id)
        pays = q.order_by(Payment.paid_at.desc()).limit(2000).all()
        if _hide_p28r:
            pays = [p for p in pays if (p.customer_id or "") not in _hide_p28r]
        # Stitch with customer names. cust_map is auto-scoped by the
        # SQLAlchemy event listener (sub_lco / employee), so any payment
        # whose customer_id is NOT a key here is out-of-scope and must be
        # skipped — otherwise we'd leak admin-wide payments. (__S40_RPT_SCOPE__)
        cust_map = {c.customer_id: c for c in db.query(Customer).filter(
            Customer.company_id == company_id).all()}
        _restrict_scope = (request.session.get("user_type") or "").lower() in ("sub_lco", "employee")
        rows = []
        for p in pays:
            c = cust_map.get(p.customer_id)
            if _restrict_scope and c is None:
                continue
            if service_type and c and c.service_type != service_type:
                continue
            if loc_id and c:
                # __S43H_LOC_FILTER__ : match by name OR id
                _ok_loc = False
                try:
                    if int(loc_id) and c.location_id == int(loc_id):
                        _ok_loc = True
                except Exception:
                    pass
                if not _ok_loc and _loc_name_for_filter:
                    if (c.locality or "").strip().upper() == _loc_name_for_filter.strip().upper():
                        _ok_loc = True
                if not _ok_loc:
                    continue
            rows.append({
                "date": _tzu_ist_str(p.paid_at, with_suffix=False),
                "customer_id": p.customer_id,
                "customer_name": c.customer_name if c else "",
                "username": c.username if c else "",
                "mobile": c.customer_phone if c else "",
                "amount": float(p.amount or 0),
                "discount": float(p.discount or 0),
                "mode": p.payment_mode or "",
                "txn": p.transaction_no or "",
                "collected_by": p.employee_id or "",
                "remarks": p.remarks or "",
            })
        total = sum(r["amount"] for r in rows)
        columns = [
            {"key": "date", "label": "Paid At"},
            {"key": "customer_id", "label": "Cust ID"},
            {"key": "customer_name", "label": "Customer Name"},
            {"key": "username", "label": "Username"},
            {"key": "mobile", "label": "Mobile"},
            {"key": "amount", "label": "Amount", "currency": True, "num": True},
            {"key": "discount", "label": "Discount", "currency": True, "num": True},
            {"key": "mode", "label": "Mode"},
            {"key": "txn", "label": "Txn No"},
            {"key": "collected_by", "label": "Collected By"},
        ]
        # Chart: daily revenue trend
        daily = {}
        for r in rows:
            d = (r["date"] or "")[:10]
            daily[d] = daily.get(d, 0) + r["amount"]
        labels = sorted(daily.keys())
        return {"ok": True,
                "title": {"collection":"Collection", "recharges":"Recharges",
                          "transaction_history":"Subscriber Transaction History",
                          "general_ledger":"General Ledger"}[rtype],
                "columns": columns, "rows": rows,
                "summary": {
                    "count":   {"value": len(rows), "label": "# Payments"},
                    "total":   {"value": total, "label": "Total Collected", "is_currency": True},
                    "avg":     {"value": (total/len(rows) if rows else 0), "label": "Avg Payment", "is_currency": True},
                    "max":     {"value": max((r["amount"] for r in rows), default=0), "label": "Max Payment", "is_currency": True},
                },
                "chart": {"type":"line", "labels": labels, "data":[daily[l] for l in labels],
                          "dataset_label":"Daily collection", "is_currency": True}}

    # ---- AMOUNT DUES -------------------------------------------------
    if rtype == "amount_dues":
        custs = _cust_q().all()
        # Sum unpaid invoice balance per customer
        rows = []
        for c in custs:
            inv_rows = db.query(Invoice).filter(
                Invoice.company_id == company_id,
                Invoice.customer_id == c.customer_id,
            ).all()
            total_billed = sum(float(i.total_amount or 0) for i in inv_rows)
            total_paid = db.query(func.coalesce(func.sum(Payment.amount), 0)).filter(
                Payment.company_id == company_id,
                Payment.customer_id == c.customer_id).scalar() or 0
            due = round(total_billed - float(total_paid), 2)
            if due <= 0: continue
            rows.append({
                "customer_id": c.customer_id, "customer_name": c.customer_name or "",
                "username": c.username or "", "mobile": c.customer_phone or "",
                "billed": round(total_billed,2), "paid": round(float(total_paid),2),
                "due": due, "status": c.status or "",
                "expiry": c.end_date or "",
            })
        rows.sort(key=lambda r: r["due"], reverse=True)
        columns = [
            {"key":"customer_id","label":"Cust ID"},
            {"key":"customer_name","label":"Name"},
            {"key":"username","label":"Username"},
            {"key":"mobile","label":"Mobile"},
            {"key":"billed","label":"Total Billed","currency":True,"num":True},
            {"key":"paid","label":"Total Paid","currency":True,"num":True},
            {"key":"due","label":"Due","currency":True,"num":True},
            {"key":"status","label":"Status","badge":True},
            {"key":"expiry","label":"Expiry"},
        ]
        total_due = sum(r["due"] for r in rows)
        # Chart: top 10 dues customers
        top = rows[:10]
        return {"ok": True, "title": "Amount Dues",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"Customers with dues"},
                    "total": {"value": total_due, "label":"Total Outstanding", "is_currency": True},
                    "avg":   {"value": (total_due/len(rows) if rows else 0), "label":"Avg Due", "is_currency": True},
                    "max":   {"value": rows[0]["due"] if rows else 0, "label":"Largest Due", "is_currency": True},
                },
                "chart": {"type":"bar", "labels":[r["customer_name"] or r["customer_id"] for r in top],
                          "data":[r["due"] for r in top],
                          "dataset_label":"Top-10 Dues","is_currency":True}}

    # ---- TOTAL SUBSCRIBERS ------------------------------------------
    if rtype == "total_subscribers":
        custs = _cust_q().order_by(Customer.created_at.desc()).all()
        plan_map = {p.id: p for p in db.query(Plan).filter(Plan.company_id == company_id).all()}
        rows = []
        for c in custs:
            plan = plan_map.get(c.plan_id)
            rows.append({
                "customer_id": c.customer_id, "customer_name": c.customer_name or "",
                "username": c.username or "", "mobile": c.customer_phone or "",
                "plan": plan.plan_name if plan else "",
                "amount": float(c.monthly_amount or 0),
                "status": c.status or "",
                "start_date": c.start_date or c.installation_date or "",
                "expiry": c.end_date or "",
                "locality": c.locality or "", "city": c.city or "",
            })
        active = sum(1 for r in rows if r["status"] == "Active")
        by_status = {}
        for r in rows: by_status[r["status"] or "Unknown"] = by_status.get(r["status"] or "Unknown", 0) + 1
        columns = [
            {"key":"customer_id","label":"Cust ID"},{"key":"customer_name","label":"Name"},
            {"key":"username","label":"Username"},{"key":"mobile","label":"Mobile"},
            {"key":"plan","label":"Plan"},
            {"key":"amount","label":"Monthly","currency":True,"num":True},
            {"key":"status","label":"Status","badge":True},
            {"key":"start_date","label":"Start"},{"key":"expiry","label":"Expiry"},
            {"key":"locality","label":"Locality"},
        ]
        return {"ok": True, "title": "Total Subscribers",
                "columns": columns, "rows": rows,
                "summary": {
                    "count":  {"value": len(rows), "label":"Total"},
                    "active": {"value": active, "label":"Active"},
                    "total":  {"value": sum(r["amount"] for r in rows), "label":"MRR Potential","is_currency":True},
                },
                "chart": {"type":"doughnut",
                          "labels": list(by_status.keys()),
                          "data": list(by_status.values()),
                          "dataset_label":"By status"}}

    # ---- ENROLLMENTS -------------------------------------------------
    if rtype == "enrollments":
        custs = _cust_q().filter(
            Customer.created_at >= start_dt,
            Customer.created_at <= end_dt).order_by(Customer.created_at.desc()).all()
        rows = []
        for c in custs:
            rows.append({
                "enrolled_at": _tzu_ist_str(c.created_at, with_suffix=False),
                "customer_id": c.customer_id, "customer_name": c.customer_name or "",
                "username": c.username or "", "mobile": c.customer_phone or "",
                "amount": float(c.monthly_amount or 0),
                "status": c.status or "",
                "locality": c.locality or "",
            })
        # Chart: enrollments per day
        daily = {}
        for r in rows:
            d = (r["enrolled_at"] or "")[:10]
            daily[d] = daily.get(d, 0) + 1
        labels = sorted(daily.keys())
        columns = [
            {"key":"enrolled_at","label":"Enrolled At"},{"key":"customer_id","label":"Cust ID"},
            {"key":"customer_name","label":"Name"},{"key":"username","label":"Username"},
            {"key":"mobile","label":"Mobile"},
            {"key":"amount","label":"Monthly","currency":True,"num":True},
            {"key":"status","label":"Status","badge":True},{"key":"locality","label":"Locality"},
        ]
        return {"ok": True, "title": "Enrollments (New Connections)",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"New Customers"},
                    "total": {"value": sum(r["amount"] for r in rows), "label":"MRR Added","is_currency":True},
                },
                "chart": {"type":"line","labels":labels,"data":[daily[l] for l in labels],
                          "dataset_label":"New connections / day"}}

    # ---- CHURNS ------------------------------------------------------
    if rtype == "churns":
        try:
            from database import CustomerStatusLog
            logs = db.query(CustomerStatusLog).filter(
                CustomerStatusLog.company_id == company_id,
                CustomerStatusLog.created_at >= start_dt,
                CustomerStatusLog.created_at <= end_dt,
                CustomerStatusLog.new_status.in_(["Inactive","Disabled","Suspended","Closed"])
            ).order_by(CustomerStatusLog.created_at.desc()).all()
        except Exception:
            logs = []
        cust_map = {c.customer_id: c for c in _cust_q().all()}
        rows = []
        for l in logs:
            c = cust_map.get(l.customer_id) if l.customer_id else None
            if not c: continue
            rows.append({
                "at": _tzu_ist_str(l.created_at, with_suffix=False),
                "customer_id": c.customer_id, "customer_name": c.customer_name or "",
                "username": c.username or "",
                "old_status": l.old_status or "", "new_status": l.new_status or "",
                "reason": (l.note or "") if hasattr(l, "note") else "",
            })
        columns = [
            {"key":"at","label":"At"},{"key":"customer_id","label":"Cust ID"},
            {"key":"customer_name","label":"Name"},{"key":"username","label":"Username"},
            {"key":"old_status","label":"From"},{"key":"new_status","label":"To","badge":True},
            {"key":"reason","label":"Reason"},
        ]
        return {"ok": True, "title": "Churns / Opt-Out",
                "columns": columns, "rows": rows,
                "summary": {"count": {"value": len(rows), "label":"Churned"}},
                "chart": {"type":"bar",
                          "labels": list({r["new_status"] for r in rows}),
                          "data":   [sum(1 for r in rows if r["new_status"]==s) for s in {r["new_status"] for r in rows}],
                          "dataset_label":"Churn by status"}}

    # ---- NEAR-EXPIRY -------------------------------------------------
    if rtype == "near_expiry":
        custs = _cust_q().filter(Customer.status == "Active").all()
        today = _dt_rpt.now().date()
        cutoff = today + _td_rpt(days=days_ahead)
        rows = []
        for c in custs:
            if not c.end_date: continue
            try:
                d = _dt_rpt.strptime(c.end_date[:10], "%Y-%m-%d").date()
            except Exception:
                continue
            if today <= d <= cutoff:
                rows.append({
                    "expiry": c.end_date[:10],
                    "days_left": (d - today).days,
                    "customer_id": c.customer_id,
                    "customer_name": c.customer_name or "",
                    "username": c.username or "",
                    "mobile": c.customer_phone or "",
                    "amount": float(c.monthly_amount or 0),
                    "locality": c.locality or "",
                })
        rows.sort(key=lambda r: r["days_left"])
        columns = [
            {"key":"expiry","label":"Expiry"},{"key":"days_left","label":"Days Left","num":True},
            {"key":"customer_id","label":"Cust ID"},{"key":"customer_name","label":"Name"},
            {"key":"username","label":"Username"},{"key":"mobile","label":"Mobile"},
            {"key":"amount","label":"Monthly","currency":True,"num":True},
            {"key":"locality","label":"Locality"},
        ]
        return {"ok": True, "title": f"Near-by Expiry (next {days_ahead} days)",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"Expiring soon"},
                    "total": {"value": sum(r["amount"] for r in rows), "label":"At-risk MRR","is_currency":True},
                },
                "chart": {"type":"bar",
                          "labels": [str(i) for i in range(0, days_ahead+1)],
                          "data":   [sum(1 for r in rows if r["days_left"]==i) for i in range(0, days_ahead+1)],
                          "dataset_label":"Expiring on day"}}

    # ---- NON-PAID ----------------------------------------------------
    if rtype == "non_paid":
        custs = _cust_q().all()
        rows = []
        for c in custs:
            recent = db.query(Payment).filter(
                Payment.company_id == company_id,
                Payment.customer_id == c.customer_id,
                Payment.paid_at >= start_dt,
                Payment.paid_at <= end_dt).first()
            if recent: continue
            rows.append({
                "customer_id": c.customer_id, "customer_name": c.customer_name or "",
                "username": c.username or "", "mobile": c.customer_phone or "",
                "plan_amount": float(c.monthly_amount or 0),
                "status": c.status or "", "expiry": c.end_date or "",
                "locality": c.locality or "",
            })
        columns = [
            {"key":"customer_id","label":"Cust ID"},{"key":"customer_name","label":"Name"},
            {"key":"username","label":"Username"},{"key":"mobile","label":"Mobile"},
            {"key":"plan_amount","label":"Plan Amount","currency":True,"num":True},
            {"key":"status","label":"Status","badge":True},
            {"key":"expiry","label":"Expiry"},{"key":"locality","label":"Locality"},
        ]
        return {"ok": True, "title": "Non-Paid Customers",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"Customers w/o payment"},
                    "total": {"value": sum(r["plan_amount"] for r in rows), "label":"MRR at risk","is_currency":True},
                },
                "chart": {"type":"bar",
                          "labels": list({r["locality"] or "-" for r in rows}),
                          "data":   [sum(1 for r in rows if (r["locality"] or "-") == k)
                                     for k in list({r["locality"] or "-" for r in rows})],
                          "dataset_label":"By locality"}}

    # ---- COMPLAINTS --------------------------------------------------
    if rtype == "complaints":
        if Complaint is None:
            return {"ok": True, "title":"Complaints", "columns":[],"rows":[],"summary":{},"chart":{}}
        q = db.query(Complaint).filter(
            Complaint.company_id == company_id,
            Complaint.created_at >= start_dt,
            Complaint.created_at <= end_dt)
        if cstatus_f:
            q = q.filter(Complaint.status == cstatus_f)
        comps = q.order_by(Complaint.created_at.desc()).all()
        cust_map = {c.customer_id: c for c in db.query(Customer).filter(
            Customer.company_id == company_id).all()}
        rows = []
        for cp in comps:
            c = cust_map.get(cp.customer_id)
            rows.append({
                "ticket": cp.ticket_no or cp.id,
                "created_at": _tzu_ist_str(cp.created_at, with_suffix=False),
                "customer_id": cp.customer_id,
                "customer_name": c.customer_name if c else "",
                "subject": cp.subject or "",
                "priority": cp.priority or "",
                "status": cp.status or "",
                "resolved_at": _tzu_ist_str(cp.resolved_at, with_suffix=False),  # _TZ_FIX_ROUND2_
            })
        by_status = {}
        for r in rows: by_status[r["status"] or "Unknown"] = by_status.get(r["status"] or "Unknown",0)+1
        columns = [
            {"key":"ticket","label":"Ticket#"},{"key":"created_at","label":"Created"},
            {"key":"customer_id","label":"Cust ID"},{"key":"customer_name","label":"Name"},
            {"key":"subject","label":"Subject"},{"key":"priority","label":"Priority"},
            {"key":"status","label":"Status","badge":True},{"key":"resolved_at","label":"Resolved"},
        ]
        return {"ok": True, "title":"Complaints",
                "columns": columns, "rows": rows,
                "summary": {
                    "count":   {"value": len(rows), "label":"Total"},
                    "pending": {"value": by_status.get("Pending",0), "label":"Pending"},
                },
                "chart": {"type":"doughnut","labels":list(by_status.keys()),
                          "data":list(by_status.values()), "dataset_label":"Status"}}

    # ---- TOP PLANS ---------------------------------------------------
    if rtype == "top_plans":
        custs = _cust_q().all()
        plan_map = {p.id: p for p in db.query(Plan).filter(Plan.company_id == company_id).all()}
        agg = {}
        for c in custs:
            p = plan_map.get(c.plan_id)
            key = p.plan_name if p else "— none —"
            agg[key] = agg.get(key, 0) + 1
        rows = [{"plan": k, "count": v} for k, v in sorted(agg.items(), key=lambda kv:-kv[1])]
        columns = [{"key":"plan","label":"Plan"},{"key":"count","label":"Subscribers","num":True}]
        return {"ok": True, "title":"Top Plans by Subscribers",
                "columns": columns, "rows": rows,
                "summary": {"count": {"value": len(rows), "label":"Plans in use"}},
                "chart": {"type":"bar",
                          "labels": [r["plan"] for r in rows[:10]],
                          "data":   [r["count"] for r in rows[:10]],
                          "dataset_label":"Subscribers"}}

    # ---- REVENUE BY PLAN --------------------------------------------
    if rtype == "revenue_by_plan":
        custs = _cust_q().all()
        plan_map = {p.id: p for p in db.query(Plan).filter(Plan.company_id == company_id).all()}
        # sum payments grouped by customer's plan
        pays = db.query(Payment).filter(
            Payment.company_id == company_id,
            Payment.paid_at >= start_dt, Payment.paid_at <= end_dt).all()
        cust_plan = {c.customer_id: c.plan_id for c in custs}
        agg = {}
        for p in pays:
            pid = cust_plan.get(p.customer_id)
            pl = plan_map.get(pid)
            key = pl.plan_name if pl else "— none —"
            agg[key] = agg.get(key, 0) + float(p.amount or 0)
        rows = [{"plan": k, "revenue": round(v,2)} for k,v in sorted(agg.items(), key=lambda kv:-kv[1])]
        columns = [{"key":"plan","label":"Plan"},
                   {"key":"revenue","label":"Revenue","currency":True,"num":True}]
        return {"ok": True, "title":"Revenue by Plan",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"Plans"},
                    "total": {"value": sum(r["revenue"] for r in rows), "label":"Total Revenue","is_currency":True},
                },
                "chart": {"type":"bar",
                          "labels":[r["plan"] for r in rows[:10]],
                          "data":  [r["revenue"] for r in rows[:10]],
                          "dataset_label":"Revenue","is_currency":True}}

    # ---- REVENUE BY LOCATION ----------------------------------------
    if rtype == "revenue_by_location":
        custs = _cust_q().all()
        cust_loc = {c.customer_id: (c.locality or "-") for c in custs}
        pays = db.query(Payment).filter(
            Payment.company_id == company_id,
            Payment.paid_at >= start_dt, Payment.paid_at <= end_dt).all()
        agg = {}
        for p in pays:
            loc = cust_loc.get(p.customer_id) or "-"
            agg[loc] = agg.get(loc, 0) + float(p.amount or 0)
        rows = [{"locality": k, "revenue": round(v,2)} for k,v in sorted(agg.items(), key=lambda kv:-kv[1])]
        columns = [{"key":"locality","label":"Locality"},
                   {"key":"revenue","label":"Revenue","currency":True,"num":True}]
        return {"ok": True, "title":"Revenue by Location",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"Localities"},
                    "total": {"value": sum(r["revenue"] for r in rows), "label":"Total Revenue","is_currency":True},
                },
                "chart": {"type":"bar","labels":[r["locality"] for r in rows[:15]],
                          "data":[r["revenue"] for r in rows[:15]],
                          "dataset_label":"Revenue","is_currency":True}}

    # ---- REVENUE BY EMPLOYEE -----------------------------------------
    if rtype == "revenue_by_employee":
        # _S39R5_FIX2 — only include actual EMPLOYEES; skip admin/system payers.
        emp_map = {e.employee_code: e for e in db.query(Employee).filter(
            Employee.company_id == company_id,
            Employee.is_deleted == False).all()}
        emp_by_id = {e.id: e for e in emp_map.values()}
        pays = db.query(Payment).filter(
            Payment.company_id == company_id,
            Payment.paid_at >= start_dt, Payment.paid_at <= end_dt).all()
        agg = {}
        for p in pays:
            k = p.employee_id or ""
            # Drop entries whose recorder isn't a known employee_code (e.g. ADMIN001).
            if not k or k not in emp_map:
                continue
            agg[k] = agg.get(k, {"amount":0, "count":0})
            agg[k]["amount"] += float(p.amount or 0)
            agg[k]["count"] += 1
        rows = []
        for k, v in sorted(agg.items(), key=lambda kv:-kv[1]["amount"]):
            nm = emp_map[k].employee_name if k in emp_map else k
            rows.append({"employee_id": k, "employee": nm or k,
                         "count": v["count"], "revenue": int(round(v["amount"]))})
        columns = [{"key":"employee","label":"Employee"},
                   {"key":"count","label":"# Payments","num":True},
                   {"key":"revenue","label":"Revenue","currency":True,"num":True}]
        return {"ok": True, "title":"Revenue by Employee",
                "columns": columns, "rows": rows,
                "summary": {
                    "count": {"value": len(rows), "label":"Employees"},
                    "total": {"value": sum(r["revenue"] for r in rows), "label":"Total Collected","is_currency":True},
                },
                "chart": {"type":"bar","labels":[r["employee"] for r in rows[:10]],
                          "data":[r["revenue"] for r in rows[:10]],
                          "dataset_label":"Revenue","is_currency":True}}

    # ---- REVENUE BY SUB-LCO  _S39R4_SUBLCO_REPORT_WIRED ------------------------
    if rtype == "revenue_by_sub_lco":
        from sqlalchemy import text as _sa_text
        # Pull sub-lcos for this company
        sublco_rows = db.execute(_sa_text(
            "SELECT id, sub_lco_code, name, commission_percent, status "
            "FROM sub_lcos WHERE company_id=:c"
        ), {"c": company_id}).fetchall()
        if not sublco_rows:
            return {"ok": True, "title": "Revenue by Sub-LCO",
                    "columns": [], "rows": [],
                    "summary": {"count": {"value": 0, "label": "Sub-LCOs"}},
                    "chart": {}}
        sublco_ids = [int(r[0]) for r in sublco_rows]

        # Customer counts per sub_lco
        cust_count_rows = db.execute(_sa_text(
            "SELECT sub_lco_id, COUNT(*) FROM customers "
            "WHERE company_id=:c AND sub_lco_id IS NOT NULL "
            "AND COALESCE(status,'') != 'Deleted' "
            "GROUP BY sub_lco_id"
        ), {"c": company_id}).fetchall()
        cust_count = {int(r[0]): int(r[1]) for r in cust_count_rows}

        # Paid (period) — payments by sub_lco's customers in window
        # Join: payments.customer_id -> customers.customer_id -> sub_lco_id
        paid_rows = db.execute(_sa_text(
            "SELECT cu.sub_lco_id, COALESCE(SUM(p.amount),0), COUNT(p.id) "
            "FROM payments p JOIN customers cu "
            "  ON cu.customer_id=p.customer_id AND cu.company_id=p.company_id "
            "WHERE p.company_id=:c AND p.paid_at>=:s AND p.paid_at<=:e "
            "  AND cu.sub_lco_id IS NOT NULL "
            "GROUP BY cu.sub_lco_id"
        ), {"c": company_id, "s": start_dt, "e": end_dt}).fetchall()
        paid_map = {int(r[0]): (float(r[1] or 0), int(r[2] or 0)) for r in paid_rows}

        # Due (current outstanding) — sum(invoices.total) - sum(payments.amount) per sub_lco
        billed_rows = db.execute(_sa_text(
            "SELECT cu.sub_lco_id, COALESCE(SUM(i.total_amount),0) "
            "FROM invoices i JOIN customers cu "
            "  ON cu.customer_id=i.customer_id AND cu.company_id=i.company_id "
            "WHERE i.company_id=:c AND cu.sub_lco_id IS NOT NULL "
            "GROUP BY cu.sub_lco_id"
        ), {"c": company_id}).fetchall()
        billed_total_map = {int(r[0]): float(r[1] or 0) for r in billed_rows}

        paid_total_rows = db.execute(_sa_text(
            "SELECT cu.sub_lco_id, COALESCE(SUM(p.amount),0) "
            "FROM payments p JOIN customers cu "
            "  ON cu.customer_id=p.customer_id AND cu.company_id=p.company_id "
            "WHERE p.company_id=:c AND cu.sub_lco_id IS NOT NULL "
            "GROUP BY cu.sub_lco_id"
        ), {"c": company_id}).fetchall()
        paid_total_map = {int(r[0]): float(r[1] or 0) for r in paid_total_rows}

        # Earning (period) — sub_lco_commissions in window
        earn_rows = db.execute(_sa_text(
            "SELECT sub_lco_id, COALESCE(SUM(commission_amount),0), COUNT(*) "
            "FROM sub_lco_commissions "
            "WHERE company_id=:c AND created_at>=:s AND created_at<=:e "
            "GROUP BY sub_lco_id"
        ), {"c": company_id, "s": start_dt, "e": end_dt}).fetchall()
        earn_map = {int(r[0]): (float(r[1] or 0), int(r[2] or 0)) for r in earn_rows}

        # Earning (lifetime, pending payout) — for context column
        earn_pending_rows = db.execute(_sa_text(
            "SELECT sub_lco_id, COALESCE(SUM(commission_amount),0) "
            "FROM sub_lco_commissions "
            "WHERE company_id=:c AND COALESCE(payout_status,'Pending')='Pending' "
            "GROUP BY sub_lco_id"
        ), {"c": company_id}).fetchall()
        earn_pending_map = {int(r[0]): float(r[1] or 0) for r in earn_pending_rows}

        rows = []
        for r in sublco_rows:
            sid = int(r[0])
            paid_amt, paid_cnt = paid_map.get(sid, (0.0, 0))
            earn_amt, earn_cnt = earn_map.get(sid, (0.0, 0))
            due_amt = round(billed_total_map.get(sid, 0.0) - paid_total_map.get(sid, 0.0), 2)
            if due_amt < 0:
                due_amt = 0.0
            rows.append({
                "sub_lco_code": r[1] or "",
                "sub_lco_name": r[2] or "",
                "commission_pct": float(r[3] or 0),
                "status": r[4] or "",
                "customers": cust_count.get(sid, 0),
                "paid": round(paid_amt, 2),
                "payments_count": paid_cnt,
                "due": due_amt,
                "earning": round(earn_amt, 2),
                "earning_pending": round(earn_pending_map.get(sid, 0.0), 2),
            })
        rows.sort(key=lambda x: -x["paid"])

        columns = [
            {"key": "sub_lco_code", "label": "Code"},
            {"key": "sub_lco_name", "label": "Name"},
            {"key": "status", "label": "Status", "badge": True},
            {"key": "customers", "label": "Customers", "num": True},
            {"key": "commission_pct", "label": "Comm %", "num": True},
            {"key": "paid", "label": "Paid (period)", "currency": True, "num": True},
            {"key": "payments_count", "label": "# Payments", "num": True},
            {"key": "due", "label": "Due (outstanding)", "currency": True, "num": True},
            {"key": "earning", "label": "Earning (period)", "currency": True, "num": True},
            {"key": "earning_pending", "label": "Pending Payout", "currency": True, "num": True},
        ]
        total_paid = sum(r["paid"] for r in rows)
        total_due = sum(r["due"] for r in rows)
        total_earn = sum(r["earning"] for r in rows)
        return {
            "ok": True, "title": "Revenue by Sub-LCO",
            "columns": columns, "rows": rows,
            "summary": {
                "count": {"value": len(rows), "label": "Sub-LCOs"},
                "total": {"value": total_paid, "label": "Total Paid", "is_currency": True},
                "due":   {"value": total_due,  "label": "Total Due",  "is_currency": True},
                "earn":  {"value": total_earn, "label": "Total Earning", "is_currency": True},
            },
            "chart": {
                "type": "bar",
                "labels": [r["sub_lco_name"] or r["sub_lco_code"] for r in rows[:10]],
                "data":   [r["paid"] for r in rows[:10]],
                "dataset_label": "Paid by Sub-LCO",
                "is_currency": True,
            },
        }

    # ---- VOUCHER USAGE ----------------------------------------------
    if rtype == "voucher_usage":
        try:
            from database import HotspotVoucher, VoucherRedemption
        except Exception:
            return {"ok": True, "title":"Voucher Usage","columns":[],"rows":[],"summary":{},"chart":{}}
        vs = db.query(HotspotVoucher).filter(
            HotspotVoucher.company_id == company_id,
            HotspotVoucher.created_at >= start_dt,
            HotspotVoucher.created_at <= end_dt).all()
        rows = []
        for v in vs:
            rows.append({
                "code": v.code, "status": v.status or "",
                "created_at": _tzu_ist_str(v.created_at, with_suffix=False),
                "used_by": v.used_by or "",
                "expires_at": v.expires_at.strftime("%Y-%m-%d") if v.expires_at else "",
            })
        by_status = {}
        for r in rows: by_status[r["status"] or "Unknown"] = by_status.get(r["status"] or "Unknown",0)+1
        columns = [{"key":"code","label":"Code"},{"key":"status","label":"Status","badge":True},
                   {"key":"created_at","label":"Created"},{"key":"used_by","label":"Used By"},
                   {"key":"expires_at","label":"Expires"}]
        return {"ok": True, "title":"Voucher Usage",
                "columns": columns, "rows": rows,
                "summary": {"count":{"value":len(rows),"label":"Vouchers issued"}},
                "chart": {"type":"doughnut","labels":list(by_status.keys()),
                          "data":list(by_status.values()),"dataset_label":"By status"}}

    return JSONResponse({"ok": False, "error": f"Unknown report_type: {rtype}"}, status_code=400)


