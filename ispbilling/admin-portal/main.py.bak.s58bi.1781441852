@app.get("/api/admin/data-mgmt/history")
async def api_dm_history(request: Request):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")
    from database import engine
    rows = []
    try:
        with engine.begin() as conn:
            cur = conn.exec_driver_sql(
                "SELECT action,kind,records,status,filename,message,created_by,created_at "
                "FROM data_mgmt_log WHERE company_id=? ORDER BY id DESC LIMIT 50",
                (company_id,),
            )
            for r in cur:
                rows.append({
                    "action": r[0], "kind": r[1], "records": r[2],
                    "status": r[3], "filename": r[4], "message": r[5],
                    "by": r[6], "at": str(r[7]),
                })
    except Exception as e:
        return JSONResponse({"success": False, "message": str(e), "rows": []})
    return {"success": True, "rows": rows}

