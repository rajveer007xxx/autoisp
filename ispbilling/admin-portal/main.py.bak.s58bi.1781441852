@app.get("/api/customer/me/online-status")
async def api_customer_me_online(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return {"online": False}
    cid = request.session.get("user_id")
    from database import Customer
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if not cust:
        return {"online": False}
    return {"online": _is_customer_live_online(db, cust)}


@app.get("/api/customer/me/speed")
async def api_customer_me_speed(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return {"mb_up": 0, "mb_dn": 0, "online": False}
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    from database import Customer
    from sqlalchemy import text as _t_s
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if not cust:
        return {"mb_up": 0, "mb_dn": 0, "online": False}
    if not company_id:
        company_id = cust.company_id or ""
    # Live online check first; if offline, return zeros.
    if not _is_customer_live_online(db, cust):
        return {"mb_up": 0, "mb_dn": 0, "online": False}
    row = db.execute(_t_s(
        "SELECT bytes_in, bytes_out FROM online_users "
        "WHERE company_id=:c AND username=:u AND status='Online' "
        "ORDER BY started_at DESC LIMIT 1"
    ), {"c": company_id, "u": (cust.username or "")}).fetchone()
    if not row:
        return {"mb_up": 0, "mb_dn": 0, "online": True}
    mb_up = float(row[0] or 0)  # bytes_in  = upload (router received)
    mb_dn = float(row[1] or 0)  # bytes_out = download (router sent)
    return {"mb_up": mb_up, "mb_dn": mb_dn, "online": True}


@app.post("/api/customer/me/complaint")
async def api_customer_me_complaint(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return {"success": False, "message": "Unauthorized"}
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    from database import Customer, Complaint
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if not cust: return {"success": False, "message": "Customer not found"}
    if not company_id: company_id = cust.company_id or ""
    body = await request.json()
    complaint_type = (body.get("type") or "Other").strip()
    message = (body.get("message") or "").strip()
    if not message: return {"success": False, "message": "Description is required"}
    import time as _t
    ticket_no = f"C{int(_t.time())}"
    try:
        c = Complaint(
            company_id=company_id, customer_id=cust.customer_id,
            ticket_no=ticket_no, complaint_type=complaint_type,
            subject=complaint_type, description=message,
            status="Pending", kind="Complaint",
            source="customer", target_role="admin",
        )
        db.add(c); db.commit()
        return {"success": True, "message": f"Ticket {ticket_no} submitted"}
    except Exception as ex:
        db.rollback()
        return {"success": False, "message": f"Could not submit: {ex}"}


@app.post("/api/customer/me/photograph")
async def api_customer_me_photograph(request: Request, db: Session = Depends(get_db)):
    """v4.7.30: Customer self-service profile photo upload.
    Multipart form with single file field 'photograph'."""
    g = _require_customer(request)
    if g: return {"success": False, "message": "Unauthorized"}
    from database import Customer
    import os as _os, uuid as _uuid
    from pathlib import Path as _Path
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    cust = db.query(Customer).filter(Customer.customer_id == cid,
                                      Customer.company_id == company_id).first()
    if not cust:
        return {"success": False, "message": "Customer not found"}
    form = await request.form()
    up = form.get("photograph")
    if not up or not hasattr(up, "filename") or not up.filename:
        return {"success": False, "message": "No file"}
    allowed = {".jpg", ".jpeg", ".png", ".webp"}
    ext = _os.path.splitext(up.filename)[1].lower()
    if ext not in allowed:
        return {"success": False, "message": "Only JPG, PNG, WEBP allowed"}
    data = await up.read()
    if len(data) > 5 * 1024 * 1024:
        return {"success": False, "message": "Max 5 MB"}
    upload_dir = _Path(f"/var/www/autoispbilling/uploads/{company_id}/customers/{cid}")
    upload_dir.mkdir(parents=True, exist_ok=True)
    fname = f"photograph-{_uuid.uuid4()}{ext}"
    fpath = upload_dir / fname
    with open(fpath, "wb") as f: f.write(data)
    rel = f"/uploads/{company_id}/customers/{cid}/{fname}"
    cust.photograph_path = rel
    db.commit()
    return {"success": True, "url": rel, "path": rel}


@app.post("/api/customer/me/change-password")
async def api_customer_me_change_password(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return {"success": False, "message": "Unauthorized"}
    cid = request.session.get("user_id")
    body = await request.json()
    old_pw = body.get("old") or ""
    new_pw = body.get("new") or ""
    if len(new_pw) < 8:
        return {"success": False, "message": "New password must be at least 8 characters"}
    from database import Customer
    from auth import verify_password, get_password_hash
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if not cust or not verify_password(old_pw, cust.password_hash):
        return {"success": False, "message": "Current password is incorrect"}
    cust.password_hash = get_password_hash(new_pw)
    db.commit()
    return {"success": True, "message": "Web portal password updated. Your internet (PPPoE) password is unchanged."}


@app.post("/api/customer/me/change-package")
async def api_customer_me_change_package(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return {"success": False, "message": "Unauthorized"}
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    body = await request.json()
    plan_id = body.get("plan_id")
    if not plan_id: return {"success": False, "message": "Plan id missing"}
    from database import Customer, Plan, Complaint
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    plan = db.query(Plan).filter(Plan.id == int(plan_id)).first()
    if not (cust and plan):
        return {"success": False, "message": "Customer or plan not found"}
    if not company_id: company_id = cust.company_id or ""
    import time as _t
    ticket_no = f"C{int(_t.time())}"
    try:
        c = Complaint(
            company_id=company_id, customer_id=cust.customer_id,
            ticket_no=ticket_no, complaint_type="Plan Change Request",
            subject=f"Plan change request: {plan.plan_name}",
            description=f"Customer requested change to plan: {plan.plan_name} (ID {plan.id})",
            status="Pending", kind="Complaint",
            source="customer", target_role="admin",
        )
        db.add(c); db.commit()
        return {"success": True, "message": f"Request received (Ticket {ticket_no}). Our team will reach out shortly."}
    except Exception as ex:
        db.rollback()
        return {"success": False, "message": f"Could not submit: {ex}"}


# Customer-scoped invoice / payment download
@app.get("/api/customer/me/invoice/{invoice_id}/download")
async def api_customer_me_invoice_download(invoice_id: int, request: Request,
                                            inline: int = 0,
                                            db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    from database import Invoice, Customer
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if not cust:
        return JSONResponse({"success": False, "message": "Customer not found"}, status_code=404)
    if not company_id:
        company_id = cust.company_id or ""
        request.session["company_id"] = company_id
    inv = db.query(Invoice).filter(
        Invoice.id == invoice_id,
        Invoice.customer_id == cust.customer_id,
        Invoice.company_id == company_id,
    ).first()
    if not inv:
        return JSONResponse({"success": False, "message": "Invoice not found"}, status_code=404)
    resp = await download_invoice(invoice_id, request, db)
    # Flip Content-Disposition to inline so the browser RENDERS the PDF
    # (instead of saving) — required for the iframe-based Print button.
    if inline and hasattr(resp, "headers"):
        try:
            resp.headers["Content-Disposition"] = f'inline; filename="invoice_{inv.invoice_no}.pdf"'
        except Exception:
            pass
    return resp


@app.get("/api/customer/me/payment/{payment_id}/receipt")
async def api_customer_me_payment_receipt(payment_id: int, request: Request,
                                           inline: int = 0,
                                           db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    from database import Payment, Customer
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if not cust:
        return JSONResponse({"success": False, "message": "Customer not found"}, status_code=404)
    if not company_id:
        company_id = cust.company_id or ""
        request.session["company_id"] = company_id
    pay = db.query(Payment).filter(
        Payment.id == payment_id,
        Payment.customer_id == cust.customer_id,
        Payment.company_id == company_id,
    ).first()
    if not pay:
        return JSONResponse({"success": False, "message": "Payment not found"}, status_code=404)
    resp = await generate_receipt(payment_id, request, db)
    if inline and hasattr(resp, "headers"):
        try:
            resp.headers["Content-Disposition"] = f'inline; filename="receipt_{pay.transaction_no or pay.id}.pdf"'
        except Exception:
            pass
    return resp

# --- WebSocket: one persistent feed per customer for live speed --------
import asyncio as _ws_asyncio


def _parse_speed_mbps(v) -> float:
    """s40r: Parse a plan `download_speed` value into Mbps. Accepts
    plain numbers, 'X Mbps', 'X Gbps', 'X Kbps'. Returns 0 on parse
    failure — caller treats 0 as 'no cap'."""
    if v is None:
        return 0
    s = str(v).strip().lower()
    if not s:
        return 0
    import re as _re_sp
    m = _re_sp.search(r"([0-9]+\.?[0-9]*)\s*(g|m|k)?", s)
    if not m:
        return 0
    try:
        n = float(m.group(1))
    except Exception:
        return 0
    unit = (m.group(2) or "m")
    if   unit == "g": return n * 1000.0
    elif unit == "m": return n
    elif unit == "k": return n / 1000.0
    return n


async def _ws_collect_speed_payload(db: Session, cust) -> dict:
    """Return the speed payload to push over the websocket.

    s40q: Live MikroTik probe — `online_users.bytes_in/out` are refreshed
    only every 120 s by the sync job, which made the live-speed graph
    update in ugly stair-steps (or stay flat for users that genuinely
    haven't transferred since the last sync). We now query the customer's
    NAS directly via the RouterOS API for fresh `/ppp/active` byte
    counters (and fall back to the cached row if the router can't be
    reached). Total per-customer latency: ~120 ms.
    """
    company_id = cust.company_id or ""
    # For static-IP customers, refresh the cached company sync first.
    auth_type = (getattr(cust, "auth_type", None) or "pppoe").strip().lower()
    if auth_type in ("static_ip", "static"):
        _sync_static_ip_company_cached(db, company_id)
    online = _is_customer_live_online(db, cust)
    if not online:
        return {"online": False, "mb_up": 0, "mb_dn": 0}
    un = (cust.username or "").strip()
    if not un:
        return {"online": True, "mb_up": 0, "mb_dn": 0}
    # 1) Try a live MikroTik probe via `/ppp/active` filtered by name.
    try:
        from sqlalchemy import text as _t_ws
        row = db.execute(_t_ws(
            "SELECT nas_ip FROM online_users "
            " WHERE company_id=:c AND username=:u AND status='Online' "
            " ORDER BY started_at DESC LIMIT 1"
        ), {"c": company_id, "u": un}).fetchone()
        nas_ip = row[0] if row else None
        if nas_ip:
            nas_row = db.execute(_t_ws(
                "SELECT ip_address, "
                "       IFNULL(api_username,'admin') AS u, "
                "       IFNULL(api_password,'')     AS p, "
                "       IFNULL(port,8728)           AS port, "
                "       IFNULL(use_tls,0)           AS use_tls "
                "  FROM nas_devices "
                " WHERE company_id=:c AND ip_address=:ip LIMIT 1"
            ), {"c": company_id, "ip": nas_ip}).fetchone()
            if nas_row:
                import librouteros as _lr, asyncio as _aio
                def _probe():
                    kw = dict(host=nas_row[0], username=nas_row[1],
                               password=nas_row[2], port=int(nas_row[3]),
                               timeout=2.0)
                    if nas_row[4]:
                        import ssl as _ssl
                        ctx = _ssl.create_default_context()
                        ctx.check_hostname = False
                        ctx.verify_mode = _ssl.CERT_NONE
                        kw["ssl_wrapper"] = lambda s: ctx.wrap_socket(
                            s, server_hostname=nas_row[0])
                    c2 = _lr.connect(**kw)
                    try:
                        # s41a: RouterOS PPPoE dynamic interfaces are
                        # named '<pppoe-{username}>' (exact, single session)
                        # OR '<pppoe-{username}-N>' when the session was
                        # rebound (RouterOS appends -1/-2/...). The previous
                        # code used the prefix '<pppoe-{username}-' which
                        # NEVER matched the common single-session name, so
                        # the live probe always returned 0. Match both
                        # variants with a regex and pick the running
                        # interface with the highest cumulative bytes
                        # (the active session vs any zombies).
                        import re as _re_ws
                        _pat = _re_ws.compile(
                            r"^<pppoe-" + _re_ws.escape(un) + r"(-\d+)?>$")
                        cands = []
                        for r2 in c2.path("interface"):
                            nm = r2.get("name") or ""
                            if not _pat.match(nm):
                                continue
                            running = r2.get("running") in (True, "true", "yes")
                            rx = int(r2.get("rx-byte") or 0)
                            tx = int(r2.get("tx-byte") or 0)
                            cands.append((running, rx + tx, rx, tx))
                        # Prefer running interfaces; among them, max bytes
                        cands.sort(key=lambda x: (x[0], x[1]), reverse=True)
                        if cands:
                            # rx-byte = bytes received from subscriber (upload)
                            # tx-byte = bytes sent to subscriber (download)
                            return (cands[0][2], cands[0][3])
                    finally:
                        try: c2.close()
                        except Exception: pass
                    return None
                got = await _aio.get_event_loop().run_in_executor(None, _probe)
                if got is not None:
                    b_up, b_dn = got
                    # b_up = subscriber upload, b_dn = subscriber download
                    return {"online": True,
                            "mb_up": float(b_up) / 1048576.0,
                            "mb_dn": float(b_dn) / 1048576.0}
    except Exception:
        # Live probe failed — fall through to cached online_users row.
        pass
    # 2) Cached row (stale up to 120 s) as a fallback.
    try:
        from sqlalchemy import text as _t_ws
        row = db.execute(_t_ws(
            "SELECT bytes_in, bytes_out FROM online_users "
            " WHERE company_id=:c AND username=:u AND status='Online' "
            " ORDER BY started_at DESC LIMIT 1"
        ), {"c": company_id, "u": un}).fetchone()
    except Exception:
        row = None
    if not row:
        return {"online": True, "mb_up": 0, "mb_dn": 0}
    return {"online": True,
            "mb_up": float(row[0] or 0),  # bytes_in  = upload
            "mb_dn": float(row[1] or 0)}  # bytes_out = download


@app.websocket("/customer/ws/speed")
async def customer_ws_speed(websocket: WebSocket):
    """Push live speed + online status to a single connected customer.
    Auth is via the existing session cookie (the websocket inherits the
    session from the HTTP handshake)."""
    sess = websocket.scope.get("session") or {}
    if (sess.get("user_type") or "").lower() != "customer":
        await websocket.close(code=4401)
        return
    cid = sess.get("user_id")
    if not cid:
        await websocket.close(code=4401)
        return
    await websocket.accept()
    # Fresh DB session for the lifetime of the websocket.
    from database import SessionLocal as _WSSL
    db = _WSSL()
    try:
        from database import Customer
        cust = db.query(Customer).filter(Customer.customer_id == cid).first()
        if not cust:
            await websocket.send_json({"error": "customer-not-found"})
            await websocket.close(code=4404)
            return
        # Push every 2 seconds until the client disconnects.
        while True:
            try:
                payload = await _ws_collect_speed_payload(db, cust)
            except Exception as ex:
                payload = {"online": False, "mb_up": 0, "mb_dn": 0,
                            "err": str(ex)[:80]}
            await websocket.send_json(payload)
            await _ws_asyncio.sleep(2.0)
    except WebSocketDisconnect:
        pass
    except Exception as ex:
        try: await websocket.send_json({"error": str(ex)[:120]})
        except Exception: pass
    finally:
        try: db.close()
        except Exception: pass


# /__S39M__ ---------------------------------------------------------------



def _count_expired_subs(db, company_id):
    """Count customers whose status is Expired or end_date < today.

    __S43Z_EXPIRED_COUNT__ — end_date is stored as DD-MM-YYYY text in
    production, so a raw string comparison against an ISO date produces
    false positives. Parse properly and only count rows that are truly
    past their billing cycle.
    """
    try:
        from datetime import date as _date, datetime as _dt
        from database import Customer
        today = _date.today()
        n = 0
        for c in db.query(Customer.status, Customer.end_date).filter(
                Customer.company_id == company_id).all():
            st = (c.status or "").strip().lower()
            if st == "expired":
                n += 1
                continue
            ed = (c.end_date or "").strip()
            if not ed:
                continue
            d = None
            for fmt in ("%Y-%m-%d", "%d-%m-%Y", "%d/%m/%Y", "%Y/%m/%d"):
                try:
                    d = _dt.strptime(ed.split(" ")[0][:10], fmt).date()
                    break
                except Exception:
                    continue
            if d is not None and d < today:
                n += 1
        return n
    except Exception:
        return 0


