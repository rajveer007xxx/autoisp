# === Session 28.1 collector leaderboard ===
@app.get("/api/admin/collector-leaderboard")
async def api_collector_leaderboard(request: Request, db: Session = Depends(get_db)):
    """Return list of admins+employees with their collected-amount & count
    this month (default) / today / this_week / all_time. Sorted desc by amount."""
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from datetime import datetime as _dt, timedelta as _td, timezone as _tz
    from database import Payment, Admin, Employee
    from sqlalchemy import func
    IST = _tz(_td(hours=5, minutes=30))
    now = _dt.now(IST)
    period = (request.query_params.get("period") or "month").lower()
    if period == "today":
        start = now.replace(hour=0, minute=0, second=0, microsecond=0)
    elif period == "week":
        start = (now - _td(days=now.weekday())).replace(hour=0, minute=0, second=0, microsecond=0)
    elif period == "all":
        start = None
    else:  # month
        start = now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)

    q = db.query(
        Payment.employee_id,
        func.coalesce(func.sum(Payment.amount), 0).label("total"),
        func.count(Payment.id).label("count"),
    ).filter(Payment.company_id == company_id)
    if start is not None:
        q = q.filter(Payment.paid_at >= start.replace(tzinfo=None))
    q = q.group_by(Payment.employee_id).order_by(func.sum(Payment.amount).desc())
    rows = q.all()

    # Resolve names
    admin_map = {(a.admin_id or "").strip(): a.admin_name or a.admin_id
                 for a in db.query(Admin).filter(Admin.company_id == company_id).all()}
    emp_map   = {(e.employee_code or "").strip(): e.employee_name or e.employee_code
                 for e in db.query(Employee).filter(Employee.company_id == company_id).all()}
    out = []
    total_sum = 0.0
    for eid, total, cnt in rows:
        eid = (eid or "").strip()
        name = admin_map.get(eid) or emp_map.get(eid) or (eid or "Unknown")
        typ  = "admin" if eid in admin_map else ("employee" if eid in emp_map else "other")
        amt  = float(total or 0)
        total_sum += amt
        out.append({"id": eid or None, "name": name, "type": typ,
                     "amount": round(amt, 2), "count": int(cnt or 0)})
    return {"success": True, "period": period, "total": round(total_sum, 2),
            "collectors": out}
