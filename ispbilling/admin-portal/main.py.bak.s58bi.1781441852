# === BEGIN employee dashboard stats (auto) ===
@app.get("/api/employee/dashboard/stats")
async def api_employee_dashboard_stats(request: Request, db: Session = Depends(get_db)):
    auth_check = require_employee(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    company_id = request.session.get("company_id")
    employee_code = request.session.get("user_id") or request.session.get("employee_code")
    from database import Customer, Payment
    from datetime import datetime as _dt_e, timedelta as _td_e
    today_str = _dt_e.utcnow().strftime("%Y-%m-%d")
    mo_start = _dt_e.utcnow().strftime("%Y-%m-01")
    end_7 = (_dt_e.utcnow() + _td_e(days=7)).strftime("%Y-%m-%d")

    base_q = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.status != "Deleted",
    )
    try:
        from main import scope_customers_to_employee as _scope
        scoped_q = _scope(base_q, request, db)
    except Exception:
        scoped_q = base_q

    customers = scoped_q.all()
    cust_ids = [c.customer_id for c in customers]
    total = len(customers)
    active = sum(1 for c in customers if (c.status or "").lower() == "active")
    deactive = sum(1 for c in customers
                   if (c.status or "").lower() in ("deactive","deactivated","suspended","disabled"))

    expiring_today = sum(1 for c in customers if (c.end_date or "") == today_str)
    expiring_7d = sum(1 for c in customers if today_str <= (c.end_date or "") <= end_7)
    expired = sum(1 for c in customers if (c.end_date or "") and (c.end_date or "") < today_str)

    # Today's collection — payments by THIS employee_code today
    collected_today = float(db.execute(text(
        "SELECT COALESCE(SUM(amount),0) FROM payments "
        "WHERE company_id=:c AND employee_id=:e AND DATE(paid_at)=DATE(:t)"
    ), {"c": company_id, "e": employee_code, "t": today_str}).scalar() or 0)
    collected_mtd = float(db.execute(text(
        "SELECT COALESCE(SUM(amount),0) FROM payments "
        "WHERE company_id=:c AND employee_id=:e AND paid_at >= :m"
    ), {"c": company_id, "e": employee_code, "m": mo_start}).scalar() or 0)

    recent_cust = sorted(customers, key=lambda x: x.id or 0, reverse=True)[:8]
    recent_pay_rows = []
    if cust_ids:
        from sqlalchemy import bindparam as _bp
        recent_pay_rows = db.execute(text(
            "SELECT p.paid_at, p.customer_id, c.customer_name, p.amount, p.payment_mode "
            "FROM payments p "
            "JOIN customers c ON c.customer_id=p.customer_id AND c.company_id=p.company_id "
            "WHERE p.company_id=:co AND p.employee_id=:e AND p.customer_id IN :ids "
            "ORDER BY p.id DESC LIMIT 8"
        ).bindparams(_bp("ids", expanding=True)),
            {"co": company_id, "e": employee_code, "ids": cust_ids}).fetchall()

    # __S43ZG__ Currently online + total dues for the scoped customers
    online_now_e = 0
    total_dues_e = 0.0
    try:
        if cust_ids:
            from sqlalchemy import bindparam as _bp_e
            online_now_e = int(db.execute(text(
                "SELECT COUNT(*) FROM online_users ou "
                "JOIN customers c ON c.username=ou.username AND c.company_id=ou.company_id "
                "WHERE ou.company_id=:co AND ou.status='Online' AND c.customer_id IN :ids "
                "  AND LOWER(COALESCE(c.status,'')) NOT IN ("
                "    'expired','disabled','deactivated','deactive','suspended',"
                "    'parked','cancelled','canceled','terminated','deleted') "
                "  AND NOT EXISTS (SELECT 1 FROM ip_pools p "
                "                  WHERE p.company_id=ou.company_id "
                "                    AND LOWER(COALESCE(p.role,''))='parking' "
                "                    AND ou.ip_address LIKE substr(p.network,1,instr(p.network,'/')-1) || '%')"
            ).bindparams(_bp_e("ids", expanding=True)),
                {"co": company_id, "ids": cust_ids}).scalar() or 0)
            total_dues_e = float(db.execute(text(
                "SELECT COALESCE(SUM(amt),0) FROM ("
                "  SELECT (COALESCE(inv.iv_total,0)-COALESCE(py.pd_total,0)) AS amt "
                "    FROM customers c "
                "    LEFT JOIN (SELECT customer_id, SUM(total_amount) AS iv_total FROM invoices "
                "               WHERE company_id=:co GROUP BY customer_id) inv "
                "      ON inv.customer_id=c.customer_id "
                "    LEFT JOIN (SELECT customer_id, SUM(amount) AS pd_total FROM payments "
                "               WHERE company_id=:co GROUP BY customer_id) py "
                "      ON py.customer_id=c.customer_id "
                "   WHERE c.company_id=:co AND c.customer_id IN :ids "
                "     AND (c.status IS NULL OR c.status != 'Deleted')"
                ") d WHERE amt > 0"
            ).bindparams(_bp_e("ids", expanding=True)),
                {"co": company_id, "ids": cust_ids}).scalar() or 0)
    except Exception as _ex_zg:
        print(f"[emp-dash-stats] s43zg compute failed: {_ex_zg}")

    return {
        "success": True,
        "stats": {
            "total_customers": total, "active_count": active, "deactive_count": deactive,
            "expiring_today": expiring_today, "expiring_7d": expiring_7d, "expired": expired,
            "collected_today": collected_today, "collected_mtd": collected_mtd,
            "online_now": online_now_e, "total_dues": total_dues_e,
            # __S43ZH__ critical alerts (company-wide) + open complaints (scoped)
            "critical_alerts": int(db.execute(text(
                "SELECT COUNT(*) FROM olt_alerts "
                " WHERE company_id=:c AND COALESCE(acked,0)=0 "
                "   AND LOWER(COALESCE(level,'')) IN ('critical','severe','high')"
            ), {"c": company_id}).scalar() or 0),
            "open_complaints": (
                int(db.execute(text(
                    "SELECT COUNT(*) FROM complaints cp "
                    " WHERE cp.company_id=:c "
                    "   AND COALESCE(cp.status,'') NOT IN ('Resolved','resolved','Closed','closed') "
                    "   AND cp.customer_id IN :ids"
                ).bindparams(_bp_e("ids", expanding=True)),
                    {"c": company_id, "ids": cust_ids}).scalar() or 0)
                if cust_ids else 0
            ),
        },
        "recent_customers": [{
            "customer_id": c.customer_id, "customer_name": c.customer_name or "",
            "customer_phone": c.customer_phone or "", "status": c.status or "",
            "end_date": c.end_date or "",
        } for c in recent_cust],
        "recent_payments": [{
            "paid_at": str(r[0] or ""), "customer_id": r[1] or "",
            "customer_name": r[2] or "", "amount": float(r[3] or 0),
            "payment_mode": r[4] or "",
        } for r in recent_pay_rows],
    }
# === END employee dashboard stats (auto) ===

