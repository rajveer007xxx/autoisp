# _S39R5FIX13_ — expense categories API (was missing — popup dropdowns blank)
@app.get("/api/admin/expenses/categories")
async def api_admin_expenses_categories(request: Request,
                                         db: Session = Depends(get_db)):
    auth = require_admin_or_internal(request)
    if auth: return auth
    company_id = request.session.get("company_id")
    # Default catalog of categories + payment modes for ISP-billing context.
    DEFAULT_CATS  = ["Salary","Office Rent","Internet / Hosting","Equipment",
                     "Petrol","Transport","Marketing","Utilities","Misc"]
    DEFAULT_MODES = ["Cash","UPI","Bank Transfer","Cheque","Credit Card","Debit Card"]
    # Merge with whatever has historically been used (so admins keep their
    # existing taxonomy while gaining the defaults too).
    try:
        rows = db.execute(text(
            "SELECT DISTINCT category FROM expenses WHERE company_id=:c "
            "AND category IS NOT NULL AND category!=''"),
            {"c": company_id}).fetchall()
        used_cats = sorted({r[0] for r in rows if r and r[0]})
    except Exception:
        used_cats = []
    try:
        rows = db.execute(text(
            "SELECT DISTINCT payment_mode FROM expenses WHERE company_id=:c "
            "AND payment_mode IS NOT NULL AND payment_mode!=''"),
            {"c": company_id}).fetchall()
        used_modes = sorted({r[0] for r in rows if r and r[0]})
    except Exception:
        used_modes = []
    return {"success": True,
            "categories": sorted(set(DEFAULT_CATS) | set(used_cats)),
            "payment_modes": sorted(set(DEFAULT_MODES) | set(used_modes))}


