        return auth_check
    
    context = get_admin_context(request, db, active_page="transactions")
    return templates.TemplateResponse("admin_transactions.html", context)

@app.get("/api/transactions/list")
async def list_transactions(request: Request, db: Session = Depends(get_db)):
    """Payment History — every actual money-received record from the Payment table,
    joined with Customer, filterable by mode/date/customer/status."""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    # __S39J__ employees need feat.transaction_history
    if not _emp_has_perm(request, db, "feat.transaction_history"):
        return {"success": False, "message": "Forbidden: missing permission"}

    company_id = request.session.get("company_id")

    from database import Payment, Customer

    try:
        query = db.query(Payment, Customer).outerjoin(
            Customer,
            (Payment.customer_id == Customer.customer_id) & (Customer.company_id == company_id)
        ).filter(Payment.company_id == company_id)

        status = (request.query_params.get('status') or '').strip()
        customer_id = (request.query_params.get('customer_id') or '').strip()
        customer_name = (request.query_params.get('customer_name') or '').strip()
        payment_mode = (request.query_params.get('payment_mode') or '').strip()
        start_date = (request.query_params.get('start_date') or '').strip()
        end_date = (request.query_params.get('end_date') or '').strip()

        if customer_id:
            query = query.filter(Payment.customer_id == customer_id)
        # _S39TX_SEARCH_BACKEND — generic search across tx_no/customer_id/name
        _qval = (request.query_params.get("q") or "").strip()
        if _qval:
            from sqlalchemy import or_
            _qq = "%" + _qval + "%"
            query = query.filter(or_(
                Payment.transaction_no.ilike(_qq),
                Payment.customer_id.ilike(_qq),
                Customer.customer_name.ilike(_qq),
            ))
        if customer_name:
            query = query.filter(Customer.customer_name.ilike(f"%{customer_name}%"))
        # Session 28 — Collected-By filter
        collected_by = (request.query_params.get('collected_by') or '').strip()
        if collected_by:
            query = query.filter(Payment.employee_id == collected_by)
        if payment_mode:
            # case-insensitive match, also treat "Online" as anything non-cash/cheque/bank/upi
            query = query.filter(Payment.payment_mode.ilike(payment_mode))
        if start_date:
            query = query.filter(Payment.paid_at >= start_date)
        if end_date:
            query = query.filter(Payment.paid_at <= end_date + " 23:59:59")

        # __S39I__/K__ Employee scope: only own collections OR payments for
        # customers in his assigned localities AND owned by the same sub_lco
        # (or the admin) as the employee.
        if (request.session.get("user_type") or "").lower() == "employee":
            from sqlalchemy import or_ as _or_emp
            ec = request.session.get("user_id") or ""
            from employee_scope import resolve_locations as _rl_e
            from sqlalchemy import func as _f_e
            _emp_locs = _rl_e(db, company_id,
                int(request.session.get("employee_id") or 0))
            if _emp_locs:
                query = query.filter(_or_emp(
                    Payment.employee_id == ec,
                    _f_e.upper(_f_e.trim(Customer.locality)).in_(_emp_locs),
                ))
            else:
                # No assigned locations → only own collections.
                query = query.filter(Payment.employee_id == ec)
            # __S39K__ Sub-LCO ownership filter on Customer
            from database import Employee as _Emp_k
            _emp_row = db.query(_Emp_k.sub_lco_id).filter(
                _Emp_k.id == int(request.session.get("employee_id") or 0)
            ).first()
            _emp_slco = int(_emp_row[0]) if _emp_row and _emp_row[0] is not None else None
            if _emp_slco is None:
                query = query.filter(Customer.sub_lco_id.is_(None))
            else:
                query = query.filter(Customer.sub_lco_id == _emp_slco)
        results = query.order_by(Payment.paid_at.desc(), Payment.id.desc()).all()

        # _S40zP_lock_filter_payments_ Hide payments of locked sub-lco customers from admin view
        try:
            _hide_p28p = _hidden_cust_ids(request, db)
            if _hide_p28p:
                results = [(p, c) for (p, c) in results
                           if (p.customer_id or '') not in _hide_p28p]
        except Exception:
            pass

        # Session 38u.2 — resolve `employee_id` to a human name.
        # Order: Sub-LCO -> Admin -> Employee -> bare-id-with-prefix.
        from database import Admin, Employee
        admin_rows = db.query(Admin).filter(Admin.company_id == company_id).all()
        admin_map = {(a.admin_id or "").strip(): (a.admin_name or a.admin_id or "")
                     for a in admin_rows}
        emp_rows = db.query(Employee).filter(Employee.company_id == company_id).all()
        emp_map = {(e.employee_code or "").strip(): (e.employee_name or e.employee_code or "")
                   for e in emp_rows}
        # Sub-LCO map (raw SQL because sub_lcos isn't an ORM model in this file)
        slco_map = {}
        try:
            from sqlalchemy import text as _t_sl
            for r in db.execute(_t_sl(
                "SELECT sub_lco_code, name FROM sub_lcos WHERE company_id=:c"
            ), {"c": company_id}).fetchall():
                slco_map[(r[0] or "").strip()] = (r[1] or r[0] or "")
        except Exception as _e_sl:
            print(f"[txn] sub_lco map skipped: {_e_sl}")

        def _resolve_collector(eid):
            eid = (eid or "").strip()
            if not eid:
                return "—"
            if eid in slco_map:
                return f"Sub-LCO · {slco_map[eid]}"
            if eid in emp_map:
                return f"Employee · {emp_map[eid]}"
            if eid in admin_map:
                return f"Admin · {admin_map[eid]}"
            if eid.lower().startswith("slco"):
                return f"Sub-LCO · {eid}"
            if eid.lower().startswith("admin"):
                return f"Admin · {eid}"
            return eid  # fall back to raw id

        transactions = []
        for pay, customer in results:
            paid_at = pay.paid_at
            if paid_at:
                try:
                    # Stored as naive UTC — convert to IST and format 12h AM/PM.
                    from datetime import timezone, timedelta
                    if hasattr(paid_at, "tzinfo"):
                        d = paid_at if paid_at.tzinfo else paid_at.replace(tzinfo=timezone.utc)
                        d = d.astimezone(timezone(timedelta(hours=5, minutes=30)))
                        paid_at_str = d.strftime("%d-%m-%Y %I:%M %p")
                    else:
                        paid_at_str = str(paid_at)
                except Exception:
                    paid_at_str = str(paid_at)
            else:
                paid_at_str = ""
            transactions.append({
                "transaction_no": pay.transaction_no or f"PAY-{pay.id}",
                "payment_id": pay.id,
                "customer_id": (customer.customer_id if customer else pay.customer_id) or "",
                "customer_name": (customer.customer_name if customer else "") or "",
                "customer_phone": (customer.customer_phone if customer else "") or "",
                "customer_email": (customer.customer_email if customer else "") or "",
                "amount": float(pay.amount or 0),
                "payment_mode": pay.payment_mode or "",
                "payment_date": paid_at_str,
                "status": "Success",
                "collected_by": _resolve_collector(pay.employee_id),
                "collected_by_id": (pay.employee_id or "").strip(),
                "remarks": pay.remarks or ""
            })

        # Apply status filter after normalization (all payments are Success today)
        if status:
            transactions = [t for t in transactions if t["status"].lower() == status.lower()]

        return {"success": True, "transactions": transactions}

    except Exception as e:
        return {"success": False, "message": str(e)}


@app.get("/api/invoices/sent-list")
async def list_sent_invoices(request: Request, db: Session = Depends(get_db)):
    """Sent Invoice List — every invoice generated for this company."""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    # __S39J__ employees need feat.invoice
    if not _emp_has_perm(request, db, "feat.invoice"):
        return {"success": False, "message": "Forbidden: missing permission"}

    company_id = request.session.get("company_id")

    from database import Invoice, Customer

    try:
        query = db.query(Invoice, Customer).outerjoin(
            Customer,
            (Invoice.customer_id == Customer.customer_id) & (Customer.company_id == company_id)
        ).filter(Invoice.company_id == company_id)

        status = (request.query_params.get('status') or '').strip()
        customer_name = (request.query_params.get('customer_name') or '').strip()
        start_date = (request.query_params.get('start_date') or '').strip()
        end_date = (request.query_params.get('end_date') or '').strip()

        if start_date:
            query = query.filter(Invoice.issue_date >= start_date)
        if end_date:
            query = query.filter(Invoice.issue_date <= end_date)
        if status:
            query = query.filter(Invoice.status.ilike(status))
        # Session 38u.3 — accept `customer_name` OR `invoice_number` OR
        # generic `q`; OR-join them so a single search box can match either.
        invoice_number = (request.query_params.get('invoice_number') or '').strip()
        q_search = (request.query_params.get('q') or '').strip()
        from sqlalchemy import or_ as _or_q
        if customer_name and invoice_number:
            query = query.filter(_or_q(
                Customer.customer_name.ilike(f"%{customer_name}%"),
                Invoice.invoice_no.ilike(f"%{invoice_number}%"),
            ))
        elif customer_name:
            query = query.filter(_or_q(
                Customer.customer_name.ilike(f"%{customer_name}%"),
                Invoice.invoice_no.ilike(f"%{customer_name}%"),
            ))
        elif invoice_number:
            query = query.filter(Invoice.invoice_no.ilike(f"%{invoice_number}%"))
        if q_search:
            query = query.filter(_or_q(
                Customer.customer_name.ilike(f"%{q_search}%"),
                Invoice.invoice_no.ilike(f"%{q_search}%"),
            ))
        # S33: customer_type (Prepaid/Postpaid) + gst_invoice (yes/no)
        ctype = (request.query_params.get('customer_type') or '').strip()
        gstf  = (request.query_params.get('gst_invoice') or '').strip().lower()
        if ctype:
            query = query.filter(Customer.customer_type.ilike(ctype))
        # __S39I__/K__ Employee scope: invoices of customers in his
        # assigned localities AND owned by the same sub_lco (or admin).
        if (request.session.get("user_type") or "").lower() == "employee":
            from employee_scope import resolve_locations as _rl_e2
            from sqlalchemy import func as _f_e2
            _emp_locs2 = _rl_e2(db, company_id,
                int(request.session.get("employee_id") or 0))
            if _emp_locs2:
                query = query.filter(
                    _f_e2.upper(_f_e2.trim(Customer.locality)).in_(_emp_locs2))
            else:
                query = query.filter(_f_e2.upper(_f_e2.trim(Customer.locality)) == "__NONE__")
            # __S39K__ Sub-LCO ownership filter on Customer
            from database import Employee as _Emp_k2
            _emp_row2 = db.query(_Emp_k2.sub_lco_id).filter(
                _Emp_k2.id == int(request.session.get("employee_id") or 0)
            ).first()
            _emp_slco2 = int(_emp_row2[0]) if _emp_row2 and _emp_row2[0] is not None else None
            if _emp_slco2 is None:
                query = query.filter(Customer.sub_lco_id.is_(None))
            else:
                query = query.filter(Customer.sub_lco_id == _emp_slco2)
        if gstf in ("yes","no"):
            # _S39R5FIX14_ — match exactly the condition the PDF uses to print
            # GSTIN: customer.gst_invoice_needed='YES' AND a non-empty GST no.
            # Otherwise the list and the PDF disagree, which is what the user
            # reported. Tax presence (cgst+sgst+igst > 0) is no longer used
            # because non-GST customers also receive tax-bearing PDFs (FIX7).
            from sqlalchemy import and_ as _and_q14
            _is_gst_inv = _and_q14(
                func.upper(func.coalesce(Customer.gst_invoice_needed, '')) == 'YES',
                func.coalesce(Customer.customer_gst_no, '') != '',
            )
            if gstf == "yes":
                query = query.filter(_is_gst_inv)
            else:
                query = query.filter(~_is_gst_inv)

        results = query.order_by(Invoice.created_at.desc(), Invoice.id.desc()).all()

        # _S40zP_lock_filter_invoices_ hide locked sub-lco invoices
        try:
            _hide_p28i = _hidden_cust_ids(request, db)
            if _hide_p28i:
                results = [(inv, c) for (inv, c) in results
                           if (inv.customer_id or "") not in _hide_p28i]
        except Exception:
            pass

        invoices = []
        for inv, customer in results:
            issue_date = inv.issue_date or ""
            # Try to normalize issue_date to DD-MM-YYYY if it's in ISO
            disp_date = issue_date
            try:
                if issue_date and len(issue_date) >= 10 and issue_date[4] == '-':
                    disp_date = f"{issue_date[8:10]}-{issue_date[5:7]}-{issue_date[0:4]}"
            except Exception:
                pass
            # Session 38u.2 — Amount Due column always shows THIS invoice's
            # total_amount (the original due of this very invoice). It does
            # NOT decrease as payments come in. Keep balance_due separately
            # for any future use.
            _cid = (customer.customer_id if customer else inv.customer_id) or ""
            _invoice_total = float(inv.total_amount or 0)
            # _S39R5j_FIX_ — Amount Due must be STATIC and match the value
            # printed on the PDF ("Total Due Amount") at the moment the
            # invoice was generated. We use the frozen `due_at_issue`
            # snapshot. For legacy invoices that pre-date the snapshot
            # column, fall back to this invoice's own total_amount (still
            # static; never recomputed from later payments).
            _frozen = float(getattr(inv, "due_at_issue", 0) or 0)
            if _frozen <= 0:
                _frozen = _invoice_total
            # _S39R5j_FIX_MANUAL_ — Walk-in/manual invoices have no Customer
            # row. Fall back to the snapshot fields stored on the invoice itself
            # so the Sent Invoices grid shows the recipient name & email.
            _manual_name  = (getattr(inv, "manual_customer_name", "") or "").strip()
            _manual_email = (getattr(inv, "manual_customer_email", "") or "").strip()
            _disp_name  = (customer.customer_name  if customer else "") or _manual_name  or ""
            _disp_email = (customer.customer_email if customer else "") or _manual_email or ""
            _disp_cid   = _cid or ("WALKIN" if _manual_name else "")
            invoices.append({
                "id": inv.id,
                "invoice_no": inv.invoice_no or "",
                "customer_id": _disp_cid,
                "customer_name": _disp_name,
                "customer_email": _disp_email,
                "plan_name": inv.plan_name or "",
                # _S39R5j_FIX_ — frozen "Total Due Amount" exactly as printed on PDF
                "amount": int(round(_frozen)),                           # column shown to user (STATIC)
                "invoice_amount": int(round(_invoice_total)),            # raw this-invoice charge (kept for reference)
                "balance_due": int(round(_frozen)),                      # frozen value (mirror of amount)
                "issue_date": disp_date,
                "due_date": inv.due_date or "",
                "status": (inv.status or "generated").title(),
                "download_url": f"/api/invoices/{inv.id}/download",
                "email_url": f"/api/invoices/{inv.id}/send-email",
                # __S43S_INV_WA__ WhatsApp icon between Email and Delete
                "whatsapp_url": f"/api/invoices/{inv.id}/send-whatsapp",
                "customer_phone": (customer.customer_phone or '') if customer else '',
            })

        return {"success": True, "invoices": invoices}

    except Exception as e:
        return {"success": False, "message": str(e)}

