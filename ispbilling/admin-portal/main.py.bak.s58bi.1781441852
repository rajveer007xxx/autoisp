@app.get("/api/complaints/list")
async def list_complaints(request: Request, db: Session = Depends(get_db)):
    """__S38W_UNIFIED_COMPLAINTS__ - unified complaints+support listing."""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    company_id = request.session.get("company_id")
    from database import Complaint, Customer
    try:
        q = db.query(Complaint).filter(
            Complaint.company_id == company_id,
            Complaint.target_role == "admin")  # __S38X_REPLY_EMAIL__
        status = request.query_params.get("status") or ""
        priority = request.query_params.get("priority") or ""
        kind = request.query_params.get("kind") or ""
        search = (request.query_params.get("search") or "").strip().lower()
        if status:   q = q.filter(Complaint.status == status)
        if priority: q = q.filter(Complaint.priority == priority)
        if kind:     q = q.filter(Complaint.kind == kind)
        rows = q.order_by(Complaint.created_at.desc()).limit(1000).all()
        cust_map = {c.customer_id: c for c in db.query(Customer).filter(
            Customer.company_id == company_id).all()}
        out = []
        for c in rows:
            cu = cust_map.get(c.customer_id)
            name = cu.customer_name if cu else ""
            if search:
                hay = f"{c.ticket_no or ''} {c.subject or ''} {c.description or ''} {name} {c.customer_id or ''}".lower()
                if search not in hay:
                    continue
            out.append({
                "id": c.id, "ticket_no": c.ticket_no,
                "kind": c.kind or "Complaint", "source": c.source or "admin",
                "customer_id": c.customer_id, "customer_name": name,
                "complaint_type": c.complaint_type or "",
                "subject": c.subject or "",
                "priority": c.priority or "Medium",
                "description": c.description or "",
                "status": c.status or "Pending",
                "created_at": _tzu_ist_str(c.created_at, with_suffix=False),
                "resolved_at": (_tzu_ist_str(c.resolved_at, with_suffix=False) or None),  # _TZ_FIX_ROUND2_
            })
        return {"success": True, "complaints": out}
    except Exception as e:
        import traceback; traceback.print_exc()
        return {"success": False, "message": str(e)}

@app.post("/api/complaints/{complaint_id}/update-status")
async def update_complaint_status(complaint_id: int, request: Request, db: Session = Depends(get_db)):
    """Update complaint status"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Complaint
    
    try:
        body = await request.json()
        new_status = body.get('status')
        
        if not new_status:
            return {"success": False, "message": "Status is required"}
        
        complaint = db.query(Complaint).filter(
            Complaint.id == complaint_id,
            Complaint.company_id == company_id
        ).first()
        
        if not complaint:
            return {"success": False, "message": "Complaint not found"}
        
        complaint.status = new_status
        if new_status == 'Resolved':
            complaint.resolved_at = datetime.utcnow()
        
        db.commit()
        
        return {"success": True, "message": "Complaint status updated successfully"}
    
    except Exception as e:
        db.rollback()
        return {"success": False, "message": str(e)}

# __S38W_UNIFIED_COMPLAINTS__ ---------------------------------------------------------
# __S38X_REPLY_EMAIL__ ----- inline SMTP helper ------------------------------
def _s38x_smtp_creds(db):
    # raw SQL because the model may not expose smtp_* cols
    from sqlalchemy import text as _sql_text
    row = db.execute(_sql_text(
        "SELECT smtp_server, smtp_port, smtp_username, smtp_password "
        "FROM superadmins LIMIT 1")).fetchone()
    if not row or not (row[0] and row[2] and row[3]):
        return None
    return {"host": row[0], "port": int(row[1] or 465),
            "user": row[2], "password": row[3]}


def _s38x_notify_reply(db, complaint, admin_msg: str, new_status: str) -> bool:
    """Email the creator of a complaint when the admin replies.
    Returns True if an e-mail was dispatched, False otherwise."""
    import smtplib, ssl, html as _html
    from email.message import EmailMessage
    creds = _s38x_smtp_creds(db)
    if not creds:
        return False

    source = (complaint.source or "").lower()
    to_email = ""
    to_name = ""
    if source == "customer" and complaint.customer_id:
        from database import Customer
        cu = db.query(Customer).filter(Customer.customer_id == complaint.customer_id,
                                        Customer.company_id == complaint.company_id).first()
        if cu:
            to_email = (cu.customer_email or "").strip()
            to_name = cu.customer_name or ""
    elif source == "employee":
        from database import Employee
        # Ticket creator employee is not recorded; try first admin_activity_log entry?
        # Best effort: if complaint has a resolved_by or any ComplaintResponse with
        # role='employee', take that employee_code as the creator.
        from database import ComplaintResponse as _CR
        er = db.query(_CR).filter(_CR.complaint_id == complaint.id,
                                   _CR.responder_role == "employee").first()
        emp_code = er.responder_id if er else None
        if emp_code:
            em = db.query(Employee).filter(Employee.employee_code == emp_code,
                                            Employee.company_id == complaint.company_id).first()
            if em:
                to_email = (em.email or "").strip()
                to_name = em.employee_name or ""
    if not to_email:
        return False

    tno = complaint.ticket_no or complaint.id
    kind = complaint.kind or "Complaint"
    subj = f"[{kind} #{tno}] Update from your ISP support team"
    body_txt = (f"Hi {to_name or ''},\n\n"
                f"Your ISP support team has responded to your {kind.lower()} "
                f"(Ticket #{tno} - {complaint.subject or ''}).\n\n")
    if admin_msg:
        body_txt += f"Message:\n{admin_msg}\n\n"
    if new_status:
        body_txt += f"Status updated to: {new_status}\n\n"
    body_txt += "Thanks,\nAuto ISP Billing\n"

    safe_msg = _html.escape(admin_msg or "").replace("\n", "<br>")
    body_html = f"""<html><body style='font-family:Arial,sans-serif;color:#0f172a;'>
      <h2 style='color:#4f46e5;'>Ticket update</h2>
      <p>Hi <b>{_html.escape(to_name or "")}</b>,</p>
      <p>Your ISP support team has responded to your <b>{_html.escape(kind)}</b>
         (Ticket <code>#{_html.escape(str(tno))}</code> – {_html.escape(complaint.subject or "")}).</p>
      {f"<p><b>New status:</b> <span style='background:#dbeafe;padding:3px 8px;border-radius:4px;'>{_html.escape(new_status)}</span></p>" if new_status else ""}
      {f"<p style='background:#f8fafc;border-left:4px solid #4f46e5;padding:12px 16px;border-radius:6px;'><b>Message from support:</b><br>{safe_msg}</p>" if admin_msg else ""}
      <p style='color:#64748b;font-size:12px;margin-top:24px;'>You can reply to this email or contact your ISP directly.</p>
    </body></html>"""

    em = EmailMessage()
    em["From"] = creds["user"]
    em["To"] = to_email
    em["Subject"] = subj
    em.set_content(body_txt)
    em.add_alternative(body_html, subtype="html")
    try:
        ctx = ssl.create_default_context()
        if creds["port"] == 465:
            with smtplib.SMTP_SSL(creds["host"], creds["port"], context=ctx, timeout=20) as srv:
                srv.login(creds["user"], creds["password"])
                srv.send_message(em)
        else:
            with smtplib.SMTP(creds["host"], creds["port"], timeout=20) as srv:
                srv.ehlo(); srv.starttls(context=ctx)
                srv.login(creds["user"], creds["password"])
                srv.send_message(em)
        print(f"[s38x notify] emailed {to_email} for ticket {tno}")
        return True
    except Exception as e:
        print(f"[s38x notify] send failed: {e}")
        return False


@app.post("/api/complaints/create")
async def api_complaints_create(request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    company_id = request.session.get("company_id")
    role = request.session.get("user_type") or "admin"
    body = await request.json()
    kind = (body.get("kind") or "Complaint").strip()
    if kind not in ("Complaint", "Support"):
        return {"success": False, "message": "Invalid kind"}
    subject = (body.get("subject") or "").strip()
    description = (body.get("description") or "").strip()
    if not subject or not description:
        return {"success": False, "message": "Subject and description required"}
    customer_id = (body.get("customer_id") or "").strip() or None
    priority = (body.get("priority") or "Medium").strip()
    from database import Complaint
    import time as _t
    ticket_no = f"{'T' if kind=='Support' else 'C'}{int(_t.time())}"
    target_role = (body.get("target_role") or "admin").strip()  # __S38X_REPLY_EMAIL__
    if target_role not in ("admin", "superadmin"):
        target_role = "admin"
    c = Complaint(
        company_id=company_id,
        customer_id=customer_id,
        ticket_no=ticket_no,
        complaint_type=body.get("complaint_type") or kind,
        priority=priority,
        subject=subject[:200],
        description=description,
        status="Pending",
        kind=kind,
        source=role,
        target_role=target_role,
    )
    db.add(c); db.commit(); db.refresh(c)
    return {"success": True, "id": c.id, "ticket_no": ticket_no}


@app.get("/api/complaints/{cid}/thread")
async def api_complaints_thread(cid: int, request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    company_id = request.session.get("company_id")
    from database import Complaint, ComplaintResponse
    c = db.query(Complaint).filter(Complaint.id == cid,
                                   Complaint.company_id == company_id).first()
    if not c:
        return {"success": False, "message": "Not found"}
    msgs = db.query(ComplaintResponse).filter(
        ComplaintResponse.complaint_id == cid
    ).order_by(ComplaintResponse.created_at.asc()).all()
    return {"success": True, "messages": [
        {"role": r.responder_role or "admin", "message": r.message,
         "created_at": _tzu_ist_str(r.created_at, with_suffix=False)}
        for r in msgs
    ]}


@app.post("/api/complaints/{cid}/reply")
async def api_complaints_reply(cid: int, request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    company_id = request.session.get("company_id")
    role = request.session.get("user_type") or "admin"
    actor = request.session.get("admin_id") or request.session.get("employee_id") or "system"
    body = await request.json()
    msg = (body.get("message") or "").strip()
    status = (body.get("status") or "").strip()
    from database import Complaint, ComplaintResponse
    c = db.query(Complaint).filter(Complaint.id == cid,
                                   Complaint.company_id == company_id).first()
    if not c:
        return {"success": False, "message": "Not found"}
    if status and status in ("Pending", "In Progress", "Resolved", "Closed"):
        c.status = status
        if status == "Resolved":
            from datetime import datetime as _dt
            c.resolved_at = _dt.utcnow()
            c.resolved_by = actor
    email_sent = False
    if msg:
        cr = ComplaintResponse(complaint_id=cid, responder_role=role,
                                responder_id=str(actor), message=msg)
        db.add(cr)
    db.commit()
    # __S38X_REPLY_EMAIL__ — email the ticket creator on any admin reply
    try:
        email_sent = _s38x_notify_reply(db, c, msg, status)
    except Exception as _e:
        print(f"[s38x notify] failed: {_e}")
    return {"success": True, "email_sent": bool(email_sent)}


