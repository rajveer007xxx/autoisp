    g = _require_customer(request)
    if g: return g
    ctx = _customer_ctx(request, db, "complaints")
    cust = ctx["customer"]
    if cust:
        from database import Complaint
        try:
            tickets = db.query(Complaint).filter(
                Complaint.customer_id == cust.customer_id,
                Complaint.company_id == cust.company_id,
            ).order_by(Complaint.id.desc()).limit(30).all()
