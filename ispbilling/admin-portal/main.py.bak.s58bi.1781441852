# === Session 31 data-management ===
import os as _s31_os, io as _s31_io, csv as _s31_csv, shutil as _s31_shutil
import re as _s31_re
import sqlite3 as _s31_sqlite3, gzip as _s31_gzip, tempfile as _s31_tempfile
from datetime import datetime as _s31_dt
from fastapi import UploadFile as _S31UploadFile, File as _S31File, Form as _S31Form
from fastapi import Response as _S31Response

# Activity-log table (idempotent create)
def _s31_ensure_log_table():
    try:
        from database import engine
        with engine.begin() as conn:
            conn.exec_driver_sql("""
                CREATE TABLE IF NOT EXISTS data_mgmt_log(
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    company_id TEXT,
                    action TEXT,
                    kind TEXT,
                    records INTEGER DEFAULT 0,
                    status TEXT,
                    filename TEXT,
                    message TEXT,
                    created_by TEXT,
                    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                )
            """)
    except Exception as e:
        print(f"[S31] log table create failed: {e}")
_s31_ensure_log_table()

def _s31_log(company_id, action, kind, records, status, filename, message, actor):
    try:
        from database import engine
        with engine.begin() as conn:
            conn.exec_driver_sql(
                "INSERT INTO data_mgmt_log(company_id,action,kind,records,status,filename,message,created_by) "
                "VALUES (?,?,?,?,?,?,?,?)",
                (company_id, action, kind, int(records or 0), status, filename or "", message or "", actor or ""),
            )
    except Exception as e:
        print(f"[S31] log insert failed: {e}")

# Map each data-kind to its export endpoint plus its import schema.
# Import schema = {header_text_lower: (model_attr, cast)}. We normalise headers
# by lowering & stripping & replacing spaces/underscores, then look up.
def _s31_hdrkey(s):
    return _s31_re.sub(r"[^a-z0-9]+", "", (s or "").strip().lower())

def _s31_f(val):
    try: return float(val) if val not in (None, "", "None") else 0.0
    except Exception: return 0.0

def _s31_i(val):
    try: return int(float(val)) if val not in (None, "", "None") else 0
    except Exception: return 0

def _s31_s(val):
    return "" if val is None else str(val).strip()

