# _S39EMP_TRAIL_API
@app.get("/api/employee-trail")
async def api_employee_trail(request: Request,
                              employee_id: int = 0,
                              minutes: int = 120,
                              db: Session = Depends(get_db)):
    """Polyline points for the Track-Employees map."""
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id", "")
    if not employee_id:
        return JSONResponse({"ok": False, "error": "employee_id_required"},
                            status_code=400)
    minutes = max(5, min(int(minutes or 120), 1440))
    sql = ("SELECT latitude, longitude, accuracy, recorded_at "
           "  FROM employee_location_history "
           " WHERE employee_id = :eid AND company_id = :cid "
           "   AND recorded_at >= datetime('now', :mins) "
           " ORDER BY recorded_at ASC")
    from sqlalchemy import text as _t
    rows = db.execute(_t(sql), {"eid": employee_id, "cid": company_id,
                                  "mins": f"-{minutes} minutes"}).fetchall()
    return JSONResponse({"ok": True, "points": [
        {"lat": r[0], "lng": r[1], "acc": r[2], "at": r[3]} for r in rows
    ]})


