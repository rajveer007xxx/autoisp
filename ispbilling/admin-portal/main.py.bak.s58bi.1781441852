# S38h — self-service password reset  __S38H_PASSWORD_RESET__
# __S38J_CAPTCHA_AND_STRICT_FIELDS__ — captcha table setup + generator
def _s38j_ensure_captcha_table(db):
    """Create the captcha table on first use."""
    from sqlalchemy import text as _t
    db.execute(_t(
        "CREATE TABLE IF NOT EXISTS password_reset_captchas ("
        " id INTEGER PRIMARY KEY AUTOINCREMENT,"
        " code VARCHAR(16) NOT NULL,"
        " expires_at DATETIME NOT NULL,"
        " is_used BOOLEAN NOT NULL DEFAULT 0,"
        " created_at DATETIME NOT NULL)"))
    db.commit()


def _s38j_make_captcha_svg(code: str) -> str:
    """Render a 5-char code as a small SVG image with noise + wavy text."""
    import random as _rnd
    W, H = 160, 52
    out = [f'<svg xmlns="http://www.w3.org/2000/svg" width="{W}" height="{H}" '
           f'viewBox="0 0 {W} {H}" style="background:#f1f5f9;border-radius:6px;">']
    # background noise: 30 random circles
    for _ in range(30):
        x = _rnd.randint(0, W); y = _rnd.randint(0, H)
        r = _rnd.randint(1, 2)
        c = _rnd.choice(["#cbd5e1", "#94a3b8", "#e2e8f0"])
        out.append(f'<circle cx="{x}" cy="{y}" r="{r}" fill="{c}"/>')
    # 3 wavy decoys lines
    for _ in range(3):
        x1 = _rnd.randint(0, 20);     y1 = _rnd.randint(5, H-5)
        x2 = _rnd.randint(W-20, W);   y2 = _rnd.randint(5, H-5)
        out.append(f'<path d="M{x1} {y1} Q{W//2} {_rnd.randint(0,H)} {x2} {y2}" '
                   f'stroke="{_rnd.choice(["#64748b","#7c3aed","#0891b2"])}" '
                   f'stroke-width="1.5" fill="none" opacity="0.55"/>')
    # Each character tilted and coloured
    step = (W - 20) / max(1, len(code))
    for i, ch in enumerate(code):
        x = 10 + int(step * i) + _rnd.randint(-2, 2)
        y = 36 + _rnd.randint(-4, 4)
        rot = _rnd.randint(-20, 20)
        color = _rnd.choice(["#0f172a", "#1e3a8a", "#6b21a8", "#115e59", "#9d174d"])
        out.append(
            f'<text x="{x}" y="{y}" font-size="28" font-family="Georgia,serif" '
            f'font-weight="bold" fill="{color}" '
            f'transform="rotate({rot} {x} {y})">{ch}</text>')
    out.append("</svg>")
    return "".join(out)


@app.get("/api/auth/captcha/new")
async def api_auth_captcha_new(request: Request, db: Session = Depends(get_db)):
    """Generate a fresh captcha; store its expected code in the DB and
    return the captcha ID + SVG markup so the client can render it
    inline without a separate image request."""
    import random as _rnd, string as _str
    from datetime import datetime as _dt, timedelta as _td
    from sqlalchemy import text as _t
    _s38j_ensure_captcha_table(db)
    # Exclude visually ambiguous chars (0, O, 1, I, L)
    alphabet = "ABCDEFGHJKMNPQRSTUVWXYZ23456789"
    code = "".join(_rnd.choice(alphabet) for _ in range(5))
    now = _dt.utcnow()
    res = db.execute(_t(
        "INSERT INTO password_reset_captchas (code, expires_at, is_used, created_at) "
        "VALUES (:c, :exp, 0, :now)"),
        {"c": code, "exp": now + _td(minutes=5), "now": now})
    db.commit()
    cap_id = res.lastrowid
    svg = _s38j_make_captcha_svg(code)
    return {"captcha_id": cap_id, "svg": svg, "ttl_seconds": 300}


def _s38j_validate_captcha(db, captcha_id, captcha_text: str) -> bool:
    """Return True if the given captcha_id matches the text (case-insensitive)
    and hasn't been used / expired.  Marks it consumed on success."""
    from datetime import datetime as _dt
    from sqlalchemy import text as _t
    if not captcha_id or not (captcha_text or "").strip():
        return False
    try:
        cid = int(captcha_id)
    except Exception:
        return False
    row = db.execute(_t(
        "SELECT id, code, expires_at, is_used FROM password_reset_captchas "
        "WHERE id = :i"), {"i": cid}).fetchone()
    if not row:
        return False
    _id, expected, exp, used = row[0], row[1], row[2], row[3]
    if used:
        return False
    if isinstance(exp, str):
        try: exp = _dt.fromisoformat(exp)
        except Exception: return False
    if exp <= _dt.utcnow():
        return False
    if (captcha_text or "").strip().upper() != (expected or "").strip().upper():
        return False
    # Single-use — mark consumed
    db.execute(_t("UPDATE password_reset_captchas SET is_used=1 WHERE id=:i"),
               {"i": _id})
    db.commit()
    return True


def _s38h_lookup_user_email(db, user_type: str, identifier: str, company_id: str = ""):
    """Resolve (row, email, company_id) for a given user-type + identifier.
    `identifier` may be their login-ID OR their registered email."""
    from database import Admin, Employee, Customer, SuperAdmin
    ut = (user_type or "").lower().strip()
    ident = (identifier or "").strip()
    if not ident:
        return None, "", ""
    if ut == "superadmin":
        row = db.query(SuperAdmin).filter(
            (SuperAdmin.superadmin_id == ident) | (SuperAdmin.email == ident)
        ).first()
        if not row: return None, "", ""
        return row, (row.email or ""), ""
    if ut == "admin":
        q = db.query(Admin).filter(
            (Admin.admin_id == ident) | (Admin.admin_email == ident)
        )
        if company_id: q = q.filter(Admin.company_id == company_id)
        row = q.first()
        if not row: return None, "", ""
        return row, (row.admin_email or ""), (row.company_id or "")
    if ut == "employee":
        q = db.query(Employee).filter(
            (Employee.employee_code == ident) | (Employee.email == ident)
        )
        if company_id: q = q.filter(Employee.company_id == company_id)
        row = q.first()
        if not row: return None, "", ""
        return row, (row.email or ""), (row.company_id or "")
    if ut == "customer":
        q = db.query(Customer).filter(
            (Customer.username == ident) | (Customer.customer_email == ident)
            | (Customer.customer_id == ident)
        )
        if company_id: q = q.filter(Customer.company_id == company_id)
        row = q.first()
        if not row: return None, "", ""
        return row, (row.customer_email or ""), (row.company_id or "")
    return None, "", ""


def _s38h_send_reset_email(db, to_email: str, reset_url: str, user_type: str,
                           display_name: str, company_id: str = "") -> str:
    """Send the reset link via the tenant's SMTP (or superadmin_settings for SA).
    Returns "" on success, otherwise error string."""
    import smtplib, ssl
    from email.message import EmailMessage
    from email.utils import formataddr
    from database import Company
    comp_name = "Auto ISP Billing"
    smtp_host = smtp_port = smtp_user = smtp_pass = None
    if company_id:
        comp = db.query(Company).filter(Company.company_id == company_id).first()
        if comp:
            comp_name = comp.company_name or comp_name
            smtp_host = comp.smtp_server or None
            smtp_port = comp.smtp_port or None
            smtp_user = comp.smtp_username or None
            smtp_pass = comp.smtp_password or None
    if not smtp_host or not smtp_user or not smtp_pass:
        # Fall back: superadmin's SMTP config (set in SA profile).
        from sqlalchemy import text as _sql_text
        sa_row = db.execute(_sql_text(
            "SELECT smtp_server, smtp_port, smtp_username, smtp_password "
            "FROM superadmins WHERE smtp_server IS NOT NULL AND smtp_server != '' "
            "AND smtp_username IS NOT NULL AND smtp_password IS NOT NULL LIMIT 1")
        ).fetchone()
        if sa_row:
            smtp_host = smtp_host or sa_row[0]
            smtp_port = smtp_port or sa_row[1] or 587
            smtp_user = smtp_user or sa_row[2]
            smtp_pass = smtp_pass or sa_row[3]
        # Env-vars fall back after SA (not commonly set here)
        smtp_host = smtp_host or os.environ.get("SMTP_HOST")
        smtp_port = smtp_port or int(os.environ.get("SMTP_PORT") or 587)
        smtp_user = smtp_user or os.environ.get("SMTP_USER")
        smtp_pass = smtp_pass or os.environ.get("SMTP_PASSWORD")
        # Last resort: any company with SMTP configured
        if not smtp_user or not smtp_pass:
            comp = db.query(Company).filter(
                Company.smtp_username.isnot(None),
                Company.smtp_password.isnot(None)).first()
            if comp:
                comp_name = comp.company_name or comp_name
                smtp_host = smtp_host or comp.smtp_server
                smtp_port = smtp_port or (comp.smtp_port or 587)
                smtp_user = smtp_user or comp.smtp_username
                smtp_pass = smtp_pass or comp.smtp_password
    if not (smtp_host and smtp_user and smtp_pass):
        return "No SMTP configured — cannot send password reset email"

    msg = EmailMessage()
    msg["Subject"] = f"{comp_name} — Password Reset Link"
    msg["From"] = formataddr((comp_name + " - Support", smtp_user))
    msg["To"] = to_email
    body = (
        f"Hello {display_name or 'there'},\n\n"
        f"We received a request to reset the password for your {user_type.upper()} "
        f"account on {comp_name}.\n\n"
        f"Click the link below (valid for 60 minutes, single use):\n\n"
        f"  {reset_url}\n\n"
        f"If you did not request this, you can ignore this email — "
        f"your existing password will keep working.\n\n"
        f"— {comp_name}\n"
    )
    msg.set_content(body)
    html = (
        f"<p>Hello <b>{display_name or 'there'}</b>,</p>"
        f"<p>We received a request to reset the password for your "
        f"<b>{user_type.upper()}</b> account on <b>{comp_name}</b>.</p>"
        f"<p style='margin:22px 0'>"
        f"<a href='{reset_url}' "
        f"style='background:#3c8dbc;color:#fff;padding:10px 22px;"
        f"border-radius:6px;text-decoration:none;font-weight:600'>"
        f"Reset password</a></p>"
        f"<p style='color:#666;font-size:12px'>"
        f"Valid for 60 minutes · Single use. If the button doesn't work, "
        f"copy this link:<br><code>{reset_url}</code></p>"
        f"<p style='color:#999;font-size:12px'>If you did not request this "
        f"reset, you can ignore this email — your existing password will "
        f"keep working.</p>"
        f"<hr><p style='color:#999;font-size:12px'>&mdash; {comp_name}</p>"
    )
    msg.add_alternative(html, subtype="html")
    try:
        port = int(smtp_port or 587)
        if port == 465:
            with smtplib.SMTP_SSL(smtp_host, port, timeout=15) as srv:
                srv.login(smtp_user, smtp_pass)
                srv.send_message(msg)
        else:
            with smtplib.SMTP(smtp_host, port, timeout=15) as srv:
                srv.starttls(context=ssl.create_default_context())
                srv.login(smtp_user, smtp_pass)
                srv.send_message(msg)
        return ""
    except Exception as e:
        return f"SMTP send failed: {e}"


@app.post("/api/auth/password-reset/request")
async def api_password_reset_request(request: Request, db: Session = Depends(get_db)):
    """Public endpoint — anyone can request a reset link.  We always return
    a generic success to avoid leaking which user IDs exist."""
    import secrets as _sec
    from datetime import datetime as _dt, timedelta as _td
    try:
        body = await request.json()
    except Exception:
        form = await request.form()
        body = {k: form.get(k) for k in form}
    user_type  = (body.get("userType") or body.get("user_type") or "").strip().lower()
    company_id = (body.get("companyId") or body.get("company_id") or "").strip()
    username   = (body.get("username") or "").strip()
    email_in   = (body.get("email") or "").strip()
    captcha_id = body.get("captcha_id") or body.get("captchaId")
    captcha_tx = (body.get("captcha_text") or body.get("captchaText") or "").strip()

    if user_type not in ("superadmin", "admin", "employee", "customer", "sub_lco"):  # _S39R5I_PWRESET_SUBLCO
        return JSONResponse({"success": False,
            "message": "Please select a portal."}, status_code=400)

    # 1) Captcha — ALWAYS required (S38j)
    if not _s38j_validate_captcha(db, captcha_id, captcha_tx):
        return JSONResponse({"success": False,
            "message": "Incorrect or expired captcha. Please try again.",
            "refresh_captcha": True}, status_code=400)

    # 2) Per-portal field validation
    if user_type == "superadmin":
        if not email_in:
            return JSONResponse({"success": False,
                "message": "Please enter your registered email."}, status_code=400)
    elif user_type in ("admin", "employee", "sub_lco"):
        if not (company_id and username and email_in):
            return JSONResponse({"success": False,
                "message": "Please enter Company ID, Username and Email."},
                status_code=400)
    elif user_type == "customer":
        if not (username and email_in):
            return JSONResponse({"success": False,
                "message": "Please enter Username and Email."}, status_code=400)

    # 3) Look up row + sanity-check that username + email + company_id all
    # belong to the SAME account before we issue a token.
    row, resolved_email = None, ""
    if user_type == "superadmin":
        from database import SuperAdmin
        row = db.query(SuperAdmin).filter(SuperAdmin.email == email_in).first()
        resolved_email = (row.email if row else "")
    elif user_type == "admin":
        from database import Admin
        row = db.query(Admin).filter(
            Admin.company_id == company_id,
            Admin.admin_id == username,
            Admin.admin_email == email_in).first()
        resolved_email = (row.admin_email if row else "")
    elif user_type == "employee":
        from database import Employee
        row = db.query(Employee).filter(
            Employee.company_id == company_id,
            Employee.employee_code == username,
            Employee.email == email_in).first()
        resolved_email = (row.email if row else "")
    elif user_type == "sub_lco":
        from database import SubLco
        row = db.query(SubLco).filter(
            SubLco.company_id == company_id,
            SubLco.sub_lco_code == username,
            SubLco.email == email_in).first()
        resolved_email = (row.email if row else "")
    elif user_type == "customer":
        from database import Customer
        row = db.query(Customer).filter(
            (Customer.username == username) | (Customer.customer_id == username),
            Customer.customer_email == email_in).first()
        resolved_email = (row.customer_email if row else "")

    generic_ok = {"success": True,
        "message": "If an account matches, a reset link has been sent to the registered email."}
    if not row or not resolved_email:
        return generic_ok
    email = resolved_email
    resolved_cid = getattr(row, "company_id", "") or ""

    # S38i rate-limit: max 3 reset requests per email per rolling hour.  __S38I_RATE_LIMIT__
    from sqlalchemy import text as _sql_text_rl
    recent_count = db.execute(_sql_text_rl(
        "SELECT COUNT(*) FROM password_resets "
        "WHERE email = :e AND created_at >= datetime('now', '-1 hour')"),
        {"e": email}).scalar() or 0
    if int(recent_count) >= 3:
        # Deliberately NOT generic — give the real user a helpful hint.
        return JSONResponse({"success": False,
            "message": "Too many reset requests for this email in the last hour. "
                       "Please wait before trying again (max 3 per hour)."},
            status_code=429)

    # Generate opaque token (URL-safe base64, 32 bytes)
    token = _sec.token_urlsafe(32)
    expires = _dt.utcnow() + _td(minutes=60)

    # Invalidate any pending resets for this email+user_type to prevent stockpiling
    from sqlalchemy import text as _sql_text
    db.execute(_sql_text(
        "UPDATE password_resets SET is_used=1 WHERE email=:e AND user_type=:ut AND is_used=0"),
        {"e": email, "ut": user_type})
    # __S39D__ scope reset to a single account (multi-admins can share email)
    _subject_id = ""
    if user_type == "admin":
        _subject_id = getattr(row, "admin_id", "") or ""
    elif user_type == "employee":
        _subject_id = getattr(row, "employee_code", "") or ""
    elif user_type == "customer":
        _subject_id = getattr(row, "customer_id", "") or ""
    elif user_type == "superadmin":
        _subject_id = getattr(row, "superadmin_id", "") or ""
    db.execute(_sql_text(
        "INSERT INTO password_resets "
        "(email, user_type, otp_code, expires_at, is_used, created_at, "
        " company_id, subject_id) "
        "VALUES (:e, :ut, :tk, :exp, 0, :now, :cid, :sid)"),
        {"e": email, "ut": user_type, "tk": token, "exp": expires,
         "now": _dt.utcnow(), "cid": resolved_cid or "", "sid": _subject_id})
    db.commit()

    # Build the reset URL using the request's own origin (scheme + host)
    scheme = request.headers.get("x-forwarded-proto") or request.url.scheme
    host = request.headers.get("host") or request.url.netloc
    base = f"{scheme}://{host}"
    reset_url = f"{base}/password-reset/{token}?t={user_type}"

    display_name = ""
    _fallback = username or email_in
    if user_type == "superadmin":
        display_name = getattr(row, "superadmin_name", "") or _fallback
    elif user_type == "admin":
        display_name = getattr(row, "admin_name", "") or _fallback
    elif user_type == "employee":
        display_name = getattr(row, "employee_name", "") or _fallback
    elif user_type == "customer":
        display_name = getattr(row, "customer_name", "") or _fallback

    err = _s38h_send_reset_email(db, email, reset_url, user_type,
                                 display_name, resolved_cid)
    if err:
        # Do NOT leak mail-delivery failure to unauthenticated users beyond a
        # soft message; log server-side.
        print(f"[password-reset] SMTP error for {email}: {err}")
        return {"success": False,
                "message": f"Could not send the reset email ({err}). "
                           f"Please contact your administrator."}
    return generic_ok


@app.get("/password-reset/{token}", response_class=HTMLResponse)
async def page_password_reset(token: str, request: Request,
                              t: str = "", db: Session = Depends(get_db)):
    """Render the new-password form. Token validity is checked both here
    (for a friendly error page) and again on submit (authoritative)."""
    from datetime import datetime as _dt
    from sqlalchemy import text as _sql_text
    _row = db.execute(_sql_text(
        "SELECT email, user_type, expires_at, is_used FROM password_resets WHERE otp_code=:tk LIMIT 1"),
        {"tk": token}).fetchone()
    class _PR:
        def __init__(self, r):
            self.email = r[0] if r else ''
            self.user_type = r[1] if r else ''
            self.expires_at = _dt.fromisoformat(r[2]) if (r and r[2]) else _dt(1970,1,1)
            self.is_used = bool(r[3]) if r else False
    pr = _PR(_row) if _row else None
    valid = bool(pr) and not pr.is_used and pr.expires_at > _dt.utcnow()
    return templates.TemplateResponse("password_reset.html", {
        "request": request,
        "token": token,
        "user_type": (pr.user_type if pr else (t or "")),
        "email_masked": (pr.email[:3] + "***@" + pr.email.split("@")[-1]) if (pr and pr.email and "@" in pr.email) else "",
        "valid": valid,
        "error": ("" if valid else
                  ("This reset link has already been used." if pr and pr.is_used
                   else "This reset link is invalid or has expired.")),
    })


@app.post("/api/auth/password-reset/confirm")
async def api_password_reset_confirm(request: Request, db: Session = Depends(get_db)):
    """Set the new password for the user bound to the token."""
    import bcrypt
    from datetime import datetime as _dt
    from database import Admin, Employee, Customer, SuperAdmin
    from sqlalchemy import text as _sql_text
    body = await request.json()
    token = (body.get("token") or "").strip()
    new_pw = body.get("password") or ""
    confirm = body.get("confirm") or ""
    if not token or not new_pw:
        return JSONResponse({"success": False, "message": "Missing token or password"},
                            status_code=400)
    if new_pw != confirm:
        return JSONResponse({"success": False, "message": "Passwords do not match."},
                            status_code=400)
    if len(new_pw) < 6:
        return JSONResponse({"success": False, "message": "Password must be at least 6 characters."},
                            status_code=400)

    _row = db.execute(_sql_text(
        "SELECT id, email, user_type, expires_at, is_used, "
        "       COALESCE(company_id, ''), COALESCE(subject_id, '') "
        "FROM password_resets WHERE otp_code=:tk LIMIT 1"),
        {"tk": token}).fetchone()
    if not _row:
        return JSONResponse({"success": False, "message": "Invalid reset link."},
                            status_code=400)
    _pr_id, _pr_email, _pr_ut, _pr_exp, _pr_used, _pr_cid, _pr_sid = _row
    if _pr_used:
        return JSONResponse({"success": False,
            "message": "This link has already been used."}, status_code=400)
    _expires_at = _dt.fromisoformat(_pr_exp) if isinstance(_pr_exp, str) else _pr_exp
    if _expires_at <= _dt.utcnow():
        return JSONResponse({"success": False, "message": "This link has expired."},
                            status_code=400)

    hashed = bcrypt.hashpw(new_pw.encode("utf-8"), bcrypt.gensalt()).decode("utf-8")
    ut = _pr_ut
    # __S39D__ scope by company_id + subject_id when present so we update
    # ONLY the specific account that requested the reset (not every admin
    # that happens to share the same email).
    if ut == "superadmin":
        if _pr_sid:
            upd_sql = ("UPDATE superadmins SET password_hash=:h "
                       "WHERE email=:e AND superadmin_id=:sid")
            params = {"h": hashed, "e": _pr_email, "sid": _pr_sid}
        else:
            upd_sql = "UPDATE superadmins SET password_hash=:h WHERE email=:e"
            params = {"h": hashed, "e": _pr_email}
    elif ut == "admin":
        if _pr_cid and _pr_sid:
            upd_sql = ("UPDATE admins SET password_hash=:h "
                       "WHERE admin_email=:e AND company_id=:cid AND admin_id=:sid")
            params = {"h": hashed, "e": _pr_email, "cid": _pr_cid, "sid": _pr_sid}
        else:
            upd_sql = "UPDATE admins SET password_hash=:h WHERE admin_email=:e"
            params = {"h": hashed, "e": _pr_email}
    elif ut == "employee":
        if _pr_cid and _pr_sid:
            upd_sql = ("UPDATE employees SET password_hash=:h "
                       "WHERE email=:e AND company_id=:cid AND employee_code=:sid")
            params = {"h": hashed, "e": _pr_email, "cid": _pr_cid, "sid": _pr_sid}
        else:
            upd_sql = "UPDATE employees SET password_hash=:h WHERE email=:e"
            params = {"h": hashed, "e": _pr_email}
    elif ut == "customer":
        if _pr_sid:
            upd_sql = ("UPDATE customers SET password_hash=:h "
                       "WHERE customer_email=:e AND customer_id=:sid")
            params = {"h": hashed, "e": _pr_email, "sid": _pr_sid}
        else:
            upd_sql = "UPDATE customers SET password_hash=:h WHERE customer_email=:e"
            params = {"h": hashed, "e": _pr_email}
    else:
        return JSONResponse({"success": False, "message": "Unknown user type."},
                            status_code=400)
    res = db.execute(_sql_text(upd_sql), params)
    if (res.rowcount or 0) == 0:
        db.rollback()
        return JSONResponse({"success": False,
            "message": "Account not found. Please contact support."},
            status_code=404)
    db.execute(_sql_text("UPDATE password_resets SET is_used=1 WHERE id=:i"), {"i": _pr_id})
    db.commit()
    return {"success": True, "message": "Password updated. You can now sign in."}


@app.post("/api/auth/login")
async def login(
    request: Request,
    userType: str = Form(...),
    userId: str = Form(...),
    password: str = Form(...),
    companyId: str = Form(None),
    remember: str = Form(None),  # __S39D__ Remember-me
    db: Session = Depends(get_db)
):
    # __S39D__ Remember-me flag: presence/truthy => remember 30d
    request.session["__s39d_remember"] = bool(remember and str(remember).lower() not in ("0", "false", "off", ""))
    
    user = None
    
    if userType == "superadmin":
        user = authenticate_superadmin(db, userId, password)
        if user:
            request.session["user_id"] = user.superadmin_id
            request.session["user_type"] = "superadmin"
            request.session["user_name"] = user.superadmin_name or "Super Administrator"
            request.session["superadmin_id"] = user.id
            return JSONResponse({"success": True, "redirect": "/superadmin/dashboard"})
    
    elif userType == "admin":
        if not companyId:
            return JSONResponse({"success": False, "message": "Company ID is required for Admin login"}, status_code=400)
        user = authenticate_admin(db, companyId, userId, password)
        # s36d-totp-check
        if user and getattr(user, "totp_enabled", 0):
            otp = (await request.form()).get("totp") if request.method == "POST" else None
            # Accept either a body field or header (for API clients)
            if not otp:
                otp = request.headers.get("x-totp-code", "").strip()
            if not otp:
                return JSONResponse({"success": False, "mfa_required": True,
                    "message": "TOTP code required"}, status_code=401)
            try:
                import pyotp
                tot = pyotp.TOTP(user.totp_secret)
                otp_stripped = str(otp).strip()
                if not tot.verify(otp_stripped, valid_window=1):
                    # s36f: fall back to recovery code consumption.
                    if _s36f_check_recovery(user, otp_stripped):
                        db.commit()
                    else:
                        return JSONResponse({"success": False, "mfa_required": True,
                            "message": "Invalid TOTP code"}, status_code=401)
            except Exception as _e:
                return JSONResponse({"success": False, "mfa_required": True,
                    "message": f"TOTP check failed: {_e}"}, status_code=401)
        if user:
            from database import Company
            from datetime import datetime as _dt_now
            company = db.query(Company).filter(Company.company_id == user.company_id).first()
            balance = float(company.balance_amount or 0) if company else 0.0
            status_val = (company.status or "Active") if company else "Active"
            # Auto-deactivate if the subscription expiry has passed. Admins whose
            # expiry was extended manually by the superadmin stay Active (and can
            # log in even while carrying a due balance) right up until end_date.
            expired = False
            if company and company.end_date:
                try:
                    end_dt = company.end_date if isinstance(company.end_date, _dt_now) else _dt_now.fromisoformat(str(company.end_date))
                except Exception:
                    end_dt = None
                if end_dt and end_dt.date() < _dt_now.now().date():
                    expired = True
                    if status_val.lower() == "active":
                        company.status = "Deactivated"
                        status_val = "Deactivated"
                        try:
                            db.commit()
                        except Exception:
                            db.rollback()
            # Only block when the account is NOT Active. Admins with due but still
            # Active (and non-expired) can log in.
            is_blocked = status_val.lower() != "active"
            if is_blocked:
                has_due = balance > 0
                sa_row = db.execute(text("SELECT upi_id, qr_code_path, contact_email, contact_number, bank_name, branch_code, account_no, branch_location, ifsc_code FROM superadmin_settings WHERE id=1")).fetchone()
                sa_user = db.execute(text("SELECT email, mobile FROM superadmins WHERE id=1")).fetchone()
                upi_id = sa_row[0] if sa_row else None
                qr_code_path = sa_row[1] if sa_row else None
                contact_email = (sa_row[2] if sa_row else None) or (sa_user[0] if sa_user else None)
                contact_phone = (sa_row[3] if sa_row else None) or (sa_user[1] if sa_user else None)
                bank_name = sa_row[4] if sa_row else None
                branch_code = sa_row[5] if sa_row else None
                account_no = sa_row[6] if sa_row else None
                branch_location = sa_row[7] if sa_row else None
                ifsc_code = sa_row[8] if sa_row else None
                block_reasons = [f"Account status is {status_val}"]
                if has_due:
                    block_reasons.append(f"Due amount pending: \u20b9{balance:,.2f}")
                if has_due:
                    message = "Your admin account has been deactivated due to a pending due amount. Clear the outstanding balance to regain access."
                else:
                    message = f"Your admin account has been {status_val}. Please contact the superadmin support team for assistance."
                return JSONResponse({
                    "success": False,
                    "blocked": True,
                    "has_due": has_due,
                    "message": message,
                    "reasons": block_reasons,
                    "status": status_val,
                    "due_amount": round(balance, 2),
                    "company_id": user.company_id,
                    "company_name": company.company_name if company else None,
                    "admin_name": user.admin_name,
                    "admin_email": user.admin_email,
                    "upi_id": upi_id,
                    "qr_code_path": qr_code_path,
                    "bank_name": bank_name,
                    "branch_code": branch_code,
                    "account_no": account_no,
                    "branch_location": branch_location,
                    "ifsc_code": ifsc_code,
                    "superadmin_contact_email": contact_email,
                    "superadmin_contact_phone": contact_phone,
                })
            request.session["user_id"] = user.admin_id
            request.session["user_type"] = "admin"
            request.session["user_name"] = user.admin_name
            request.session["company_id"] = user.company_id
            try:
                from login_tracking import record_login as _rl
                _rl("admin", user.admin_id, user.company_id, user.admin_name,
                    request.client.host if request.client else None,
                    request.headers.get("user-agent"))
            except Exception:
                pass
            return JSONResponse({"success": True, "redirect": "/admin/dashboard"})
    
    elif userType == "employee":
        if not companyId:
            return JSONResponse({"success": False, "message": "Company ID is required for Employee login"}, status_code=400)
        user = authenticate_employee(db, companyId, userId, password)
        if user:
            request.session["user_id"] = user.employee_code
            request.session["user_type"] = "employee"
            request.session["user_name"] = user.employee_name
            request.session["company_id"] = user.company_id
            request.session["employee_id"] = user.id
            try:
                from login_tracking import record_login as _rl
                _rl("employee", user.employee_code, user.company_id,
                    user.employee_name,
                    request.client.host if request.client else None,
                    request.headers.get("user-agent"))
            except Exception:
                pass
            return JSONResponse({"success": True, "redirect": "/employee/dashboard"})
    
    elif userType == "customer":
        user = authenticate_customer(db, userId, password)
        if user:
            request.session["user_id"] = user.customer_id
            request.session["user_type"] = "customer"
            request.session["user_name"] = user.customer_name
            # __S39M__ extra session keys for the modern user portal
            request.session["company_id"] = user.company_id
            request.session["customer_pk"] = user.id
            return JSONResponse({"success": True, "redirect": "/customer/dashboard"})

    elif userType == "sub_lco":
        # Session 38y — Sub-LCO (franchisee) login
        if not companyId:
            return JSONResponse({"success": False, "message": "Company ID is required for Sub-LCO login"}, status_code=400)
        try:
            import sub_lco as _slm
            row = _slm.authenticate_sub_lco(db, companyId, userId, password)
            if row:
                request.session["user_id"] = row["sub_lco_code"]
                request.session["user_type"] = "sub_lco"
                request.session["user_name"] = row["name"] or row["username"]
                request.session["company_id"] = row["company_id"]
                request.session["sub_lco_db_id"] = row["id"]
                try:
                    from login_tracking import record_login as _rl
                    _rl("sub_lco", row["sub_lco_code"], row["company_id"],
                        row["name"] or row["username"],
                        request.client.host if request.client else None,
                        request.headers.get("user-agent"))
                except Exception:
                    pass
                return JSONResponse({"success": True, "redirect": "/sub-lco/dashboard"})
        except Exception as _e:
            import logging; logging.getLogger("main").exception("sub_lco auth failed: %s", _e)

    return JSONResponse({"success": False, "message": "Invalid credentials"}, status_code=401)

@app.get("/auth/sso")
async def auth_sso(request: Request, token: str = "", db: Session = Depends(get_db)):
    """_S40g_ — Consume a short-lived SSO token minted by the mobile API
    and set the web session cookie + redirect to the right portal."""
    if not token:
        return RedirectResponse(url="/login?sso_err=missing", status_code=303)
    # _S58AK_PG_  Read from Postgres (db_compat wrapper) — the legacy
    # SQLite cache at /var/lib/autoispbilling/autoispbilling.db is no
    # longer being written; we were silently rejecting every SSO token.
    from datetime import datetime, timezone as _tz
    try:
        from db_compat import get_raw_conn as _g_sso
        with _g_sso(timeout=8) as c:
            cur = c.execute(
                "SELECT token, user_type, company_id, user_pk, username, "
                "       target, expires_at, COALESCE(consumed,0) AS consumed "
                "  FROM mobile_sso_tokens WHERE token=? LIMIT 1",
                (token,))
            r = cur.fetchone()
            if not r:
                return RedirectResponse(url="/login?sso_err=invalid", status_code=303)
            row = dict(zip(["token","user_type","company_id","user_pk",
                            "username","target","expires_at","consumed"], r))
            if row.get("consumed"):
                return RedirectResponse(url="/login?sso_err=consumed", status_code=303)
            exp = row.get("expires_at") or ""
            # Postgres returns datetime; SQLite returned string. Normalise.
            if hasattr(exp, "isoformat"):
                exp = exp.astimezone(_tz.utc).isoformat() if exp.tzinfo else exp.isoformat()
            if exp and exp < datetime.now(_tz.utc).isoformat():
                return RedirectResponse(url="/login?sso_err=expired", status_code=303)
            c.execute("UPDATE mobile_sso_tokens SET consumed=1 WHERE token=?", (token,))
            try: c.commit()
            except Exception: pass
    except Exception as e:
        print(f"[sso] consume error: {e}")
        return RedirectResponse(url="/login?sso_err=server", status_code=303)
    user_type = row["user_type"]
    request.session["user_type"] = user_type
    request.session["company_id"] = row["company_id"]
    request.session["user_id"] = row["username"]
    request.session["user_name"] = row["username"]
    # Resolve PK fields the rest of the app expects
    user_pk = row["user_pk"]
    if user_type == "admin":
        # Already lives in admins table; admin login uses admin_id+session
        pass
    elif user_type == "employee":
        try: request.session["employee_id"] = int(user_pk)
        except Exception: pass
    elif user_type == "sub_lco":
        try: request.session["sub_lco_db_id"] = int(user_pk)
        except Exception: pass
    elif user_type == "customer":
        # __S44B__ Customer SSO (mobile app → web upgrade checkout WebView).
        # Phase25/27 endpoints expect session["user_id"] = customer_id
        # (not username), so resolve customer_id by user_pk (customers.id).
        try:
            import sqlite3 as _sql2
            with _sql2.connect(db_path) as _c2:
                _c2.row_factory = _sql2.Row
                _rc = _c2.execute(
                    "SELECT customer_id, customer_name FROM customers "
                    "WHERE id=? AND company_id=? LIMIT 1",
                    (int(user_pk), row["company_id"])).fetchone()
                if _rc:
                    request.session["user_id"]   = _rc["customer_id"]
                    request.session["user_name"] = _rc["customer_name"] or _rc["customer_id"]
        except Exception:
            pass
    target = (row["target"] or "").strip()
    if not target:
        # Default landing per role
        target = {
            "admin":    "/admin/add-customer?mobile=1",
            "employee": "/admin/add-customer?mobile=1",
            "sub_lco":  "/admin/add-customer?mobile=1",
            "customer": "/customer/dashboard",
        }.get(user_type, "/admin/dashboard")
    return RedirectResponse(url=target, status_code=303)


@app.get("/logout")

async def logout(request: Request):
    request.session.clear()
    return RedirectResponse(url="/login")



@app.get("/admin/dashboard", response_class=HTMLResponse)
async def admin_dashboard(request: Request, db: Session = Depends(get_db)):
    """Admin dashboard page"""
    auth_check = require_admin(request)
    if auth_check:
        return auth_check

    context = get_admin_context(request, db, "dashboard")
    # _S39R5F_MAX_USERS — package max users from superadmin_packages
    try:
        from sqlalchemy import text as _t_pkg
        from database import engine as _eng_pkg
        _co = context.get("company")
        _pn = getattr(_co, "package", None) if _co else None
        if _pn:
            with _eng_pkg.begin() as _c:
                _r = _c.execute(_t_pkg("SELECT user_count FROM superadmin_packages "
                                       "WHERE package_name=:n AND is_active=true LIMIT 1"),
                                {"n": _pn}).fetchone()
            if _r and _r[0] is not None and str(_r[0]).strip() != "":
                context["package_max_users"] = int(_r[0])
            else:
                context["package_max_users"] = None
        else:
            context["package_max_users"] = None
    except Exception as _e_pkg:
        print(f"[pkg_max_users] {_e_pkg}")
        context["package_max_users"] = None
    company_id = request.session.get("company_id")

    from database import Customer, Payment, Invoice
    from datetime import datetime, timedelta, date

    today = date.today()
    month_start = today.replace(day=1)
    last_month_end = month_start - timedelta(days=1)
    last_month_start = last_month_end.replace(day=1)
    in_three_days = today + timedelta(days=3)

    # Service-type filter: "broadband" (default) or "cabletv".
    # Dashboard toggle passes ?service=cabletv / ?service=broadband.
    service_param = (request.query_params.get("service") or "broadband").strip().lower()
    # _S40zg_  Expanded service filter — fiber/FTTH/Internet all count as broadband
    if service_param == "cabletv":
        service_filter = ("Cable", "Cable TV", "CableTV", "cabletv", "cable", "cable tv",
                          "CABLE", "CABLE TV")
    else:
        service_filter = ("Broadband", "broadband", "BROADBAND",
                          "fiber", "Fiber", "FIBER", "fibernet", "Fibernet",
                          "ftth", "FTTH", "Ftth", "internet", "Internet",
                          "INTERNET", "wireless", "Wireless", "")

    customers = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.status != "Deleted",
        Customer.service_type.in_(service_filter),
    ).all()

    scoped_customer_ids = [c.customer_id for c in customers if c.customer_id]

    total_customers = len(customers)
    active_count = sum(1 for c in customers if (c.status or "").lower() == "active")
    deactive_count = sum(
        1 for c in customers
        if (c.status or "").lower() in ("deactive", "deactivated", "inactive")
    )
    suspended_count = sum(
        1 for c in customers
        if (c.status or "").lower() == "suspended"
    )

    month_start_dt = datetime.combine(month_start, datetime.min.time())
    today_start_dt = datetime.combine(today, datetime.min.time())
    today_end_dt = datetime.combine(today, datetime.max.time())
    last_month_start_dt = datetime.combine(last_month_start, datetime.min.time())
    last_month_end_dt = datetime.combine(last_month_end, datetime.max.time())

    # All Payment/Invoice stats below are scoped to customers of the selected service.
    def _scope_pay(q):
        if scoped_customer_ids:
            return q.filter(Payment.customer_id.in_(scoped_customer_ids))
        # No customers for this service -> force empty result set
        return q.filter(Payment.id == -1)

    def _scope_inv(q):
        if scoped_customer_ids:
            return q.filter(Invoice.customer_id.in_(scoped_customer_ids))
        return q.filter(Invoice.id == -1)

    payment_total_since = _scope_pay(db.query(func.coalesce(func.sum(Payment.amount), 0.0)).filter(
        Payment.company_id == company_id,
        Payment.paid_at >= month_start_dt,
    )).scalar() or 0.0
    payment_count_month = _scope_pay(db.query(func.count(Payment.id)).filter(
        Payment.company_id == company_id,
        Payment.paid_at >= month_start_dt,
    )).scalar() or 0

    payment_total_today = _scope_pay(db.query(func.coalesce(func.sum(Payment.amount), 0.0)).filter(
        Payment.company_id == company_id,
        Payment.paid_at >= today_start_dt,
        Payment.paid_at <= today_end_dt,
    )).scalar() or 0.0
    payment_count_today = _scope_pay(db.query(func.count(Payment.id)).filter(
        Payment.company_id == company_id,
        Payment.paid_at >= today_start_dt,
        Payment.paid_at <= today_end_dt,
    )).scalar() or 0

    payment_total_last_month = _scope_pay(db.query(func.coalesce(func.sum(Payment.amount), 0.0)).filter(
        Payment.company_id == company_id,
        Payment.paid_at >= last_month_start_dt,
        Payment.paid_at <= last_month_end_dt,
    )).scalar() or 0.0

    invoice_totals = _scope_inv(db.query(
        Invoice.customer_id,
        func.coalesce(func.sum(Invoice.total_amount), 0.0).label("inv_total"),
    ).filter(Invoice.company_id == company_id)).group_by(Invoice.customer_id).all()
    payment_totals = _scope_pay(db.query(
        Payment.customer_id,
        func.coalesce(func.sum(Payment.amount), 0.0).label("pay_total"),
        func.coalesce(func.sum(Payment.discount), 0.0).label("disc_total"),
    ).filter(Payment.company_id == company_id)).group_by(Payment.customer_id).all()

    inv_map = {r.customer_id: float(r.inv_total or 0) for r in invoice_totals}
    pay_map = {
        r.customer_id: float((r.pay_total or 0) + (r.disc_total or 0))
        for r in payment_totals
    }
    total_dues = 0.0
    due_customer_count = 0
    for cid in set(list(inv_map.keys()) + list(pay_map.keys())):
        bal = inv_map.get(cid, 0.0) - pay_map.get(cid, 0.0)
        if bal > 0:
            total_dues += bal
            due_customer_count += 1

    # Complaint model isn't mapped in this portal's ORM -- query the raw table.
    try:
        # _BUG5_USERS_ONLINE_ : live count from online_users for THIS company
        try:
            # s41h: align with mobile API — only count fresh, Online rows
            # (the previous query counted stale/Offline/WalledGarden rows too,
            # which inflated the dashboard total by ~7 users).
            # _S58K_PG_NATIVE_  rewrite the online-users count in PG-native
            # syntax: no IFNULL, no julianday(). Removes silent-fail risk that
            # was making the dashboard tile show 0 after the PG migration.
            # _S58K2_FRESH_CONN_  use a fresh engine.connect() so this
            # query is not affected by a poisoned upstream session.
            from database import engine as _eng_online
            with _eng_online.connect() as _oconn:
                users_online_now = int(_oconn.execute(text(
                    "SELECT COUNT(DISTINCT ou.username) FROM online_users ou "
                    "JOIN customers c ON c.username = ou.username "
                    "    AND c.company_id = ou.company_id "
                    "WHERE c.company_id = :cid "
                    # _S58L_INCLUDE_WG_  WalledGarden users are physically online (parking pool)
                    "  AND LOWER(COALESCE(ou.status,'')) IN ('online','walledgarden','parked') "
                    "  AND COALESCE(c.status,'') NOT IN ("
                    "      'Expired','expired','Disabled','disabled',"
                    "      'Deactivated','deactivated','Suspended','suspended',"
                    "      'Parked','parked','Cancelled','cancelled',"
                    "      'Canceled','canceled','Terminated','terminated',"
                    "      'Deleted','deleted') "
                    # _S58K3_  Status is the source of truth; the sync
                    # flips it to 'Offline' when a session ends. No need
                    # for a freshness window which the sync job often lags.
                ), {"cid": company_id}).scalar() or 0)
        except Exception:
            users_online_now = 0

        complaints_this_month = int(db.execute(text(
            "SELECT COUNT(*) FROM complaints WHERE company_id = :cid AND created_at >= :start"
        ), {"cid": company_id, "start": datetime.combine(month_start, datetime.min.time()).isoformat()}).scalar() or 0)
        complaints_last_month = int(db.execute(text(
            "SELECT COUNT(*) FROM complaints WHERE company_id = :cid "
            "AND created_at >= :start AND created_at <= :end"
        ), {
            "cid": company_id,
            "start": datetime.combine(last_month_start, datetime.min.time()).isoformat(),
            "end": datetime.combine(last_month_end, datetime.max.time()).isoformat(),
        }).scalar() or 0)
    except Exception:
        complaints_this_month = 0
        complaints_last_month = 0

    enrollments_this_month = db.query(func.count(Customer.id)).filter(
        Customer.company_id == company_id,
        Customer.status != "Deleted",
        Customer.created_at >= datetime.combine(month_start, datetime.min.time()),
    ).scalar() or 0
    enrollments_last_month = db.query(func.count(Customer.id)).filter(
        Customer.company_id == company_id,
        Customer.status != "Deleted",
        Customer.created_at >= datetime.combine(last_month_start, datetime.min.time()),
        Customer.created_at <= datetime.combine(last_month_end, datetime.max.time()),
    ).scalar() or 0

    expiring_today = 0
    expiring_next_3_days = 0
    for c in customers:
        if not c.end_date:
            continue
        try:
            end_dt = datetime.strptime(c.end_date, "%Y-%m-%d").date()
        except Exception:
            continue
        if end_dt == today:
            expiring_today += 1
        if today <= end_dt <= in_three_days:
            expiring_next_3_days += 1

    today_recharged = db.query(func.count(Invoice.id)).filter(
        Invoice.company_id == company_id,
        Invoice.issue_date == today.strftime("%Y-%m-%d"),
    ).scalar() or 0


    # s36b9-hotspot-widgets-stats ----------------------------------------
    try:
        from database import HotspotVoucher
        hs_today_sold = db.query(func.count(HotspotVoucher.id)).filter(
            HotspotVoucher.company_id == company_id,
            HotspotVoucher.created_at >= today_start_dt,
            HotspotVoucher.created_at <= today_end_dt,
        ).scalar() or 0
        hs_today_used = db.query(func.count(HotspotVoucher.id)).filter(
            HotspotVoucher.company_id == company_id,
            HotspotVoucher.status == "used",
            HotspotVoucher.used_at >= today_start_dt,
            HotspotVoucher.used_at <= today_end_dt,
        ).scalar() or 0
        hs_expired_pending = db.query(func.count(HotspotVoucher.id)).filter(
            HotspotVoucher.company_id == company_id,
            HotspotVoucher.status == "expired",
        ).scalar() or 0
    except Exception:
        hs_today_sold = hs_today_used = hs_expired_pending = 0

    # Active hotspot sessions = hotspot-auth customers currently Online.
    try:
        from radius_network import OnlineUser
        from database import Customer as _Cust
        hotspot_usernames = [row[0] for row in db.query(_Cust.username).filter(
            _Cust.company_id == company_id,
            _Cust.auth_type == "hotspot",
        ).all() if row[0]]
        if hotspot_usernames:
            hs_active_sessions = db.query(func.count(OnlineUser.id)).filter(
                OnlineUser.company_id == company_id,
                OnlineUser.status == "Online",
                OnlineUser.username.in_(hotspot_usernames),
            ).scalar() or 0
        else:
            hs_active_sessions = 0
    except Exception:
        hs_active_sessions = 0
    # -------------------------------------------------------------------

    context.update({
        "stats": {
            "total_subscribers": total_customers,
            # _S39DASH_EXPIRED_BACKEND
            "expired_subscribers": _count_expired_subs(db, company_id),
            "active_subscribers": active_count,
            "deactive_subscribers": deactive_count,
            "suspended_subscribers": suspended_count,
            "collection_today_amount": float(payment_total_today),
            "collection_today_count": int(payment_count_today),
            "collection_month_amount": float(payment_total_since),
            "collection_month_count": int(payment_count_month),
            "collection_last_month_amount": float(payment_total_last_month),
            "collection_diff": float(payment_total_since) - float(payment_total_last_month),
            "total_dues_amount": float(total_dues),
            "dues_customer_count": int(due_customer_count),
            "users_online_now": int(users_online_now),  # _BUG5_USERS_ONLINE_
            # __S43ZF__ Parked users tile (customers in parked statuses)
            "parked_users": int(db.execute(text(
                "SELECT COUNT(*) FROM customers WHERE company_id=:cid "
                "AND LOWER(IFNULL(status,'')) IN ("
                "  'expired','disabled','deactivated','deactive',"
                "  'suspended','parked','cancelled','canceled',"
                "  'terminated')"  # 'deleted' deliberately excluded
            ), {"cid": company_id}).scalar() or 0),
            "complaints_this_month": int(complaints_this_month),
            "complaints_last_month": int(complaints_last_month),
            "complaints_diff": int(complaints_this_month) - int(complaints_last_month),
            "enrollments_this_month": int(enrollments_this_month),
            "enrollments_last_month": int(enrollments_last_month),
            "enrollments_diff": int(enrollments_this_month) - int(enrollments_last_month),
            "expiring_today": int(expiring_today),
            "expiring_next_3_days": int(expiring_next_3_days),
            "today_recharged": int(today_recharged),
            # s36b9 hotspot widgets
            "hs_active_sessions":    int(hs_active_sessions),
            "hs_vouchers_sold_today":     int(hs_today_sold),
            "hs_vouchers_redeemed_today": int(hs_today_used),
            "hs_vouchers_expired_pending": int(hs_expired_pending),
        },
    })
    return templates.TemplateResponse("admin_dashboard.html", context)

@app.get("/admin/subscribers/{customer_pk}", response_class=HTMLResponse)
async def admin_subscriber_detail(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Session 23.3 - Subscriber detail page (Details / Connection / KYC / Audit Trail).
    Data: profile, address, connection settings, live session, radacct usage windows,
    active invoices, package sales, unified audit log."""
    import os, sqlite3 as _sq
    from datetime import datetime as _dt
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    context = get_admin_context(request, db, "users")
    company_id = request.session.get("company_id")

    from database import Customer, Plan, Payment, Invoice, Transaction
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        from fastapi.responses import RedirectResponse
        return RedirectResponse(url="/admin/users", status_code=303)

    plan = None
    if cust.plan_id:
        plan = db.query(Plan).filter(
            Plan.id == cust.plan_id,
            Plan.company_id == company_id).first()

    total_invoiced = (db.query(func.coalesce(func.sum(Invoice.total_amount), 0.0))
                        .filter(Invoice.company_id == company_id,
                                Invoice.customer_id == cust.customer_id).scalar() or 0.0)
    total_received = (db.query(func.coalesce(func.sum(Payment.amount), 0.0))
                        .filter(Payment.company_id == company_id,
                                Payment.customer_id == cust.customer_id).scalar() or 0.0)
    total_discount = (db.query(func.coalesce(func.sum(Payment.discount), 0.0))
                        .filter(Payment.company_id == company_id,
                                Payment.customer_id == cust.customer_id).scalar() or 0.0)
    balance = float(total_invoiced) - float(total_received) - float(total_discount)

    active_invoices = (db.query(Invoice)
                         .filter(Invoice.company_id == company_id,
                                 Invoice.customer_id == cust.customer_id,
                                 Invoice.status != "paid")
                         .order_by(Invoice.created_at.desc()).limit(10).all())
    recent_invoices = (db.query(Invoice)
                         .filter(Invoice.company_id == company_id,
                                 Invoice.customer_id == cust.customer_id)
                         .order_by(Invoice.created_at.desc()).limit(10).all())
    recent_payments = (db.query(Payment)
                         .filter(Payment.company_id == company_id,
                                 Payment.customer_id == cust.customer_id)
                         .order_by(Payment.paid_at.desc().nullslast(),
                                   Payment.created_at.desc()).limit(10).all())
    package_sales = (db.query(Transaction)
                       .filter(Transaction.company_id == company_id,
                               Transaction.customer_id == cust.customer_id,
                               Transaction.transaction_type.in_(["renewal", "payment", "new"]))
                       .order_by(Transaction.created_at.desc()).limit(50).all())

    # Status log - used for audit trail
    status_log = []
    try:
        from radius_network import CustomerStatusLog
        status_log = (db.query(CustomerStatusLog)
                        .filter(CustomerStatusLog.company_id == company_id,
                                CustomerStatusLog.customer_id == cust.customer_id)
                        .order_by(CustomerStatusLog.created_at.desc())
                        .all())
    except Exception:
        pass

    # Unified audit trail: transactions + status changes + payments + creation
    audit_events = []
    # 1. Customer creation
    if cust.created_at:
        # S42T-AUDIT-CREATOR: NEVER fall back to the current viewer's
        # session — that mislabels existing customers (e.g. admin
        # viewing a customer created by sub-LCO would see admin's name).
        # Prefer the stamped `created_by`; otherwise resolve role-FK to
        # the appropriate parent record; otherwise show "System".
        _actor = getattr(cust, "created_by", None)
        if not _actor:
            try:
                if getattr(cust, "created_by_employee_id", None):
                    _e = db.query(Employee).filter(
                        Employee.id == cust.created_by_employee_id).first()
                    if _e:
                        _actor = (getattr(_e, "employee_name", "") or "") + " (Employee)"
                if not _actor and getattr(cust, "created_by_sub_lco_id", None):
                    from database import SubLCO as _SL
                    _s = db.query(_SL).filter(_SL.id == cust.created_by_sub_lco_id).first()
                    if _s:
                        _actor = (getattr(_s, "name", "") or "") + " (Sub-LCO)"
            except Exception as _ae:
                print(f"[audit_trail s42t] {_ae}")
        actor = _actor or "System"
        audit_events.append({
            "ts": cust.created_at, "type": "create",
            "text": f"New Subscriber Created by {actor}",
        })
    # 2. Package renewals / assignments (Transaction)
    for tx in package_sales:
        tx_type = tx.transaction_type or ""
        plan_nm = (plan.plan_name if plan and tx.transaction_type == "renewal" else (tx.remarks or tx_type))
        # s36b3: audit date/time format – DD-MM-YYYY
        if tx.start_date and tx.end_date:
            _sd = format_date_ddmmyyyy(tx.start_date) if isinstance(tx.start_date, str) else tx.start_date.strftime('%d-%m-%Y')
            _ed = format_date_ddmmyyyy(tx.end_date) if isinstance(tx.end_date, str) else tx.end_date.strftime('%d-%m-%Y')
            line = (f'Package "{plan_nm}" is renewed for the subscriber '
                    f"with validity From {_sd} To {_ed}")
        else:
            line = f"Package transaction: {tx.remarks or tx_type} - INR {tx.amount or 0:.0f}"
        audit_events.append({
            "ts": tx.created_at, "type": "renewal",
            "text": line,
        })
    # 3. Status changes (CustomerStatusLog)
    for s in status_log:
        actor = s.actor_name or s.actor_id or s.actor_type or "System"
        line = (f'Subscriber Account status is changed to "{s.new_status}" '
                f"by {actor}"
                + (f" (reason: {s.reason})" if s.reason else ""))
        audit_events.append({
            "ts": s.created_at, "type": "status",
            "text": line,
        })
    # 4. Payments
    for p in recent_payments:
        audit_events.append({
            "ts": p.paid_at or p.created_at, "type": "payment",
            "text": (f"Payment of INR {p.amount or 0:.0f} received via "
                     f"{p.payment_mode or 'unknown'}"
                     + (f" (txn {p.transaction_no})" if p.transaction_no else "")),
        })
    # Sort descending
    audit_events = [e for e in audit_events if e.get("ts")]
    audit_events.sort(key=lambda e: e["ts"], reverse=True)

    # Group by date (day)
    audit_grouped = []
    last_date = None
    current = None
    # Session 25.10: resolve admin's company row ONCE for tz offset
    from database import Company as _Comp
    _company_for_tz = db.query(_Comp).filter(_Comp.company_id == cust.company_id).first()
    # s36b4: revert audit time to 12h – user wants AM/PM IST display back.
    # Date heading stays DD-MM-YYYY (per s36b3).
    for ev in audit_events:
        ts_local = to_local(ev["ts"], _company_for_tz)
        date_str = ts_local.strftime("%d-%m-%Y")
        if date_str != last_date:
            current = {"date": date_str, "events": []}
            audit_grouped.append(current)
            last_date = date_str
        current["events"].append({
            "time": ts_local.strftime("%I:%M %p"),
            "text": ev["text"],
            "type": ev["type"],
        })

    # Live session
    live = None
    access_count = 0
    try:
        from radius_network import OnlineUser, NasDevice, AccessRequestLog
        ou = (db.query(OnlineUser)
                .filter(OnlineUser.company_id == company_id,
                        OnlineUser.username == cust.username,
                        OnlineUser.status == "Online").first())
        if ou:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.ip_address == ou.nas_ip).first()
            live = {
                "ip": ou.ip_address or "",
                "mac": ou.mac_address or "",
                "uptime": ou.uptime_seconds or 0,
                "nas_name": nas.name if nas else (ou.nas_ip or ""),
                "nas_id": nas.id if nas else 0,
                "nas_port": ou.nas_port_id or "",
                # S42M-BYTES-SWAP: bytes_in (raw) → DOWNLOAD, bytes_out (raw) → UPLOAD.
                "bytes_in_mb":  ((ou.bytes_out or 0)
                                  if (os.getenv("RADACCT_BYTES_SWAP","0") not in ("0","false","False",""))
                                  else (ou.bytes_in  or 0)),
                "bytes_out_mb": ((ou.bytes_in  or 0)
                                  if (os.getenv("RADACCT_BYTES_SWAP","0") not in ("0","false","False",""))
                                  else (ou.bytes_out or 0)),
                "started_at": ou.started_at,
            }
        access_count = (db.query(AccessRequestLog)
                          .filter(AccessRequestLog.company_id == company_id,
                                  AccessRequestLog.username == cust.username).count())
    except Exception:
        pass

    # Radacct windows
    def _usage(cur2, where_epoch):
        # S42J — fence by company_id column so customers sharing usernames
        # across tenants don't pool each other's data usage.
        cur2.execute("""SELECT COUNT(*),
                              COALESCE(SUM(acctinputoctets), 0),
                              COALESCE(SUM(acctoutputoctets), 0),
                              COALESCE(SUM(acctsessiontime), 0)
                       FROM radacct WHERE username = ? AND company_id = ? """ + where_epoch,
                    (cust.username, str(cust.company_id)))
        s, inp, outp, secs = cur2.fetchone()
        # S42M-BYTES-SWAP: keep this helper aligned with the rest of the UI.
        _swap_h = os.getenv("RADACCT_BYTES_SWAP", "0") not in ("0","false","False","")
        up_raw, dn_raw = float(inp or 0), float(outp or 0)
        if _swap_h:
            up_raw, dn_raw = dn_raw, up_raw
        return {"sessions": s or 0,
                "upload_mb":   up_raw / 1048576.0,
                "download_mb": dn_raw / 1048576.0,
                "total_mb":   (up_raw + dn_raw) / 1048576.0,
                "online_hours": float(secs or 0) / 3600.0}
    usage_total = {"sessions":0,"upload_mb":0,"download_mb":0,"total_mb":0,"online_hours":0}
    usage_today = dict(usage_total)
    usage_month = dict(usage_total)
    try:
        p = os.getenv("RADACCT_DB_PATH", "/var/lib/freeradius/radacct.db")
        if os.path.exists(p) and cust.username:
            # S42J — make sure recent radacct rows have company_id mapped.
            try:
                from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa4
                _rp_bfa4(db, radacct_path=p, limit=2000)
            except Exception:
                pass
            con = _sq.connect(p); cur2 = con.cursor()
            usage_total = _usage(cur2, "")
            # _BUG1C_FIX_ : IST midnight + include still-active
            _ist_midnight = ("strftime('%s','now','localtime',"
                              "'start of day','utc')")
            # === S41W-USAGE-WINDOW ===
            # Removed `OR acctstoptime IS NULL` from today / month windows
            # — that catch-all made stale NULL-stop rows (sessions the
            # router lost the stop-record for) contaminate both windows,
            # often producing identical numbers across Total / Today /
            # Monthly cards (user report 2026-05-16). A session is only
            # counted in `today` if its acctstarttime OR acctupdatetime
            # is within today (IST). Same for month.
            usage_today = _usage(cur2,
                f" AND (acctstarttime >= {_ist_midnight} "
                f"     OR acctupdatetime >= {_ist_midnight})")
            usage_month = _usage(cur2,
                " AND (acctstarttime >= strftime('%s','now','-30 days') "
                "     OR acctupdatetime >= strftime('%s','now','-30 days'))")
            con.close()
    except Exception:
        pass

    # === S42G-USAGE-LIVE-OVERLAY-V2 ===
    # FreeRADIUS only writes acctinputoctets/acctoutputoctets on each
    # interim-update (typically 5-10 min). For multi-day sessions that
    # may have NO open radacct row (Mikrotik sometimes loses the
    # accounting-start), the entire usage lives only in .
    # Strategy:
    #   (a) Check whether radacct already has an OPEN row for this user
    #       AND that row carries non-zero counters (i.e. interim has
    #       fired). If so the tile is already accurate -- skip overlay.
    #   (b) Otherwise overlay online_users live counters onto today /
    #       month / total UNCONDITIONALLY. This over-reports Today only
    #       when a session spans midnight, but is far better than the
    #       previous "show 0" behaviour. Total/Monthly are always correct.
    try:
        from sqlalchemy import text as _t_lo
        # Quick dedup check: open radacct row with non-zero bytes?
        _ra_has_live = False
        try:
            import sqlite3 as _sq_lo
            _ra_lo = _sq_lo.connect("/var/lib/freeradius/radacct.db", timeout=2.0)
            _r1 = _ra_lo.execute(
                "SELECT COALESCE(acctinputoctets,0)+COALESCE(acctoutputoctets,0) "
                "  FROM radacct WHERE username=? AND company_id=? AND acctstoptime IS NULL "
                "  ORDER BY acctstarttime DESC LIMIT 1",
                ((cust.username or ""), str(cust.company_id))).fetchone()
            _ra_lo.close()
            if _r1 and (_r1[0] or 0) > 0:
                _ra_has_live = True
        except Exception:
            pass

        if not _ra_has_live:
            ou = db.execute(_t_lo(
                "SELECT bytes_in, bytes_out, uptime_seconds "
                "  FROM online_users "
                " WHERE company_id=:co AND username=:u "
                "   AND status IN ('Online','WalledGarden') "
                " ORDER BY started_at DESC LIMIT 1"),
                {"co": cust.company_id, "u": (cust.username or "")}).fetchone()
            if ou:
                _lup = float(ou[0] or 0)    # MB
                _ldn = float(ou[1] or 0)    # MB
                _lsec = int(ou[2] or 0)
                if _lup or _ldn or _lsec:
                    for bucket in (usage_total, usage_today, usage_month):
                        bucket["upload_mb"]   += _lup
                        bucket["download_mb"] += _ldn
                        bucket["total_mb"]    += (_lup + _ldn)
                        bucket["online_hours"]+= (_lsec / 3600.0)
    except Exception as _ole:
        print(f"[usage live-overlay v2] {_ole}")

    # Package timing
    pkg_used_days = 0; pkg_days_left = 0; pkg_hours_left = 0; pkg_min_left = 0
    if cust.start_date:
        try:
            sd = _dt.strptime(cust.start_date, "%Y-%m-%d")
            pkg_used_days = max(0, (_dt.utcnow() - sd).days)
        except Exception:
            pass
    if cust.end_date:
        try:
            ed = _dt.strptime(cust.end_date, "%Y-%m-%d")
            delta = ed - _dt.utcnow()
            if delta.total_seconds() > 0:
                pkg_days_left = delta.days
                rem = delta.seconds
                pkg_hours_left = rem // 3600
                pkg_min_left = (rem % 3600) // 60
        except Exception:
            pass

    # Dynamic status badge text
    status_badge = cust.status or "New"
    if cust.status == "Active":
        # Look at latest renewal
        if package_sales:
            latest = package_sales[0]
            if latest.transaction_type == "renewal":
                status_badge = "Package Renewed"
            elif latest.transaction_type == "new":
                status_badge = "Package Assigned"
            else:
                status_badge = "Package Assigned"
        else:
            status_badge = "Package Assigned"

    # KYC files - detect if they exist on disk
    import os as _os
    uploads_base = "/opt/ispbilling/admin-portal/static/uploads"
    def _file_url(path):
        if not path: return None
        # Case A: stored as URL like "/static/uploads/..." -> filesystem path is
        # /opt/ispbilling/admin-portal + that URL.
        if path.startswith("/static/"):
            fs = "/opt/ispbilling/admin-portal" + path
            return path if _os.path.exists(fs) else None
        # Case B: stored as bare filename -> it lives directly under uploads_base.
        fs = path if path.startswith("/") else _os.path.join(uploads_base, path)
        if _os.path.exists(fs):
            return f"/static/uploads/{_os.path.basename(fs)}"
        return None
    kyc = {
        "photograph": _file_url(cust.photograph_path),
        "id_proof_doc": _file_url(cust.id_proof_doc_path),
        "address_proof": _file_url(cust.address_proof_path),
    }
    kyc_has_any = any(v for v in kyc.values())

    context.update({
        "cust": cust, "plan": plan,
        "status_badge": status_badge,
        "billing": {
            "total_invoiced": total_invoiced,
            "total_received": total_received,
            "total_discount": total_discount,
            "balance": balance,
        },
        "active_invoices": active_invoices,
        "recent_invoices": recent_invoices,
        "recent_payments": recent_payments,
        "package_sales": package_sales,
        "status_log": status_log,
        "audit_grouped": audit_grouped,
        "live": live,
        "access_count": access_count,
        "usage_total": usage_total,
        "usage_today": usage_today,
        "usage_month": usage_month,
        "pkg_used_days": pkg_used_days,
        "pkg_days_left": pkg_days_left,
        "pkg_hours_left": pkg_hours_left,
        "pkg_min_left": pkg_min_left,
        "kyc": kyc,
        "kyc_has_any": kyc_has_any,
    })
    return templates.TemplateResponse("admin_subscriber.html", context)



# === _S39R5P_INLINE_EXPIRY_ — inline expiry sweep helper ===========================
# Called from /admin/users so admins always see fresh `Expired` status
# without waiting up to 15 minutes for the cron timer. Uses the same
# exclusive-end-date semantic as the cron (cutoff = today IST).
def _s39r5p_inline_expiry_sweep(db, company_id):
    """__s56i_expiry_fix__ — two-way sweep:
       (a) flip Active→Expired ONLY when end_date is strictly in the past
           (d < today). Customers keep access THROUGH their expiry day.
       (b) flip Expired→Active when end_date is in the future (handles
           customers who were renewed without an explicit status update,
           e.g. via direct DB update or upstream sync).
       Returns total rows touched.
    """
    from datetime import datetime as _dt
    from zoneinfo import ZoneInfo as _ZI
    today = _dt.now(_ZI("Asia/Kolkata")).date()

    def _norm(s):
        if not s:
            return None
        s = str(s).strip()
        for fmt in ("%Y-%m-%d", "%d-%m-%Y", "%d/%m/%Y", "%Y/%m/%d"):
            try:
                return _dt.strptime(s, fmt).date()
            except ValueError:
                continue
        return None

    touched = 0
    try:
        from radius_network import Customer as _Cust
    except Exception:
        try:
            from database import Customer as _Cust
        except Exception:
            return 0
    try:
        # (a) Active → Expired (strictly past)
        active_rows = db.query(_Cust).filter(
            _Cust.company_id == company_id,
            _Cust.status == "Active",
            _Cust.end_date.isnot(None),
            _Cust.end_date != "",
        ).all()
        for c in active_rows:
            d = _norm(c.end_date)
            if not d or d >= today:
                continue  # no end-date OR end-date is today/future → keep active
            try:
                c.status = "Expired"
                touched += 1
            except Exception:
                continue

        # __s56s_no_auto_unfly__ — the reverse Expired→Active sweep was
        # incorrect. Once auto-renew flips a customer to Expired with an
        # outstanding invoice, they must STAY Expired until the admin
        # records a payment (which re-activates them via the regular
        # payment flow). Removed.

        if touched:
            db.commit()
    except Exception as _e:
        try:
            db.rollback()
        except Exception:
            pass
        print(f"[s39r5p inline expiry] error: {_e}")
    return touched

# === _S39R5P_INLINE_EXPIRY_ — manual renewal trigger ==============================
@app.post("/api/admin/run-renewal-now")
async def s39r5p_run_renewal_now(request: Request):
    """Spawn the auto-renew cron in the background. Admin-only.
       Returns immediately; the cron writes to its own log file.
    """
    auth_check = require_admin(request)
    if auth_check:
        return JSONResponse({"success": False,
                              "message": "Not authorised"}, status_code=403)
    import subprocess
    try:
        subprocess.Popen(
            ["/opt/ispbilling/venv/bin/python",
             "/opt/ispbilling/auto_renew_expired.py"],
            cwd="/opt/ispbilling",
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            close_fds=True,
        )
        return JSONResponse({"success": True,
                              "message": "Renewal sweep started in background. "
                                         "Refresh in ~30 seconds to see updates."})
    except Exception as _e:
        return JSONResponse({"success": False,
                              "message": f"Failed to start: {_e}"},
                            status_code=500)
# === end _S39R5P_INLINE_EXPIRY_ ====================================================


@app.get("/admin/users", response_class=HTMLResponse)
async def admin_users(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    
    context = get_admin_context(request, db, "users")
    company_id = request.session.get("company_id")
    # _S39R5P_INLINE_EXPIRY_ — flip past-due Active customers to Expired
    # so admins always see correct status without waiting for the cron.
    try:
        _flipped = _s39r5p_inline_expiry_sweep(db, company_id)
        if _flipped:
            print(f"[s39r5p] inline-flipped {_flipped} customers to Expired "
                  f"on /admin/users for company={company_id}")
    except Exception as _e:
        print(f"[s39r5p] inline expiry sweep skipped: {_e}")
    # _PERF_AND_LIVESESSION_FIX_V1_ : Inline MikroTik sync DISABLED on every /admin/users
    # page load.  Was a 30-60s blocker; the 90s
    # `isp-online-sync.timer` background job already keeps
    # `online_users` table fresh.  Page now renders straight from cache.
    pass  # see _PERF_AND_LIVESESSION_FIX_V1_

    # _PERF_AND_LIVESESSION_FIX_V1_ : static-IP inline online sync also DISABLED on /admin/users
    # for the same reason — handled by the 90s background timer.
    pass
    
    from database import Customer, Payment, Plan, Invoice, ReceivedTracker
    from datetime import datetime, timedelta
    
    customers = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.status != "Deleted"
    ).all()
    # _S40zP_lock_filter_users_ Hide locked sub-lco customers from admin view
    try:
        _hide_p28u = _hidden_cust_ids(request, db)
        if _hide_p28u:
            customers = [c for c in customers if c.customer_id not in _hide_p28u]
    except Exception:
        pass
    # s36c-auth-filter — honour ?auth=<hotspot|pppoe|static_ip|static_mac>
    _auth_q = (request.query_params.get("auth") or "").strip().lower()
    if _auth_q in ("hotspot", "pppoe", "static_ip", "static_mac"):
        customers = [c for c in customers
                     if (c.auth_type or "pppoe").lower() == _auth_q]
    
    payment_sums = {}
    discount_sums = {}
    invoice_sums = {}
    received_since_reset = {}
    
    payment_data = db.query(
        Payment.customer_id,
        func.sum(Payment.amount).label('total_amount'),
        func.sum(Payment.discount).label('total_discount')
    ).filter(
        Payment.company_id == company_id
    ).group_by(Payment.customer_id).all()
    
    for row in payment_data:
        payment_sums[row.customer_id] = row.total_amount or 0
        discount_sums[row.customer_id] = row.total_discount or 0
    
    invoice_data = db.query(
        Invoice.customer_id,
        func.sum(Invoice.total_amount).label('total_invoices')
    ).filter(
        Invoice.company_id == company_id
    ).group_by(Invoice.customer_id).all()
    
    for row in invoice_data:
        invoice_sums[row.customer_id] = row.total_invoices or 0
    
    tracker_data = db.query(ReceivedTracker).filter(
        ReceivedTracker.company_id == company_id
    ).all()
    
    for tracker in tracker_data:
        received_since_reset[tracker.customer_id] = tracker.received_since_reset or 0
    
    plans = {p.id: p for p in db.query(Plan).filter(Plan.company_id == company_id).all()}

    # __S43ZE__ Session 20 — per-customer online flag.
    # Build TWO sets: usernames currently Online (status='Online') and
    # usernames currently in a live session at all (status IN Online,
    # WalledGarden). The latter is intersected with parked-style customer
    # statuses to produce a "Parked" 3rd state distinct from "Online".
    online_usernames = set()
    live_session_usernames = set()
    try:
        from sqlalchemy import text as _sa_text
        for row in db.execute(_sa_text(
            "SELECT DISTINCT username, status FROM online_users "
            "WHERE company_id = :cid AND status IN ('Online','WalledGarden')"
        ), {"cid": company_id}):
            u, st = (row[0] or "").lower(), (row[1] or "")
            if not u:
                continue
            live_session_usernames.add(u)
            if st == "Online":
                online_usernames.add(u)
    except Exception:
        pass
    # __S43ZE__ Customer statuses that, when paired with a live session,
    # mean the customer is parked in the walled-garden / parking pool.
    _PARKED_CUST_STATUSES = {
        "expired", "disabled", "deactivated", "deactive",
        "suspended", "parked", "cancelled", "canceled",
        "terminated", "deleted",
    }

    users = []
    for customer in customers:
        plan_obj = plans.get(customer.plan_id) if customer.plan_id else None
        plan_name = plan_obj.plan_name if plan_obj else "N/A"
        
        # __s56AI_amount_from_plan__ — Amount column must always reflect
        # the CURRENT plan price including tax. The legacy per-customer
        # monthly_amount override caused stale / random values when plans
        # were re-priced or when one-off charges wrote into the column.
        if plan_obj and plan_obj.after_tax_amount:
            amount_display = plan_obj.after_tax_amount
        elif customer.monthly_amount:
            amount_display = customer.monthly_amount
        else:
            amount_display = 0
        
        total_invoices = invoice_sums.get(customer.customer_id, 0)
        received_amount = payment_sums.get(customer.customer_id, 0)
        discount_amount = discount_sums.get(customer.customer_id, 0)
        received_since_last_invoice = received_since_reset.get(customer.customer_id, 0)
        
        balance = total_invoices - received_amount - discount_amount
        
        # _S39R5FIX9_ — show end_date EXACTLY as stored in DB (no -1 day shift)
        if customer.end_date:
            try:
                exp_date = format_date_ddmmyyyy(customer.end_date)
            except Exception:
                exp_date = customer.end_date or ""
        else:
            exp_date = ""
        
        address_full = customer.address or ""
        address_line = address_full.split('\n')[0] if address_full else (customer.locality or "")
        
        users.append({
            "pk": customer.id,
            "cust_id": customer.customer_id,
            "cust_name": customer.customer_name,
            "user_name": customer.username,
            "username": customer.username,           # S28.2b — for data-username attr
            "locality": customer.locality,           # S28.2b — for locality filter
            "service_type": customer.service_type,   # S28.2b — for service-type filter
            "vlan_enabled": getattr(customer, "vlan_enabled", 0) or 0,    # __s55s_vlan__
            "vlan_id":      getattr(customer, "vlan_id", None),           # __s55s_vlan__
            # __s56s_nas_badge_context__ — surface the pinned NAS so the
            # subscribers list can show a "Pinned: <NAS>" chip and let
            # admins filter by NAS pin for migration audits.
            "nas_id":   getattr(customer, "provisioned_nas_id", None),
            "nas_name": "",   # filled below from nas_lookup
            "nas_ip":   "",   # ditto
            "address": address_line,
            "mobile": customer.customer_phone,
            "status": customer.status,
            "plan": plan_name,
            "amount": f"{amount_display:,.0f}" if amount_display else "0",
            "received": f"{received_since_last_invoice:,.0f}",
            "balance": f"{balance:,.0f}",
            "exp_date": exp_date,
            # __S43ZE__ 3-state online status
            "is_online": (customer.username or "").lower() in online_usernames,
            "online_state": (
                "online" if (customer.username or "").lower() in online_usernames
                else (
                    "parked" if (
                        (customer.username or "").lower() in live_session_usernames
                        and (customer.status or "").strip().lower() in _PARKED_CUST_STATUSES
                    )
                    else (
                        # Treat Parked-status customers as "parked" even if no live
                        # session was captured yet (the cache may be stale).
                        "parked" if (customer.status or "").strip().lower() in _PARKED_CUST_STATUSES
                        else "offline"
                    )
                )
            ),
        })
    
    # __s56s_nas_badge_context__ — decorate each user with its pinned
    # NAS name/ip + expose the active NAS list for the new filter.
    try:
        from radius_network import NasDevice
        _nas_rows = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active").order_by(NasDevice.id).all()
        _nas_by_id = {n.id: n for n in _nas_rows}
        for u in users:
            if u.get("nas_id") and u["nas_id"] in _nas_by_id:
                _n = _nas_by_id[u["nas_id"]]
                u["nas_name"] = _n.name or f"NAS#{_n.id}"
                u["nas_ip"]   = _n.ip_address or ""
        context["nas_options"] = [
            {"id": n.id, "name": n.name or f"NAS#{n.id}",
             "ip": n.ip_address or ""} for n in _nas_rows]
    except Exception as _e:
        print(f"[s56s_nas_badge_context] skipped: {_e}")
        context["nas_options"] = []

    context["users"] = users
    # __s56AH_vlan_from_pool__ — enrich VLAN from authoritative pool
    try:
        _enrich_users_vlan(db, company_id, users)
    except Exception as _ve:
        print(f"[admin_users vlan-enrich] {_ve}")
    return templates.TemplateResponse("admin_users.html", context)


# Session 24 helper: disable or enable a specific customer's
# /ppp secret on the MikroTik router they are provisioned on.
# Used by bulk-action AND by post-renewal status reconciliation so
# Expired accounts cannot authenticate via the router's LOCAL secret.
def _router_set_secret_disabled_for_cust(db, company_id, cust, disabled_value):
    # s36b6: multi-auth dispatcher — route to the correct AuthBackend based
    # on cust.auth_type. Each backend performs: disable/enable + kick so the
    # client loses its current IP and picks up the right pool on re-auth.
    try:
        if not (cust and cust.username):
            return False, "no username"
        from radius_network import NasDevice
        import routeros_provision as rp
        from auth_backends import backend_for_customer

        nas_rows = []
        if getattr(cust, "provisioned_nas_id", None):
            n = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
            if n: nas_rows.append(n)
        if not nas_rows:
            nas_rows = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").all()
        if not nas_rows:
            return False, "no active NAS"

        backend = backend_for_customer(cust)
        touched = False
        kicked  = False
        errors  = []
        for nas in nas_rows:
            try:
                with rp.RouterOSClient(nas, dry_run=False) as rc:
                    # 1. Move the user into / out of the walled-garden on router.
                    if disabled_value:
                        r = backend.disable(rc, cust)
                    else:
                        r = backend.enable(rc, cust)
                    if r.get("ok"):
                        touched = touched or bool(r.get("touched") or r.get("walled") or r.get("allowed"))
                    else:
                        errors.append(f"backend.{'disable' if disabled_value else 'enable'} "
                                      f"{nas.name or nas.ip_address}: {r.get('error')}")

                    # 2. Kick any live session so re-auth picks the right pool.
                    r2 = backend.kick(rc, cust)
                    if r2.get("ok"):
                        k = r2.get("kicked", 0) or r2.get("flushed_connections", 0)
                        if k:
                            kicked = True
                    else:
                        errors.append(f"backend.kick {nas.name or nas.ip_address}: {r2.get('error')}")
            except Exception as e:
                errors.append(f"{nas.name or nas.ip_address}: {e}")

        # 3. CoA-Disconnect (only relevant to PPPoE / Hotspot, harmless for static).
        if (cust.auth_type or "pppoe") in ("pppoe", "hotspot"):
            try:
                import freeradius_manager as fm
                for nas in nas_rows:
                    try:
                        fm.send_coa_disconnect(
                            nas_ip=nas.ip_address,
                            username=cust.username,
                            secret=(nas.secret or "testing123"))
                    except Exception as _e:
                        errors.append(f"coa {nas.name or nas.ip_address}: {_e}")
            except Exception as _e:
                errors.append(f"coa-import: {_e}")

        if touched or kicked:
            msg_parts = []
            if touched: msg_parts.append(
                f"{backend.key} disabled={'yes' if disabled_value else 'no'}")
            if kicked:  msg_parts.append("session kicked")
            if errors:  msg_parts.append("warnings=" + "|".join(errors))
            return True, ", ".join(msg_parts)
        return False, "nothing to do" + (" / " + "|".join(errors) if errors else "")
    except Exception as e:
        return False, f"router error: {e}"

def _router_kick_active_session(db, company_id, cust):
    """s41c: Drop the LIVE PPP session for  on every Active NAS,
    WITHOUT disabling the PPP secret. Combined with a re-rendered
    isp-users file (now containing parking attributes), the user
    immediately re-authenticates and lands in the parking-pool with
    Mikrotik-Address-List=parked-customers — which the existing
    walled-garden NAT rule redirects to /pay/captive."""
    try:
        if not (cust and cust.username):
            return False, "no username"
        from radius_network import NasDevice
        import routeros_provision as rp
        from auth_backends import backend_for_customer
        nas_rows = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active").all()
        if not nas_rows:
            return False, "no active NAS"
        backend = backend_for_customer(cust)
        kicked = False
        errors = []
        for nas in nas_rows:
            try:
                with rp.RouterOSClient(nas, dry_run=False) as rc:
                    r = backend.kick(rc, cust)
                    if r.get("ok"):
                        if r.get("kicked"): kicked = True
                    else:
                        errors.append(f"{nas.name or nas.ip_address}: {r.get('error')}")
            except Exception as e:
                errors.append(f"{nas.name or nas.ip_address}: {e}")
        # CoA-Disconnect as well so RADIUS state matches router state.
        try:
            import freeradius_manager as fm
            for nas in nas_rows:
                try:
                    fm.send_coa_disconnect(nas_ip=nas.ip_address,
                        username=cust.username, secret=(nas.secret or "testing123"))
                except Exception as _e:
                    errors.append(f"coa {nas.name or nas.ip_address}: {_e}")
        except Exception as _e:
            errors.append(f"coa-import: {_e}")

        # ─── _S58Q_PARKING_OP_FIX_  ───────────────────────────────────
        # After the kick + CoA, also purge the user's stale dynamic
        # address-list entries and conntrack rows on every Active NAS.
        # This is what makes "Active again" actually mean "out of
        # parking-pool" from the user's browser POV — even before the
        # CPE redials. Failures here are non-fatal; we just append to
        # the errors list and surface them in the result string.
        try:
            _purged_lists = 0
            _flushed_conntrack = 0
            for nas in nas_rows:
                try:
                    with rp.RouterOSClient(nas, dry_run=False) as rc2:
                        # 1) Sniff the IP the user was assigned (if still
                        #    visible) so we can flush its conntrack rows.
                        _old_ip = ""
                        try:
                            for row in rc2._api.path("ppp/active"):
                                if (row.get("name") or "").strip() == (cust.username or ""):
                                    _old_ip = (row.get("address") or "").strip()
                                    break
                        except Exception:
                            pass

                        # 2) Remove dynamic /ip/firewall/address-list
                        #    rows for this user in the parking/block lists.
                        try:
                            alist = rc2._api.path("ip/firewall/address-list")
                            _tag = (cust.username or "").strip()
                            for row in list(alist):
                                lname   = (row.get("list") or "").strip()
                                comment = (row.get("comment") or "").strip()
                                if lname in ("parked-customers", "blocked", "isp-walled-garden") and (
                                       _tag and _tag in comment):
                                    try:
                                        alist.remove(row[".id"])
                                        _purged_lists += 1
                                    except TypeError:
                                        alist("remove", **{".id": row[".id"]})
                                        _purged_lists += 1
                                    except Exception:
                                        pass
                        except Exception as _e:
                            errors.append(f"addrlist {nas.name or nas.ip_address}: {_e}")

                        # 3) Flush conntrack for the user's previous IP
                        #    so any captive-portal browser tabs lose
                        #    their cached redirect immediately.
                        if _old_ip:
                            try:
                                r3 = rc2.flush_conntrack_for_ip(_old_ip)
                                _flushed_conntrack += int(r3.get("removed") or 0)
                            except Exception as _e:
                                errors.append(f"conntrack {nas.name or nas.ip_address}: {_e}")
                except Exception as _e:
                    errors.append(f"{nas.name or nas.ip_address} cleanup: {_e}")

            # Surface the cleanup outcomes in the message so SLCOs can
            # see at a glance whether the fix actually did anything.
            if _purged_lists:
                msg_parts_extra = f"purged {_purged_lists} addr-list row(s)"
            else:
                msg_parts_extra = ""
            if _flushed_conntrack:
                msg_parts_extra = (msg_parts_extra + ", " if msg_parts_extra else "") +                                    f"flushed {_flushed_conntrack} conntrack row(s)"
        except Exception as _e:
            errors.append(f"parking-cleanup: {_e}")
            msg_parts_extra = ""
        # ─── /_S58Q_PARKING_OP_FIX_ ───────────────────────────────────

        return (True if kicked else False), (
            ("kicked" if kicked else "no live session") +
            ((" / " + msg_parts_extra) if msg_parts_extra else "") +
            (" / " + "|".join(errors) if errors else ""))
    except Exception as e:
        return False, f"router error: {e}"


def _enforce_static_ip_state(db, cust):
    """__S38T_TRUE_STATIC_IP__ — For auth_type=static_ip customers push
    (Active) or tear down (non-Active) the Mikrotik firewall + simple-
    queue entries on every Active NAS in the tenant. No-op for customers
    on other auth types.
    Returns a dict with per-NAS results."""
    try:
        auth_type = (getattr(cust, "auth_type", None) or "pppoe").strip().lower()
        if auth_type not in ("static_ip", "static-ip", "static"):
            return {"skipped": True, "reason": "not static_ip"}
        static_ip = (getattr(cust, "static_ip_address", None) or "").strip()
        if not static_ip:
            return {"skipped": True, "reason": "no static_ip_address"}
        should_allow = (cust.status or "").strip().lower() == "active"
        from database import Plan
        from radius_network import NasDevice
        import routeros_provision as rp
        nas_rows = (db.query(NasDevice)
                      .filter(NasDevice.company_id == cust.company_id,
                              NasDevice.status == "Active").all())
        if not nas_rows:
            return {"skipped": True, "reason": "no active NAS"}
        plan = None
        if cust.plan_id:
            plan = (db.query(Plan)
                      .filter(Plan.id == cust.plan_id,
                              Plan.company_id == cust.company_id).first())
        plan_dict = {
            "plan_name": plan.plan_name if plan else "",
            "download_speed": (plan.download_speed if plan else "") or "",
            "upload_speed": (plan.upload_speed if plan else "") or "",
        } if plan else {}
        results = []
        for nas in nas_rows:
            try:
                if should_allow:
                    res = rp.provision_customer_static(
                        nas=nas,
                        customer={"username": cust.username or ""},
                        plan=plan_dict, password="", static_ip=static_ip,
                        dry_run=False)
                else:
                    res = rp.unprovision_customer_static(
                        nas=nas,
                        customer={"username": cust.username or ""},
                        static_ip=static_ip, dry_run=False)
                results.append({"nas_id": nas.id, "nas_name": nas.name,
                                "success": bool(res.get("success")),
                                "message": res.get("message")})
            except Exception as _e:
                results.append({"nas_id": nas.id, "nas_name": nas.name,
                                "success": False, "message": str(_e)})
        return {"success": all(r.get("success") for r in results),
                "should_allow": should_allow, "results": results}
    except Exception as e:
        return {"success": False, "message": f"static-ip enforce: {e}"}


def _enforce_user_state(db, cust, *, force_radius_restart: bool = True, kick_session: bool = True):
    """Single source of truth for translating a customer's DB status into
    router + RADIUS state (kick + pool reassignment on next reauth).

    Call this EVERY time `cust.status` is mutated. Safe to call repeatedly.

    __S38T__ addendum: auth_type=static_ip customers are dispatched to
    `_enforce_static_ip_state` (pure firewall + queue, no PPPoE/RADIUS).
    """
    if not cust or not getattr(cust, "company_id", None):
        return {"success": False, "message": "no cust/company"}
    auth_type = (getattr(cust, "auth_type", None) or "pppoe").strip().lower()
    if auth_type in ("static_ip", "static-ip", "static"):
        sip = _enforce_static_ip_state(db, cust)
        try:
            from radius_network import _sync_freeradius_all_tenants
            r = _sync_freeradius_all_tenants(db, restart=force_radius_restart)
        except Exception as e:
            r = {"error": str(e)}
        return {"success": bool(sip.get("success")) if not sip.get("skipped") else True,
                "auth_type": "static_ip",
                "static_ip": sip, "radius": r}
    should_block = (cust.status or "").strip().lower() != "active"
    try:
        ok, msg = _router_set_secret_disabled_for_cust(
            db, cust.company_id, cust, disabled_value=should_block)
    except Exception as e:
        ok, msg = False, f"router error: {e}"
    try:
        from radius_network import _sync_freeradius_all_tenants
        r = _sync_freeradius_all_tenants(db, restart=force_radius_restart)
        sync_ok = bool(r.get("success"))
    except Exception as e:
        r, sync_ok = {"error": str(e)}, False
    # # __ENFORCE_COA_KICK__
    # Always issue RADIUS CoA-Disconnect after a state flip so any
    # currently-online session is torn down. The router then re-dials
    # and (with the freshly-synced /etc/freeradius/users) gets the
    # correct pool — real PPPoE pool when Active, no auth when blocked.
    # This is what fixes "made user Active but still on 10.99.99.x
    # parking IP" — the existing live session has to be kicked.
    # # __BULK_PARALLEL_COA_KICK_REVERT__
    # CoA-Disconnect is already issued inside _router_set_secret_disabled_for_cust
    # (which `_enforce_user_state` invoked via the `ok, msg = ...` line above).
    # That helper calls backend.kick + freeradius_manager.send_coa_disconnect
    # against every active NAS for the tenant, so adding a 2nd CoA here just
    # duplicates work and slows bulk operations by ~0.5-1s per customer.
    # The `kick_session` parameter is kept as a no-op for API compatibility.
    _ = kick_session  # silence "unused" lints; reserved for future toggle
    return {"success": ok and sync_ok, "block": should_block,
            "router_ok": ok, "router_msg": msg, "radius": r}
# === /Session 27.4 ===



@app.get("/api/customers/{customer_pk}/nas-options")
async def api_customer_nas_options(customer_pk: int, request: Request,
                                     db: Session = Depends(get_db)):
    """_s56s_rebind_  Return active NAS devices + the customer's current
    provisioned_nas_id, for the Rebind-to-NAS dropdown."""
    auth_check = require_auth(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    from radius_network import NasDevice
    c = db.query(Customer).filter(Customer.id == customer_pk,
                                    Customer.company_id == company_id).first()
    if not c:
        return JSONResponse({"success": False,
                              "message": "customer not found"},
                              status_code=404)
    nas = db.query(NasDevice).filter(
        NasDevice.company_id == company_id,
        NasDevice.status == "Active").order_by(NasDevice.id).all()
    return {
        "success": True,
        "current_nas_id": getattr(c, "provisioned_nas_id", None),
        "username": c.username or "",
        "status": c.status or "Active",
        "nas_devices": [
            {"id": n.id, "name": n.name,
             "ip_address": n.ip_address,
             "is_current": (n.id == (c.provisioned_nas_id or 0))}
            for n in nas
        ],
    }


@app.post("/api/customers/{customer_pk}/rebind-nas")
async def api_customer_rebind_nas(customer_pk: int, request: Request,
                                    db: Session = Depends(get_db)):
    """_s56s_rebind_  One-click NAS rebind for the Connection tab.
    Body: { "nas_id": <int|null> }

    Flow:
      1. Resolve old + new NAS rows.
      2. Update customer.provisioned_nas_id (or NULL to remove pin).
      3. Commit, then FreeRADIUS resync + restart so the new
         `NAS-IP-Address ==` check is live.
      4. CoA-Disconnect on the OLD NAS so the live session drops; the
         CPE will then re-dial and either land on the NEW NAS (if it
         has a route there) or get rejected (which is the correct
         behaviour — we *want* it to stop using the wrong NAS).
      5. Also send a CoA-Disconnect on the NEW NAS as a safety net in
         case there is already a partial / stale session there.

    Returns per-step ok flags so the UI can show a friendly progress
    breakdown.
    """
    auth_check = require_auth(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")
    body = await request.json()
    new_nas_id = body.get("nas_id")
    # Allow null / empty-string to mean "remove pin".
    if new_nas_id in ("", None, "null"):
        new_nas_id = None
    else:
        try: new_nas_id = int(new_nas_id)
        except (TypeError, ValueError):
            return {"success": False,
                    "message": "nas_id must be an integer or null"}

    from database import Customer
    from radius_network import NasDevice
    c = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not c:
        return JSONResponse({"success": False,
                              "message": "customer not found"},
                              status_code=404)

    old_nas_id = getattr(c, "provisioned_nas_id", None)
    if old_nas_id == new_nas_id:
        return {"success": True, "noop": True,
                "message": "Customer is already bound to this NAS."}

    # Validate new NAS belongs to the same company + Active.
    new_nas = None
    if new_nas_id is not None:
        new_nas = db.query(NasDevice).filter(
            NasDevice.id == new_nas_id,
            NasDevice.company_id == company_id,
            NasDevice.status == "Active").first()
        if not new_nas:
            return {"success": False,
                    "message": f"NAS #{new_nas_id} not found or not active "
                               "for this company."}

    old_nas = None
    if old_nas_id:
        old_nas = db.query(NasDevice).filter(
            NasDevice.id == old_nas_id,
            NasDevice.company_id == company_id).first()

    # 1. Update + commit
    c.provisioned_nas_id = new_nas_id
    db.commit()
    db.refresh(c)

    steps = {"updated": True, "old_nas": old_nas.name if old_nas else None,
             "new_nas": new_nas.name if new_nas else None,
             "freeradius_resync": False, "old_nas_kick": False,
             "new_nas_kick": False}

    # 2. FreeRADIUS resync + restart
    try:
        from radius_network import _sync_freeradius_all_tenants
        r = _sync_freeradius_all_tenants(db, restart=True)
        steps["freeradius_resync"] = bool(r.get("success"))
    except Exception as e:
        steps["freeradius_resync_error"] = str(e)[:200]

    # 3 + 4. Kick on OLD NAS (most important) + NEW NAS (safety).
    if c.username:
        import freeradius_manager as fm
        for nas, key in ((old_nas, "old_nas_kick"),
                          (new_nas, "new_nas_kick")):
            if not nas: continue
            try:
                fm.send_coa_disconnect(
                    nas_ip=nas.ip_address,
                    username=c.username,
                    secret=(nas.secret or "testing123"))
                steps[key] = True
            except Exception as e:
                steps[key + "_error"] = str(e)[:200]

    msg_parts = []
    if old_nas and new_nas:
        msg_parts.append(f"Rebound {c.username or c.customer_id} "
                         f"from {old_nas.name} → {new_nas.name}")
    elif new_nas:
        msg_parts.append(f"Pinned {c.username or c.customer_id} "
                         f"to {new_nas.name}")
    elif old_nas:
        msg_parts.append(f"Removed NAS pin "
                         f"(was {old_nas.name}) from {c.username or c.customer_id}")
    if steps.get("freeradius_resync"):
        msg_parts.append("FreeRADIUS resynced")
    kicks = sum(1 for k in ("old_nas_kick", "new_nas_kick") if steps.get(k))
    if kicks:
        msg_parts.append(f"{kicks} session kick(s) sent")
    return {"success": True, "message": ". ".join(msg_parts) + ".",
            "steps": steps}


@app.post("/api/customers/bulk-action")
async def bulk_customer_action(request: Request, db: Session = Depends(get_db)):
    """Session 20 — bulk status/MAC operations on the Users page.
    Body: { "customer_ids": [..], "action": "make_active"|"reset_mac"
              |"disconnect"|"disable"|"enable"|"deactivate"|"suspend" }

    __S38T_SUBLCO__: accept Sub-LCO callers as well — the
    SubLcoScopeMiddleware sets a SQLAlchemy ContextVar that auto-injects
    `Customer.sub_lco_id == <session sub_lco_db_id>` into every ORM
    query. So the row-set returned below is already restricted to the
    Sub-LCO'''s own customers; an Admin sees the whole tenant.
    """
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    body = await request.json()
    action = (body.get("action") or "").strip()
    ids = body.get("customer_ids") or []
    if not action or not ids:
        return {"success": False, "message": "action + customer_ids required"}

    from database import Customer
    from radius_network import NasDevice
    # Accept either customer_id (business account#) OR id (DB pk).
    str_ids = [str(x) for x in ids]
    int_ids = []
    for x in ids:
        try: int_ids.append(int(x))
        except Exception: pass
    rows = (db.query(Customer)
              .filter(Customer.company_id == company_id)
              .filter((Customer.customer_id.in_(str_ids)) |
                      (Customer.id.in_(int_ids)))
              .all())
    if not rows:
        return {"success": False, "message": "No customers matched."}

    # _S58BD_NAS_AUTO_  optional nas_id for the assign_nas action.
    _nas_id_target = body.get("nas_id")
    try: _nas_id_target = int(_nas_id_target) if _nas_id_target else None
    except Exception: _nas_id_target = None

    touched = 0
    kicked  = 0
    errors  = []

    # Helper: for disconnect / disable we also send CoA-Disconnect so the
    # live PPPoE session is dropped instantly, not just at next auth.
    def _coa_kick(c):
        nonlocal kicked
        try:
            nas = (db.query(NasDevice)
                     .filter(NasDevice.company_id == company_id,
                             NasDevice.status == "Active",
                             NasDevice.id == (c.provisioned_nas_id or 0))
                     .first())
            if not nas:
                nas = (db.query(NasDevice)
                         .filter(NasDevice.company_id == company_id,
                                 NasDevice.status == "Active").first())
            if not nas or not c.username:
                return
            import freeradius_manager as fm
            fm.send_coa_disconnect(nas_ip=nas.ip_address,
                                   username=c.username,
                                   secret=(nas.secret or "testing123"))
            kicked += 1
        except Exception as e:
            errors.append(f"kick {c.customer_id}: {e}")

    # Helper: enable/disable the /ppp secret on MikroTik so local-auth
    # also blocks the user (not only RADIUS).
    def _router_set_secret_disabled(c, disabled_value):
        try:
            if not c.username:
                return
            nas = (db.query(NasDevice)
                     .filter(NasDevice.company_id == company_id,
                             NasDevice.id == (c.provisioned_nas_id or 0))
                     .first())
            if not nas:
                nas = (db.query(NasDevice)
                         .filter(NasDevice.company_id == company_id,
                                 NasDevice.status == "Active").first())
            if not nas:
                return
            import routeros_provision as rp
            with rp.RouterOSClient(nas, dry_run=False) as rc:
                secrets = rc._api.path("ppp/secret")
                for row in secrets:
                    if (row.get("name") or "").strip() == c.username:
                        secrets.update(**{".id": row[".id"],
                                          "disabled": "yes" if disabled_value else "no"})
                        break
        except Exception as e:
            errors.append(f"router-secret {c.customer_id}: {e}")

    for c in rows:
        try:
            _actor = dict(
                actor_type=request.session.get("user_type", "admin"),
                actor_id=request.session.get("user_id", ""),
                actor_name=request.session.get("user_name", ""),
            )
            _was_parked_s56s = (c.status or "").strip().lower() in (
                "parked", "expired", "disabled", "deactive", "suspended")
            if action == "make_active":
                log_customer_status_change(db, c, "Active",
                    reason="bulk Make-Active", **_actor)
                c.status = "Active"
                c.is_suspended = False
                # s36b5: unified-disconnect – the inner enforce already
                # handles router toggle + backend.kick + radclient CoA via
                # _router_set_secret_disabled_for_cust. We just skip the
                # per-customer FreeRADIUS restart; bulk does ONE sync+restart
                # at the end of the loop.
                try:
                    _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e:
                    errors.append(f"enforce {c.customer_id}: {_e}")
            elif action == "reset_mac":
                if hasattr(c, "mac_address"):
                    c.mac_address = ""
            elif action == "disconnect":
                _coa_kick(c)
            elif action in ("disable", "suspend", "deactivate"):
                new_st = {"suspend": "Expired",
                          "disable": "Disabled",
                          "deactivate": "Deactive"}[action]
                log_customer_status_change(db, c, new_st,
                    reason=f"bulk {action.capitalize()}", **_actor)
                c.status = new_st
                c.is_suspended = True
                # s36b5: unified-disconnect – secret disable + kick + CoA so
                # the live client loses its real IP and on reconnect lands in
                # the walled-garden pool.
                try:
                    _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e:
                    errors.append(f"enforce {c.customer_id}: {_e}")
            elif action in ("enable", "resume"):
                log_customer_status_change(db, c, "Active",
                    reason=f"bulk {action.capitalize()}", **_actor)
                c.status = "Active"
                c.is_suspended = False
                # s36b5: unified-disconnect – flip secret back on, kick the
                # (if any) walled-garden session so re-auth lands in real pool.
                try:
                    _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e:
                    errors.append(f"enforce {c.customer_id}: {_e}")
            elif action == "park":
                # s41f: One-click PARK — flip to "Parked" (distinct from
                # natural "Expired") + kick LIVE session. Secret stays
                # enabled. RADIUS resync at end emits parking-pool attrs.
                log_customer_status_change(db, c, "Parked",
                    reason="bulk Park", **_actor)
                c.status = "Parked"
                c.is_suspended = True
                try:
                    _router_kick_active_session(db, company_id, c)
                except Exception as _e:
                    errors.append(f"park-kick {c.customer_id}: {_e}")
            elif action == "unpark":
                # s41f: Reverse — Active again, kick live parking session.
                log_customer_status_change(db, c, "Active",
                    reason="bulk Unpark", **_actor)
                c.status = "Active"
                c.is_suspended = False
                try:
                    _router_kick_active_session(db, company_id, c)
                except Exception as _e:
                    errors.append(f"unpark-kick {c.customer_id}: {_e}")
            elif action == "terminate":
                log_customer_status_change(db, c, "Terminated",
                    reason="bulk Terminate", **_actor)
                c.status = "Terminated"
                c.is_suspended = True
                # s36b5: unified-disconnect – terminate has the same router
                # effect as disable: secret off + kick + CoA.
                try:
                    _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e:
                    errors.append(f"enforce {c.customer_id}: {_e}")
            else:
                return {"success": False, "message": f"Unknown action {action!r}"}
            touched += 1
        except Exception as e:
            errors.append(f"{c.customer_id}: {e}")

    db.commit()

    # Re-sync FreeRADIUS so the new statuses take effect immediately.
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=True)
    except Exception as e:
        errors.append(f"freeradius-sync: {e}")

    # __s56s_kick_after_restart__  Bug fix: bulk make_active / enable /
    # unpark kicks the live session via backend.kick + CoA INSIDE
    # _enforce_user_state — BEFORE the final FreeRADIUS restart. So when
    # the kicked session re-dials, FreeRADIUS still has the OLD (parking)
    # config in memory → user lands back in parking pool. Solution: do
    # a SECOND kick pass AFTER FreeRADIUS has reloaded with the fresh
    # Active-state config. This second kick triggers the CPE to re-auth
    # cleanly with the new PPPoE-pool attributes.
    if action in ("make_active", "enable", "resume", "unpark"):
        try:
            import time as _t_s56s
            _t_s56s.sleep(1.5)  # let radiusd finish reloading users file
            for _c in rows:
                if (_c.status or "").lower() == "active":
                    try:
                        _coa_kick(_c)
                    except Exception as _ke:
                        errors.append(f"2nd-kick {_c.customer_id}: {_ke}")
        except Exception as _e:
            errors.append(f"post-restart kick pass: {_e}")

    msg = f"{action} applied to {touched} customer(s)"
    if kicked: msg += f", {kicked} live session(s) kicked"
    if errors: msg += f"; errors: {len(errors)}"
    return {"success": True, "message": msg, "touched": touched,
            "kicked": kicked, "errors": errors}


