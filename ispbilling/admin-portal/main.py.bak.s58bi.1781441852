# __S39EMP_HELPERS__

def _s39emp_sync_locality_for_employee(db, company_id, employee_id, sid, admin_id=None):
    """Auto-create employee_locality_assignments rows so the new Sub-LCO
    employee inherits the Sub-LCO's assigned locations across all 3
    connection types (Broadband, PPPoE, static_ip).
    Idempotent: uses INSERT OR IGNORE-style upsert via SELECT-then-INSERT."""
    if not sid or not employee_id:
        return 0
    from sqlalchemy import text as _t
    rows = db.execute(_t(
        "SELECT location_id FROM sub_lco_locations WHERE sub_lco_id=:s"
    ), {"s": int(sid)}).fetchall()
    if not rows:
        return 0
    types = ("Broadband", "PPPoE", "static_ip")
    inserted = 0
    for (loc_id,) in rows:
        for ct in types:
            exists = db.execute(_t(
                "SELECT 1 FROM employee_locality_assignments "
                "WHERE employee_id=:e AND location_id=:l AND connection_type=:c"
            ), {"e": int(employee_id), "l": int(loc_id), "c": ct}).fetchone()
            if exists:
                continue
            db.execute(_t(
                "INSERT INTO employee_locality_assignments "
                "(company_id, employee_id, location_id, connection_type, "
                " active, created_at, updated_at, created_by, updated_by) "
                "VALUES (:co, :e, :l, :c, 1, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP, :a, :a)"
            ), {"co": company_id, "e": int(employee_id),
                "l": int(loc_id), "c": ct, "a": admin_id or ""})
            inserted += 1
    return inserted


def _s39emp_resync_all_employees_for_sub_lco(db, company_id, sid, admin_id=None):
    """Called when admin updates a Sub-LCO's location set: resync ALL existing
    employees of that Sub-LCO so their employee_locality_assignments match
    exactly the current sub_lco_locations set (deactivate stale, add new)."""
    if not sid:
        return 0
    from sqlalchemy import text as _t
    emp_rows = db.execute(_t(
        "SELECT id FROM employees WHERE company_id=:co AND sub_lco_id=:s "
        "AND is_deleted=false"
    ), {"co": company_id, "s": int(sid)}).fetchall()
    loc_rows = db.execute(_t(
        "SELECT location_id FROM sub_lco_locations WHERE sub_lco_id=:s"
    ), {"s": int(sid)}).fetchall()
    valid_locs = {int(r[0]) for r in loc_rows}
    types = ("Broadband", "PPPoE", "static_ip")
    changed = 0
    for (emp_id,) in emp_rows:
        # remove stale assignments not in valid_locs
        db.execute(_t(
            "DELETE FROM employee_locality_assignments "
            "WHERE employee_id=:e AND location_id NOT IN ("
            "  SELECT location_id FROM sub_lco_locations WHERE sub_lco_id=:s)"
        ), {"e": int(emp_id), "s": int(sid)})
        for loc_id in valid_locs:
            for ct in types:
                exists = db.execute(_t(
                    "SELECT 1 FROM employee_locality_assignments "
                    "WHERE employee_id=:e AND location_id=:l AND connection_type=:c"
                ), {"e": int(emp_id), "l": int(loc_id), "c": ct}).fetchone()
                if exists:
                    continue
                db.execute(_t(
                    "INSERT INTO employee_locality_assignments "
                    "(company_id, employee_id, location_id, connection_type, "
                    " active, created_at, updated_at, created_by, updated_by) "
                    "VALUES (:co, :e, :l, :c, 1, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP, :a, :a)"
                ), {"co": company_id, "e": int(emp_id),
                    "l": int(loc_id), "c": ct, "a": admin_id or ""})
                changed += 1
    return changed

def _s39emp_sub_lco_id(request):
    """Return current sub_lco_db_id from session (int) or None."""
    try:
        if (request.session.get("user_type") or "").lower() == "sub_lco":
            sid = request.session.get("sub_lco_db_id")
            return int(sid) if sid else None
    except Exception:
        pass
    return None


def _s39emp_code_map(db, company_id):
    """Map {sub_lco_db_id -> sub_lco_code} for a company. Used to suffix
    employee names with '(Sub-LCO: CODE)' in the Admin views."""
    from sqlalchemy import text as _t
    out = {}
    try:
        rows = db.execute(_t(
            "SELECT id, sub_lco_code FROM sub_lcos WHERE company_id = :c"
        ), {"c": company_id}).fetchall()
        for rid, code in rows:
            if rid is not None:
                out[int(rid)] = (code or "").strip()
    except Exception:
        pass
    return out

