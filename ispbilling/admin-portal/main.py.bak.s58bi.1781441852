# ===== _S39R5I_SECURITY — Security hardening =====
# 1) Per-IP login rate-limit (in-memory; per-process; clear after 60 min idle).
#    Defends /api/auth/login + /api/auth/password-reset/request from brute-force.
import time as _r5i_time
import threading as _r5i_thr
_r5i_lock = _r5i_thr.Lock()
_r5i_buckets: dict = {}            # ip -> {endpoint: [(ts, fail_count), ...]}
_R5I_WINDOW_SEC = 60               # rolling window
_R5I_MAX_PER_WIN = 12              # 12 attempts per minute per IP per endpoint
_R5I_BLOCK_SEC = 600               # 10-minute lockout once tripped
_r5i_blocked: dict = {}            # ip -> blocked_until_ts


def _r5i_get_ip(request) -> str:
    xf = request.headers.get("x-forwarded-for") or ""
    if xf:
        return xf.split(",")[0].strip()
    cli = getattr(request, "client", None)
    return getattr(cli, "host", "?") if cli else "?"


@app.middleware("http")
async def _r5i_security_middleware(request, call_next):
    """Combines (a) rate-limit on auth endpoints + (b) security headers."""
    path = request.url.path or ""
    # ---- (a) rate-limit ----
    if path in ("/api/auth/login", "/api/auth/password-reset/request"):
        ip = _r5i_get_ip(request)
        now = _r5i_time.time()
        with _r5i_lock:
            blocked_until = _r5i_blocked.get(ip)
            if blocked_until and blocked_until > now:
                from fastapi.responses import JSONResponse as _JR
                return _JR({"success": False,
                            "message": "Too many attempts. Try again in a few minutes.",
                            "retry_after": int(blocked_until - now)},
                           status_code=429)
            slot = _r5i_buckets.setdefault(ip, {}).setdefault(path, [])
            # purge old
            cutoff = now - _R5I_WINDOW_SEC
            while slot and slot[0] < cutoff:
                slot.pop(0)
            slot.append(now)
            if len(slot) > _R5I_MAX_PER_WIN:
                _r5i_blocked[ip] = now + _R5I_BLOCK_SEC
                from fastapi.responses import JSONResponse as _JR
                return _JR({"success": False,
                            "message": "Too many attempts. Locked out for 10 minutes.",
                            "retry_after": _R5I_BLOCK_SEC},
                           status_code=429)
    # ---- pass through ----
    response = await call_next(request)
    # _S40zκ_  Throttled session-activity heartbeat (only for HTML/page hits)
    try:
        utype = request.session.get("user_type")
        uid   = request.session.get("user_id")
        if utype and uid and utype in ("admin", "sub_lco", "employee"):
            from login_tracking import heartbeat as _hb
            _hb(utype, uid, request.session.get("company_id"))
    except Exception:
        pass
    # ---- (b) security headers ----
    response.headers.setdefault("X-Frame-Options", "SAMEORIGIN")
    response.headers.setdefault("X-Content-Type-Options", "nosniff")
    response.headers.setdefault("Referrer-Policy", "strict-origin-when-cross-origin")
    response.headers.setdefault("Permissions-Policy",
                                "geolocation=(self), microphone=(), camera=(self)")
    response.headers.setdefault("Strict-Transport-Security",
                                "max-age=31536000; includeSubDomains")
    # CSP is intentionally permissive for inline JS used in legacy templates
    csp = ("default-src 'self' data: blob: https:; "
           "img-src 'self' data: blob: https:; "
           "style-src 'self' 'unsafe-inline' https:; "
           "script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; "
           "font-src 'self' data: https:; "
           "connect-src 'self' https: wss:; "
           "frame-ancestors 'self';")
    response.headers.setdefault("Content-Security-Policy", csp)
    return response



