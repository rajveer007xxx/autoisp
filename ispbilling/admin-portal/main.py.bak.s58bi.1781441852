@app.on_event("startup")
def startup_event():
    import sqlite3
    from database import DB_PATH
    from pathlib import Path
    
    db_dir = Path(DB_PATH).parent
    db_dir.mkdir(parents=True, exist_ok=True)
    
    init_db()

    # s37q: idempotent permissions seed — ensures the 35 default entries
    # (19 feature + 6 app + 10 report) always exist. INSERT OR IGNORE so
    # admins' existing grants are untouched.
    try:
        conn_p = sqlite3.connect(DB_PATH)
        cur_p = conn_p.cursor()
        _DEFAULT_PERMS = [
            # (key, label, category)
            ('feat.user_management',    'User Management',          'feature'),
            ('feat.complaints',         'Complaints',               'feature'),
            ('feat.bill_dues',          'Bill Dues',                'feature'),
            ('feat.reports',            'Reports',                  'feature'),
            ('feat.renew_button',       'Renew button',             'feature'),
            ('feat.send_coupon',        'Send Coupon',              'feature'),
            ('feat.transaction_history','Transaction History',      'feature'),
            ('feat.my_support_list',    'My Support List',          'feature'),
            ('feat.global_edit',        'Global Edit Permission',   'feature'),
            ('feat.change_status',      'Change Status',            'feature'),
            ('feat.revenue_list',       'Revenue List',             'feature'),
            ('feat.invoice',            'Invoice',                  'feature'),
            ('feat.get_paid',           'Get Paid',                 'feature'),
            ('feat.stop_connection',    'Stop Connection Permission','feature'),
            ('feat.my_account',         'My Account Permission',    'feature'),
            ('feat.data_management',    'Data Management',          'feature'),
            ('feat.notification',       'Notification',             'feature'),
            ('feat.dashboard',          'Dashboard Permission',     'feature'),
            ('feat.edit_payment',       'Can Edit Payment Details', 'feature'),
            ('app.subscriber',   'Subscriber',   'app'),
            ('app.bill_due',     'Bill Due',     'app'),
            ('app.get_paid',     'Get Paid',     'app'),
            ('app.transaction',  'Transaction',  'app'),
            ('app.complaint',    'Complaint',    'app'),
            ('app.report',       'Report',       'app'),
            ('app.discount',     'Discount',     'app'),
            ('rep.collection',              'Collection',                     'report'),
            ('rep.amount_dues',             'Amount Dues',                    'report'),
            ('rep.complaint',               'Complaint',                      'report'),
            ('rep.total_subscriber',        'Total Subscriber',               'report'),
            ('rep.enrolment',               'Enrolment',                      'report'),
            ('rep.churn',                   'Churn/Opt-out',                  'report'),
            ('rep.subscriber_transactions', 'Subscriber Transaction History', 'report'),
            ('rep.general_ledger',          'General Ledger',                 'report'),
            ('rep.near_by_expiry',          'Near By Expiry',                 'report'),
            ('rep.recharges',               'Recharges',                      'report'),
        ]
        for k, lbl, cat in _DEFAULT_PERMS:
            cur_p.execute("INSERT OR IGNORE INTO permissions (key, label, category, created_at) "
                           "VALUES (?, ?, ?, datetime('now'))", (k, lbl, cat))
        conn_p.commit()
        conn_p.close()
    except Exception as _e:
        print(f"[perm-seed WARN] {_e}")

    
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    cursor.execute("PRAGMA table_info(customers)")
    columns = [row[1] for row in cursor.fetchall()]
    
    if 'customer_type' not in columns:
        cursor.execute("ALTER TABLE customers ADD COLUMN customer_type TEXT DEFAULT 'Postpaid'")
        cursor.execute("UPDATE customers SET customer_type = 'Postpaid' WHERE customer_type IS NULL")
        conn.commit()

    # Billing-address + document-upload columns (all nullable).
    extra_customer_columns = [
        'billing_address', 'billing_locality', 'billing_city',
        'billing_state', 'billing_pincode',
        'photograph_path', 'address_proof_path', 'id_proof_doc_path',
    ]
    for col in extra_customer_columns:
        if col not in columns:
            cursor.execute(f"ALTER TABLE customers ADD COLUMN {col} TEXT")
            conn.commit()
    
    conn.close()
    
    # Create network-related tables (Online Users, NAS Devices, IP Pools, Access Logs).
    try:
        radius_network.setup_tables()
    except Exception as e:
        print(f"radius_network.setup_tables error: {e}")

    # --- Migrate `plans` table: add extended bandwidth / RouterOS columns ---
    try:
        conn = sqlite3.connect(DB_PATH)
        cur = conn.cursor()

        # nas_devices extra columns
        cur.execute("PRAGMA table_info(nas_devices)")
        nas_cols = {row[1] for row in cur.fetchall()}
        nas_mig = [
            ("api_username",    "TEXT DEFAULT 'admin'"),
            ("api_password",    "TEXT DEFAULT ''"),
            ("port",            "INTEGER DEFAULT 8728"),
            ("use_tls",         "INTEGER DEFAULT 0"),
            ("use_ssh",         "INTEGER DEFAULT 0"),
            ("ssh_port",        "INTEGER DEFAULT 22"),
            ("provisioned_at",  "DATETIME"),
            ("last_status",     "TEXT DEFAULT 'unknown'"),
            ("last_status_msg", "TEXT DEFAULT ''"),
            ("pppoe_pool_name", "TEXT DEFAULT 'pppoe-pool'"),
            ("pinned_wan_iface", "TEXT DEFAULT ''"),
        ]
        for col_name, col_def in nas_mig:
            if col_name not in nas_cols:
                cur.execute(f"ALTER TABLE nas_devices ADD COLUMN {col_name} {col_def}")
                print(f"✓ nas_devices.{col_name} column added")

        # customers extra columns (PPPoE provisioning memory)
        cur.execute("PRAGMA table_info(customers)")
        cust_cols = {row[1] for row in cur.fetchall()}
        for col_name, col_def in [
            ("provisioned_nas_id", "INTEGER"),
            ("pppoe_password",     "TEXT DEFAULT ''"),
            ("latitude",           "REAL"),
            ("longitude",          "REAL"),
        ]:
            if col_name not in cust_cols:
                cur.execute(f"ALTER TABLE customers ADD COLUMN {col_name} {col_def}")
                print(f"✓ customers.{col_name} column added")

        # ip_pools extra columns — role (PPPoE/Hotspot/Parking), DNS, comment
        cur.execute("PRAGMA table_info(ip_pools)")
        ipp_cols = {row[1] for row in cur.fetchall()}
        for col_name, col_def in [
            ("role",        "TEXT DEFAULT 'PPPoE'"),
            ("dns_servers", "TEXT DEFAULT '8.8.8.8,1.1.1.1'"),
            ("comment",     "TEXT DEFAULT ''"),
        ]:
            if col_name not in ipp_cols:
                cur.execute(f"ALTER TABLE ip_pools ADD COLUMN {col_name} {col_def}")
                print(f"✓ ip_pools.{col_name} column added")
        conn.commit()

        cur.execute("PRAGMA table_info(plans)")
        plan_cols = {row[1] for row in cur.fetchall()}

        plan_migrations = [
            ("download_speed",       "TEXT"),
            ("upload_speed",         "TEXT"),
            ("validity_unit",        "TEXT DEFAULT 'days'"),
            ("fup_enabled",          "INTEGER DEFAULT 0"),
            ("fup_limit_gb",         "REAL DEFAULT 0.0"),
            ("fup_post_download",    "TEXT"),
            ("fup_post_upload",      "TEXT"),
            ("night_boost_enabled",  "INTEGER DEFAULT 0"),
            ("night_boost_start",    "TEXT"),
            ("night_boost_end",      "TEXT"),
            ("night_boost_download", "TEXT"),
            ("night_boost_upload",   "TEXT"),
            ("burst_enabled",        "INTEGER DEFAULT 0"),
            ("burst_limit_down",     "TEXT"),
            ("burst_limit_up",       "TEXT"),
            ("burst_threshold_down", "TEXT"),
            ("burst_threshold_up",   "TEXT"),
            ("burst_time_down",      "INTEGER DEFAULT 0"),
            ("burst_time_up",        "INTEGER DEFAULT 0"),
            ("priority",             "INTEGER DEFAULT 8"),
            ("queue_type",           "TEXT DEFAULT 'default'"),
        ]
        for col_name, col_def in plan_migrations:
            if col_name not in plan_cols:
                cur.execute(f"ALTER TABLE plans ADD COLUMN {col_name} {col_def}")
                print(f"✓ plans.{col_name} column added")
        conn.commit()
        conn.close()
    except Exception as e:
        print(f"plans migration error: {e}")
    
    print("✓ Application startup complete")


def require_superadmin(request: Request):
    if "user_id" not in request.session:
        return RedirectResponse(url="/login", status_code=303)
    if request.session.get("user_type") != "superadmin":
        return RedirectResponse(url="/login", status_code=303)
    return None

# Shared secret that the SuperAdmin portal presents when proxying NAS
# actions on behalf of a specific tenant (it doesn't have that tenant's
# session cookie). Checked ONLY for requests originating on 127.0.0.1 so
# it can't be exploited from the public internet even if the token leaks.
INTERNAL_TOKEN = os.environ.get("ISP_INTERNAL_TOKEN", "isp-bill-internal-sa-token-v1")

# Session 25.10: Country -> UTC offset (hours). Covers the common ISP markets.
# All DB timestamps are stored as naive UTC (datetime.utcnow()), so we add the
# offset here to display in admin's local time.
COUNTRY_TZ_OFFSET = {
    "India": 5.5, "in": 5.5, "IN": 5.5,
    "Nepal": 5.75,
    "Bangladesh": 6.0, "Sri Lanka": 5.5,
    "Pakistan": 5.0,
    "UAE": 4.0, "United Arab Emirates": 4.0, "Saudi Arabia": 3.0,
    "United Kingdom": 0.0, "UK": 0.0, "GB": 0.0,
    "United States": -5.0, "US": -5.0, "USA": -5.0,
    "Canada": -5.0, "Australia": 10.0,
    "Singapore": 8.0, "Malaysia": 8.0, "Thailand": 7.0,
    "Indonesia": 7.0, "Philippines": 8.0, "Vietnam": 7.0,
    "Germany": 1.0, "France": 1.0, "Italy": 1.0, "Spain": 1.0,
    "South Africa": 2.0, "Kenya": 3.0, "Nigeria": 1.0,
    "Brazil": -3.0, "Mexico": -6.0,
    "Japan": 9.0, "South Korea": 9.0, "China": 8.0,
    "Russia": 3.0, "Turkey": 3.0,
}

def company_tz_offset(company):
    """Return UTC offset in hours for a Company row. Defaults to IST (+5.5)."""
    if not company:
        return 5.5
    country = (getattr(company, "country", None) or "").strip()
    if not country:
        return 5.5
    return COUNTRY_TZ_OFFSET.get(country, COUNTRY_TZ_OFFSET.get(country.title(), 5.5))

def to_local(dt, company):
    """Convert naive UTC datetime to company-local timezone (naive again)."""
    if dt is None:
        return None
    from datetime import timedelta as _td
    try:
        return dt + _td(hours=company_tz_offset(company))
    except Exception:
        return dt



# __S38T_SUBLCO_ACTION_RELAX__ — Session 38t.5
# __S38T_PHASE6_AUTH__


# _S39R5C_ROLE_DENY — render access-denied page when the visitor is
# authenticated but their role does not match this page.
def _render_access_denied(request: "Request", required_role: str):
    sess = request.session
    ut = (sess.get("user_type") or "").lower()
    label_map = {"admin": "Administrator", "sub_lco": "Sub-LCO",
                 "employee": "Employee", "user": "Customer",
                 "superadmin": "Super Administrator"}
    home_map = {"admin": "/admin/dashboard", "sub_lco": "/sub-lco/dashboard",
                "employee": "/employee/dashboard", "user": "/user/dashboard",
                "superadmin": "/superadmin/dashboard"}
    ctx = {
        "request": request,
        "current_user_label": (sess.get("user_name") or sess.get("user_id") or
                               label_map.get(ut, "a user")),
        "required_role_label": label_map.get(required_role, "authorized personnel"),
        "home_url": home_map.get(ut, "/login"),
        "requested_path": str(request.url.path),
        "company_name": sess.get("company_name") or sess.get("company_id") or "",
    }
    return templates.TemplateResponse("access_denied.html", ctx, status_code=403)


def require_admin_or_internal(request: Request):
    """Return a `company_id` string if the request is authorized, else a
    `JSONResponse` that the caller should return. Accepts two paths:
      A. Admin session  — `company_id` pulled from `request.session`.
      B. Internal proxy — caller sent `X-Internal-Token: <INTERNAL_TOKEN>`
         AND the connection is from 127.0.0.1; `company_id` taken from
         `X-Company-Id` header. Used by the SuperAdmin portal to run
         NAS actions on behalf of a specific tenant.
    """
    tok = request.headers.get("X-Internal-Token") or request.headers.get("x-internal-token")
    if tok and tok == INTERNAL_TOKEN:
        client_host = (request.client.host if request.client else "") or ""
        if client_host in ("127.0.0.1", "::1", "localhost"):
            cid = (request.headers.get("X-Company-Id")
                    or request.headers.get("x-company-id") or "").strip()
            if cid:
                return cid
            return JSONResponse(
                {"success": False, "message": "X-Company-Id header required for internal calls"},
                status_code=400,
            )
    # _S39R5C2_INTERNAL_HTML — when the caller is a browser (Accept: text/html)
    # and not using the internal-token path, return browser-friendly responses
    # (login redirect / access-denied page) instead of raw JSON.
    _accept = (request.headers.get("accept") or "").lower()
    _wants_html = ("text/html" in _accept) and not tok
    if "user_id" not in request.session:
        if _wants_html:
            return RedirectResponse(url="/login", status_code=303)
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    if request.session.get("user_type") not in ("admin", "superadmin"):
        if _wants_html:
            return _render_access_denied(request, "admin")
        return JSONResponse({"success": False, "message": "Admin role required"}, status_code=403)
    cid = request.session.get("company_id") or ""
    if not cid:
        if _wants_html:
            return _render_access_denied(request, "admin")
        return JSONResponse({"success": False, "message": "No company context"}, status_code=400)
    return cid

def require_admin(request: Request):
    if "user_id" not in request.session:
        return RedirectResponse(url="/login", status_code=303)
    ut = request.session.get("user_type")
    if ut in ("admin", "superadmin"):
        return None
    # Session 38y.5 — allow sub-LCO sessions onto a curated set of admin APIs
    # (reports, invoices, complaints). Data is auto-scoped via SQLAlchemy
    # event listeners set up in sub_lco.attach_scope_events().
    if ut == "sub_lco":
        try:
            import sub_lco as _slmod
            sid = request.session.get("sub_lco_db_id")
            if sid:
                _slmod._SUB_LCO_CTX.set(int(sid))
        except Exception:
            pass
        p = request.url.path
        slco_admin_api = (
            "/api/admin/reports/",
            "/api/admin/invoices/",
            "/api/admin/collectors",
            "/api/invoices/",
            "/api/complaints/",
            "/api/transactions/",
        )
        if p.startswith(slco_admin_api):
            return None
    # Authenticated but wrong role → render Access Denied page.
    return _render_access_denied(request, "admin")

def require_employee(request: Request):
    if "user_id" not in request.session:
        return RedirectResponse(url="/login", status_code=303)
    if request.session.get("user_type") != "employee":
        return _render_access_denied(request, "employee")
    return None

def require_auth(request: Request):
    """Allow any authenticated user. Session 38y.3 — sub-LCO sessions get a
    curated whitelist of admin APIs; data is auto-scoped via SQLAlchemy event
    listeners attached in sub_lco.attach_scope_events().

    _S40zπ_v463_  Also accepts the internal-token + X-Company-Id pair
    for loopback calls from the mobile-api service (port 8005). When this
    path is taken, we synthesize a session-like context using request.state.
    """
    # _S40zπ_v463_  Internal-token shortcut for mobile-api forwarders.
    tok = request.headers.get("X-Internal-Token") or request.headers.get("x-internal-token")
    if tok and tok == INTERNAL_TOKEN:
        client_host = (request.client.host if request.client else "") or ""
        if client_host in ("127.0.0.1", "::1", "localhost"):
            cid = (request.headers.get("X-Company-Id")
                    or request.headers.get("x-company-id") or "").strip()
            if cid:
                request.session["user_id"] = "mobile-api"
                request.session["user_type"] = "admin"
                request.session["company_id"] = cid
                return None
    if "user_id" not in request.session:
        return JSONResponse(
            {"success": False, "message": "Unauthorized"}, status_code=401
        )
    # Session 38y.3 — set the sub-LCO scope contextvar so SQLAlchemy event
    # listeners auto-filter Customer / Location queries. This runs at the
    # very top of every admin endpoint that calls require_auth.
    if request.session.get("user_type") == "sub_lco":
        try:
            import sub_lco as _slmod
            sid = request.session.get("sub_lco_db_id")
            if sid:
                _slmod._SUB_LCO_CTX.set(int(sid))
        except Exception as _e:
            print(f"[sub_lco] ctx set failed: {_e}")
        path = request.url.path
        if (path.startswith("/api/sub-lco/") or path.startswith("/sub-lco/")
                or path in ("/api/plans/list", "/api/customers/check-username",
                            "/api/employees/list", "/api/locations/list",
                            "/api/payments/transaction-no")):
            return None
        shared_prefixes = (
            "/api/customers/",
            "/api/payments/",
            "/api/online-users/",
            "/api/admin/online-users/",
            "/api/admin/customers/",
            "/api/admin/bulk-",
            "/api/invoices/",
            "/api/admin/invoices/",
            "/api/admin/collectors",
            "/api/transactions/",
            "/api/complaints/",
            "/api/admin/reports/",
            # __S38T_SUBLCO_ACTION_RELAX__: subscriber-detail action endpoints
            # (change-password, change-plan, override-speed, create-message,
            # kyc-upload, details-save, connection-save, ...). Each individual
            # endpoint already enforces tenant + sub_lco_id scoping via the
            # SQLAlchemy ContextVar listener.
            "/api/subscribers/",
            # __S38T_PHASE6_AUTH__: Connection-tab IP pool dropdowns
            "/api/fix-ip/",
            # __S38U9__: Manual-invoice composer (admin parity for sub-LCO)
            "/api/manual-invoice/",
            # __S39EMP__: Employee CRUD parity for sub-LCO
            "/api/employees/",
            "/api/employee-locations",
            # __S39L__: locked filter dropdowns
            "/api/admin/collectors",
            # __S40_SUBLCO_WA_REF__: WhatsApp campaigns/templates + Referrals
            "/api/admin/wa-campaigns",
            "/api/admin/wa-templates",
            "/api/admin/sms-campaigns",
            "/api/admin/referrals/",
            "/api/sms/",
        )
        if path.startswith(shared_prefixes):
            return None
        # __S38T_PHASE6_AUTH__: Sub-LCO HTML pages reachable from the
        # shared subscriber-detail template. Data isolation enforced via
        # SQLAlchemy ContextVar event listeners.
        shared_html_prefixes = (
            "/admin/transactions",
            "/admin/subscribers/",
            # __S40_SUBLCO_WA_REF__: WhatsApp + Referrals + SMS pages
            "/admin/whatsapp-campaign",
            "/admin/whatsapp-templates",
            "/admin/referrals",
            "/admin/sms-center",
            # __S43A_SUBLCO_ADDCUST__: Unified Add-Customer wizard
            # (mobile WebView + web sidebar both target this URL).
            "/admin/add-customer",
        )
        if path.startswith(shared_html_prefixes):
            return None
        return JSONResponse(
            {"success": False,
             "message": "This resource is not accessible for Sub-LCO role."},
            status_code=403,
        )
    # __S38T_EMP_SCOPE__ — Employee sessions auto-scope to assigned
    # location names so any ORM Customer query is server-side restricted
    # to those rows. Mirrors the Sub-LCO ContextVar pattern.
    if request.session.get("user_type") == "employee":
        try:
            import employee_scope as _esmod
            from database import SessionLocal as _ESL
            _edb = _ESL()
            try:
                _esmod.set_scope_from_session(request, _edb)
            finally:
                _edb.close()
        except Exception as _e:
            print(f"[employee] scope set failed: {_e}")
    return None

def require_not_employee(request: Request):
    """Block employees from accessing destructive operations"""
    if request.session.get("user_type") == "employee":
        raise HTTPException(status_code=403, detail="Employees cannot perform this action")
    return None


    """Block employees from accessing destructive operations"""
    if request.session.get("user_type") == "employee":
        raise HTTPException(status_code=403, detail="Employees cannot perform this action")
    return None

def get_admin_context(request: Request, db: Session, active_page: str = ""):
    """Helper function to get common admin context data"""
    user_id = request.session.get("user_id", "N/A")
    user_name = request.session.get("user_name", "User")
    user_type = request.session.get("user_type", "admin")
    company_id = request.session.get("company_id", "N/A")
    
    from database import Company, Admin
    company = db.query(Company).filter(Company.company_id == company_id).first()
    company_name = company.company_name if company else "N/A"
    company_logo = company.logo_path if company and company.logo_path else None
    
    admin = db.query(Admin).filter(Admin.admin_id == user_id).first()
    admin_name = admin.admin_name if admin else user_name
    profile_image = admin.profile_image_path if admin and admin.profile_image_path else None
    
    # s36g-mfa-policy: compute MFA warning/block for this admin.
    try:
        from database import Admin as _Adm, Company as _Com
        import datetime as _dts36g
        _cid = request.session.get("company_id")
        _aid = request.session.get("user_id")
        _com = db.query(_Com).filter(_Com.company_id == _cid).first()
        _adm = db.query(_Adm).filter(_Adm.admin_id == _aid, _Adm.company_id == _cid).first()
        mfa_state = {"required": False, "enabled": False, "overdue": False,
                     "days_left": None, "deadline": ""}
        if _com and int(getattr(_com, "mfa_required_for_admins", 0) or 0):
            mfa_state["required"] = True
            mfa_state["enabled"] = bool(_adm and getattr(_adm, "totp_enabled", 0))
            dl = _adm.mfa_deadline if _adm and _adm.mfa_deadline else ""
            if dl and not mfa_state["enabled"]:
                try:
                    d = _dts36g.datetime.fromisoformat(dl)
                    delta = (d - _dts36g.datetime.utcnow()).days
                    mfa_state["days_left"] = delta
                    mfa_state["deadline"] = d.strftime("%d-%m-%Y")
                    if delta < 0: mfa_state["overdue"] = True
                except Exception:
                    pass
        _ctx_s36g_mfa = mfa_state
    except Exception:
        _ctx_s36g_mfa = {"required": False, "enabled": False, "overdue": False,
                         "days_left": None, "deadline": ""}
    return {
        # _S39R1_PORTAL_PREFIX_ADMIN — used by templates to build
        # portal-aware URLs (employee/sub-lco set their own path_prefix
        # in their respective context helpers).
        "path_prefix": "/admin",
        "request": request,
        "user_id": user_id,
        "user_name": user_name,
        "admin_name": admin_name,
        "profile_image": profile_image,
        "user_type": user_type,
        "company_id": company_id,
        "company_name": company_name,
        "company_logo": company_logo,
        "company": company,           # Session 25.6 - for feature-flag checks in templates
        "active_page": active_page,
        "mfa_state": _ctx_s36g_mfa,  # s36g MFA enforcement banner
    }

def get_employee_context(request: Request, db: Session, active_page: str = ""):
    from database import Company, Employee, EmployeePermission, Permission, EmployeeLocalityAssignment
    
    employee_code = request.session.get("user_id", "N/A")
    user_name = request.session.get("user_name", "User")
    company_id = request.session.get("company_id", "N/A")
    
    company = db.query(Company).filter(Company.company_id == company_id).first()
    company_name = company.company_name if company else "N/A"
    company_logo = company.logo_path if company and company.logo_path else None
    
    employee = db.query(Employee).filter(
        Employee.employee_code == employee_code,
        Employee.company_id == company_id
    ).first()
    
    employee_name = employee.employee_name if employee else user_name
    profile_image = employee.profile_image_path if employee and employee.profile_image_path else None
    employee_id = employee.id if employee else None
    
    permissions = []
    if employee:
        perms = db.query(Permission.key).join(
            EmployeePermission,
            EmployeePermission.permission_id == Permission.id
        ).filter(
            EmployeePermission.employee_id == employee.id
        ).all()
        permissions = [p.key for p in perms]
    
    assigned_location_ids = []
    if employee:
        locs = db.query(EmployeeLocalityAssignment.location_id).filter(
            EmployeeLocalityAssignment.employee_id == employee.id,
            EmployeeLocalityAssignment.active == True
        ).distinct().all()
        assigned_location_ids = [loc.location_id for loc in locs]
    
    return {
        "request": request,
        "user_id": employee_code,
        "user_name": user_name,
        "employee_name": employee_name,
        "employee_id": employee_id,
        "profile_image": profile_image,
        "user_type": "employee",
        "company_id": company_id,
        "company_name": company_name,
        "company_logo": company_logo,
        "permissions": permissions,
        "assigned_location_ids": assigned_location_ids,
        "active_page": active_page
    }



def _emp_has_perm(request: Request, db: Session, *keys: str) -> bool:
    """Return True if the logged-in employee has at least ONE of the given
    permission keys. Admins/sub-LCOs always pass through."""
    ut = (request.session.get("user_type") or "").lower()
    if ut != "employee":
        return True  # non-employee roles bypass
    if not keys:
        return False
    try:
        emp_code = request.session.get("user_id") or ""
        company_id = request.session.get("company_id") or ""
        from sqlalchemy import text as _t_p
        rows = db.execute(_t_p(
            "SELECT p.key FROM permissions p "
            "JOIN employee_permissions ep ON ep.permission_id = p.id "
            "JOIN employees e ON e.id = ep.employee_id "
            "WHERE e.employee_code=:ec AND e.company_id=:co"
        ), {"ec": emp_code, "co": company_id}).fetchall()
        emp_keys = {r[0] for r in rows}
        return any(k in emp_keys for k in keys)
    except Exception as _ex:
        print(f"[_emp_has_perm] {_ex}")
        return False


def _emp_require_perm(request: Request, db: Session, *keys: str):
    """Raise a 303 redirect to /employee/dashboard when the employee lacks
    the perm. Returns None when allowed (admin/sub-lco bypass)."""
    if _emp_has_perm(request, db, *keys):
        return None
    from fastapi.responses import RedirectResponse
    return RedirectResponse(url="/employee/dashboard?denied=1", status_code=303)

def _emp_admin_context(request: Request, db: Session, active_page: str):
    """Mirror of _slco_admin_context but for Employee — returns
    get_admin_context()-shaped dict with base_template=base_employee.html
    and path_prefix=/employee, so admin Jinja templates can render inside
    the employee shell."""
    base_ctx = get_admin_context(request, db)
    emp_ctx  = get_employee_context(request, db, active_page)
    base_ctx.update({
        "base_template": "base_employee.html",
        "path_prefix": "/employee",
        "active_page": active_page,
        "user_type": "employee",
        # Override admin name/profile fields with the employee's
        "admin_name":      emp_ctx.get("employee_name") or emp_ctx.get("user_name"),
        "employee_name":   emp_ctx.get("employee_name"),
        "user_name":       emp_ctx.get("user_name"),
        "profile_image":   emp_ctx.get("profile_image"),
        "user_id":         emp_ctx.get("user_id"),
        "company_id":      emp_ctx.get("company_id"),
        "company_name":    emp_ctx.get("company_name"),
        "company_logo":    emp_ctx.get("company_logo"),
        "permissions":     emp_ctx.get("permissions"),
        # __S43ZA_EMP_ID_IN_CTX__ — surface employee_id so /employee routes can scope.
        "employee_id":     emp_ctx.get("employee_id"),
        "assigned_location_ids": emp_ctx.get("assigned_location_ids") or [],
    })
    return base_ctx

def scope_customers_to_employee(query, request: Request, db: Session):
    """Filter customer query to only include customers in employee's assigned localities"""
    from database import Location, EmployeeLocalityAssignment, Employee
    from sqlalchemy import func
    
    employee_code = request.session.get("user_id")
    company_id = request.session.get("company_id")
    
    if not employee_code or not company_id:
        return query.filter(text("1=0"))
    
    employee = db.query(Employee).filter(
        Employee.employee_code == employee_code,
        Employee.company_id == company_id
    ).first()
    
    if not employee:
        return query.filter(text("1=0"))
    
    assigned_location_ids_subq = db.query(EmployeeLocalityAssignment.location_id).filter(
        EmployeeLocalityAssignment.employee_id == employee.id,
        EmployeeLocalityAssignment.company_id == company_id,
        EmployeeLocalityAssignment.active == True
    ).subquery()
    
    location_names = db.query(Location.name).filter(
        Location.id.in_(select(assigned_location_ids_subq)),
        Location.company_id == company_id
    ).all()
    
    if not location_names:
        return query.filter(text("1=0"))
    
    normalized_names = [name[0].strip().upper() for name in location_names if name[0]]
    
    if not normalized_names:
        return query.filter(text("1=0"))
    
    # __S43ZB__ Strict isolation hybrid:
    #   own-added OR (sub_lco_id = parent AND locality IN assigned)
    from sqlalchemy import or_ as _or_zb, and_ as _and_zb
    _slc = getattr(employee, "sub_lco_id", None)
    loc_pred = func.upper(func.trim(Customer.locality)).in_(normalized_names)
    own_pred = Customer.created_by_employee_id == int(employee.id)
    if _slc is None:
        slc_pred = _and_zb(Customer.sub_lco_id.is_(None), loc_pred)
    else:
        slc_pred = _and_zb(Customer.sub_lco_id == int(_slc), loc_pred)
    q = query.filter(_or_zb(own_pred, slc_pred))
    return q


async def homepage(request: Request):
    return templates.TemplateResponse("index.html", {"request": request})


# __s56AH_vlan_from_pool__  Source-of-truth VLAN read — module level.
def _enrich_users_vlan(db, company_id, users_list):
    """Walk users_list (list of dicts) and back-fill vlan_id / vlan_enabled
    from vlan_pool whenever the customers row had them NULL."""
    if not users_list:
        return
    try:
        from sqlalchemy import text as _vt
        rows = db.execute(_vt(
            "SELECT customer_id, vlan_id FROM vlan_pool "
            "WHERE company_id=:c AND state='assigned' AND customer_id IS NOT NULL"),
            {"c": company_id}).fetchall()
    except Exception as e:
        print(f"[_enrich_users_vlan] {e}")
        return
    pmap = {int(r[0]): int(r[1]) for r in rows if r[0] is not None and r[1] is not None}
    if not pmap:
        return
    for u in users_list:
        try:
            pk = int(u.get("pk") or 0)
        except Exception:
            continue
        v = pmap.get(pk)
        if v and not u.get("vlan_id"):
            u["vlan_id"] = v
            u["vlan_enabled"] = 1


