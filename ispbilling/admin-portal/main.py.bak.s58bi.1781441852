# === Session 35.1 admin notification state ===
try:
    from database import engine as _s351_engine
    with _s351_engine.begin() as _c:
        _c.exec_driver_sql("""
          CREATE TABLE IF NOT EXISTS admin_notification_state (
            company_id TEXT NOT NULL,
            admin_id   TEXT NOT NULL,
            last_seen_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
            PRIMARY KEY (company_id, admin_id)
          )
        """)
except Exception as _e:
    print(f"[S35.1] state table create failed: {_e}")


def _s351_last_seen(db, company_id, admin_id):
    try:
        row = db.execute(text(
            "SELECT last_seen_at FROM admin_notification_state WHERE company_id=:c AND admin_id=:a"
        ), {"c": company_id, "a": admin_id}).fetchone()
        if row and row[0]:
            val = row[0]
            if isinstance(val, str):
                try: val = datetime.fromisoformat(val.replace('Z',''))
                except Exception: return datetime.min
            # _S57C_NAIVE_  Strip tzinfo so callers can compare against
            # tz-naive datetimes (the existing ISO-parsed `ts` is naive).
            try:
                if getattr(val, 'tzinfo', None) is not None:
                    val = val.replace(tzinfo=None)
            except Exception:
                pass
            return val
    except Exception: pass
    return datetime.min


# === /Session 35.1 ===


# ===== s36b6: NAS one-click setup =====
# SuperAdmin-triggered quick-setup endpoints. Each fires an auto_configure
# run scoped to one task so routers can be bootstrapped for a particular
# auth method in one click.

@app.post("/api/nas-devices/{nas_id}/quick-setup/{profile}")
async def api_nas_quick_setup(nas_id: int, profile: str, request: Request,
                               db: Session = Depends(get_db)):
    # Only SuperAdmin or admin of the owning company may run this.
    try:
        from radius_network import NasDevice
        from routeros_provision import auto_configure
        ua = request.session.get("user_type")
        if ua not in ("admin", "superadmin"):
            return JSONResponse({"ok": False, "error": "auth"}, status_code=401)

        nas = db.query(NasDevice).filter(NasDevice.id == nas_id).first()
        if not nas:
            return JSONResponse({"ok": False, "error": "nas not found"}, status_code=404)
        # Scope check for admin
        if ua == "admin" and nas.company_id != request.session.get("company_id"):
            return JSONResponse({"ok": False, "error": "forbidden"}, status_code=403)

        # s36b6e: real option keys consumed by routeros_provision.auto_configure
        profile_map = {
            "pppoe":         {"queue_types": True, "pppoe_server": True,
                               "radius_client": True},
            "hotspot":       {"queue_types": True, "hotspot": True,
                               "radius_client": True},
            "static":        {"queue_types": True, "parking_pool": True,
                               "firewall_nat_baseline": True},
            "walled_garden": {"parking_pool": True, "firewall_nat_baseline": True},
        }
        options = profile_map.get(profile)
        if not options:
            return JSONResponse({"ok": False,
                                 "error": f"unknown profile {profile!r}"}, status_code=400)

        # Sensible defaults; admin can always re-run Auto-Configure for custom values.
        # s36b6d: resolve radius_server_ip via env / request hostname fallbacks.
        import os as _os_s36
        _radius_ip = (_os_s36.environ.get("ISP_PUBLIC_IP")
                      or getattr(request.url, "hostname", None)
                      or "127.0.0.1")
        result = auto_configure(
            nas=nas, options=options, ip_pools=[], plans=[],
            radius_server_ip=_radius_ip,
            radius_secret=(nas.secret or "testing123"),
            dry_run=False,
        )
        return JSONResponse({"ok": True, "profile": profile, "report": result})
    except Exception as e:
        return JSONResponse({"ok": False, "error": str(e)}, status_code=500)
# ===== /s36b6 NAS one-click setup =====


# ===== s36b7: static-ip uniqueness =====
def _validate_static_ip_unique(db, company_id: str, nas_id,
                                static_ip: str,
                                exclude_customer_id: str = None):
    """Return (True, None) if the static IP is free on the given NAS for
    this company, or (False, conflicting_customer_id) if taken.

    s36b7b: if nas_id is None, we still enforce COMPANY-WIDE uniqueness for
    static IPs so operators cannot double-assign an IP just because neither
    customer has a NAS set yet. If nas_id is provided, narrow the check to
    that NAS (allowing the same IP on different NAS boxes).

    An empty/missing IP returns (True, None) — nothing to check."""
    if not static_ip or not static_ip.strip():
        return True, None
    from database import Customer
    q = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.auth_type == "static_ip",
        Customer.static_ip_address == static_ip.strip(),
        Customer.status != "Deleted",
    )
    if nas_id:
        q = q.filter(Customer.provisioned_nas_id == nas_id)
    if exclude_customer_id:
        q = q.filter(Customer.customer_id != exclude_customer_id)
    dup = q.first()
    if dup:
        return False, dup.customer_id
    return True, None
