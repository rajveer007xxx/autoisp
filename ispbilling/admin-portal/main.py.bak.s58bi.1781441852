# === Session 33 extras ===
import io as _s33_io, zipfile as _s33_zip, re as _s33_re
from fastapi.responses import StreamingResponse as _S33Stream
from fastapi import Response as _S33Response

def _s33_dmy(v):
    """Jinja-safe: render any date-ish input as DD-MM-YYYY."""
    if v is None or v == "":
        return ""
    try:
        import datetime as _dt
        if isinstance(v, (_dt.date, _dt.datetime)):
            return v.strftime("%d-%m-%Y")
        s = str(v).strip()
        # ISO yyyy-mm-dd (or with time)
        if len(s) >= 10 and s[4] == "-" and s[7] == "-":
            return f"{s[8:10]}-{s[5:7]}-{s[0:4]}"
        # already dd-mm-yyyy
        if len(s) >= 10 and s[2] == "-" and s[5] == "-":
            # detect mm-dd-yyyy by day > 12 heuristic
            try:
                d1 = int(s[0:2]); d2 = int(s[3:5])
                if d1 > 12 or d2 > 12:
                    return f"{min(d1,d2):02d}-{max(d1,d2):02d}-{s[6:10]}" if False else s
            except Exception:
                pass
            return s
        return s
    except Exception:
        return str(v)

try:
    templates.env.globals["dmy"] = _s33_dmy
except Exception as _e:
    print(f"[S33] could not register dmy jinja helper: {_e}")


@app.get("/api/invoices/download-zip")
async def invoices_download_zip(request: Request, db: Session = Depends(get_db)):
    """Stream a ZIP of every invoice PDF matching the active filters.
    Query params: status, start_date, end_date, customer_name, customer_type,
    gst_invoice (yes/no)."""
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    company_id = request.session.get("company_id")
    if not company_id:
        return JSONResponse({"success": False, "message": "No company"}, status_code=400)

    from database import Invoice, Customer, Company

    q = db.query(Invoice, Customer).outerjoin(
        Customer,
        (Invoice.customer_id == Customer.customer_id) & (Customer.company_id == company_id)
    ).filter(Invoice.company_id == company_id)

    qp = request.query_params
    status       = (qp.get('status') or '').strip()
    customer_name= (qp.get('customer_name') or '').strip()
    start_date   = (qp.get('start_date') or '').strip()
    end_date     = (qp.get('end_date') or '').strip()
    ctype        = (qp.get('customer_type') or '').strip()
    gstf         = (qp.get('gst_invoice') or '').strip().lower()

    if start_date: q = q.filter(Invoice.issue_date >= start_date)
    if end_date:   q = q.filter(Invoice.issue_date <= end_date)
    if status:     q = q.filter(Invoice.status.ilike(status))
    if customer_name:
        q = q.filter(Customer.customer_name.ilike(f"%{customer_name}%"))
    if ctype:
        q = q.filter(Customer.customer_type.ilike(ctype))
    if gstf in ("yes","no"):
        # S33.2: same strict rule as sent-list
        if gstf == "yes":
            q = q.filter(Invoice.has_gst_no == True)
        else:
            q = q.filter(
                or_(Invoice.has_gst_no == False,
                    Invoice.has_gst_no == None)
            )

    rows = q.order_by(Invoice.created_at.desc(), Invoice.id.desc()).all()
    company = db.query(Company).filter(Company.company_id == company_id).first()
    company_data = {
        "company_name": company.company_name if company else "Auto ISP Billing",
        "company_address": company.company_address if company else "",
        "company_phone": company.company_phone if company else "",
        "company_email": company.company_email if company else "",
        "gst_number": company.gst_number if company else "",
    }

    buf = _s33_io.BytesIO()
    with _s33_zip.ZipFile(buf, 'w', _s33_zip.ZIP_DEFLATED) as zf:
        count = 0
        for inv, cust in rows:
            try:
                # Prefer the cached PDF if it exists
                pdf_bytes = None
                if inv.pdf_path and os.path.exists(inv.pdf_path):
                    with open(inv.pdf_path, 'rb') as fp: pdf_bytes = fp.read()
                else:
                    if not cust:
                        # Skip if we cannot even render it
                        continue
                    invoice_data = {
                        "invoice_no": inv.invoice_no,
                        "issue_date": inv.issue_date,
                        "due_date": inv.due_date,
                        "service_period_start": inv.start_date,
                        "service_period_end": inv.end_date,
                        "plan_name": inv.plan_name or "",
                        "base_amount": float(inv.base_amount or 0),
                        "cgst": float(inv.cgst_tax or 0),
                        "sgst": float(inv.sgst_tax or 0),
                        "igst": float(inv.igst_tax or 0),
                        "total_amount": float(inv.total_amount or 0),
                        "billing_type": (cust.customer_type or "PREPAID"),
                    }
                    customer_data = {
                        "customer_id": cust.customer_id,
                        "customer_name": cust.customer_name,
                        "customer_email": cust.customer_email,
                        "customer_phone": cust.customer_phone,
                        "address": cust.address,
                    }
                    pdf_bytes = generate_invoice_pdf(invoice_data, company_data, customer_data, [])
                if not pdf_bytes: continue
                # Zip entry name
                safe_inv = (inv.invoice_no or f"INV-{inv.id}").replace('/', '_').replace(' ', '_')
                safe_cust = ((cust.customer_name if cust else '') or (cust.customer_id if cust else '') or "customer").strip()
                safe_cust = _s33_re.sub(r"[^A-Za-z0-9._-]+", "_", safe_cust)[:40]
                name = f"{safe_inv}_{safe_cust}.pdf"
                zf.writestr(name, pdf_bytes)
                count += 1
            except Exception as e:
                print(f"[S33 zip] skip inv {getattr(inv,'id',None)}: {e}")
                continue
        # (README omitted per user request)

    buf.seek(0)
    fname = "invoices_" + datetime.now().strftime("%Y%m%d_%H%M") + ".zip"
    return _S33Stream(
        iter([buf.getvalue()]),
        media_type="application/zip",
        headers={"Content-Disposition": f'attachment; filename="{fname}"'},
    )


# ---------- Global Search ----------
@app.get("/api/admin/global-search")
async def api_global_search(request: Request, q: str = "", limit: int = 10, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")
    q = (q or "").strip()
    if not q or len(q) < 2:
        return {"success": True, "q": q, "results": []}
    results = []
    try:
        from database import Customer, Plan, Employee
        like = f"%{q}%"
        custs = db.query(Customer).filter(
            Customer.company_id == company_id,
            (Customer.customer_id.ilike(like) |
             Customer.customer_name.ilike(like) |
             Customer.username.ilike(like) |
             Customer.customer_phone.ilike(like) |
             Customer.customer_email.ilike(like))
        ).order_by(Customer.id.desc()).limit(limit).all()
        for c in custs:
            results.append({
                "type": "customer",
                "label": (c.customer_name or c.customer_id or "Customer"),
                "sub":   f"{c.customer_id or ''} · {c.customer_phone or ''} · {c.status or ''}",
                "url":   f"/admin/subscribers/{c.id}",
                "icon":  "fa fa-user",
            })
        plans = db.query(Plan).filter(
            Plan.company_id == company_id,
            (Plan.plan_name.ilike(like) | Plan.speed.ilike(like))
        ).limit(limit).all()
        for p in plans:
            results.append({
                "type": "plan",
                "label": p.plan_name or "Plan",
                "sub":   f"{p.service or ''} · {p.speed or ''} · ₹{p.after_tax_amount or 0:.0f}",
                "url":   "/admin/plans",
                "icon":  "fa fa-cubes",
            })
        emps = db.query(Employee).filter(
            Employee.company_id == company_id,
            Employee.is_deleted == False,
            (Employee.employee_name.ilike(like) |
             Employee.employee_code.ilike(like) |
             Employee.mobile.ilike(like) |
             Employee.email.ilike(like))
        ).limit(limit).all()
        for e in emps:
            results.append({
                "type": "employee",
                "label": e.employee_name or e.employee_code or "Employee",
                "sub":   f"{e.employee_code or ''} · {e.mobile or ''} · {e.status or ''}",
                "url":   "/admin/employees",
                "icon":  "fa fa-id-badge",
            })
    except Exception as ex:
        return {"success": False, "message": str(ex), "results": []}
    return {"success": True, "q": q, "results": results[: max(1, int(limit) * 3)]}

# === /Session 33 ===

# === S33.6 Invoice.has_gst_no auto-fill hook ===
def _s336_fill_has_gst_no(mapper, connection, target):
    """Before any Invoice is inserted, make sure has_gst_no is not NULL.

    Priority:
      1. If the code explicitly set it, keep it.
      2. Otherwise, check the PDF text if a pdf_path is already populated.
      3. Otherwise, fall back to the customer's current GST state.
      4. Otherwise, default to False (safe).
    """
    try:
        if getattr(target, "has_gst_no", None) is not None:
            return
        pdf_has = None
        pdf_path = getattr(target, "pdf_path", None)
        if pdf_path and os.path.exists(pdf_path):
            try:
                import re as _re
                from pypdf import PdfReader as _PdfReader
                t = "\n".join((p.extract_text() or "") for p in _PdfReader(pdf_path).pages)
                for m in _re.findall(r"GSTIN\s*[-:]?\s*([A-Za-z0-9]+)", t):
                    v = (m or "").strip()
                    if v and v.upper() not in ("N","NA","NONE","NIL"):
                        pdf_has = True; break
                if pdf_has is None:
                    pdf_has = False
            except Exception:
                pdf_has = None
        if pdf_has is not None:
            target.has_gst_no = bool(pdf_has)
            return
        # Fallback — customer's current GST state
        from database import Customer as _Cust
        cust_id = getattr(target, "customer_id", None)
        comp_id = getattr(target, "company_id", None)
        row = None
        if cust_id and comp_id:
            row = connection.execute(
                _Cust.__table__.select().where(
                    (_Cust.company_id == comp_id) & (_Cust.customer_id == cust_id)
                )
            ).first()
        if row is not None:
            d = dict(row._mapping)
            need = str(d.get("gst_invoice_needed") or "").upper() == "YES"
            gno  = str(d.get("customer_gst_no") or "").strip()
            target.has_gst_no = bool(need and gno)
        else:
            target.has_gst_no = False
    except Exception:
        # Never block an insert over this
        try: target.has_gst_no = False
        except Exception: pass
    # S33.7 — snapshot due_at_issue as running balance at this moment
    try:
        if getattr(target, "due_at_issue", None) in (None, 0, 0.0):
            from database import Invoice as _Inv, Payment as _Pay
            _comp = getattr(target, "company_id", None)
            _cust = getattr(target, "customer_id", None)
            if _comp and _cust:
                now_ts = getattr(target, "created_at", None) or datetime.now()
                inv_rows = connection.execute(
                    _Inv.__table__.select().where(
                        (_Inv.company_id == _comp) & (_Inv.customer_id == _cust)
                    )
                ).fetchall()
                inv_sum = sum(float((r._mapping.get("total_amount") or 0)) for r in inv_rows
                              if (r._mapping.get("created_at") or datetime.min) <= now_ts)
                pay_rows = connection.execute(
                    _Pay.__table__.select().where(
                        (_Pay.company_id == _comp) & (_Pay.customer_id == _cust)
                    )
                ).fetchall()
                pay_sum = sum(float((r._mapping.get("amount") or 0)) for r in pay_rows
                              if (r._mapping.get("paid_at") or datetime.min) <= now_ts)
                disc_sum = sum(float((r._mapping.get("discount") or 0)) for r in pay_rows
                              if (r._mapping.get("paid_at") or datetime.min) <= now_ts)
                # Include THIS invoice's own charge (not yet in inv_rows because
                # before_insert fires before the row exists)
                this_charge = float(getattr(target, "total_amount", 0) or 0)
                target.due_at_issue = round(inv_sum + this_charge - pay_sum - disc_sum, 2)
    except Exception:
        pass

from sqlalchemy import event as _s336_event
try:
    # _S39R5j_LISTENER_FIX_ — Invoice isn't in module scope here, so import it
    # from `database` before attaching the listener. Previously this block
    # silently failed with "name 'Invoice' is not defined" which left every
    # newly-created invoice with NULL due_at_issue.
    from database import Invoice as _S336_Invoice
    _s336_event.listen(_S336_Invoice, "before_insert", _s336_fill_has_gst_no)
    print("[S33.6] Invoice before_insert has_gst_no listener attached")
except Exception as _e:
    print(f"[S33.6] could not attach Invoice listener: {_e}")
# === /S33.6 hook ===

# === Session 34 wan speed ===
_S34_WAN_CACHE = {}   # nas_id -> {"iface": str, "ts": float}

@app.get("/api/admin/wan-speed/snapshot")
async def api_wan_snapshot(request: Request, nas_id: int = 0,
                           db: Session = Depends(get_db)):
    """Return current rx/tx bytes for the WAN interface of a NAS device.

    The client polls this ~once per second and computes Mbps from two
    successive snapshots. First call auto-detects the WAN interface and
    caches it for 5 minutes.
    """
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")

    from radius_network import NasDevice
    from routeros_provision import RouterOSClient

    q = db.query(NasDevice).filter(NasDevice.company_id == company_id,
                                   NasDevice.status == "Active")
    if nas_id:
        q = q.filter(NasDevice.id == int(nas_id))
    nas = q.order_by(NasDevice.id).first()
    if not nas:
        return JSONResponse({"ok": False, "message": "No active NAS device configured"},
                            status_code=404)

    # iface cache — re-use within 5 min
    import time as _t
    cache = _S34_WAN_CACHE.get(nas.id) or {}
    iface = cache.get("iface")
    iface_type = cache.get("iface_type") or ""
    pinned = False
    # s39: If an admin has pinned a WAN iface for this NAS, always use it
    # (no auto-detect, no cache TTL). This prevents the graph from
    # flipping to the wrong port during a multi-WAN failover test.
    pinned_iface = (getattr(nas, "pinned_wan_iface", "") or "").strip()
    if pinned_iface:
        iface = pinned_iface
        iface_type = cache.get("iface_type") or ""  # best-effort
        pinned = True
    if (not pinned) and (not iface or (_t.time() - cache.get("ts", 0)) > 300):
        try:
            with RouterOSClient(nas, dry_run=False) as c:
                info = c.detect_wan() or {}
                iface = info.get("interface")
                # Resolve the iface type from candidates for transparency.
                iface_type = ""
                for _cand in (info.get("candidates") or []):
                    if (_cand.get("name") or "") == iface:
                        iface_type = _cand.get("type") or ""
                        break
                if iface:
                    _S34_WAN_CACHE[nas.id] = {
                        "iface": iface, "iface_type": iface_type, "ts": _t.time()
                    }
                    try:
                        print(f"[WAN-SPEED] nas={nas.id}({nas.name}) detected WAN iface='{iface}' type='{iface_type}' src='{info.get('source')}'", flush=True)
                    except Exception:
                        pass
        except Exception as e:
            return JSONResponse({"ok": False, "message": f"WAN detect failed: {e}"},
                                status_code=502)
    if not iface:
        return JSONResponse({"ok": False, "message": "Could not detect WAN interface"},
                            status_code=502)

    try:
        with RouterOSClient(nas, dry_run=False) as c:
            rx_bytes = tx_bytes = None
            link_rate = None  # bits/sec, when known
            running = None
            if getattr(c, "_api", None):
                rows = list(c._api.path("interface"))
                row = next((r for r in rows if (r.get("name") or "") == iface), None)
                if row:
                    rx_bytes = int(row.get("rx-byte") or 0)
                    tx_bytes = int(row.get("tx-byte") or 0)
                    running  = row.get("running") in (True, "true", "yes")
                # Try ethernet monitor for negotiated link rate (e.g. "1Gbps")
                try:
                    eths = list(c._api.path("interface/ethernet"))
                    is_eth = any((e.get("name") or "") == iface for e in eths)
                    if is_eth:
                        mon = list(c._api(
                            "/interface/ethernet/monitor",
                            "=numbers=" + iface,
                            "=once=",
                        ))
                        if mon:
                            rate_str = (mon[0].get("rate") or "").strip().lower()
                            # Examples: "1Gbps", "100Mbps", "10Mbps"
                            mult = None
                            if rate_str.endswith("gbps"): mult = 1_000_000_000
                            elif rate_str.endswith("mbps"): mult = 1_000_000
                            elif rate_str.endswith("kbps"): mult = 1_000
                            if mult:
                                try:
                                    num = float(re.findall(r"[\d.]+", rate_str)[0])
                                    link_rate = int(num * mult)
                                except Exception:
                                    pass
                except Exception:
                    pass
            elif getattr(c, "_ssh", None):
                out, _, _ = c._ssh.exec(f'/interface print terse where name="{iface}"')
                m_rx = re.search(r'rx-byte=(\d+)', out or '')
                m_tx = re.search(r'tx-byte=(\d+)', out or '')
                if m_rx: rx_bytes = int(m_rx.group(1))
                if m_tx: tx_bytes = int(m_tx.group(1))
            if rx_bytes is None or tx_bytes is None:
                return JSONResponse({"ok": False, "message": f"Interface '{iface}' not found"},
                                    status_code=502)
            return {
                "ok": True,
                "nas": {"id": nas.id, "name": nas.name, "ip": nas.ip_address},
                "iface": iface,
                "iface_type": iface_type,
                "link_rate": link_rate,
                "running": running,
                "pinned": pinned,
                "rx_bytes": rx_bytes,
                "tx_bytes": tx_bytes,
                "ts": _t.time(),
            }
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"Read failed: {e}"},
                            status_code=502)
# === /Session 34 ===

