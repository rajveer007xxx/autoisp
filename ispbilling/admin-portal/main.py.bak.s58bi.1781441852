# Session 25.13 - prevent stubborn browser caches on subscriber detail pages
from starlette.middleware.base import BaseHTTPMiddleware
class NoCacheAdminPages(BaseHTTPMiddleware):
    async def dispatch(self, request, call_next):
        response = await call_next(request)
        path = request.url.path
        if (path.startswith("/admin/subscribers/") or
            path.startswith("/admin/users") or
            path.startswith("/admin/nas-devices") or
            path.startswith("/pay")):
            response.headers["Cache-Control"] = "no-store, no-cache, must-revalidate, max-age=0"
            response.headers["Pragma"] = "no-cache"
            response.headers["Expires"] = "0"
            response.headers["X-AISPB-NoCache"] = "1"
        return response
app.add_middleware(NoCacheAdminPages)

# __S39D__ Remember-me: 30-day lifetime by default; login endpoint
# rewrites the Set-Cookie header without Max-Age when user did not
# tick "Remember me", making it a session cookie that dies when
# browser closes.
app.add_middleware(SessionMiddleware, secret_key="your-secret-key-change-in-production-12345678", max_age=30*24*60*60, same_site="lax", https_only=False)
import re  # __S39D__

# __S39D__ Remember-me cookie rewriter — strips Max-Age/Expires from the
# session cookie when the user did NOT tick "Remember me", so it becomes a
# browser-session cookie that dies on browser close. Implemented as a raw
# ASGI middleware to intercept Set-Cookie at send-time (more reliable than
# mutating response.raw_headers after BaseHTTPMiddleware).
class _S39DRememberMeASGI:
    def __init__(self, app):
        self.app = app

    async def __call__(self, scope, receive, send):
        if scope["type"] != "http":
            await self.app(scope, receive, send)
            return

        async def _wrapped_send(event):
            if event["type"] == "http.response.start":
                try:
                    sess = scope.get("session") or {}
                    rem  = sess.get("__s39d_remember")
                    headers = list(event.get("headers", []))
                    if rem is False:
                        for i, (h_name, h_val) in enumerate(headers):
                            if h_name.lower() == b"set-cookie":
                                txt = h_val.decode("latin-1")
                                if "session=" in txt:
                                    txt = re.sub(r"; ?Max-Age=\d+", "", txt, flags=re.I)
                                    txt = re.sub(r"; ?Expires=[^;]+", "", txt, flags=re.I)
                                    headers[i] = (h_name, txt.encode("latin-1"))
                    # __s56AO_cookie_domain__ : add Domain= so session
                    # cookie is sent to ALL *.autoispbilling.com subdomains
                    # (required for OLT Web UI proxy at olt-N.olt.autoispbilling.com).
                    for i, (h_name, h_val) in enumerate(headers):
                        if h_name.lower() == b"set-cookie":
                            txt = h_val.decode("latin-1")
                            if txt.lower().startswith("session=") and "domain=" not in txt.lower():
                                txt = txt.rstrip("\r\n").rstrip() + "; Domain=autoispbilling.com"
                                headers[i] = (h_name, txt.encode("latin-1"))
                    event["headers"] = headers
                except Exception:
                    pass
            await send(event)

        await self.app(scope, receive, _wrapped_send)

app.add_middleware(_S39DRememberMeASGI)
