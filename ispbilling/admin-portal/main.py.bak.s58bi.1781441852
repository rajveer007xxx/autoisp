@app.get("/employee/profile", response_class=HTMLResponse)
async def employee_profile_page(request: Request, db: Session = Depends(get_db)):
    """__S43ZP__ Dedicated, read-only employee profile page."""
    auth_check = require_employee(request)
    if auth_check: return auth_check

    from database import Employee
    company_id = request.session.get("company_id")
    emp_code = request.session.get("user_id")

    emp_row = (db.query(Employee)
                 .filter(Employee.company_id == company_id,
                         Employee.employee_code == emp_code)
                 .first())

    sub_lco_name = None
    if emp_row and getattr(emp_row, "sub_lco_id", None):
        try:
            row = db.execute(text(
                "SELECT name FROM sub_lcos WHERE id=:i AND company_id=:c"
            ), {"i": int(emp_row.sub_lco_id), "c": company_id}).fetchone()
            if row:
                sub_lco_name = row[0]
        except Exception:
            sub_lco_name = None

    ctx = _emp_admin_context(request, db, "profile")
    ctx["employee"] = {
        "code":          emp_row.employee_code if emp_row else (emp_code or ""),
        "name":          emp_row.employee_name if emp_row else "",
        "email":         (emp_row.email if emp_row else "") or "",
        "mobile":        (emp_row.mobile if emp_row else "") or "",
        "status":        (emp_row.status if emp_row else "Active") or "Active",
        "profile_image": (emp_row.profile_image_path if emp_row else "") or "",
        "sub_lco_name":  sub_lco_name,
    }
    return templates.TemplateResponse("employee_profile.html", ctx)


# __S43ZP__ Employee profile API: change password (current+new) ──────────
@app.post("/api/employee/profile/change-password")
async def api_employee_profile_change_password(request: Request,
                                                db: Session = Depends(get_db)):
    auth_check = require_employee(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    import bcrypt
    from database import Employee
    try:
        body = await request.json()
    except Exception:
        body = {}
    cur = (body.get("current_password") or "").strip()
    new = (body.get("new_password") or "").strip()
    if not cur or len(new) < 6:
        return JSONResponse({"success": False,
                             "message": "Current password required and new password must be at least 6 characters."},
                            status_code=400)
    company_id = request.session.get("company_id")
    emp_code   = request.session.get("user_id")
    emp = (db.query(Employee)
             .filter(Employee.company_id == company_id,
                     Employee.employee_code == emp_code)
             .first())
    if not emp:
        return JSONResponse({"success": False, "message": "Employee account not found."},
                            status_code=404)
    try:
        ok = bcrypt.checkpw(cur.encode("utf-8"),
                            (emp.password_hash or "").encode("utf-8"))
    except Exception:
        ok = False
    if not ok:
        return JSONResponse({"success": False, "message": "Current password is incorrect."},
                            status_code=400)
    emp.password_hash = bcrypt.hashpw(new.encode("utf-8"), bcrypt.gensalt()).decode("utf-8")
    db.commit()
    # Force re-login for safety.
    try:
        request.session.clear()
    except Exception:
        pass
    return {"success": True, "message": "Password changed. Please sign in again."}


# __S43ZP__ Employee profile photo upload ─────────────────────────────────
@app.post("/api/employee/profile/upload-photo")
async def api_employee_profile_upload_photo(request: Request,
                                             photo: UploadFile = File(...),
                                             db: Session = Depends(get_db)):
    auth_check = require_employee(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    from database import Employee
    import uuid as _uuid
    company_id = request.session.get("company_id")
    emp_code   = request.session.get("user_id")
    emp = (db.query(Employee)
             .filter(Employee.company_id == company_id,
                     Employee.employee_code == emp_code)
             .first())
    if not emp:
        return JSONResponse({"success": False, "message": "Employee account not found."},
                            status_code=404)
    ext = (os.path.splitext(photo.filename or "")[1] or ".jpg").lower()
    if ext not in (".jpg", ".jpeg", ".png", ".webp"):
        return JSONResponse({"success": False, "message": "Unsupported file type."},
                            status_code=400)
    save_dir = "/opt/ispbilling/admin-portal/static/employee_photos"
    os.makedirs(save_dir, exist_ok=True)
    fname = f"emp_{company_id}_{emp_code}_{_uuid.uuid4().hex[:8]}{ext}"
    fpath = os.path.join(save_dir, fname)
    with open(fpath, "wb") as fout:
        fout.write(await photo.read())
    rel_url = f"/static/employee_photos/{fname}"
    emp.profile_image_path = rel_url
    db.commit()
    return {"success": True, "message": "Photo uploaded.", "path": rel_url}

