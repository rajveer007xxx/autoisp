    nas_map = {n.id: n.name for n in db.query(NasDevice).filter(NasDevice.company_id == company_id).all()}
    headers = ['ID','IP Address','Label','Status','Assigned To','Assigned NAS','Notes','Created At','Updated At']
    rows = []
