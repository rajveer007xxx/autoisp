import os as _mi_os
from datetime import datetime as _mi_dt, timedelta as _mi_td

def _mi_resolve_sender(request, db):
    cid = request.session.get("company_id") or ""
    user_type = request.session.get("user_type") or "admin"
    sender_label = ""
    sender_role = ""
    sender_email = ""
    sender_phone = ""
    sender_address = ""
    sender_gst = ""
    sender_terms = ""; sender_decl = ""; sender_actor_id = ""
    sender_brand = {}
    if user_type == "sub_lco":
        sid = request.session.get("sub_lco_db_id") or request.session.get("sub_lco_id")
        row = db.execute(text(
            "SELECT id, name, sub_lco_code, email, mobile, address, "
            "       COALESCE(terms_conditions,''), COALESCE(declaration,''), "
            "       COALESCE(inv_company_name,''), COALESCE(inv_company_gst,''), "
            "       COALESCE(inv_company_phone,''), COALESCE(inv_company_email,''), "
            "       COALESCE(inv_company_address,''), COALESCE(inv_bank_name,''), "
            "       COALESCE(inv_account_number,''), COALESCE(inv_branch_ifsc,''), "
            "       COALESCE(inv_branch_location,''), COALESCE(inv_upi_id,'') "
            "FROM sub_lcos WHERE id=:i AND company_id=:c"
        ), {"i": sid, "c": cid}).fetchone()
        if row:
            sender_actor_id = str(row[0])
            sender_label = row[1]; sender_role = f"Sub-LCO · {row[2]}"
            sender_email = row[3] or ""; sender_phone = row[4] or ""
            sender_address = row[5] or ""
            sender_terms = row[6] or ""; sender_decl = row[7] or ""
            sender_brand = {
                "inv_company_name": row[8] or "", "inv_company_gst": row[9] or "",
                "inv_company_phone": row[10] or "", "inv_company_email": row[11] or "",
                "inv_company_address": row[12] or "", "inv_bank_name": row[13] or "",
                "inv_account_number": row[14] or "", "inv_branch_ifsc": row[15] or "",
                "inv_branch_location": row[16] or "", "inv_upi_id": row[17] or "",
            }
    elif user_type == "employee":
        ec = request.session.get("user_id") or request.session.get("employee_code") or ""
        row = db.execute(text(
            "SELECT employee_name, mobile, email, address, "
            "       COALESCE(terms_conditions,''), COALESCE(declaration,''), "
            "       COALESCE(inv_company_name,''), COALESCE(inv_company_gst,''), "
            "       COALESCE(inv_company_phone,''), COALESCE(inv_company_email,''), "
            "       COALESCE(inv_company_address,''), COALESCE(inv_bank_name,''), "
            "       COALESCE(inv_account_number,''), COALESCE(inv_branch_ifsc,''), "
            "       COALESCE(inv_branch_location,''), COALESCE(inv_upi_id,'') "
            "FROM employees WHERE employee_code=:e AND company_id=:c"
        ), {"e": ec, "c": cid}).fetchone()
        if row:
            sender_actor_id = ec
            sender_label = row[0]; sender_role = f"Employee · {ec}"
            sender_email = (row[2] or ""); sender_phone = (row[1] or "")
            sender_address = row[3] or ""
            sender_terms = row[4] or ""; sender_decl = row[5] or ""
            sender_brand = {
                "inv_company_name": row[6] or "", "inv_company_gst": row[7] or "",
                "inv_company_phone": row[8] or "", "inv_company_email": row[9] or "",
                "inv_company_address": row[10] or "", "inv_bank_name": row[11] or "",
                "inv_account_number": row[12] or "", "inv_branch_ifsc": row[13] or "",
                "inv_branch_location": row[14] or "", "inv_upi_id": row[15] or "",
            }
    if not sender_label:
        ad = request.session.get("user_id") or request.session.get("admin_id") or ""
        row = db.execute(text(
            "SELECT admin_name, admin_id FROM admins WHERE admin_id=:a AND company_id=:c"
        ), {"a": ad, "c": cid}).fetchone()
        sender_label = (row[0] if row else "Admin") or "Admin"
        sender_role = f"Admin · {ad}"
        sender_actor_id = ad
    # GST# always sourced from the company (legal entity).
    co_row = db.execute(text(
        "SELECT gst_number, company_address, COALESCE(terms_conditions,''), COALESCE(declaration,'') "
        "FROM companies WHERE company_id=:c LIMIT 1"
    ), {"c": cid}).fetchone()
    co_terms = ""; co_decl = ""
    if co_row:
        sender_gst = co_row[0] or ""
        if not sender_address:
            sender_address = co_row[1] or ""
        co_terms = co_row[2] or ""
        co_decl  = co_row[3] or ""
    # For admin, the row-level T&C / declaration ARE the company-wide ones.
    if user_type not in ("sub_lco", "employee"):
        sender_terms = co_terms; sender_decl = co_decl
    return {
        "label": sender_label, "role": sender_role,
        "email": sender_email, "phone": sender_phone,
        "address": sender_address, "gst_no": sender_gst,
        "user_type": user_type,
        "actor_id": sender_actor_id,
        "terms_conditions": sender_terms,
        "declaration": sender_decl,
        "company_terms_conditions": co_terms,
        "company_declaration": co_decl,
        "branding": sender_brand,
    }

def _mi_company(db, cid):
    row = db.execute(text(
        "SELECT company_name, company_email, company_phone, company_address, "
        "       state, city, pincode, gst_number, bank_name, account_number, "
        "       branch_code, branch_location, branch_ifsc, upi_id, "
        "       declaration, terms_conditions, gst_invoice_needed, "
        "       smtp_server, smtp_port, smtp_username, smtp_password "
        "FROM companies WHERE company_id=:c LIMIT 1"
    ), {"c": cid}).fetchone()
    if not row:
        company = {}
    else:
        keys = ["company_name","company_email","company_phone","company_address",
                "state","city","pincode","gst_number","bank_name","account_number",
                "branch_code","branch_location","branch_ifsc","upi_id",
                "declaration","terms_conditions","gst_invoice_needed",
                "smtp_server","smtp_port","smtp_username","smtp_password"]
        company = {k: (v if v is not None else "") for k, v in zip(keys, row)}
    # __S38U13__ — when company SMTP missing/blank, mirror main.py's
    # superadmin-fallback so manual invoices use the same SMTP path that
    # auto-generated invoices already rely on.
    if not (company.get("smtp_server") and company.get("smtp_username")
            and company.get("smtp_password")):
        try:
            sa = db.execute(text(
                "SELECT smtp_server, smtp_port, smtp_username, smtp_password "
                "FROM superadmins WHERE id=1"
            )).fetchone()
            if sa and all(sa):
                company["smtp_server"]   = company.get("smtp_server")   or sa[0]
                company["smtp_port"]     = company.get("smtp_port")     or sa[1]
                company["smtp_username"] = company.get("smtp_username") or sa[2]
                company["smtp_password"] = company.get("smtp_password") or sa[3]
        except Exception as _e:
            print(f"[manual-invoice] superadmin SMTP fallback failed: {_e}")
    return company

@app.get("/api/manual-invoice/sender-info")
async def api_mi_sender_info(request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    cid = request.session.get("company_id")
    sender = _mi_resolve_sender(request, db)
    company = _mi_company(db, cid)
    # SMTP fields are sensitive — strip from response.
    safe = {k: v for k, v in company.items() if not k.startswith("smtp_")}
    return {"success": True, "sender": sender, "company": safe}

@app.get("/api/manual-invoice/customers")
async def api_mi_customers(request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    company_id = request.session.get("company_id")
    from database import Customer
    q = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.status != "Deleted",
    ).order_by(Customer.customer_name)
    items = []
    for c in q.limit(2000).all():
        items.append({
            "customer_id": c.customer_id,
            "customer_name": c.customer_name or "",
            "customer_email": c.customer_email or "",
            "customer_phone": c.customer_phone or "",
            "address": c.address or "",
            "city": c.city or "",
            "state": c.state or "",
            "pincode": c.pincode or "",
            "customer_gst_no": getattr(c, "customer_gst_no", "") or "",
        })
    return {"success": True, "items": items}




def _mi_to_standard_pdf_args(invoice: dict, recipient: dict,
                              company_for_pdf: dict, line_items: list):
    """_S40ze_  Convert manual-send invoice payload to the args expected
    by the standard generate_invoice_pdf(). Computes totals + GST from
    line_items so the regular template renders with proper amounts."""
    # Sub-total / GST
    sub_total = 0.0; cgst_tax = 0.0; sgst_tax = 0.0
    for li in (line_items or []):
        try:
            q = float(li.get("qty", 1) or 1)
            r = float(li.get("rate", 0) or 0)
            sub_total += q * r
            cgst_tax  += q * r * float(li.get("cgst_pct", 0) or 0) / 100.0
            sgst_tax  += q * r * float(li.get("sgst_pct", 0) or 0) / 100.0
        except Exception:
            pass
    has_gst = bool(invoice.get("is_gst")) and (cgst_tax > 0 or sgst_tax > 0)
    if not has_gst:
        cgst_tax = 0.0; sgst_tax = 0.0
    grand_total = sub_total + cgst_tax + sgst_tax
    cgst_pct = (cgst_tax / sub_total * 100.0) if (has_gst and sub_total) else 0
    sgst_pct = (sgst_tax / sub_total * 100.0) if (has_gst and sub_total) else 0
    # Description: concatenate line-item descriptions so the standard
    # template has something readable in its plan/description column.
    # _S40zλ_  The form sends `description` (and `hsn`), older callers may
    # send `name` / `hsn_sac` — accept both keys gracefully.
    descs = [str(li.get("description") or li.get("name") or "").strip()
              for li in (line_items or [])]
    descs = [d for d in descs if d]
    description = "; ".join(descs) if descs else (invoice.get("notes") or "Service")
    # Prev-due — manual invoices may include an existing customer's running
    # outstanding balance. invoice["total_due"] = running + this_total, so
    # anything above this invoice's grand_total is the prev-due bucket.
    try:
        prev_due = max(0.0, float(invoice.get("total_due", 0) or 0) - grand_total)
    except Exception:
        prev_due = 0.0
    invoice_data = {
        "invoice_no":     invoice.get("invoice_no") or "",
        "issue_date":     invoice.get("issue_date") or "",
        "base_amount":    sub_total,
        "total_amount":   grand_total,
        "cgst_tax":       cgst_tax,
        "sgst_tax":       sgst_tax,
        "igst_tax":       0.0,
        "cgst_percent":   cgst_pct,
        "sgst_percent":   sgst_pct,
        "igst_percent":   0.0,
        "description":    description,
        "plan_name":      description,
        # _S40zf_  Convert {name|description, qty, rate, cgst_pct, sgst_pct,
        # hsn|hsn_sac} → standard line-item format.
        "line_items":     [
            {
                "description": (str(li.get("description") or li.get("name") or "").strip()
                                or "Service"),
                "hsn_sac":     (str(li.get("hsn_sac") or li.get("hsn") or "").strip()
                                or "998422"),
                "quantity":    f"{int(float(li.get('qty', 1) or 1))} nos",
                "rate":        f"{float(li.get('rate', 0) or 0):.2f}",
                "amount":      f"{float(li.get('qty', 1) or 1) * float(li.get('rate', 0) or 0):.2f}",
            }
            for li in (line_items or [])
        ],
        "prev_due_total": prev_due,
        "payment_received": 0.0,
        "start_date":     invoice.get("issue_date") or "",
        "end_date":       invoice.get("due_date") or "",
        "invoice_type":   "Manual",
        "is_first_invoice": False,
        "is_postpaid":    True,
        "period_months":  0,
    }
    customer_data = {
        "customer_name":      recipient.get("name") or recipient.get("customer_name") or "",
        "username":           recipient.get("customer_id") or recipient.get("username") or "",
        "mobile":             recipient.get("phone") or recipient.get("mobile") or "",
        "address":            recipient.get("address") or "",
        "billing_address":    recipient.get("address") or "",
        # _v4730_ADDR  Forward full address parts to the PDF builder.
        "locality":           recipient.get("locality") or "",
        "billing_locality":   recipient.get("locality") or "",
        "city":               recipient.get("city") or "",
        "billing_city":       recipient.get("city") or "",
        "district":           recipient.get("district") or "",
        "billing_district":   recipient.get("district") or "",
        "state":              recipient.get("state") or "",
        "billing_state":      recipient.get("state") or "",
        "pincode":            recipient.get("pincode") or "",
        "billing_pincode":    recipient.get("pincode") or "",
        "country":            recipient.get("country") or "India",
        "category":           "",
        "billing_type":       "Postpaid",
        "customer_gst_no":    recipient.get("gst_no") or recipient.get("customer_gst_no") or "",
        "gst_invoice_needed": "yes" if has_gst else "no",
    }
    return invoice_data, company_for_pdf, customer_data


def _mi_build_pdf(payload, request, db):
    cid = request.session.get("company_id")
    sender = _mi_resolve_sender(request, db)
    company = _mi_company(db, cid)
    invoice = {
        "invoice_no": payload.get("invoice_no") or ("INV" + str(_mi_dt.utcnow().strftime("%H%M%S")) + str(int(_mi_dt.utcnow().timestamp()) % 1000).zfill(3))[:9],
        "issue_date": payload.get("issue_date") or _mi_dt.utcnow().strftime("%Y-%m-%d"),
        "due_date": payload.get("due_date") or "",
        "notes": payload.get("notes") or "",
        "is_gst": bool(payload.get("is_gst")),
    }
    # __S38U10__ — per-invoice T&C/declaration overrides come from the form.
    if (payload.get("terms_conditions") or "").strip():
        sender["terms_conditions"] = payload["terms_conditions"]
    if (payload.get("declaration") or "").strip():
        sender["declaration"] = payload["declaration"]
    recipient = payload.get("recipient") or {}
    # _v4730_  Enrich existing-customer recipients with the full address so
    # the standard PDF block prints city/district/state/pincode/country.
    if recipient.get("mode") == "existing" and recipient.get("customer_id"):
        try:
            from database import Customer as _CRow
            _cr = (db.query(_CRow)
                     .filter(_CRow.customer_id == recipient["customer_id"],
                             _CRow.company_id == cid).first())
            if _cr:
                # Don't overwrite user-supplied overrides if any.
                for k_src, k_dst in (
                    ("customer_name",   "name"),
                    ("customer_phone",  "phone"),
                    ("customer_email",  "email"),
                    ("address",         "address"),
                    ("locality",        "locality"),
                    ("city",            "city"),
                    ("district",        "district"),
                    ("state",           "state"),
                    ("pincode",         "pincode"),
                    ("country",         "country"),
                    ("gst_no",          "gst_no"),
                ):
                    if not recipient.get(k_dst):
                        recipient[k_dst] = getattr(_cr, k_src, "") or ""
        except Exception as _eer:
            print(f"[manual-invoice] recipient enrich failed (non-fatal): {_eer}")
    line_items = payload.get("line_items") or []
    # __S38U9__ Compute total due. For existing customers, use the running
    # outstanding balance helper. For new recipients, the invoice grand total.
    total_due = 0.0
    try:
        sub_total = sum(float(li.get("qty",1) or 0) * float(li.get("rate",0) or 0)
                        for li in line_items)
        cgst = sum(float(li.get("qty",1) or 0) * float(li.get("rate",0) or 0)
                   * float(li.get("cgst_pct",0) or 0)/100
                   for li in line_items) if invoice["is_gst"] else 0
        sgst = sum(float(li.get("qty",1) or 0) * float(li.get("rate",0) or 0)
                   * float(li.get("sgst_pct",0) or 0)/100
                   for li in line_items) if invoice["is_gst"] else 0
        this_total = sub_total + cgst + sgst
        if recipient.get("mode") == "existing" and recipient.get("customer_id"):
            try:
                running = float(compute_customer_balance(recipient["customer_id"], cid, db) or 0)
            except Exception:
                running = 0.0
            total_due = running + this_total
        else:
            total_due = this_total
    except Exception:
        pass
    invoice["total_due"] = total_due
    # __S38U10__ — Sender-scoped T&C / declaration override.
    company_for_pdf = dict(company) if isinstance(company, dict) else {}
    if (sender.get("terms_conditions") or "").strip():
        company_for_pdf["terms_conditions"] = sender["terms_conditions"]
    if (sender.get("declaration") or "").strip():
        company_for_pdf["declaration"] = sender["declaration"]
    # __S38U11__ — sub-LCO / employee branding overrides for header + bank.
    brand = sender.get("branding") or {}
    if sender.get("user_type") in ("sub_lco", "employee"):
        # ALWAYS overwrite for sub-LCO/employee — admin's company info must
        # not leak into their invoices, even if they haven't filled in
        # their own. Empty fields just render as blank, which is correct.
        company_for_pdf["company_name"]    = brand.get("inv_company_name")    or sender.get("label") or ""
        company_for_pdf["gst_number"]      = brand.get("inv_company_gst")     or ""
        company_for_pdf["company_phone"]   = brand.get("inv_company_phone")   or sender.get("phone") or ""
        company_for_pdf["company_email"]   = brand.get("inv_company_email")   or sender.get("email") or ""
        company_for_pdf["company_address"] = brand.get("inv_company_address") or sender.get("address") or ""
        company_for_pdf["bank_name"]       = brand.get("inv_bank_name")       or ""
        company_for_pdf["account_number"]  = brand.get("inv_account_number")  or ""
        company_for_pdf["branch_ifsc"]     = brand.get("inv_branch_ifsc")     or ""
        company_for_pdf["branch_location"] = brand.get("inv_branch_location") or ""
        company_for_pdf["upi_id"]          = brand.get("inv_upi_id")          or ""
        # sender.gst_no must mirror the actor's own GST, not the company's.
        sender["gst_no"] = brand.get("inv_company_gst") or ""
        sender["address"] = company_for_pdf["company_address"]
    # _S40ze_  Use the SAME template as the regular invoice flow so the
    # branding, GST table, signature, T&C/declaration block all match.
    inv_data, co_data, cust_data = _mi_to_standard_pdf_args(
        invoice, recipient, company_for_pdf, line_items)
    # PREV_BAL_DUES_FIX_MANUAL_INVOICE_v1 — build a real previous_invoices list so the
    # PDF actually renders the "Previous Balance" line. Use the recipient's
    # outstanding unpaid invoices when this is an existing customer.
    _prev_due = float(inv_data.get("prev_due_total") or 0)
    _prev_list = []
    if _prev_due > 0:
        _rcp = recipient or {}
        _rcid = _rcp.get("customer_id") if _rcp.get("mode") == "existing" else None
        if _rcid:
            try:
                from database import Invoice as _PrevInv
                _prior = (db.query(_PrevInv)
                          .filter(_PrevInv.company_id == cid,
                                  _PrevInv.customer_id == _rcid)
                          .order_by(_PrevInv.issue_date.asc(),
                                    _PrevInv.id.asc())
                          .all())
                _unpaid = [x for x in _prior
                           if (x.status or "").lower() not in
                              ("paid", "cancelled", "void")]
                _shown = (_unpaid or _prior[-1:])[:5]
                _nos = ", ".join([x.invoice_no for x in _shown])
                if _unpaid and len(_unpaid) > 5:
                    _nos += f", +{len(_unpaid) - 5} more"
                _prev_list = [{
                    "invoice_no":   _nos or "Previous outstanding",
                    "issue_date":   (_shown[0].issue_date if _shown else ""),
                    "amount":       round(_prev_due, 2),
                    "total_amount": round(_prev_due, 2),
                }]
            except Exception:
                _prev_list = [{
                    "invoice_no":   "Previous outstanding",
                    "issue_date":   "",
                    "amount":       round(_prev_due, 2),
                    "total_amount": round(_prev_due, 2),
                }]
        else:
            _prev_list = [{
                "invoice_no":   "Previous outstanding",
                "issue_date":   "",
                "amount":       round(_prev_due, 2),
                "total_amount": round(_prev_due, 2),
            }]
    pdf_bytes = generate_invoice_pdf(inv_data, co_data, cust_data, _prev_list)
    return invoice, pdf_bytes, company_for_pdf, sender

@app.post("/api/manual-invoice/preview")
async def api_mi_preview(request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    payload = await request.json()
    try:
        invoice, pdf_bytes, *_ = _mi_build_pdf(payload, request, db)
    except Exception as e:
        return JSONResponse({"success": False, "message": f"PDF generation failed: {e}"}, status_code=500)
    from fastapi.responses import Response
    return Response(content=pdf_bytes, media_type="application/pdf",
                    headers={"Content-Disposition": f"inline; filename=preview_{invoice['invoice_no']}.pdf"})

@app.post("/api/manual-invoice/send")
async def api_mi_send(request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    payload = await request.json()
    cid = request.session.get("company_id")

    # Generate a real invoice number using existing helper
    try:
        invoice_no = generate_invoice_number(cid, db)
    except Exception:
        # Same shorter format if helper fails — INV + 6 digits.
        import random as _rnd
        invoice_no = f"INV{_rnd.randint(100000, 999999)}"
    payload["invoice_no"] = invoice_no

    try:
        invoice, pdf_bytes, company, sender = _mi_build_pdf(payload, request, db)
    except Exception as e:
        return JSONResponse({"success": False, "message": f"PDF generation failed: {e}"}, status_code=500)

    # Persist the PDF
    pdf_dir = "/var/lib/autoispbilling/manual_invoices"
    try: _mi_os.makedirs(pdf_dir, exist_ok=True)
    except Exception: pass
    pdf_path = f"{pdf_dir}/{invoice_no}.pdf"
    try:
        with open(pdf_path, "wb") as f: f.write(pdf_bytes)
    except Exception as e:
        print(f"[manual-invoice] PDF save failed: {e}")
        pdf_path = ""

    # Persist invoice row so it shows up in Sent Invoice History
    line_items = payload.get("line_items") or []
    sub_total  = sum(float(li.get("qty",1) or 0) * float(li.get("rate",0) or 0) for li in line_items)
    cgst_total = sum(float(li.get("qty",1) or 0) * float(li.get("rate",0) or 0) * float(li.get("cgst_pct",0) or 0)/100 for li in line_items) if payload.get("is_gst") else 0
    sgst_total = sum(float(li.get("qty",1) or 0) * float(li.get("rate",0) or 0) * float(li.get("sgst_pct",0) or 0)/100 for li in line_items) if payload.get("is_gst") else 0
    grand = sub_total + cgst_total + sgst_total

    rcp = payload.get("recipient") or {}
    cust_id_for_invoice = rcp.get("customer_id") or f"MANUAL-{int(_mi_dt.utcnow().timestamp())}"
    plan_label = "Manual: " + ", ".join(((li.get("description") or li.get("name") or "") for li in line_items[:2]))[:120]

    try:
        # _S39R2B_MANUAL_INVOICE_FIX — also persist recipient name/email/phone
        # so the Sent Invoice History page can render them and the download
        # endpoint doesn't fail for non-customer (manual) recipients.
        # PREV_BAL_DUES_FIX_MANUAL_SQL_v1 — due_at_issue must be the running balance
        # at the moment of issue (incl. this invoice), NOT just this invoice's
        # grand total, so downstream readers/mobile show the previous balance
        # carry-forward consistently. invoice["total_due"] is computed in
        # _mi_build_pdf as `running + this_total` for existing customers, and
        # just `this_total` for non-customers — both correct.
        _due_at_issue = round(float(invoice.get("total_due") or grand), 2)
        db.execute(text(
            "INSERT INTO invoices(company_id,customer_id,invoice_no,issue_date,due_date,"
            "start_date,end_date,period_months,plan_id,plan_name,base_amount,"
            "cgst_tax,sgst_tax,igst_tax,total_amount,pdf_path,status,"
            "created_at,updated_at,has_gst_no,due_at_issue,"
            "manual_customer_name,manual_customer_email,manual_customer_phone) "
            "VALUES (:co,:cid,:no,:isd,:dd,'','',0,NULL,:pn,:b,:c,:s,0,:t,:pp,'sent',"
            ":now,:now,:hg,:dai,:mn,:me,:mp)"
        ), {
            "co": cid, "cid": cust_id_for_invoice, "no": invoice_no,
            "isd": invoice["issue_date"], "dd": invoice["due_date"],
            "pn": plan_label, "b": round(sub_total,2),
            "c": round(cgst_total,2), "s": round(sgst_total,2),
            "t": round(grand,2), "pp": pdf_path,
            "dai": _due_at_issue,
            "now": _mi_dt.utcnow(),
            "hg": 1 if payload.get("is_gst") else 0,
            "mn": (rcp.get("name") or rcp.get("customer_name") or "")[:255],
            "me": (rcp.get("email") or "")[:255],
            "mp": (rcp.get("phone") or rcp.get("mobile") or "")[:255],
        })
        db.commit()
    except Exception as e:
        db.rollback()
        print(f"[manual-invoice] DB insert failed: {e}")

    # Deliver
    delivery = payload.get("delivery") or {}
    sent_email = sent_wa = False
    notes_summary = []
    if delivery.get("email") and rcp.get("email"):
        try:
            # __S38U14__ — custom manual-invoice email body
            import smtplib
            from email.mime.multipart import MIMEMultipart
            from email.mime.text import MIMEText
            from email.mime.application import MIMEApplication
            from email.utils import formataddr as _fmtaddr_mi

            smtp_host = company.get("smtp_server") or _mi_os.getenv("SMTP_HOST", "smtp.hostinger.com")
            smtp_port = int(company.get("smtp_port") or _mi_os.getenv("SMTP_PORT", 465))
            smtp_user = company.get("smtp_username") or _mi_os.getenv("SMTP_USER")
            smtp_password = company.get("smtp_password") or _mi_os.getenv("SMTP_PASSWORD")
            if not (smtp_user and smtp_password):
                raise RuntimeError("SMTP not configured.")

            co_name  = company.get("company_name") or "ISP Billing"
            co_phone = company.get("company_phone") or sender.get("phone") or ""
            co_addr  = company.get("company_address") or sender.get("address") or ""

            descs = [li.get("description", "").strip()
                     for li in (payload.get("line_items") or []) if li.get("description")]
            item_label = ", ".join(descs) if descs else "your subscription"
            cust_name = rcp.get("name") or "Customer"

            body_lines = [
                "Dear " + cust_name + ",",
                "",
                "Thank you for purchasing/service (" + item_label + "), please find attached your invoice.",
                "",
                "This is an automatically generated message to confirm your purchase/service. Please do not reply to this e-mail, but you may wish to save it for your records.",
                "",
                "Should you have any questions about your subscription, feel free to call " + co_name + " & " + co_phone + ".",
                "",
                "Regards,",
                co_name,
                co_addr,
            ]
            body = "\n".join(body_lines)

            msg = MIMEMultipart()
            msg["From"] = _fmtaddr_mi((co_name.upper() + " - Invoice", smtp_user))
            msg["Reply-To"] = smtp_user
            msg["To"] = rcp["email"]
            msg["Subject"] = "Invoice - " + str(invoice_no)
            msg.attach(MIMEText(body, "plain"))

            att = MIMEApplication(pdf_bytes, _subtype="pdf")
            att.add_header("Content-Disposition", "attachment",
                            filename="invoice_" + str(invoice_no) + ".pdf")
            msg.attach(att)

            if smtp_port == 465:
                srv = smtplib.SMTP_SSL(smtp_host, smtp_port, timeout=20)
            else:
                srv = smtplib.SMTP(smtp_host, smtp_port, timeout=20)
                srv.starttls()
            srv.login(smtp_user, smtp_password)
            srv.send_message(msg)
            srv.quit()

            sent_email = True
            notes_summary.append("✓ Email to " + rcp["email"])
        except Exception as e:
            notes_summary.append("✗ Email failed: " + str(e))
    if delivery.get("whatsapp") and rcp.get("phone"):
        try:
            from twilio_whatsapp import _normalise_phone, _send_freeform
            to_ = _normalise_phone(rcp["phone"])
            if to_:
                msg = (
                    f"Hi {rcp.get('name','')}, your invoice {invoice_no} of "
                    f"₹{grand:,.2f} from {company.get('company_name','')} is attached. "
                    f"Issued: {invoice['issue_date']} · Due: {invoice['due_date']}."
                )
                res = _send_freeform(to_, msg)
                sent_wa = bool(isinstance(res, dict) and res.get("success"))
                notes_summary.append(("✓" if sent_wa else "✗") + " WhatsApp to " + rcp["phone"])
            else:
                notes_summary.append("✗ WhatsApp: invalid phone number")
        except Exception as e:
            notes_summary.append(f"✗ WhatsApp failed: {e}")

    return {
        "success": True,
        "invoice_no": invoice_no,
        "download_url": f"/api/manual-invoice/{invoice_no}/download",
        "delivery_summary": "\n".join(notes_summary) if notes_summary else "Saved without sending.",
        "email_sent": sent_email, "whatsapp_sent": sent_wa,
    }

# === BEGIN manual-invoice save-defaults (38u.10) ===
@app.post("/api/manual-invoice/save-defaults")
async def api_mi_save_defaults(request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    payload = await request.json()
    terms = (payload.get("terms_conditions") or "").strip()
    decl  = (payload.get("declaration") or "").strip()
    cid = request.session.get("company_id") or ""
    user_type = request.session.get("user_type") or "admin"
    branding = payload.get("branding") or {}
    BR_KEYS = ["inv_company_name","inv_company_gst","inv_company_phone",
               "inv_company_email","inv_company_address","inv_bank_name",
               "inv_account_number","inv_branch_ifsc","inv_branch_location",
               "inv_upi_id"]
    br_vals = {k: (branding.get(k) or "").strip() for k in BR_KEYS}
    try:
        if user_type == "sub_lco":
            sid = request.session.get("sub_lco_db_id") or request.session.get("sub_lco_id")
            db.execute(text(
                "UPDATE sub_lcos SET terms_conditions=:t, declaration=:d, "
                "  inv_company_name=:icn, inv_company_gst=:icg, "
                "  inv_company_phone=:icp, inv_company_email=:ice, "
                "  inv_company_address=:ica, inv_bank_name=:ibn, "
                "  inv_account_number=:ian, inv_branch_ifsc=:iif, "
                "  inv_branch_location=:ibl, inv_upi_id=:iui "
                "WHERE id=:i AND company_id=:c"
            ).execution_options(skip_sub_lco_scope=True), {
                "t": terms, "d": decl, "i": sid, "c": cid,
                "icn": br_vals["inv_company_name"], "icg": br_vals["inv_company_gst"],
                "icp": br_vals["inv_company_phone"], "ice": br_vals["inv_company_email"],
                "ica": br_vals["inv_company_address"], "ibn": br_vals["inv_bank_name"],
                "ian": br_vals["inv_account_number"], "iif": br_vals["inv_branch_ifsc"],
                "ibl": br_vals["inv_branch_location"], "iui": br_vals["inv_upi_id"],
            })
        elif user_type == "employee":
            ec = request.session.get("user_id") or request.session.get("employee_code")
            db.execute(text(
                "UPDATE employees SET terms_conditions=:t, declaration=:d, "
                "  inv_company_name=:icn, inv_company_gst=:icg, "
                "  inv_company_phone=:icp, inv_company_email=:ice, "
                "  inv_company_address=:ica, inv_bank_name=:ibn, "
                "  inv_account_number=:ian, inv_branch_ifsc=:iif, "
                "  inv_branch_location=:ibl, inv_upi_id=:iui "
                "WHERE employee_code=:e AND company_id=:c"
            ), {
                "t": terms, "d": decl, "e": ec, "c": cid,
                "icn": br_vals["inv_company_name"], "icg": br_vals["inv_company_gst"],
                "icp": br_vals["inv_company_phone"], "ice": br_vals["inv_company_email"],
                "ica": br_vals["inv_company_address"], "ibn": br_vals["inv_bank_name"],
                "ian": br_vals["inv_account_number"], "iif": br_vals["inv_branch_ifsc"],
                "ibl": br_vals["inv_branch_location"], "iui": br_vals["inv_upi_id"],
            })
        else:
            # Admin saves to companies (existing fields).
            db.execute(text(
                "UPDATE companies SET terms_conditions=:t, declaration=:d "
                "WHERE company_id=:c"
            ), {"t": terms, "d": decl, "c": cid})
        db.commit()
        return {"success": True, "message": "Defaults saved."}
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": f"Save failed: {e}"}, status_code=500)
# === END manual-invoice save-defaults (38u.10) ===

@app.get("/api/manual-invoice/{invoice_no}/download")
async def api_mi_download(invoice_no: str, request: Request, db: Session = Depends(get_db)):
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    cid = request.session.get("company_id")
    row = db.execute(text(
        "SELECT pdf_path FROM invoices WHERE invoice_no=:n AND company_id=:c LIMIT 1"
    ), {"n": invoice_no, "c": cid}).fetchone()
    if not row or not row[0] or not _mi_os.path.exists(row[0]):
        return JSONResponse({"success": False, "message": "Invoice PDF not found."}, status_code=404)
    from fastapi.responses import FileResponse
    return FileResponse(row[0], media_type="application/pdf",
                        filename=f"{invoice_no}.pdf")
# === END manual-invoice API (38u.8) ===


# __S39D__ Logout + heartbeat for the idle-timeout layer
@app.post("/api/auth/logout")
async def s39d_logout(request: Request):
    try:
        request.session.clear()
    except Exception:
        pass
    return {"success": True}


@app.post("/api/auth/heartbeat")
async def s39d_heartbeat(request: Request):
    # Touch the session so SessionMiddleware re-issues the cookie with a
    # fresh Max-Age (when remember=true).
    import time as _t
    try:
        request.session["__last_seen"] = int(_t.time())
    except Exception:
        pass
    return {"success": True}




# __S39H__ Employee subscriber-detail (parity with Sub-LCO) ------------
@app.get("/employee/subscribers/{customer_pk}", response_class=HTMLResponse)
async def employee_subscriber_detail(customer_pk: int, request: Request,
                                       db: Session = Depends(get_db)):
    auth_check = require_employee(request)
    if auth_check:
        return auth_check
    sess = request.scope.get("session") or {}
    real_ut = sess.get("user_type")
    # Ensure the employee's locality scope is active for any Customer
    # queries spawned by the admin handler.
    try:
        import employee_scope as _esmod
        _esmod.set_scope_from_session(request, db)
    except Exception:
        pass
    sess["user_type"] = "admin"
    try:
        response = await admin_subscriber_detail(customer_pk, request, db)
    finally:
        sess["user_type"] = real_ut

    # Rewrite the not-found redirect URL from /admin/users → /employee/users
    from fastapi.responses import RedirectResponse
    if isinstance(response, RedirectResponse):
        loc = response.headers.get("location", "")
        if "/admin/users" in loc:
            return RedirectResponse(url="/employee/users", status_code=303)
        return response

    if hasattr(response, "context"):
        ctx = dict(response.context)
        ctx.update(_emp_admin_context(request, db, "users"))
        return templates.TemplateResponse(response.template.name, ctx)
    return response


