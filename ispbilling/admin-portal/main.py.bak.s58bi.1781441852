    "public-ips":   {"schema": {}, "export": "/api/admin/public-ips/export-full"},
}


# _S39R5S_ — Sample headers expanded for parity with the Add Customer page.
_S31_SAMPLE_HEADERS = {
    "customers": [
        "Customer ID","Username","PPPoE Password","Status","Customer Name","Nickname",
        "Customer Type","Service Type","Plan Name","Monthly Amount",
        "Mobile","Alt Mobile","Email","Address","Locality","City","State","Pincode",
        "Latitude","Longitude",
        "ID Proof Type","ID Proof No","CAF No",
        "MAC Address","IP Address","Static IP","Static Netmask","Vendor","Modem No",
        "Zone","Node","Distance From Node",
        "Installation Date","Start Date","End Date","Period",
        "Bill Amount","Total Bill Amount","Received Amount",
        "Security Deposit","Installation Charges","Router Charges",
        "Auto Renew","Discount/Credit",
        "GST Invoice","Customer GST No","CGST %","SGST %","IGST %",
        "Sub LCO Code","Location",
    ],
    "plans":     ["Plan Name","Service","Speed","Download Speed","Upload Speed","Validity","Validity Unit",
        "Base Amount","CGST %","SGST %","IGST %","After-Tax Amount","Description","Priority","Queue Type"],
    "employees": ["Employee Code","Employee Name","Mobile","Email","Address","Status"],
    "locations": ["Name","City","State","Pincode","Status"],
    "nas":       ["Name","IP Address","Secret","Type","Location","Status","Auth Modes",
        "API Username","API Password","API Port","SSH Port","PPPoE Pool","PPPoE Service Name",
        "PPPoE Interface","PPPoE VLAN","Hotspot Interface","Hotspot DNS","Hotspot Pool"],
    "ip-pools":  ["Name","Network","Gateway","Start IP","End IP","Role","Status","DNS Servers","Comment"],
}

@app.get("/api/admin/data-mgmt/sample")
async def api_dm_sample(request: Request, kind: str = "customers"):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    kind = (kind or "").lower().strip()
    headers = _S31_SAMPLE_HEADERS.get(kind)
    if not headers:
        return JSONResponse({"error": f"No sample for {kind}"}, status_code=400)
    buf = _s31_io.StringIO()
    w = _s31_csv.writer(buf); w.writerow(headers)
    # Add one sample row of empty strings so Excel opens cleanly
    w.writerow([""] * len(headers))
    return _S31Response(
        buf.getvalue(), media_type="text/csv",
        headers={"Content-Disposition": f'attachment; filename="sample_{kind}.csv"'},
    )


# -------------------- IMPORT --------------------
def _s31_sanitize_xlsx_styles(raw_bytes: bytes) -> bytes:
    """_S40d_ — Some 3rd-party tools (Xceednet, FreeRADIUS dashboards,
    …) emit XLSX with broken `<fill/>` elements that crash openpyxl.
    Re-zip the workbook with a minimal valid styles.xml so we can still
    read the cell *values* (which is all we need for import)."""
    import zipfile as _zf
    src_buf = _s31_io.BytesIO(raw_bytes)
    out_buf = _s31_io.BytesIO()
    minimal = (
        b'<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
        b'<styleSheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">'
        b'<fonts count="1"><font><sz val="11"/><name val="Calibri"/></font></fonts>'
        b'<fills count="1"><fill><patternFill patternType="none"/></fill></fills>'
        b'<borders count="1"><border/></borders>'
        b'<cellStyleXfs count="1"><xf/></cellStyleXfs>'
        b'<cellXfs count="1"><xf/></cellXfs>'
        b'</styleSheet>'
    )
    with _zf.ZipFile(src_buf, "r") as zin, \
            _zf.ZipFile(out_buf, "w", _zf.ZIP_DEFLATED) as zout:
        for item in zin.infolist():
            data = zin.read(item.filename)
            if item.filename == "xl/styles.xml":
                data = minimal
            zout.writestr(item, data)
    return out_buf.getvalue()


# Regex helpers for column auto-detection
import re as _s31_re
_S40D_DATE_RE  = _s31_re.compile(r"^\s*\d{1,2}[\-/][A-Za-z]{3}[\-/]\d{2,4}\s*$|^\s*\d{4}-\d{2}-\d{2}\b")
_S40D_PHONE_RE = _s31_re.compile(r"^\s*\+?\d[\d\s\-]{7,16}\s*$")
_S40D_EMAIL_RE = _s31_re.compile(r"^[^\s@]+@[^\s@]+\.[^\s@]+$")
_S40D_PLAN_RE  = _s31_re.compile(r"\d+\s*(Kbps|Mbps|Gbps)\b", _s31_re.I)
_S40D_USER_RE  = _s31_re.compile(r"^[a-z0-9._\-]+\.[a-z]{2,}$|^[a-z0-9._\-]{4,}@[a-z0-9._\-]+$", _s31_re.I)
_S40D_AMT_RE   = _s31_re.compile(r"^[₹$€£]?\s*\d+(?:[.,]\d+)?\s*$")
_S40D_PIN_RE   = _s31_re.compile(r"^\d{5,7}$")
_S40D_BYTES_RE = _s31_re.compile(r"^\s*\d+(?:[.,]\d+)?\s*(Bytes|B|KB|MB|GB|TB|PB)\s*$", _s31_re.I)
_S40D_STATUS_VOC = (
    "active", "package assigned", "package renewed", "package changed",
    "package cancelled", "disabled", "enabled", "expired", "terminated",
    "suspended", "fair usage policy", "data topped up", "approved",
    "created new",
)


def _s40d_detect_columns(sample_rows: list) -> dict:
    """Look at up to 8 data rows and return a {col_index: field_name}
    mapping. Used when the workbook header doesn't match any known
    schema columns (Xceednet, ISP-XYZ exports, …)."""
    n_cols = max((len(r) for r in sample_rows), default=0)
    if n_cols == 0:
        return {}
    score = {i: {} for i in range(n_cols)}

    def bump(i, field, n=1):
        score[i][field] = score[i].get(field, 0) + n

    for row in sample_rows:
        for i, v in enumerate(row):
            if v is None: continue
            s = str(v).strip()
            if not s: continue
            sl = s.lower()
            if _S40D_EMAIL_RE.match(s):
                bump(i, "customer_email", 5); continue
            if _S40D_PHONE_RE.match(s) and len(s.replace(" ", "").replace("-", "")) >= 10:
                bump(i, "customer_phone", 5); continue
            if _S40D_DATE_RE.match(s):
                bump(i, "__date__", 3); continue
            if _S40D_BYTES_RE.match(s):
                bump(i, "__bytes__", 4); continue
            if _S40D_PIN_RE.match(s):
                bump(i, "pincode", 2); continue
            if _S40D_PLAN_RE.search(s):
                bump(i, "__plan_name__", 4); continue
            if sl in _S40D_STATUS_VOC:
                bump(i, "status", 4); continue
            if sl in ("yes", "no", "online", "offline", "true", "false"):
                bump(i, "__bool__", 1); continue
            # Only count as monetary if it has a currency symbol — plain
            # integers (1, 2, 226 …) are usually IDs / serials.
            if s.startswith("₹") or s.startswith("$") or s.startswith("€") or s.startswith("£"):
                bump(i, "monthly_amount", 4); continue
            if _S40D_USER_RE.match(s):
                bump(i, "username", 4); continue
            # Free-text — could be name, address, locality, state
            if 2 <= len(s) <= 80:
                if sl in ("madhya pradesh", "maharashtra", "delhi", "karnataka",
                          "uttar pradesh", "rajasthan", "gujarat", "tamil nadu",
                          "telangana", "kerala", "punjab", "haryana", "bihar",
                          "west bengal", "odisha", "jharkhand", "assam"):
                    bump(i, "state", 5)
                elif sl in ("in", "ind", "india"):
                    bump(i, "country", 3)
                else:
                    bump(i, "__text__", 1)

    # First pass: pick winning field per column
    raw_final = {}
    for i in range(n_cols):
        s = score[i]
        if not s: continue
        best = max(s, key=s.get)
        if best in ("__bool__", "__text__", "__bytes__"): continue
        raw_final[i] = best

    # Resolve dates: highest-scoring → start_date, next → end_date
    date_cols = sorted([i for i in range(n_cols) if score[i].get("__date__")],
                       key=lambda i: -score[i]["__date__"])
    final = {}
    used_fields = set()
    if date_cols:
        final[date_cols[0]] = "start_date"
        used_fields.add("start_date")
        if len(date_cols) > 1:
            final[date_cols[1]] = "end_date"
            used_fields.add("end_date")

    # De-duplicate single-value fields. Phone is preferred over amount
    # for ambiguous columns; keep only the highest-scoring column per
    # field. Ambiguous IP addresses (often appear as "phone-like" 4-octet
    # numbers) are dropped.
    SINGLE_FIELDS = ("customer_phone", "customer_email", "username",
                     "monthly_amount", "pincode", "state", "country",
                     "status")
    for fld in SINGLE_FIELDS:
        cands = [i for i, f in raw_final.items() if f == fld]
        if not cands: continue
        cands.sort(key=lambda i: -score[i].get(fld, 0))
        final[cands[0]] = fld
        used_fields.add(fld)

    # Plan column (multi-occurrence allowed in raw, take winner)
    plan_cands = [i for i, f in raw_final.items() if f == "__plan_name__"]
    if plan_cands:
        plan_cands.sort(key=lambda i: -score[i].get("__plan_name__", 0))
        final[plan_cands[0]] = "__plan_name__"

    # customer_name / address / locality = the longest-populated text
    # columns AFTER the username column. We also drop columns whose
    # values are mostly the SAME (e.g. "Fiber" / service type) since
    # those carry no per-row info.
    user_cols = [i for i in range(n_cols) if final.get(i) == "username"]
    n_samples = max(1, len(sample_rows))
    min_hits = max(1, int(n_samples * 0.4))
    # Build per-column unique-ratio
    def _col_unique_ratio(ci):
        vals = [(str(r[ci]).strip().lower()) for r in sample_rows
                if ci < len(r) and r[ci] is not None and str(r[ci]).strip()]
        if not vals: return 0.0
        return len(set(vals)) / len(vals)
    def _col_dominant(ci):
        s = score[ci]
        if not s: return None
        return max(s, key=s.get)
    text_cols = sorted([
        i for i in range(n_cols)
        if score[i].get("__text__", 0) >= min_hits
            and i not in final
            and (not user_cols or i > min(user_cols))
            and _col_unique_ratio(i) >= 0.5
            and _col_dominant(i) not in ("__bytes__", "__bool__")
    ])
    # Assign in ascending column order:
    # 1st → customer_name, 2nd → address.  Locality / city are
    # commonly inferred wrong on Xceednet exports (data-used / service
    # type get mistaken for locations), so we only assign them when
    # they have very high uniqueness AND look like place-names.
    pri = ["customer_name", "address"]
    for col_i, fld in zip(text_cols, pri):
        final[col_i] = fld
    return final


def _s31_read_rows(upload: _S31UploadFile, raw_bytes: bytes):
    """Yield dict rows from a CSV or XLSX upload. Never raises on missing fields."""
    name = (upload.filename or "").lower()
    if name.endswith(".xlsx") or name.endswith(".xls"):
        from openpyxl import load_workbook
        wb = None
        for attempt in ("first_pass", "sanitize_styles"):
            try:
                payload = (raw_bytes if attempt == "first_pass"
                           else _s31_sanitize_xlsx_styles(raw_bytes))
                wb = load_workbook(_s31_io.BytesIO(payload),
                                   data_only=True, read_only=True)
                if attempt == "sanitize_styles":
                    print("[S31] xlsx loaded after stylesheet sanitization")
                break
            except Exception as e:
                print(f"[S31] xlsx open ({attempt}) failed: {e}")
        if wb is None:
            # Last-ditch: try CSV
            try:
                text = raw_bytes.decode("utf-8", errors="replace")
                reader = _s31_csv.DictReader(_s31_io.StringIO(text))
                for r in reader: yield r
            except Exception as e2:
                print(f"[S31] csv fallback failed: {e2}")
            return
        ws = wb.active
        all_rows = list(ws.iter_rows(values_only=True))
        if not all_rows:
            return

        # Build candidate header from row 1
        header_raw = [str(h).strip() if h is not None else ""
                      for h in all_rows[0]]
        # Try the schema-style header path first
        header_keys = [_s31_hdrkey(h) for h in header_raw]
        # Detect "Xceednet-style" headers — when they look like statuses
        # rather than field names, the schema lookup will yield 0 hits
        # for ALL of them, so use position-based auto-detection.
        # We do this lazily: pre-scan customer schema since most imports
        # are customer imports. (Other kinds will use the regular path.)
        sample_rows = [r for r in all_rows[1:9] if r is not None]
        # Filter out completely-blank rows
        sample_rows = [r for r in sample_rows
                       if any((c is not None and str(c).strip())
                              for c in r)]
        autodetect = {}
        try:
            schema_hits = sum(1 for hk in header_keys
                              if hk and hk in _S31_CUSTOMER_FIELDS)
            if schema_hits == 0 and sample_rows:
                autodetect = _s40d_detect_columns(sample_rows)
                print(f"[S31] header auto-detect → {autodetect}")
        except Exception as _e:
            print(f"[S31] auto-detect skipped: {_e}")

        for ri, row in enumerate(all_rows[1:], start=2):
            if row is None: continue
            if all((c is None or str(c).strip() == "") for c in row): continue
            d = {}
            if autodetect:
                # Yield with synthetic column-name keys (matching DB
                # field names directly) so the existing schema mapping
                # in _S31_CUSTOMER_FIELDS picks them up.
                for i, fld in autodetect.items():
                    if i >= len(row): continue
                    v = row[i]
                    if v is None or str(v).strip() == "": continue
                    # Use a stable synthetic key the schema knows about
                    synthetic = {
                        "customer_phone": "Mobile",
                        "customer_email": "Email",
                        "customer_name":  "Customer Name",
                        "username":       "Username",
                        "address":        "Address",
                        "locality":       "Locality",
                        "city":           "City",
                        "state":          "State",
                        "country":        "Country",
                        "pincode":        "Pincode",
                        "start_date":     "Start Date",
                        "end_date":       "End Date",
                        "status":         "Status",
                        "monthly_amount": "Monthly Amount",
                        "__plan_name__":  "Plan Name",
                    }.get(fld, fld)
                    d[synthetic] = v
            else:
                for i, h in enumerate(header_raw):
                    if not h: continue
                    d[h] = row[i] if i < len(row) else None
            yield d
    else:
        text = raw_bytes.decode("utf-8", errors="replace")
        # Tolerate BOM
        if text.startswith("\ufeff"): text = text.lstrip("\ufeff")
        reader = _s31_csv.DictReader(_s31_io.StringIO(text))
        for r in reader: yield r


@app.post("/api/admin/data-mgmt/import")
async def api_dm_import(
    request: Request,
    kind: str = _S31Form(...),
    file: _S31UploadFile = _S31File(...),
    db: Session = Depends(get_db),
):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")
    actor = request.session.get("user_name") or request.session.get("user_id") or "admin"
    kind = (kind or "").lower().strip()
    info = _S31_KIND_MAP.get(kind)
    if not info or not info.get("schema"):
        return JSONResponse({"success": False, "message": f"Import not supported for {kind}"}, status_code=400)
    try:
        raw = await file.read()
    except Exception as e:
        return JSONResponse({"success": False, "message": f"Upload failed: {e}"}, status_code=400)

    schema = info["schema"]
    # Lazy import model
    try:
        mod = __import__(info["module"], fromlist=[info["model"]])
        Model = getattr(mod, info["model"])
    except Exception as e:
        return JSONResponse({"success": False, "message": f"Model load failed: {e}"}, status_code=500)

    ok = skipped = failed = 0
    errors = []
    unmapped_headers: set = set()
    import uuid as _s31_uuid, hashlib as _s31_hash

    # _S39R5S_ — Pre-load lookup caches for plan/locality/sub-lco resolution
    # (only executed if the customer schema is the active one). Each
    # lookup is wrapped independently so a missing model (e.g. SubLCO is
    # a raw table, not an ORM class) doesn't kill the other two.
    _plan_lookup = {}
    _subl_lookup = {}
    _loc_lookup  = {}
    if kind == "customers":
        try:
            from database import Plan as _Plan
            for p in db.query(_Plan).filter(_Plan.company_id == company_id).all():
                if p.plan_name:
                    _plan_lookup[p.plan_name.strip().lower()] = p.id
        except Exception as _e:
            print(f"[S31] plan lookup preload failed: {_e}")
        try:
            from database import Location as _Location
            for l in db.query(_Location).filter(_Location.company_id == company_id).all():
                if l.name:
                    _loc_lookup[l.name.strip().lower()] = l.id
        except Exception as _e:
            print(f"[S31] location lookup preload failed: {_e}")
        try:
            # `sub_lcos` is a raw table (no ORM class) — query directly.
            from sqlalchemy import text as _text
            for r in db.execute(_text(
                "SELECT id, sub_lco_code, name FROM sub_lcos "
                "  WHERE company_id=:co"), {"co": company_id}).fetchall():
                if r[1]: _subl_lookup[str(r[1]).strip().lower()] = r[0]
                if r[2]: _subl_lookup[str(r[2]).strip().lower()] = r[0]
        except Exception as _e:
            print(f"[S31] sub_lco lookup preload failed: {_e}")

    for row in _s31_read_rows(file, raw):
        try:
            data = {}
            for raw_key, raw_val in (row or {}).items():
                k = _s31_hdrkey(raw_key)
                if k in schema:
                    col, cast = schema[k]
                    # _S39R5S_ — Treat blank cells as "leave it for staff to
                    # fill manually" — never coerce them to "0" or "0.0".
                    if raw_val is None or (isinstance(raw_val, str) and raw_val.strip() == ""):
                        continue
                    try:
                        data[col] = cast(raw_val)
                    except Exception:
                        data[col] = _s31_s(raw_val)
                elif raw_key:
                    unmapped_headers.add(str(raw_key))

            # _S39R5S_ — Resolve plan-name / sub-lco / location placeholders
            # added by the customer schema → the actual *_id columns.
            if kind == "customers":
                pn = data.pop("__plan_name__", None)
                if pn:
                    pid = _plan_lookup.get(str(pn).strip().lower())
                    if pid: data["plan_id"] = pid
                sc = data.pop("__sub_lco_code__", None)
                if sc:
                    sid = _subl_lookup.get(str(sc).strip().lower())
                    if sid: data["sub_lco_id"] = sid
                ln = data.pop("__location_name__", None)
                if ln:
                    lid = _loc_lookup.get(str(ln).strip().lower())
                    if lid: data["location_id"] = lid

            # _S39R5S_ — Previously, rows with NO recognised columns were
            # silently dropped which made admins think the import did
            # nothing. Now we only skip if the row is *completely* blank
            # (every cell empty). Anything with even a single cell of
            # content is imported — staff can fill in the rest later.
            non_blank = any((v not in (None, "", [], {})) for v in (row or {}).values())
            if not data and not non_blank:
                skipped += 1
                continue
            if not data and non_blank:
                # We got *some* data but none of the headers matched. Persist
                # whatever we can pull out so the row isn't lost.
                data["customer_name"] = next(
                    (str(v).strip() for v in row.values()
                     if v not in (None, "") and isinstance(v, (str, int, float))),
                    "Imported row")

            # Per-kind safety defaults so missing fields never raise DB errors.
            # _S39R5S_ — Mandatory NOT NULL columns get safe placeholders;
            # all other missing fields are intentionally left blank so
            # staff can edit them on the customer page later.
            if kind == "customers":
                if not data.get("customer_id"):
                    data["customer_id"] = _s31_dt.now().strftime("%y%m%d") + _s31_uuid.uuid4().hex[:6].upper()
                # Username is needed for RADIUS — fall back to the
                # auto-generated customer_id if the import doesn't have one.
                if not data.get("username"):
                    data["username"] = data["customer_id"]
                # Don't auto-generate a password for the user — leave blank
                # so staff can set it (if the column is NOT NULL on this
                # DB, fall back to a deterministic empty string hash).
                if not data.get("pppoe_password"):
                    data["pppoe_password"] = ""
                data["password_hash"] = _s31_hash.sha256(
                    (data.get("pppoe_password") or "").encode()).hexdigest()
                data["registration_type"] = data.get("registration_type", "Bulk Import")
                # Sensible defaults *only* when not provided so admins can
                # filter / list these rows; do NOT clobber imported values.
                data.setdefault("status", "Active")
                data.setdefault("auto_renew", "No")
                data.setdefault("gst_invoice_needed", "NO")
            elif kind == "plans":
                data.setdefault("service", "Broadband")
                data.setdefault("validity", 30)
                if not data.get("after_tax_amount"):
                    b = _s31_f(data.get("base_amount"))
                    g = _s31_f(data.get("cgst_tax")) + _s31_f(data.get("sgst_tax")) + _s31_f(data.get("igst_tax"))
                    data["after_tax_amount"] = round(b * (1 + g/100.0), 2)
            elif kind == "employees":
                if not data.get("employee_code"):
                    data["employee_code"] = "EMP-" + _s31_uuid.uuid4().hex[:6].upper()
                data.setdefault("status", "Active")
                data.setdefault("mobile", "")
                # Mandatory NOT NULL column
                try:
                    import bcrypt as _bc
                    data["password_hash"] = _bc.hashpw(b"ChangeMe@123", _bc.gensalt()).decode()
                except Exception:
                    data["password_hash"] = _s31_hash.sha256(b"ChangeMe@123").hexdigest()
            elif kind == "locations":
                # _S39R5S_ — Don't drop the row on missing name; default it
                # so staff can rename later in Locations page.
                if not data.get("name"):
                    data["name"] = f"Imported Location {_s31_uuid.uuid4().hex[:6].upper()}"
                data.setdefault("status", "Active")
            elif kind == "nas":
                # _S39R5S_ — Same philosophy: keep the row, fill blanks.
                if not data.get("name"):
                    data["name"] = f"Imported NAS {_s31_uuid.uuid4().hex[:6].upper()}"
                if not data.get("ip_address"):
                    data["ip_address"] = "0.0.0.0"
                data.setdefault("type", "Mikrotik")
                data.setdefault("status", "Active")
                data.setdefault("auth_modes", "pppoe")
                data.setdefault("port", 8728)
            elif kind == "ip-pools":
                if not data.get("name"):
                    data["name"] = f"Imported Pool {_s31_uuid.uuid4().hex[:6].upper()}"
                data.setdefault("network", "")
                data.setdefault("status", "Active")
                data.setdefault("role", "PPPoE")

            data["company_id"] = company_id
            obj = Model(**{k: v for k, v in data.items() if hasattr(Model, k)})
            db.add(obj)
            db.flush()
            ok += 1
        except Exception as e:
            failed += 1
            db.rollback()
            if len(errors) < 5: errors.append(str(e)[:200])

    try: db.commit()
    except Exception as e:
        db.rollback()
        _s31_log(company_id, "import", kind, ok, "partial", file.filename, str(e)[:200], actor)
        return JSONResponse({"success": False, "imported": ok, "skipped": skipped,
                             "failed": failed, "errors": errors,
                             "message": f"Commit failed: {e}"}, status_code=500)

    status = "success" if failed == 0 else "partial"
    _s31_log(company_id, "import", kind, ok, status, file.filename,
             f"ok={ok} skipped={skipped} failed={failed}", actor)
    # _S39R5S_ — Surface unmapped column headers so admins know which
    # spreadsheet columns the importer ignored (rather than guessing why
    # data didn't show up on the customer page).
    return JSONResponse({"success": True, "imported": ok, "skipped": skipped,
                         "failed": failed, "errors": errors,
                         "unmapped_headers": sorted(unmapped_headers)[:20]})


# -------------------- EXPORT (thin wrapper with date-range pass-through) --------------------
@app.get("/api/admin/data-mgmt/export")
async def api_dm_export(request: Request, kind: str = "customers",
                        format: str = "csv", start: str = "", end: str = ""):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    kind = (kind or "").lower().strip()
    info = _S31_KIND_MAP.get(kind)
    if not info:
        return JSONResponse({"error": f"unknown kind {kind}"}, status_code=400)
    fmt = "xlsx" if (format or "").lower() in ("excel", "xlsx") else "csv"
    qs = f"?format={fmt}"
    if start: qs += f"&start={start}"
    if end:   qs += f"&end={end}"
    # Log the export intent (actual download streams from the sub-endpoint)
    try:
        _s31_log(request.session.get("company_id"), "export", kind, 0, "queued",
                 f"{kind}.{fmt}", f"range={start}..{end}",
                 request.session.get("user_name") or request.session.get("user_id") or "admin")
    except Exception: pass
    return RedirectResponse(url=info["export"] + qs, status_code=303)


# -------------------- BACKUP --------------------
@app.get("/api/admin/data-mgmt/backup")
async def api_dm_backup(request: Request):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get("company_id")
    actor = request.session.get("user_name") or request.session.get("user_id") or "admin"
    # Copy the SQLite DB file via sqlite3 online-backup API (safe even while app is running).
    try:
        from database import engine
        db_url = str(engine.url)
        src_path = None
        if db_url.startswith("sqlite:///"):
            src_path = db_url.replace("sqlite:///", "", 1)
        if not src_path or not _s31_os.path.exists(src_path):
            raise RuntimeError(f"DB file not found at {src_path}")

        tmp_dir = _s31_tempfile.mkdtemp(prefix="ispb_bkp_")
        out_path = _s31_os.path.join(tmp_dir, f"isp_backup_{_s31_dt.now().strftime('%Y%m%d_%H%M%S')}.sqlite")
        src = _s31_sqlite3.connect(src_path)
        dst = _s31_sqlite3.connect(out_path)
        with dst: src.backup(dst)
        src.close(); dst.close()

        # gzip
        gz_path = out_path + ".gz"
        with open(out_path, "rb") as fi, _s31_gzip.open(gz_path, "wb") as fo:
            _s31_shutil.copyfileobj(fi, fo)
        _s31_os.remove(out_path)
        with open(gz_path, "rb") as f:
            blob = f.read()
        _s31_shutil.rmtree(tmp_dir, ignore_errors=True)
        _s31_log(company_id, "backup", "database", 1, "success",
                 _s31_os.path.basename(gz_path), f"size={len(blob)}", actor)
        return _S31Response(
            blob, media_type="application/gzip",
            headers={"Content-Disposition": f'attachment; filename="{_s31_os.path.basename(gz_path)}"'},
        )
    except Exception as e:
        _s31_log(company_id, "backup", "database", 0, "failed", "", str(e)[:200], actor)
        return JSONResponse({"success": False, "message": f"Backup failed: {e}"}, status_code=500)


