# __S39M__ Modern Customer Portal ---------------------------------------
def _require_customer(request: Request):
    if (request.session.get("user_type") or "").lower() != "customer":
        from fastapi.responses import RedirectResponse
        return RedirectResponse(url="/login", status_code=303)
    return None


# ---- Date formatting (Indian standard) ---------------------------------
# IMPORTANT: DB datetimes for paid_at, issue_date, created_at are stored in
# the same wall-clock that the existing PDF receipt prints (verified by user
# feedback). DO NOT call to_local()/timezone-shift them again — that caused
# the +5h30 drift in v2. Only format with Indian DD-MM-YYYY hh:MM AM/PM.
def _fmt_dt_in(dt) -> str:
    """_S40zκ_ Format datetime/str as DD-MM-YYYY HH:MM (24h, IST).
    All timestamps stored in DB are UTC (datetime.utcnow / converted
    paid_at). Convert UTC -> IST (+5:30) before display."""
    if not dt:
        return ""
    from datetime import datetime as _dt, timedelta as _td
    try:
        if isinstance(dt, str):
            s = dt.strip()
            if not s:
                return ""
            for fmt in ("%Y-%m-%d %H:%M:%S.%f", "%Y-%m-%d %H:%M:%S",
                        "%Y-%m-%d %H:%M", "%Y-%m-%dT%H:%M:%S.%f",
                        "%Y-%m-%dT%H:%M:%S", "%Y-%m-%dT%H:%M", "%Y-%m-%d"):
                try:
                    dt = _dt.strptime(s, fmt); break
                except Exception:
                    continue
            else:
                return s
        return (dt + _td(hours=5, minutes=30)).strftime("%d-%m-%Y %H:%M")
    except Exception:
        return str(dt)


def _fmt_date_in(dt) -> str:
    """Format DATE-only as DD-MM-YYYY."""
    if not dt:
        return ""
    from datetime import datetime as _dt, date as _date
    try:
        if isinstance(dt, str):
            s = dt.strip()
            if not s: return ""
            for fmt in ("%Y-%m-%d %H:%M:%S.%f", "%Y-%m-%d %H:%M:%S",
                        "%Y-%m-%d %H:%M", "%Y-%m-%d"):
                try:
                    dt = _dt.strptime(s, fmt); break
                except Exception:
                    continue
            else:
                return s
        if isinstance(dt, _date) and not isinstance(dt, _dt):
            return dt.strftime("%d-%m-%Y")
        return dt.strftime("%d-%m-%Y")
    except Exception:
        return str(dt)


# ---- Real-time online status (Mikrotik live polling) -------------------
# __S39M_V6__ TTL cache for static-IP company sync.  The Mikrotik scan
# is identical for every customer in the same company, so we only run it
# once per ~5 seconds no matter how many customers / tabs are polling.
_STATIC_IP_SYNC_CACHE = {}      # {company_id: last_run_epoch}
_STATIC_IP_SYNC_TTL   = 5.0     # seconds


def _sync_static_ip_company_cached(db: Session, company_id: str) -> None:
    """Wrapper around _sync_static_ip_online_for_company that runs at most
    once every _STATIC_IP_SYNC_TTL seconds per company."""
    import time as _t
    if not company_id:
        return
    last = _STATIC_IP_SYNC_CACHE.get(company_id, 0.0)
    if (_t.time() - last) < _STATIC_IP_SYNC_TTL:
        return
    try:
        from radius_network import _sync_static_ip_online_for_company
        _sync_static_ip_online_for_company(db, company_id)
        db.commit()
        _STATIC_IP_SYNC_CACHE[company_id] = _t.time()
    except Exception as _ex:
        print(f"[_sync_static_ip_company_cached] {_ex}")


def _is_customer_live_online(db: Session, cust) -> bool:
    """Live-poll Mikrotik for this customer's current session.

    PPPoE      → /ppp/active list, match by username.
    static-IP  → reuse the proven `_sync_static_ip_online_for_company`
                 helper which checks ARP + simple-queue counters, then
                 reads the freshly-updated `online_users` row.

    Falls back to the cached `online_users` table if no NAS reachable.

    === S42D-STATUS-GATE ===
    Non-Active customers (Expired / Suspended / Parked / Cancelled) are
    NEVER live-online. Mikrotik may still hold a stale pppoe session and
    our `online_users` cache may carry a leftover row, but the *commercial*
    answer to "is this subscriber currently using the internet" is no.
    Without this gate, an Expired user could see ONLINE on their portal
    while the admin shows them as Offline (the actual user report).
    """
    if not cust:
        return False
    _live_statuses = {"active", "online"}
    _st = (getattr(cust, "status", None) or "").strip().lower()
    if _st not in _live_statuses:
        # Also proactively close any stale online_users row so the next
        # admin Online-Users sync agrees.
        try:
            from sqlalchemy import text as _t_sg
            db.execute(_t_sg(
                "UPDATE online_users SET status='Offline', "
                "       updated_at=CURRENT_TIMESTAMP "
                " WHERE company_id=:c AND username=:u AND status='Online'"),
                {"c": cust.company_id or "", "u": (cust.username or "")})
            db.commit()
        except Exception:
            try: db.rollback()
            except Exception: pass
        return False
    username = (cust.username or "").strip().lower()
    auth_type = (getattr(cust, "auth_type", None) or "pppoe").strip().lower()
    company_id = cust.company_id or ""

    # ---- Static-IP customers ----------------------------------------
    # Reuse the existing helper that the admin / sub-LCO portals use.
    # It does ARP + simple-queue scan and writes the result back to
    # online_users — so we just read what it wrote.
    if auth_type in ("static_ip", "static"):
        # Cached: at most one Mikrotik scan per 5s per company.
        _sync_static_ip_company_cached(db, company_id)
        try:
            from sqlalchemy import text as _t_si
            row = db.execute(_t_si(
                "SELECT 1 FROM online_users "
                " WHERE company_id=:c AND username=:u AND status='Online' LIMIT 1"
            ), {"c": company_id, "u": (cust.username or "")}).fetchone()
            return bool(row)
        except Exception as ex:
            print(f"[_is_customer_live_online] static_ip read: {ex}")
            return False

    # ---- PPPoE / hotspot customers ---------------------------------
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        nas_rows = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active",
        ).all()
    except Exception as ex:
        print(f"[_is_customer_live_online] nas lookup: {ex}")
        nas_rows = []

    any_nas_reachable = False
    for nas in nas_rows:
        try:
            with rp.RouterOSClient(nas, dry_run=False) as rc:
                any_nas_reachable = True
                if username:
                    try:
                        active = rc.list_pppoe_active()
                        for row in (active or []):
                            if (row.get("name") or "").strip().lower() == username:
                                return True
                    except Exception as e1:
                        print(f"[_is_customer_live_online] pppoe: {e1}")
                # Hotspot active list (best-effort)
                try:
                    if hasattr(rc, "_api") and rc._api is not None:
                        for r in rc._api.path("ip/hotspot/active"):
                            if (r.get("user") or "").strip().lower() == username:
                                return True
                except Exception:
                    pass
        except Exception as e:
            print(f"[_is_customer_live_online] nas {nas.id} unreachable: {e}")
            continue

    if not any_nas_reachable:
        try:
            from sqlalchemy import text as _t_o
            row = db.execute(_t_o(
                "SELECT 1 FROM online_users WHERE company_id=:c AND username=:u "
                "AND status='Online' LIMIT 1"
            ), {"c": company_id, "u": (cust.username or "")}).fetchone()
            return bool(row)
        except Exception:
            return False
    return False


def _invoice_type_label(inv) -> tuple[bool, str]:
    """Return (is_manual, label).  Detects manual / addon invoices that
    don't have a normal billing period."""
    plan_name = (getattr(inv, "plan_name", "") or "").strip()
    plan_id   = getattr(inv, "plan_id", None)
    start = (getattr(inv, "start_date", "") or "").strip()
    end   = (getattr(inv, "end_date", "")   or "").strip()
    # Normalise plan_name lower for keyword check.
    pl = plan_name.lower()
    if pl.startswith("manual:"):
        # "Manual: CAT6 CABLE" -> "Manual: CAT6 CABLE"
        return True, plan_name
    if "addon" in pl:
        return True, (plan_name or "Addon Bill")
    if not plan_id and not (start and end):
        # No plan + no period — almost certainly a manual / one-off bill.
        return True, (plan_name or "One-off Bill")
    return False, plan_name


def _customer_ctx(request: Request, db: Session, active_page: str = "dashboard"):
    from database import Customer, Company
    cid = request.session.get("user_id")
    company_id = request.session.get("company_id") or ""
    cust = db.query(Customer).filter(Customer.customer_id == cid).first()
    if cust and not company_id:
        company_id = cust.company_id or ""
        request.session["company_id"] = company_id
    company = db.query(Company).filter(Company.company_id == company_id).first()
    online = _is_customer_live_online(db, cust)
    company_name = (company.company_name if company else None) or "ISP"
    company_logo = (getattr(company, "logo_path", None) or
                    getattr(company, "company_logo", None) or "")
    if company_logo and not company_logo.startswith("/"):
        company_logo = "/" + company_logo
    return {
        "request": request,
        "active_page": active_page,
        "customer": cust,
        "customer_name": (cust.customer_name if cust else "") or (request.session.get("user_name") or ""),
        "is_online": online,
        "company": company,
        "company_id": company_id,
        "company_name": company_name,
        "company_logo": company_logo or None,
        "company_phone": getattr(company, "company_phone", "") if company else "",
        "company_email": getattr(company, "company_email", "") if company else "",
        "company_theme_color": getattr(company, "theme_color", None) or "#0ea5e9",
        "company_theme_accent": getattr(company, "theme_accent", None) or "#7c3aed",
    }


def _customer_team_contacts(db: Session, cust):
    if not cust: return {}
    out = {"employee_name": "", "employee_phone": "", "employee_email": "",
           "sub_lco_name": "", "sub_lco_phone": "", "sub_lco_email": ""}
    try:
        from sqlalchemy import text as _t_tc
        if cust.locality:
            row = db.execute(_t_tc("""
                SELECT e.employee_name, e.mobile, e.email
                  FROM employee_locality_assignments ela
                  JOIN employees e ON ela.employee_id = e.id
                  JOIN locations  l ON ela.location_id = l.id
                 WHERE ela.company_id = :co AND ela.active = 1
                   AND UPPER(TRIM(l.name)) = UPPER(TRIM(:loc))
                 LIMIT 1
            """), {"co": cust.company_id, "loc": cust.locality}).fetchone()
            if row:
                out["employee_name"]  = row[0] or ""
                out["employee_phone"] = row[1] or ""
                out["employee_email"] = row[2] or ""
        if getattr(cust, "sub_lco_id", None):
            row = db.execute(_t_tc(
                "SELECT COALESCE(name, ''), COALESCE(mobile, ''), COALESCE(email,'') "
                "FROM sub_lcos WHERE id=:s"
            ), {"s": int(cust.sub_lco_id)}).fetchone()
            if row:
                out["sub_lco_name"]  = row[0] or ""
                out["sub_lco_phone"] = row[1] or ""
                out["sub_lco_email"] = row[2] or ""
    except Exception as _ex:
        print(f"[_customer_team_contacts] {_ex}")
    return out


def _cust_balance(db: Session, cust) -> float:
    if not cust: return 0.0
    try:
        return float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception as ex:
        print(f"[_cust_balance] {ex}")
        return 0.0


def _build_upi_link(company, cust, amount: float) -> str:
    """Build a upi:// deep-link with customer name + id in the note."""
    try:
        if amount <= 0: return ""
        from urllib.parse import quote
        upi_id = (getattr(company, "upi_id", None)
                  or getattr(company, "company_upi_id", None)
                  or getattr(company, "merchant_upi", None) or "")
        upi_id = (upi_id or "").strip()
        if not upi_id or "@" not in upi_id:
            return ""
        payee = (company.company_name if company else "ISP") or "ISP"
        # Customer name + id in transaction note (visible in UPI app).
        cust_name = (cust.customer_name if cust else "") or "Customer"
        cust_id   = (cust.customer_id   if cust else "") or ""
        note = f"{cust_name} ({cust_id}) - Internet Bill"
        # Truncate note if too long for UPI spec (most apps allow up to ~80 chars).
        note = note[:80]
        return (f"upi://pay?pa={quote(upi_id)}"
                f"&pn={quote(payee)}"
                f"&am={amount:.2f}"
                f"&cu=INR"
                f"&tn={quote(note)}"
                f"&tr={quote(cust_id or 'BILL')}")
    except Exception as ex:
        print(f"[_build_upi_link] {ex}")
        return ""


# ---- Page routes -------------------------------------------------------
@app.get("/customer/dashboard", response_class=HTMLResponse)
async def customer_dashboard(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return g
    ctx = _customer_ctx(request, db, "dashboard")
    cust = ctx["customer"]; company = ctx["company"]
    ctx.update(_customer_team_contacts(db, cust))
    if cust:
        from sqlalchemy import text as _t_d
        from database import Plan, Invoice, Payment
        plan = None
        if getattr(cust, "plan_id", None):
            plan = db.query(Plan).filter(Plan.id == cust.plan_id).first()
        ctx.update({
            "plan_name":  plan.plan_name if plan else "—",
            "plan_price": int(plan.after_tax_amount or 0) if plan else 0,
            "plan_validity": int(plan.validity or 30) if plan else 30,
            "plan_service":  (plan.service if plan else "") or "",
            # s40r: plan download speed (Mbps) used ONLY as the upper cap
            # for the live-speed graph's anti-spike clamp. Stored in a
            # data attribute, never rendered as text to the customer.
            "plan_download_speed": (
                _parse_speed_mbps(getattr(plan, "download_speed", None))
                if plan else 0),
            "end_date_fmt":  _fmt_date_in(cust.end_date),
            "days_remaining": 0,
        })
        try:
            from datetime import date, datetime as _dt
            if cust.end_date:
                ed = cust.end_date
                if isinstance(ed, str):
                    ed = _dt.strptime(ed.split(" ")[0], "%Y-%m-%d").date()
                ctx["days_remaining"] = max(0, (ed - date.today()).days)
        except Exception:
            pass
        ctx["balance"] = _cust_balance(db, cust)
        ctx["upi_link"] = _build_upi_link(company, cust, ctx["balance"])
        invs = db.query(Invoice).filter(
            Invoice.customer_id == cust.customer_id,
            Invoice.company_id == cust.company_id,
        ).order_by(Invoice.id.desc()).limit(5).all()
        # __S43ZY__ Skip manual / addon invoices in the dashboard tile too.
        ctx["recent_invoices"] = [{
            "invoice_no": i.invoice_no,
            "issue_date": _fmt_date_in(i.issue_date),
            "total_amount": float(i.total_amount or 0),
            "status": (i.status or "Unpaid"),
        } for i in invs if not _invoice_type_label(i)[0]]
        pays = db.query(Payment).filter(
            Payment.customer_id == cust.customer_id,
            Payment.company_id == cust.company_id,
        ).order_by(Payment.id.desc()).limit(5).all()
        # === S41U-USER-DASH-DATEONLY ===
        # User dashboard "Recent Payments" tile: date only (no time) per user request.
        # __S43ZY__ Skip manual book-keeping (plan upgrade / adjustment / credit note).
        _HIDE_PAY = ("plan upgrade", "adjustment", "credit note",
                     "manual credit", "manual debit", "internal")
        def _hide_p(_p):
            _mode = (_p.payment_mode or "").lower()
            _rem  = (_p.remarks or "").lower()
            return any(h in _mode for h in _HIDE_PAY) or any(h in _rem for h in _HIDE_PAY)
        ctx["recent_payments"] = [{
            "paid_at": _fmt_date_in(p.paid_at),
            "amount": float(p.amount or 0),
            "payment_mode": p.payment_mode or "",
            "transaction_no": p.transaction_no or "",
        } for p in pays if not _hide_p(p)]
        # bytes_in/bytes_out are MB on this schema.
        try:
            row = db.execute(_t_d("""
                SELECT COALESCE(SUM(bytes_in),0), COALESCE(SUM(bytes_out),0), COUNT(*)
                  FROM online_users
                 WHERE company_id=:co AND username=:u
                   AND started_at >= datetime('now', '-30 days')
            """), {"co": cust.company_id, "u": (cust.username or "")}).fetchone()
            # S42M-BYTES-SWAP: this deployment reports bytes-in/out reversed.
            # bytes_in (raw)  → DOWNLOAD;  bytes_out (raw) → UPLOAD.
            import os as _os_dd
            _swap = _os_dd.getenv("RADACCT_BYTES_SWAP", "0") not in ("0","false","False","")
            mb_raw_in  = float(row[0] or 0)
            mb_raw_out = float(row[1] or 0)
            mb_up = mb_raw_out if _swap else mb_raw_in
            mb_dn = mb_raw_in  if _swap else mb_raw_out
            ctx["uploaded_gb"]   = round(mb_up / 1024.0, 2)
            ctx["downloaded_gb"] = round(mb_dn / 1024.0, 2)
            ctx["data_used_gb"]  = round((mb_up + mb_dn) / 1024.0, 2)
        except Exception:
            ctx["downloaded_gb"] = 0; ctx["uploaded_gb"] = 0; ctx["data_used_gb"] = 0
    return templates.TemplateResponse("user_dashboard.html", ctx)


@app.get("/customer/invoices", response_class=HTMLResponse)
async def customer_invoices_page(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return g
    ctx = _customer_ctx(request, db, "invoices")
    cust = ctx["customer"]
    if cust:
        from database import Invoice
        invs = db.query(Invoice).filter(
            Invoice.customer_id == cust.customer_id,
            Invoice.company_id == cust.company_id,
        ).order_by(Invoice.id.desc()).all()
        rows = []
        for i in invs:
            is_manual, type_label = _invoice_type_label(i)
            # __S43ZY__ Hide manual / addon / one-off invoices from the
            # customer-facing list (admin-only book-keeping rows).
            if is_manual:
                continue
            _period_amt = float(i.total_amount or 0)
            _due_run    = float(getattr(i, "due_at_issue", 0) or 0)
            # _v4730_INV_TOTAL_DUE — show running balance at issue time
            # (current period + previous dues) when available.
            _shown_amt  = _due_run if _due_run > 0 else _period_amt
            rows.append({
                "id": i.id,
                "invoice_no": i.invoice_no,
                "issue_date": _fmt_date_in(i.issue_date),
                "start_date": _fmt_date_in(getattr(i, "start_date", "")),
                "end_date":   _fmt_date_in(getattr(i, "end_date", "")),
                "total_amount":     _shown_amt,
                "period_amount":    _period_amt,
                "previous_balance": round(max(0.0, _shown_amt - _period_amt), 2),
                "status": (i.status or "Unpaid"),
                "is_manual": is_manual,
                "type_label": type_label,
            })
        ctx["invoices"] = rows
    return templates.TemplateResponse("user_invoices.html", ctx)


@app.get("/customer/payments", response_class=HTMLResponse)
async def customer_payments_page(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return g
    ctx = _customer_ctx(request, db, "payments")
    cust = ctx["customer"]
    if cust:
        from database import Payment
        pays = db.query(Payment).filter(
            Payment.customer_id == cust.customer_id,
            Payment.company_id == cust.company_id,
        ).order_by(Payment.id.desc()).all()
        # __RENEWAL_PERIOD_CUST_PORTAL__
        try:
            from invoice_period_for_payment import invoice_period_for_payment as _ipfp_cp
        except Exception:
            _ipfp_cp = lambda *a, **kw: None
        ctx["payments"] = []
        # __S43ZY__ Skip manual book-keeping rows from the customer-facing payments page.
        _HIDE_PAY_CP = ("plan upgrade", "adjustment", "credit note",
                        "manual credit", "manual debit", "internal")
        for p in pays:
            _mode_lc = (p.payment_mode or "").lower()
            _rem_lc  = (p.remarks or "").lower()
            if any(h in _mode_lc for h in _HIDE_PAY_CP) or any(h in _rem_lc for h in _HIDE_PAY_CP):
                continue
            _inv_p = _ipfp_cp(p, db) or {}
            ctx["payments"].append({
                "id": p.id,
                # === S41S-USER-PAY-DATEONLY ===
                # User-portal Payment History: date only, no time (per user req).
                "paid_at": _fmt_date_in(p.paid_at),
                "amount": float(p.amount or 0),
                "payment_mode": p.payment_mode or "",
                "transaction_no": p.transaction_no or "",
                "remarks": p.remarks or "",
                "renewal_period": _inv_p.get("renewal_period", ""),
                "plan_name": _inv_p.get("plan_name", ""),
            })
    return templates.TemplateResponse("user_payments.html", ctx)


@app.get("/customer/usage", response_class=HTMLResponse)
async def customer_usage_page(request: Request, db: Session = Depends(get_db)):
    g = _require_customer(request)
    if g: return g
    ctx = _customer_ctx(request, db, "usage")
    cust = ctx["customer"]
    # __S43V_SHOW_USAGE__ short-circuit if admin has not opted this user in
    if cust and not bool(getattr(cust, "show_data_usage", 0)):
        return RedirectResponse(url="/customer/dashboard", status_code=303)
    sessions = []
    if cust:
        # === S42D-USAGE-RADACCT ===
        # Previous version pulled from `online_users` — only CURRENTLY
        # online sessions are in that table, and rows get pruned when a
        # subscriber disconnects, so the historic chart was always empty.
        # Switch to the FreeRADIUS `radacct` table (separate SQLite DB)
        # which has every session start/stop with byte counters.
        # `acctinputoctets` = bytes uploaded by subscriber
        # `acctoutputoctets` = bytes downloaded by subscriber
        import sqlite3 as _sq_u
        try:
            # S42J — backfill so recent rows have company_id, then strict fence.
            try:
                from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa6
                _rp_bfa6(db, radacct_path="/var/lib/freeradius/radacct.db", limit=2000)
            except Exception:
                pass
            _ra = _sq_u.connect("/var/lib/freeradius/radacct.db",
                                  isolation_level=None, timeout=2.0)
            _ra.row_factory = _sq_u.Row
            un = (cust.username or "").strip()
            rs = _ra.execute(
                "SELECT datetime(acctstarttime,'unixepoch','localtime') AS started_at,"
                "       COALESCE(acctsessiontime,0) AS uptime_seconds,"
                "       COALESCE(acctinputoctets,0)  AS bytes_up,"
                "       COALESCE(acctoutputoctets,0) AS bytes_dn,"
                "       COALESCE(nasipaddress,'')    AS nas_ip,"
                "       (acctstoptime IS NULL)       AS is_open "
                "  FROM radacct "
                " WHERE username=? AND company_id=? "
                " ORDER BY acctstarttime DESC "
                " LIMIT 30",
                (un, str(cust.company_id))).fetchall()
            _ra.close()
            # S42M-BYTES-SWAP: align customer-portal usage with the
            # corrected up/down mapping. `rs` rows are sqlite3.Row so
            # we transform them into plain dicts here.
            import os as _os_bs2
            _swap_u = _os_bs2.getenv("RADACCT_BYTES_SWAP", "0") not in ("0","false","False","")
            if _swap_u:
                rs = [{"started_at":   r["started_at"],
                       "uptime_seconds": r["uptime_seconds"],
                       "bytes_up":     r["bytes_dn"],  # swapped
                       "bytes_dn":     r["bytes_up"],  # swapped
                       "nas_ip":       r["nas_ip"],
                       "is_open":      r["is_open"]} for r in rs]
        except Exception as _eu:
            print(f"[user-usage radacct] {_eu}")
            rs = []
        # === S42E-LIVE-OVERLAY ===
        # Until FreeRADIUS receives the next interim-update (typically
        # 5-10 min), an open (acctstoptime IS NULL) radacct row carries
        # 0 for acctinputoctets/acctoutputoctets. The matching
        #  row IS refreshed every 120s by the sync job AND
        # via live MikroTik probes. We additionally fire a fresh probe
        # via -style path so the user portal
        # always shows up-to-the-second counters for the current session.
        live_up_mb = live_dn_mb = 0.0
        live_secs = 0
        live_nas = ""
        try:
            from sqlalchemy import text as _t_ou
            ou = db.execute(_t_ou(
                "SELECT bytes_in, bytes_out, uptime_seconds, nas_ip, started_at "
                "  FROM online_users "
                " WHERE company_id=:co AND username=:u "
                "   AND status IN ('Online','WalledGarden') "
                " ORDER BY started_at DESC LIMIT 1"),
                {"co": cust.company_id, "u": (cust.username or "")}).fetchone()
            if ou:
                # S42M-BYTES-SWAP: align live overlay with rest of UI.
                import os as _os_bs3
                _swap_lv = _os_bs3.getenv("RADACCT_BYTES_SWAP", "0") not in ("0","false","False","")
                _raw_in  = float(ou[0] or 0)
                _raw_out = float(ou[1] or 0)
                live_up_mb = _raw_out if _swap_lv else _raw_in
                live_dn_mb = _raw_in  if _swap_lv else _raw_out
                live_secs  = int(ou[2] or 0)
                live_nas   = ou[3] or ""
        except Exception:
            pass

        mb_up_sum = mb_dn_sum = 0.0
        # === S42I-STALE-OPEN-DETECT ===
        # A radacct row can stay OPEN (acctstoptime IS NULL) for weeks
        # if Mikrotik never sent Acct-Stop. In that case the user's
        # ACTUAL current session lives only in  with a
        # much fresher started_at. Without this guard, my earlier
        # synth-row logic ran with  and never inserted
        # the live row -- so the user portal showed only the April-23
        # stale row labelled as live (Shailendra2 case).
        from datetime import datetime as _dt_so, timedelta as _td_so
        had_open = False
        if rs:
            for r in rs:
                if not r["is_open"]: continue
                # Parse radacct start (already local-time-formatted str).
                try:
                    _rast = _dt_so.strptime((r["started_at"] or "")[:19],
                                              "%Y-%m-%d %H:%M:%S")
                except Exception:
                    _rast = None
                # If online_users start is materially later (>1h) than
                # the radacct open row, treat radacct as stale.
                _ou_started = None
                if ou and ou[4]:
                    try:
                        _s = ou[4]
                        if isinstance(_s, str):
                            _ou_started = _dt_so.strptime(_s[:19], "%Y-%m-%d %H:%M:%S")
                        else:
                            _ou_started = _s
                    except Exception:
                        pass
                if _rast and _ou_started and (_ou_started - _rast) > _td_so(hours=1):
                    # Stale radacct open row — ignore for liveness purposes.
                    continue
                had_open = True
                break
        if (not had_open) and (live_up_mb or live_dn_mb or live_secs):
            sessions.append({
                "start": "(current)",
                "duration": (f"{live_secs // 3600}h {(live_secs % 3600) // 60}m"
                             if live_secs else "(live)"),
                "up_gb":   round(live_up_mb / 1024.0, 3),
                "down_gb": round(live_dn_mb / 1024.0, 3),
                "up_mb":   round(live_up_mb, 1),
                "down_mb": round(live_dn_mb, 1),
                "nas_ip":  live_nas,
            })
            mb_up_sum += live_up_mb
            mb_dn_sum += live_dn_mb

        for r in rs:
            up = int(r["uptime_seconds"] or 0)
            b_up = float(r["bytes_up"] or 0)
            b_dn = float(r["bytes_dn"] or 0)
            mb_up = b_up / 1048576.0
            mb_dn = b_dn / 1048576.0
            # === S42E-LIVE-OVERLAY-OPEN ===
            # If this is the open (live) row and FreeRADIUS hasn'''t
            # written interim counters yet, overlay with online_users
            # values so the user sees real-time data.
            if r["is_open"] and (mb_up == 0 and mb_dn == 0) and (live_up_mb or live_dn_mb):
                mb_up = live_up_mb
                mb_dn = live_dn_mb
                up = max(up, live_secs)
            sessions.append({
                "start": r["started_at"] or "",
                "duration": (f"{up // 3600}h {(up % 3600) // 60}m"
                             if up else ("(live)" if r["is_open"] else "0h 0m")),
                "up_gb":   round(mb_up / 1024.0, 3),
                "down_gb": round(mb_dn / 1024.0, 3),
                "up_mb":   round(mb_up, 1),
                "down_mb": round(mb_dn, 1),
                "nas_ip":  r["nas_ip"] or "",
                "is_live": bool(r["is_open"]),
            })
            mb_up_sum += mb_up
            mb_dn_sum += mb_dn
        ctx["uploaded_gb"]   = round(mb_up_sum / 1024.0, 2)
        ctx["downloaded_gb"] = round(mb_dn_sum / 1024.0, 2)
        ctx["data_used_gb"]  = round((mb_up_sum + mb_dn_sum) / 1024.0, 2)
        ctx["session_count"] = len(sessions)
        ctx["sessions"] = sessions
    return templates.TemplateResponse("user_usage.html", ctx)


