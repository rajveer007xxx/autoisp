# Helpers for extended Plan fields --------------------------------------------
def _to_bool(v):
    if isinstance(v, bool):
        return v
    if v is None:
        return False
    s = str(v).strip().lower()
    return s in ("1", "true", "yes", "on")


def _to_float(v, default=0.0):
    try:
        if v in (None, ""):
            return default
        return float(v)
    except (TypeError, ValueError):
        return default


def _to_int(v, default=0):
    try:
        if v in (None, ""):
            return default
        return int(float(v))
    except (TypeError, ValueError):
        return default


def _parse_plan_validity(data):
    """Accept validity either as plain int (days) or number+unit (days/months/years)."""
    unit = (data.get("validity_unit") or "days").strip().lower()
    raw = data.get("validity", "30")
    try:
        n = int(str(raw).split()[0])
    except (TypeError, ValueError):
        if "month" in str(raw).lower():
            return 30
        return 30
    if unit == "months":
        return n * 30
    if unit == "years":
        return n * 365
    return n


def _plan_speed_label(data):
    """Build the legacy single-line 'speed' label from dl/ul if provided."""
    explicit = (data.get("speed") or "").strip()
    if explicit:
        return explicit
    dl = (data.get("download_speed") or "").strip()
    ul = (data.get("upload_speed") or "").strip()
    if dl and ul:
        return f"{dl} / {ul}"
    return dl or ul or ""


def _plan_extended_kwargs(data):
    """Return kwargs dict for the extended Plan columns from request data."""
    return {
        "download_speed": (data.get("download_speed") or "").strip() or None,
        "upload_speed": (data.get("upload_speed") or "").strip() or None,
        "validity_unit": (data.get("validity_unit") or "days").strip() or "days",
        "fup_enabled": _to_bool(data.get("fup_enabled")),
        "fup_limit_gb": _to_float(data.get("fup_limit_gb")),
        "fup_post_download": (data.get("fup_post_download") or "").strip() or None,
        "fup_post_upload": (data.get("fup_post_upload") or "").strip() or None,
        "night_boost_enabled": _to_bool(data.get("night_boost_enabled")),
        "night_boost_start": (data.get("night_boost_start") or "").strip() or None,
        "night_boost_end": (data.get("night_boost_end") or "").strip() or None,
        "night_boost_download": (data.get("night_boost_download") or "").strip() or None,
        "night_boost_upload": (data.get("night_boost_upload") or "").strip() or None,
        "burst_enabled": _to_bool(data.get("burst_enabled")),
        "burst_limit_down": (data.get("burst_limit_down") or "").strip() or None,
        "burst_limit_up": (data.get("burst_limit_up") or "").strip() or None,
        "burst_threshold_down": (data.get("burst_threshold_down") or "").strip() or None,
        "burst_threshold_up": (data.get("burst_threshold_up") or "").strip() or None,
        "burst_time_down": _to_int(data.get("burst_time_down")),
        "burst_time_up": _to_int(data.get("burst_time_up")),
        "priority": _to_int(data.get("priority"), 8),
        "queue_type": (data.get("queue_type") or "default").strip() or "default",
        # _S40zP_dns_  Per-plan DNS content-filter profile (None = no filtering)
        "dns_profile_id": _to_int(data.get("dns_profile_id")) or None,
    }


def _plan_to_dict(plan):
    """Serialize a Plan ORM object to dict, including extended fields."""
    return {
        "id": plan.id,
        "service": plan.service,
        "plan_name": plan.plan_name,
        "speed": plan.speed,
        "validity": plan.validity,
        "base_amount": round(plan.base_amount or 0),
        "cgst_tax": plan.cgst_tax,
        "sgst_tax": plan.sgst_tax,
        "igst_tax": plan.igst_tax,
        "after_tax_amount": round(plan.after_tax_amount or 0),
        "description": plan.description,
        "download_speed": plan.download_speed,
        "upload_speed": plan.upload_speed,
        "validity_unit": plan.validity_unit or "days",
        "fup_enabled": bool(plan.fup_enabled),
        "fup_limit_gb": plan.fup_limit_gb or 0,
        "fup_post_download": plan.fup_post_download,
        "fup_post_upload": plan.fup_post_upload,
        "night_boost_enabled": bool(plan.night_boost_enabled),
        "night_boost_start": plan.night_boost_start,
        "night_boost_end": plan.night_boost_end,
        "night_boost_download": plan.night_boost_download,
        "night_boost_upload": plan.night_boost_upload,
        "burst_enabled": bool(plan.burst_enabled),
        "burst_limit_down": plan.burst_limit_down,
        "burst_limit_up": plan.burst_limit_up,
        "burst_threshold_down": plan.burst_threshold_down,
        "burst_threshold_up": plan.burst_threshold_up,
        "burst_time_down": plan.burst_time_down or 0,
        "burst_time_up": plan.burst_time_up or 0,
        "priority": plan.priority or 8,
        "queue_type": plan.queue_type or "default",
        "dns_profile_id": plan.dns_profile_id,
    }



@app.post("/api/plans")
async def create_plan(request: Request, db: Session = Depends(get_db)):
    """Create a new plan"""
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    
    company_id = request.session.get("company_id")
    if not company_id:
        return JSONResponse({"success": False, "message": "Company ID not found"}, status_code=400)
    
    from database import Plan
    
    try:
        data = await request.json()
        
        base_amount = float(data.get("base_amount", 0))
        cgst_tax = float(data.get("cgst_tax", 0))
        sgst_tax = float(data.get("sgst_tax", 0))
        igst_tax = float(data.get("igst_tax", 0))
        
        if cgst_tax > 0 or sgst_tax > 0:
            cgst_amount = (base_amount * cgst_tax) / 100
            sgst_amount = (base_amount * sgst_tax) / 100
            after_tax_amount = round(base_amount + cgst_amount + sgst_amount)
        else:
            igst_amount = (base_amount * igst_tax) / 100
            after_tax_amount = round(base_amount + igst_amount)
        
        validity = _parse_plan_validity(data)
        
        kwargs = dict(
            company_id=company_id,
            service=data.get("service"),
            plan_name=data.get("plan_name"),
            speed=_plan_speed_label(data),
            validity=validity,
            base_amount=base_amount,
            cgst_tax=cgst_tax,
            sgst_tax=sgst_tax,
            igst_tax=igst_tax,
            after_tax_amount=after_tax_amount,
            description=data.get("description", ""),
        )
        kwargs.update(_plan_extended_kwargs(data))
        new_plan = Plan(**kwargs)
        
        db.add(new_plan)
        db.commit()
        db.refresh(new_plan)
        
        return JSONResponse({"success": True, "message": "Plan saved successfully", "plan_id": new_plan.id})
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": str(e)}, status_code=500)

@app.get("/api/plans/list")
async def list_plans(request: Request, service: str = None, db: Session = Depends(get_db)):
    """Get list of plans filtered by service type"""
    auth_check = require_auth(request)
    if auth_check:
        return {"error": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Plan
    
    query = db.query(Plan).filter(Plan.company_id == company_id)
    if service:
        query = query.filter(Plan.service == service)
    
    plans = query.all()
    
    return {"plans": [_plan_to_dict(plan) for plan in plans]}

@app.get("/api/plans/{plan_id}")
async def get_plan(plan_id: int, request: Request, db: Session = Depends(get_db)):
    """Get a single plan by ID"""
    auth_check = require_auth(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    
    company_id = request.session.get("company_id")
    if not company_id:
        return JSONResponse({"success": False, "message": "Company ID not found"}, status_code=400)
    
    from database import Plan
    
    plan = db.query(Plan).filter(Plan.id == plan_id, Plan.company_id == company_id).first()
    if not plan:
        return JSONResponse({"success": False, "message": "Plan not found"}, status_code=404)
    
    return _plan_to_dict(plan)

@app.put("/api/plans/{plan_id}")
async def update_plan(plan_id: int, request: Request, db: Session = Depends(get_db)):
    """Update an existing plan (admin only)"""
    auth_check = require_admin(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    
    company_id = request.session.get("company_id")
    if not company_id:
        return JSONResponse({"success": False, "message": "Company ID not found"}, status_code=400)
    
    from database import Plan
    
    try:
        plan = db.query(Plan).filter(Plan.id == plan_id, Plan.company_id == company_id).first()
        if not plan:
            return JSONResponse({"success": False, "message": "Plan not found"}, status_code=404)
        
        data = await request.json()
        
        base_amount = float(data.get("base_amount", plan.base_amount))
        cgst_tax = float(data.get("cgst_tax", plan.cgst_tax))
        sgst_tax = float(data.get("sgst_tax", plan.sgst_tax))
        igst_tax = float(data.get("igst_tax", plan.igst_tax))
        
        if cgst_tax > 0 or sgst_tax > 0:
            cgst_amount = (base_amount * cgst_tax) / 100
            sgst_amount = (base_amount * sgst_tax) / 100
            after_tax_amount = round(base_amount + cgst_amount + sgst_amount)
        else:
            igst_amount = (base_amount * igst_tax) / 100
            after_tax_amount = round(base_amount + igst_amount)
        
        validity = _parse_plan_validity(data) if ("validity" in data or "validity_unit" in data) else plan.validity
        
        plan.service = data.get("service", plan.service)
        plan.plan_name = data.get("plan_name", plan.plan_name)
        plan.speed = _plan_speed_label(data) or plan.speed
        plan.validity = validity
        plan.base_amount = base_amount
        plan.cgst_tax = cgst_tax
        plan.sgst_tax = sgst_tax
        plan.igst_tax = igst_tax
        plan.after_tax_amount = after_tax_amount
        plan.description = data.get("description", plan.description)

        # Apply extended fields only for keys that are actually sent
        ext = _plan_extended_kwargs(data)
        for k, v in ext.items():
            if k in data:
                setattr(plan, k, v)
        
        db.commit()
        
        return JSONResponse({"success": True, "message": "Plan updated successfully"})
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": str(e)}, status_code=500)

@app.delete("/api/plans/{plan_id}")
async def delete_plan(plan_id: int, request: Request, db: Session = Depends(get_db)):
    """Delete a plan (admin only)"""
    auth_check = require_admin(request)
    if auth_check:
        return JSONResponse({"success": False, "message": "Unauthorized"}, status_code=401)
    
    company_id = request.session.get("company_id")
    if not company_id:
        return JSONResponse({"success": False, "message": "Company ID not found"}, status_code=400)
    
    from database import Plan
    
    try:
        plan = db.query(Plan).filter(Plan.id == plan_id, Plan.company_id == company_id).first()
        if not plan:
            return JSONResponse({"success": False, "message": "Plan not found"}, status_code=404)
        
        db.delete(plan)
        db.commit()
        
        return JSONResponse({"success": True, "message": "Plan deleted successfully"})
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": str(e)}, status_code=500)

@app.get("/api/profile/get")
async def get_profile(request: Request, db: Session = Depends(get_db)):
    """Get current admin profile data"""
    auth_check = require_auth(request)
    if auth_check:
        return {"error": "Unauthorized"}
    
    user_id = request.session.get("user_id")
    company_id = request.session.get("company_id")
    
    from database import Admin, Company
    
    # Get admin data
    admin = db.query(Admin).filter(Admin.admin_id == user_id).first()
    if not admin:
        return {"error": "Admin not found"}
    
    # Get company data
    company = db.query(Company).filter(Company.company_id == company_id).first()
    if not company:
        return {"error": "Company not found"}
    
    return {
        "admin": {
            "admin_id": admin.admin_id,
            "admin_name": admin.admin_name,
            "admin_email": admin.admin_email,
            "admin_mobile": admin.admin_mobile,
            "profile_image_path": admin.profile_image_path,
            # _S39R5U_ — Per-admin invoice seal & signature
            "seal_signature_path": getattr(admin, "seal_signature_path", None),
        },
        "company": {
            "company_id": company.company_id,
            "company_name": company.company_name,
            "company_email": company.company_email,
            "company_phone": company.company_phone,
            "company_address": company.company_address,
            "country": company.country,
            "state": company.state,
            "city": company.city,
            "pincode": company.pincode,
            "gst_number": company.gst_number,
            "bank_name": company.bank_name,
            "account_number": company.account_number,
            "branch_code": company.branch_code,
            "branch_location": company.branch_location,
            "branch_ifsc": company.branch_ifsc,
            "upi_id": company.upi_id,
            "account_holder_name": getattr(company, "account_holder_name", "") or "",
            "logo_path": company.logo_path,
            "declaration": company.declaration or "",
            "terms_conditions": company.terms_conditions or "",
            # === S41Y-UI-GET auto-email toggles ===
            "auto_email_invoices": int(getattr(company, "auto_email_invoices", 1) or 0),
            "auto_email_receipts": int(getattr(company, "auto_email_receipts", 0) or 0),
            # _S58AW_  Telegram alert credentials (per-tenant)
            "telegram_bot_token":     getattr(company, "telegram_bot_token", "") or "",
            "telegram_admin_chat_id": getattr(company, "telegram_admin_chat_id", "") or ""
        }
    }

@app.post("/api/profile/update")
async def update_profile(request: Request, db: Session = Depends(get_db)):
    """Update admin profile data"""
    auth_check = require_auth(request)
    if auth_check:
        return {"error": "Unauthorized"}
    
    user_id = request.session.get("user_id")
    company_id = request.session.get("company_id")
    
    from database import Admin, Company
    import bcrypt
    
    form_data = await request.form()
    
    # Update admin data
    admin = db.query(Admin).filter(Admin.admin_id == user_id).first()
    if admin:
        admin.admin_name = form_data.get("name", admin.admin_name)
        admin.admin_email = form_data.get("email", admin.admin_email)
        admin.admin_mobile = form_data.get("mobile", admin.admin_mobile)
        
        old_password = form_data.get("old_password")
        new_password = form_data.get("password")
        if old_password and new_password:
            # Verify old password
            if bcrypt.checkpw(old_password.encode('utf-8'), admin.password_hash.encode('utf-8')):
                # Hash new password
                hashed = bcrypt.hashpw(new_password.encode('utf-8'), bcrypt.gensalt())
                admin.password_hash = hashed.decode('utf-8')
            else:
                return {"error": "Old password is incorrect"}
    
    # Update company data
    company = db.query(Company).filter(Company.company_id == company_id).first()
    if company:
        company.company_name = form_data.get("company_name", company.company_name)
        company.company_email = form_data.get("email", company.company_email)
        company.company_phone = form_data.get("mobile", company.company_phone)
        company.company_address = form_data.get("company_address", company.company_address)
        company.country = form_data.get("country", company.country)
        company.state = form_data.get("state", company.state)
        company.city = form_data.get("city", company.city)
        company.pincode = form_data.get("pincode", company.pincode)
        company.gst_number = form_data.get("gst_number", company.gst_number)
        company.bank_name = form_data.get("bank_name", company.bank_name)
        company.account_number = form_data.get("account_no", company.account_number)
        company.branch_code = form_data.get("branch_code", company.branch_code)
        company.branch_location = form_data.get("branch_location", company.branch_location)
        company.branch_ifsc = form_data.get("ifsc", company.branch_ifsc)
        company.upi_id = form_data.get("upi_id", company.upi_id)
        # __S43ZW__ account holder name (shown on customer pay page bank panel)
        try:
            company.account_holder_name = form_data.get(
                "account_holder_name", company.account_holder_name)
        except Exception:
            pass
        company.declaration = form_data.get("declaration", company.declaration)
        company.terms_conditions = form_data.get("terms_conditions", company.terms_conditions)
        # === S41Y-UI-SAVE auto-email toggles ===
        company.auto_email_invoices = 1 if form_data.get("auto_email_invoices") else 0
        company.auto_email_receipts = 1 if form_data.get("auto_email_receipts") else 0
        # _S58AW_  Save Telegram alert credentials (silently no-op if the
        # columns are absent on an older schema — same idiom as the
        # account_holder_name block above).
        try:
            _tg_tok = (form_data.get("telegram_bot_token") or "").strip()
            _tg_cht = (form_data.get("telegram_admin_chat_id") or "").strip()
            if hasattr(company, "telegram_bot_token"):
                company.telegram_bot_token = _tg_tok or None
            if hasattr(company, "telegram_admin_chat_id"):
                company.telegram_admin_chat_id = _tg_cht or None
        except Exception as _te:
            print(f"[profile-update telegram] {_te}")
        
        import os
        import uuid
        from pathlib import Path
        
        qr_code = form_data.get("qr_code")
        if qr_code and hasattr(qr_code, 'filename') and qr_code.filename:
            allowed_extensions = {'.jpg', '.jpeg', '.png', '.webp'}
            file_ext = os.path.splitext(qr_code.filename)[1].lower()
            if file_ext in allowed_extensions:
                upload_dir = Path(f"static/uploads/{company_id}/company")
                upload_dir.mkdir(parents=True, exist_ok=True)
                unique_filename = f"qr-{uuid.uuid4()}{file_ext}"
                file_path = upload_dir / unique_filename
                contents = await qr_code.read()
                if len(contents) <= 2 * 1024 * 1024:  # 2MB limit
                    with open(file_path, "wb") as f:
                        f.write(contents)
                    company.bank_qr_code = str(file_path)
        
        company_logo = form_data.get("company_logo")
        if company_logo and hasattr(company_logo, 'filename') and company_logo.filename:
            allowed_extensions = {'.jpg', '.jpeg', '.png', '.webp'}
            file_ext = os.path.splitext(company_logo.filename)[1].lower()
            if file_ext in allowed_extensions:
                upload_dir = Path(f"static/uploads/{company_id}/company")
                upload_dir.mkdir(parents=True, exist_ok=True)
                unique_filename = f"logo-{uuid.uuid4()}{file_ext}"
                file_path = upload_dir / unique_filename
                contents = await company_logo.read()
                if len(contents) <= 2 * 1024 * 1024:  # 2MB limit
                    with open(file_path, "wb") as f:
                        f.write(contents)
                    company.logo_path = f"/static/uploads/{company_id}/company/{unique_filename}"
        
        profile_image = form_data.get("profile_image")
        if profile_image and hasattr(profile_image, 'filename') and profile_image.filename:
            allowed_extensions = {'.jpg', '.jpeg', '.png', '.webp'}
            file_ext = os.path.splitext(profile_image.filename)[1].lower()
            if file_ext in allowed_extensions:
                upload_dir = Path(f"static/uploads/{company_id}/admins/{user_id}")
                upload_dir.mkdir(parents=True, exist_ok=True)
                unique_filename = f"profile-{uuid.uuid4()}{file_ext}"
                file_path = upload_dir / unique_filename
                contents = await profile_image.read()
                if len(contents) <= 2 * 1024 * 1024:  # 2MB limit
                    with open(file_path, "wb") as f:
                        f.write(contents)
                    if admin:
                        admin.profile_image_path = f"/static/uploads/{company_id}/admins/{user_id}/{unique_filename}"

        # _S39R5U_ — Seal & signature upload (per-admin). PNG preferred so
        # the transparent background sits cleanly above "Authorised
        # Signatory" on every invoice PDF the company emits.
        seal_signature = form_data.get("seal_signature")
        if seal_signature and hasattr(seal_signature, 'filename') and seal_signature.filename:
            allowed_extensions = {'.jpg', '.jpeg', '.png', '.webp'}
            file_ext = os.path.splitext(seal_signature.filename)[1].lower()
            if file_ext in allowed_extensions:
                upload_dir = Path(f"static/uploads/{company_id}/admins/{user_id}")
                upload_dir.mkdir(parents=True, exist_ok=True)
                unique_filename = f"seal-{uuid.uuid4()}{file_ext}"
                file_path = upload_dir / unique_filename
                contents = await seal_signature.read()
                if len(contents) <= 2 * 1024 * 1024:  # 2MB limit
                    with open(file_path, "wb") as f:
                        f.write(contents)
                    if admin:
                        admin.seal_signature_path = (
                            f"/static/uploads/{company_id}/admins/{user_id}/{unique_filename}")
    
    try:
        db.commit()
        return {"success": True, "message": "Profile updated successfully"}
    except Exception as e:
        db.rollback()
        return {"error": str(e)}

@app.post("/api/profile/upload-image")
async def upload_profile_image(request: Request, db: Session = Depends(get_db)):
    """Upload profile image"""
    auth_check = require_auth(request)
    if auth_check:
        return {"error": "Unauthorized"}
    
    user_id = request.session.get("user_id")
    company_id = request.session.get("company_id")
    
    from database import Admin
    import os
    import uuid
    from pathlib import Path
    
    form_data = await request.form()
    profile_image = form_data.get("profile_image")
    
    if not profile_image or not hasattr(profile_image, 'filename'):
        return {"error": "No image file provided"}
    
    # Validate file type
    allowed_extensions = {'.jpg', '.jpeg', '.png', '.webp'}
    file_ext = os.path.splitext(profile_image.filename)[1].lower()
    if file_ext not in allowed_extensions:
        return {"error": "Invalid file type. Only JPG, PNG, and WebP are allowed"}
    
    upload_dir = Path(f"/var/www/autoispbilling/uploads/{company_id}/admins/{user_id}")
    upload_dir.mkdir(parents=True, exist_ok=True)
    
    # Generate unique filename
    unique_filename = f"profile-{uuid.uuid4()}{file_ext}"
    file_path = upload_dir / unique_filename
    
    # Save file
    try:
        contents = await profile_image.read()
        
        if len(contents) > 2 * 1024 * 1024:
            return {"error": "File size must be less than 2MB"}
        
        with open(file_path, "wb") as f:
            f.write(contents)
        
        relative_path = f"/uploads/{company_id}/admins/{user_id}/{unique_filename}"
        admin = db.query(Admin).filter(Admin.admin_id == user_id).first()
        if admin:
            admin.profile_image_path = relative_path
            db.commit()
        
        return {"success": True, "image_path": relative_path}
    except Exception as e:
        return {"error": str(e)}

@app.post("/api/customers/{customer_id}/documents")
async def upload_customer_documents(
    customer_id: str, request: Request, db: Session = Depends(get_db)
):
    """Upload optional customer documents (photograph, address proof, identity proof).

    Accepts a multipart form with up to three files named ``photograph``,
    ``address_proof``, and ``id_proof_doc``. Each file is optional. Returns the
    relative paths that were saved on the customer row.
    """
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}

    company_id = request.session.get("company_id")

    from database import Customer
    import os
    import uuid
    from pathlib import Path

    customer = (
        db.query(Customer)
        .filter(Customer.customer_id == customer_id, Customer.company_id == company_id)
        .first()
    )
    if not customer:
        return {"success": False, "message": "Customer not found"}

    form_data = await request.form()
    allowed_extensions = {".jpg", ".jpeg", ".png", ".webp", ".pdf"}
    max_size = 5 * 1024 * 1024  # 5 MB per file
    upload_dir = Path(
        f"/var/www/autoispbilling/uploads/{company_id}/customers/{customer_id}"
    )
    upload_dir.mkdir(parents=True, exist_ok=True)

    saved: dict = {}
    for field, column in [
        ("photograph", "photograph_path"),
        ("address_proof", "address_proof_path"),
        ("id_proof_doc", "id_proof_doc_path"),
    ]:
        uploaded = form_data.get(field)
        if not uploaded or not hasattr(uploaded, "filename") or not uploaded.filename:
            continue

        file_ext = os.path.splitext(uploaded.filename)[1].lower()
        if file_ext not in allowed_extensions:
            return {
                "success": False,
                "message": f"Invalid file type for {field}. Allowed: JPG, PNG, WebP, PDF",
            }

        contents = await uploaded.read()
        if len(contents) > max_size:
            return {
                "success": False,
                "message": f"{field.replace('_', ' ').title()} must be under 5 MB",
            }

        unique_filename = f"{field}-{uuid.uuid4()}{file_ext}"
        file_path = upload_dir / unique_filename
        try:
            with open(file_path, "wb") as f:
                f.write(contents)
        except Exception as e:
            return {"success": False, "message": f"Failed to save {field}: {e}"}

        relative_path = (
            f"/uploads/{company_id}/customers/{customer_id}/{unique_filename}"
        )
        setattr(customer, column, relative_path)
        saved[column] = relative_path

    if saved:
        db.commit()

    return {"success": True, "uploaded": saved}

@app.post("/api/customers/create")
async def create_customer(request: Request, db: Session = Depends(get_db)):
    """Create new customer"""
    auth_check = require_auth(request)
    if auth_check:
        return {"error": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Customer
    import bcrypt
    import json
    
    try:
        data = await request.json()
        
        # Validate required fields
        required_fields = ['customer_id', 'service_type', 'username', 'name', 'mobile', 'password']
        for field in required_fields:
            if not data.get(field):
                return {"success": False, "message": f"Missing required field: {field}"}
        
        existing = db.query(Customer).filter(Customer.customer_id == data['customer_id']).first()
        if existing:
            return {"success": False, "message": "Customer ID already exists"}
        
        from database import Company, SuperAdminPackage
        company = db.query(Company).filter(Company.company_id == company_id).first()
        if company and company.package:
            pkg = db.query(SuperAdminPackage).filter(SuperAdminPackage.package_name == company.package).first()
            if pkg and pkg.user_count and pkg.user_count > 0:
                current_count = db.query(Customer).filter(
                    Customer.company_id == company_id,
                    (Customer.status == None) | (Customer.status != "Deleted")
                ).count()
                if current_count >= pkg.user_count:
                    return {
                        "success": False,
                        "message": f"User quota exceeded. Your '{company.package}' package allows only {pkg.user_count} customers and you already have {current_count}. Please contact the superadmin to upgrade your package.",
                        "quota_exceeded": True,
                        "current_count": current_count,
                        "user_count": pkg.user_count,
                        "package_name": company.package,
                    }
        
        password_hash = bcrypt.hashpw(data['password'].encode('utf-8'), bcrypt.gensalt()).decode('utf-8')
        
        def parse_float(value):
            # _S39R5_FIX1 — money is integer-only; round half-up (banker's safe at .5)
            if not value or value == '':
                return None
            try:
                clean_value = str(value).replace('₹', '').replace(',', '').strip()
                return int(round(float(clean_value)))
            except Exception:
                return None
        
        def parse_float_geo(value):
            # _S39R5L_GEO — geo coords stored as REAL; -90..90 / -180..180.
            if value is None or value == '' or value == 'null':
                return None
            try:
                f = float(str(value).strip())
                if f != f:  # NaN
                    return None
                return f
            except Exception:
                return None
        def parse_int(value):
            if not value or value == '':
                return None
            try:
                return int(value)
            except:
                return None
        
        customer = Customer(
            company_id=company_id,
            customer_id=data['customer_id'],
            password_hash=password_hash,
            registration_type=data.get('registration_type', 'New Customer'),
            service_type=data['service_type'],
            username=data['username'],
            customer_name=data['name'],
            nickname=data.get('nickname'),
            customer_email=data.get('email'),
            customer_phone=data['mobile'],
            alt_mobile=data.get('alt_mobile'),
            gst_invoice_needed=data.get('gst_invoice_needed', 'NO'),
            customer_gst_no=data.get('customer_gst_no'),
            id_proof=data.get('id_proof'),
            id_proof_no=data.get('id_proof_no'),
            installation_date=data.get('installation_date'),
            address=data.get('address'),
            locality=data.get('locality'),
            city=data.get('city'),
            state=data.get('state'),
            pincode=data.get('pincode'),
            latitude=parse_float_geo(data.get('latitude')),
            longitude=parse_float_geo(data.get('longitude')),
            billing_address=(data.get('billing_address') or None),
            billing_locality=(data.get('billing_locality') or None),
            billing_city=(data.get('billing_city') or None),
            billing_state=(data.get('billing_state') or None),
            billing_pincode=(data.get('billing_pincode') or None),
            photograph_path=(data.get('photograph_path') or None),
            address_proof_path=(data.get('address_proof_path') or None),
            id_proof_doc_path=(data.get('id_proof_doc_path') or None),
            plan_id=parse_int(data.get('plan')),
            dns_profile_id=(parse_int(data.get('dns_profile_id')) or None),
            monthly_amount=parse_float(data.get('monthly_amount')),
            auto_renew=data.get('auto_renew', 'Yes'),
            customer_type=data.get('customer_type', 'Postpaid'),
            caf_no=data.get('caf_no'),
            mac_address=data.get('mac_address'),
            ip_address=data.get('ip_address'),
            # __s56g_persist_nas__ — persist NAS routing choice
            # so RADIUS routes the customer to the picked Mikrotik,
            # not the fallback default NAS. (Bug fix 2026-06-02)
            # _S58BD_NAS_AUTO_  If the form submitted no NAS, fall back
            # to the OLDEST active NAS for this tenant so the customer
            # is always pinned to a real router. Operators wanted the
            # "Any active NAS" mode removed entirely.
            provisioned_nas_id=(parse_int(data.get('provisioned_nas_id'))
                or _s58bd_default_nas_id(db, company_id)),
            vendor=data.get('vendor'),
            modem_no=data.get('modem_no'),
            start_date=data.get('start_date'),
            period=parse_int(data.get('period')),
            end_date=data.get('end_date'),
            bill_amount=parse_float(data.get('bill_amount')),
            cgst_tax=parse_float(data.get('cgst_tax')),
            sgst_tax=parse_float(data.get('sgst_tax')),
            igst_tax=parse_float(data.get('igst_tax')),
            total_bill_amount=parse_float(data.get('total_bill_amount')),
            payment_mode=data.get('payment_mode'),
            received_amount=parse_float(data.get('received_amount')),
            security_deposit=parse_float(data.get('security_deposit')),
            installation_charges=parse_float(data.get('installation_charges')),
            router_charges=parse_float(data.get('router_charges')),
            discount_credit=parse_float(data.get('discount_credit')) or 0.0,
            transaction_id=data.get('transaction_id'),
            payment_notes=data.get('payment_notes'),
            status=(lambda: 'Active' if (
                (parse_float(data.get('received_amount')) or 0) >=
                (parse_float(data.get('total_bill_amount')) or
                 parse_float(data.get('bill_amount')) or 0)
            ) else 'Deactive')(),
            # Session 19 — store raw PPPoE password (cleartext) so FreeRADIUS
            # can authenticate the user immediately on PPPoE dial-in without
            # needing a separate Provision-Customer click. Admin-entered
            # 'password' field doubles as the PPPoE secret.
            pppoe_password=(data.get('password') or '').strip(),
        )
        # Session 18 — multi-scenario auth fields. Only set if the model
        # actually defines them (post-migration). setattr is no-op if the
        # column hasn't been created yet, keeping this code forwards+back
        # compatible.
        for _fname, _src, _default in [
            ("auth_type",               data.get("auth_type"),               "pppoe"),
            ("static_ip_address",       data.get("static_ip_address"),       ""),
            ("static_netmask",          data.get("static_netmask"),          "255.255.255.0"),
            ("mac_address",             data.get("mac_address"),             ""),
            ("hotspot_session_timeout", data.get("hotspot_session_timeout"), 0),
            ("hotspot_idle_timeout",    data.get("hotspot_idle_timeout"),    600),
        ]:
            if hasattr(customer, _fname):
                try:
                    val = _src if (_src not in (None, "")) else _default
                    if _fname in ("hotspot_session_timeout", "hotspot_idle_timeout"):
                        val = int(val or 0)
                    setattr(customer, _fname, val)
                except Exception:
                    pass
        
        # v11 — when an Employee (not Admin/Sub-LCO) creates a customer,
        # auto-stamp sub_lco_id + locality from the employee's context so
        # (a) the new customer immediately appears in the employee's listing,
        # (b) the implicit SELECT in db.refresh() doesn't get filtered out.
        try:
            from employee_scope import _EMP_SLCO_CTX, _EMP_LOC_CTX, _UNSET
            _emp_slco = _EMP_SLCO_CTX.get()
            _emp_locs = _EMP_LOC_CTX.get()
            if _emp_locs is not None:  # Employee request context
                if _emp_slco is not _UNSET and _emp_slco is not None:
                    if not getattr(customer, "sub_lco_id", None):
                        customer.sub_lco_id = int(_emp_slco)
                # Stamp locality from employee's allowed list when client
                # didn't pick one or picked an out-of-scope one.
                if _emp_locs:
                    cur = (customer.locality or "").strip().upper()
                    if not cur or cur not in {n.upper() for n in _emp_locs}:
                        customer.locality = _emp_locs[0]
        except Exception as _ee:
            print(f"[create_customer emp-stamp] {_ee}")

        db.add(customer)
        # S42T-AUDIT-CREATOR: stamp the actual creator (admin/sub-LCO/
        # employee) BEFORE first commit so SQL trigger / refresh sees it.
        try:
            _sess = request.session
            _role = (_sess.get("user_type") or "").lower()
            _name = _sess.get("user_name") or _sess.get("name") or ""
            _spk  = _sess.get("user_pk")
            customer.created_by = _name or _role or "System"
            customer.created_by_role = _role or "admin"
            if _role == "sub_lco" and _spk:
                customer.created_by_sub_lco_id = int(_spk)
            elif _role == "employee" and _spk:
                customer.created_by_employee_id = int(_spk)
                # Also stamp the parent sub-LCO if any.
                try:
                    from database import Employee as _Emp
                    _e = db.query(_Emp).filter(_Emp.id == int(_spk)).first()
                    if _e and getattr(_e, "sub_lco_id", None):
                        customer.created_by_sub_lco_id = int(_e.sub_lco_id)
                except Exception:
                    pass
        except Exception as _ce:
            print(f"[create_customer s42t] {_ce}")
        db.commit()
        # v11 — bypass the employee scope-filter for the post-commit
        # refresh (it would otherwise re-apply the locality / sub_lco
        # WHERE clause and find nothing).
        try:
            db.refresh(customer)
        except Exception as _re:
            # Fall back: manually re-load via raw SQL into the instance.
            from sqlalchemy import text as _t_re
            print(f"[create_customer] refresh blocked by scope filter: {_re}")
            row = db.execute(_t_re(
                "SELECT id FROM customers WHERE customer_id = :cid LIMIT 1"
            ), {"cid": customer.customer_id}).fetchone()
            if row:
                customer.id = row[0]
        
        # _v466_GEOCODE_FALLBACK — when the form supplies an address but no
        # GPS lat/lng, geocode the address via Nominatim. Saves the result so
        # subsequent ONU assignment can attach to the same coords.
        try:
            if (customer.latitude in (None, "", 0) or
                customer.longitude in (None, "", 0)):
                addr_parts = [
                    str(customer.installation_address or "").strip(),
                    str(customer.locality or "").strip(),
                    str(customer.city or "").strip(),
                    str(customer.state or "").strip(),
                    str(customer.pincode or "").strip(),
                    "India",
                ]
                addr_q = ", ".join([p for p in addr_parts if p])
                if addr_q and len(addr_q) > 12:
                    import urllib.request, urllib.parse, json as _json
                    url = (
                        "https://nominatim.openstreetmap.org/search?"
                        + urllib.parse.urlencode({
                            "q": addr_q, "format": "json", "limit": 1,
                            "addressdetails": 0, "countrycodes": "in",
                        })
                    )
                    req = urllib.request.Request(url, headers={
                        "User-Agent": "AutoISPBilling/4.6 (geocoder)",
                    })
                    try:
                        with urllib.request.urlopen(req, timeout=4) as rr:
                            data = _json.loads(rr.read())
                        if data and isinstance(data, list):
                            customer.latitude  = float(data[0]["lat"])
                            customer.longitude = float(data[0]["lon"])
                            db.add(customer); db.commit()
                            print(f"[create_customer] geocoded address → {customer.latitude},{customer.longitude}")
                    except Exception as _ge:
                        print(f"[create_customer] geocode failed (non-fatal): {_ge}")
        except Exception as _ge2:
            print(f"[create_customer] geocode block error: {_ge2}")

        # _v4733_LATLNG_CREATE_MIRROR  Mirror to legacy lat/lng columns
        # so the mobile API "use_customer_address" feature finds them.
        try:
            from sqlalchemy import text as _t_lc
            if (getattr(customer, 'latitude', None) is not None
                and getattr(customer, 'longitude', None) is not None):
                db.execute(_t_lc(
                    "UPDATE customers SET lat=:la, lng=:ln "
                    " WHERE company_id=:cid AND customer_id=:cust"
                ), {"la": float(customer.latitude),
                    "ln": float(customer.longitude),
                    "cid": company_id,
                    "cust": customer.customer_id})
                db.commit()
        except Exception as _lec:
            print(f"[create_customer] lat/lng mirror failed (non-fatal): {_lec}")
        # _v4732_  Auto-place ONU pin via the shared helper (no-op
        # silently when the customer has no installation lat/lng OR no
        # modem/MAC to identify the physical ONU).
        _v4732_attach_onu_pin(db, customer, company_id,
                              created_by=(data.get('created_by') or 'admin'))
        # S42S-NO-FAKE-ONU: the legacy `_v463_AUTOPLACE_ONU_MAP_PIN`
        # fallback that created a synthetic `network_hardware` ONU row
        # whenever a customer had lat/lng (but no real device) is
        # REMOVED. From now on the customer pin is shown by itself; an
        # ONU/ONT pin is created on the network map ONLY when the
        # operator binds a real modem_no / MAC (handled by
        # `_v4732_attach_onu_pin` above).

        caf_pdf_data = None
        # _BUG8_EXISTING_NOINVOICE_ : skip the entire invoice block
        # for non-New customers (migrated/existing/bulk-import).
        _reg_type_norm = (customer.registration_type or "New Customer").strip().lower()
        _skip_invoice = (_reg_type_norm not in ("new customer",))
        if _skip_invoice:
            print(f"[bug8] skipping invoice generation for "
                   f"existing/migrated customer {customer.customer_id} "
                   f"(registration_type={customer.registration_type!r})")
        
        try:
            if _skip_invoice: raise _ESkipInv("skip")
            from database import Company, Plan, Invoice, Transaction, Payment, ReceivedTracker
            from datetime import timedelta
            import os
            
            company = db.query(Company).filter(Company.company_id == company_id).first()
            plan = db.query(Plan).filter(Plan.id == customer.plan_id).first() if customer.plan_id else None
            plan_name = plan.plan_name if plan else 'Broadband'
            
            is_postpaid = (customer.customer_type or 'PREPAID').upper() == 'POSTPAID'
            is_first_invoice = True  # Always true for new customer
            
            invoice_no = generate_invoice_number(company_id, db)
            issue_date = datetime.now()
            due_date = issue_date + timedelta(days=7)
            
            period_months = customer.period or 1
            
            security_deposit = customer.security_deposit or 0
            installation_charges = customer.installation_charges or 0
            router_charges = customer.router_charges or 0
            discount_credit = customer.discount_credit or 0
            
            line_items = []
            
            if is_postpaid and is_first_invoice:
                base_amount = customer.bill_amount or 0
                
                # _S39R5FIX11_ — tax decided by BILLING state, not installation state
                tax_breakdown = compute_tax_breakdown(
                    company.state if company else '',
                    (customer.billing_state or customer.state or ''),
                    base_amount,
                    cgst_rate=(plan.cgst_tax if plan else None),
                    sgst_rate=(plan.sgst_tax if plan else None),
                    igst_rate=(plan.igst_tax if plan else None),
                )
                cgst_tax = tax_breakdown['cgst_tax']
                sgst_tax = tax_breakdown['sgst_tax']
                igst_tax = tax_breakdown['igst_tax']
                plan_total = tax_breakdown['total_amount']
                
                line_items.append({
                    'description': f"{plan_name.upper()}\nPlan Security",
                    'hsn_sac': '998422',
                    'quantity': '1 nos',
                    'rate': int(base_amount),
                    'amount': int(plan_total)
                })
                
                if installation_charges > 0:
                    line_items.append({
                        'description': 'Installation Charges',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': int(installation_charges),
                        'amount': int(installation_charges)
                    })
                
                if router_charges > 0:
                    line_items.append({
                        'description': 'STB/MODEM/Router Deposit',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': int(router_charges),
                        'amount': int(router_charges)
                    })
                
                if security_deposit > 0:
                    line_items.append({
                        'description': 'Security Deposit',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': int(security_deposit),
                        'amount': int(security_deposit)
                    })
                
                if discount_credit > 0:
                    line_items.append({
                        'description': 'Discount',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': -int(discount_credit),
                        'amount': -int(discount_credit)
                    })
                
                total_amount = plan_total + installation_charges + router_charges + security_deposit - discount_credit
                
            else:
                base_amount = customer.bill_amount or 0
                
                # _S39R5FIX11_ — tax decided by BILLING state, not installation state
                tax_breakdown = compute_tax_breakdown(
                    company.state if company else '',
                    (customer.billing_state or customer.state or ''),
                    base_amount,
                    cgst_rate=(plan.cgst_tax if plan else None),
                    sgst_rate=(plan.sgst_tax if plan else None),
                    igst_rate=(plan.igst_tax if plan else None),
                )
                
                cgst_tax = tax_breakdown['cgst_tax']
                sgst_tax = tax_breakdown['sgst_tax']
                igst_tax = tax_breakdown['igst_tax']
                plan_total = tax_breakdown['total_amount']
                
                start_date_formatted = format_date_ddmmyyyy(customer.start_date) if customer.start_date else ''
                end_date_formatted = format_date_ddmmyyyy(customer.end_date) if customer.end_date else ''
                if start_date_formatted and end_date_formatted:
                    period_description = f"{plan_name.upper()}\nPERIOD {start_date_formatted} TO {end_date_formatted}"
                else:
                    period_description = f"{plan_name.upper()}\nPERIOD {period_months} Month(s)"
                
                line_items.append({
                    'description': period_description,
                    'hsn_sac': '998422',
                    'quantity': '1 nos',
                    'rate': int(base_amount),
                    'amount': int(plan_total)
                })
                
                if installation_charges > 0:
                    line_items.append({
                        'description': 'Installation Charges',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': int(installation_charges),
                        'amount': int(installation_charges)
                    })
                
                if security_deposit > 0:
                    line_items.append({
                        'description': 'Security Deposit',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': int(security_deposit),
                        'amount': int(security_deposit)
                    })
                
                if router_charges > 0:
                    line_items.append({
                        'description': 'STB/MODEM/Router Deposit',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': int(router_charges),
                        'amount': int(router_charges)
                    })
                
                if discount_credit > 0:
                    line_items.append({
                        'description': 'Discount',
                        'hsn_sac': '998422',
                        'quantity': '1 nos',
                        'rate': -int(discount_credit),
                        'amount': -int(discount_credit)
                    })
                
                total_amount = plan_total + installation_charges + router_charges + security_deposit - discount_credit
            
            payment_received = customer.received_amount or 0
            if payment_received >= total_amount:
                invoice_status = 'paid'
            elif payment_received > 0:
                invoice_status = 'partial'
            else:
                invoice_status = 'generated'
            
            invoice = Invoice(
                company_id=company_id,
                customer_id=customer.customer_id,
                invoice_no=invoice_no,
                issue_date=issue_date.strftime('%Y-%m-%d'),
                due_date=due_date.strftime('%Y-%m-%d'),
                start_date=customer.start_date or issue_date.strftime('%Y-%m-%d'),
                end_date=customer.end_date or due_date.strftime('%Y-%m-%d'),
                period_months=period_months if not (is_postpaid and is_first_invoice) else 0,
                plan_id=customer.plan_id,
                plan_name=plan_name,
                base_amount=base_amount,
                cgst_tax=cgst_tax,
                sgst_tax=sgst_tax,
                igst_tax=igst_tax,
                total_amount=total_amount,
                status=invoice_status
            )
            
            try:
            
                invoice.has_gst_no = bool(
            
                    str(getattr(customer, 'customer_gst_no', '') or '').strip()
            
                    and str(getattr(customer, 'gst_invoice_needed', '') or '').upper() == 'YES'
            
                )
            
            except Exception:
            
                pass
            db.add(invoice)
            db.flush()
            # __MSG91_HOOK_INVOICE__  customer-renewal flow
            try:
                from msg91_hooks import notify_invoice_generated as _mh_ni
                _mh_ni(invoice, customer, company)
            except Exception as _mh_e:
                print(f"[msg91 invoice hook] {_mh_e}")
            
            print(f"✓ Invoice created: {invoice_no} (Type: {'POSTPAID' if is_postpaid else 'PREPAID'}, First: {is_first_invoice}, Total: ₹{total_amount}, Status: {invoice_status})")
            
            invoice_data = {
                'invoice_no': invoice_no,
                'issue_date': invoice.issue_date,
                'due_date': invoice.due_date,
                'start_date': invoice.start_date,
                'end_date': invoice.end_date,
                'plan_name': plan_name,
                'period_months': period_months if not (is_postpaid and is_first_invoice) else 0,
                'base_amount': base_amount,
                'cgst_tax': cgst_tax,
                'sgst_tax': sgst_tax,
                'igst_tax': igst_tax,
                'total_amount': total_amount,
                'customer_name': customer.customer_name,
                'prev_due_total': 0,
                'line_items': line_items,
                'payment_received': payment_received,
                'is_first_invoice': is_first_invoice,
                'is_postpaid': is_postpaid
            }
            
            company_data = {
                'company_name': company.company_name if company else 'AUTO ISP BILLING',
                'company_address': company.company_address if company else '',
                'company_phone': company.company_phone if company else '',
                'company_email': company.company_email if company else '',
                'state': company.state if company else '',
                'gst_number': company.gst_number if company else '',
                'bank_name': company.bank_name if company else '',
                'account_number': company.account_number if company else '',
                'branch_ifsc': company.branch_ifsc if company else '',
                'upi_id': company.upi_id if company else '',
                'declaration': company.declaration if company else 'Thanks for your business. Hope you are enjoying our services.',
                'terms_conditions': company.terms_conditions if company else 'Payment is due within 7 days of invoice date.',
                'smtp_server': company.smtp_server if company else '',
                'smtp_port': company.smtp_port if company else 587,
                'smtp_username': company.smtp_username if company else '',
                'smtp_password': company.smtp_password if company else '',
                'bank_qr_code': getattr(company, 'bank_qr_code', None) if company else None
            }
            
            customer_data = {
                'customer_name': customer.customer_name,
                'username': customer.username,
                'address': customer.address or '',
                'customer_gst_no': customer.customer_gst_no or '',
                'state': customer.state or '',
                # _S39R5FIX11d_ — billing-side overrides for tax + PDF
                'billing_address': customer.billing_address or '',
                'billing_state': customer.billing_state or '',
                'city': customer.city or '',
                'mobile': customer.customer_phone or '',
                'billing_type': customer.customer_type or 'PREPAID',
                'category': customer.service_type or 'Broadband',
                'gst_invoice_needed': customer.gst_invoice_needed or 'No'
            }
            
            pdf_data = generate_invoice_pdf(invoice_data, company_data, customer_data, [])
            
            pdf_dir = f"/var/lib/autoispbilling/invoices/{company_id}"
            os.makedirs(pdf_dir, exist_ok=True)
            pdf_path = f"{pdf_dir}/{invoice_no}.pdf"
            
            with open(pdf_path, 'wb') as f:
                f.write(pdf_data)
            
            invoice.pdf_path = pdf_path
            
            all_unpaid_invoices = db.query(Invoice).filter(
                Invoice.company_id == company_id,
                Invoice.customer_id == customer.customer_id,
                Invoice.status.in_(['generated', 'overdue', 'partial'])
            ).all()
            
            total_due = sum(inv.total_amount for inv in all_unpaid_invoices)
            customer.total_bill_amount = total_due
            
            # DO NOT zero out security_deposit, installation_charges, router_charges
            
            transaction = Transaction(
                company_id=company_id,
                customer_id=customer.customer_id,
                transaction_type='renewal',
                amount=total_amount,
                invoice_id=invoice.id,
                start_date=invoice.start_date,
                end_date=invoice.end_date,
                period_months=period_months if not (is_postpaid and is_first_invoice) else 0,
                remarks=f"Initial invoice for {period_months} month(s)" if not (is_postpaid and is_first_invoice) else "Initial invoice - Plan Security for Postpaid Users"
            )
            db.add(transaction)
            db.commit()
            
            print(f"✓ Invoice created: {invoice_no} for ₹{total_amount}")
            
            if customer.received_amount and customer.received_amount > 0:
                try:
                    payment_mode = customer.payment_mode or 'Cash'
                    transaction_no = generate_transaction_no(payment_mode, db)
                    
                    # Initial payment recorded at customer registration.
                    # Resolve the actual session actor — for sub-LCO sessions this
                    # is the SLCO code, for employee sessions the EMP code, for
                    # admins the admin_id. Falls back to ADMIN001 only as last
                    # resort. (Session 38u.2 fix.)
                    _actor_eid = (
                        (request.session.get("sub_lco_code")
                         if request.session.get("user_type") == "sub_lco" else None)
                        or (request.session.get("employee_code")
                            if request.session.get("user_type") == "employee" else None)
                        or request.session.get("user_id")
                        or request.session.get("admin_id")
                        or "ADMIN001"
                    )
                    payment = Payment(
                        company_id=company_id,
                        customer_id=customer.customer_id,
                        employee_id=_actor_eid,
                        amount=customer.received_amount,
                        discount=0.0,
                        payment_mode=payment_mode,
                        transaction_no=transaction_no,
                        paid_at=datetime.utcnow(),
                        remarks=customer.payment_notes or "Initial payment at customer registration"
                    )
                    db.add(payment)
                    db.flush()
                    
                    received_tracker = db.query(ReceivedTracker).filter(
                        ReceivedTracker.company_id == company_id,
                        ReceivedTracker.customer_id == customer.customer_id
                    ).first()
                    
                    if received_tracker:
                        received_tracker.received_since_reset += customer.received_amount
                        received_tracker.updated_at = datetime.utcnow()
                    else:
                        received_tracker = ReceivedTracker(
                            company_id=company_id,
                            customer_id=customer.customer_id,
                            received_since_reset=customer.received_amount,
                            last_reset_at=datetime.utcnow(),
                            updated_at=datetime.utcnow()
                        )
                        db.add(received_tracker)
                    
                    db.commit()
                    print(f"✓ Payment created: {transaction_no} for ₹{customer.received_amount}")
                    # _v4727_  Auto-email receipt DISABLED — operator
                    # explicitly requested manual share/send only.
                    # try:
                    #     await _send_receipt_email_for_payment(payment.id, company_id, db)
                    # except Exception as _eRcpt2:
                    #     print(f"[receipt-email auto-init] payment#{payment.id}: {_eRcpt2}")
                except Exception as payment_error:
                    print(f"Failed to create payment: {str(payment_error)}")
                    db.rollback()
            
            reg_type = (customer.registration_type or 'New Customer').strip().lower()
            # === S41Y-GATE-ADDCUST ===
            _co_email_flag = 1
            try:
                _co_email_flag = int(getattr(company, 'auto_email_invoices', 1) or 0)
            except Exception:
                _co_email_flag = 1
            if customer.customer_email and reg_type == 'new customer' and _co_email_flag:
                try:
                    email_result = await send_invoice_email(invoice_data, customer.customer_email, company_data, pdf_data, customer.customer_type or 'PREPAID')
                    if email_result and email_result.get('success'):
                        print(f"✓ Invoice email sent to {customer.customer_email}")
                    else:
                        print(f"✗ Failed to send invoice email: {email_result.get('message', 'Unknown error') if email_result else 'No result returned'}")
                except Exception as email_error:
                    print(f"✗ Exception sending invoice email: {str(email_error)}")
                    import traceback
                    traceback.print_exc()
            elif customer.customer_email:
                print(f"⊘ Invoice email skipped for migrated customer (registration_type={customer.registration_type!r}, customer_id={customer.customer_id}, email={customer.customer_email})")
            else:
                print(f"⊘ No email address provided for customer {customer.customer_id}")
            # _S58AW_WELCOME_HOOK_ — fire one-time welcome email with
            # credentials + invoice PDF. Best-effort, never throws.
            if (customer.customer_email and reg_type == 'new customer'
                and _co_email_flag):
                try:
                    await s58aw_send_welcome_email(
                        customer, company, plan_name,
                        raw_password=data.get('password') or '',
                        invoice_pdf=(pdf_data or b''),
                    )
                except Exception as _wee:
                    print(f"[welcome-email hook] {_wee}")
            
            caf_customer_data = {
                'caf_no': customer.caf_no or '',
                'customer_id': customer.customer_id or '',
                'installation_date': customer.installation_date or '',
                'customer_name': customer.customer_name or '',
                'username': customer.username or '',
                'customer_email': customer.customer_email or '',
                'customer_phone': customer.customer_phone or '',
                'alt_mobile': customer.alt_mobile or '',
                'id_proof': customer.id_proof or '',
                'id_proof_no': customer.id_proof_no or '',
                'address': customer.address or '',
                'locality': customer.locality or '',
                'city': customer.city or '',
                'state': customer.state or '',
                'pincode': customer.pincode or '',
                'service_type': customer.service_type or '',
                'plan_name': plan_name or '',
                'customer_type': customer.customer_type or '',
                'monthly_amount': customer.monthly_amount or 0,
                'start_date': customer.start_date or '',
                'end_date': customer.end_date or '',
                'mac_address': customer.mac_address or '',
                'ip_address': customer.ip_address or '',
                # Session 22 — image paths + billing address for CAF layout
                'photograph_path': customer.photograph_path or '',
                'id_proof_doc_path': customer.id_proof_doc_path or '',
                'address_proof_path': customer.address_proof_path or '',
                'billing_address': customer.billing_address or '',
                'billing_locality': customer.billing_locality or '',
                'billing_city': customer.billing_city or '',
                'billing_state': customer.billing_state or '',
                'billing_pincode': customer.billing_pincode or '',
            }
            
            caf_pdf_data = generate_caf_pdf(caf_customer_data, company_data)
            
            customer.caf_pdf = caf_pdf_data
            db.commit()
        
        except Exception as invoice_error:
            print(f"Failed to generate/send invoice/CAF: {str(invoice_error)}")

        # __S38T_TRUE_STATIC_IP__ — provision pure static-IP binding on the
        # tenant's Mikrotik NAS devices so the new customer gets internet
        # WITHOUT needing to dial PPPoE. No-op for pppoe/hotspot customers.
        try:
            _enforce_user_state(db, customer, force_radius_restart=True)
        except Exception as _sip_err:
            print(f"[warn] create static-ip enforce failed: {_sip_err}")

        # _S40b_ — TR-069 auto-push on customer CREATE
        # Safety net: if any ONU is already bound to this customer
        # (rare but possible if the ONU was pre-assigned via /api/admin/olt/onus
        #  PATCH before the customer record was finalised), push the new
        # PPPoE creds immediately to avoid the next install visit.
        try:
            from olt_routes import _genieacs_auto_push as _gap, engine as _olt_eng
            with _olt_eng.begin() as _c:
                _onus = _c.exec_driver_sql(
                    "SELECT id FROM onus WHERE company_id=? AND customer_id=?",
                    (company_id, data['customer_id'])).fetchall()
            for (_oid,) in _onus:
                try:
                    _gap(company_id, _oid, reason="customer create")
                except Exception:
                    pass
        except Exception as _e:
            print(f"[create_customer] tr069 push skipped: {_e}")

        # _S40zκ_ Auto-geocode address → ONU pin (Phase 2.6 Method B).
        # Runs in background thread to avoid blocking the response.
        try:
            import threading as _thr
            def _geo_async(cust_id, comp_id):
                from database import SessionLocal as _SL, Customer as _C
                from phase26_geolocation import _geocode_customer, _propagate_to_onu
                _db = _SL()
                try:
                    cust = _db.query(_C).filter(_C.customer_id == cust_id,
                                                 _C.company_id == comp_id).first()
                    if cust:
                        r = _geocode_customer(_db, cust, force=False)
                        if r.get("success") and not r.get("skipped"):
                            _propagate_to_onu(_db, cust_id, comp_id)
                finally:
                    _db.close()
            _thr.Thread(target=_geo_async,
                        args=(data['customer_id'], company_id), daemon=True).start()
        except Exception as _e:
            print(f"[create_customer] geocode skipped: {_e}")

                # __s55s_vlan_create_hook__ — additive VLAN binding
        try:
            _vlan_en = 1 if str(data.get("vlan_enabled", "")).strip().lower() in ("1","true","on","yes") else 0
            _vlan_id = data.get("vlan_id")
            if _vlan_en and _vlan_id:
                _vlan_id = int(_vlan_id)
                from sqlalchemy import text as _t
                # Atomically claim the VLAN in vlan_pool
                _ok = db.execute(_t(
                    "UPDATE vlan_pool SET state='assigned', customer_id=:cid, "
                    "assigned_at=:now, assigned_by=:by "
                    "WHERE company_id=:c AND vlan_id=:v AND state='free'"
                ), {"cid": customer.id, "now": datetime.utcnow().isoformat(),
                    "by": request.session.get("user_id"),
                    "c": company_id, "v": _vlan_id}).rowcount
                if _ok:
                    customer.vlan_enabled = 1
                    customer.vlan_id = _vlan_id
                    db.add(customer); db.commit()
                else:
                    customer.vlan_enabled = 0
                    customer.vlan_id = None
                    db.add(customer); db.commit()
        except Exception as _ve:
            db.rollback()
            print(f"[create_customer vlan-hook] {_ve}")

        return {"success": True, "message": "Customer created successfully", "customer_id": data['customer_id']}
    
    except Exception as e:
        db.rollback()
        return {"success": False, "message": str(e)}

@app.get("/admin/add-customer", response_class=HTMLResponse)
async def add_customer(request: Request, db: Session = Depends(get_db)):
    """Unified add customer page.

    S42Q-ADDCUST-OPEN: this page is the single Add-Customer entry
    point for admin, sub-LCO and employee (mobile WebView uses the
    same URL via SSO). Use `require_auth` so non-admins can render;
    POST `/api/customers/create` already enforces tenant scope via
    session.
    """
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    
    context = get_admin_context(request, db, "users")
    return templates.TemplateResponse("add_customer.html", context)

@app.get("/api/customers/check-username")
async def check_username(username: str, request: Request, db: Session = Depends(get_db)):
    """Check if username already exists for the company"""
    auth_check = require_auth(request)
    if auth_check:
        return {"exists": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Customer
    
    try:
        existing_customer = db.query(Customer).filter(
            Customer.username == username,
            Customer.company_id == company_id
        ).first()
        
        return {"exists": existing_customer is not None}
    
    except Exception as e:
        print(f"Error checking username: {str(e)}")
        return {"exists": False, "error": str(e)}

@app.get("/api/customers/deleted")
async def get_deleted_customers(request: Request, db: Session = Depends(get_db)):
    """Get list of deleted customers"""
    import sys
    print("=" * 80, file=sys.stderr, flush=True)
    print("DELETED CUSTOMERS ENDPOINT CALLED", file=sys.stderr, flush=True)
    print("=" * 80, file=sys.stderr, flush=True)
    
    auth_check = require_auth(request)
    if auth_check:
        print("AUTH CHECK FAILED", file=sys.stderr, flush=True)
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    print(f"COMPANY ID: {company_id}", file=sys.stderr, flush=True)
    
    from database import Customer
    
    try:
        deleted_customers = db.query(Customer).filter(
            Customer.company_id == company_id,
            Customer.status == "Deleted"
        ).all()
        
        print(f"DEBUG: Deleted customers query - company_id={company_id}, count={len(deleted_customers)}")
        
        customers_list = []
        for customer in deleted_customers:
            try:
                balance = calculate_total_due(customer, db)
            except Exception as e:
                print(f"DEBUG: Error calculating balance for {customer.customer_id}: {str(e)}")
                balance = '₹0'
            
            customers_list.append({
                'cust_id': customer.customer_id,
                'cust_name': customer.customer_name,
                'mobile': customer.customer_phone,
                'address': customer.address or '',
                'plan': customer.plan_id,
                'amount': float(customer.monthly_amount) if customer.monthly_amount else 0,
                'balance': balance,
                'exp_date': customer.end_date or 'N/A'
            })
        
        print(f"DEBUG: Returning {len(customers_list)} deleted customers")
        
        return {
            "success": True,
            "customers": customers_list
        }
    
    except Exception as e:
        print(f"DEBUG: Error in get_deleted_customers: {str(e)}")
        import traceback
        traceback.print_exc()
        return {"success": False, "message": str(e)}

@app.post("/api/customers/{customer_id}/restore")
async def restore_customer(customer_id: str, request: Request, db: Session = Depends(get_db), _ = Depends(require_not_employee)):
    """Restore a deleted customer"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Customer
    
    try:
        customer = db.query(Customer).filter(
            Customer.customer_id == customer_id,
            Customer.company_id == company_id
        ).first()
        
        if not customer:
            return {"success": False, "message": "Customer not found"}
        
        if customer.status != "Deleted":
            return {"success": False, "message": "Customer is not deleted"}
        
        # Restore customer by setting status to Deactive
        customer.status = "Deactive"
        db.commit()
        # s36b5: unified-disconnect – the restored account should not have
        # any live session. Kick + keep secret disabled.
        try:
            _enforce_user_state(db, customer)
        except Exception as _e:
            print(f"[warn] restore enforce: {_e}")
        
        return {
            "success": True,
            "message": f"Customer {customer.customer_name} has been restored successfully"
        }
    
    except Exception as e:
        db.rollback()
        return {"success": False, "message": f"Error restoring customer: {str(e)}"}

@app.delete("/api/customers/{customer_id}/permanent")
async def permanent_delete_customer(customer_id: str, request: Request, db: Session = Depends(get_db), _ = Depends(require_not_employee)):
    """Permanently delete a customer from the database (cannot be undone)"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Customer
    
    try:
        customer = db.query(Customer).filter(
            Customer.customer_id == customer_id,
            Customer.company_id == company_id,
            Customer.status == "Deleted"
        ).first()
        
        if not customer:
            return {"success": False, "message": "Deleted customer not found. Only deleted customers can be permanently removed."}
        
        customer_name = customer.customer_name
        
        db.delete(customer)
        db.commit()
        
        return {
            "success": True,
            "message": f"Customer {customer_name} (ID: {customer_id}) has been permanently deleted from the database"
        }
    
    except Exception as e:
        db.rollback()
        return {"success": False, "message": f"Error permanently deleting customer: {str(e)}"}
@app.get("/api/customers/{customer_id}")
async def get_customer(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Get customer data by ID"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Customer, Plan
    
    try:
        customer = db.query(Customer).filter(
            Customer.customer_id == customer_id,
            Customer.company_id == company_id
        ).first()
        
        if not customer:
            return {"success": False, "message": "Customer not found"}
        
        plan_name = None
        if customer.plan_id:
            plan = db.query(Plan).filter(
                Plan.id == customer.plan_id,
                Plan.company_id == company_id
            ).first()
            if plan:
                plan_name = plan.plan_name
        
        customer_data = {
            # __S38U7__ expose DB pk + billing fields for the Edit modal
            "id": customer.id,
            "pk": customer.id,
            "billing_address": customer.billing_address or "",
            "billing_locality": getattr(customer, "billing_locality", "") or "",
            "billing_state": getattr(customer, "billing_state", "") or "",
            "billing_city": getattr(customer, "billing_city", "") or "",
            "billing_pincode": getattr(customer, "billing_pincode", "") or "",
            # _v4733_  Expose installation lat/lng so the Edit modal
            # can pre-fill them after save (was returning nothing).
            "latitude":  customer.latitude,
            "longitude": customer.longitude,
            "lat":       getattr(customer, "lat", None),
            "lng":       getattr(customer, "lng", None),
            "customer_id": customer.customer_id,
            "service_type": customer.service_type,
            "username": customer.username,
            "customer_name": customer.customer_name,
            "customer_email": customer.customer_email,
            "customer_phone": customer.customer_phone,
            "alt_mobile": customer.alt_mobile,
            "gst_invoice_needed": customer.gst_invoice_needed,
            "customer_gst_no": customer.customer_gst_no,
            "id_proof": customer.id_proof,
            "id_proof_no": customer.id_proof_no,
            "installation_date": customer.installation_date,
            "address": customer.address,
            "locality": customer.locality,
            "state": customer.state,
            "city": customer.city,
            "pincode": customer.pincode,
            "plan_id": customer.plan_id,
            "plan_name": plan_name,
            "dns_profile_id": getattr(customer, "dns_profile_id", None),
            # __s56g_get_nas__ — expose chosen NAS so the Edit modal
            # can pre-select the dropdown. (Bug fix 2026-06-02)
            "provisioned_nas_id": getattr(customer, "provisioned_nas_id", None),
            "monthly_amount": float(customer.monthly_amount) if customer.monthly_amount is not None else None,
            "auto_renew": customer.auto_renew,
            "customer_type": customer.customer_type,
            "caf_no": customer.caf_no,
            "mac_address": customer.mac_address,
            "ip_address": customer.ip_address,
            "vendor": customer.vendor,
            "modem_no": customer.modem_no,
            "start_date": customer.start_date,
            "period": customer.period,
            "end_date": customer.end_date,
            "bill_amount": float(customer.bill_amount) if customer.bill_amount is not None else None,
            "cgst_tax": float(customer.cgst_tax) if customer.cgst_tax is not None else None,
            "sgst_tax": float(customer.sgst_tax) if customer.sgst_tax is not None else None,
            "igst_tax": float(customer.igst_tax) if customer.igst_tax is not None else None,
            "total_bill_amount": float(customer.total_bill_amount) if customer.total_bill_amount is not None else None,
            "security_deposit": float(customer.security_deposit) if customer.security_deposit is not None else None,
            "installation_charges": float(customer.installation_charges) if customer.installation_charges is not None else None,
            "received_amount": float(customer.received_amount) if customer.received_amount is not None else None,
            "router_charges": float(customer.router_charges) if customer.router_charges is not None else None,
            "discount_credit": float(customer.discount_credit) if customer.discount_credit is not None else 0.0,
            "payment_mode": customer.payment_mode,
            "transaction_id": customer.transaction_id,
            "payment_notes": customer.payment_notes,
            "status": customer.status,
            # s36b6b: wire auth fields — expose for Edit popup
            "auth_type": getattr(customer, "auth_type", "pppoe") or "pppoe",
            "static_ip_address": getattr(customer, "static_ip_address", "") or "",
            "static_netmask": getattr(customer, "static_netmask", "255.255.255.0") or "255.255.255.0",
            "hotspot_session_timeout": getattr(customer, "hotspot_session_timeout", 0) or 0,
            "hotspot_idle_timeout": getattr(customer, "hotspot_idle_timeout", 600) or 600,
            # __s56AH_edit_vlan_response__ — expose VLAN to the Edit modal
            "vlan_enabled": int(getattr(customer, "vlan_enabled", 0) or 0),
            "vlan_id": getattr(customer, "vlan_id", None),
        }

        # __s56AH_edit_vlan_response__ — back-fill from vlan_pool when
        # customers row was never updated (the older bulk-assign API).
        if not customer_data.get("vlan_id"):
            try:
                from sqlalchemy import text as _vt
                _vrow = db.execute(_vt(
                    "SELECT vlan_id FROM vlan_pool "
                    "WHERE company_id=:c AND customer_id=:cid AND state='assigned' LIMIT 1"),
                    {"c": customer.company_id, "cid": customer.id}).fetchone()
                if _vrow and _vrow[0]:
                    customer_data["vlan_id"] = int(_vrow[0])
                    customer_data["vlan_enabled"] = 1
            except Exception as _ve:
                print(f"[get_customer vlan-enrich] {_ve}")

        previous_due = calculate_total_due(customer, db)
        customer_data["previous_due"] = previous_due
        
        return {"success": True, "customer": customer_data}
    
    except Exception as e:
        return {"success": False, "message": str(e)}

@app.get("/api/customers/{customer_id}/transactions")
async def get_customer_transactions(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Get transaction history for a customer with balance calculations - includes BOTH invoices and payments"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Payment, Customer, Invoice, Transaction, Admin, Employee
    from datetime import datetime
    
    def parse_date_robust(date_str, has_time=False):
        """Parse date string with multiple format attempts, never fallback to now()"""
        if not date_str:
            return datetime.min
        
        if isinstance(date_str, datetime):
            return date_str
        
        formats = [
            "%Y-%m-%d %H:%M:%S",
            "%Y-%m-%d %H:%M",
            "%Y-%m-%d",
            "%d-%m-%Y %H:%M:%S",
            "%d-%m-%Y %H:%M",
            "%d-%m-%Y",
            "%d/%m/%Y %H:%M:%S",
            "%d/%m/%Y %H:%M",
            "%d/%m/%Y"
        ]
        
        for fmt in formats:
            try:
                return datetime.strptime(str(date_str), fmt)
            except:
                continue
        
        return datetime.min
    
    try:
        customer = db.query(Customer).filter(
            Customer.customer_id == customer_id,
            Customer.company_id == company_id
        ).first()
        
        if not customer:
            return {"success": False, "message": "Customer not found"}
        
        admin_map = {}
        employee_map = {}
        
        admins = db.query(Admin).filter(Admin.company_id == company_id).all()
        for admin in admins:
            admin_map[admin.admin_id] = admin.admin_name or admin.admin_id
        
        employees = db.query(Employee).filter(Employee.company_id == company_id).all()
        for emp in employees:
            employee_map[emp.employee_code] = emp.employee_name or emp.employee_code
        
        invoices = db.query(Invoice).filter(
            Invoice.customer_id == customer_id,
            Invoice.company_id == company_id
        ).order_by(Invoice.issue_date.asc(), Invoice.id.asc()).all()
        
        payments = db.query(Payment).filter(
            Payment.customer_id == customer_id,
            Payment.company_id == company_id
        ).order_by(Payment.paid_at.asc(), Payment.id.asc()).all()
        
        invoice_transaction_map = {}
        transactions_for_invoices = db.query(Transaction).filter(
            Transaction.customer_id == customer_id,
            Transaction.company_id == company_id,
            Transaction.invoice_id.isnot(None)
        ).all()
        
        for txn in transactions_for_invoices:
            if txn.invoice_id:
                invoice_transaction_map[txn.invoice_id] = txn.remarks or "Invoice for service period"
        
        all_transactions = []
        
        # Add invoices with proper remarks from Transaction table
        for invoice in invoices:
            created_at = invoice.created_at if invoice.created_at else parse_date_robust(invoice.issue_date, has_time=False)
            
            remarks = invoice_transaction_map.get(invoice.id, f"Invoice for service period")
            
            all_transactions.append({
                "type": "invoice",
                "date": created_at,
                "id": invoice.id,
                "data": invoice,
                "remarks": remarks
            })
        
        # Add payments
        for payment in payments:
            created_at = payment.created_at if payment.created_at else parse_date_robust(payment.paid_at, has_time=True)
            
            all_transactions.append({
                "type": "payment",
                "date": created_at,
                "id": payment.id,
                "data": payment,
                "remarks": payment.remarks or f"Payment via {payment.payment_mode or 'CASH'}"
            })
        
        all_transactions.sort(key=lambda x: (x["date"], x["id"]), reverse=False)
        
        running_balance = 0.0
        transactions = []
        
        for txn in all_transactions:
            if txn["type"] == "invoice":
                invoice = txn["data"]
                amount = float(invoice.total_amount) if invoice.total_amount else 0.0
                
                running_balance = running_balance + amount
                balance_after = running_balance
                
                performed_by = "Admin"
                if hasattr(invoice, 'created_by') and invoice.created_by:
                    performed_by = admin_map.get(invoice.created_by) or employee_map.get(invoice.created_by) or invoice.created_by
                
                transactions.append({
                    "type": "invoice",
                    "transaction_no": invoice.invoice_no,
                    # === S41S-TXN-HISTORY-DATETIME ===
                    # Previously stripped time off invoice rows; we now show full
                    # DD-MM-YYYY HH:MM IST so invoices + payments sort correctly
                    # chronologically when both happen on the same day.
                    "paid_at": (_tzu_ist_str(txn["date"], with_suffix=False) if txn["date"] != datetime.min else ""),
                    "amount": amount,
                    "discount": 0.0,
                    "payment_mode": "",
                    "remarks": txn["remarks"],
                    "payment_remarks": "",
                    "employee_id": "ADMIN001",
                    "performed_by": performed_by,
                    "balance_after": round(balance_after),
                    "invoice_id": invoice.id,
                    "has_invoice": True,
                    "download_url": f"/api/invoices/{invoice.id}/download",
                    "email_url": f"/api/invoices/{invoice.id}/send-email"
                })
            
            elif txn["type"] == "payment":
                payment = txn["data"]
                amount = float(payment.amount) if payment.amount else 0.0
                discount = float(payment.discount) if payment.discount else 0.0
                total_payment = amount + discount
                
                running_balance = running_balance - total_payment
                balance_after = running_balance
                
                remarks = txn["remarks"]
                if discount > 0:
                    remarks = f"{remarks} (Discount: ₹{int(discount)})"
                
                emp_id = payment.employee_id or "ADMIN001"
                performed_by = employee_map.get(emp_id) or admin_map.get(emp_id) or emp_id
                
                transactions.append({
                    "type": "payment",
                    "transaction_no": payment.transaction_no,
                    "paid_at": (_tzu_ist_str(txn["date"], with_suffix=False) if txn["date"] != datetime.min else ""),  # _GLOBAL_TZ_FIX_V2_
                    "amount": amount,
                    "discount": discount,
                    "payment_mode": payment.payment_mode,
                    "remarks": remarks,
                    "payment_remarks": payment.remarks or "",
                    "employee_id": payment.employee_id or "ADMIN001",
                    "performed_by": performed_by,
                    "balance_after": round(balance_after),
                    "has_invoice": False,
                    "payment_id": payment.id,
                    "download_url": f"/api/payments/{payment.id}/receipt",
                    "email_url": f"/api/payments/{payment.id}/send-email"
                })
        
        # Reverse the list to display newest first
        transactions.reverse()
        
        return {
            "success": True, 
            "transactions": transactions,
            "customer": {
                "customer_id": customer.customer_id,
                "customer_name": customer.customer_name,
                "customer_email": customer.customer_email,
                "customer_phone": customer.customer_phone,
                "address": customer.address,
                "current_balance": float(customer.total_bill_amount) if customer.total_bill_amount else 0.0
            }
        }
    
    except Exception as e:
        return {"success": False, "message": str(e)}

@app.get("/api/payments/{payment_id}/receipt")
async def generate_receipt(payment_id: int, request: Request, db: Session = Depends(get_db)):
    """Generate PDF receipt for a payment"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
    from database import Payment, Customer, Company, Admin, Employee
    from reportlab.lib.pagesizes import letter
    from reportlab.lib.units import inch
    from reportlab.pdfgen import canvas
    from reportlab.lib import colors
    from reportlab.pdfbase import pdfmetrics
    from reportlab.pdfbase.ttfonts import TTFont
    from io import BytesIO
    from fastapi.responses import StreamingResponse
    
    try:
        try:
            pdfmetrics.registerFont(TTFont('DejaVu', '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf'))
            pdfmetrics.registerFont(TTFont('DejaVu-Bold', '/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf'))
            FONT_REGULAR = 'DejaVu'
            FONT_BOLD = 'DejaVu-Bold'
        except:
            FONT_REGULAR = 'Helvetica'
            FONT_BOLD = 'Helvetica-Bold'
        
        payment = db.query(Payment).filter(
            Payment.id == payment_id,
            Payment.company_id == company_id
        ).first()
        
        if not payment:
            return {"success": False, "message": "Payment not found"}
        
        customer = db.query(Customer).filter(
            Customer.customer_id == payment.customer_id,
            Customer.company_id == company_id
        ).first()
        
        company = db.query(Company).filter(
            Company.company_id == company_id
        ).first()
        
        cashier_name = "System"
        if payment.employee_id:
            admin = db.query(Admin).filter(
                Admin.admin_id == payment.employee_id,
                Admin.company_id == company_id
            ).first()
            if admin:
                cashier_name = admin.admin_name
            else:
                employee = db.query(Employee).filter(
                    Employee.employee_code == payment.employee_id,
                    Employee.company_id == company_id
                ).first()
                if employee:
                    cashier_name = employee.employee_name
        
        # _S40zπ_RECEIPT_BAL_FIX_  Permanent receipt-balance algebra.
        # The legacy code used customer.total_bill_amount (just the LATEST
        # invoice total) as "initial due" and then subtracted EVERY past
        # payment from it — producing wildly negative numbers (e.g. -9526)
        # because total_bill_amount is per-invoice, not cumulative.
        # Correct ledger algebra (matches compute_customer_balance):
        #   balance_after_X = SUM(invoices issued <= X.paid_at)
        #                   - SUM(payments.amount + discount where (paid_at,id) <= X.(paid_at,id))
        #   balance_before_X = balance_after_X + (X.amount + X.discount)
        from database import Invoice as _RBInvoice
        _rb_pay_at = payment.paid_at
        _rb_pay_id = payment.id
        # Sum invoices issued at-or-before this payment.
        _rb_inv_rows = db.query(_RBInvoice.total_amount, _RBInvoice.issue_date,
                                _RBInvoice.created_at).filter(
            _RBInvoice.company_id == company_id,
            _RBInvoice.customer_id == payment.customer_id,
        ).all()
        def _rb_norm_d(x):
            if not x: return None
            x = str(x)[:10]
            for fmt in ('%Y-%m-%d', '%d-%m-%Y', '%d/%m/%Y'):
                try:
                    from datetime import datetime as _dt
                    return _dt.strptime(x, fmt).date()
                except Exception:
                    continue
            return None
        _rb_pay_date = _rb_pay_at.date() if _rb_pay_at else None
        # === S41W-RECEIPT-INV-ALL ===
        # User reported that receipt PDFs were showing "Balance After
        # Payment" as NEGATIVE when the user backdated a payment to a
        # date before the Manual Adjustment invoice was issued. The
        # filter `invoice.issue_date <= payment.paid_at` excluded the
        # adjustment invoice. Switching to "all invoices, all of them"
        # always gives a sane snapshot: total_invoiced is the lifetime
        # liability; (paid_up_to + disc_up_to) is the cumulative credit
        # at-this-payment by (paid_at, id). Balance = invoiced - paid.
        _rb_total_invoiced = 0.0
        for _amt, _idate, _cat in _rb_inv_rows:
            _rb_total_invoiced += float(_amt or 0)
        # Sum payments at-or-before this payment (chronological by paid_at, id).
        all_payments = db.query(Payment).filter(
            Payment.customer_id == payment.customer_id,
            Payment.company_id == company_id
        ).order_by(Payment.paid_at.asc(), Payment.id.asc()).all()
        _rb_paid_up_to = 0.0
        _rb_disc_up_to = 0.0
        _rb_self_paid = 0.0
        _rb_self_disc = 0.0
        for _p in all_payments:
            _pa = float(_p.amount or 0)
            _pd = float(_p.discount or 0)
            _is_self = (_p.id == _rb_pay_id)
            _p_at = _p.paid_at
            _before_or_eq = False
            if _is_self:
                _before_or_eq = True
            elif _p_at and _rb_pay_at:
                if _p_at < _rb_pay_at:
                    _before_or_eq = True
                elif _p_at == _rb_pay_at and (_p.id or 0) < (_rb_pay_id or 0):
                    _before_or_eq = True
            if _before_or_eq:
                _rb_paid_up_to += _pa
                _rb_disc_up_to += _pd
                if _is_self:
                    _rb_self_paid = _pa
                    _rb_self_disc = _pd
        balance_after_raw = round(_rb_total_invoiced - _rb_paid_up_to - _rb_disc_up_to, 2)
        balance_before_raw = round(balance_after_raw + _rb_self_paid + _rb_self_disc, 2)
        # === S41W-RECEIPT-CLAMP-NEG ===
        # Never present a negative due as a "balance". Negative = credit.
        balance_after  = max(0.0, balance_after_raw)
        balance_before = max(0.0, balance_before_raw)
        _credit_after  = abs(min(0.0, balance_after_raw))
        
        buffer = BytesIO()
        c = canvas.Canvas(buffer, pagesize=letter)
        width, height = letter
        
        y_position = height - 1 * inch
        
        c.setFont(FONT_BOLD, 20)
        c.drawCentredString(width / 2, y_position, company.company_name if company else "Auto ISP Billing")
        y_position -= 0.3 * inch
        
        c.setFont(FONT_REGULAR, 10)
        if company and company.company_address:
            c.drawCentredString(width / 2, y_position, company.company_address)
            y_position -= 0.2 * inch
        
        if company and company.company_phone:
            c.drawCentredString(width / 2, y_position, f"Contact: {company.company_phone}")
            y_position -= 0.4 * inch
        
        c.setFont(FONT_BOLD, 16)
        c.drawCentredString(width / 2, y_position, "Payment Receipt")
        y_position -= 0.5 * inch
        
        c.setFont(FONT_REGULAR, 11)
        c.drawString(1 * inch, y_position, f"Dear {customer.customer_name if customer else 'Customer'}")
        y_position -= 0.2 * inch
        c.drawString(1 * inch, y_position, "Details of your transaction are given below:")
        y_position -= 0.4 * inch
        
        c.line(1 * inch, y_position, width - 1 * inch, y_position)
        y_position -= 0.3 * inch
        
        # __RENEWAL_PERIOD_PDF__  invoice-derived renewal period
        _rb_renewal_period = ""
        try:
            from invoice_period_for_payment import invoice_period_for_payment as _ipfp
            _rb_inv_p = _ipfp(payment, db)
            if _rb_inv_p and _rb_inv_p.get("renewal_period"):
                _rb_renewal_period = _rb_inv_p["renewal_period"]
        except Exception as _e:
            print(f"[receipt renewal period] {_e}")
        receipt_data = [
            ("Customer ID", payment.customer_id),
            ("Total Due Balance (Before Payment)", f"₹{round(balance_before)}"),
            ("Amount Paid", f"₹{round(payment.amount)}"),
            ("Discount", f"₹{round(payment.discount)}" if payment.discount else "₹0"),
            ("Balance After Payment", f"₹{round(balance_after)}"),
            ("Transaction ID", payment.transaction_no),
            ("Date", (payment.paid_at + timedelta(hours=5, minutes=30)).strftime("%d-%m-%Y") if payment.paid_at else ""),
            ("Payment Mode", payment.payment_mode),
            ("Payment Remark", payment.remarks or "-"),
            ("Cashier", cashier_name),
        ]
        # === S41W-EMAIL-RECEIPT-NO-PERIOD ===
        # __s56u_period_back__ — user re-requested the period on the
        # email receipt (2026-05-31). Pulled from the LATEST invoice
        # covering this payment, via invoice_period_for_payment().
        if _rb_renewal_period:
            receipt_data.append(("Renewal Period", _rb_renewal_period))
        
        label_x = 1 * inch
        value_x = width - 1 * inch
        
        for label, value in receipt_data:
            c.setFont(FONT_BOLD, 10)
            c.drawString(label_x, y_position, label)
            c.setFont(FONT_REGULAR, 10)
            c.drawRightString(value_x, y_position, str(value))
            y_position -= 0.35 * inch
        
        y_position -= 0.2 * inch
        c.line(1 * inch, y_position, width - 1 * inch, y_position)
        y_position -= 0.3 * inch
        
        c.setFont(FONT_REGULAR, 9)
        c.drawString(1 * inch, y_position, "This will be credited into your account. Please quote your transaction ID for any queries")
        y_position -= 0.15 * inch
        c.drawString(1 * inch, y_position, "related to this transaction.")
        y_position -= 0.3 * inch
        
        c.setFont(FONT_REGULAR, 9)
        c.drawString(1 * inch, y_position, "For more details, visit: www.autoispbilling.com")
        
        c.save()
        buffer.seek(0)
        
        return StreamingResponse(
            buffer,
            media_type="application/pdf",
            headers={
                "Content-Disposition": f"attachment; filename=receipt_{payment.transaction_no}.pdf"
            }
        )
    
    except Exception as e:
        return {"success": False, "message": str(e)}


@app.get("/api/internal/invoices/{invoice_id}/pdf")
async def internal_invoice_pdf(invoice_id: int, request: Request,
                                db: Session = Depends(get_db)):
    """_v4719_INTERNAL_INV_PDF  Localhost-only PDF for the mobile app."""
    from fastapi.responses import Response as _Resp
    host = (request.client.host if request.client else "") or ""
    if host not in ("127.0.0.1", "::1", "localhost"):
        return _Resp(content=b'{"detail":"Forbidden"}', status_code=403,
                     media_type="application/json")
    company_id = request.query_params.get("company_id") or ""
    from database import Invoice, Customer, Company
    inv = db.query(Invoice).filter(Invoice.id == invoice_id,
                                    Invoice.company_id == company_id).first()
    if not inv:
        return _Resp(content=b'{"detail":"not_found"}', status_code=404,
                     media_type="application/json")
    # Serve cached PDF if present, else generate on the fly.
    if inv.pdf_path and os.path.exists(inv.pdf_path):
        with open(inv.pdf_path, "rb") as f:
            return _Resp(content=f.read(), media_type="application/pdf")
    try:
        cust = db.query(Customer).filter(
            Customer.customer_id == inv.customer_id,
            Customer.company_id  == company_id).first()
        comp = db.query(Company).filter(Company.company_id == company_id).first()
        invoice_data  = {"id": inv.id, "invoice_no": inv.invoice_no,
                         "issue_date": inv.issue_date, "due_date": inv.due_date,
                         "start_date": getattr(inv, "start_date", None),
                         "end_date":   getattr(inv, "end_date", None),
                         "total_amount": float(inv.total_amount or 0),
                         "status": inv.status or "Unpaid",
                         "remarks": getattr(inv, "remarks", "") or ""}
        company_data  = {"company_name": comp.company_name if comp else "",
                         "company_phone": getattr(comp, "company_phone", "") if comp else "",
                         "company_email": getattr(comp, "company_email", "") if comp else "",
                         "company_address": getattr(comp, "company_address", "") if comp else "",
                         "gst_number": getattr(comp, "gst_number", "") if comp else "",
                         "logo_path":  getattr(comp, "logo_path", "") if comp else ""}
        customer_data = {"customer_name": cust.customer_name if cust else "",
                         "customer_phone": cust.customer_phone if cust else "",
                         "customer_email": cust.customer_email if cust else "",
                         "address": getattr(cust, "address", "") if cust else "",
                         "locality": getattr(cust, "locality", "") if cust else "",
                         "customer_id": cust.customer_id if cust else ""}
        pdf_data = generate_invoice_pdf(invoice_data, company_data, customer_data, [])
        return _Resp(content=pdf_data, media_type="application/pdf")
    except Exception as e:
        return _Resp(content=f'{{"detail":"pdf_error:{e}"}}'.encode(),
                     status_code=500, media_type="application/json")


@app.get("/api/internal/payments/{payment_id}/receipt-pdf")
async def internal_receipt_pdf(payment_id: int, request: Request, db: Session = Depends(get_db)):
    """_S40zπ_MOBILE_FIX_  Localhost-only PDF receipt for service-to-service.
    Used by mobile-api to mirror the official web receipt for offline sharing."""
    from fastapi.responses import Response as _Resp
    host = (request.client.host if request.client else "") or ""
    if host not in ("127.0.0.1", "::1", "localhost"):
        return _Resp(content=b'{"detail":"Forbidden"}', status_code=403,
                     media_type="application/json")
    company_id = request.query_params.get("company_id") or ""
    if not company_id:
        return _Resp(content=b'{"detail":"company_id required"}', status_code=400,
                     media_type="application/json")
    from database import Payment as _PM
    payment = db.query(_PM).filter(_PM.id == payment_id, _PM.company_id == company_id).first()
    if not payment:
        return _Resp(content=b'{"detail":"payment_not_found"}', status_code=404,
                     media_type="application/json")
    # Reuse the existing helper that builds the PDF — call generate_receipt
    # with a stub session that has company_id pre-filled.
    class _StubReq:
        def __init__(self, cid):
            self.session = {"company_id": cid, "user_type": "admin",
                            "user_id": "INTERNAL", "logged_in": True}
            self.client = None
            self.headers = {}
    try:
        return await generate_receipt(payment_id, _StubReq(company_id), db)
    except Exception as _e:
        return _Resp(content=str(_e).encode(), status_code=500,
                     media_type="text/plain")


# === POST-PAYMENT-RECONCILE-V1 ===
@app.post("/api/internal/customer/{customer_id}/post-payment-reconcile")
async def internal_post_payment_reconcile(customer_id: str, request: Request,
                                           db: Session = Depends(get_db)):
    """Internal (mobile-api → admin-portal). Called after a mobile-app
    payment is inserted into the `payments` table. Performs:
      1. Invoice status rollup (Partial → Paid once cumulative payments
         cover the invoice amount).
      2. Refreshes `received_tracker.received_since_reset` to the sum of
         payments (+ discounts) recorded since the tracker'''s last reset.
      3. Auto-reactivates the customer (and runs `_enforce_user_state` to
         kick parking session + reload FreeRADIUS) when balance == 0.
    Idempotent — safe to retry. Localhost + X-Internal-Token only.
    """
    cid_or_resp = require_admin_or_internal(request)
    if not isinstance(cid_or_resp, str):
        return cid_or_resp
    company_id = cid_or_resp

    from database import Customer, ReceivedTracker
    from sqlalchemy import text as _t_ir

    customer = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.customer_id == customer_id
    ).first()
    if not customer:
        return {"success": False, "message": "customer_not_found"}

    # 1) Invoice status rollup (mirrors web /api/payments/create logic)
    try:
        cum = float(db.execute(_t_ir(
            "SELECT COALESCE(SUM(amount),0) FROM payments "
            "WHERE customer_id = :c AND company_id = :co"
        ), {"c": customer_id, "co": company_id}).scalar() or 0)
        db.execute(_t_ir("""
            UPDATE invoices SET status = CASE
                WHEN COALESCE(total_amount,0) <= 0
                  THEN COALESCE(NULLIF(LOWER(status),''''''),'''paid''')
                WHEN :cum + 0.005 >= COALESCE(total_amount,0) THEN '''paid'''
                WHEN :cum > 0 THEN '''partial'''
                ELSE COALESCE(NULLIF(LOWER(status),''''''),'''generated''')
            END
            WHERE customer_id = :c AND company_id = :co
              AND LOWER(COALESCE(status,''''''')) IN
                  ('''partial''','''pending''','''unpaid''','''generated''','''''')
        """), {"cum": cum, "c": customer_id, "co": company_id})
        db.commit()
    except Exception as _r:
        print(f"[post-payment-reconcile rollup] {_r}")

    # 2) received_tracker: recompute received_since_reset from payments
    #    issued at-or-after tracker.last_reset_at. Cheaper than tracking
    #    increments and immune to drift.
    tracker = None
    try:
        tracker = db.query(ReceivedTracker).filter(
            ReceivedTracker.company_id == company_id,
            ReceivedTracker.customer_id == customer_id
        ).first()
        if not tracker:
            tracker = ReceivedTracker(
                company_id=company_id,
                customer_id=customer_id,
                received_since_reset=0.0,
                last_reset_at=datetime.utcnow(),
                updated_at=datetime.utcnow()
            )
            db.add(tracker)
            db.flush()
        # 6h skew tolerance (same as web flow)
        from datetime import timedelta as _td_rcv
        _floor = tracker.last_reset_at - _td_rcv(hours=6)
        recv = float(db.execute(_t_ir(
            "SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) "
            "  FROM payments "
            " WHERE company_id = :co AND customer_id = :c "
            "   AND paid_at >= :floor"
        ), {"co": company_id, "c": customer_id,
            "floor": _floor.strftime("%Y-%m-%d %H:%M:%S")}).scalar() or 0)
        tracker.received_since_reset = round(recv, 2)
        tracker.updated_at = datetime.utcnow()
        db.commit()
    except Exception as _r:
        print(f"[post-payment-reconcile tracker] {_r}")

    # 3) Compute fresh balance + auto-reactivate
    new_balance = 0.0
    reactivated = False
    try:
        new_balance = compute_customer_balance(customer_id, company_id, db)
        cur_status = (customer.status or "").strip().lower()
        # __S43L_REACT_ANY_PAY__: reconcile triggers reactivation when ANY
        # payment exists post-reset (caller already wrote the payment row),
        # not only when balance == 0. Internet should resume on partial pay.
        _has_any_pay = float(db.execute(_t_ir(
            "SELECT COALESCE(SUM(amount),0) FROM payments "
            " WHERE company_id=:co AND customer_id=:c"
        ), {"co": company_id, "c": customer_id}).scalar() or 0)
        if cur_status != "active" and (new_balance <= 0.01 or _has_any_pay > 0):
            try:
                log_customer_status_change(
                    db, customer, "Active",
                    reason="balance cleared via mobile-app payment",
                    actor_type="mobile_app",
                    actor_id="",
                    actor_name="",
                    balance=new_balance,
                )
            except Exception as _le:
                print(f"[post-payment-reconcile log] {_le}")
            customer.status = "Active"
            db.commit()
            try:
                _enforce_user_state(db, customer)
            except Exception as _e:
                print(f"[post-payment-reconcile enforce] {_e}")
            reactivated = True
    except Exception as _be:
        print(f"[post-payment-reconcile balance] {_be}")

    return {"success": True,
            "new_balance": new_balance,
            "received_since_reset": (tracker.received_since_reset if tracker else 0),
            "status": customer.status,
            "reactivated": reactivated}
# === /POST-PAYMENT-RECONCILE-V1 ===

@app.post("/api/internal/payments/{payment_id}/send-receipt-email")
async def internal_send_receipt_email(payment_id: int, request: Request, db: Session = Depends(get_db)):
    """Localhost-only: server-to-server receipt email trigger.
    Used by employee-portal / mobile-api-v3 to reuse the admin PDF+SMTP helper."""
    host = (request.client.host if request.client else "") or ""
    if host not in ("127.0.0.1", "::1", "localhost"):
        return {"success": False, "message": "Forbidden"}
    company_id = request.query_params.get("company_id") or ""
    if not company_id:
        return {"success": False, "message": "company_id required"}
    try:
        return await _send_receipt_email_for_payment(payment_id, company_id, db)
    except Exception as e:
        return {"success": False, "message": f"{e}"}


async def _send_receipt_email_for_payment(payment_id: int, company_id: str, db: Session) -> dict:
    """Internal: build & email a payment receipt PDF. Used by manual button + auto-email after payment commit."""
    
    from database import Payment, Customer, Company, Admin, Employee
    from reportlab.lib.pagesizes import letter
    from reportlab.lib.units import inch
    from reportlab.pdfgen import canvas
    from reportlab.pdfbase import pdfmetrics
    from reportlab.pdfbase.ttfonts import TTFont
    from io import BytesIO
    import smtplib
    from email.mime.multipart import MIMEMultipart
    from email.mime.text import MIMEText
    from email.mime.application import MIMEApplication
    
    try:
        try:
            pdfmetrics.registerFont(TTFont('DejaVu', '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf'))
            pdfmetrics.registerFont(TTFont('DejaVu-Bold', '/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf'))
            FONT_REGULAR = 'DejaVu'
            FONT_BOLD = 'DejaVu-Bold'
        except:
            FONT_REGULAR = 'Helvetica'
            FONT_BOLD = 'Helvetica-Bold'
        
        payment = db.query(Payment).filter(
            Payment.id == payment_id,
            Payment.company_id == company_id
        ).first()
        
        if not payment:
            return {"success": False, "message": "Payment not found"}
        
        customer = db.query(Customer).filter(
            Customer.customer_id == payment.customer_id,
            Customer.company_id == company_id
        ).first()
        
        if not customer or not customer.customer_email:
            return {"success": False, "message": "Customer email not available"}
        
        company = db.query(Company).filter(
            Company.company_id == company_id
        ).first()
        
        cashier_name = "System"
        if payment.employee_id:
            admin = db.query(Admin).filter(
                Admin.admin_id == payment.employee_id,
                Admin.company_id == company_id
            ).first()
            if admin:
                cashier_name = admin.admin_name
            else:
                employee = db.query(Employee).filter(
                    Employee.employee_code == payment.employee_id,
                    Employee.company_id == company_id
                ).first()
                if employee:
                    cashier_name = employee.employee_name
        
        # _S40zπ_RECEIPT_BAL_FIX_  Permanent receipt-balance algebra.
        # The legacy code used customer.total_bill_amount (just the LATEST
        # invoice total) as "initial due" and then subtracted EVERY past
        # payment from it — producing wildly negative numbers (e.g. -9526)
        # because total_bill_amount is per-invoice, not cumulative.
        # Correct ledger algebra (matches compute_customer_balance):
        #   balance_after_X = SUM(invoices issued <= X.paid_at)
        #                   - SUM(payments.amount + discount where (paid_at,id) <= X.(paid_at,id))
        #   balance_before_X = balance_after_X + (X.amount + X.discount)
        from database import Invoice as _RBInvoice
        _rb_pay_at = payment.paid_at
        _rb_pay_id = payment.id
        # Sum invoices issued at-or-before this payment.
        _rb_inv_rows = db.query(_RBInvoice.total_amount, _RBInvoice.issue_date,
                                _RBInvoice.created_at).filter(
            _RBInvoice.company_id == company_id,
            _RBInvoice.customer_id == payment.customer_id,
        ).all()
        def _rb_norm_d(x):
            if not x: return None
            x = str(x)[:10]
            for fmt in ('%Y-%m-%d', '%d-%m-%Y', '%d/%m/%Y'):
                try:
                    from datetime import datetime as _dt
                    return _dt.strptime(x, fmt).date()
                except Exception:
                    continue
            return None
        _rb_pay_date = _rb_pay_at.date() if _rb_pay_at else None
        _rb_total_invoiced = 0.0
        for _amt, _idate, _cat in _rb_inv_rows:
            _amt = float(_amt or 0)
            # Invoice counted if its issue_date or created_at <= payment date.
            _i_d = _rb_norm_d(_idate)
            _c_d = _cat.date() if _cat else None
            if _rb_pay_date and (_i_d and _i_d <= _rb_pay_date):
                _rb_total_invoiced += _amt
            elif _rb_pay_at and _c_d and _c_d <= _rb_pay_date:
                _rb_total_invoiced += _amt
            elif not _rb_pay_date:
                # Defensive: if payment has no date, count all invoices.
                _rb_total_invoiced += _amt
        # Sum payments at-or-before this payment (chronological by paid_at, id).
        all_payments = db.query(Payment).filter(
            Payment.customer_id == payment.customer_id,
            Payment.company_id == company_id
        ).order_by(Payment.paid_at.asc(), Payment.id.asc()).all()
        _rb_paid_up_to = 0.0
        _rb_disc_up_to = 0.0
        _rb_self_paid = 0.0
        _rb_self_disc = 0.0
        for _p in all_payments:
            _pa = float(_p.amount or 0)
            _pd = float(_p.discount or 0)
            _is_self = (_p.id == _rb_pay_id)
            _p_at = _p.paid_at
            _before_or_eq = False
            if _is_self:
                _before_or_eq = True
            elif _p_at and _rb_pay_at:
                if _p_at < _rb_pay_at:
                    _before_or_eq = True
                elif _p_at == _rb_pay_at and (_p.id or 0) < (_rb_pay_id or 0):
                    _before_or_eq = True
            if _before_or_eq:
                _rb_paid_up_to += _pa
                _rb_disc_up_to += _pd
                if _is_self:
                    _rb_self_paid = _pa
                    _rb_self_disc = _pd
        balance_after = round(_rb_total_invoiced - _rb_paid_up_to - _rb_disc_up_to, 2)
        balance_before = round(balance_after + _rb_self_paid + _rb_self_disc, 2)
        
        buffer = BytesIO()
        c = canvas.Canvas(buffer, pagesize=letter)
        width, height = letter
        
        y_position = height - 1 * inch
        
        c.setFont(FONT_BOLD, 20)
        c.drawCentredString(width / 2, y_position, company.company_name if company else "Auto ISP Billing")
        y_position -= 0.3 * inch
        
        c.setFont(FONT_REGULAR, 10)
        if company and company.company_address:
            c.drawCentredString(width / 2, y_position, company.company_address)
            y_position -= 0.2 * inch
        
        if company and company.company_phone:
            c.drawCentredString(width / 2, y_position, f"Contact: {company.company_phone}")
            y_position -= 0.4 * inch
        
        c.setFont(FONT_BOLD, 16)
        c.drawCentredString(width / 2, y_position, "Payment Receipt")
        y_position -= 0.5 * inch
        
        c.setFont(FONT_REGULAR, 11)
        c.drawString(1 * inch, y_position, f"Dear {customer.customer_name if customer else 'Customer'}")
        y_position -= 0.2 * inch
        c.drawString(1 * inch, y_position, "Details of your transaction are given below:")
        y_position -= 0.4 * inch
        
        c.line(1 * inch, y_position, width - 1 * inch, y_position)
        y_position -= 0.3 * inch
        
        # __s56AJ_email_pdf_period__  Use same helper as print receipt
        _email_renewal_period = ""
        try:
            from invoice_period_for_payment import invoice_period_for_payment as _ipfp_e
            _ipfp_res = _ipfp_e(payment, db)
            if _ipfp_res and _ipfp_res.get("renewal_period"):
                _email_renewal_period = _ipfp_res["renewal_period"]
        except Exception as _epe:
            print(f"[email-receipt period] {_epe}")

        receipt_data = [
            ("Customer ID", payment.customer_id),
            ("Total Due Balance (Before Payment)", f"₹{round(balance_before)}"),
            ("Amount Paid", f"₹{round(payment.amount)}"),
            ("Discount", f"₹{round(payment.discount)}" if payment.discount else "₹0"),
            ("Balance After Payment", f"₹{round(balance_after)}"),
            ("Transaction ID", payment.transaction_no),
            ("Date", (payment.paid_at + timedelta(hours=5, minutes=30)).strftime("%d-%m-%Y") if payment.paid_at else ""),
            ("Payment Mode", payment.payment_mode),
            ("Payment Remark", payment.remarks or "-"),
            ("Cashier", cashier_name),
        ]
        if _email_renewal_period:
            receipt_data.insert(5, ("Renewal Period", _email_renewal_period))
        
        label_x = 1 * inch
        value_x = width - 1 * inch
        
        for label, value in receipt_data:
            c.setFont(FONT_BOLD, 10)
            c.drawString(label_x, y_position, label)
            c.setFont(FONT_REGULAR, 10)
            c.drawRightString(value_x, y_position, str(value))
            y_position -= 0.35 * inch
        
        y_position -= 0.2 * inch
        c.line(1 * inch, y_position, width - 1 * inch, y_position)
        y_position -= 0.3 * inch
        
        c.setFont(FONT_REGULAR, 9)
        c.drawString(1 * inch, y_position, "This will be credited into your account. Please quote your transaction ID for any queries")
        y_position -= 0.15 * inch
        c.drawString(1 * inch, y_position, "related to this transaction.")
        y_position -= 0.3 * inch
        
        c.setFont(FONT_REGULAR, 9)
        c.drawString(1 * inch, y_position, "For more details, visit: www.autoispbilling.com")
        
        c.save()
        buffer.seek(0)
        pdf_data = buffer.read()
        
        # s36b2: from-name — "<COMPANY_NAME_UPPER> - Receipt" <no-reply@...>
        from email.utils import formataddr as _fmtaddr_s36b2
        _cname_s36b2 = ((company.company_name if company else "") or "Auto ISP Billing").upper()
        _from_addr_s36b2 = "no-reply@autoispbilling.com"
        msg = MIMEMultipart()
        msg['From'] = _fmtaddr_s36b2((f"{_cname_s36b2} - Receipt", _from_addr_s36b2))
        msg['Reply-To'] = _from_addr_s36b2
        msg['To'] = customer.customer_email
        msg['Subject'] = f"Payment Receipt - {payment.transaction_no}"
        
        body = f"""Dear {customer.customer_name},

Thank you for your payment. Please find attached your payment receipt.

Transaction Details:
- Transaction ID: {payment.transaction_no}
- Amount Paid: ₹{round(payment.amount)}
- Date: {(payment.paid_at + timedelta(hours=5, minutes=30)).strftime("%d-%m-%Y") if payment.paid_at else ""}
- Payment Mode: {payment.payment_mode}

If you have any questions, please contact us.

Best regards,
{company.company_name if company else "Auto ISP Billing"}
"""
        
        msg.attach(MIMEText(body, 'plain'))
        
        pdf_attachment = MIMEApplication(pdf_data, _subtype='pdf')
        pdf_attachment.add_header('Content-Disposition', 'attachment', filename=f'receipt_{payment.transaction_no}.pdf')
        msg.attach(pdf_attachment)
        
        smtp_server = "smtp.hostinger.com"
        smtp_port = 465
        smtp_username = "no-reply@autoispbilling.com"
        smtp_password = "Login@121212"
        
        with smtplib.SMTP_SSL(smtp_server, smtp_port) as server:
            server.login(smtp_username, smtp_password)
            server.send_message(msg)
        
        return {
            "success": True, 
            "message": f"Receipt sent successfully to {customer.customer_email}"
        }
    
    except Exception as e:
        return {"success": False, "message": f"Failed to send email: {str(e)}"}


@app.post("/api/payments/{payment_id}/send-email")
async def send_receipt_email(payment_id: int, request: Request, db: Session = Depends(get_db)):
    """Send receipt via email with PDF attachment"""
    auth_check = require_auth(request)
    if auth_check:
        return {"success": False, "message": "Unauthorized"}
    
    company_id = request.session.get("company_id")
    
