@app.post("/api/public/complaints/create")
async def api_public_complaints_create(request: Request, db: Session = Depends(get_db)):
    """Customer-facing (no session). Requires customer_id in body — we validate
    it exists but don\'t require auth because the /pay/{id} deep-link is treated
    as light-auth (a customer with the URL is assumed legitimate)."""
    body = await request.json()
    customer_id = (body.get("customer_id") or "").strip()
    if not customer_id:
        return {"success": False, "message": "customer_id required"}
    from database import Customer, Complaint
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    if not cust:
        return {"success": False, "message": "Customer not found"}
    kind = (body.get("kind") or "Complaint").strip()
    if kind not in ("Complaint", "Support"):
        kind = "Complaint"
    subject = (body.get("subject") or "").strip()
    description = (body.get("description") or "").strip()
    if not subject or not description:
        return {"success": False, "message": "Subject and description required"}
    import time as _t
    ticket_no = f"{'T' if kind=='Support' else 'C'}{int(_t.time())}"
    c = Complaint(
        company_id=cust.company_id,
        customer_id=customer_id,
        ticket_no=ticket_no,
        complaint_type=kind,
        priority=(body.get("priority") or "Medium"),
        subject=subject[:200],
        description=description,
        status="Pending",
        kind=kind,
        source="customer",
    )
    db.add(c); db.commit(); db.refresh(c)
    return {"success": True, "ticket_no": ticket_no}


