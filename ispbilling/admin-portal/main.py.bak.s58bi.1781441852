# === Session 30 full-data exports ===
from fastapi import Response as _S30Response
Response = _S30Response
import csv as _s30_csv, io as _s30_io
from datetime import datetime as _s30_dt

def _s30_stamp():
    return _s30_dt.now().strftime('%Y%m%d_%H%M')

def _s30_send(headers, rows, fmt, stem):
    # Return CSV or XLSX Response for the given tabular data.
    stamp = _s30_stamp()
    fmt = (fmt or 'csv').lower()
    if fmt == 'xlsx':
        try:
            from openpyxl import Workbook
            wb = Workbook(); ws = wb.active
            ws.title = stem[:31] or 'Sheet1'
            ws.append(headers)
            for r in rows: ws.append(list(r))
            for col_idx in range(1, len(headers)+1):
                ws.column_dimensions[ws.cell(row=1, column=col_idx).column_letter].width = 18
            buf = _s30_io.BytesIO(); wb.save(buf); buf.seek(0)
            return Response(
                buf.getvalue(),
                media_type='application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                headers={'Content-Disposition': f'attachment; filename="{stem}_{stamp}.xlsx"'},
            )
        except Exception as e:
            print(f"[S30] xlsx export failed, falling back to CSV: {e}")
    buf = _s30_io.StringIO()
    w = _s30_csv.writer(buf); w.writerow(headers)
    for r in rows: w.writerow(r)
    return Response(
        buf.getvalue(), media_type='text/csv',
        headers={'Content-Disposition': f'attachment; filename="{stem}_{stamp}.csv"'},
    )


def _s30_v(obj, *names, default=''):
    # Safe getattr that tries many candidate column names.
    for n in names:
        if hasattr(obj, n):
            v = getattr(obj, n)
            if v is not None:
                return v
    return default


# ---------- Customers ----------
@app.get("/api/admin/customers/export-full")
async def api_customers_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from database import Customer, Plan, Company
    custs = db.query(Customer).filter(Customer.company_id == company_id).order_by(Customer.id).all()
    plan_map = {p.id: p for p in db.query(Plan).filter(Plan.company_id == company_id).all()}
    company = db.query(Company).filter(Company.company_id == company_id).first()
    cname = company.company_name if company else ''
    headers = ['Service ID','Username','PPPoE Password','Status','Customer Name','Customer Type',
               'Service Type','Plan Name','Plan Amount','Mobile','Alt Mobile','Email',
               'Address','Locality','City','State','Pincode',
               'ID Proof Type','ID Proof No','CAF No','MAC Address','IP Address',
               'Fixed IP','Zone','Node','Installation Date','Start Date','End Date',
               'Monthly Amount','Security Deposit','Installation Charges',
               'Auto Renew','Discount/Credit','GST Invoice','Customer GST No','Company']
    rows = []
    for c in custs:
        p = plan_map.get(c.plan_id) if c.plan_id else None
        rows.append([
            c.customer_id or '', c.username or '', c.pppoe_password or '',
            c.status or '', c.customer_name or '', c.customer_type or '',
            c.service_type or '', (p.plan_name if p else ''),
            (p.after_tax_amount if p else '') or '',
            c.customer_phone or '', c.alt_mobile or '', c.customer_email or '',
            c.address or '', c.locality or '', c.city or '', c.state or '', c.pincode or '',
            c.id_proof or '', c.id_proof_no or '', c.caf_no or '',
            c.mac_address or '', c.ip_address or '',
            _s30_v(c, 'fix_ip_address', 'fixed_ip', default=''),
            _s30_v(c, 'zone'), _s30_v(c, 'node'),
            c.installation_date or '', c.start_date or '', c.end_date or '',
            c.monthly_amount or 0, c.security_deposit or 0, c.installation_charges or 0,
            c.auto_renew or '', c.discount_credit or 0,
            c.gst_invoice_needed or '', c.customer_gst_no or '', cname,
        ])
    return _s30_send(headers, rows, fmt, 'customers')


# ---------- Plans ----------
@app.get("/api/admin/plans/export-full")
async def api_plans_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from database import Plan
    plans = db.query(Plan).filter(Plan.company_id == company_id).order_by(Plan.id).all()
    headers = ['Plan Name','Service','Speed','Download Speed','Upload Speed',
               'Validity','Validity Unit','Base Amount','CGST %','SGST %','IGST %',
               'After-Tax Amount','FUP Enabled','FUP Limit (GB)','FUP Post-DL','FUP Post-UL',
               'Night Boost','Night Start','Night End','Night DL','Night UL',
               'Burst Enabled','Burst DL','Burst UL','Priority','Queue Type','Description']
    rows = []
    for p in plans:
        rows.append([
            p.plan_name or '', p.service or '', p.speed or '',
            _s30_v(p, 'download_speed'), _s30_v(p, 'upload_speed'),
            p.validity or '', _s30_v(p, 'validity_unit', default='days'),
            p.base_amount or 0, p.cgst_tax or 0, p.sgst_tax or 0, p.igst_tax or 0,
            p.after_tax_amount or 0,
            'Yes' if _s30_v(p, 'fup_enabled') else 'No',
            _s30_v(p, 'fup_limit_gb', default=0),
            _s30_v(p, 'fup_post_download'), _s30_v(p, 'fup_post_upload'),
            'Yes' if _s30_v(p, 'night_boost_enabled') else 'No',
            _s30_v(p, 'night_boost_start'), _s30_v(p, 'night_boost_end'),
            _s30_v(p, 'night_boost_download'), _s30_v(p, 'night_boost_upload'),
            'Yes' if _s30_v(p, 'burst_enabled') else 'No',
            _s30_v(p, 'burst_limit_down'), _s30_v(p, 'burst_limit_up'),
            _s30_v(p, 'priority', default=8), _s30_v(p, 'queue_type', default='default'),
            p.description or '',
        ])
    return _s30_send(headers, rows, fmt, 'plans')


