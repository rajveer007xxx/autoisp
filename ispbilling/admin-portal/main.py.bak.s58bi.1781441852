# s37p: NAS activity list — used by the admin portal and proxied by the
# SuperAdmin NAS Console's "Audit Trail" modal.
@app.get("/api/nas-devices/activity")
async def api_nas_activity(request: Request, nas_id: int | None = None,
                            limit: int = 100, db: Session = Depends(get_db)):
    company_id = require_admin_or_internal(request)
    if not isinstance(company_id, str):
        return company_id
    from sqlalchemy import text as _sql
    from datetime import datetime as _dt, timezone as _tz, timedelta as _td
    IST = _tz(_td(hours=5, minutes=30))

    q = ("SELECT id, actor_id, actor_name, actor_type, action, target_id, "
         "summary, payload_json, ip_address, created_at "
         "FROM admin_activity_log "
         "WHERE company_id=:co AND target_type='nas_device'")
    params = {"co": company_id}
    if nas_id:
        q += " AND target_id=:tid"
        params["tid"] = str(nas_id)
    q += " ORDER BY id DESC LIMIT :lim"
    params["lim"] = max(1, min(int(limit or 100), 1000))

    rows = db.execute(_sql(q), params).all()
    out = []
    for r in rows:
        created = r[9]
        # created_at is TEXT in SQLite (default CURRENT_TIMESTAMP emits UTC
        # without tz suffix). Parse best-effort and convert to IST.
        ts_fmt = ""
        try:
            if isinstance(created, str) and created:
                s = created.replace("T", " ").split(".", 1)[0]
                d = _dt.strptime(s, "%Y-%m-%d %H:%M:%S").replace(tzinfo=_tz.utc)
                ts_fmt = d.astimezone(IST).strftime("%d-%m-%Y %H:%M")
            elif hasattr(created, "strftime"):
                dd = created
                if dd.tzinfo is None:
                    dd = dd.replace(tzinfo=_tz.utc)
                ts_fmt = dd.astimezone(IST).strftime("%d-%m-%Y %H:%M")
        except Exception:
            ts_fmt = str(created or "")
        out.append({
            "id":           r[0],
            "actor_id":     r[1] or "",
            "actor_name":   r[2] or "",
            "actor_type":   r[3] or "",
            "action":       r[4] or "",
            "target_id":    r[5] or "",
            "summary":      r[6] or "",
            "payload_json": r[7] or "{}",
            "ip_address":   r[8] or "",
            "created_at_ist": ts_fmt,
        })
    return {"ok": True, "rows": out, "count": len(out)}



def log_admin_activity(db, request, action: str, target_type: str,
                        target_id: str | None = None,
                        summary: str | None = None,
                        payload: dict | None = None):
    """Insert one row into admin_activity_log. Fire-and-forget: any exception
    is swallowed so activity logging can never break a real mutation."""
    try:
        from database import AdminActivityLog
        rec = AdminActivityLog(
            company_id=request.session.get("company_id", "N/A"),
            actor_id=request.session.get("user_id", ""),
            actor_name=request.session.get("user_name", "") or request.session.get("user_id", ""),
            actor_type=request.session.get("user_type", "admin"),
            action=(action or "invoke")[:32],
            target_type=(target_type or "")[:32],
            target_id=(str(target_id) if target_id else "")[:64],
            summary=(summary or "")[:255],
            payload_json=_s36b8_json.dumps(payload or {}, default=str)[:10000],
            ip_address=(request.client.host if request and request.client else ""),
        )
        db.add(rec)
        db.commit()
    except Exception as _e:
        try: db.rollback()
        except Exception: pass

@app.get("/admin/activity-log", response_class=HTMLResponse)
async def admin_activity_log_page(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    ctx = get_admin_context(request, db, "activity_log")
    return templates.TemplateResponse("admin_activity_log.html", ctx)

@app.get("/api/activity-log/list")
async def api_activity_log_list(request: Request,
                                 limit: int = 15, page: int = 1,
                                 target_type: str = "",
                                 db: Session = Depends(get_db)):
    """_S39ACT_PAGINATION — server-side pagination."""
    auth_check = require_admin(request)
    if auth_check:
        return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    from database import AdminActivityLog
    company_id = request.session.get("company_id", "N/A")
    q = db.query(AdminActivityLog).filter(AdminActivityLog.company_id == company_id)
    if target_type:
        q = q.filter(AdminActivityLog.target_type == target_type)
    # _S40zP_lock_filter_activity_ Hide activity entries whose target is a hidden customer.
    try:
        _hide_p28a = _hidden_cust_ids(request, db)
        if _hide_p28a:
            from sqlalchemy import and_ as _aa, not_ as _nn, or_ as _oo
            from sqlalchemy import func as _ff
            q = q.filter(_nn(_aa(
                _ff.lower(AdminActivityLog.target_type) == "customer",
                AdminActivityLog.target_id.in_(_hide_p28a),
            )))
    except Exception:
        pass
    total = q.count()
    limit = max(1, min(int(limit or 15), 200))
    page  = max(1, int(page or 1))
    rows = q.order_by(AdminActivityLog.id.desc())\
            .offset((page - 1) * limit).limit(limit).all()
    return JSONResponse({"ok": True, "total": total,
        "page": page, "per": limit,
        "pages": (total + limit - 1) // limit,
        "rows": [{
        "id": r.id, "actor_name": r.actor_name, "actor_id": r.actor_id,
        "actor_type": r.actor_type, "action": r.action,
        "target_type": r.target_type, "target_id": r.target_id,
        "summary": r.summary, "ip": r.ip_address,
        "at": str(r.created_at) if r.created_at else "",
    } for r in rows]})

