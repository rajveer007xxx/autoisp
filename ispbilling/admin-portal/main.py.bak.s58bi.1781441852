@app.post("/api/admin/mfa-policy/save")
async def api_admin_mfa_policy_save(request: Request, db: Session = Depends(get_db)):
    auth = require_admin(request)
    if auth: return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    from database import Company, Admin
    from datetime import datetime as _dt, timedelta as _td
    body = await request.json()
    company_id = request.session.get("company_id")
    comp = db.query(Company).filter(Company.company_id == company_id).first()
    if not comp:
        return JSONResponse({"ok": False, "error": "no company"}, status_code=400)
    req_flag = 1 if body.get("mfa_required") else 0
    grace = max(0, min(int(body.get("mfa_grace_period_days") or 7), 90))
    was_on = bool(getattr(comp, "mfa_required_for_admins", 0))
    comp.mfa_required_for_admins = req_flag
    comp.mfa_grace_period_days = grace

    # When turning policy ON for the first time, set mfa_deadline on each
    # admin in this company who hasn't already enabled 2FA.
    if req_flag and not was_on:
        deadline = (_dt.utcnow() + _td(days=grace)).isoformat()
        admins_row = db.query(Admin).filter(
            Admin.company_id == company_id,
            (Admin.totp_enabled == 0) | (Admin.totp_enabled.is_(None))).all()
        for a in admins_row:
            a.mfa_deadline = deadline
    elif not req_flag:
        # Clear deadlines
        db.query(Admin).filter(Admin.company_id == company_id).update(
            {Admin.mfa_deadline: ""})
    db.commit()
    try:
        log_admin_activity(db, request, "update", "mfa_policy",
                           target_id=company_id,
                           summary=f"required={req_flag} grace={grace}d")
    except Exception:
        pass
    return {"ok": True, "mfa_required": bool(req_flag), "grace": grace}





# s36h-setup-hotspot
# S38c: read authoritative RADIUS secret from clients.conf — __S38C_RADIUS_REAL_SECRET__
@app.get("/api/nas-devices/{nas_id}/radius-real-secret")
async def api_nas_radius_real_secret(nas_id: int, request: Request, db: Session = Depends(get_db)):
    """Return the secret that FreeRADIUS actually uses for this NAS, pulled
    live from /etc/freeradius/3.0/clients.conf (the on-disk source of truth).
    Requires admin auth + matching company scope; used by the SuperAdmin
    Edit NAS popup so operators can verify the router-server handshake
    without SSH'ing into the VPS."""
    from radius_network import NasDevice
    auth_check = require_admin_or_internal(request)
    if not isinstance(auth_check, str):
        if "user_id" not in request.session:
            return auth_check
        company_id = request.session.get("company_id") or ""
    else:
        company_id = auth_check
    if not company_id:
        return JSONResponse({"success": False, "message": "No company context"}, status_code=400)
    nas = db.query(NasDevice).filter(
        NasDevice.id == nas_id, NasDevice.company_id == company_id).first()
    if not nas:
        return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)

    # shortname convention = <company_id>_<NAME_upper_underscored>
    import re as _re
    shortname = f"{company_id}_{_re.sub(r'[^A-Za-z0-9]+', '_', (nas.name or '').upper()).strip('_')}"
    path = "/etc/freeradius/3.0/clients.conf"
    try:
        with open(path) as f:
            raw = f.read()
    except Exception as e:
        return JSONResponse({"success": False, "message": f"clients.conf unreadable: {e}"},
                            status_code=500)

    # Match:  client <shortname> { ... secret = <value> ... }
    m = _re.search(
        r"client\s+" + _re.escape(shortname) + r"\s*\{([^}]*)\}",
        raw, _re.S)
    # Fallback: match by ipaddr if shortname doesn't match (e.g. manual edits)
    if not m and nas.ip_address:
        m = _re.search(
            r"client\s+[A-Za-z0-9_\-]+\s*\{[^}]*ipaddr\s*=\s*"
            + _re.escape(nas.ip_address) + r"[^}]*\}",
            raw, _re.S)
    if not m:
        return JSONResponse({"success": False,
                             "shortname": shortname,
                             "message": "No matching client block in clients.conf"},
                            status_code=404)
    body = m.group(1) if m.lastindex else m.group(0)
    sm = _re.search(r"secret\s*=\s*([^\s#]+)", body)
    if not sm:
        return JSONResponse({"success": False, "shortname": shortname,
                             "message": "client block has no secret= line"},
                            status_code=500)
    secret = sm.group(1).strip().strip('"').strip("'")
    # Read DB value for comparison
    db_secret = nas.secret or ""
    in_sync = (db_secret == secret)
    return {"success": True,
            "shortname": shortname,
            "secret": secret,
            "db_secret": db_secret,
            "in_sync_with_db": in_sync,
            "source": "freeradius_clients_conf"}


# S38g: router -> DB secret repair — __S38G_SYNC_SECRET_FROM_ROUTER__
@app.get("/api/nas-devices/{nas_id}/router-radius-entries")
async def api_nas_router_radius_entries(nas_id: int, request: Request, db: Session = Depends(get_db)):
    """Return /radius entries live from the router (via API/SSH). Used by
    the SuperAdmin Edit NAS popup to preview what secret the router
    currently has before overwriting the DB value."""
    from radius_network import NasDevice
    auth_check = require_admin_or_internal(request)
    if not isinstance(auth_check, str):
        if "user_id" not in request.session:
            return auth_check
        company_id = request.session.get("company_id") or ""
    else:
        company_id = auth_check
    if not company_id:
        return JSONResponse({"success": False, "message": "No company context"}, status_code=400)
    nas = db.query(NasDevice).filter(NasDevice.id == nas_id,
                                     NasDevice.company_id == company_id).first()
    if not nas:
        return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)
    from routeros_provision import list_router_radius
    return list_router_radius(nas)


@app.post("/api/nas-devices/{nas_id}/sync-secret-from-router")
async def api_nas_sync_secret_from_router(nas_id: int, request: Request, db: Session = Depends(get_db)):
    """Pull the router's /radius shared secret for our RADIUS server IP,
    and save it into nas.secret + regenerate clients.conf + reload freeradius.
    Use this when the router has the "real" secret but the DB/clients.conf
    have drifted (e.g. admin typed the secret directly on the router)."""
    from radius_network import NasDevice
    auth_check = require_admin_or_internal(request)
    if not isinstance(auth_check, str):
        if "user_id" not in request.session:
            return auth_check
        company_id = request.session.get("company_id") or ""
    else:
        company_id = auth_check
    if not company_id:
        return JSONResponse({"success": False, "message": "No company context"}, status_code=400)
    nas = db.query(NasDevice).filter(NasDevice.id == nas_id,
                                     NasDevice.company_id == company_id).first()
    if not nas:
        return JSONResponse({"success": False, "message": "NAS not found"}, status_code=404)

    # Look up our RADIUS server IP from env / company config
    import os as _os
    our_ip = (_os.environ.get("RADIUS_SERVER_IP") or "127.0.0.1").strip()

    from routeros_provision import list_router_radius
    res = list_router_radius(nas)
    if not res.get("success"):
        return JSONResponse({"success": False,
                             "message": f"Router query failed: {res.get('message')}"},
                            status_code=502)
    rows = res.get("radius") or []
    # Match by address — prefer our_ip, fall back to the NAS shortname comment
    match = None
    for rr in rows:
        if (rr.get("address") or "").strip() == our_ip:
            match = rr; break
    if not match and rows:
        # Try matching by comment containing "auto-isp-billing" (added by Auto-Configure)
        for rr in rows:
            if "auto-isp-billing" in (rr.get("comment") or "").lower():
                match = rr; break
    if not match:
        return JSONResponse({"success": False,
            "message": f"No /radius entry found on the router for address={our_ip}. "
                       f"Router has {len(rows)} entries: {[r.get('address') for r in rows]}"},
            status_code=404)

    router_secret = (match.get("secret") or "").strip()
    if not router_secret:
        return JSONResponse({"success": False,
            "message": "Router's /radius row for our server has an empty secret field."},
            status_code=409)

    old_secret = (nas.secret or "")
    if router_secret == old_secret:
        return {"success": True,
                "changed": False,
                "secret": router_secret,
                "message": "Already in sync — DB matches router."}

    # Persist + resync clients.conf
    try:
        nas.secret = router_secret
        db.commit()
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": f"DB update failed: {e}"},
                            status_code=500)
    sync_msg = ""
    try:
        from radius_network import _auto_sync_after_nas_save
        _auto_sync_after_nas_save(nas, action="update", db=db, actor=None,
                                   resync_server=True)
        sync_msg = "FreeRADIUS clients.conf rewritten and reloaded."
    except Exception as e:
        sync_msg = f"DB updated, but FreeRADIUS sync failed: {e}"

    try:
        log_admin_activity(db, request, "sync-secret", "nas_device",
                           target_id=str(nas.id),
                           summary=f"Copied /radius secret from router to DB for NAS {nas.name}")
    except Exception:
        pass

    return {"success": True,
            "changed": True,
            "old_secret": old_secret,
            "secret": router_secret,
            "sync_msg": sync_msg,
            "router_address": match.get("address"),
            "router_comment": match.get("comment"),
            "message": f"Copied secret from router ({match.get('address')}) into DB. " + sync_msg}


@app.post("/api/nas-devices/{nas_id}/setup-hotspot")
async def api_nas_setup_hotspot(nas_id: int, request: Request,
                                  db: Session = Depends(get_db)):
    """Run configure_hotspot + firewall_nat_baseline on the NAS. This sets
    up the Hotspot server, DHCP pool, RADIUS-driven profile, walled-garden
    + masquerade NAT — everything needed for the captive portal to work."""
    auth = require_admin(request)
    if auth: return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    from radius_network import NasDevice
    company_id = request.session.get("company_id")
    nas = db.query(NasDevice).filter(
        NasDevice.id == nas_id, NasDevice.company_id == company_id).first()
    if not nas:
        return JSONResponse({"ok": False, "error": "NAS not found"}, status_code=404)
    body = await request.json()
    interface = (body.get("interface") or "ether3").strip()
    address = (body.get("address") or "10.10.10.1/24").strip()
    pool_name = (body.get("pool_name") or "hotspot-pool").strip()
    pool_ranges = (body.get("pool_ranges") or "10.10.10.10-10.10.10.250").strip()
    wan_interface = (body.get("wan_interface") or "ether1").strip()
    dry_run = bool(body.get("dry_run", False))
    enable = bool(body.get("enable", True))

    try:
        from routeros_provision import RouterOSClient
        with RouterOSClient(nas, dry_run=dry_run) as cli:
            hs_cmds = cli.configure_hotspot(
                interface=interface, address=address,
                pool_name=pool_name, pool_ranges=pool_ranges,
                use_radius=True, disabled=not enable)
            nat_cmds = cli.configure_firewall_nat_baseline(
                wan_interface=wan_interface)
            commands = cli.commands
    except Exception as e:
        return JSONResponse({"ok": False, "error": str(e)}, status_code=500)

    # __S39E__ auto-update auth_modes label so the NAS row reflects
    # that hotspot is now configured. Purely cosmetic for the UI; does NOT
    # affect PPPoE or static-IP authentication paths.
    try:
        if not dry_run:
            modes = set(filter(None, (nas.auth_modes or "pppoe").split(",")))
            modes.add("hotspot")
            nas.auth_modes = ",".join(sorted(modes))
            db.commit()
    except Exception as _ex:
        db.rollback()
        print(f"[s39e] auth_modes update failed: {_ex}")
    
    try:
        log_admin_activity(db, request, "configure", "nas_hotspot",
                           target_id=str(nas_id),
                           summary=f"setup hotspot on {nas.name}: {interface} {address}")
    except Exception:
        pass
    return {"ok": True, "nas": nas.name, "dry_run": dry_run,
            "hotspot_commands": hs_cmds, "nat_commands": nat_cmds,
            "all_commands": commands,
            "auth_modes": nas.auth_modes}



# s36i-fix-ip-api --------------------------------------------------------
@app.get("/api/public-ips/pools")
async def api_public_ips_pools(request: Request, db: Session = Depends(get_db)):
    """List distinct pool_name values for the dropdown."""
    auth = require_admin(request)
    if auth: return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    from radius_network import PublicIpAddress
    from sqlalchemy import distinct, func
    company_id = request.session.get("company_id")
    rows = db.query(
        PublicIpAddress.pool_name,
        func.sum(1).label("total"),
        func.sum(
            (PublicIpAddress.status == "Free").cast(__import__("sqlalchemy").Integer)
        ).label("free"),
    ).filter(PublicIpAddress.company_id == company_id).group_by(PublicIpAddress.pool_name).order_by(PublicIpAddress.pool_name).all()
    return {"ok": True, "rows": [
        {"pool_name": (r[0] or "Default"), "total": int(r[1] or 0),
         "free": int(r[2] or 0)} for r in rows]}


@app.get("/api/public-ips/available")
async def api_public_ips_available(request: Request,
                                    pool: str = "",
                                    include_current: str = "",
                                    db: Session = Depends(get_db)):
    """Return free IPs in `pool`.  If `include_current` is set, also
    include that single IP (so an admin editing an already-assigned
    customer sees their current IP in the dropdown)."""
    auth = require_admin(request)
    if auth: return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    from radius_network import PublicIpAddress
    from sqlalchemy import or_
    company_id = request.session.get("company_id")
    pool = (pool or "Default").strip()
    q = db.query(PublicIpAddress).filter(
        PublicIpAddress.company_id == company_id,
        PublicIpAddress.pool_name == pool,
    )
    if include_current:
        q = q.filter(or_(PublicIpAddress.status == "Free",
                          PublicIpAddress.ip_address == include_current))
    else:
        q = q.filter(PublicIpAddress.status == "Free")
    rows = q.order_by(PublicIpAddress.ip_address).all()
    return {"ok": True, "pool": pool, "rows": [
        {"id": r.id, "ip": r.ip_address, "label": r.label or "",
         "status": r.status, "assigned_to": r.assigned_to or ""}
        for r in rows]}


# __S38R_POOL_EXCLUSION__ --------------------------------------------------------
def _compute_pool_ranges_excluding(start_ip: str, end_ip: str,
                                    excluded: set) -> str:
    """Given a raw range ``start_ip..end_ip`` and a set of IPs to exclude,
    return a comma-separated MikroTik-compatible range string that omits
    every excluded IP.  Example::

        start=10.0.0.10, end=10.0.0.20, excluded={10.0.0.12, 10.0.0.15}
        -> "10.0.0.10-10.0.0.11,10.0.0.13-10.0.0.14,10.0.0.16-10.0.0.20"
    """
    import ipaddress as _ip
    try:
        a = int(_ip.IPv4Address(start_ip.strip()))
        b = int(_ip.IPv4Address(end_ip.strip()))
    except Exception:
        return ""
    if a > b:
        a, b = b, a
    excluded_ints = set()
    for e in excluded:
        try:
            excluded_ints.add(int(_ip.IPv4Address(e.strip())))
        except Exception:
            pass

    out_pairs = []
    cur_start = None
    for i in range(a, b + 1):
        if i in excluded_ints:
            if cur_start is not None:
                out_pairs.append((cur_start, i - 1))
                cur_start = None
        else:
            if cur_start is None:
                cur_start = i
    if cur_start is not None:
        out_pairs.append((cur_start, b))
    return ",".join(f"{_ip.IPv4Address(s)}-{_ip.IPv4Address(e)}" for s, e in out_pairs)


def _sync_mikrotik_pool_exclusions(db, company_id: str, pool_name: str):
    """Recompute the effective /ip/pool ranges for `pool_name` in the
    given tenant (raw range minus every pinned IP in that pool) and push
    to every Active NAS of this tenant.  Idempotent and safe — logs but
    doesn't raise on per-NAS failure (e.g. router down)."""
    import ipaddress as _ip
    try:
        from database import Customer
        from radius_network import IpPool, NasDevice
        import routeros_provision as rp
    except Exception as e:
        print(f"[fix-ip pool-sync] import failed: {e}")
        return {"ok": False, "error": str(e)}

    ip_pool = db.query(IpPool).filter(
        IpPool.company_id == company_id,
        IpPool.name == pool_name,
    ).first()
    if not ip_pool or not (ip_pool.start_ip and ip_pool.end_ip):
        return {"ok": False, "reason": "pool_not_found_or_no_range"}

    try:
        a = int(_ip.IPv4Address(ip_pool.start_ip.strip()))
        b = int(_ip.IPv4Address(ip_pool.end_ip.strip()))
        if a > b: a, b = b, a
    except Exception:
        return {"ok": False, "reason": "bad_range"}

    # Gather pinned IPs in this company that fall within the pool range.
    pinned = set()
    rows = db.query(Customer.static_ip_address).filter(
        Customer.company_id == company_id,
        Customer.static_ip_address != "",
    ).all()
    for (sip,) in rows:
        sip = (sip or "").strip()
        if not sip: continue
        try:
            v = int(_ip.IPv4Address(sip))
        except Exception:
            continue
        if a <= v <= b:
            pinned.add(sip)

    ranges_str = _compute_pool_ranges_excluding(ip_pool.start_ip, ip_pool.end_ip, pinned)
    if not ranges_str:
        return {"ok": False, "reason": "empty_ranges"}

    nas_rows = db.query(NasDevice).filter(
        NasDevice.company_id == company_id,
        NasDevice.status == "Active",
    ).all()
    results = []
    for n in nas_rows:
        if not (n.ip_address and n.api_password):
            continue
        try:
            with rp.RouterOSClient(n, dry_run=False) as c:
                res = c.set_pool_ranges(pool_name, ranges_str)
                results.append({"nas_id": n.id, "nas_name": n.name, **res})
        except _ESkipInv:
            pass  # silently skip — registration_type is non-new
        except Exception as e:
            results.append({"nas_id": n.id, "nas_name": n.name, "error": str(e)})
    print(f"[fix-ip pool-sync] company={company_id} pool={pool_name} "
          f"pinned={len(pinned)} ranges={ranges_str} -> {results}")
    return {"ok": True, "pinned": sorted(pinned), "ranges": ranges_str,
            "nas_results": results}


@app.post("/api/customers/{customer_pk}/fix-ip")
async def api_customer_fix_ip(customer_pk: int, request: Request,
                                db: Session = Depends(get_db)):
    """Assign a Public IP to a PPPoE customer for RADIUS Framed-IP-Address.
    NO /ppp secret update — we rely on RADIUS Access-Accept carrying the
    Framed-IP-Address attribute. Works for hotspot/static_ip/pppoe alike."""
    auth = require_auth(request)
    if auth: return JSONResponse({"success": False, "message": "auth"}, status_code=401)
    from database import Customer
    from radius_network import PublicIpAddress
    company_id = request.session.get("company_id")
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    pool = (body.get("pool_name") or "Default").strip()
    ip = (body.get("ip_address") or "").strip()
    source = (body.get("source") or "public").strip().lower()  # __S38O_CONN_TAB__
    if not ip:
        return JSONResponse({"success": False, "message": "ip_address required"}, status_code=400)

    # __S38Q_EXCLUSIVE_FIXIP__ — EXCLUSIVE LOCK: a pinned IP belongs to exactly one
    # customer.  If any OTHER customer in this company already holds this
    # IP as their `static_ip_address`, the admin must first free it from
    # that customer (Fix IP = No on their Connection tab) before we will
    # re-pin it here.  Applies to all three sources — PPPoE, Hotspot,
    # Public — regardless of the holder's online/offline state.
    holder = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.static_ip_address == ip,
        Customer.id != customer_pk,
    ).first()
    if holder:
        return JSONResponse({
            "success": False,
            "message": ("IP " + ip + " is already fixed to "
                        + (holder.username or getattr(holder, "customer_name", "") or ("customer #" + str(holder.id)))
                        + ". Open that subscriber's Connection tab, set Fix IP = No "
                          "(this releases the IP), then retry."),
            "locked_by": {"customer_id": holder.id,
                           "username": holder.username or "",
                           "name": getattr(holder, "customer_name", "") or ""},
        }, status_code=409)

    # --- __S38O_CONN_TAB__ PPPoE / Hotspot pool pinning ---
    # IPs taken from the ip_pools (PPPoE/Hotspot) table aren't tracked in
    # the public_ip_addresses reservation ledger, so we simply free the
    # customer's prior public-IP reservation (if any) and record the new
    # IP on the customer row.  FreeRADIUS emits Framed-IP-Address either
    # way (see freeradius_manager._render_users_file).
    if source in ("pppoe", "hotspot"):
        old_ip = (cust.static_ip_address or "").strip()
        if old_ip and old_ip != ip:
            old_row = db.query(PublicIpAddress).filter(
                PublicIpAddress.company_id == company_id,
                PublicIpAddress.ip_address == old_ip,
                PublicIpAddress.assigned_to == (cust.username or "")).first()
            if old_row:
                old_row.status = "Free"
                old_row.assigned_to = ""
                old_row.assigned_nas_id = None
        cust.static_ip_address = ip
        cust.fix_ip_address = "Yes"
        db.commit()
        # __s56j_pubip_takes_effect_now__ — restart=True forces FreeRADIUS to
        # re-read isp-users so the new Framed-IP-Address is visible to the
        # daemon (the files module caches users at startup); without this
        # the next login still gets the OLD IP. CoA-Disconnect below kicks
        # the live PPPoE session so the customer reconnects automatically
        # and receives the new pinned IP — no manual reboot/reconnect.
        try:
            from radius_network import _sync_freeradius_all_tenants
            _sync_freeradius_all_tenants(db, restart=True)
        except Exception as e:
            return {"success": True, "ip": ip, "pool": pool,
                    "message": f"Assigned but RADIUS sync warn: {e}"}
        try:
            import freeradius_manager as _fm
            from database import NasDevice as _NAS
            _nas = None
            if getattr(cust, "provisioned_nas_id", None):
                _nas = db.query(_NAS).filter(
                    _NAS.company_id == company_id,
                    _NAS.id == int(cust.provisioned_nas_id)).first()
            if _nas and _nas.ip_address:
                _fm.send_coa_disconnect(
                    nas_ip=_nas.ip_address,
                    username=(cust.username or ""),
                    secret=(getattr(_nas, "secret", None) or "testing123"),
                )
        except Exception as _e:
            print(f"[fix-ip/pool kick] {_e}")
        # __S38R_POOL_EXCLUSION__ — exclude the pinned IP from MikroTik's dynamic pool
        # range so user-B can never receive it even while this holder is offline.
        try:
            pool_sync = _sync_mikrotik_pool_exclusions(db, company_id, pool)
        except Exception as e:
            pool_sync = {"ok": False, "error": str(e)}
        try:
            log_admin_activity(db, request, "update", "customer",
                target_id=str(customer_pk),
                summary=f"fixed {source} IP {ip} (pool {pool})")
        except Exception:
            pass
        return {"success": True, "ip": ip, "pool": pool,
                "pool_sync": pool_sync,
                "message": f"Assigned {ip} to {cust.username} and removed it from {pool}'s dynamic range. Customer must reconnect (PPPoE session logout + login) for the pinned IP to take effect."}

    # 1. Release the customer's CURRENT fixed IP (if any) to Free.
    old_ip = (cust.static_ip_address or "").strip()
    if old_ip and old_ip != ip:
        old_row = db.query(PublicIpAddress).filter(
            PublicIpAddress.company_id == company_id,
            PublicIpAddress.ip_address == old_ip,
            PublicIpAddress.assigned_to == (cust.username or "")).first()
        if old_row:
            old_row.status = "Free"
            old_row.assigned_to = ""
            old_row.assigned_nas_id = None

    # 2. Reserve the new IP (must be Free, in the chosen pool, same company).
    row = db.query(PublicIpAddress).filter(
        PublicIpAddress.company_id == company_id,
        PublicIpAddress.ip_address == ip,
        PublicIpAddress.pool_name == pool).first()
    if not row:
        return JSONResponse({"success": False,
            "message": f"{ip} not found in pool {pool}"}, status_code=404)
    if row.status != "Free" and row.assigned_to != (cust.username or ""):
        return JSONResponse({"success": False,
            "message": f"{ip} is already assigned to {row.assigned_to}"}, status_code=409)
    row.status = "Assigned"
    row.assigned_to = cust.username or ""
    row.assigned_nas_id = cust.provisioned_nas_id

    # 3. Update customer record
    cust.static_ip_address = ip
    cust.fix_ip_address = "Yes"
    db.commit()

    # 4. Regenerate FreeRADIUS users file AND restart so the daemon
    # actually re-reads isp-users (the files module caches at startup,
    # so a plain rewrite-without-restart leaves the live daemon serving
    # the stale users — Framed-IP-Address would never be sent until the
    # next manual restart). __s56j_pubip_takes_effect_now__
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=True)
    except Exception as e:
        return JSONResponse({"success": True,
            "message": f"Assigned but RADIUS sync warn: {e}",
            "ip": ip, "pool": pool}, status_code=200)
    # __s56j_kick_session__ — kick the live PPPoE session via CoA-Disconnect
    # so the customer reconnects immediately and gets the pinned IP. Without
    # this the existing session keeps the old IP until a manual reboot.
    try:
        import freeradius_manager as _fm
        from database import NasDevice as _NAS
        _nas = None
        if getattr(cust, "provisioned_nas_id", None):
            _nas = db.query(_NAS).filter(
                _NAS.company_id == company_id,
                _NAS.id == int(cust.provisioned_nas_id)).first()
        if _nas and _nas.ip_address:
            _fm.send_coa_disconnect(
                nas_ip=_nas.ip_address,
                username=(cust.username or ""),
                secret=(getattr(_nas, "secret", None) or "testing123"),
            )
    except Exception as _e:
        print(f"[fix-ip/public kick] {_e}")

    try:
        log_admin_activity(db, request, "update", "customer",
            target_id=str(customer_pk),
            summary=f"fixed public IP {ip} (pool {pool})")
    except Exception:
        pass
    return {"success": True, "ip": ip, "pool": pool,
            "message": f"Assigned {ip} to {cust.username}. Customer must reconnect (PPPoE session logout + login) for the pinned IP to take effect."}


# __S38O_CONN_TAB__ + __S38P_FIXUPS__ ------------------------------------------------------
@app.get("/api/fix-ip/pools")
async def api_fix_ip_pools(request: Request, db: Session = Depends(get_db)):
    """Unified pool list for the Connection tab's Fixed-IP-Pool dropdown.
    Merges PPPoE / Hotspot pools (from ip_pools) with Public IP pools
    (from public_ip_addresses). Each row carries a `source` tag."""
    auth = require_auth(request)
    if auth: return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    from radius_network import PublicIpAddress, IpPool
    from database import Customer
    import ipaddress as _ip
    from sqlalchemy import func
    company_id = request.session.get("company_id")
    rows = []

    # --- ip_pools: PPPoE + Hotspot (enumerate range, count pinned) -----
    # __S38P_FIXUPS__ also exclude IPs held by ONLINE sessions — dynamically
    # leased PPPoE IPs aren't in customers.static_ip_address.
    pinned = {c.static_ip_address.strip()
              for c in db.query(Customer).filter(
                    Customer.company_id == company_id,
                    Customer.static_ip_address != "").all()
              if (c.static_ip_address or "").strip()}
    from radius_network import OnlineUser as _OU
    for o in db.query(_OU).filter(_OU.company_id == company_id,
                                   _OU.status == "Online").all():
        ipx = (o.ip_address or "").strip()
        if ipx:
            pinned.add(ipx)

    pool_rows = db.query(IpPool).filter(
        IpPool.company_id == company_id,
        IpPool.status == "Active").all()
    for p in pool_rows:
        role = (p.role or "PPPoE").lower()
        if role not in ("pppoe", "hotspot"):
            continue
        total = free = 0
        try:
            if p.start_ip and p.end_ip:
                a = int(_ip.IPv4Address(p.start_ip.strip()))
                b = int(_ip.IPv4Address(p.end_ip.strip()))
                if a > b: a, b = b, a
                total = b - a + 1
                # free = total minus pinned addresses inside range
                for i in range(a, b + 1):
                    ipstr = str(_ip.IPv4Address(i))
                    if ipstr not in pinned:
                        free += 1
            elif p.network:
                net = _ip.IPv4Network(p.network.strip(), strict=False)
                hosts = list(net.hosts())
                total = len(hosts)
                free = sum(1 for h in hosts if str(h) not in pinned)
        except Exception:
            total = free = 0
        rows.append({"pool_name": p.name, "source": role,
                     "total": total, "free": free})

    # --- public_ip_addresses pools -------------------------------------
    pub = db.query(
        PublicIpAddress.pool_name,
        func.sum(1).label("total"),
        func.sum(
            (PublicIpAddress.status == "Free").cast(__import__("sqlalchemy").Integer)
        ).label("free"),
    ).filter(PublicIpAddress.company_id == company_id)     .group_by(PublicIpAddress.pool_name).order_by(PublicIpAddress.pool_name).all()
    for r in pub:
        rows.append({"pool_name": (r[0] or "Default"), "source": "public",
                     "total": int(r[1] or 0), "free": int(r[2] or 0)})
    return {"ok": True, "rows": rows}


@app.get("/api/fix-ip/available")
async def api_fix_ip_available(request: Request,
                                pool: str = "",
                                source: str = "public",
                                include_current: str = "",
                                db: Session = Depends(get_db)):
    """List free IPs in the given pool.  `source` selects the backing
    table: `public` -> public_ip_addresses.Free, `pppoe`/`hotspot` ->
    enumerate the ip_pools range and return whatever isn't already
    pinned on some customer."""
    auth = require_auth(request)
    if auth: return JSONResponse({"ok": False, "error": "auth"}, status_code=401)
    company_id = request.session.get("company_id")
    pool = (pool or "").strip()
    include = (include_current or "").strip()
    src = (source or "public").strip().lower()
    if not pool:
        return {"ok": True, "rows": []}

    from radius_network import PublicIpAddress, IpPool
    from database import Customer
    import ipaddress as _ip

    if src == "public":
        q = db.query(PublicIpAddress).filter(
            PublicIpAddress.company_id == company_id,
            PublicIpAddress.pool_name == pool,
        )
        rows = [r for r in q.all() if r.status == "Free" or r.ip_address == include]
        rows.sort(key=lambda r: r.ip_address)
        return {"ok": True, "rows": [
            {"ip": r.ip_address, "label": r.label or "",
             "status": r.status} for r in rows]}

    # pppoe / hotspot — enumerate the range
    p = db.query(IpPool).filter(
        IpPool.company_id == company_id,
        IpPool.name == pool).first()
    if not p:
        return {"ok": False, "message": f"pool {pool} not found", "rows": []}
    pinned = {c.static_ip_address.strip()
              for c in db.query(Customer).filter(
                    Customer.company_id == company_id,
                    Customer.static_ip_address != "").all()
              if (c.static_ip_address or "").strip()}
    # __S38P_FIXUPS__ — also exclude online-session IPs
    from radius_network import OnlineUser as _OU2
    for o in db.query(_OU2).filter(_OU2.company_id == company_id,
                                    _OU2.status == "Online").all():
        ipx = (o.ip_address or "").strip()
        if ipx:
            pinned.add(ipx)
    out = []
    try:
        ips = []
        if p.start_ip and p.end_ip:
            a = int(_ip.IPv4Address(p.start_ip.strip()))
            b = int(_ip.IPv4Address(p.end_ip.strip()))
            if a > b: a, b = b, a
            ips = [str(_ip.IPv4Address(i)) for i in range(a, b + 1)]
        elif p.network:
            net = _ip.IPv4Network(p.network.strip(), strict=False)
            ips = [str(h) for h in net.hosts()]
        for ipstr in ips:
            if ipstr == include or ipstr not in pinned:
                out.append({"ip": ipstr, "label": "",
                            "status": "Current" if ipstr == include else "Free"})
            if len(out) >= 500:
                break
    except Exception as e:
        return {"ok": False, "message": f"range parse error: {e}", "rows": []}
    return {"ok": True, "rows": out}


@app.post("/api/customers/{customer_pk}/capture-mac")
async def api_customer_capture_mac(customer_pk: int, request: Request,
                                    db: Session = Depends(get_db)):
    """Capture the customer's currently-connected MAC from the most
    recent RADIUS/PPPoE session (online_users.mac_address).  Falls back
    to querying the provisioned NAS's /ppp active list directly."""
    auth = require_auth(request)
    if auth: return JSONResponse({"success": False, "message": "auth"}, status_code=401)
    company_id = request.session.get("company_id")
    from database import Customer
    from radius_network import OnlineUser, NasDevice
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    username = (cust.username or "").strip()
    if not username:
        return JSONResponse({"success": False, "message": "customer has no PPPoE username"}, status_code=400)

    # __S38P_FIXUPS__ — STRICT: only ONLINE sessions count.  Stale Offline
    # rows in online_users must not leak another user's MAC (previous bug
    # where an expired customer returned a neighbour's caller-id).
    mac = ""
    src = ""
    # 1. Live NAS probe first (ground truth; filters precisely on username)
    try:
        import routeros_provision as rp
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").first()
        if nas and nas.ip_address and nas.api_password:
            with rp.RouterOSClient(nas, dry_run=False) as c:
                actives = c.list_pppoe_active()
                for a in actives:
                    if (a.get("name") or "").strip() == username:
                        mac = (a.get("caller-id") or "").strip()
                        src = "nas_probe"
                        break
    except Exception:
        pass

    # 2. Fallback to online_users ONLY IF status=='Online'
    if not mac:
        ou = db.query(OnlineUser).filter(
            OnlineUser.company_id == company_id,
            OnlineUser.username == username,
            OnlineUser.status == "Online").order_by(OnlineUser.id.desc()).first()
        if ou and (ou.mac_address or "").strip():
            mac = ou.mac_address.strip()
            src = "online_users"

    # 3. __S38T_STATIC_MAC__ — Static-IP customers have no PPPoE session,
    # so the /ppp/active probe (step 1) and online_users (step 2) may
    # both miss them on routers we couldn't reach for online sync. Fall
    # back to live /ip/arp lookup keyed on the customer's static IP.
    if not mac and (cust.static_ip_address or "").strip() and             (cust.auth_type or "").strip().lower() in ("static_ip", "static-ip", "static"):
        try:
            import routeros_provision as rp
            sip = (cust.static_ip_address or "").strip()
            nas_rows = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").all()
            for n in nas_rows:
                try:
                    with rp.RouterOSClient(n, dry_run=False) as cc:
                        for a in cc._api.path("ip/arp"):
                            if (a.get("address") or "").strip() == sip:
                                cand = (a.get("mac-address") or "").strip()
                                if cand:
                                    mac = cand
                                    src = "arp_static"
                                    break
                    if mac:
                        break
                except Exception:
                    continue
        except Exception:
            pass

    if not mac:
        # tweak the helpful message — different hint for static-IP customers.
        is_static = (cust.auth_type or "").strip().lower() in ("static_ip", "static-ip", "static")
        if is_static:
            hint = ("Static-IP customer not currently transmitting. Make sure the CPE "
                    "at " + (cust.static_ip_address or "?") + " is powered on and connected, "
                    "then click Capture again. (We read the MAC from the router's ARP table.)")
        else:
            hint = ("This customer is NOT currently online. Ask them to connect "
                    "(PPPoE dial-in) from the device you want to bind, then click "
                    "Capture again.")
        return JSONResponse({"success": False, "message": hint, "mac": ""},
                             status_code=404)

    mac = mac.upper().replace("-", ":").strip()
    cust.mac_address = mac
    db.commit()
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=False)
    except Exception:
        pass
    return {"success": True, "mac": mac, "source": src or "live"}


@app.post("/api/customers/{customer_pk}/fix-ip/clear")
async def api_customer_fix_ip_clear(customer_pk: int, request: Request,
                                      db: Session = Depends(get_db)):
    """Release the customer's fixed IP back to the pool."""
    auth = require_auth(request)
    if auth: return JSONResponse({"success": False, "message": "auth"}, status_code=401)
    from database import Customer
    from radius_network import PublicIpAddress
    company_id = request.session.get("company_id")
    _prev_pool = ""
    _cust_row = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if _cust_row and _cust_row.static_ip_address:
        from radius_network import IpPool as _IP
        import ipaddress as _ipmod
        try:
            _ipval = int(_ipmod.IPv4Address(_cust_row.static_ip_address.strip()))
        except Exception:
            _ipval = None
        if _ipval is not None:
            for _p in db.query(_IP).filter(_IP.company_id == company_id).all():
                try:
                    _a = int(_ipmod.IPv4Address((_p.start_ip or '').strip()))
                    _b = int(_ipmod.IPv4Address((_p.end_ip or '').strip()))
                    if _a > _b: _a, _b = _b, _a
                    if _a <= _ipval <= _b:
                        _prev_pool = _p.name
                        break
                except Exception:
                    continue
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "not found"}, status_code=404)
    old_ip = (cust.static_ip_address or "").strip()
    if old_ip:
        row = db.query(PublicIpAddress).filter(
            PublicIpAddress.company_id == company_id,
            PublicIpAddress.ip_address == old_ip).first()
        if row:
            row.status = "Free"
            row.assigned_to = ""
            row.assigned_nas_id = None
    cust.static_ip_address = ""
    cust.fix_ip_address = "No"
    db.commit()
    # __S38R_POOL_EXCLUSION__: re-add the freed IP to MikroTik's dynamic range
    try:
        if _prev_pool:
            _sync_mikrotik_pool_exclusions(db, company_id, _prev_pool)
    except Exception as _e:
        print(f'[fix-ip/clear pool-sync] failed: {_e}')
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=True)
    except Exception:
        pass
    # __s56j_release_kick__ — drop the live session so the customer
    # reconnects onto the dynamic pool immediately.
    try:
        import freeradius_manager as _fm
        from database import NasDevice as _NAS
        _nas = None
        if getattr(cust, "provisioned_nas_id", None):
            _nas = db.query(_NAS).filter(
                _NAS.company_id == company_id,
                _NAS.id == int(cust.provisioned_nas_id)).first()
        if _nas and _nas.ip_address:
            _fm.send_coa_disconnect(
                nas_ip=_nas.ip_address,
                username=(cust.username or ""),
                secret=(getattr(_nas, "secret", None) or "testing123"),
            )
    except Exception as _e:
        print(f"[fix-ip/release kick] {_e}")
    try:
        log_admin_activity(db, request, "update", "customer",
            target_id=str(customer_pk),
            summary=f"released public IP {old_ip}")
    except Exception:
        pass
    return {"success": True, "released": old_ip,
            "message": "Fixed IP released. Live session kicked — next reconnect uses the regular pool."}

if __name__ == "__main__":
    uvicorn.run(app, host="127.0.0.1", port=8002)


# ============ Session 23.3 Subscriber edit endpoints ============
@app.post("/api/subscribers/{customer_pk}/details-save")
async def api_subscriber_details_save(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Save basic details + address from the Subscriber page Edit modal."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    # __S38T_DETAILS_FIELD_GUARD__ — Sub-LCO + Employee can edit profile
    # but MUST NOT change contact-of-record fields (email / mobile /
    # address). Strip server-side so a crafted POST cannot bypass the
    # disabled UI inputs.
    _ut_g = (request.session.get('user_type') or '').lower()
    if _ut_g in ('sub_lco', 'employee') and isinstance(body, dict):
        for _bf in ('customer_email', 'customer_phone', 'alt_mobile',
                    'address', 'locality', 'city', 'state', 'pincode',
                    'billing_address', 'billing_locality', 'billing_city',
                    'billing_state', 'billing_pincode'):
            body.pop(_bf, None)
    # whitelist
    for f in ["customer_name", "username", "customer_phone", "alt_mobile", "customer_email",
              "id_proof", "id_proof_no", "auto_renew", "service_type",
              "address", "locality", "city", "state", "pincode", "latitude", "longitude",
              "billing_address", "billing_locality", "billing_city",
              "billing_state", "billing_pincode",
              "customer_gst_no", "gst_invoice_needed", "payment_notes"]:
        if f in body:
            setattr(cust, f, body[f])
    db.commit()
    return {"success": True, "message": "Details saved"}


@app.post("/api/subscribers/{customer_pk}/connection-save")
async def api_subscriber_connection_save(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Save connection tab fields."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    # __S38O_CONN_TAB__: simplified fields + inverse translation for notification toggles
    for f in ["fix_ip_address", "bind_mac_address", "mac_address"]:
        if f in body:
            setattr(cust, f, str(body[f] or "").strip())
    # UI exposes send_sms / send_whatsapp / send_email (Yes = do send).
    # DB keeps legacy do_not_send_* columns.  Translate: Yes -> No (send),
    # No -> Yes (do NOT send).  Legacy callsites remain untouched.
    _ui2db = {"send_sms": "do_not_send_sms",
              "send_whatsapp": "do_not_send_whatsapp",
              "send_email": "do_not_send_email"}
    for ui_key, db_key in _ui2db.items():
        if ui_key in body:
            v = (str(body[ui_key] or "").strip().lower())
            setattr(cust, db_key, "No" if v in ("yes", "true", "1") else "Yes")
    # Legacy direct writes still honoured (back-compat for other callers).
    for f in ["do_not_send_sms", "do_not_send_whatsapp", "do_not_send_email",
              "zone", "node", "distance_from_node", "reset_mac_flag",
              "leased_line_subscriber"]:
        if f in body:
            setattr(cust, f, str(body[f]))
    if "allow_devices" in body:
        try:
            cust.allow_devices = int(body["allow_devices"])
        except Exception:
            pass
    # __S43V_SHOW_USAGE__ Yes/No → 1/0
    if "show_data_usage" in body:
        v = str(body["show_data_usage"] or "").strip().lower()
        cust.show_data_usage = 1 if v in ("yes", "true", "1") else 0
    db.commit()
    # MAC-bind / send_* changes may affect the FreeRADIUS users file
    # (Calling-Station-Id check-item).  Resync quietly.
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=False)
    except Exception:
        pass
    return {"success": True, "message": "Connection settings saved"}


@app.post("/api/subscribers/{customer_pk}/change-password")
async def api_subscriber_change_password(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Update PPPoE password for this subscriber + sync to FreeRADIUS."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    pw = (body.get("password") or "").strip()
    pw2 = (body.get("confirm") or "").strip()
    if not pw or len(pw) < 4:
        return JSONResponse({"success": False, "message": "password must be at least 4 characters"}, status_code=400)
    if pw != pw2:
        return JSONResponse({"success": False, "message": "passwords do not match"}, status_code=400)
    cust.pppoe_password = pw
    # s40q: per user request — admin-side PPPoE password changes for
    # EXISTING customers must NOT overwrite the user's portal/app
    # login password. (Mirror only happens on customer create.)
    db.commit()
    # 1. Trigger FreeRADIUS sync
    fr_msg = ""
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=False)
        fr_msg = "RADIUS synced"
    except Exception as e:
        fr_msg = f"RADIUS sync failed: {e}"
    # 2. Push to MikroTik /ppp secret (so local-auth path also matches,
    #    otherwise Mikrotik would keep rejecting the new password locally
    #    before it ever reaches RADIUS). Session 24.3.
    router_msg = ""
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").first()
        if nas and cust.username:
            with rp.RouterOSClient(nas, dry_run=False) as c:
                c.create_pppoe_secret(
                    cust.username, pw,
                    profile=(cust.plan_profile or "isp-default")
                            if hasattr(cust, "plan_profile") else "isp-default")
            router_msg = f"pushed to {nas.name or nas.ip_address}"
            # Kick current session so CPE re-auths with the new secret
            try:
                with rp.RouterOSClient(nas, dry_run=False) as c2:
                    actives = c2._api.path("ppp/active")
                    for a in actives:
                        if (a.get("name") or "").strip() == cust.username:
                            # librouteros Path.remove takes the id positionally
                            try:
                                actives.remove(a[".id"])
                            except TypeError:
                                # older librouteros
                                actives("remove", **{".id": a[".id"]})
                            router_msg += " + session kicked"
                            break
            except Exception as e:
                router_msg += f" (kick err: {e})"
        else:
            router_msg = "no active NAS / username - router NOT updated"
    except Exception as e:
        router_msg = f"router push failed: {e}"

    # _S40_AUTOPROV_ — TR-069 auto-push to ONUs linked to this customer
    tr069_msg = ""
    try:
        from olt_routes import _genieacs_auto_push as _gap, engine as _olt_eng
        with _olt_eng.begin() as _c:
            _onus = _c.exec_driver_sql(
                "SELECT id FROM onus WHERE company_id=? AND customer_id=?",
                (company_id, cust.customer_id)).fetchall()
        if _onus:
            _ok_n = 0
            for (_oid,) in _onus:
                _r = _gap(company_id, _oid,
                         reason="pppoe pw change")
                if _r.get("ok"):
                    _ok_n += 1
            tr069_msg = (f"pushed to {_ok_n}/{len(_onus)} ONU(s)"
                         if _ok_n else f"queued to {len(_onus)} ONU(s) (ACS not yet acked)")
        else:
            tr069_msg = "no linked ONU"
    except Exception as e:
        tr069_msg = f"TR-069 push failed: {e}"

    return {"success": True,
            "message": (f"Password saved to DB ✓ | RADIUS: {fr_msg} | "
                        f"MikroTik: {router_msg} | TR-069: {tr069_msg}")}  # _S39R5FIX13_


# ============ Session 23.4 Subscriber addons ============

@app.get("/api/subscribers/{customer_pk}/access-logs")
async def api_subscriber_access_logs(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Return access-request events for a subscriber.

    Session 24 contract:
      stored_password   = password currently on the Mikrotik /ppp secret
                          (the ground-truth the router uses for LOCAL auth).
                          Falls back to DB if the router is unreachable.
      detected_password = latest password the end-user's CPE actually tried
                          (pulled from FreeRADIUS radpostauth, regardless of
                          accept/reject).
      events            = merged timeline of app log + radpostauth +
                          live /ppp/active sessions. For /ppp/active we
                          compute the REAL session start time (now-uptime)
                          so the timestamp does not advance on every refresh.
    """
    import os as _os, sqlite3 as _sq, re as _re
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)

    # ---- Stored password = Mikrotik /ppp secret (ground truth) ----
    stored_password = ""
    router_name = ""
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").first()
        if nas:
            router_name = nas.name or nas.ip_address or ""
            with rp.RouterOSClient(nas, dry_run=False) as c:
                for r in c._api.path("ppp/secret"):
                    if (r.get("name") or "").strip() == cust.username:
                        stored_password = str(r.get("password") or "").strip()
                        break
    except Exception:
        pass
    # DB fallback if router unreachable
    if not stored_password:
        stored_password = cust.pppoe_password or ""

    events = []
    detected_password = ""
    detected_ts = ""

    # 1) App-side AccessRequestLog (auth + accounting)
    try:
        from radius_network import AccessRequestLog
        rows = (db.query(AccessRequestLog)
                  .filter(AccessRequestLog.company_id == company_id,
                          AccessRequestLog.username == cust.username)
                  .order_by(AccessRequestLog.created_at.desc())
                  .limit(200).all())
        for r in rows:
            events.append({
                "ts": _tzu_ist_str(r.created_at),  # _GLOBAL_TZ_FIX_V2_
                "type": r.request_type or "Auth",
                "status": r.status or "",
                "reason": _simplify_auth_reason(r.reason or "", r.status or ""),
                "nas_ip": r.nas_ip or "",
                "mac": "",
                "ip": r.ip_address or "",
                "password": "",
                "source": "app",
            })
    except Exception:
        pass

    # 2) FreeRADIUS radpostauth - has the actual password the CPE sent.
    try:
        radacct_path = _os.getenv("RADACCT_DB_PATH", "/var/lib/freeradius/radacct.db")
        if _os.path.exists(radacct_path):
            con = _sq.connect(radacct_path); cur = con.cursor()
            cur.execute("PRAGMA table_info(radpostauth)")
            rp_cols = {r[1] for r in cur.fetchall()}
            has_nas = "nasipaddress" in rp_cols
            has_caller = "callingstationid" in rp_cols
            has_reason = "reason" in rp_cols
            sel = "authdate, pass, reply, class"
            if has_nas: sel += ", nasipaddress"
            if has_caller: sel += ", callingstationid"
            if has_reason: sel += ", reason"
            # S42J — ensure new rows are mapped, then strict company_id fence.
            try:
                from radpostauth_tenant import backfill_company_id as _rp_bf2
                _rp_bf2(db, radacct_path=radacct_path, limit=2000)
            except Exception:
                pass
            cur.execute(f"""SELECT {sel} FROM radpostauth
                           WHERE username = ?
                             AND company_id = ?
                           ORDER BY authdate DESC LIMIT 200""",
                        (cust.username, str(cust.company_id)))
            for row in cur.fetchall():
                dt, pw, reply, cls = row[0], row[1], row[2], row[3]
                idx = 4
                nas_ip = row[idx] if has_nas else ""; idx += 1 if has_nas else 0
                caller = row[idx] if has_caller else ""; idx += 1 if has_caller else 0
                reason = row[idx] if has_reason else ""
                # _GLOBAL_TZ_FIX_V2_ : radpostauth.authdate is server-local IST.
                ts_out = _tzu_ist_local_str(dt)
                # Capture the most-recent non-empty password as "Detected"
                if pw and not detected_password:
                    detected_password = str(pw).strip()
                    detected_ts = ts_out
                events.append({
                    "ts": ts_out,
                    "type": "Auth",
                    "status": ("Accept" if (reply or "").lower().startswith("access-accept")
                               else ("Reject" if (reply or "").lower().startswith("access-reject")
                                     else (reply or "-"))),
                    "reason": _simplify_auth_reason(reason or "", reply or ""),
                    "nas_ip": nas_ip or cls or "",
                    "mac": caller or "",
                    "ip": "",
                    "password": pw or "",
                    "source": "radius",
                })
            con.close()
    except Exception:
        pass

    # 3) MikroTik /ppp/active - live/current session carries the real MAC.
    #    Derive the ACTUAL login timestamp so it does not drift on refresh.
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        from datetime import datetime as _dt, timedelta as _td
        nas_qs = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active").all()

        def _parse_uptime(s):
            """RouterOS uptime like '1w2d3h4m5s' -> seconds."""
            if not s: return 0
            mults = {"w": 604800, "d": 86400, "h": 3600, "m": 60, "s": 1}
            total = 0
            for num, unit in _re.findall(r"(\d+)([wdhms])", str(s)):
                total += int(num) * mults.get(unit, 0)
            return total

        for nas in nas_qs:
            try:
                with rp.RouterOSClient(nas, dry_run=False) as c:
                    for a in c._api.path("ppp/active"):
                        if (a.get("name") or "").strip() == cust.username:
                            upt = _parse_uptime(a.get("uptime") or "")
                            start = _dt.utcnow() - _td(seconds=upt)
                            events.append({
                                "ts": _tzu_ist_str(start),  # _TZ_FIX_ROUND2_  (canonical IST string)
                                "type": "PPPoE",
                                "status": "Accept",
                                "reason": "Live session on " + (nas.name or nas.ip_address),
                                "nas_ip": nas.ip_address or "",
                                "mac": a.get("caller-id") or "",
                                "ip": a.get("address") or "",
                                "password": "",
                                "source": "router",
                            })
            except Exception:
                pass
    except Exception:
        pass

    # Sort newest first
    events.sort(key=lambda e: e.get("ts", ""), reverse=True)

    in_sync = bool(stored_password) and (stored_password == detected_password)
    return {
        "success": True,
        "username": cust.username,
        "stored_password": stored_password,
        "detected_password": detected_password,
        "detected_ts": detected_ts,
        "router_name": router_name,
        "in_sync": in_sync,
        "events": events,
    }



@app.post("/api/subscribers/{customer_pk}/save-detected-password")
async def api_subscriber_save_detected_password(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Persist the detected password to:
      1. our DB (cust.pppoe_password)
      2. FreeRADIUS isp-users (rebuild + reload freeradius so the new
         password takes effect for the next Access-Request)

    NOTE (Session 39H): Previously this endpoint also pushed the password
    to the Mikrotik's /ppp secret table. That path is intentionally REMOVED
    because Mikrotik checks /ppp/secret BEFORE consulting RADIUS — having a
    matching local secret short-circuits RADIUS and made the customer
    appear to authenticate "via the router" instead of FreeRADIUS, which
    is what the user explicitly wants for centralised auth.
    """
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    pw = (body.get("password") or "").strip()
    if not pw:
        return JSONResponse({"success": False, "message": "password required"}, status_code=400)
    # 1. DB
    cust.pppoe_password = pw
    # s40q: per user request — admin-side PPPoE password changes for
    # existing customers must NOT overwrite the user's portal/app login
    # password. (Mirror only happens on customer create.)
    db.commit()
    # 2. FreeRADIUS — rebuild isp-users + restart so the new password is
    #    immediately usable on the very next dial-in attempt.
    fr_msg = ""
    try:
        from radius_network import _build_customer_radius_rows_global
        import freeradius_manager as fm
        cust_rows = _build_customer_radius_rows_global(db, company_id)
        res = fm.sync_users_file(cust_rows, restart=True)
        if res.get("success"):
            fr_msg = f"isp-users rewritten ({res.get('users_written', 0)} users), freeradius reloaded"
        else:
            fr_msg = f"FreeRADIUS sync failed: {res.get('message', 'unknown')}"
    except Exception as e:
        fr_msg = f"FreeRADIUS sync failed: {e}"
    return {"success": True,
            "message": f"Password saved to DB. {fr_msg}. RADIUS will now accept this password on the next dial-in."}

@app.post("/api/subscribers/{customer_pk}/capture-detected-password")
async def api_subscriber_capture_detected(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """CRITICAL-PATH endpoint: detect what the end-user's CPE is actually
    dialling with RIGHT NOW, even when Mikrotik's local /ppp secret is
    blocking attempts from reaching RADIUS.

    Flow:
      1. Snapshot current /ppp secret (to restore on failure).
      2. Temporarily disable the /ppp secret     -> auth falls through to RADIUS
      3. Force-kick any active /ppp/active row  -> CPE redials immediately
      4. Poll radpostauth for new rows newer than start_ts, for up to 30 s
      5. ALWAYS re-enable the original /ppp secret at the end so the
         subscriber is not stuck offline.

    Returns the detected password (or empty if nothing captured in window).
    """
    import os as _os, sqlite3 as _sq, time as _t
    from datetime import datetime as _dt
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    from radius_network import NasDevice
    import routeros_provision as rp

    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust or not cust.username:
        return JSONResponse({"success": False, "message": "customer not found / no username"}, status_code=404)

    # Pick the NAS this customer is provisioned on
    nas = None
    if cust.provisioned_nas_id:
        nas = db.query(NasDevice).filter(
            NasDevice.id == cust.provisioned_nas_id,
            NasDevice.company_id == company_id).first()
    if not nas:
        nas = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active").first()
    if not nas:
        return {"success": False, "message": "no active NAS available to capture on"}

    start_ts = _dt.utcnow().strftime("%Y-%m-%d %H:%M:%S")
    secret_id = None
    original_disabled = None
    stages = []
    try:
        with rp.RouterOSClient(nas, dry_run=False) as c:
            secrets = c._api.path("ppp/secret")
            # 1. Find the secret row id & snapshot disabled state
            for s in secrets:
                if (s.get("name") or "").strip() == cust.username:
                    secret_id = s[".id"]
                    original_disabled = (str(s.get("disabled") or "false").lower()
                                         in ("true","yes","1"))
                    break
            if not secret_id:
                return {"success": False,
                        "message": f"secret for {cust.username} not found on {nas.name}"}
            # 2. Disable the local secret so auth falls through to RADIUS
            secrets.update(**{".id": secret_id, "disabled": "yes"})
            stages.append("disabled local secret")
            # 3. Remove any active /ppp/active row (forces CPE redial)
            try:
                actives = c._api.path("ppp/active")
                for a in actives:
                    if (a.get("name") or "").strip() == cust.username:
                        actives.remove(**{".id": a[".id"]})
                        stages.append("kicked active session")
                        break
            except Exception as e:
                stages.append(f"kick-err:{e}")

        # 4. Poll radpostauth for a new row
        radacct_path = _os.getenv("RADACCT_DB_PATH", "/var/lib/freeradius/radacct.db")
        detected_pw = ""
        detected_reply = ""
        detected_ts = ""
        attempts_seen = 0
        deadline = _t.time() + 30.0
        while _t.time() < deadline:
            try:
                if _os.path.exists(radacct_path):
                    con = _sq.connect(radacct_path); cur = con.cursor()
                    # S42J — strict tenant fence even on this hot polling path.
                    # Briefly backfill so newly-inserted rows get a company_id.
                    try:
                        from radpostauth_tenant import backfill_company_id as _rp_bf3
                        _rp_bf3(db, radacct_path=radacct_path, limit=200)
                    except Exception:
                        pass
                    cur.execute("""SELECT authdate, pass, reply FROM radpostauth
                                   WHERE username = ? AND authdate >= ?
                                     AND company_id = ?
                                   ORDER BY authdate DESC LIMIT 5""",
                                (cust.username, start_ts, str(cust.company_id)))
                    rows = cur.fetchall()
                    con.close()
                    attempts_seen = len(rows)
                    if rows:
                        dt, pw, reply = rows[0]
                        if pw:
                            detected_pw = str(pw).strip()
                            detected_reply = reply or ""
                            try:
                                detected_ts = dt.split(".")[0].replace(" ", "T") + "Z"
                            except Exception:
                                detected_ts = dt
                            break
            except Exception as e:
                stages.append(f"poll-err:{e}")
            _t.sleep(2.0)

        # 5. Re-enable the local secret (best-effort)
        try:
            with rp.RouterOSClient(nas, dry_run=False) as c2:
                c2._api.path("ppp/secret").update(
                    **{".id": secret_id,
                       "disabled": "yes" if original_disabled else "no"})
                stages.append("restored local secret")
        except Exception as e:
            stages.append(f"restore-err:{e}")

        if detected_pw:
            return {"success": True,
                    "detected_password": detected_pw,
                    "detected_ts": detected_ts,
                    "detected_reply": detected_reply,
                    "attempts": attempts_seen,
                    "stages": stages,
                    "message": f"Captured '{detected_pw}' (reply: {detected_reply or 'n/a'})"}
        return {"success": False,
                "detected_password": "",
                "attempts": attempts_seen,
                "stages": stages,
                "message": ("No new auth attempt reached RADIUS in 30 s. "
                            "CPE may be offline, or Mikrotik is not forwarding "
                            "to RADIUS (check /ppp aaa use-radius=yes and the "
                            "profile's use-radius setting).")}
    except Exception as e:
        # Safety: always try to restore local secret on any failure
        try:
            if secret_id is not None:
                with rp.RouterOSClient(nas, dry_run=False) as c3:
                    c3._api.path("ppp/secret").update(
                        **{".id": secret_id,
                           "disabled": "yes" if original_disabled else "no"})
                stages.append("restored on error")
        except Exception:
            pass
        return {"success": False, "message": f"capture error: {e}", "stages": stages}




def _simplify_auth_reason(raw, status):
    """Collapse verbose FreeRADIUS failure messages into short UI labels."""
    # status may be Access-Accept (from radpostauth.reply) OR Accept (app status)
    sl = (status or "").lower()
    if "accept" in sl and "reject" not in sl:
        return "Success"
    r = (raw or "").lower()
    if "mschap" in r and ("incorrect" in r or "rejected" in r):
        return "Password Mismatch"
    if "pap" in r and "does not match" in r:
        return "Password Mismatch"
    if "no \"known good\"" in r or "known good password" in r:
        return "Unknown User"
    if "module-failure" in r:
        return "Module Failure"
    if "login incorrect" in r or "reject" in r:
        return "Password Mismatch"
    if not r:
        return "Rejected"
    return raw[:60] if raw else "Rejected"


def _subscriber_sessions_for(db, company_id, customer_pk, since_epoch=None, until_epoch=None, previous_view=False):
    """Helper: fetch radacct session rows for the customer within window.

    S42M:
      - `previous_view=True` (Previous Usage page): hide currently-open
        radacct rows AND do not synthesize a live-session row. The live
        session legitimately belongs on the Current Usage page only.
      - Upload/Download mapping (S42M-BYTES-SWAP): standard FreeRADIUS
        convention says `acctinputoctets` is bytes RX by NAS (user
        upload) and `acctoutputoctets` is bytes TX by NAS (user
        download). In THIS deployment (verified against MikroTik /ppp
        and customer queue counters), the values arrive reversed for
        every PPPoE customer — Upload was consistently shown ~6x
        larger than Download for residential users. We swap globally
        so the figures presented match real-world traffic shape. If a
        future operator needs the opposite, set environment variable
        `RADACCT_BYTES_SWAP=0`.
    """
    import os as _os_bs
    # S42N: align with Online Users page (single source of truth):
    #   bytes_in  (raw radacct/online_users) = subscriber UPLOAD
    #   bytes_out (raw radacct/online_users) = subscriber DOWNLOAD
    # The previous S42M swap was wrong (it disagreed with Online Users
    # page + the live-speed JS at templates/admin_online_users.html).
    # Default OFF; can be re-enabled per-deployment via env if a future
    # tenant runs an inverted MikroTik profile.
    _BYTES_SWAP = _os_bs.getenv("RADACCT_BYTES_SWAP", "0") not in ("0", "false", "False", "")
    import os as _os, sqlite3 as _sq
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return None, []
    radacct_path = _os.getenv("RADACCT_DB_PATH", "/var/lib/freeradius/radacct.db")
    if not _os.path.exists(radacct_path) or not cust.username:
        return cust, []
    con = _sq.connect(radacct_path); cur = con.cursor()
    # S42J — backfill + strict tenant fence by company_id column.
    try:
        from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa5
        _rp_bfa5(db, radacct_path=radacct_path, limit=2000)
    except Exception:
        pass
    where = "WHERE username = ? AND company_id = ?"
    params = [cust.username, str(cust.company_id)]
    if since_epoch is not None:
        # _BUG1_FIX_ : include rows whose session is STILL active
        # (acctstoptime IS NULL/0) even if they started BEFORE the
        # window, so the "current session" page never shows blank
        # while the customer is online.
        where += " AND (acctstarttime >= ? OR IFNULL(acctstoptime,0) = 0)"
        params.append(since_epoch)
    if until_epoch is not None:
        where += " AND acctstarttime < ?"
        params.append(until_epoch)
    cur.execute(f"""SELECT acctstarttime, acctstoptime, acctsessiontime,
                           acctinputoctets, acctoutputoctets,
                           nasipaddress, callingstationid, framedipaddress,
                           framedipv6address, acctterminatecause
                    FROM radacct {where}
                    ORDER BY acctstarttime DESC""", params)
    sessions = []
    from datetime import datetime as _dt2, timedelta as _td2
    def _fmt_ist(epoch):
        # Session 25.7: radacct stores Unix epoch. Format as DD-MM-YYYY HH:MM IST.
        if not epoch:
            return ""
        try:
            return (_dt2.utcfromtimestamp(int(epoch)) + _td2(hours=5, minutes=30)).strftime("%d-%m-%Y %H:%M")
        except Exception:
            return str(epoch)
    # _BUG2_FIX_ : only the SINGLE most-recent row with NULL stop is
    # truly live. All other NULL stops are orphan records (router
    # restarted / lost the Acct-Stop). Sort by start DESC and mark.
    # _BUG1B_LIVE_PIN_ : pin the live session to TOP of the list.
    rows = list(cur.fetchall())
    # Sort: live (NULL stop) first by start DESC, then closed by start DESC
    rows.sort(key=lambda r: (
        0 if (not r[1]) else 1,            # live first
        -(int(r[0]) if r[0] else 0)         # then by start DESC
    ))
    # _TZ_FIX_ROUND3_ : only treat as "currently online" if the row
    # also exists in the live `online_users` cache (synced from
    # MikroTik /ppp/active every 90s).  Stale NULL-stop rows from
    # weeks ago should be labelled accordingly, not "online".
    # _S58AG_PG_  Read live usernames from Postgres (the daemon writes
    # only to Postgres now; the old sqlite cache is permanently stale).
    # Use EXTRACT(EPOCH FROM (NOW() - updated_at)) so the freshness check
    # works on TIMESTAMPTZ columns.
    _live_usernames = set()
    try:
        from db_compat import get_raw_conn as _g_live
        _cl = _g_live(timeout=8)
        try:
            _cur_live = _cl.execute(
                "SELECT username FROM online_users "
                " WHERE company_id=%s "
                "   AND LOWER(COALESCE(status,'')) IN ('online','walledgarden') "
                "   AND (updated_at IS NULL OR "
                "        EXTRACT(EPOCH FROM (NOW() - updated_at)) <= 1800)",
                (company_id,))
            _live_usernames = {r[0] for r in _cur_live.fetchall() if r and r[0]}
        finally:
            try: _cl.close()
            except Exception: pass
    except Exception as _e_live_pg:
        # Fallback (unlikely): try the legacy SQLite cache if Postgres lookup fails.
        try:
            import sqlite3 as _sq_live
            with _sq_live.connect(
                    "file:/var/lib/autoispbilling/autoispbilling.db?mode=ro",
                    uri=True, timeout=5) as _cl_s:
                _live_usernames = {row[0] for row in _cl_s.execute(
                    "SELECT username FROM online_users "
                    " WHERE company_id=? AND LOWER(IFNULL(status,'')) IN ('online','walledgarden') "
                    "   AND (updated_at IS NULL OR "
                    "        CAST((julianday('now') - julianday(updated_at))*86400 AS INTEGER) <= 1800)",
                    (company_id,)).fetchall() if row[0]}
        except Exception:
            pass
    _truly_live = bool(cust and cust.username in _live_usernames)
    # _PERF_AND_LIVESESSION_FIX_V1_ : a NULL-stop radacct row is only "currently online"
    # if its start time is also recent (within 24h).  Older NULL-stop
    # rows are orphans — the router restarted/lost the session.
    # S42K-PARKED-LIVE: long-running walled-garden / parked sessions
    # can stay open for weeks. If `_truly_live` is True (online_users
    # cache confirms the session is still alive — including Parked /
    # WalledGarden), trust the cache regardless of session age.
    import time as _t_live
    _recent_cutoff = int(_t_live.time()) - 24 * 3600
    seen_live = False
    for r in rows:
        start, stop, secs, inp, outp, nas, mac, ip, ipv6, cause = r
        try:
            _start_epoch = int(start) if start is not None else 0
        except Exception:
            _start_epoch = 0
        # S42M-PREVIOUS-VIEW: on Previous Usage pages, open sessions
        # must NOT appear at all — they belong to Current Usage. Skip
        # any radacct row whose acctstoptime is NULL when we're
        # rendering historical view.
        if previous_view and (not stop):
            continue
        _is_recent = _start_epoch >= _recent_cutoff
        # S42K: if the cache says this customer is currently live (Online
        # or WalledGarden), accept the first open radacct row as `is_live`
        # even if it started weeks ago (e.g. a parked customer who's been
        # in the walled garden continuously).
        is_live = (not stop) and (not seen_live) and _truly_live
        # === S41Y-SKIP-STALE ===
        # Hide truly-stale rows (NULL-stop AND not "live" AND
        # started > 24h ago) from the sessions table — they confuse the
        # admin (e.g. "21 hrs 47 mins" labels next to current sessions).
        if (not stop) and (not is_live) and (not _is_recent):
            continue
        if is_live:
            seen_live = True
            stop_label = "(currently online)"
        elif not stop:
            stop_label = "(stale — router lost the session)"
        else:
            stop_label = _fmt_ist(stop)
        sessions.append({
            "start": _fmt_ist(start),
            "stop": stop_label,
            "is_live": is_live,
            "secs": secs or 0,
            # S42M-BYTES-SWAP: see docstring at top of fn.
            "up_mb":    ((outp or 0) if _BYTES_SWAP else (inp or 0))  / 1048576.0,
            "down_mb":  ((inp  or 0) if _BYTES_SWAP else (outp or 0)) / 1048576.0,
            "total_mb": ((inp or 0) + (outp or 0)) / 1048576.0,
            "nas": nas or "", "mac": mac or "", "ip": ip or "",
            "ipv6": ipv6 or "", "cause": cause or "",
        })
    con.close()
    # _SYNTHETIC_LIVE_ROW_V1_ : If the customer is TRULY live (online_users cache
    # says so) but the loop above never produced an `is_live` row — typically
    # because FreeRADIUS accounting is broken or radacct hasn't received the
    # new session yet — synthesize a live row from online_users so the admin
    # sees the active PPPoE session that just came up (router reboot,
    # reconnect, etc).
    # S42M-PREVIOUS-VIEW: skip on Previous Usage pages.
    if _truly_live and not seen_live and not previous_view:
        try:
            from datetime import datetime as _dt_live, timedelta as _td_live
            # _S58AG_PG_  Synthetic live row also from Postgres now.
            from db_compat import get_raw_conn as _g_syn
            _cl2 = _g_syn(timeout=8)
            try:
                _cur_syn = _cl2.execute(
                    "SELECT username, ip_address, mac_address, nas_ip, "
                    "       started_at, uptime_seconds, bytes_in, bytes_out, "
                    "       framed_protocol, updated_at "
                    "  FROM online_users "
                    " WHERE company_id=%s AND username=%s "
                    "   AND LOWER(COALESCE(status,'')) IN ('online','walledgarden') "
                    " ORDER BY id DESC LIMIT 1",
                    (company_id, cust.username))
                _r_tup = _cur_syn.fetchone()
            finally:
                try: _cl2.close()
                except Exception: pass
            # Convert tuple to dict so the legacy index-by-name code keeps
            # working unchanged.
            _row = None
            if _r_tup:
                _row = {
                    "username": _r_tup[0], "ip_address": _r_tup[1],
                    "mac_address": _r_tup[2], "nas_ip": _r_tup[3],
                    "started_at": _r_tup[4], "uptime_seconds": _r_tup[5],
                    "bytes_in": _r_tup[6], "bytes_out": _r_tup[7],
                    "framed_protocol": _r_tup[8], "updated_at": _r_tup[9],
                }
            if _row:
                # _LIVE_START_FROM_UPTIME_V1_ : compute the TRUE session start from the
                # MikroTik-reported uptime. The DB `started_at` column may be stale
                # (some sync paths set it only on first-insert).  When uptime is
                # known, prefer `now_utc - uptime`. Fall back to stored value only
                # if uptime is 0/missing.
                def _parse_dt(s):
                    if not s: return None
                    # psycopg2 returns native datetime objects; sqlite path
                    # returns ISO strings. Normalise to naive UTC.
                    if isinstance(s, _dt_live):
                        if s.tzinfo is not None:
                            from datetime import timezone as _tz
                            s = s.astimezone(_tz.utc).replace(tzinfo=None)
                        return s
                    try:
                        s = str(s).split(".")[0].split("+")[0].rstrip("Z")
                        if "T" in s:
                            return _dt_live.strptime(s, "%Y-%m-%dT%H:%M:%S")
                        return _dt_live.strptime(s, "%Y-%m-%d %H:%M:%S")
                    except Exception:
                        return None
                _uptime_s = 0
                try:
                    _uptime_s = int(_row["uptime_seconds"] or 0)
                except Exception:
                    _uptime_s = 0
                _now_utc = _dt_live.utcnow()
                if _uptime_s > 0:
                    _started_utc = _now_utc - _td_live(seconds=_uptime_s)
                else:
                    _started_utc = _parse_dt(_row["started_at"])
                if _started_utc:
                    _started_str = (_started_utc + _td_live(hours=5, minutes=30)
                                    ).strftime("%d-%m-%Y %H:%M")
                else:
                    _started_str = ""
                # === S41Y-SYN-LIVE-MB-FIX ===
                # online_users.bytes_in / bytes_out are stored in MB
                # (see radius_network.py:310-311 + 947+1040+1094 polling
                # paths). Previous code re-divided by 1048576 → produced
                # KB-scale numbers for live sessions even when actual usage
                # was GB. Use values as-is (they are already MB).
                _live_session = {
                    "start": _started_str,
                    "stop": "(currently online)",
                    "is_live": True,
                    "secs": int(_row["uptime_seconds"] or 0),
                    # S42M-BYTES-SWAP: align with radacct row mapping.
                    "up_mb":   (float(_row["bytes_out"] or 0) if _BYTES_SWAP
                                else float(_row["bytes_in"]  or 0)),
                    "down_mb": (float(_row["bytes_in"]  or 0) if _BYTES_SWAP
                                else float(_row["bytes_out"] or 0)),
                    "total_mb": (float(_row["bytes_in"]  or 0) +
                                  float(_row["bytes_out"] or 0)),
                    "nas":  _row["nas_ip"]      or "",
                    "mac":  _row["mac_address"] or "",
                    "ip":   _row["ip_address"]  or "",
                    "ipv6": "",
                    "cause": "",
                    "_source": "online_users_cache",
                }
                # Apply the same window filter the radacct query used so the
                # synthetic row only appears on the right page (current vs previous).
                _show = True
                if _started_utc:
                    _epoch = int(_started_utc.timestamp())
                    if since_epoch is not None and _epoch < since_epoch:
                        _show = False
                    if until_epoch is not None and _epoch >= until_epoch:
                        _show = False
                if _show:
                    # Pin to top of list.
                    sessions.insert(0, _live_session)
        except Exception as _e_live:
            print(f"[live-row] {cust.username}: {_e_live}")
    return cust, sessions


@app.get("/admin/subscribers/{customer_pk}/usage/current", response_class=HTMLResponse)
async def admin_subscriber_usage_current(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Current calendar-month session report for the subscriber.
    s26.17f: usage-pagination — paginate 25 latest rows per page."""
    import time
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    context = get_admin_context(request, db, "users")
    company_id = request.session.get("company_id")
    now = datetime.now()
    month_start = datetime(now.year, now.month, 1)
    since = int(month_start.timestamp())
    cust, sessions = _subscriber_sessions_for(db, company_id, customer_pk, since_epoch=since)
    if not cust:
        from fastapi.responses import RedirectResponse
        return RedirectResponse(url="/admin/users", status_code=303)

    # --- pagination: 25 latest per page ---
    per_page = 25
    try:
        page = max(1, int(request.query_params.get("page", "1") or 1))
    except Exception:
        page = 1
    total = len(sessions)
    pages = max(1, (total + per_page - 1) // per_page)
    if page > pages: page = pages
    start = (page - 1) * per_page
    end   = start + per_page
    page_sessions = sessions[start:end]

    context.update({
        "cust": cust, "sessions": page_sessions,
        "title": "Current Usage",
        "subtitle": f"{month_start.strftime('%B %Y')} - showing {len(page_sessions)} of {total} session(s)",
        "mode": "current",
        "pagination": {"page": page, "pages": pages, "per_page": per_page,
                       "total": total, "start": start + 1 if total else 0,
                       "end": min(end, total)},
    })
    return templates.TemplateResponse("admin_subscriber_usage.html", context)


@app.get("/admin/subscribers/{customer_pk}/usage/previous", response_class=HTMLResponse)
async def admin_subscriber_usage_previous(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """All historic sessions BEFORE current month.
    s39r5j: optional `month=YYYY-MM` query param narrows the window to that month."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    context = get_admin_context(request, db, "users")
    company_id = request.session.get("company_id")
    now = datetime.now()
    month_start = datetime(now.year, now.month, 1)

    # --- optional ?month=YYYY-MM filter ---
    month_q = (request.query_params.get("month") or "").strip()
    since_epoch = None
    until_epoch = int(month_start.timestamp())
    window_label = f"All months before {month_start.strftime('%B %Y')}"
    try:
        if month_q and len(month_q) == 7 and month_q[4] == "-":
            y, m = int(month_q[0:4]), int(month_q[5:7])
            win_start = datetime(y, m, 1)
            win_end = datetime(y + (m // 12), (m % 12) + 1, 1)
            since_epoch = int(win_start.timestamp())
            until_epoch = int(win_end.timestamp())
            window_label = win_start.strftime("%B %Y")
    except Exception:
        # Bad month param — fall back to the all-historic default.
        since_epoch, until_epoch = None, int(month_start.timestamp())

    cust, sessions = _subscriber_sessions_for(db, company_id, customer_pk,
                                               since_epoch=since_epoch,
                                               until_epoch=until_epoch,
                                               previous_view=True)
    if not cust:
        from fastapi.responses import RedirectResponse
        return RedirectResponse(url="/admin/users", status_code=303)
    context.update({
        "cust": cust, "sessions": sessions,
        "title": "All Previous Usage" if not month_q else f"Sessions — {window_label}",
        "subtitle": f"{window_label} - {len(sessions)} session(s)",
        "mode": "previous",
    })
    return templates.TemplateResponse("admin_subscriber_usage.html", context)

@app.post("/api/subscribers/{customer_pk}/clear-access-logs")
async def api_subscriber_clear_access_logs(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Wipe AccessRequestLog + radpostauth rows for this subscriber."""
    import os as _os, sqlite3 as _sq
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    removed_app, removed_rad = 0, 0
    try:
        from radius_network import AccessRequestLog
        q = db.query(AccessRequestLog).filter(
            AccessRequestLog.company_id == company_id,
            AccessRequestLog.username == cust.username)
        removed_app = q.count()
        q.delete(synchronize_session=False)
        db.commit()
    except Exception:
        db.rollback()
    try:
        radacct_path = _os.getenv("RADACCT_DB_PATH", "/var/lib/freeradius/radacct.db")
        if _os.path.exists(radacct_path) and cust.username:
            # S42J — fence by company_id column so other tenants who
            # happen to share this username are NEVER touched.
            con = _sq.connect(radacct_path); cur = con.cursor()
            cur.execute("PRAGMA table_info(radpostauth)")
            _has_cid = any(r[1] == "company_id" for r in cur.fetchall())
            if _has_cid:
                # Ensure recent rows have company_id resolved first.
                try:
                    from radpostauth_tenant import backfill_company_id as _rp_bf
                    _rp_bf(db, radacct_path=radacct_path, limit=5000)
                except Exception:
                    pass
                cur.execute("DELETE FROM radpostauth WHERE username = ? AND company_id = ?",
                            (cust.username, str(company_id)))
            else:
                # Pre-S42J fallback: scope by username alone (legacy path).
                cur.execute("DELETE FROM radpostauth WHERE username = ?", (cust.username,))
            removed_rad = cur.rowcount
            con.commit(); con.close()
    except Exception:
        pass
    return {"success": True, "message": f"Cleared {removed_app} app + {removed_rad} radius log(s)"}

@app.get("/api/subscribers/{customer_pk}/router-password")
async def api_subscriber_router_password(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Read the PPPoE secret directly from the MikroTik router.
    This IS the ground-truth password the subscriber must use to auth."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").first()
        if not nas:
            return {"success": False, "message": "no active NAS found",
                    "router_password": "", "router_name": ""}
        with rp.RouterOSClient(nas, dry_run=False) as c:
            for r in c._api.path("ppp/secret"):
                if (r.get("name") or "").strip() == cust.username:
                    return {"success": True,
                            "router_password": r.get("password") or "",
                            "router_name": nas.name or nas.ip_address or ""}
        return {"success": False, "message": "secret not found on router",
                "router_password": "", "router_name": nas.name or ""}
    except Exception as e:
        return {"success": False, "message": f"router error: {e}",
                "router_password": "", "router_name": ""}


# ============ Session 25.2 Public suspension / payment portal ============

def _pay_status_labels(status, balance):
    s = (status or "Active").strip().lower()
    if s == "suspended":
        return ("Account Suspended",
                "Your account is suspended due to an unpaid balance. "
                "Clear the amount below to reconnect automatically.")
    if s == "expired":
        return ("Subscription Expired",
                "Your subscription has expired. Please pay the balance to renew and reconnect.")
    if s in ("disabled", "deactive", "deactivated"):
        return (f"Account {status}",
                "Your account is currently not active. Please clear the dues below.")
    if s == "terminated":
        return ("Account Terminated",
                "Your account has been terminated. Please contact your ISP.")
    if balance and balance > 0.01:
        return ("Payment Due",
                "An outstanding balance is due on your account.")
    return ("Active",
            "No outstanding balance - service is active.")


@app.get("/pay", response_class=HTMLResponse)
async def pay_lookup(request: Request, db: Session = Depends(get_db)):
    """Tiny self-service lookup: user enters their customer ID, we 302 to /pay/<id>."""
    # _v4719_PAY_DEEPLINK  When the mobile Pay-Now button sends ?cust_id=…,
    # skip the lookup form and 302 straight to /pay/<cust_id>.
    cust_qs = (request.query_params.get("cust_id")
               or request.query_params.get("customer_id")
               or "").strip()
    if cust_qs:
        amt = (request.query_params.get("amount") or "").strip()
        tail = f"?amount={amt}" if amt else ""
        return RedirectResponse(url=f"/pay/{cust_qs}{tail}", status_code=302)
    html = """<!doctype html>
<html><head>
<title>Pay Your Bill</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  body{background:#0f172a;color:#e2e8f0;font-family:-apple-system,sans-serif;
       display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;padding:20px;}
  .box{background:#111827;padding:30px;border-radius:12px;max-width:420px;width:100%;
       border:1px solid #1f2937;text-align:center;}
  input{background:#0b1220;border:1px solid #334155;color:#fff;padding:14px;
        border-radius:8px;width:100%;font-size:16px;margin:10px 0;box-sizing:border-box;}
  button{background:linear-gradient(135deg,#059669,#10b981);border:none;color:#fff;
         padding:14px 24px;border-radius:8px;font-size:16px;font-weight:600;width:100%;
         cursor:pointer;}
  h2{margin:0 0 6px 0;}
  .muted{color:#64748b;font-size:13px;margin-bottom:20px;}
</style></head>
<body><div class="box">
  <h2>Pay Your Bill</h2>
  <div class="muted">Enter your Customer ID to view balance &amp; pay online</div>
  <form onsubmit="location.href='/pay/'+encodeURIComponent(document.getElementById('cid').value.trim());return false;">
    <input id="cid" placeholder="Customer ID (e.g. 75401779)" required autofocus data-testid="pay-lookup-input">
    <button type="submit" data-testid="pay-lookup-submit">Continue &rarr;</button>
  </form>
</div></body></html>"""
    return HTMLResponse(html)


@app.get("/pay/captive", response_class=HTMLResponse)
async def pay_captive(request: Request, db: Session = Depends(get_db)):
    """s26.8: captive-auto-identify
    Walled-garden users dst-nat'd here get auto-identified via a
    Mikrotik /ppp/active lookup. If exactly one walled-garden user is
    connected through the NAS whose public IP matches the incoming
    request, we 302 straight to /pay/<customer_id> so they don't have
    to type their ID. Fallbacks: picker for multiple, plain /pay
    lookup for zero / error.
    """
    # X-Real-IP is the Mikrotik's WAN IP after masquerade.
    src_ip = (request.headers.get("x-real-ip")
              or (request.headers.get("x-forwarded-for") or "").split(",")[0].strip()
              or (request.client.host if request.client else ""))
    if not src_ip:
        return RedirectResponse(url="/pay", status_code=302)

    from database import Customer
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
    except Exception:
        return RedirectResponse(url="/pay", status_code=302)

    try:
        nas_rows = db.query(NasDevice).filter(NasDevice.ip_address == src_ip,
                                               NasDevice.status == "Active").all()
    except Exception:
        nas_rows = []
    if not nas_rows:
        # Unknown router in this request. Fall through to manual lookup.
        return RedirectResponse(url="/pay", status_code=302)

    wg_candidates = []  # list of (customer_id, customer_name, phone)
    seen_cids = set()
    for nas in nas_rows:
        try:
            with rp.RouterOSClient(nas, dry_run=False) as rc:
                active = rc.list_pppoe_active()
        except Exception:
            continue
        for row in active:
            username = (row.get("name") or "").strip()
            user_ip  = (row.get("address") or "").strip()
            # s41c: Walled-garden / parking users sit in the parking pool.
            # Historical default was 10.255.x.x; current router config is
            # 10.99.99.x; some tenants configure their own RFC1918 range.
            # Trust the DB status instead of hardcoding a single subnet:
            # any non-Active customer with a live PPPoE session is a
            # parked-captive candidate.
            cust = db.query(Customer).filter(
                Customer.company_id == nas.company_id,
                Customer.username == username).first()
            if not cust:
                continue
            st = (cust.status or "").strip().lower()
            if st == "active":
                continue
            # Best-effort: skip clearly-public IPs (someone manually moved
            # an Expired user back to the real pool). Accept RFC1918 only.
            if not (user_ip.startswith("10.") or user_ip.startswith("192.168.")
                    or user_ip.startswith("172.")):
                continue
            if cust.customer_id in seen_cids:
                continue
            seen_cids.add(cust.customer_id)
            wg_candidates.append({
                "customer_id":    cust.customer_id,
                "customer_name":  cust.customer_name or "",
                "customer_phone": cust.customer_phone or "",
                "masked_phone":   ("*" * 6 + (cust.customer_phone or "")[-4:]
                                   if cust.customer_phone else ""),
                "private_ip":     user_ip,
                "nas_id":         nas.id,
                "status":         cust.status or "",
            })

    # # __CAPTIVE_CONNTRACK_AUTO_ID__
    # ------------------------------------------------------------------
    # ZERO-TOUCH AUTO-IDENTIFY via Mikrotik conntrack.
    #
    # The Mikrotik knows exactly which parking-pool private IP just
    # opened a TCP connection to the cloud. We look it up by matching
    # `reply-dst-address` to (X-Real-IP : X-Real-Port) as observed at
    # nginx -> uvicorn boundary.
    #
    # If we find a unique private IP that ALSO matches one of the
    # parked candidates we already enumerated, redirect straight to
    # that customer's bill. Otherwise fall through to the existing
    # single/zero/multi branches below (form is the last resort).
    # __CAPTIVE_CONNTRACK_DISABLED__
    # Conntrack auto-identify temporarily disabled: iterating
    # /ip/firewall/connection on busy MikroTiks (16k+ rows) was
    # blocking uvicorn workers for 5-30s per request and slowing
    # the whole site. Falls through to phone-lookup form below.
    # TODO: re-enable with server-side `.where()` filter + 1s
    # hard timeout + short-TTL cache shared across workers.
    # ------------------------------------------------------------------

    if len(wg_candidates) == 1:
        return RedirectResponse(url=f"/pay/{wg_candidates[0]["customer_id"]}", status_code=302)

    if len(wg_candidates) == 0:
        return RedirectResponse(url="/pay", status_code=302)

    # # __CAPTIVE_PRIVATE_LOOKUP__
    # Privacy fix: multiple parked users can share the same NAS WAN
    # IP. Never render a list of who they are — instead ask each
    # user to identify themselves by their registered mobile number
    # (full or trailing digits). Match server-side against the
    # parked candidates and 302 ONLY to that one user's own page.
    typed = (request.query_params.get("phone") or "").strip()
    error_msg = ""
    if typed:
        # # __CAPTIVE_PRIVATE_LOOKUP_V2__
        # Normalise: drop non-digits, then trim a leading 91 (India
        # country code) so users typing "+91 9876543210" or
        # "9876543210" both produce the same 10-digit canonical form.
        digits = re.sub(r"\D", "", typed)
        if digits.startswith("91") and len(digits) > 10:
            digits = digits[-10:]
        if len(digits) < 4:
            error_msg = "Please enter at least the last 4 digits of your mobile."
        else:
            def _norm(p):
                d = re.sub(r"\D", "", p or "")
                if d.startswith("91") and len(d) > 10:
                    d = d[-10:]
                return d
            matches = [c for c in wg_candidates
                       if _norm(c.get("customer_phone")).endswith(digits)]
            if len(matches) == 1:
                return RedirectResponse(
                    url=f"/pay/{matches[0]['customer_id']}",
                    status_code=302)
            if len(matches) == 0:
                error_msg = "Mobile number not found. Please check and try again."
            else:
                error_msg = ("Multiple matches found. Please type a few "
                             "more digits of your mobile number.")

    err_html = (
        f'<div class="err">{error_msg}</div>' if error_msg else ""
    )
    html = f"""<!doctype html><html><head>
<title>Pay Your Bill</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  body{{background:#0f172a;color:#e2e8f0;font-family:-apple-system,sans-serif;
        display:flex;align-items:center;justify-content:center;min-height:100vh;
        margin:0;padding:20px;}}
  .box{{background:#111827;padding:28px;border-radius:14px;max-width:420px;
        width:100%;border:1px solid #1f2937;
        box-shadow:0 18px 50px rgba(0,0,0,.45);}}
  h2{{margin:0 0 6px 0;text-align:center;letter-spacing:.2px;}}
  .muted{{color:#94a3b8;font-size:13.5px;margin-bottom:18px;text-align:center;
          line-height:1.45;}}
  label{{display:block;font-size:12px;color:#94a3b8;
         text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px;}}
  input{{width:100%;box-sizing:border-box;background:#0b1220;
         border:1px solid #334155;color:#e2e8f0;border-radius:9px;
         padding:13px 14px;font-size:16px;outline:none;
         transition:border-color .15s;}}
  input:focus{{border-color:#10b981;}}
  button{{width:100%;margin-top:14px;background:#10b981;border:0;
          color:#06281e;font-weight:700;padding:13px;border-radius:9px;
          font-size:15px;cursor:pointer;letter-spacing:.3px;}}
  button:hover{{background:#0fbb86;}}
  .err{{background:#3f1d1d;border:1px solid #b91c1c;color:#fecaca;
        padding:10px 12px;border-radius:8px;margin-bottom:14px;
        font-size:13.5px;text-align:center;}}
  .hint{{font-size:11.5px;color:#64748b;margin-top:8px;text-align:center;}}
  .other{{margin-top:18px;text-align:center;}}
  .other a{{color:#10b981;font-size:13px;text-decoration:none;}}
  .other a:hover{{text-decoration:underline;}}
</style></head>
<body><div class="box">
  <h2>Pay Your Bill</h2>
  <div class="muted">Enter your registered mobile number to continue.</div>
  {err_html}
  <form method="get" action="/pay/captive" autocomplete="off">
    <label for="phone">Registered Mobile Number</label>
    <input id="phone" name="phone" type="tel" inputmode="numeric"
           pattern="[0-9 +\-]*" minlength="4" maxlength="15"
           placeholder="e.g. 9876543210" required autofocus
           value="{typed[:15]}">
    <div class="hint">Last 4-10 digits are enough.</div>
    <button type="submit">Continue</button>
  </form>
  <div class="other"><a href="/pay">Have your Customer ID instead?</a></div>
</div></body></html>"""
    return HTMLResponse(html)


@app.get("/pay/{customer_id}", response_class=HTMLResponse)
async def pay_suspension_page(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Public suspension / payment page - no auth, no session required.
    Reveals ONLY billing-relevant info: name, id, balance, ISP bank/UPI/QR."""
    from database import Customer, Company
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    if not cust:
        return HTMLResponse(
            f"<!doctype html><html><body style='background:#0f172a;color:#e2e8f0;"
            f"font-family:sans-serif;padding:40px;text-align:center'>"
            f"<h2>Customer not found</h2>"
            f"<p>We could not find an account with ID <code>{customer_id}</code>.</p>"
            f"<p><a href='/pay' style='color:#10b981'>&larr; Try again</a></p>"
            f"</body></html>",
            status_code=404)
    company = db.query(Company).filter(Company.company_id == cust.company_id).first()
    try:
        balance = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        balance = 0.0
    status_label, status_message = _pay_status_labels(cust.status, balance)

    # __S43ZS__ Build the list of available payment gateways for this tenant.
    # Order: tenant's own configured (and active) gateways first (default
    # flagged with `default=True`); env-fallback Razorpay is included only
    # when the tenant has NO configured Razorpay (so we don't display
    # platform keys to a tenant that brought their own).
    from payments.registry import GATEWAYS as _GW_SCHEMAS_PUB
    available_gateways = []
    default_gateway = None
    try:
        from sqlalchemy import text as _t_pub
        rows = db.execute(_t_pub(
            "SELECT gateway_name, is_default, status "
            "FROM payment_gateways WHERE company_id=:cid AND status='Active'"
        ), {"cid": cust.company_id}).fetchall()
        for r in rows:
            gw_name = r[0]
            schema = _GW_SCHEMAS_PUB.get((gw_name or "").lower())
            if not schema or not schema.get("active"):
                continue   # creds saved but adapter not yet live → hide
            available_gateways.append({
                "name": gw_name,
                "label": schema["label"],
                "default": bool(r[1]),
            })
        # Default = explicitly-flagged or first
        for g in available_gateways:
            if g["default"]:
                default_gateway = g["name"]; break
        if not default_gateway and available_gateways:
            default_gateway = available_gateways[0]["name"]
    except Exception:
        pass

    # Env-fallback Razorpay (backward compat for the original platform tenant).
    if not available_gateways:
        if os.environ.get("RAZORPAY_KEY_ID") and os.environ.get("RAZORPAY_KEY_SECRET"):
            company_opt_in = bool(getattr(company, "enable_online_payment", 0) or 0) if company else False
            if company_opt_in:
                available_gateways.append({
                    "name": "razorpay", "label": "Razorpay", "default": True
                })
                default_gateway = "razorpay"

    razorpay_ready = (default_gateway == "razorpay")  # legacy flag kept for template
    return templates.TemplateResponse("pay_suspended.html", {
        "request": request,
        "customer": cust,
        "company": company,
        "balance": balance,
        "status_label": status_label,
        "status_message": status_message,
        "razorpay_ready": razorpay_ready,
        # __S43ZS__ new context
        "available_gateways": available_gateways,
        "default_gateway": default_gateway,
    })


@app.post("/api/pay/{customer_id}/razorpay-order")
async def api_pay_razorpay_order(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Create a Razorpay order for this customer's outstanding balance.

    __S43ZQ__: Per-tenant credentials — loads keys from `payment_gateways`
    table for this customer's company; falls back to platform env vars
    only when no tenant row is configured (keeps the original live tenant
    working unchanged).
    """
    from database import Customer, Company
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    if not cust:
        return {"success": False, "message": "customer not found"}
    # __S43ZQ__ Try per-tenant credentials first.
    key_id = ""
    key_secret = ""
    try:
        from payments.routes_admin import get_company_credentials as _pg_creds
        _c = _pg_creds(db, cust.company_id, "razorpay")
        if _c:
            key_id = _c.get("key_id") or ""
            key_secret = _c.get("key_secret") or ""
    except Exception:
        pass
    if not key_id or not key_secret:
        key_id = os.environ.get("RAZORPAY_KEY_ID") or ""
        key_secret = os.environ.get("RAZORPAY_KEY_SECRET") or ""
    if not key_id or not key_secret:
        return {"success": False,
                "message": "Online gateway not configured. Please use UPI / QR / Bank transfer."}
    if not cust:
        return {"success": False, "message": "customer not found"}
    # Session 25.6 - check per-company feature flag
    company_row = db.query(Company).filter(Company.company_id == cust.company_id).first()
    company_opt_in_check = bool(getattr(company_row, "enable_online_payment", 0) or 0) if company_row else False
    if not company_opt_in_check:
        return {"success": False,
                "message": "Online payment is not enabled for this ISP. Please use UPI / QR / Bank transfer."}
    try:
        balance = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        balance = 0.0
    if balance <= 0.01:
        return {"success": False, "message": "no outstanding balance"}
    try:
        import razorpay  # only imported when keys present
        client = razorpay.Client(auth=(key_id, key_secret))
        amount_paise = int(round(balance * 100))
        import time as _time
        order = client.order.create({
            "amount": amount_paise,
            "currency": "INR",
            "receipt": f"cust-{customer_id}-{int(_time.time())}",
            "notes": {"customer_id": customer_id, "company_id": cust.company_id},
        })
        return {"success": True, "key_id": key_id,
                "order_id": order["id"], "amount": amount_paise}
    except Exception as e:
        return {"success": False, "message": f"order create failed: {e}"}


@app.post("/api/pay/{customer_id}/razorpay-verify")
async def api_pay_razorpay_verify(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Verify Razorpay callback signature and, on success, record a Manual
    Credit payment + flip customer back to Active + resync FreeRADIUS so
    the Mikrotik parking reply flips back to the normal pool.

    Phase 3 stub: the auto-resume wiring will land in Session 25.3.
    """
    # __S43ZQ_VERIFY__ — per-tenant Razorpay credentials with env fallback
    from database import Customer as _C_v43
    _cust_v = db.query(_C_v43).filter(_C_v43.customer_id == customer_id).first()
    key_id = ""
    key_secret = ""
    if _cust_v:
        try:
            from payments.routes_admin import get_company_credentials as _pg_creds_v
            _c_v = _pg_creds_v(db, _cust_v.company_id, "razorpay")
            if _c_v:
                key_id = _c_v.get("key_id") or ""
                key_secret = _c_v.get("key_secret") or ""
        except Exception:
            pass
    if not key_id or not key_secret:
        key_id = os.environ.get("RAZORPAY_KEY_ID") or ""
        key_secret = os.environ.get("RAZORPAY_KEY_SECRET") or ""
    if not key_id or not key_secret:
        return {"success": False, "message": "Online gateway not configured"}
    body = await request.json()
    order_id = body.get("razorpay_order_id")
    payment_id = body.get("razorpay_payment_id")
    signature = body.get("razorpay_signature")
    if not (order_id and payment_id and signature):
        return {"success": False, "message": "missing razorpay callback fields"}
    try:
        import razorpay
        client = razorpay.Client(auth=(key_id, key_secret))
        client.utility.verify_payment_signature({
            "razorpay_order_id": order_id,
            "razorpay_payment_id": payment_id,
            "razorpay_signature": signature,
        })
    except Exception as e:
        return {"success": False, "message": f"signature invalid: {e}"}

    # Signature OK: fetch actual paid amount from Razorpay, record payment,
    # flip to Active, re-enable router secret, kick live session so user
    # reconnects on the normal pool within seconds.
    # s26.9: razorpay-instant-reactivate
    from database import Customer, Payment
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    if not cust:
        return {"success": False, "message": "customer not found after verify"}

    # Prefer the ACTUAL paid amount over a balance snapshot.
    try:
        import razorpay as _rzp2
        _cl = _rzp2.Client(auth=(key_id, key_secret))
        _fetched = _cl.payment.fetch(payment_id)
        paid_amount = float((_fetched.get("amount") or 0)) / 100.0
    except Exception:
        paid_amount = float(
            compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)

    # Idempotency: skip if we've already recorded this payment_id.
    already = db.query(Payment).filter(Payment.transaction_no == payment_id).first()
    if not already:
        try:
            p = Payment(
                customer_id=cust.customer_id,
                company_id=cust.company_id,
                amount=paid_amount,
                payment_mode="Razorpay",
                transaction_no=payment_id,
                paid_at=datetime.utcnow(),
                remarks=f"Razorpay order {order_id} (browser verify)",
                created_at=datetime.utcnow(),
            )
            db.add(p); db.commit()
        except Exception as e:
            db.rollback()
            return {"success": True,
                    "message": f"Payment verified, but DB log failed: {e}. Please contact your ISP."}
    try:
        if cust.status != "Active":
            cust.status = "Active"
            cust.is_suspended = False
            db.commit()
        # Session 27.4 — unified enforcer (kick parking session + reload RADIUS)
        try:
            _enforce_user_state(db, cust)
        except Exception as _e1:
            print(f"[warn] razorpay-verify enforce: {_e1}")
    except Exception:
        db.rollback()
    return {"success": True,
            "amount_paid": paid_amount,
            "message": "Payment received. Reconnecting you to the internet now..."}

@app.post("/api/pay/razorpay-webhook")
async def api_pay_razorpay_webhook(request: Request, db: Session = Depends(get_db)):
    """__S43ZU__ Legacy endpoint — kept for backward-compat with Razorpay
    dashboards that haven't been migrated yet. Forwards to the canonical
    /api/webhooks/razorpay handler in-process. New integrations MUST point
    to /api/webhooks/razorpay (no `pay/` prefix)."""
    # Find the central handler registered by payments.routes_pay
    for r in app.router.routes:
        if getattr(r, "path", "") == "/api/webhooks/{gateway}":
            return await r.endpoint(gateway="razorpay", request=request, db=db)
    # Defensive fallback — central router not yet wired
    return JSONResponse({"success": False,
                         "message": "central webhook router not initialised"},
                         status_code=503)



@app.post("/api/company/walled-garden")
async def api_company_walled_garden(request: Request, db: Session = Depends(get_db)):
    """Per-company toggle for walled-garden mode (Session 25.3).

    Body: {enabled: bool}
    When OFF, Suspended/Disabled/Expired/Deactive customers get
    Access-Reject again (pre-s25.1 behaviour) - admin takes
    responsibility for sending them to the pay page manually.
    """
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    body = await request.json()
    enabled = 1 if body.get("enabled", True) else 0
    from sqlalchemy import text as _text
    db.execute(_text("UPDATE companies SET walled_garden_enabled=:e WHERE company_id=:c"),
               {"e": enabled, "c": company_id})
    db.commit()
    # Immediately regen FreeRADIUS so toggle takes effect without waiting
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=True)
    except Exception:
        pass
    return {"success": True, "enabled": bool(enabled),
            "message": f"Walled-garden {'ENABLED' if enabled else 'DISABLED'} for this company."}


@app.get("/api/company/walled-garden")
async def api_company_walled_garden_get(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from sqlalchemy import text as _text
    row = db.execute(_text("SELECT IFNULL(walled_garden_enabled,1) FROM companies "
                          "WHERE company_id=:c"), {"c": company_id}).fetchone()
    return {"success": True, "enabled": bool(row[0]) if row else True}


@app.get("/api/subscribers/{customer_pk}/pay-link")
async def api_subscriber_pay_link(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Returns the per-customer pay URL + a WhatsApp deep-link with a
    pre-filled SMS-style message (Session 25.3).

    Usage from UI:
      - "Copy Link" for email / manual paste
      - "Send WhatsApp" opens wa.me with pre-filled text
    """
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer, Company
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    company = db.query(Company).filter(Company.company_id == company_id).first()
    try:
        bal = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        bal = 0.0
    # Prefer pay.autoispbilling.com if admin has wired up DNS; otherwise the
    # IP-based URL always works (captive-portal hijack lands on the default host).
    pay_host = os.environ.get("PAY_DOMAIN", "pay.autoispbilling.com")
    pay_url = f"https://{pay_host}/pay/{cust.customer_id}"
    msg = (f"Hi {cust.customer_name or cust.customer_id}, your "
           f"{company.company_name if company else 'internet'} account is "
           f"currently {cust.status or 'inactive'}. "
           f"Outstanding balance: Rs.{bal:.2f}. "
           f"Please pay here to reconnect: {pay_url}")
    # Phone sanitize - WhatsApp wa.me needs country code, no +, no spaces.
    raw = (cust.customer_phone or "").strip()
    digits = "".join(ch for ch in raw if ch.isdigit())
    if digits and not digits.startswith("91") and len(digits) == 10:
        digits = "91" + digits
    import urllib.parse as _u
    wa_url = (f"https://wa.me/{digits}?text={_u.quote(msg)}"
              if digits else "")
    return {
        "success": True,
        "pay_url": pay_url,
        "message_text": msg,
        "whatsapp_url": wa_url,
        "phone": digits,
        "has_phone": bool(digits),
        "balance": bal,
        "status": cust.status or "",
    }

@app.get("/pay/{customer_id}/history", response_class=HTMLResponse)
async def pay_history_page(customer_id: str, request: Request,
                            db: Session = Depends(get_db)):
    """__S43ZU__ Customer-facing transaction history."""
    from database import Customer, Company, Payment
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    if not cust:
        return templates.TemplateResponse("pay_failed.html", {
            "request": request, "customer": None, "message": "Customer not found."
        }, status_code=404)
    company = db.query(Company).filter(Company.company_id == cust.company_id).first()
    try:
        balance = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        balance = 0.0
    # Pull last 50 payments + best-effort gateway label
    rows = (db.query(Payment)
              .filter(Payment.customer_id == cust.customer_id,
                      Payment.company_id == cust.company_id)
              .order_by(Payment.id.desc())
              .limit(80).all())
    # __S43ZW__ filter out manual book-keeping rows (plan upgrades, internal
    # adjustments, discount-only credits) — keep only real money movements
    # that the customer initiated or that an admin recorded as a real
    # cash/UPI/bank/online payment.
    HIDE_MODE_HINTS = ("plan upgrade", "adjustment", "credit note",
                       "manual credit", "manual debit", "internal")
    HIDE_REMARK_HINTS = ("plan upgrade approved", "adjustment", "credit note")
    items = []
    for p in rows:
        mode_raw = (p.payment_mode or "Manual")
        mode_lc = mode_raw.lower()
        remarks_lc = (p.remarks or "").lower()
        if any(h in mode_lc for h in HIDE_MODE_HINTS):
            continue
        if any(h in remarks_lc for h in HIDE_REMARK_HINTS):
            continue
        gw = ""
        for k in ("razorpay", "payu", "cashfree", "phonepe", "ccavenue", "stripe"):
            if k in mode_lc:
                gw = k; break
        items.append({
            "id": p.id,
            "txn_no": p.transaction_no or "",
            "amount": float(p.amount or 0),
            "discount": float(p.discount or 0),
            "mode": mode_raw,
            "gateway": gw,
            "paid_at": (p.paid_at or p.created_at) and (p.paid_at or p.created_at).strftime("%d-%b-%Y %H:%M"),
            "remarks": (p.remarks or "")[:80],
            "is_refund": float(p.amount or 0) < 0,
        })
    return templates.TemplateResponse("pay_history.html", {
        "request": request, "customer": cust, "company": company,
        "balance": balance, "items": items,
    })


@app.get("/pay/success/{customer_id}", response_class=HTMLResponse)
async def pay_success(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Public success page shown after Razorpay payment captures. Shows
    animated checkmark + payment proof + auto-redirects to main-domain /login."""
    from database import Customer, Company
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    company = None
    if cust:
        company = db.query(Company).filter(Company.company_id == cust.company_id).first()
    payment_id = request.query_params.get("payment_id", "")
    try:
        amount = float(request.query_params.get("amount", "0") or 0)
    except Exception:
        amount = 0.0
    from datetime import datetime as _dt, timedelta as _td
    now_ist = (_dt.utcnow() + _td(hours=5, minutes=30)).strftime("%d-%m-%Y %H:%M IST")
    # IMPORTANT: this page is served from pay.autoispbilling.com whose nginx
    # only proxies /pay*, /api/pay*, /static, /uploads. A naive '/login' here
    # falls through to the catch-all that 302s back to /pay - which looks
    # like the page is "not redirecting to login". So build an absolute URL
    # to the main domain.
    main_login_url = os.environ.get("MAIN_LOGIN_URL") or "https://www.autoispbilling.com/login"
    return templates.TemplateResponse("pay_success.html", {
        "request": request, "customer": cust, "company": company,
        "payment_id": payment_id, "amount": amount, "now_ist": now_ist,
        "main_login_url": main_login_url,
    })


@app.get("/pay/failed/{customer_id}", response_class=HTMLResponse)
async def pay_failed(customer_id: str, request: Request, db: Session = Depends(get_db)):
    """Public failure page shown when Razorpay checkout fires payment.failed.
    Shows error code + description + retry button back to /pay/<id>."""
    from database import Customer, Company
    cust = db.query(Customer).filter(Customer.customer_id == customer_id).first()
    company = None
    if cust:
        company = db.query(Company).filter(Company.company_id == cust.company_id).first()
    error_code = request.query_params.get("code", "") or ""
    error_description = request.query_params.get("description", "") or "Payment could not be completed."
    payment_id = request.query_params.get("payment_id", "") or ""
    try:
        amount = float(request.query_params.get("amount", "0") or 0)
    except Exception:
        amount = 0.0
    gateway = request.query_params.get("gw", "") or ""
    return templates.TemplateResponse("pay_failed.html", {
        "request": request, "customer": cust, "company": company,
        "error_code": error_code, "error_description": error_description,
        "payment_id": payment_id, "amount": amount, "gateway": gateway,
    })

@app.post("/api/subscribers/{customer_pk}/kyc-upload")
async def api_subscriber_kyc_upload(customer_pk: int, request: Request,
                                    kind: str = Form(...),
                                    file: UploadFile = File(...),
                                    db: Session = Depends(get_db)):
    """Session 25.11 - upload KYC document for a subscriber.
    kind: photograph | id_proof | address_proof"""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    if kind not in ("photograph", "id_proof", "address_proof"):
        return JSONResponse({"success": False, "message": "invalid kind"}, status_code=400)

    import os as _os, uuid as _uuid
    uploads_base = "/opt/ispbilling/admin-portal/static/uploads"
    dest_dir = _os.path.join(uploads_base, "kyc", str(cust.id))
    _os.makedirs(dest_dir, exist_ok=True)
    ext = _os.path.splitext(file.filename)[1].lower() or ".bin"
    filename = f"{kind}_{_uuid.uuid4().hex[:8]}{ext}"
    dst = _os.path.join(dest_dir, filename)
    try:
        with open(dst, "wb") as f:
            f.write(await file.read())
    except Exception as e:
        return {"success": False, "message": f"write failed: {e}"}

    # Persist the URL path (served from /static/uploads/kyc/...)
    url_path = f"/static/uploads/kyc/{cust.id}/{filename}"
    if kind == "photograph":
        cust.photograph_path = url_path
    elif kind == "id_proof":
        cust.id_proof_doc_path = url_path
    else:
        cust.address_proof_path = url_path
    db.commit()
    return {"success": True, "url": url_path}

@app.post("/api/subscribers/{customer_pk}/override-speed")
async def api_subscriber_override_speed(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Session 25.12 - override this subscriber's rate-limit.
    Body: {upload_mbps, download_mbps}  OR  {remove: true}"""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    if body.get("remove"):
        cust.custom_rate_limit = None
        db.commit()
        rate_str = None
    else:
        try:
            up = int(body.get("upload_mbps") or 0)
            dn = int(body.get("download_mbps") or 0)
            if up <= 0 or dn <= 0:
                return {"success": False, "message": "Both Upload and Download Mbps are required and > 0"}
        except Exception:
            return {"success": False, "message": "Upload/Download must be integers"}
        rate_str = f"{up}M/{dn}M"
        cust.custom_rate_limit = rate_str
        db.commit()

    # Apply immediately on Mikrotik (/ppp/secret rate-limit) + kick session.
    msg_parts = ["DB updated"]
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").first()
        if nas and cust.username:
            with rp.RouterOSClient(nas, dry_run=False) as c:
                secrets = c._api.path("ppp/secret")
                for row in secrets:
                    if (row.get("name") or "").strip() == cust.username:
                        upd = {".id": row[".id"]}
                        upd["rate-limit"] = rate_str or ""
                        secrets.update(**upd)
                        msg_parts.append(f"Mikrotik updated ({nas.name})")
                        break
                # kick session
                try:
                    actives = c._api.path("ppp/active")
                    for a in actives:
                        if (a.get("name") or "").strip() == cust.username:
                            try: actives.remove(a[".id"])
                            except TypeError: actives("remove", **{".id": a[".id"]})
                            msg_parts.append("session kicked")
                            break
                except Exception: pass
    except Exception as e:
        msg_parts.append(f"router err: {e}")

    # Regen FreeRADIUS so the override sticks across reauth
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=False)
        msg_parts.append("RADIUS synced")
    except Exception as e:
        msg_parts.append(f"radius err: {e}")

    return {"success": True,
            "rate_limit": rate_str or "(plan default)",
            "message": f"Speed override {'removed' if not rate_str else 'set to ' + rate_str}. " +
                       "; ".join(msg_parts) + "."}


@app.post("/api/subscribers/{customer_pk}/create-message")
async def api_subscriber_create_message(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Session 25.12 - create an alert (Direct Message) or ticket for this subscriber.
    Both go into support_tickets with different category values:
      kind='alert'  -> category='alert'
      kind='ticket' -> category='ticket'
    Body: {kind, subject, body, priority}
    """
    import uuid as _uuid
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    body = await request.json()
    kind = (body.get("kind") or "alert").strip().lower()
    if kind not in ("alert", "ticket"):
        kind = "alert"
    subject = (body.get("subject") or "").strip()
    body_txt = (body.get("body") or "").strip()
    priority = (body.get("priority") or "Medium").strip()
    if not subject or not body_txt:
        return {"success": False, "message": "subject and body required"}
    import time as _time
    ticket_no = f"{'T' if kind == 'ticket' else 'A'}-{int(_time.time())}-{_uuid.uuid4().hex[:4].upper()}"
    from sqlalchemy import text as _text
    try:
        db.execute(_text("""
            INSERT INTO support_tickets
            (company_id, admin_id, ticket_no, category, priority, subject,
             description, status, created_at, updated_at)
            VALUES (:company_id, :admin_id, :ticket_no, :cat, :prio, :subj,
                    :desc, 'Open', :now, :now)
        """), {
            "company_id": company_id,
            "admin_id": request.session.get("user_id", "admin"),
            "ticket_no": ticket_no,
            "cat": f"{kind}:customer:{cust.customer_id}",
            "prio": priority,
            "subj": f"[{cust.customer_id}] {subject}",
            "desc": body_txt,
            "now": datetime.utcnow(),
        })
        db.commit()
    except Exception as e:
        db.rollback()
        return {"success": False, "message": f"db error: {e}"}
    return {"success": True, "ticket_no": ticket_no,
            "message": f"{kind.capitalize()} #{ticket_no} created."}

@app.post("/api/subscribers/{customer_pk}/park-now")
async def api_subscriber_park_now(customer_pk: int, request: Request,
                                   db: Session = Depends(get_db)):
    """s41d: One-click "Park Now".

    1. Flip the customer's status to 'Expired'.
    2. Kick any live PPPoE session (via the per-auth-type backend) and
       send a CoA-Disconnect. Does NOT disable the PPP secret — the
       user must still be able to re-authenticate so they land in the
       parking-pool with `Mikrotik-Address-List=parked-customers`.
    3. Re-render /etc/freeradius/3.0/mods-config/files/isp-users so the
       new attributes are served on the next dial.

    Scope: admin, sub-lco (only their own customers), employee (only
    customers in their assigned locality).
    """
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    user_type = (request.session.get("user_type") or "admin").lower()
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"},
                            status_code=404)
    # Scope enforcement (sub-lco / employee)
    if user_type == "sub_lco":
        slc = (request.session.get("sub_lco_db_id")
               or request.session.get("sub_lco_id"))
        if str(getattr(cust, "sub_lco_id", "") or "") != str(slc or ""):
            return JSONResponse({"success": False,
                "message": "Customer is outside your sub-LCO scope."},
                status_code=403)
    elif user_type == "employee":
        try:
            from sqlalchemy import text as _sql_text
            emp_id = request.session.get("employee_id")
            rows = db.execute(_sql_text(
                "SELECT location_id FROM employee_locality_assignments "
                "WHERE employee_id=:e AND company_id=:c"),
                {"e": emp_id, "c": company_id}).fetchall()
            allowed = {r[0] for r in rows}
            if (getattr(cust, "location_id", None) and
                cust.location_id not in allowed):
                return JSONResponse({"success": False,
                    "message": "Customer is in a locality you are not assigned to."},
                    status_code=403)
        except Exception:
            pass
    # 1. Status flip — distinct "Parked" so the UI can show a different
    # badge and offer an Unpark button (vs natural Expired which is a
    # passive end-of-billing-cycle state managed by the renewal scheduler).
    try:
        cust.status = "Parked"
        cust.is_suspended = True
        db.commit()
    except Exception as _e:
        try: db.rollback()
        except Exception: pass
        return {"success": False, "message": f"DB update failed: {_e}"}
    # 2. Kick live session (uses the s41c helper).
    kick_info = ""
    try:
        ok, info = _router_kick_active_session(db, company_id, cust)
        kick_info = str(info)[:200]
    except Exception as _e:
        kick_info = f"kick failed: {_e}"
    # 3. RADIUS re-render for this tenant only (faster than _all_tenants)
    users_written = 0
    try:
        from radius_network import (_build_customer_radius_rows_global as _build,
                                     NasDevice)
        import freeradius_manager as fm
        cust_rows = _build(db, company_id)
        nas_rows = db.query(NasDevice).filter(
            NasDevice.company_id == company_id,
            NasDevice.status == "Active").all()
        # sync_all writes BOTH clients.conf and isp-users; we just need users
        res = fm.sync_users_file(cust_rows, restart=True)
        users_written = res.get("written") or len(cust_rows)
    except Exception as _e:
        return {"success": True,
                "warning": f"Status flipped + session kicked but RADIUS resync failed: {_e}",
                "kicked": kick_info,
                "users_written": 0,
                "message": "Subscriber parked — RADIUS resync had an issue, please retry Sync from FreeRADIUS panel."}
    return {"success": True,
            "kicked": kick_info,
            "users_written": users_written,
            "message": "Subscriber parked. On next reconnect they will be redirected to the pay page."}


@app.post("/api/subscribers/{customer_pk}/unpark")
async def api_subscriber_unpark(customer_pk: int, request: Request,
                                 db: Session = Depends(get_db)):
    """s41f: Reverse of Park Now — flips status back to Active and re-syncs
    RADIUS so the user gets a real-pool IP on the next dial. Kicks any
    live parking-pool session so the user re-auths immediately."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    user_type = (request.session.get("user_type") or "admin").lower()
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"},
                            status_code=404)
    if user_type == "sub_lco":
        slc = (request.session.get("sub_lco_db_id")
               or request.session.get("sub_lco_id"))
        if str(getattr(cust, "sub_lco_id", "") or "") != str(slc or ""):
            return JSONResponse({"success": False,
                "message": "Customer is outside your sub-LCO scope."},
                status_code=403)
    elif user_type == "employee":
        try:
            from sqlalchemy import text as _sql_text
            emp_id = request.session.get("employee_id")
            rows = db.execute(_sql_text(
                "SELECT location_id FROM employee_locality_assignments "
                "WHERE employee_id=:e AND company_id=:c"),
                {"e": emp_id, "c": company_id}).fetchall()
            allowed = {r[0] for r in rows}
            if (getattr(cust, "location_id", None) and
                cust.location_id not in allowed):
                return JSONResponse({"success": False,
                    "message": "Customer is in a locality you are not assigned to."},
                    status_code=403)
        except Exception:
            pass
    try:
        cust.status = "Active"
        cust.is_suspended = False
        db.commit()
    except Exception as _e:
        try: db.rollback()
        except Exception: pass
        return {"success": False, "message": f"DB update failed: {_e}"}
    # Kick the parked session so the user re-auths into the real pool.
    kick_info = ""
    try:
        ok, info = _router_kick_active_session(db, company_id, cust)
        kick_info = str(info)[:200]
    except Exception as _e:
        kick_info = f"kick failed: {_e}"
    users_written = 0
    try:
        from radius_network import (_build_customer_radius_rows_global as _b,
                                     NasDevice)
        import freeradius_manager as fm
        cust_rows = _b(db, company_id)
        res = fm.sync_users_file(cust_rows, restart=True)
        users_written = res.get("written") or len(cust_rows)
    except Exception as _e:
        return {"success": True,
                "warning": f"Status flipped but RADIUS resync failed: {_e}",
                "kicked": kick_info, "users_written": 0,
                "message": "Unparked — RADIUS resync had an issue, please retry Sync."}
    return {"success": True, "kicked": kick_info,
            "users_written": users_written,
            "message": "Subscriber unparked. They will get a real-pool IP on next dial."}


@app.post("/api/subscribers/{customer_pk}/change-plan")
async def api_subscriber_change_plan(customer_pk: int, request: Request, db: Session = Depends(get_db)):
    """Session 25.15 - change a subscriber's plan without running the full renewal
    machinery. Just flips customer.plan_id + pushes new rate-limit to Mikrotik.
    Optionally triggers a renew invoice if body.with_invoice=true.
    Body: {plan_id: int, with_invoice: bool (optional)}"""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    body = await request.json()
    new_plan_id = body.get("plan_id")
    if not new_plan_id:
        return {"success": False, "message": "plan_id required"}
    try:
        new_plan_id = int(new_plan_id)
    except Exception:
        return {"success": False, "message": "plan_id must be an integer"}
    from database import Customer, Plan
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    plan = db.query(Plan).filter(
        Plan.id == new_plan_id,
        Plan.company_id == company_id).first()
    if not plan:
        return {"success": False, "message": "plan not found for this company"}

    old_plan_id = cust.plan_id
    cust.plan_id = new_plan_id
    if plan.base_amount is not None:
        cust.monthly_amount = plan.base_amount
    db.commit()

    # s26.17e: change-plan-with-invoice
    # If admin asked "Change Plan with Invoice", run the full renewal
    # pipeline (period=1 month) so an Invoice is written, previous
    # balance carried over, balance updated and invoice emailed.
    invoice_info = None
    if body.get("with_invoice"):
        try:
            from services.billing import renew_customer_core
            from datetime import datetime as _dt
            rres = renew_customer_core(
                company_id=company_id,
                customer_id=cust.customer_id,
                start_date=_dt.now(),
                period_months=1,
                with_invoice=True,
                db=db,
                source="plan-change",
            )
            if rres and rres.get("success"):
                invoice_info = {
                    "invoice_no": rres.get("invoice_no"),
                    "amount":     rres.get("total_amount") or rres.get("amount"),
                }
                # Best-effort: email the invoice now (fire-and-forget)
                try:
                    import asyncio as _asyncio
                    from database import Invoice as _Inv, Customer as _C, Company as _Co
                    _inv = db.query(_Inv).filter(_Inv.invoice_no == rres.get("invoice_no")).first()
                    if _inv:
                        _c = db.query(_C).filter(
                            _C.customer_id == cust.customer_id,
                            _C.company_id == company_id).first()
                        _co = db.query(_Co).filter(_Co.company_id == company_id).first()
                        if _c and _c.customer_email and _co:
                            try:
                                # s41n: BUG — arguments were swapped.
                                # generate_invoice_pdf expects
                                # (invoice, company, customer). Previously
                                # we passed (invoice, customer, company),
                                # which is why change-package invoices
                                # were missing seller GST/phone/bank A/c
                                # and buyer name/mobile (the PDF looked up
                                # fields against the wrong dict).
                                pdf_bytes = generate_invoice_pdf(
                                    _inv.__dict__, _co.__dict__, _c.__dict__)
                            except Exception:
                                pdf_bytes = None
                            # === S41Y-GATE-PLANCHG ===
                            _pcflag = 1
                            try:
                                _pcflag = int(getattr(_co, 'auto_email_invoices', 1) or 0)
                            except Exception:
                                _pcflag = 1
                            if pdf_bytes and _pcflag:
                                _loop = _asyncio.get_event_loop()
                                _loop.create_task(send_invoice_email(
                                    _inv.__dict__, _c.customer_email,
                                    _co.__dict__, pdf_bytes,
                                    _c.customer_type or "PREPAID"))
                except Exception as _ee:
                    print(f"[warn] plan-change invoice email: {_ee}")
        except Exception as _e:
            print(f"[warn] plan-change invoice flow: {_e}")

    # Push new Mikrotik rate-limit
    msg = [f"DB: plan_id {old_plan_id} -> {new_plan_id}"]
    if invoice_info:
        msg.append(f"Invoice {invoice_info['invoice_no']} generated (\u20b9{invoice_info['amount']})")
    try:
        from radius_network import NasDevice
        import routeros_provision as rp
        nas = None
        if cust.provisioned_nas_id:
            nas = db.query(NasDevice).filter(
                NasDevice.id == cust.provisioned_nas_id,
                NasDevice.company_id == company_id).first()
        if not nas:
            nas = db.query(NasDevice).filter(
                NasDevice.company_id == company_id,
                NasDevice.status == "Active").first()
        if nas and cust.username and plan.speed and not cust.custom_rate_limit:
            # Convert "100 Mbps" or "100/50 Mbps" -> "100M/50M"
            import re as _re
            m = _re.findall(r"\d+", str(plan.speed))
            if len(m) >= 2:
                rate = f"{m[0]}M/{m[1]}M"
            elif len(m) == 1:
                rate = f"{m[0]}M/{m[0]}M"
            else:
                rate = ""
            if rate:
                with rp.RouterOSClient(nas, dry_run=False) as c:
                    secrets = c._api.path("ppp/secret")
                    for row in secrets:
                        if (row.get("name") or "").strip() == cust.username:
                            secrets.update(**{".id": row[".id"], "rate-limit": rate})
                            msg.append(f"Mikrotik rate-limit set to {rate}")
                            break
        elif cust.custom_rate_limit:
            msg.append("Mikrotik unchanged (custom override in effect)")
    except Exception as e:
        msg.append(f"router err: {e}")

    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=False)
        msg.append("RADIUS synced")
    except Exception as e:
        msg.append(f"radius err: {e}")

    return {"success": True, "new_plan": plan.plan_name, "speed": plan.speed,
            "invoice": invoice_info,
            "message": f"Plan changed to {plan.plan_name}. " + "; ".join(msg)}


# === Session 27.3 WhatsApp feature-flag guard ===
def _require_whatsapp_enabled(request: Request, db: Session):
    """Return JSONResponse(403) if this admin's company has
    `enable_whatsapp_api` disabled by the superadmin, else None."""
    company_id = request.session.get("company_id")
    if not company_id:
        return JSONResponse({"success": False, "message": "no company in session"}, status_code=401)
    from database import Company
    comp = db.query(Company).filter(Company.company_id == company_id).first()
    if not comp or not getattr(comp, "enable_whatsapp_api", 0):
        return JSONResponse(
            {"success": False,
             "message": "WhatsApp feature is disabled for your account. "
                        "Ask the Superadmin to enable it."},
            status_code=403)
    return None
# === /Session 27.3 ===

# === Session 27 Twilio WhatsApp endpoints ===
from fastapi import BackgroundTasks as _BG27

@app.post("/api/subscribers/{customer_pk}/send-pay-link-whatsapp")
async def api_send_pay_link_whatsapp(customer_pk: int, request: Request,
                                      background_tasks: _BG27,
                                      db: Session = Depends(get_db)):
    """Send pay-link to a single suspended customer via WhatsApp API.
    s41a: When SuperAdmin has not enabled the WhatsApp API for this admin,
    returns {feature_disabled, fallback_wa_url} so the UI can open the
    customer's normal WhatsApp / WhatsApp Business app pre-filled."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer, Company
    cust = db.query(Customer).filter(
        Customer.id == customer_pk,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    company = db.query(Company).filter(Company.company_id == company_id).first()
    try:
        bal = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        bal = 0.0
    pay_host = os.environ.get("PAY_DOMAIN", "pay.autoispbilling.com")
    pay_url = f"https://{pay_host}/pay/{cust.customer_id}"

    # s41a: Build wa.me fallback up front (used when WA API disabled)
    phone_raw = (cust.customer_phone or "").strip()
    digits = "".join(ch for ch in phone_raw if ch.isdigit())
    if digits and len(digits) == 10:
        digits = "91" + digits
    import urllib.parse as _u41
    body_text = (f"Hi {cust.customer_name or cust.customer_id}, your "
                 f"{company.company_name if company else 'internet'} account is "
                 f"expired/suspended. Pay Rs.{bal:.2f} here to reconnect: {pay_url}")
    fallback_url = (f"https://wa.me/{digits}?text={_u41.quote(body_text)}"
                    if digits else "")
    if not company or not getattr(company, "enable_whatsapp_api", 0):
        return {"success": False, "feature_disabled": True,
                "fallback_wa_url": fallback_url, "pay_url": pay_url,
                "phone": phone_raw,
                "message": "WhatsApp API disabled by Superadmin"}

    from twilio_whatsapp import send_pay_link_whatsapp
    result = send_pay_link_whatsapp(
        phone=cust.customer_phone or "",
        customer_name=cust.customer_name or cust.customer_id or "",
        amount_due=bal,
        pay_url=pay_url,
        company_name=(company.company_name if company else ""),
    )
    return {"success": bool(result.get("success")), "result": result,
            "pay_url": pay_url, "phone": cust.customer_phone or ""}


# === Session 27.7 bulk WA daily cooldown ===
_WA_BULK_STATE_PATH = "/var/lib/ispbilling/wa_bulk_cooldown.json"

def _wa_bulk_cooldown_load():
    import json
    try:
        with open(_WA_BULK_STATE_PATH) as f:
            return json.load(f)
    except Exception:
        return {}

def _wa_bulk_cooldown_save(state):
    import json, os as _os
    _os.makedirs(_os.path.dirname(_WA_BULK_STATE_PATH), exist_ok=True)
    try:
        with open(_WA_BULK_STATE_PATH, "w") as f:
            json.dump(state, f, indent=2, sort_keys=True)
    except Exception as e:
        print(f"[s27.7] state save failed: {e}")

def _wa_bulk_today_key():
    from datetime import datetime as _dt, timedelta as _td, timezone as _tz
    IST = _tz(_td(hours=5, minutes=30))
    return _dt.now(IST).strftime("%Y-%m-%d")


@app.get("/api/admin/bulk-wa-cooldown-status")
async def api_bulk_wa_cooldown_status(request: Request,
                                       db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    _wa = _require_whatsapp_enabled(request, db)
    if _wa is not None:
        return _wa
    company_id = request.session.get("company_id")
    state = _wa_bulk_cooldown_load()
    entry = state.get(company_id) or {}
    today = _wa_bulk_today_key()
    used_today = entry.get("last_sent_date") == today
    return {"success": True, "used_today": used_today,
            "last_sent_date": entry.get("last_sent_date"),
            "last_queued": entry.get("queued"),
            "today_ist": today}


@app.post("/api/admin/bulk-send-pay-link-whatsapp")
async def api_bulk_send_pay_link_whatsapp(request: Request,
                                           background_tasks: _BG27,
                                           db: Session = Depends(get_db)):
    """Send pay-link WhatsApp to ALL **Expired** customers of this admin's
    company. Once per admin-company per IST day."""
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    _wa = _require_whatsapp_enabled(request, db)
    if _wa is not None:
        return _wa
    company_id = request.session.get("company_id")
    today = _wa_bulk_today_key()
    state = _wa_bulk_cooldown_load()
    entry = state.get(company_id) or {}
    if entry.get("last_sent_date") == today:
        return JSONResponse({
            "success": False,
            "cooldown": True,
            "last_sent_date": entry.get("last_sent_date"),
            "message": "Bulk WhatsApp pay-link already sent today for your "
                       "company. You can run it again tomorrow after 00:00 IST.",
        }, status_code=429)

    from database import Customer, Company
    company = db.query(Company).filter(Company.company_id == company_id).first()
    # Session 27.7 — target Expired (not Suspended)
    expired = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.status.in_(["Expired", "expired"]),
    ).all()
    pay_host = os.environ.get("PAY_DOMAIN", "pay.autoispbilling.com")
    items = []
    skipped = 0
    for c in expired:
        if (getattr(c, "do_not_send_whatsapp", "") or "").strip().lower() in ("yes", "true", "1"):
            skipped += 1
            continue
        if not (c.customer_phone or "").strip():
            skipped += 1
            continue
        try:
            bal = float(compute_customer_balance(c.customer_id, c.company_id, db) or 0.0)
        except Exception:
            bal = 0.0
        items.append({
            "phone":  c.customer_phone,
            "name":   c.customer_name or c.customer_id,
            "amount": bal,
            "url":    f"https://{pay_host}/pay/{c.customer_id}",
            "company_name": company.company_name if company else "",
        })
    queued = len(items)
    def _runner(batch):
        from twilio_whatsapp import bulk_send_pay_link
        try:
            res = bulk_send_pay_link(batch)
            print(f"[s27.7-bulk-wa] ok={res['ok']} failed={res['failed']} total={res['total']}")
        except Exception as e:
            print(f"[s27.7-bulk-wa] runner error: {e}")
    background_tasks.add_task(_runner, items)
    # record cooldown immediately (so a second click doesn't also queue)
    state[company_id] = {
        "last_sent_date": today,
        "queued": queued,
        "skipped": skipped,
        "total_expired": len(expired),
    }
    _wa_bulk_cooldown_save(state)
    return {"success": True, "queued": queued, "skipped": skipped,
            "total_expired": len(expired),
            "cooldown_active_until": "tomorrow 00:00 IST",
            "message": f"Queued {queued} WhatsApp pay-link messages. "
                       f"(skipped {skipped} — no phone / opt-out)"}
# === /Session 27.7 ===



@app.post("/api/invoices/{invoice_id}/send-whatsapp")
async def api_send_invoice_whatsapp(invoice_id: int, request: Request,
                                     db: Session = Depends(get_db)):
    """Send invoice PDF download link via WhatsApp to the invoice's customer.
    s41a: Falls back to wa.me when WA API is disabled by SuperAdmin."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer, Company, Invoice
    inv = db.query(Invoice).filter(
        Invoice.id == invoice_id,
        Invoice.company_id == company_id).first()
    if not inv:
        return JSONResponse({"success": False, "message": "invoice not found"}, status_code=404)
    cust = db.query(Customer).filter(
        Customer.customer_id == inv.customer_id,
        Customer.company_id == company_id).first()
    if not cust or not (cust.customer_phone or "").strip():
        return {"success": False, "message": "no phone on file"}
    company = db.query(Company).filter(Company.company_id == company_id).first()
    host = os.environ.get("MAIN_DOMAIN", "autoispbilling.com")
    inv_url = f"https://{host}/api/invoices/{inv.id}/download"
    # s41a: wa.me fallback
    phone_raw = (cust.customer_phone or "").strip()
    digits = "".join(ch for ch in phone_raw if ch.isdigit())
    if digits and len(digits) == 10:
        digits = "91" + digits
    import urllib.parse as _u41
    body_text = (f"Hi {cust.customer_name or ''}, your invoice "
                 f"{inv.invoice_no or ('#' + str(inv.id))} for "
                 f"Rs.{float(inv.total_amount or 0):.2f} is ready. "
                 f"Download: {inv_url}")
    fallback_url = (f"https://wa.me/{digits}?text={_u41.quote(body_text)}"
                    if digits else "")
    if not company or not getattr(company, "enable_whatsapp_api", 0):
        return {"success": False, "feature_disabled": True,
                "fallback_wa_url": fallback_url, "invoice_url": inv_url,
                "message": "WhatsApp API disabled by Superadmin"}
    from twilio_whatsapp import send_invoice_whatsapp
    result = send_invoice_whatsapp(
        phone=cust.customer_phone,
        customer_name=cust.customer_name or "",
        amount=float(inv.total_amount or 0),
        invoice_url=inv_url,
        invoice_no=inv.invoice_no or f"#{inv.id}",
        company_name=company.company_name if company else "",
    )
    return {"success": bool(result.get("success")), "result": result, "invoice_url": inv_url}


@app.post("/api/admin/whatsapp-sandbox/debug")
async def api_whatsapp_sandbox_debug(request: Request):
    """Superadmin/Admin debug — send freeform 'hi' to a phone via Twilio.
    Body: {"phone": "+91XXXXXXXXXX", "text": "..."}"""
    auth_check = require_admin(request)
    if auth_check:
        return auth_check
    _wa = _require_whatsapp_enabled(request, db)
    if _wa is not None:
        return _wa
    import json as _json
    body = await request.body()
    try:
        data = _json.loads(body or b"{}")
    except Exception:
        data = {}
    phone = (data.get("phone") or "").strip()
    text  = (data.get("text")  or "Hello from AutoISP WhatsApp test.").strip()
    from twilio_whatsapp import _normalise_phone, _send_freeform
    to_ = _normalise_phone(phone)
    if not to_:
        return {"success": False, "error": "invalid phone"}
    res = _send_freeform(to_, text)
    return {"success": bool(res.get("success")), "result": res, "to": to_}

# === /Session 27 Twilio WhatsApp endpoints ===

# === Session 27.5 free-text WhatsApp to any customer ===
@app.post("/api/customers/{customer_id}/send-whatsapp")
async def api_customer_send_whatsapp(customer_id: str, request: Request,
                                       db: Session = Depends(get_db)):
    """Send a free-text WhatsApp to the customer looked up by `customer_id`.

    _S39R5L_WA_SCOPE — Sub-LCO can only DM customers in their hierarchy;
    employees can only DM customers in localities assigned to them. Admins
    have unrestricted scope (existing behaviour).
    """
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    user_type = (request.session.get("user_type") or "admin").lower()
    if user_type in ("sub_lco", "employee"):
        from database import Customer
        company_id = request.session.get("company_id")
        target = db.query(Customer).filter(
            Customer.customer_id == customer_id,
            Customer.company_id == company_id).first()
        if not target:
            return JSONResponse({"success": False,
                "message": "Customer not found in your scope."}, status_code=404)
        if user_type == "sub_lco":
            sub_lco_id = (request.session.get("sub_lco_db_id") or
                          request.session.get("sub_lco_id"))
            if str(getattr(target, "sub_lco_id", "") or "") != str(sub_lco_id or ""):
                return JSONResponse({"success": False,
                    "message": "WhatsApp blocked: this customer is outside your sub-LCO scope."},
                    status_code=403)
        elif user_type == "employee":
            try:
                from sqlalchemy import text as _sql_text
                emp_id = request.session.get("employee_id")
                rows = db.execute(_sql_text(
                    "SELECT location_id FROM employee_locality_assignments "
                    "WHERE employee_id=:e AND company_id=:c"),
                    {"e": emp_id, "c": company_id}).fetchall()
                allowed_locs = {r[0] for r in rows}
                if (getattr(target, "location_id", None) and
                    target.location_id not in allowed_locs):
                    return JSONResponse({"success": False,
                        "message": "WhatsApp blocked: customer is in a locality "
                                   "you are not assigned to."}, status_code=403)
            except Exception as _e:
                pass
    import json as _json
    body = await request.body()
    try:
        data = _json.loads(body or b"{}")
    except Exception:
        data = {}
    msg = (data.get("message") or "").strip()
    company_id = request.session.get("company_id")
    from database import Customer, Company
    cust = db.query(Customer).filter(
        Customer.customer_id == customer_id,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    phone = (cust.customer_phone or "").strip()
    if not phone:
        return {"success": False, "message": "customer has no phone on file"}
    # Build wa.me fallback upfront (used when feature disabled)
    digits = "".join(ch for ch in phone if ch.isdigit())
    if digits and len(digits) == 10:
        digits = "91" + digits
    import urllib.parse as _u
    fallback_url = f"https://wa.me/{digits}?text={_u.quote(msg or 'Hello')}" if digits else ""
    # Gate by feature flag
    comp = db.query(Company).filter(Company.company_id == company_id).first()
    if not comp or not getattr(comp, "enable_whatsapp_api", 0):
        return {"success": False,
                "feature_disabled": True,
                "fallback_wa_url": fallback_url,
                "message": "WhatsApp API disabled by Superadmin"}
    if not msg:
        return {"success": False, "message": "empty message"}
    # __s56l_wa_template_routing__ — route by template_kind to the
    # appropriate approved MSG91 template. Unsupported template_kinds
    # return a wa.me fallback so the caller can still reach the customer.
    template_kind = (data.get("template_kind") or "").strip().lower()
    # Common customer-derived bits
    try:
        bal = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        bal = 0.0
    outstanding_str = f"{bal:.2f}"
    cname = (getattr(cust, "customer_name", "") or "").strip() or (cust.username or "")
    company_name = ((getattr(comp, "company_name", "") or "").strip()) or "Auto ISP"
    company_phone = (getattr(comp, "company_phone", "") or "").strip()
    company_addr = (getattr(comp, "company_address", "") or "").strip()
    pay_host = os.environ.get("PAY_DOMAIN", "pay.autoispbilling.com")
    pay_url = f"https://{pay_host}/pay/{cust.customer_id}"
    expiry_str = ""
    try:
        if getattr(cust, "end_date", None):
            expiry_str = str(cust.end_date)[:10]
    except Exception:
        pass

    try:
        from msg91_whatsapp import (
            send_payment_link as _wa_paylink,
            send_plan_expiring_soon as _wa_expire,
        )
    except Exception as _e:
        return {"success": False, "message": f"msg91 module load failed: {_e}"}

    if template_kind in ("payment_reminder", "payment", "paylink", "payment_link"):
        if bal <= 0:
            return {"success": False,
                "message": f"No reminder sent — {cust.customer_id} has no pending dues (₹{bal:.2f})."}
        res = _wa_paylink(
            phone=phone, customer_name=cname, company_name=company_name,
            outstanding=outstanding_str, pay_url=pay_url,
            support_phone=company_phone, company_address=company_addr,
            company_id=company_id,
        )
        return {"success": bool(res.get("success")), "result": res,
                "template_used": "payment_link"}

    if template_kind in ("expiry_alert", "plan_expiring_soon", "expiry"):
        if not expiry_str:
            return {"success": False, "message": "Customer has no expiry date on file."}
        plan_name = ""
        try:
            from database import Plan as _Plan
            if getattr(cust, "plan_id", None):
                _p = db.query(_Plan).filter(_Plan.id == cust.plan_id).first()
                if _p:
                    plan_name = (getattr(_p, "plan_name", "") or "").strip()
        except Exception:
            pass
        res = _wa_expire(
            phone=phone, customer_name=cname, plan_name=(plan_name or "Internet"),
            expiry_date=expiry_str, outstanding=outstanding_str,
            support_phone=company_phone, company_name=company_name,
            company_address=company_addr, customer_id=cust.customer_id,
            company_id=company_id,
        )
        return {"success": bool(res.get("success")), "result": res,
                "template_used": "plan_expiring_soon"}

    # welcome / complaint_followup / general_announcement / unknown:
    # no approved MSG91 template exists — fall back to wa.me so admin can
    # still send via the customer's WhatsApp chat from their own device.
    return {"success": False,
            "feature_unsupported": True,
            "fallback_wa_url": fallback_url,
            "message": ("This template is not registered on MSG91. "
                        "Opening WhatsApp Web/app instead so you can send "
                        "the message from your own number.")}


@app.post("/api/customers/{customer_id}/send-pay-link-whatsapp")
async def api_customer_send_paylink_whatsapp(customer_id: str, request: Request,
                                               db: Session = Depends(get_db)):
    """Variant of /api/subscribers/{pk}/send-pay-link-whatsapp keyed by
    customer_id string. Same feature-flag gate + wa.me fallback."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Customer, Company
    cust = db.query(Customer).filter(
        Customer.customer_id == customer_id,
        Customer.company_id == company_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer not found"}, status_code=404)
    comp = db.query(Company).filter(Company.company_id == company_id).first()
    try:
        bal = float(compute_customer_balance(cust.customer_id, cust.company_id, db) or 0.0)
    except Exception:
        bal = 0.0
    pay_host = os.environ.get("PAY_DOMAIN", "pay.autoispbilling.com")
    pay_url = f"https://{pay_host}/pay/{cust.customer_id}"
    # Default wa.me fallback
    phone = (cust.customer_phone or "").strip()
    digits = "".join(ch for ch in phone if ch.isdigit())
    if digits and len(digits) == 10:
        digits = "91" + digits
    import urllib.parse as _u
    body_text = (f"Hi {cust.customer_name or cust.customer_id}, your "
                 f"{comp.company_name if comp else 'internet'} account is expired/suspended. "
                 f"Pay Rs.{bal:.2f} here to reconnect: {pay_url}")
    fallback_url = (f"https://wa.me/{digits}?text={_u.quote(body_text)}"
                    if digits else "")
    # Gate
    if not comp or not getattr(comp, "enable_whatsapp_api", 0):
        return {"success": False,
                "feature_disabled": True,
                "fallback_wa_url": fallback_url,
                "pay_url": pay_url,
                "message": "WhatsApp API disabled by Superadmin"}
    from twilio_whatsapp import send_pay_link_whatsapp
    res = send_pay_link_whatsapp(
        phone=phone,
        customer_name=cust.customer_name or cust.customer_id or "",
        amount_due=bal,
        pay_url=pay_url,
        company_name=(comp.company_name if comp else ""),
    )
    return {"success": bool(res.get("success")), "result": res,
            "pay_url": pay_url}
