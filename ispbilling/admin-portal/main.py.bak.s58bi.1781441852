    headers = ['ID','Employee Code','Name','Mobile','Email','Address','Status',
               'Last Latitude','Last Longitude','Last Seen At','Created By','Created At','Updated At']
    rows = []
    for e in items:
        rows.append([
            e.id, e.employee_code or '', e.employee_name or '',
            e.mobile or '', e.email or '', e.address or '', e.status or '',
            e.last_latitude or '', e.last_longitude or '',
            e.last_seen_at.isoformat() if e.last_seen_at else '',
            e.created_by or '',
            e.created_at.isoformat() if e.created_at else '',
            e.updated_at.isoformat() if e.updated_at else '',
        ])
    return _s30_send(headers, rows, fmt, 'employees')


# ---------- Locations ----------
@app.get("/api/admin/locations/export-full")
async def api_locations_export_full(request: Request, db: Session = Depends(get_db)):
    auth_check = require_admin(request)
    if auth_check: return auth_check
    company_id = request.session.get('company_id')
    fmt = (request.query_params.get('format') or 'csv').lower()
    from database import Location, Customer
    items = db.query(Location).filter(Location.company_id == company_id).order_by(Location.id).all()
    # Customer counts per locality
    counts = {}
    for row in db.query(Customer.locality, func.count(Customer.id)).filter(
            Customer.company_id == company_id).group_by(Customer.locality).all():
        counts[(row[0] or '').strip().lower()] = int(row[1] or 0)
    headers = ['ID','Name','City','State','Pincode','Status','Subscribers','Created At']
    rows = []
    for loc in items:
        rows.append([
            loc.id, loc.name or '', loc.city or '', loc.state or '',
            loc.pincode or '', loc.status or '',
            counts.get((loc.name or '').strip().lower(), 0),
            loc.created_at.isoformat() if loc.created_at else '',
        ])
    return _s30_send(headers, rows, fmt, 'locations')


# ---------- Public IPs ----------
