# _v472_WA_INTERNAL  Localhost-only Twilio WhatsApp receipt sender.  The
# mobile-api-v3 forwarder calls this so we don't duplicate the receipt-PDF
# build + Twilio dispatch logic.
@app.post("/api/internal/payments/{payment_id}/send-receipt-whatsapp")
async def internal_send_receipt_whatsapp(payment_id: int,
                                         request: Request,
                                         db: Session = Depends(get_db)):
    host = (request.client.host if request.client else "") or ""
    if host not in ("127.0.0.1", "::1", "localhost"):
        return {"success": False, "message": "Forbidden"}
    company_id = request.query_params.get("company_id") or ""
    if not company_id:
        return {"success": False, "message": "company_id required"}
    from database import Company, Customer, Payment
    from sqlalchemy import text as _t
    comp = db.query(Company).filter(Company.company_id == company_id).first()
    # _v472_RAW  enable_whatsapp_api column is not on the SQLAlchemy model;
    # query raw so the flag works regardless of model schema drift.
    try:
        wa_flag = db.execute(_t("SELECT enable_whatsapp_api FROM companies "
                                " WHERE company_id=:cid"),
                             {"cid": company_id}).scalar() or 0
    except Exception:
        wa_flag = 0
    if not comp or not wa_flag:
        return {"success": False, "reason": "gateway_disabled",
                "message": "WhatsApp gateway disabled by superadmin"}
    pay = db.query(Payment).filter(
        Payment.id == payment_id,
        Payment.company_id == company_id).first()
    if not pay:
        return {"success": False, "message": "payment_not_found"}
    cust = db.query(Customer).filter(
        Customer.customer_id == pay.customer_id,
        Customer.company_id == company_id).first()
    phone = (cust.customer_phone if cust and cust.customer_phone else "") or ""
    phone = "".join(ch for ch in phone if ch.isdigit())
    if len(phone) > 10 and phone.startswith("91"): phone = phone[2:]
    if len(phone) > 10 and phone.startswith("0"):  phone = phone[1:]
    if len(phone) < 10:
        return {"success": False, "message": "invalid_customer_phone"}
    # Compose human-readable receipt body (mirrors mobile shareOnWhatsapp).
    # _v4710_  Date-only (strip time portion). pay.paid_at may be a string
    # 'YYYY-MM-DD HH:MM:SS' (DB stores IST) or a datetime — handle both.
    try:
        if hasattr(pay.paid_at, 'strftime'):
            _date_only = (pay.paid_at + timedelta(hours=5, minutes=30)).strftime('%d-%m-%Y')
        else:
            _s = str(pay.paid_at or '')[:10]
            _date_only = datetime.strptime(_s, '%Y-%m-%d').strftime('%d-%m-%Y') if _s else ''
    except Exception:
        _date_only = str(pay.paid_at or '')[:10]
    body = (f"*{comp.company_name or 'AutoISP Billing'}*\n_PAYMENT RECEIPT_\n\n"
            f"Receipt: {pay.transaction_no or pay.id}\n"
            f"Date: {_date_only}\n"
            f"Customer: {(cust.customer_name if cust else '') or ''}\n"
            f"Cust ID: {pay.customer_id}\n"
            f"Cash Paid: \u20b9{float(pay.amount or 0):.0f}\n")
    if pay.discount and float(pay.discount) > 0:
        body += f"Discount: -\u20b9{float(pay.discount):.0f}\n"
    body += (f"Mode: {pay.payment_mode or 'Cash'}\n\n"
             f"Thank you!\n\n"
             f"_Powered By Auto ISP Billing_\n"
             f"www.autoispbilling.com")
    # __MSG91_RECEIPT_DIRECT__  Was: Twilio direct .messages.create()
    try:
        from msg91_whatsapp import send_payment_receipt, normalise_phone
        ph = normalise_phone(phone)
        if not ph:
            return {"success": False, "reason": "invalid_phone",
                    "message": "Invalid phone number"}
        # The legacy body contains amount + txn + URL — extract them.
        import re as _re
        amt_m = _re.search(r"Rs\.?\s*([\d,.]+)", body or "")
        txn_m = _re.search(r"Txn\s+([^,)\s]+)", body or "")
        url_m = _re.search(r"https?://\S+", body or "")
        res = send_payment_receipt(
            phone=ph,
            customer_name=(getattr(cust, 'customer_name', '') or 'Customer'),
            transaction_no=(txn_m.group(1) if txn_m else '—'),
            amount=(amt_m.group(1).replace(',','') if amt_m else '0'),
            receipt_url=(url_m.group(0) if url_m else ''),
            company_name=(getattr(comp, 'company_name', '') or 'AUTO ISP BILLING'),
            company_address=(getattr(comp, 'company_address', '') or ''),
            company_id=(getattr(comp, 'company_id', None) if comp else None),
        )
        if res.get('success'):
            return {"success": True, "sid": res.get('msg91_message_id'),
                    "message": f"WhatsApp receipt sent to +91{phone}"}
        return {"success": False, "reason": "msg91_error",
                "message": res.get('error') or 'Send failed'}
    except Exception as e:
        return {"success": False, "reason": "msg91_error",
                "message": f"{e}"}


# _v4727_  FAQ pages (role-aware via base_template)
# === S42B-MSG91-TEMPLATES ===
@app.get("/api/admin/wa-templates/msg91")
async def api_msg91_templates_list(request: Request,
                                   db: Session = Depends(get_db)):
    """Proxy MSG91's "Get all approved WhatsApp templates" API.
    Per user request, the WhatsApp Campaigns page must pull verified
    templates from MSG91, not from the legacy local table. The +New
    template button on the Campaigns page is hidden — admins can only
    USE approved templates (creation happens in the MSG91 dashboard
    and Meta verifies them)."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    try:
        authkey = os.environ.get("MSG91_AUTHKEY", "").strip()
        integrated = os.environ.get("MSG91_INTEGRATED_NUMBER", "").strip()
        if not authkey or not integrated:
            return {"success": False, "items": [],
                    "message": "MSG91 not configured. Ask superadmin to set MSG91_AUTHKEY + MSG91_INTEGRATED_NUMBER."}
        # === S42C-MSG91-CORRECT-URL ===
        # Correct MSG91 endpoint is `/api/v5/whatsapp/get-template-client/{integrated_number}`
        # (per https://docs.msg91.com/whatsapp/get-templates).
        # The response shape is {status, data: [{ name, category, languages:[{language,status,code:[{type:BODY,text}]}] }]}.
        # We ONLY surface entries whose language.status == APPROVED.
        import httpx as _hx
        url = f"https://control.msg91.com/api/v5/whatsapp/get-template-client/{integrated}"
        async with _hx.AsyncClient(timeout=10) as cx:
            r = await cx.get(url, headers={"authkey": authkey,
                                            "accept": "application/json"})
        if r.status_code != 200:
            return {"success": False, "items": [],
                    "message": f"MSG91 HTTP {r.status_code}: {r.text[:200]}"}
        body = r.json() or {}
        raw = body.get("data") or []
        items = []
        for t in raw:
            if not isinstance(t, dict): continue
            cat = (t.get("category") or "").lower()
            for L in t.get("languages", []) or []:
                if not isinstance(L, dict): continue
                status = (L.get("status") or "").upper()
                if status != "APPROVED":
                    continue   # skip PENDING, REJECTED, etc.
                code = L.get("code") or []
                body_text = ""
                for c in code:
                    if isinstance(c, dict) and (c.get("type") or "").upper() == "BODY":
                        body_text = c.get("text") or ""
                        break
                items.append({
                    "id":         L.get("id") or t.get("name"),
                    "name":       t.get("name") or "",
                    "language":   L.get("language") or "en",
                    "category":   cat,
                    "status":     status,
                    "body_text":  body_text,
                    "components": code,
                    "variables":  L.get("variables") or [],
                    "source":     "msg91",
                })
        return {"success": True, "items": items,
                "count": len(items),
                "integrated_number": integrated}
    except Exception as e:
        return {"success": False, "items": [],
                "message": f"MSG91 fetch error: {str(e)[:200]}"}
# === /S42B-MSG91-TEMPLATES ===

@app.get("/admin/faq", response_class=HTMLResponse)
@app.get("/sub-lco/faq", response_class=HTMLResponse)
@app.get("/employee/faq", response_class=HTMLResponse)
def admin_faq_page(request: Request):
    # __FAQ_AUTH_GUARD__  Block unauthenticated access.
    if not request.session.get("user_id"):
        from fastapi.responses import RedirectResponse as _RR_faq
        # Bounce to the role-appropriate login page so the user
        # lands on the correct tab after signing in.
        return _RR_faq(url="/admin/login", status_code=302)
    path = str(request.url.path or "")
    if path.startswith("/sub-lco"):
        base_tpl, role, path_prefix = "base_sub_lco.html", "sub_lco", "/sub-lco"
    elif path.startswith("/employee"):
        base_tpl, role, path_prefix = "base_employee.html", "employee", "/employee"
    else:
        base_tpl, role, path_prefix = "base_admin.html", "admin", "/admin"
    ctx = {
        "request": request,
        "base_template": base_tpl,
        "layout_template": base_tpl,
        "active_page": "faq",
        "active_section": "faq",
        "user_type": role,
        "path_prefix": path_prefix,
    }
    try:
        # Best-effort: enrich with the role-appropriate shell context so the
        # base templates render logo, profile, company name, etc. as usual.
        from sqlalchemy.orm import Session as _Sess  # noqa: F401
        db = next(get_db())  # type: ignore
        try:
            if role == "admin":
                ctx.update(get_admin_context(request, db))
            elif role == "employee":
                ctx.update(_emp_admin_context(request, db, "faq"))
            elif role == "sub_lco":
                ctx.update(_slco_admin_context(request, db, "faq"))
        finally:
            try: db.close()
            except Exception: pass
    except Exception:
        pass
    # Always re-stamp these (role context updates may overwrite them)
    ctx["base_template"]   = base_tpl
    ctx["layout_template"] = base_tpl
    ctx["active_page"]     = "faq"
    return templates.TemplateResponse("admin_faq.html", ctx)



# __S43J_DELETE_ENDPOINTS__  Admin-only delete for payment + invoice with
# automatic DB revert + PDF wipe across all portals.

import os as _os_s43j, glob as _glob_s43j

def _s43j_require_admin_strict(request):
    """Reject anything except admin / superadmin."""
    ut = (request.session.get("user_type") or "").lower()
    if ut not in ("admin", "superadmin"):
        return JSONResponse(
            {"success": False, "message": "Admin only"}, status_code=403)
    return None


@app.post("/api/admin/payments/{payment_id}/delete")
async def admin_delete_payment(payment_id: int, request: Request,
                                db: Session = Depends(get_db)):
    g = _s43j_require_admin_strict(request)
    if g is not None: return g
    cid = request.session.get("company_id")
    actor = request.session.get("user_id") or request.session.get("admin_id") or "admin"
    from sqlalchemy import text as _t
    row = db.execute(_t(
        "SELECT id, customer_id, amount, transaction_no, paid_at "
        "  FROM payments WHERE id=:i AND company_id=:c LIMIT 1"
    ), {"i": payment_id, "c": cid}).fetchone()
    if not row:
        return JSONResponse({"success": False, "message": "Payment not found"},
                            status_code=404)
    pay_id, customer_id, amount, txn_no, paid_at = row
    amount = float(amount or 0)
    try:
        # 1) Revert customer counters
        db.execute(_t(
            "UPDATE customers SET received_amount = COALESCE(received_amount,0) - :amt, "
            "                     total_bill_amount = COALESCE(total_bill_amount,0) + :amt "
            "WHERE customer_id=:cust AND company_id=:c"
        ), {"amt": amount, "cust": customer_id, "c": cid})
        # 2) Revert received_tracker
        try:
            db.execute(_t(
                "UPDATE received_tracker "
                "   SET received_since_reset = COALESCE(received_since_reset,0) - :amt "
                " WHERE company_id=:c AND customer_id=:cust"
            ), {"amt": amount, "cust": customer_id, "c": cid})
        except Exception: pass
        # 3) Delete the linked transaction row(s)
        db.execute(_t(
            "DELETE FROM transactions "
            " WHERE company_id=:c AND customer_id=:cust AND amount=:amt "
            "   AND created_at=:pa"
        ), {"c": cid, "cust": customer_id, "amt": amount, "pa": paid_at})
        # 4) Delete the payment row
        db.execute(_t("DELETE FROM payments WHERE id=:i AND company_id=:c"),
                   {"i": pay_id, "c": cid})
        # 5) Wipe all on-disk receipt PDFs that reference this txn_no / id
        for base in (f"/var/lib/autoispbilling/receipts/{cid}",
                     f"/var/lib/autoispbilling/receipts/SUPERADMIN",
                     "/var/lib/autoispbilling/receipts"):
            try:
                for pat in (f"*{txn_no}*", f"*payment-{pay_id}*",
                            f"RCP-{pay_id:06d}*", f"*{pay_id}*.pdf"):
                    for f in _glob_s43j.glob(_os_s43j.path.join(base, pat)):
                        try: _os_s43j.remove(f)
                        except Exception: pass
            except Exception: pass
        # 6) Audit log
        try:
            db.execute(_t(
                "INSERT INTO audit_trail (company_id, customer_id, action, "
                "  details, performed_by, performed_at) "
                "VALUES (:c, :cust, 'payment_delete', :det, :who, datetime('now'))"
            ), {"c": cid, "cust": customer_id,
                "det": f"Deleted payment {txn_no} (id={pay_id}) for {amount}",
                "who": actor})
        except Exception: pass
        db.commit()
        return {"success": True,
                "message": f"Payment {txn_no} deleted and reverted."}
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": str(e)},
                            status_code=500)


@app.post("/api/admin/invoices/{invoice_id}/delete")
async def admin_delete_invoice(invoice_id: int, request: Request,
                                db: Session = Depends(get_db)):
    g = _s43j_require_admin_strict(request)
    if g is not None: return g
    cid = request.session.get("company_id")
    actor = request.session.get("user_id") or request.session.get("admin_id") or "admin"
    from sqlalchemy import text as _t
    row = db.execute(_t(
        "SELECT id, customer_id, invoice_no, pdf_path, total_amount "
        "  FROM invoices WHERE id=:i AND company_id=:c LIMIT 1"
    ), {"i": invoice_id, "c": cid}).fetchone()
    if not row:
        return JSONResponse({"success": False, "message": "Invoice not found"},
                            status_code=404)
    inv_id, customer_id, invoice_no, pdf_path, total_amount = row
    try:
        # 1) Delete invoice row
        db.execute(_t("DELETE FROM invoices WHERE id=:i AND company_id=:c"),
                   {"i": inv_id, "c": cid})
        # 2) Wipe on-disk PDFs (canonical path + matching globs)
        if pdf_path:
            try:
                _os_s43j.remove(pdf_path)
            except Exception: pass
        for base in ("/var/lib/autoispbilling/invoices",
                     "/var/lib/autoispbilling/manual_invoices",
                     f"/var/lib/autoispbilling/invoices/{cid}"):
            try:
                for pat in (f"*{invoice_no}*",):
                    for f in _glob_s43j.glob(_os_s43j.path.join(base, pat)):
                        try: _os_s43j.remove(f)
                        except Exception: pass
            except Exception: pass
        # 3) Audit
        try:
            db.execute(_t(
                "INSERT INTO audit_trail (company_id, customer_id, action, "
                "  details, performed_by, performed_at) "
                "VALUES (:c, :cust, 'invoice_delete', :det, :who, datetime('now'))"
            ), {"c": cid, "cust": customer_id,
                "det": f"Deleted invoice {invoice_no} (id={inv_id}) for {total_amount}",
                "who": actor})
        except Exception: pass
        db.commit()
        return {"success": True,
                "message": f"Invoice {invoice_no} deleted from DB and disk."}
    except Exception as e:
        db.rollback()
        return JSONResponse({"success": False, "message": str(e)},
                            status_code=500)




# __S43Q_ENFORCE_STATE_INTERNAL__  Internal endpoint used by mobile-api after
# a payment or status flip on a previously-inactive customer. Re-enters
# _enforce_user_state which (a) toggles the router PPP secret to match
# Active/Inactive state, (b) sends CoA-Disconnect so any walled-garden
# session is kicked, and (c) re-syncs FreeRADIUS so the next dial-in lands
# in the real pool. Localhost + X-Internal-Token gated.
# _S58AW_  Mobile-API → admin-portal bridge for TR-069 actions on ONUs.
# Localhost + X-Internal-Token gated (same pattern as enforce-state).
@app.post("/api/internal/onus/{onu_id}/push-tr069")
async def api_internal_onu_push_tr069(onu_id: int, request: Request):
    cid_or_resp = require_admin_or_internal(request)
    if not isinstance(cid_or_resp, str):
        return cid_or_resp
    company_id = cid_or_resp
    body = {}
    try: body = await request.json()
    except Exception: pass
    reason = (body or {}).get("reason") or "internal_bridge"
    try:
        from olt_routes import _genieacs_auto_push as _gap
        res = _gap(company_id, int(onu_id), reason=reason) or {}
        return {"ok": True, "detail": res}
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"push_failed: {e!r}"},
                            status_code=500)


@app.post("/api/internal/onus/{onu_id}/reboot")
async def api_internal_onu_reboot(onu_id: int, request: Request,
                                  db: Session = Depends(get_db)):
    cid_or_resp = require_admin_or_internal(request)
    if not isinstance(cid_or_resp, str):
        return cid_or_resp
    company_id = cid_or_resp
    try:
        from olt_routes import _genieacs_request as _gr, _onu_genieacs_id as _gid
        # Find serial of the ONU + post a Reboot task to GenieACS.
        row = db.execute(text(
            "SELECT serial, mac FROM onus WHERE id=:id AND company_id=:cid LIMIT 1"
        ), {"id": int(onu_id), "cid": company_id}).fetchone()
        if not row:
            return JSONResponse({"ok": False, "message": "onu_not_found"},
                                status_code=404)
        sn  = (row[0] or row[1] or "").upper()
        if not sn:
            return JSONResponse({"ok": False, "message": "no_serial"},
                                status_code=400)
        # GenieACS device IDs come in many shapes — try the common ones.
        dev_id = _gid(sn) if callable(_gid) else sn
        res = _gr(f"/devices/{dev_id}/tasks?connection_request",
                  method="POST",
                  payload={"name": "reboot"})
        return {"ok": True, "tr069": res}
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"reboot_failed: {e!r}"},
                            status_code=500)


@app.post("/api/internal/customer/{customer_id}/enforce-state")
async def api_internal_enforce_state(customer_id: str, request: Request,
                                     db: Session = Depends(get_db)):
    cid_or_resp = require_admin_or_internal(request)
    if not isinstance(cid_or_resp, str):
        return cid_or_resp
    company_id = cid_or_resp
    from database import Customer
    cust = db.query(Customer).filter(
        Customer.company_id == company_id,
        Customer.customer_id == customer_id).first()
    if not cust:
        return JSONResponse({"success": False, "message": "customer_not_found"},
                            status_code=404)
    try:
        r = _enforce_user_state(db, cust)
        return {"success": bool(r.get("success")), "detail": r}
    except Exception as e:
        return JSONResponse({"success": False, "message": str(e)},
                            status_code=500)



# _S58AW_INTERNAL_BULK_BEGIN_
@app.post("/api/internal/customers/bulk-action")
async def api_internal_bulk_action(request: Request, db: Session = Depends(get_db)):
    """Internal-token bridge for the mobile-app bulk-action toolbar.
    Re-uses the same bulk_customer_action logic by impersonating the
    session via X-Company-Id + X-Actor-* headers."""
    cid_or_resp = require_admin_or_internal(request)
    if not isinstance(cid_or_resp, str):
        return cid_or_resp
    company_id = cid_or_resp
    body = await request.json()
    action = (body.get("action") or "").strip()
    ids = body.get("customer_ids") or []
    if not action or not ids:
        return JSONResponse({"success": False,
                             "message": "action + customer_ids required"},
                            status_code=400)

    from database import Customer
    from radius_network import NasDevice
    str_ids = [str(x) for x in ids]
    int_ids = []
    for x in ids:
        try: int_ids.append(int(x))
        except Exception: pass
    rows = (db.query(Customer)
              .filter(Customer.company_id == company_id)
              .filter((Customer.customer_id.in_(str_ids)) |
                      (Customer.id.in_(int_ids)))
              .all())
    if not rows:
        return {"success": False, "message": "No customers matched."}

    touched = 0
    kicked  = 0
    errors  = []

    def _coa_kick(c):
        nonlocal kicked
        try:
            nas = (db.query(NasDevice)
                     .filter(NasDevice.company_id == company_id,
                             NasDevice.status == "Active",
                             NasDevice.id == (c.provisioned_nas_id or 0))
                     .first())
            if not nas:
                nas = (db.query(NasDevice)
                         .filter(NasDevice.company_id == company_id,
                                 NasDevice.status == "Active").first())
            if not nas or not c.username:
                return
            import freeradius_manager as fm
            fm.send_coa_disconnect(nas_ip=nas.ip_address,
                                   username=c.username,
                                   secret=(nas.secret or "testing123"))
            kicked += 1
        except Exception as e:
            errors.append(f"kick {c.customer_id}: {e}")

    _actor = dict(
        actor_type=(request.headers.get("X-Actor-Role") or "admin"),
        actor_id="",
        actor_name=(request.headers.get("X-Actor-Username") or "mobile-app"),
    )

    # _S58BD_NAS_TARGET_FIX_  Read nas_id once for the assign_nas action.
    _nas_id_target = body.get("nas_id")
    try: _nas_id_target = int(_nas_id_target) if _nas_id_target else None
    except Exception: _nas_id_target = None

    for c in rows:
        try:
            if action == "make_active":
                log_customer_status_change(db, c, "Active",
                    reason="bulk Make-Active (mobile)", **_actor)
                c.status = "Active"; c.is_suspended = False
                try: _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e: errors.append(f"enforce {c.customer_id}: {_e}")
            elif action == "reset_mac":
                if hasattr(c, "mac_address"): c.mac_address = ""
            elif action == "disconnect":
                _coa_kick(c)
            elif action in ("disable", "suspend", "deactivate"):
                new_st = {"suspend": "Expired",
                          "disable": "Disabled",
                          "deactivate": "Deactive"}[action]
                log_customer_status_change(db, c, new_st,
                    reason=f"bulk {action.capitalize()} (mobile)", **_actor)
                c.status = new_st; c.is_suspended = True
                try: _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e: errors.append(f"enforce {c.customer_id}: {_e}")
            elif action in ("enable", "resume"):
                log_customer_status_change(db, c, "Active",
                    reason=f"bulk {action.capitalize()} (mobile)", **_actor)
                c.status = "Active"; c.is_suspended = False
                try: _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e: errors.append(f"enforce {c.customer_id}: {_e}")
            elif action == "park":
                log_customer_status_change(db, c, "Parked",
                    reason="bulk Park (mobile)", **_actor)
                c.status = "Parked"; c.is_suspended = True
                try: _router_kick_active_session(db, company_id, c)
                except Exception as _e: errors.append(f"park-kick {c.customer_id}: {_e}")
            elif action == "unpark":
                log_customer_status_change(db, c, "Active",
                    reason="bulk Unpark (mobile)", **_actor)
                c.status = "Active"; c.is_suspended = False
                try: _router_kick_active_session(db, company_id, c)
                except Exception as _e: errors.append(f"unpark-kick {c.customer_id}: {_e}")
            elif action == "terminate":
                log_customer_status_change(db, c, "Terminated",
                    reason="bulk Terminate (mobile)", **_actor)
                c.status = "Terminated"; c.is_suspended = True
                try: _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e: errors.append(f"enforce {c.customer_id}: {_e}")
            elif action == "assign_nas":
                # _S58BD_NAS_AUTO_  Bulk re-route customers to a new NAS.
                # nas_id is read from the request body once outside the
                # loop (see below). Tracks rebound count separately.
                if not _nas_id_target:
                    return JSONResponse({"success": False,
                        "message": "assign_nas requires nas_id in body"},
                        status_code=400)
                c.provisioned_nas_id = _nas_id_target
                # Force a router-secret re-sync on next CoA.
                try: _enforce_user_state(db, c, force_radius_restart=False)
                except Exception as _e: errors.append(f"enforce {c.customer_id}: {_e}")
            else:
                return JSONResponse({"success": False,
                                     "message": f"Unknown action {action!r}"},
                                    status_code=400)
            touched += 1
        except Exception as e:
            errors.append(f"{c.customer_id}: {e}")
    db.commit()
    try:
        from radius_network import _sync_freeradius_all_tenants
        _sync_freeradius_all_tenants(db, restart=True)
    except Exception as e:
        errors.append(f"freeradius-sync: {e}")
    if action in ("make_active", "enable", "resume", "unpark"):
        try:
            import time as _t; _t.sleep(1.5)
            for _c in rows:
                if (_c.status or "").lower() == "active":
                    try: _coa_kick(_c)
                    except Exception as _ke: errors.append(f"2nd-kick {_c.customer_id}: {_ke}")
        except Exception as _e: errors.append(f"post-restart kick: {_e}")

    msg = f"{action} applied to {touched} customer(s)"
    if kicked: msg += f", {kicked} live session(s) kicked"
    if errors: msg += f"; {len(errors)} error(s)"
    return {"success": True, "ok": True, "message": msg,
            "touched": touched, "kicked": kicked, "errors": errors}


@app.post("/api/internal/onus/{onu_id}/factory-reset")
async def api_internal_onu_factory_reset(onu_id: int, request: Request,
                                          db: Session = Depends(get_db)):
    """GenieACS factory-reset for an ONU. Resolves the GenieACS device
    _id by serial then posts a factoryReset task. Localhost +
    X-Internal-Token gated."""
    cid_or_resp = require_admin_or_internal(request)
    if not isinstance(cid_or_resp, str):
        return cid_or_resp
    company_id = cid_or_resp
    try:
        from olt_routes import _settings_for
        row = db.execute(text(
            "SELECT serial, mac FROM onus WHERE id=:id AND company_id=:cid LIMIT 1"
        ), {"id": int(onu_id), "cid": company_id}).fetchone()
        if not row:
            return JSONResponse({"ok": False, "message": "onu_not_found"},
                                status_code=404)
        sn = (row[0] or row[1] or "").upper()
        if not sn:
            return JSONResponse({"ok": False, "message": "no_serial"},
                                status_code=400)
        s = _settings_for(company_id)
        base = (s.get("genieacs_url") or "").rstrip("/")
        if not base:
            return JSONResponse({"ok": False,
                "message": "ACS URL not configured for this tenant."},
                status_code=400)
        import urllib.request, urllib.parse, base64 as _b64, json as _j
        auth_hdr = None
        if s.get("genieacs_username"):
            tok = _b64.b64encode(f"{s["genieacs_username"]}:{s.get("genieacs_password") or ""}".encode()).decode()
            auth_hdr = "Basic " + tok
        # 1) Resolve real ACS device _id by SerialNumber.
        device_id = None
        try:
            q = _j.dumps({"_deviceId._SerialNumber": sn})
            qurl = (base + "/devices?query=" + urllib.parse.quote(q) + "&projection=_id")
            qreq = urllib.request.Request(qurl)
            if auth_hdr: qreq.add_header("Authorization", auth_hdr)
            with urllib.request.urlopen(qreq, timeout=8) as r:
                arr = _j.loads(r.read(8192).decode("utf-8","ignore") or "[]")
                if isinstance(arr, list) and arr:
                    device_id = arr[0].get("_id")
        except Exception as _qe:
            return JSONResponse({"ok": False,
                "message": f"ACS device lookup failed: {_qe}"},
                status_code=502)
        if not device_id:
            return JSONResponse({"ok": False,
                "message": f"ONU {sn!r} not registered with ACS yet."},
                status_code=404)
        # 2) POST factoryReset task.
        url = (base + "/devices/" + urllib.parse.quote(device_id)
               + "/tasks?connection_request")
        req = urllib.request.Request(url,
                data=_j.dumps({"name": "factoryReset"}).encode(),
                headers={"Content-Type": "application/json"})
        if auth_hdr: req.add_header("Authorization", auth_hdr)
        with urllib.request.urlopen(req, timeout=10) as r:
            return {"ok": True, "status": r.status,
                    "device_id": device_id,
                    "response": r.read(2048).decode("utf-8","ignore")}
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"factory_reset_failed: {e!r}"},
                            status_code=500)
# _S58AW_INTERNAL_BULK_END_


# _S58AW_WELCOME_EMAIL_BEGIN_
async def s58aw_send_welcome_email(customer, company, plan_name: str,
                                    raw_password: str, invoice_pdf: bytes = b""):
    """Send a one-time Welcome email to a new customer with their PPPoE /
    portal credentials and (optionally) their first invoice attached.

    SMTP resolution mirrors send_invoice_email(): company → superadmin →
    env. Failures are logged but never raise (the customer is already
    persisted; email is best-effort)."""
    import smtplib
    from email.mime.multipart import MIMEMultipart
    from email.mime.text import MIMEText
    from email.mime.application import MIMEApplication
    from email.utils import formataddr

    try:
        if not customer or not getattr(customer, 'customer_email', None):
            return {"ok": False, "skip": "no_email"}
        # Resolve SMTP — same fallback chain as send_invoice_email.
        smtp_server  = getattr(company, 'smtp_server', None)
        smtp_port    = getattr(company, 'smtp_port', None)
        smtp_user    = getattr(company, 'smtp_username', None)
        smtp_pass    = getattr(company, 'smtp_password', None)
        if not all([smtp_server, smtp_port, smtp_user, smtp_pass]):
            try:
                from database import SessionLocal
                from sqlalchemy import text as _t
                _tmp = SessionLocal()
                try:
                    r = _tmp.execute(_t(
                        "SELECT smtp_server, smtp_port, smtp_username, smtp_password "
                        "FROM superadmins WHERE id = 1"
                    )).fetchone()
                    if r and all([r[0], r[1], r[2], r[3]]):
                        smtp_server = smtp_server or r[0]
                        smtp_port   = smtp_port   or r[1]
                        smtp_user   = smtp_user   or r[2]
                        smtp_pass   = smtp_pass   or r[3]
                finally:
                    _tmp.close()
            except Exception as _e:
                print(f"[welcome-email] SA SMTP lookup failed: {_e}")
        if not all([smtp_server, smtp_port, smtp_user, smtp_pass]):
            print(f"[welcome-email] no SMTP configured — skipping for "
                  f"{customer.customer_id}")
            return {"ok": False, "skip": "no_smtp"}
        try: smtp_port = int(smtp_port)
        except Exception: pass

        comp_name = (getattr(company, 'company_name', '') or 'Auto ISP Billing').upper()
        msg = MIMEMultipart('mixed')
        msg['From']     = formataddr((f"{comp_name} - Welcome", smtp_user))
        msg['To']       = customer.customer_email
        msg['Reply-To'] = smtp_user
        msg['Subject']  = f"Welcome to {comp_name} — Your account is ready"

        portal_url = (getattr(company, 'portal_url', None)
                      or f"https://{getattr(company,'company_id','')}.autoispbilling.com")
        body_html = f"""<!doctype html><html><body style="font-family:Arial,sans-serif;
  color:#222;padding:0;margin:0;background:#f7f7fb">
<div style="max-width:600px;margin:0 auto;background:#fff;padding:24px;
  border-radius:8px;border:1px solid #e7e7ee">
  <h2 style="color:#5b3fc4;margin:0 0 12px">Welcome aboard, {customer.customer_name or 'Customer'}!</h2>
  <p style="font-size:14px;line-height:1.5">
    Your <b>{comp_name}</b> account has been created. Please save the
    credentials below — you'll need them every time you sign in to the
    customer portal or your router's PPPoE dialer.
  </p>
  <table style="width:100%;border-collapse:collapse;margin:12px 0;
    font-size:14px;border:1px solid #e7e7ee">
    <tr><td style="padding:8px 12px;background:#f4f1ff;width:35%">Customer&nbsp;ID</td>
        <td style="padding:8px 12px"><b>{customer.customer_id}</b></td></tr>
    <tr><td style="padding:8px 12px;background:#f4f1ff">Username</td>
        <td style="padding:8px 12px">{customer.username or '—'}</td></tr>
    <tr><td style="padding:8px 12px;background:#f4f1ff">Password</td>
        <td style="padding:8px 12px"><b>{raw_password or '—'}</b></td></tr>
    <tr><td style="padding:8px 12px;background:#f4f1ff">Plan</td>
        <td style="padding:8px 12px">{plan_name or '—'}</td></tr>
    <tr><td style="padding:8px 12px;background:#f4f1ff">Customer Portal</td>
        <td style="padding:8px 12px"><a href="{portal_url}">{portal_url}</a></td></tr>
  </table>
  <p style="font-size:13px;color:#666">
    Your first invoice is attached to this email. For any help reach us
    on <b>{getattr(company, 'company_phone', '') or 'our support number'}</b>
    or reply to this email.
  </p>
  <p style="font-size:13px;color:#888;margin-top:20px">
    — Team {comp_name}
  </p>
</div></body></html>"""
        msg.attach(MIMEText(body_html, 'html', 'utf-8'))

        if invoice_pdf:
            try:
                att = MIMEApplication(invoice_pdf, _subtype='pdf')
                att.add_header('Content-Disposition', 'attachment',
                               filename=f"Welcome-Invoice-{customer.customer_id}.pdf")
                msg.attach(att)
            except Exception as _ae:
                print(f"[welcome-email] attach failed: {_ae}")

        # SMTP send (SSL on 465, STARTTLS otherwise).
        port = int(smtp_port or 587)
        try:
            if port == 465:
                with smtplib.SMTP_SSL(smtp_server, port, timeout=15) as srv:
                    srv.login(smtp_user, smtp_pass)
                    srv.send_message(msg)
            else:
                with smtplib.SMTP(smtp_server, port, timeout=15) as srv:
                    srv.starttls()
                    srv.login(smtp_user, smtp_pass)
                    srv.send_message(msg)
            print(f"[welcome-email] ✓ sent to {customer.customer_email} "
                  f"(customer {customer.customer_id})")
            return {"ok": True}
        except Exception as e:
            print(f"[welcome-email] SMTP send failed for {customer.customer_email}: {e}")
            return {"ok": False, "error": str(e)}
    except Exception as e:
        print(f"[welcome-email] unhandled error: {e}")
        return {"ok": False, "error": str(e)}
# _S58AW_WELCOME_EMAIL_END_



# _S58BD_NAS_AUTO_DONE_  Default-NAS resolver + assign-nas action used
# by create_customer fallback and the new bulk-assign endpoint.
def _s58bd_default_nas_id(db, company_id: str) -> "Optional[int]":
    """Return the *oldest* Active NAS id for the tenant (or None)."""
    try:
        from radius_network import NasDevice
        n = (db.query(NasDevice)
                .filter(NasDevice.company_id == company_id,
                        NasDevice.status == "Active")
                .order_by(NasDevice.id.asc())
                .first())
        return n.id if n else None
    except Exception as e:
        print(f"[s58bd default-nas] {e}")
        return None
