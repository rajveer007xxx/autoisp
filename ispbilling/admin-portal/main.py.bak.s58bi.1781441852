import secrets as _secrets_s36b7
import string as _string_s36b7

def _s36b7_gen_code(length: int = 10) -> str:
    """Generate a human-friendly voucher code (no confusing chars)."""
    alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"  # omit O,0,I,1
    return "".join(_secrets_s36b7.choice(alphabet) for _ in range(length))

