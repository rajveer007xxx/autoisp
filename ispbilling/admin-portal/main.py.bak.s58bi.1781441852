# _v4734_UPSERT_ONU_PIN_DIRECT
# ────────────────────────────────────────────────────────────────
# Direct (no Customer ORM) variant: upsert a network_hardware pin
# given the raw onu_id + lat + lng. Used after EVERY pathway that
# mutates `onus.lat/lng/location_source` (mobile endpoint, admin
# drag-to-correct, network-map "place" endpoint).
# Idempotent. Returns True on success, False on failure (non-fatal).
def _v4734_upsert_onu_pin(db, company_id, onu_id, lat, lng,
                           source="manual", actor="admin"):
    try:
        from sqlalchemy import text as _t
        import json as _j
        # Look up the ONU row + linked customer in one shot.
        row = db.execute(_t(
            "SELECT o.id, o.olt_id, o.serial, o.mac, o.status, o.rx_power, "
            "       o.tx_power, o.pon_port_index, o.customer_id, "
            "       c.customer_name, c.customer_phone, c.locality "
            "  FROM onus o "
            "  LEFT JOIN customers c ON c.customer_id=o.customer_id "
            "                       AND c.company_id=o.company_id "
            " WHERE o.id=:oid AND o.company_id=:cid LIMIT 1"
        ), {"oid": onu_id, "cid": company_id}).fetchone()
        if not row:
            return False
        cust_id   = row[8] or ""
        cust_name = row[9] or row[2] or f"ONU-{onu_id}"
        # Build display name preferring customer_id for the search anchor.
        nm = f"{cust_name} ({cust_id})" if cust_id else f"ONU-{onu_id} ({row[2] or 'no-sn'})"
        props = {
            "customer_id":    cust_id,
            "customer_name":  row[9] or "",
            "customer_phone": row[10] or "",
            "status":         row[4] or "Pending",
            "modem_no":       row[2] or "",
            "mac_address":    row[3] or "",
            "rx_power":       row[5] or "",
            "tx_power":       row[6] or "",
            "pon_port":       row[7] or "",
            "olt_id":         row[1] or "",
            "source":         source,
            "auto":           True,
        }
        # Find existing pin (prefer ref_onu_id match; fall back to name).
        existing = db.execute(_t(
            "SELECT id FROM network_hardware "
            " WHERE company_id=:cid AND kind='onu' AND ref_onu_id=:rid LIMIT 1"
        ), {"cid": company_id, "rid": onu_id}).fetchone()
        if not existing and cust_id:
            existing = db.execute(_t(
                "SELECT id FROM network_hardware "
                " WHERE company_id=:cid AND kind='onu' "
                "   AND name LIKE :nm LIMIT 1"
            ), {"cid": company_id, "nm": f"%({cust_id})%"}).fetchone()
        if existing:
            db.execute(_t(
                "UPDATE network_hardware "
                "   SET name=:nm, lat=:lat, lng=:lng, "
                "       ref_olt_id=:rolt, ref_onu_id=:ronu, "
                "       props_json=:p, updated_at=CURRENT_TIMESTAMP "
                " WHERE id=:id"
            ), {"nm": nm, "lat": float(lat), "lng": float(lng),
                "rolt": row[1], "ronu": onu_id,
                "p": _j.dumps(props, ensure_ascii=False),
                "id": existing[0]})
            print(f"[_v4734_upsert_onu_pin] moved pin #{existing[0]} for ONU {onu_id} → ({lat},{lng})")
        else:
            db.execute(_t(
                "INSERT INTO network_hardware "
                " (company_id, kind, name, lat, lng, "
                "  ref_olt_id, ref_onu_id, props_json, created_by) "
                " VALUES (:cid, 'onu', :nm, :lat, :lng, "
                "         :rolt, :ronu, :p, :cb)"
            ), {"cid": company_id, "nm": nm,
                "lat": float(lat), "lng": float(lng),
                "rolt": row[1], "ronu": onu_id,
                "p": _j.dumps(props, ensure_ascii=False),
                "cb": actor or "admin"})
            print(f"[_v4734_upsert_onu_pin] created pin for ONU {onu_id} at ({lat},{lng})")
        db.commit()
        return True
    except Exception as _e:
        print(f"[_v4734_upsert_onu_pin] FAILED (non-fatal): {_e}")
        return False
# ────────────────────────────────────────────────────────────────

# _v4732_ATTACH_ONU_PIN
# ────────────────────────────────────────────────────────────────
# Idempotent helper that ensures a customer with installation lat/lng
# AND a modem/MAC has a SINGLE network_hardware ONU pin on the GIS
# map, linked (via ref_onu_id/ref_olt_id) to the real ONU row so the
# popup shows the same Connect / Trace Path / Open-in-OLT-Mgmt /
# Delete actions as manually-dropped pins.
#
# Called from create_customer and update_customer. Failure is
# non-fatal — logs and returns False.
def _v4732_attach_onu_pin(db, customer, company_id, created_by="admin"):
    try:
        from sqlalchemy import text as _t
        import json as _j
        lat = getattr(customer, "latitude", None)
        lng = getattr(customer, "longitude", None)
        if lat in (None, "", 0) or lng in (None, "", 0):
            return False
        # Need at least ONE physical identifier to be useful as an ONU pin.
        modem  = (getattr(customer, "modem_no",    "") or "").strip()
        mac    = (getattr(customer, "mac_address", "") or "").strip()
        if not modem and not mac:
            return False

        # 1) Look up the actual ONU row by serial=modem_no OR mac.
        onu_row = None
        try:
            if modem:
                onu_row = db.execute(_t(
                    "SELECT id, olt_id, status, rx_power, tx_power "
                    "  FROM onus "
                    " WHERE company_id=:cid "
                    "   AND (LOWER(IFNULL(serial,''))=LOWER(:modem)) "
                    " LIMIT 1"
                ), {"cid": company_id, "modem": modem}).fetchone()
            if not onu_row and mac:
                onu_row = db.execute(_t(
                    "SELECT id, olt_id, status, rx_power, tx_power "
                    "  FROM onus "
                    " WHERE company_id=:cid "
                    "   AND (LOWER(IFNULL(mac,''))=LOWER(:mac)) "
                    " LIMIT 1"
                ), {"cid": company_id, "mac": mac}).fetchone()
        except Exception:
            onu_row = None

        # S42S-NO-FAKE-ONU: do NOT create/update an ONU pin unless the
        # modem/MAC actually corresponds to a row in the `onus` table.
        # The customer's lat/lng marker by itself is enough until a real
        # device is provisioned by admin/sub-LCO/employee.
        if not onu_row:
            print(f"[_v4732_attach_onu_pin] skipped — no real ONU for "
                  f"customer {customer.customer_id} (modem={modem!r}, mac={mac!r})")
            return False

        ref_onu_id = onu_row[0] if onu_row else None
        ref_olt_id = onu_row[1] if onu_row else None
        onu_status = (onu_row[2] if onu_row else "") or "Pending"
        onu_rx     = (onu_row[3] if onu_row else "") or ""
        onu_tx     = (onu_row[4] if onu_row else "") or ""

        # 2) Locate any EXISTING pin for this customer (prefer ref_onu_id
        # match, then name match — keeps us idempotent even if the user
        # previously had it without a linked onus row).
        existing = None
        if ref_onu_id:
            existing = db.execute(_t(
                "SELECT id FROM network_hardware "
                " WHERE company_id=:cid AND kind='onu' "
                "   AND ref_onu_id=:rid LIMIT 1"
            ), {"cid": company_id, "rid": ref_onu_id}).fetchone()
        if not existing:
            existing = db.execute(_t(
                "SELECT id FROM network_hardware "
                " WHERE company_id=:cid AND kind='onu' "
                "   AND name LIKE :nm LIMIT 1"
            ), {"cid": company_id,
                "nm": f"%{customer.customer_id}%"}).fetchone()

        props = {
            "customer_id":    str(customer.customer_id or ""),
            "customer_name":  customer.customer_name or "",
            "customer_phone": customer.customer_phone or "",
            "status":         onu_status,
            "modem_no":       modem,
            "mac_address":    mac,
            "rx_power":       onu_rx,
            "tx_power":       onu_tx,
            "auto":           True,
            "source":         "auto-attach",
            "linked_onu":     bool(ref_onu_id),
        }
        name = f"{customer.customer_name or 'ONU'} ({customer.customer_id})"

        if existing:
            db.execute(_t(
                "UPDATE network_hardware "
                "   SET name=:nm, lat=:lat, lng=:lng, "
                "       ref_olt_id=:rolt, ref_onu_id=:ronu, "
                "       props_json=:p, updated_at=CURRENT_TIMESTAMP "
                " WHERE id=:id"
            ), {"nm": name, "lat": float(lat), "lng": float(lng),
                "rolt": ref_olt_id, "ronu": ref_onu_id,
                "p": _j.dumps(props, ensure_ascii=False),
                "id": existing[0]})
            print(f"[_v4732_attach_onu_pin] moved pin #{existing[0]} for "
                  f"{customer.customer_id} → ({lat},{lng}) "
                  f"ref_onu_id={ref_onu_id} ref_olt_id={ref_olt_id}")
        else:
            db.execute(_t(
                "INSERT INTO network_hardware "
                " (company_id, kind, name, lat, lng, "
                "  ref_olt_id, ref_onu_id, props_json, created_by) "
                " VALUES (:cid, 'onu', :nm, :lat, :lng, "
                "         :rolt, :ronu, :p, :cb)"
            ), {"cid": company_id, "nm": name,
                "lat": float(lat), "lng": float(lng),
                "rolt": ref_olt_id, "ronu": ref_onu_id,
                "p": _j.dumps(props, ensure_ascii=False),
                "cb": created_by or "admin"})
            print(f"[_v4732_attach_onu_pin] created pin for "
                  f"{customer.customer_id} at ({lat},{lng}) "
                  f"ref_onu_id={ref_onu_id} ref_olt_id={ref_olt_id}")
        db.commit()
        return True
    except Exception as _e:
        print(f"[_v4732_attach_onu_pin] FAILED (non-fatal): {_e}")
        return False
