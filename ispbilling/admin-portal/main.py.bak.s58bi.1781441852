# === Session 27.9 payment-receipt WhatsApp endpoint ===
@app.post("/api/payments/{payment_id}/send-whatsapp")
async def api_payment_send_whatsapp(payment_id: int, request: Request,
                                      db: Session = Depends(get_db)):
    """Send the payment-receipt download link to the customer's WhatsApp.
    When superadmin flag enable_whatsapp_api is OFF, returns a wa.me
    fallback URL so the UI can open the native app instead."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    from database import Payment, Customer, Company
    pay = db.query(Payment).filter(
        Payment.id == payment_id,
        Payment.company_id == company_id).first()
    if not pay:
        return JSONResponse({"success": False, "message": "payment not found"}, status_code=404)
    cust = db.query(Customer).filter(
        Customer.customer_id == pay.customer_id,
        Customer.company_id == company_id).first()
    phone = (cust.customer_phone if cust else "") or ""
    if not phone:
        return {"success": False, "message": "customer has no phone on file"}

    host = os.environ.get("MAIN_DOMAIN", "autoispbilling.com")
    receipt_url = f"https://{host}/api/payments/{pay.id}/receipt"
    name = cust.customer_name if cust else pay.customer_id
    msg = (f"Hi {name or 'Customer'}, your payment receipt "
           f"(Txn {pay.transaction_no or pay.id}, Rs.{float(pay.amount or 0):.2f}) "
           f"is ready. Download: {receipt_url}")
    # wa.me fallback (always usable)
    digits = "".join(ch for ch in phone if ch.isdigit())
    if len(digits) == 10:
        digits = "91" + digits
    import urllib.parse as _u
    fallback_url = f"https://wa.me/{digits}?text={_u.quote(msg)}" if digits else ""
    # Feature flag check
    comp = db.query(Company).filter(Company.company_id == company_id).first()
    if not comp or not getattr(comp, "enable_whatsapp_api", 0):
        return {"success": False,
                "feature_disabled": True,
                "fallback_wa_url": fallback_url,
                "message": "WhatsApp API disabled by Superadmin"}
    from twilio_whatsapp import _send_freeform, _normalise_phone
    to_ = _normalise_phone(phone)
    if not to_:
        return {"success": False, "message": "invalid phone format"}
    res = _send_freeform(to_, msg)
    return {"success": bool(res.get("success")), "result": res,
            "receipt_url": receipt_url}
# === /Session 27.9 ===


# === Session 28 collectors endpoint ===
@app.get("/api/admin/collectors")
async def api_admin_collectors(request: Request, db: Session = Depends(get_db)):
    """Return list of admins + employees for Payment History 'Collected By' filter.
    __S39L__ Employees see only themselves; Sub-LCOs see only themselves.
    Admins see the full company roster."""
    auth_check = require_auth(request)
    if auth_check:
        return auth_check
    company_id = request.session.get("company_id")
    user_type = (request.session.get("user_type") or "admin").lower()
    from database import Admin, Employee
    
    # __S39L__ Employee: lock to self only.
    if user_type == "employee":
        try:
            eid = int(request.session.get("employee_id") or 0)
            emp = db.query(Employee).filter(Employee.id == eid).first() if eid else None
        except Exception:
            emp = None
        if not emp:
            return {"success": True, "collectors": []}
        return {"success": True, "collectors": [
            {"id": emp.employee_code, "name": emp.employee_name or emp.employee_code, "type": "employee"}
        ]}
    
    # __S43ZH__ Sub-LCO: self + their employees (no admins / other SLCOs).
    if user_type == "sub_lco":
        try:
            from sqlalchemy import text as _t_c
            sid = int(request.session.get("sub_lco_db_id") or 0)
            collectors = []
            row = db.execute(_t_c(
                "SELECT sub_lco_code, COALESCE(name, username, '') AS nm "
                "FROM sub_lcos WHERE id=:s AND company_id=:c"
            ), {"s": sid, "c": company_id}).fetchone()
            if row:
                collectors.append({"id": row[0], "name": row[1] or row[0], "type": "sub_lco"})
            emp_rows = db.execute(_t_c(
                "SELECT employee_code, COALESCE(employee_name, employee_code, '') "
                "  FROM employees "
                " WHERE company_id=:c AND sub_lco_id=:s "
                "   AND COALESCE(is_deleted,0)=0 "
                " ORDER BY employee_name COLLATE NOCASE"
            ), {"c": company_id, "s": sid}).fetchall()
            for er in emp_rows:
                collectors.append({"id": er[0], "name": er[1] or er[0], "type": "employee"})
            return {"success": True, "collectors": collectors}
        except Exception as _ex_c:
            print(f"[collectors] sub_lco branch failed: {_ex_c}")
            return {"success": True, "collectors": []}
    
    admins = db.query(Admin).filter(Admin.company_id == company_id).all()
    emps   = db.query(Employee).filter(Employee.company_id == company_id,
                                        Employee.is_deleted == False).all()
    rows = []
    for a in admins:
        rows.append({"id": a.admin_id, "name": a.admin_name or a.admin_id, "type": "admin"})
    for e in emps:
        rows.append({"id": e.employee_code, "name": e.employee_name or e.employee_code, "type": "employee"})
    # __S43H_COLLECTORS_SUBLCO__: include sub-LCOs in the admin collector dropdown
    try:
        from sqlalchemy import text as _t_sl
        sl_rows = db.execute(_t_sl(
            "SELECT sub_lco_code, COALESCE(name, username, sub_lco_code) AS nm "
            "FROM sub_lcos WHERE company_id=:c "
            "  AND COALESCE(status,'Active') != 'Inactive' "
            "ORDER BY nm COLLATE NOCASE"
        ), {"c": company_id}).fetchall()
        for r in sl_rows:
            rows.append({"id": r[0], "name": r[1] or r[0], "type": "sub_lco"})
    except Exception as _e:
        print(f"[collectors] sub_lcos query failed: {_e}")
    return {"success": True, "collectors": rows}
