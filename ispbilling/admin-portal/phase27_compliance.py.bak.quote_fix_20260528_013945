                     dt_from, dt_from + " 00:00:00",
                     dt_to,   dt_to   + " 23:59:59")).fetchall()
            for r in rows: w.writerow([r[k] for k in r.keys()])
            ipdr_count = len(rows)
            ipdr_bytes = ipdr_csv.getvalue().encode("utf-8")
            z.writestr("ipdr_records.csv", ipdr_bytes)

            # URL log slice
            url_csv = _io.StringIO()
            w = _csv.writer(url_csv)
            w.writerow(["ts", "user_ip", "method", "host", "url", "dst_port",
                          "status_code", "bytes_xfer", "user_agent", "nas_ip"])
            with _conn() as c:
                rows = c.execute(
                    "SELECT ts, user_ip, method, host, url, dst_port, status_code, "
                    "bytes_xfer, user_agent, nas_ip FROM url_logs "
                    "WHERE company_id=? "
                    "  AND ((? != '' AND customer_id=?) OR (? = '')) "
                    "  AND (? = '' OR ts >= ?) "
                    "  AND (? = '' OR ts <= ?) "
                    "ORDER BY ts",
                    (cid, cust_id, cust_id, cust_id,
                     dt_from, dt_from + " 00:00:00",
                     dt_to,   dt_to   + " 23:59:59")).fetchall()
            for r in rows: w.writerow([r[k] for k in r.keys()])
            url_count = len(rows)
            url_bytes = url_csv.getvalue().encode("utf-8")
            z.writestr("url_logs.csv", url_bytes)

            # Session/accounting (radacct mirror) — best effort
            sess_csv = _io.StringIO()
            w = _csv.writer(sess_csv)
            w.writerow(["username", "framedipaddress", "callingstationid",
                          "nasipaddress", "acctstarttime", "acctstoptime",
                          "acctsessiontime", "acctinputoctets", "acctoutputoctets",
                          "acctterminatecause"])
            try:
                rcon = sqlite3.connect(RADACCT_DB, timeout=10)
                rcon.row_factory = sqlite3.Row
                # S42J — backfill + strict company_id fence on LI exports.
                try:
                    from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa7
                    _rp_bfa7(db, radacct_path=RADACCT_DB, limit=2000)
                except Exception:
                    pass
                ra = rcon.execute(
                    "SELECT username, framedipaddress, callingstationid, "
                    "nasipaddress, acctstarttime, acctstoptime, acctsessiontime, "
                    "acctinputoctets, acctoutputoctets, acctterminatecause "
                    "FROM radacct WHERE username=? AND company_id=? "
                    "  AND (? = '' OR acctstarttime >= ?) "
                    "  AND (? = '' OR acctstarttime <= ?) ORDER BY acctstarttime",
                    (target_user, str(cid),
                     dt_from, dt_from + " 00:00:00",
                     dt_to, dt_to + " 23:59:59")).fetchall()
                rcon.close()
                for r in ra:
                    w.writerow([r[k] for k in r.keys()])
                radacct_rows = list(ra)
            except Exception as e:
                w.writerow([f"-- radacct unavailable: {e}", "", "", "", "", "", "", "", "", ""])
            sess_bytes = sess_csv.getvalue().encode("utf-8")
            z.writestr("session_records.csv", sess_bytes)

            # Order metadata
            import json as _json
            md = {
                "order": dict(order),
                "company_id": cid,
                "generated_at": now_str,
                "generated_by": actor,
                "counts": {
                    "ipdr": ipdr_count,
                    "url_logs": url_count,
                    "session_records": len(radacct_rows),
                },
            }
            md_bytes = _json.dumps(md, indent=2, default=str).encode("utf-8")
            z.writestr("order_metadata.json", md_bytes)

            # Chain of custody (sha256 of each file)
            coc = (readme
                + "\n\nFile checksums (SHA-256):\n"
                + f"  ipdr_records.csv     {_h.sha256(ipdr_bytes).hexdigest()}\n"
                + f"  url_logs.csv         {_h.sha256(url_bytes).hexdigest()}\n"
                + f"  session_records.csv  {_h.sha256(sess_bytes).hexdigest()}\n"
                + f"  order_metadata.json  {_h.sha256(md_bytes).hexdigest()}\n"
                + "\nRow counts:\n"
                + f"  ipdr_records.csv    : {ipdr_count}\n"
                + f"  url_logs.csv        : {url_count}\n"
                + f"  session_records.csv : {len(radacct_rows)}\n")
            z.writestr("chain_of_custody.txt", coc)

        buf.seek(0)
        safe_order = re.sub(r"[^A-Za-z0-9_-]+", "_", str(order["order_no"]))[:40]
        fname = f"li_bundle_{safe_order}_{datetime.now(IST).strftime('%Y%m%d_%H%M')}.zip"
        return StreamingResponse(iter([buf.getvalue()]),
            media_type="application/zip",
            headers={"Content-Disposition": f'attachment; filename="{fname}"'})

