def _conn():
    c = sqlite3.connect(DB_PATH, timeout=15)
    c.row_factory = sqlite3.Row
    return c


def _hash_token(token: str) -> str:
    return hashlib.sha256(token.encode("utf-8")).hexdigest()


def _verify_ingest_token(token: str, kind: str) -> Optional[str]:
    """Returns company_id if token is valid + active, else None."""
    if not token:
        return None
    h = _hash_token(token)
    with _conn() as c:
        row = c.execute(
            "SELECT id, company_id FROM compliance_ingest_tokens "
            " WHERE token_hash=? AND kind=? AND COALESCE(revoked,0)=0",
            (h, kind)).fetchone()
        if not row:
            return None
        c.execute("UPDATE compliance_ingest_tokens SET last_used_at=? WHERE id=?",
                  (datetime.now(timezone.utc).isoformat(), row["id"]))
        c.commit()
        return row["company_id"]


# ───────────────────────────────────────────── retention policy core
RETENTION_DAYS = 730  # 2 years
ARCHIVE_DIR = "/var/lib/autoispbilling/compliance_archive"


def _run_retention_once(scope_company_id: str = None) -> dict:
    """Archive then delete rows older than RETENTION_DAYS from compliance tables.

    __S55G_RETENTION_COMPANY__ — Multi-tenant aware.

    If scope_company_id is provided (e.g. when called from an admin UI),
    only that tenant's rows are processed and the resulting retention_runs
    record carries the same company_id.

    If scope_company_id is None (system cron / SuperAdmin), the function
    iterates over every distinct company_id in each target table and
    writes one retention_runs row per (table, company_id). It additionally
    emits a single 'radacct' row (company_id IS NULL) as a system-wide
    attestation, since FreeRADIUS accounting is not per-tenant scoped at
    the row level.
    """
    os.makedirs(ARCHIVE_DIR, exist_ok=True)
    cutoff = datetime.now(timezone.utc) - timedelta(days=RETENTION_DAYS)
    cutoff_iso = cutoff.strftime("%Y-%m-%d %H:%M:%S")
    summary = []

    targets = [
        ("ipdr_records", "start_ts",
         "id,company_id,customer_id,user_ip,src_ip,src_port,dst_ip,dst_port,protocol,start_ts,stop_ts,bytes_in,bytes_out,nas_ip,created_at"),
        ("url_logs", "ts",
         "id,company_id,customer_id,user_ip,ts,method,host,url,dst_port,status_code,bytes_xfer,user_agent,nas_ip,created_at"),
    ]

    for table, ts_col, cols in targets:
        # Determine which companies to process this run.
        if scope_company_id:
            companies = [str(scope_company_id)]
        else:
            try:
                with _conn() as c:
                    companies = [str(r[0]) for r in c.execute(
                        f"SELECT DISTINCT company_id FROM {table} "
                        f"WHERE company_id IS NOT NULL AND company_id != \'\'"
                    ).fetchall()]
            except Exception:
                companies = []

        # Nothing to do for this table? Still log an empty per-tenant row
        # so the UI shows the run finished.
        if not companies:
            companies = [scope_company_id] if scope_company_id else []

        for cid in companies:
            rows_archived = 0
            rows_deleted = 0
            archive_path = ""
            ok = 1
            msg = ""
            try:
                with _conn() as c:
                    rows = c.execute(
                        f"SELECT {cols} FROM {table} "
                        f"WHERE company_id = ? AND {ts_col} IS NOT NULL AND {ts_col} < ?",
                        (cid, cutoff_iso)).fetchall()
                    if rows:
                        archive_path = os.path.join(
                            ARCHIVE_DIR,
                            f"{table}_{cid}_pruned_{datetime.now(timezone.utc).strftime(\'%Y%m%d_%H%M%S\')}.csv")
                        with open(archive_path, "w", encoding="utf-8", newline="") as f:
                            w = csv.writer(f)
                            w.writerow(cols.split(","))
                            for r in rows:
                                w.writerow([r[k] if k in r.keys() else "" for k in cols.split(",")])
                        rows_archived = len(rows)
                        c.execute(
                            f"DELETE FROM {table} "
                            f"WHERE company_id = ? AND {ts_col} IS NOT NULL AND {ts_col} < ?",
                            (cid, cutoff_iso))
                        rows_deleted = c.total_changes
                        c.commit()
                    msg = f"archived {rows_archived}, deleted {rows_deleted}"
            except Exception as e:
                ok = 0
                msg = f"error: {e}"

            with _conn() as c:
                c.execute(
                    "INSERT INTO retention_runs(target_table,cutoff_ts,rows_archived,"
                    " rows_deleted,archive_path,ok,message,company_id) VALUES (?,?,?,?,?,?,?,?)",
                    (table, cutoff_iso, rows_archived, rows_deleted,
                     archive_path, ok, msg, cid))
                c.commit()
            summary.append({"table": table, "company_id": cid,
                            "archived": rows_archived, "deleted": rows_deleted,
                            "ok": bool(ok), "msg": msg})

    # radacct attestation — emitted only on system-wide (no scope) runs
    # because radacct is not per-tenant scoped at the row level.
    if not scope_company_id:
        try:
            rcon = sqlite3.connect(RADACCT_DB, timeout=10)
            ra_cnt = rcon.execute(
                "SELECT COUNT(*) FROM radacct WHERE acctstarttime IS NOT NULL "
                " AND acctstarttime < datetime(?, \'unixepoch\')",
                (int(cutoff.timestamp()),)).fetchone()[0]
            rcon.close()
        except Exception as e:
            ra_cnt = -1
        with _conn() as c:
            c.execute(
                "INSERT INTO retention_runs(target_table,cutoff_ts,rows_archived,"
                " rows_deleted,ok,message,company_id) VALUES (\'radacct\',?,?,0,1,?,NULL)",
                (cutoff_iso, ra_cnt,
                 f"radacct rows older than cutoff: {ra_cnt} (kept; read-only)"))
            c.commit()
        summary.append({"table": "radacct", "older_count": ra_cnt, "kept": True})

    return {"cutoff": cutoff_iso, "summary": summary,
            "scope_company_id": scope_company_id}


