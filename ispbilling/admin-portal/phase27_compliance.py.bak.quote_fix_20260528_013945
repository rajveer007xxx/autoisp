        cutoff_24 = (datetime.now(timezone.utc) - timedelta(hours=24)).strftime("%Y-%m-%d %H:%M:%S")
        items = []
        with _conn() as c:
            # _S40zP_lock_filter_nps_ Hide locked sub-lco customer ip from counts
            try:
                _hide_p = _hidden_cust_ids_p27(request, db)
            except Exception:
                _hide_p = set()
            _excl_sql = "" if not _hide_p else (
                " AND COALESCE(customer_id,'') NOT IN (" + ",".join('?' for _ in _hide_p) + ")")
            _excl_args = list(_hide_p)
            for nas in nas_list:
                ip = nas.ip_address or ""
                ipdr_last = c.execute(
                    "SELECT MAX(created_at) FROM ipdr_records WHERE company_id=? AND nas_ip=?" + _excl_sql,
                    tuple([cid, ip] + _excl_args)).fetchone()[0]
                url_last  = c.execute(
                    "SELECT MAX(created_at) FROM url_logs   WHERE company_id=? AND nas_ip=?",
                    (cid, ip)).fetchone()[0]
                ipdr_24 = c.execute(
                    "SELECT COUNT(*) FROM ipdr_records WHERE company_id=? AND nas_ip=? AND created_at >= ?",
                    (cid, ip, cutoff_24)).fetchone()[0]
                url_24  = c.execute(
                    "SELECT COUNT(*) FROM url_logs   WHERE company_id=? AND nas_ip=? AND created_at >= ?",
                    (cid, ip, cutoff_24)).fetchone()[0]
                # Has a deployment script ever been generated for this NAS?
                deploys = c.execute(
                    "SELECT kind, MAX(generated_at) AS gen FROM nas_compliance_deployments "
                    "WHERE company_id=? AND nas_id=? GROUP BY kind",
                    (cid, nas.id)).fetchall()
                deploy_map = {d["kind"]: d["gen"] for d in deploys}
                items.append({
                    "nas_id": nas.id, "name": nas.name or "",
                    "ip": ip,
                    "ipdr_last": ipdr_last, "ipdr_count_24h": ipdr_24,
                    "ipdr_deployed_at": deploy_map.get("ipdr"),
                    "url_last": url_last,   "url_count_24h": url_24,
                    "url_deployed_at": deploy_map.get("url"),
                })
        # Compute per-NAS status pill (green/amber/red)
        now = datetime.now(timezone.utc)
        for it in items:
            for kind in ("ipdr", "url"):
                last_key = f"{kind}_last"
                deploy_key = f"{kind}_deployed_at"
                status_key = f"{kind}_status"
                last = it[last_key]
                if not it[deploy_key]:
                    it[status_key] = "not_deployed"
                    continue
                if not last:
                    it[status_key] = "deployed_no_data"
                    continue
                try:
                    dt = datetime.strptime(last[:19], "%Y-%m-%d %H:%M:%S")
                    delta_min = (now.replace(tzinfo=None) - dt).total_seconds() / 60
                except Exception:
                    delta_min = 99999
                if delta_min < 30:
                    it[status_key] = "active"
                elif delta_min < 240:
                    it[status_key] = "stale"
                else:
                    it[status_key] = "stopped"
        return {"success": True, "items": items}

