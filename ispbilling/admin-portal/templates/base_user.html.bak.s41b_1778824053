<body>
    <header class="user-header">
        <div class="user-header-inner">
            <a class="brand" href="/customer/dashboard">
                <span class="brand-logo{% if company_logo %} has-image{% endif %}">
                    {% if company_logo %}
                        <img src="{{ company_logo }}" alt="{{ company_name }}">
                    {% else %}
                        <i class="bi bi-broadcast-pin"></i>
                    {% endif %}
                </span>
                <span>{{ company_name|default('My ISP') }}</span>
            </a>

            <span class="online-pill {{ 'online' if is_online else 'offline' }}" data-testid="user-online-pill" id="userOnlinePill">
                <span class="dot"></span>
                {{ 'Online' if is_online else 'Offline' }}
            </span>

            <nav class="nav-pills">
                <a href="/customer/dashboard"      class="{{ 'active' if active_page == 'dashboard' }}"      data-testid="user-nav-dashboard">Dashboard</a>
                <a href="/customer/invoices"       class="{{ 'active' if active_page == 'invoices' }}"       data-testid="user-nav-invoices">Invoices</a>
                <a href="/customer/payments"       class="{{ 'active' if active_page == 'payments' }}"       data-testid="user-nav-payments">Payments</a>
                <a href="/customer/usage"          class="{{ 'active' if active_page == 'usage' }}"          data-testid="user-nav-usage">Data Usage</a>
                <a href="/customer/complaints"     class="{{ 'active' if active_page == 'complaints' }}"     data-testid="user-nav-complaints">Support</a>
                <a href="/customer/change-plan"    class="{{ 'active' if active_page == 'change_plan' or active_page == 'change_package' or active_page == 'upgrade_plan' }}" data-testid="user-nav-change-plan">Change Plan</a>
                <a href="/customer/wifi-settings"  class="{{ 'active' if active_page == 'wifi_settings' }}"  data-testid="user-nav-wifi">WiFi Settings</a>
                <a href="/customer/profile"        class="{{ 'active' if active_page == 'profile' }}"        data-testid="user-nav-profile">Profile</a>
            </nav>

            <div class="user-menu">
                {# _v4730_AVATAR  Show customer photo first, fall back to initial. #}
                {% set _cust_img = customer.photograph_path if customer and customer.photograph_path else "" %}
                {% if _cust_img %}
                  <img src="{{ _cust_img if _cust_img.startswith('/') or _cust_img.startswith('http') else '/' ~ _cust_img }}"
                       class="avatar avatar-img" alt="profile"
                       data-testid="user-avatar-img"
                       onerror="this.outerHTML='<span class=&quot;avatar&quot; data-testid=&quot;user-avatar-letter&quot;>'+'{{ (customer_name|default('U'))[0]|upper }}'+'</span>'">
                {% else %}
                  <span class="avatar" data-testid="user-avatar-letter">{{ (customer_name|default('U'))[0]|upper }}</span>
                {% endif %}
                <span class="name" data-testid="user-name">{{ customer_name|default('Customer') }}</span>
                <a href="#" onclick="fetch('/api/auth/logout',{method:'POST'}).then(()=>location='/login');return false;" title="Logout" style="color:var(--text-mid);font-size:16px;">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </div>
    </header>

    <main>{% block content %}{% endblock %}</main>

    <script>
    // Auto-refresh online status every 30s
    (function pollOnline(){
        fetch('/api/customer/me/online-status').then(r=>r.json()).then(d=>{
            const p = document.getElementById('userOnlinePill');
            if(!p) return;
            const dot = p.querySelector('.dot');
            if(d && d.online){
                p.classList.add('online'); p.classList.remove('offline');
                p.lastChild.textContent = ' Online';
            } else {
                p.classList.add('offline'); p.classList.remove('online');
                p.lastChild.textContent = ' Offline';
            }
        }).catch(()=>{});
    })();
    setInterval(()=>{ fetch('/api/customer/me/online-status').then(r=>r.json()).then(d=>{
        const p = document.getElementById('userOnlinePill'); if(!p) return;
        const cls = d.online ? 'online' : 'offline';
        p.className = 'online-pill ' + cls;
        p.lastChild.textContent = d.online ? ' Online' : ' Offline';
    }).catch(()=>{}); }, 30000);
    </script>
