<!-- _S40zθ_  IST DD-MM-YYYY HH:MM formatter (shared across portals) -->
<script>
(function(){
  if (window.__S40ZG_IST_INIT__) return; window.__S40ZG_IST_INIT__ = true;
  function pad(n){ return n < 10 ? ('0'+n) : (''+n); }
  // _GLOBAL_FMTIST_STR_SAFE_V1_ : fmtIST is now string-safe + null-safe.
  function fmtIST(d){
