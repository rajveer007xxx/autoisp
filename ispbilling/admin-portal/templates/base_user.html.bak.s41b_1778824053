<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ company_name|default('User Portal') }}{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ company_logo|default('/static/uploads/logos/default.png') }}">

    <!-- Bootstrap Icons + Font -->
    <link rel="stylesheet" href="/static/css/list_headers.css" data-tag="_S39R5A_TBL_HEADERS">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --brand-primary: {{ company_theme_color|default('#0ea5e9') }};
            --brand-accent:  {{ company_theme_accent|default('#7c3aed') }};
            --bg-base:       #0f172a;
            --bg-elev:       #1e293b;
            --bg-card:       rgba(255,255,255,0.04);
            --text-hi:       #f1f5f9;
            --text-mid:      #94a3b8;
            --text-lo:       #64748b;
            --border:        rgba(255,255,255,0.08);
            --success:       #10b981;
            --warn:          #f59e0b;
            --danger:        #ef4444;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: radial-gradient(ellipse at top right, rgba(124,58,237,0.15), transparent 50%),
                        radial-gradient(ellipse at bottom left,  rgba(14,165,233,0.18), transparent 50%),
                        var(--bg-base);
            color: var(--text-hi);
            min-height: 100vh;
            line-height: 1.55;
            -webkit-font-smoothing: antialiased;
        }
        a { color: inherit; text-decoration: none; }
        ::selection { background: var(--brand-primary); color: #fff; }

        /* Header */
        .user-header {
            position: sticky; top: 0; z-index: 50;
            background: rgba(15,23,42,0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
        }
        .user-header-inner {
            max-width: 1280px; margin: 0 auto;
            padding: 14px 24px;
            display: flex; align-items: center; gap: 16px;
        }
        .brand {
            display: flex; align-items: center; gap: 12px; font-weight: 700; font-size: 18px;
            min-width: 0;
        }
        .brand-logo {
            flex: 0 0 auto;
            min-width: 36px; height: 36px; padding: 0 4px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 8px 20px rgba(14,165,233,0.25);
            overflow: hidden;
        }
        .brand-logo.has-image {
            flex: 0 0 auto;
            background: transparent;
            box-shadow: none;
            padding: 0;
            min-width: 0;
            height: 44px;
            max-width: 240px;
        }
        .brand-logo.has-image img {
            height: 100%; width: auto; max-width: 240px;
            object-fit: contain; display: block;
        }
        .brand-logo i { color: #fff; font-size: 18px; }
        @media (max-width: 540px) {
            .brand-logo.has-image + span { display: none; }
            .brand-logo.has-image { max-width: 180px; }
            .brand-logo.has-image img { max-width: 180px; }
        }

        /* Online pill */
        .online-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 5px 11px; border-radius: 999px;
            font-size: 11px; font-weight: 700; letter-spacing: .4px;
            text-transform: uppercase;
        }
        .online-pill.online {
            background: rgba(16,185,129,0.15); color: #34d399;
            border: 1px solid rgba(16,185,129,0.3);
        }
        .online-pill.offline {
            background: rgba(239,68,68,0.15); color: #f87171;
            border: 1px solid rgba(239,68,68,0.3);
        }
        .online-pill .dot {
            width: 7px; height: 7px; border-radius: 999px; background: currentColor;
            animation: pulse 1.6s ease-in-out infinite;
        }
        @keyframes pulse {
            0%,100% { opacity: 1; transform: scale(1); }
            50%     { opacity: .5; transform: scale(1.3); }
        }

        .nav-pills {
            display: flex; gap: 4px; margin-left: auto;
        }
        .nav-pills a {
            padding: 8px 14px; border-radius: 8px;
            font-size: 13px; font-weight: 500;
            color: var(--text-mid);
            transition: background .15s, color .15s;
        }
        .nav-pills a:hover { background: rgba(255,255,255,0.05); color: var(--text-hi); }
        .nav-pills a.active {
            background: linear-gradient(135deg, rgba(14,165,233,0.2), rgba(124,58,237,0.2));
            color: #fff;
            border: 1px solid rgba(14,165,233,0.3);
        }

        .user-menu {
            display: flex; align-items: center; gap: 10px;
            padding: 6px 8px 6px 14px; border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--bg-elev);
        }
        .user-menu .name { font-size: 13px; font-weight: 600; }
        .user-menu .avatar-img {width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,.4);}
        .user-menu .avatar {
            width: 32px; height: 32px; border-radius: 999px;
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; color: #fff; font-size: 13px;
        }

        /* Main */
        main { max-width: 1280px; margin: 32px auto 80px; padding: 0 24px; }

        .page-title {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 24px;
        }
        .page-title h1 {
            font-size: 28px; font-weight: 700; letter-spacing: -.02em;
        }
        .page-title p { color: var(--text-mid); font-size: 14px; margin-top: 4px; }

        /* Cards */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            backdrop-filter: blur(8px);
        }
        .card h3 { font-size: 14px; font-weight: 600; color: var(--text-mid); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 12px; }
        .card-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; }

        .stat-tile { padding: 22px; }
        .stat-tile .label { color: var(--text-mid); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }
        .stat-tile .value {
            font-size: 32px; font-weight: 800; letter-spacing: -.02em; margin-top: 8px;
            background: linear-gradient(135deg, var(--text-hi), var(--text-mid));
            -webkit-background-clip: text; background-clip: text; color: transparent;
        }
        .stat-tile .value.accent {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
            -webkit-background-clip: text; background-clip: text; color: transparent;
        }
        .stat-tile .delta { color: var(--text-lo); font-size: 12px; margin-top: 6px; }
        .stat-tile.success .value { background: linear-gradient(135deg, #10b981, #34d399); -webkit-background-clip: text; background-clip: text; color: transparent; }

        /* Buttons */
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 10px 18px; border-radius: 10px;
            border: 1px solid var(--border);
            background: var(--bg-elev);
            color: var(--text-hi); font-size: 13px; font-weight: 600;
            cursor: pointer; transition: all .15s;
            text-decoration: none;
        }
        .btn:hover { transform: translateY(-1px); border-color: var(--brand-primary); }
        .btn.primary {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-accent));
            border: none;
            box-shadow: 0 8px 20px rgba(14,165,233,0.25);
        }
        .btn.primary:hover { filter: brightness(1.1); }
        .btn.danger { background: rgba(239,68,68,0.15); color: #f87171; border-color: rgba(239,68,68,0.3); }

        /* Tables */
        table { width: 100%; border-collapse: collapse; }
        th, td { text-align: left; padding: 12px 14px; font-size: 13px; }
        th { color: var(--text-mid); font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid var(--border); }
        tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); }
        tbody tr:hover { background: rgba(255,255,255,0.02); }
        td.amount { font-weight: 700; font-variant-numeric: tabular-nums; }
        .pill { display: inline-flex; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; }
        .pill.paid { background: rgba(16,185,129,0.15); color: #34d399; }
        .pill.unpaid { background: rgba(239,68,68,0.15); color: #f87171; }
        .pill.partial { background: rgba(245,158,11,0.15); color: #fbbf24; }
        .pill.sent { background: rgba(245,158,11,0.15); color: #fbbf24; }
        .pill.generated { background: rgba(148,163,184,0.15); color: #94a3b8; }
        .pill.pending { background: rgba(245,158,11,0.15); color: #fbbf24; }
        .pill.resolved { background: rgba(16,185,129,0.15); color: #34d399; }
        .pill.open { background: rgba(239,68,68,0.15); color: #f87171; }

        /* Form */
        input, select, textarea {
            background: var(--bg-elev);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 11px 14px;
            color: var(--text-hi); font-family: inherit; font-size: 14px;
            width: 100%;
        }
        input:focus, select:focus, textarea:focus { outline: none; border-color: var(--brand-primary); box-shadow: 0 0 0 3px rgba(14,165,233,0.15); }
        label { display: block; font-size: 12px; font-weight: 600; color: var(--text-mid); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .04em; }

        /* Live speed graph */
        .speed-graph {
            height: 180px; width: 100%;
            background: linear-gradient(180deg, rgba(14,165,233,0.06) 0%, transparent 100%);
            border-radius: 10px;
        }

        @media (max-width: 768px) {
            .nav-pills { display: none; }
            main { padding: 0 16px; margin-top: 20px; }
            .page-title h1 { font-size: 22px; }
        }
    </style>
    {% block extra_head %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

