/* ─── Brighten faded cells ─── */
.onu-table .dev-details{ line-height: 1.55 !important; }
.onu-table .dev-details .lbl{ color: #94A3B8 !important; font-size: 10.5px !important; font-weight: 700 !important; text-transform: uppercase !important; letter-spacing: .06em !important; }
.onu-table .dev-details .val{ font-family: 'JetBrains Mono', SFMono-Regular, Menlo, monospace !important; font-size: 13px !important; font-weight: 600 !important; color: #E7ECF5 !important; }
.onu-table .dev-details .val.sn{ color: #67E8F9 !important; background: rgba(0,229,255,.14) !important; border: 1px solid rgba(0,229,255,.35) !important; padding: 2px 8px !important; border-radius: 6px !important; }
.onu-table .dev-details .val.id{ color: #C7D2FE !important; background: rgba(124,92,255,.15) !important; border: 1px solid rgba(124,92,255,.40) !important; padding: 2px 8px !important; border-radius: 6px !important; }
.onu-table .dev-details .val.wan{ color: #86EFAC !important; font-weight: 700 !important; }

/* RX(dBm) cell — make value text actually visible */
.onu-table .rx-big{ font-weight: 800 !important; font-size: 14px !important; padding: 6px 12px !important; min-width: 70px; justify-content: center; }
.onu-table .rx-big.good{ color: #86EFAC !important; background: rgba(34,197,94,.18) !important; border: 1px solid rgba(34,197,94,.55) !important; }
.onu-table .rx-big.warn{ color: #FCD34D !important; background: rgba(245,158,11,.18) !important; border: 1px solid rgba(245,158,11,.55) !important; }
.onu-table .rx-big.bad{ color: #FCA5A5 !important; background: rgba(239,68,68,.18) !important; border: 1px solid rgba(239,68,68,.55) !important; }
.onu-table .rx-big.none{ color: #CBD5E1 !important; background: rgba(148,163,184,.18) !important; border: 1px solid rgba(148,163,184,.45) !important; }

/* TR069 pill */
.onu-table .tr-pill{ font-size: 11.5px !important; font-weight: 800 !important; letter-spacing: .04em !important; padding: 5px 14px !important; }
.onu-table .tr-pill.on{ color: #86EFAC !important; background: rgba(34,197,94,.20) !important; border: 1px solid rgba(34,197,94,.55) !important; }
.onu-table .tr-pill.off{ color: #CBD5E1 !important; background: rgba(148,163,184,.18) !important; border: 1px solid rgba(148,163,184,.45) !important; }

/* Status pill */
.onu-table .st-pill{ font-size: 12px !important; font-weight: 800 !important; padding: 5px 16px !important; letter-spacing: .02em !important; box-shadow: inset 0 1px 0 rgba(255,255,255,.08); }
.onu-table .st-pill.on{ color: #86EFAC !important; background: rgba(34,197,94,.22) !important; border: 1px solid rgba(34,197,94,.50) !important; }
.onu-table .st-pill.off{ color: #FCA5A5 !important; background: rgba(239,68,68,.22) !important; border: 1px solid rgba(239,68,68,.50) !important; }

/* Fiber link */
.onu-table .fl-cell .fl-status{ font-weight: 800 !important; font-size: 12.5px !important; }
.onu-table .fl-cell .fl-status.linked{ color: #86EFAC !important; }
.onu-table .fl-cell .fl-status.unlinked{ color: #CBD5E1 !important; }
.onu-table .fl-cell .fl-dist{ color: #94A3B8 !important; }

/* Action icon buttons — visible borders/colors */
.onu-table .act-icons .icobtn{ width: 34px !important; height: 34px !important; opacity: 1 !important; }
.onu-table .act-icons .icobtn i{ font-size: 15px !important; }
.onu-table .act-icons .icobtn.wifi{ color: #FCD34D !important; border: 1px solid rgba(245,158,11,.55) !important; background: rgba(245,158,11,.10) !important; }
.onu-table .act-icons .icobtn.wan{ color: #C4B5FD !important; border: 1px solid rgba(124,92,255,.55) !important; background: rgba(124,92,255,.10) !important; }
.onu-table .act-icons .icobtn.menu{ color: #67E8F9 !important; border: 1px solid rgba(0,229,255,.55) !important; background: rgba(0,229,255,.10) !important; }
.onu-table .act-icons .icobtn:hover{ filter: brightness(1.25); }

/* Last register / last deregister cells */
.onu-table .ls-cell .t{ color: #F1F5F9 !important; font-weight: 700 !important; }
.onu-table .ls-cell .d{ color: #94A3B8 !important; }

/* Customer / Link customer button */
.onu-table .cust-cell .pillc{ color: #F1F5F9 !important; font-weight: 700 !important; }
.onu-table .cust-cell .phone{ color: #CBD5E1 !important; }
.onu-table .cust-cell .add-loc{ color: #C7D2FE !important; background: rgba(99,102,241,.16) !important; border: 1px solid rgba(99,102,241,.45) !important; padding: 5px 12px !important; border-radius: 8px !important; display: inline-flex !important; align-items: center; gap: 5px; font-size: 12px !important; font-weight: 700 !important; }
.onu-table .cust-cell .add-loc:hover{ background: rgba(99,102,241,.28) !important; }

/* Generic "—" dash placeholders */
.onu-table td{ color: #E7ECF5 !important; }
.onu-table tbody tr:hover{ background: rgba(99,102,241,.06) !important; }

/* Headers */
.onu-table thead th{ color: #F1F5F9 !important; background: #0F1422 !important; font-weight: 800 !important; letter-spacing: .04em !important; }

/* ─── Modal centering + body scroll lock ─── */
.modal-back{
    position: fixed !important;
    top: 0 !important; left: 0 !important; right: 0 !important; bottom: 0 !important;
    width: 100vw !important; height: 100vh !important;
    margin: 0 !important; padding: 24px !important;
    background: rgba(2,6,23,.78) !important;
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
    z-index: 99999 !important;
    align-items: center !important;
    justify-content: center !important;
    overflow-y: auto !important;
}
.modal-back.show{ display: flex !important; }
.modal-back > .modal-card{
    margin: auto !important;
    max-width: 620px !important; width: 100% !important;
    max-height: 92vh !important; overflow-y: auto !important;
    background: #161D2E !important;
    border: 1px solid rgba(99,102,241,.50) !important;
    border-radius: 20px !important;
    box-shadow: 0 40px 100px rgba(0,0,0,.75), 0 10px 30px rgba(99,102,241,.25) !important;
    color: #E7ECF5 !important;
    transform: none !important;
    position: relative !important;
    inset: auto !important;
    top: auto !important; left: auto !important;
}
#wifi_modal > .modal-card{ max-width: 760px !important; }
@media (max-width: 600px){
    .modal-back{ padding: 10px !important; }
    .modal-back > .modal-card{ padding: 18px !important; border-radius: 16px !important; }
}



/* S55Q · subtle backdrop for context menus */
.ctx-menu-backdrop{ position: fixed !important; inset: 0 !important; background: rgba(2,6,23,0.40) !important; backdrop-filter: blur(2px) !important; -webkit-backdrop-filter: blur(2px) !important; z-index: 9998 !important; }
.ctx-menu{ z-index: 10001 !important; box-shadow: 0 18px 60px rgba(0,0,0,0.55), 0 6px 18px rgba(99,102,241,0.30) !important; border: 1px solid rgba(99,102,241,0.45) !important; min-width: 220px !important; }
.ctx-menu button{ color: #E7ECF5 !important; font-weight: 600 !important; }
.ctx-menu button:hover{ color: #67E8F9 !important; background: rgba(0,229,255,0.10) !important; }

/* S55P · Spacing + white MAC + white icons */
.onu-table .dev-details > div{ margin: 3px 0 !important; }
.onu-table .dev-details .val.sn{
    color: #FFFFFF !important;
    background: rgba(0,229,255,.12) !important;
    border: 1px solid rgba(0,229,255,.40) !important;
    display: inline-block !important;
    line-height: 1.5 !important;
}
.onu-table .dev-details .val.id{
    color: #FFFFFF !important;
    background: rgba(124,92,255,.16) !important;
    border: 1px solid rgba(124,92,255,.45) !important;
    display: inline-block !important;
    line-height: 1.5 !important;
}
.onu-table .act-icons .icobtn,
.onu-table .act-icons .icobtn i,
.onu-table .act-icons .icobtn.wifi,
.onu-table .act-icons .icobtn.wan,
.onu-table .act-icons .icobtn.menu{ color: #FFFFFF !important; }
.onu-table .act-icons .icobtn{ background: rgba(255,255,255,.05) !important; border: 1px solid rgba(255,255,255,.22) !important; }
.onu-table .act-icons .icobtn.wifi{ background: rgba(245,158,11,.18) !important; border-color: rgba(245,158,11,.55) !important; }
.onu-table .act-icons .icobtn.wan { background: rgba(124,92,255,.20) !important; border-color: rgba(124,92,255,.55) !important; }
.onu-table .act-icons .icobtn.menu{ background: rgba(0,229,255,.16) !important; border-color: rgba(0,229,255,.55) !important; }
.onu-table .act-icons .icobtn:hover{ filter: brightness(1.35); border-color: #fff !important; }

/* Lock body scroll when ANY modal is open */
body.modal-open{ overflow: hidden !important; padding-right: 0 !important; }
</style>

<script id="s55o-modal-glue">
(function(){
  /* (A) Re-parent every .modal-back to <body> so position:fixed escapes any
         transform / filter / contain ancestor. */
  function reparentAll(){
    document.querySelectorAll('.modal-back').forEach(function(m){
      if (m.parentNode !== document.body) document.body.appendChild(m);
    });
  }
  /* (B) Toggle body.modal-open whenever any modal-back has class 'show'. */
  function refreshBodyLock(){
    var any = !!document.querySelector('.modal-back.show');
    document.body.classList.toggle('modal-open', any);
    /* iOS-friendly scroll-lock: fix body in place at current scrollY.
       This guarantees the entire document collapses to viewport size — no
       exposed content below the backdrop, in real usage AND in full-page
       screenshots. */
    if (any && !document.body.dataset._s55pLockY) {
      var y = window.scrollY || window.pageYOffset || 0;
      document.body.dataset._s55pLockY = String(y);
      document.body.style.position = 'fixed';
      document.body.style.top = '-' + y + 'px';
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
      document.body.style.overflow = 'hidden';
      document.documentElement.style.overflow = 'hidden';
    } else if (!any && document.body.dataset._s55pLockY) {
      var y = parseInt(document.body.dataset._s55pLockY, 10) || 0;
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
      delete document.body.dataset._s55pLockY;
      window.scrollTo(0, y);
    }
  }
  function hookAll(){
    reparentAll();
    document.querySelectorAll('.modal-back').forEach(function(m){
      if (m.__s55oHooked) return;
      m.__s55oHooked = true;
      new MutationObserver(function(){ refreshBodyLock(); }).observe(m, { attributes: true, attributeFilter: ['class','style'] });
    });
    refreshBodyLock();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function(){ hookAll(); setTimeout(hookAll, 800); });
  } else { hookAll(); setTimeout(hookAll, 800); }

  /* Also watch for new modals injected later (e.g. by Bulk-action modals). */
  new MutationObserver(function(muts){
    var added = false;
    muts.forEach(function(mu){ mu.addedNodes && mu.addedNodes.forEach(function(n){
      if (n.nodeType === 1 && (n.classList && n.classList.contains('modal-back') || (n.querySelector && n.querySelector('.modal-back')))) added = true;
    });});
    if (added) hookAll();
  }).observe(document.body, { childList: true, subtree: true });
})();
</script>
