<script>
const IS_ADMIN_OLT = {{ 'true' if scope and scope.role == 'admin' else 'false' }};
window.IS_ADMIN_OLT = IS_ADMIN_OLT;
const $$ = (id)=>document.getElementById(id);
function closeModal(id){ $$(id).classList.remove('show'); }

async function loadOnus(){
  const params = new URLSearchParams();
  const olt = $$('f_olt').value, st = $$('f_status').value,
    pon = $$('f_pon').value, rx = $$('f_rx').value, q = $$('f_q').value;
  if (olt) params.set('olt_id', olt);
  if (st)  params.set('status', st);
  if (pon) params.set('pon_port_index', pon);
  if (rx)  params.set('rx_max', rx);
  if (q)   params.set('q', q);
  const r = await fetch('/api/admin/olt/onus?'+params.toString());
  const j = await r.json();
  const tb = $$('onu_tbody'); tb.innerHTML = '';
  if (!j.items || j.items.length===0){
    tb.innerHTML = '<tr><td colspan="9" class="empty">No ONUs match filters.</td></tr>';
    return;
  }
  for (const o of j.items){
    // _S46N_  Treat rx_power==0 same as null — VSOL EPON MIB
    // doesn't expose optical readings.
    const rxValid = (o.rx_power!==null && o.rx_power!==0 && o.rx_power!==undefined);
    const rxLevel = !rxValid ? 'none' :
      (o.rx_power <= -28 ? 'bad' : (o.rx_power <= -25 ? 'warn' : 'good'));
    const rxText = !rxValid ? '—' : o.rx_power.toFixed(2);
    const tr = document.createElement('tr');
    tr.dataset.testid = 'onu-row-'+o.id;

    // _S46Q_  DEVICE DETAILS — MAC is the primary identifier on
    // EPON OLTs (they don't expose a separate serial); P.MAC dropped.
    const macId = o.mac || o.serial || '—';
    const portId = `${(o.olt_tech || 'GPON').toUpperCase()}0/${o.pon_port_index}:${o.onu_index}`;
    const wanLine = o.wan_mode
      ? `<div><span class="lbl">WAN:</span><span class="val wan">${(o.wan_username||o.wan_mode||'').toUpperCase()}</span></div>` : '';
    const desc = (o.vendor||'—') + (o.model ? ' · '+o.model : '');
    const devCell = `<div class="dev-details">
        <div><span class="lbl">MAC:</span><span class="val sn">${macId}</span></div>
        <div><span class="lbl">ID:</span><span class="val id">${portId}</span></div>
        <div><span class="lbl">Desc:</span><span class="val">${desc}</span></div>
        ${wanLine}
      </div>`;

    // CUSTOMER INFO cell
    const custCell = o.customer_id
      ? `<div class="cust-cell">
           <div class="pillc">${o.customer_name||'(no name)'}</div>
           <div class="phone"><i class="bi bi-headset"></i> ${o.customer_phone||o.customer_id||''}</div>
           <a class="add-loc" onclick="onuMap(${o.id})"><i class="bi bi-geo-alt-fill"></i> Add Loc</a>
         </div>`
      : `<div class="cust-cell" style="color:#8A93A6">
           <span style="font-size:12px">— Unlinked —</span><br>
           <a class="add-loc" onclick="openEdit(${o.id})">
             <i class="bi bi-person-add"></i> Link customer</a>
         </div>`;

    // FIBER LINK cell
    // _S46N_  Fiber link state honest about no-RX.
    const linked = o.status === 'online';
    const dist = o.distance_m ? (o.distance_m+'m') : '';
    const noRx = (o.fiber_link === 'no-rx');
    const flLabel = !linked ? 'Down' : (noRx ? 'Linked (no RX)' : 'Linked');
    const flCell = `<div class="fl-cell">
        <div class="fl-status ${linked?'linked':'unlinked'}">${flLabel}</div>
        ${dist?'<div class="fl-dist" style="font-size:11px;color:#94a3b8;margin-top:2px;font-weight:500">'+dist+'</div>':''}
      </div>`;

    // ACTION 3-icon group
    const safe = (s) => (s||'').replace(/[\\'"]/g,'');
    const actCell = `<div class="act-icons">
        <button class="icobtn wifi" title="Wi-Fi"
          data-testid="onu-wifi-${o.id}"
          onclick="openWifi(${o.id},'${safe(o.serial)}','${safe(o.olt_name)}',${o.pon_port_index},${o.onu_index})">
          <i class="bi bi-wifi"></i></button>
        <button class="icobtn wan" title="WAN"
          data-testid="onu-wan-${o.id}"
          onclick="openWan(${o.id},'${safe(o.serial)}','${safe(o.olt_name)}',${o.pon_port_index},${o.onu_index})">
          <i class="bi bi-globe-asia-australia"></i></button>
        <button class="icobtn menu" title="More"
          data-testid="onu-more-${o.id}"
          onclick="onuMoreMenu(event, ${o.id}, '${safe(o.serial)}', '${safe(o.status)}')">
          <i class="bi bi-sliders2"></i></button>
      </div>`;

    // TR-069 pill
    const trCell = o.tr069_enabled
      ? '<span class="tr-pill on">ENABLED</span>'
      : '<span class="tr-pill off">DISABLED</span>';

    // _S47D_  Three-column event history: register / deregister / reason
    const fmtTs = (s) => {
      if (!s) return '<span style="color:#475569">—</span>';
      const t = formatLastSeenTime(s), d = formatLastSeenDate(s);
      return `<div class="ls-cell"><div class="t">${t}</div><div class="d">${d}</div></div>`;
    };
    const lsRegCell    = fmtTs(o.last_register_time);
    const lsOffCell    = fmtTs(o.last_offline);
    const reasonText   = o.offline_reason || (o.status==='online' ? '—' : 'Link Down');
    const reasonCell   = `<span style="font-size:12px;color:${o.status==='online'?'#94a3b8':'#fbbf24'};">${reasonText}</span>`;

    // STATUS pill
    const stCell = (o.status === 'online')
      ? '<span class="st-pill on">Online</span>'
      : '<span class="st-pill off">Offline</span>';

    tr.innerHTML = `
      <td>${devCell}</td>
      <td><span class="rx-big ${rxLevel}">${rxText}</span></td>
      <td>${custCell}</td>
      <td>${flCell}</td>
      <td>${actCell}</td>
      <td>${trCell}</td>
      <td>${lsRegCell}</td>
      <td>${lsOffCell}</td>
      <td>${reasonCell}</td>
      <td>${stCell}</td>
    `;
    tb.appendChild(tr);
  }
}

// _S46F_  Format helpers
function formatLastSeenTime(iso){
  if (!iso) return '—';
  try { const d = new Date(iso);
    return d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', hour12:true}); }
  catch(e){ return '—'; }
}
function formatLastSeenDate(iso){
  if (!iso) return '';
  try { const d = new Date(iso);
    return d.toLocaleDateString([], {month:'short', day:'2-digit'}); }
  catch(e){ return ''; }
}

// _S46F_  "More" 3-dot menu shown by gear icon
function onuMoreMenu(evt, id, serial, status){
  evt.stopPropagation();
  closeAnyCtxMenus();
  const menu = document.createElement('div');
  menu.className = 'ctx-menu';
  menu.id = '_onu_menu_'+id;
  let html = `<button onclick="openEdit(${id})">
    <i class="bi bi-pencil-square"></i> Edit ONU</button>`;
  html += `<button onclick="onuMap(${id})">
    <i class="bi bi-pin-map-fill"></i> Network Map</button>`;
  html += `<button onclick="onuAct(${id},'reboot')">
    <i class="bi bi-power"></i> Reboot</button>`;
  // _S48F_  TR-069 RPC + CLI actions
  html += `<button onclick="onuConnectedDevices(${id})">
    <i class="bi bi-display"></i> Connected Devices</button>`;
  html += `<button onclick="onuLanIp(${id})">
    <i class="bi bi-ethernet"></i> Change LAN IP</button>`;
  html += `<button onclick="onuSpeedTest(${id})">
    <i class="bi bi-speedometer"></i> Run Speed Test</button>`;
  html += `<button onclick="onuRefreshParams(${id})">
    <i class="bi bi-arrow-clockwise"></i> Refresh Parameters</button>`;
  if (window.IS_ADMIN_OLT){
    html += `<div class="sep"></div>`;
    html += `<button onclick="onuAct(${id},'activate')">
      <i class="bi bi-lightning-charge-fill"></i> Activate</button>`;
    html += `<button onclick="onuAct(${id},'factory-reset')">
      <i class="bi bi-arrow-counterclockwise"></i> Factory Reset</button>`;
    html += `<button style="color:#F87171" onclick="onuDelete(${id},'${serial}','${status}')">
      <i class="bi bi-trash3-fill"></i> Delete ONU</button>`;
  }
  menu.innerHTML = html;
  const bd = document.createElement('div');
  bd.className = 'ctx-menu-backdrop';
  bd.addEventListener('click', closeAnyCtxMenus);
  document.body.appendChild(bd);
  document.body.appendChild(menu);
  const rect = evt.currentTarget.getBoundingClientRect();
  /* position:fixed → use viewport coords directly */
  let top  = rect.bottom + 4;
  let left = rect.right - 220;
  /* Clamp inside viewport so menu never goes off-screen */
  const menuW = 240, menuH = 380;
  if (left < 8) left = 8;
  if (left + menuW > window.innerWidth - 8) left = window.innerWidth - menuW - 8;
  if (top + menuH > window.innerHeight - 8) top = Math.max(8, rect.top - menuH - 4);
  menu.style.top  = top  + 'px';
  menu.style.left = left + 'px';
  setTimeout(() => document.addEventListener('click', closeAnyCtxMenus, { once: true }), 0);
}
function closeAnyCtxMenus(){
  document.querySelectorAll('.ctx-menu').forEach(m => m.remove());
  document.querySelectorAll('.ctx-menu-backdrop').forEach(m => m.remove());
}

// _S46F_  Status filter chips
let _chipFilter = '';
function setChipFilter(btn, val){
  document.querySelectorAll('.onu-chips .chip').forEach(c => c.classList.remove('on'));
  btn.classList.add('on');
  _chipFilter = val;
  // Map "warn" / "critical" / "idle" to backend status filter where possible.
  const stEl = document.getElementById('f_status');
  if (val === 'online' || val === 'offline'){
    stEl.value = val;
  } else {
    stEl.value = '';
  }
  // RX-based filters set the rx_max input
  const rxEl = document.getElementById('f_rx');
  if (val === 'warn')      rxEl.value = '-25';
  else if (val === 'critical') rxEl.value = '-28';
  else if (val === 'idle' || val === '' || val === 'online' || val === 'offline') rxEl.value = '';
  loadOnus();
}

function _ctx(serial, olt, pon, onu){
  return `<b>${serial||'—'}</b> · ${olt} · PON ${pon}/${onu}`;
}

async function openWifi(onuId, serial, olt, pon, onu){
  const r = await fetch(`/api/admin/olt/onus/${onuId}`);
  const j = await r.json();
  const o = (j && j.onu) || {};
  const f = $$('wifi_form');
  f.onu_id.value = onuId;
  // 2.4 GHz
  f.ssid.value = o.wifi_ssid || '';
  f.password.value = '';
  f.radio_24_enabled.value = String(o.wifi_radio_24_enabled === 0 ? 0 : 1);
