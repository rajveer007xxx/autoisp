{% extends layout_template|default("base_admin.html") %}
{% block title %}ONU / ONT Manager · AutoISP Billing{% endblock %}

{% block content %}
<script>window.OLT_PORTAL_PREFIX = "{{ olt_url_prefix or '/admin/olt' }}";</script>
<style>
/* _S52_MENU_ZINDEX — popup menus must float ABOVE sticky admin header (z=100). */
[id$="_menu"], .more-menu, .onu-action-menu, .ctx-menu, .popup-menu, .modal-back { z-index: 10000 !important; }
.modal-back.show { z-index: 10001 !important; }

  :root{
    --olt-card:#161D2E; --olt-line:#1F2940; --olt-fg:#E7ECF5;
    --olt-mute:#8A93A6; --olt-cyan:#00E5FF; --olt-violet:#7C5CFF;
    --olt-green:#22C55E; --olt-amber:#F59E0B; --olt-red:#EF4444;
  }
  .ws { color:var(--olt-fg); padding:18px 6px 60px; }
  .ws h1 { font-size:22px; font-weight:800; letter-spacing:-.4px; margin:0 0 4px; }
  .ws .sub { color:var(--olt-mute); font-size:13px; margin-bottom:18px; }
  .tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px; }
  .tabs a { padding:8px 14px; border-radius:99px; font-size:12.5px;
    text-decoration:none; color:var(--olt-mute);
    border:1px solid var(--olt-line); background:var(--olt-card); }
  .tabs a.on { color:#0B0F1A; background:linear-gradient(135deg,var(--olt-cyan),var(--olt-violet));
    border-color:transparent; font-weight:700; }
  .filterbar { display:grid; gap:10px;
    grid-template-columns:repeat(auto-fit,minmax(140px,1fr));
    background:var(--olt-card); border:1px solid var(--olt-line);
    border-radius:14px; padding:14px; margin-bottom:14px; }
  .filterbar label { display:flex; flex-direction:column; gap:4px;
    font-size:11px; letter-spacing:.6px; text-transform:uppercase;
    color:var(--olt-mute); }
  .filterbar select, .filterbar input {
    background:#0B0F1A; border:1px solid var(--olt-line); color:var(--olt-fg);
    border-radius:10px; padding:9px 10px; font-size:13px; outline:none; }
  .filterbar select:focus, .filterbar input:focus { border-color:var(--olt-cyan); }
  .panel { background:var(--olt-card); border:1px solid var(--olt-line);
    border-radius:18px; padding:0; overflow:hidden; }
  table.olt { width:100%; border-collapse:collapse; }
  table.olt th, table.olt td { padding:10px 12px; border-bottom:1px solid
    var(--olt-line); font-size:12.5px; text-align:left; vertical-align:middle; }
  table.olt th { color:var(--olt-mute); font-weight:600; font-size:10.5px;
    letter-spacing:.8px; text-transform:uppercase; background:#101725; }
  table.olt tr:hover td { background:rgba(0,229,255,.04); }
  .pill { display:inline-flex; padding:3px 10px; border-radius:99px;
    font-size:10.5px; font-weight:700; letter-spacing:.4px; }
  .pill.online { background:rgba(34,197,94,.12); color:#34D399; }
  .pill.offline { background:rgba(239,68,68,.14); color:#F87171; }
  .pill.unknown { background:rgba(138,147,166,.14); color:var(--olt-mute); }
  .rx-bad{color:#F87171;font-weight:700} .rx-warn{color:#FBBF24;font-weight:700}
  .rx-good{color:#34D399;font-weight:700}
  .actbtn { padding:5px 9px; border-radius:8px; border:1px solid var(--olt-line);
    background:transparent; color:var(--olt-fg); font-size:11px; cursor:pointer;
    margin-right:3px; margin-bottom:3px; white-space:nowrap; font-weight:600; }
  .actbtn:hover { border-color:var(--olt-cyan); color:var(--olt-cyan); }
  .actbtn.primary { background:rgba(0,229,255,.12); border-color:rgba(0,229,255,.3); color:#67E8F9; }
  .actbtn.warn:hover { border-color:var(--olt-amber); color:var(--olt-amber); }
  .actbtn.danger:hover { border-color:var(--olt-red); color:var(--olt-red); }
  .actcell { min-width:340px; }
  .empty { text-align:center; padding:60px 10px; color:var(--olt-mute); }

  /* Modals */
  .modal-back { display:none; position:fixed; inset:0; background:rgba(0,0,0,.6);
    z-index:9999; align-items:center; justify-content:center; padding:20px; }
  .modal-back.show { display:flex; }
  .modal-card { background:var(--olt-card); border:1px solid var(--olt-line);
    border-radius:18px; padding:24px; max-width:560px; width:100%;
    color:var(--olt-fg); max-height:90vh; overflow:auto; }
  .modal-h { display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; }
  .modal-h h3 { margin:0; font-size:16px; }
  .modal-x { background:transparent; border:none; color:var(--olt-mute); font-size:22px; cursor:pointer; }
  .field { display:flex; flex-direction:column; gap:4px; margin-bottom:12px; }
  .field label { font-size:11px; letter-spacing:.6px; text-transform:uppercase; color:var(--olt-mute); }
  .field input, .field select { background:#0B0F1A; border:1px solid var(--olt-line);
    color:var(--olt-fg); border-radius:10px; padding:10px 12px; font-size:13.5px; outline:none; }
  .field input:focus, .field select:focus { border-color:var(--olt-cyan); }
  .row2 { display:grid; gap:10px; grid-template-columns:1fr 1fr; }
  .btn { padding:10px 16px; border-radius:10px; border:1px solid var(--olt-line);
    background:var(--olt-card); color:var(--olt-fg); font-size:13px;
    cursor:pointer; font-weight:700; }
  .btn.primary { background:linear-gradient(135deg,var(--olt-cyan),var(--olt-violet));
    color:#0B0F1A; border-color:transparent; }
  .ctx-info { background:rgba(0,229,255,.06); border:1px solid rgba(0,229,255,.2);
    border-radius:10px; padding:10px 12px; font-size:12px; color:#9DDDF0; margin-bottom:14px; }
  .ctx-info b { color:#E7ECF5; }

  /* _S46F_  aspbilling-style table polish */
  .onu-chips { display:flex; gap:8px; margin:0 0 10px;
    background:var(--olt-card); border:1px solid var(--olt-line);
    border-radius:14px; padding:8px 10px; width:max-content; }
  .onu-chips .chip { background:transparent; border:1px solid var(--olt-line);
    color:var(--olt-mute); border-radius:8px; padding:7px 11px; font-size:13px;
    cursor:pointer; transition:all .15s; }
  .onu-chips .chip:hover { color:var(--olt-fg); border-color:var(--olt-cyan); }
  .onu-chips .chip.on { background:rgba(124,92,255,.18); color:#C4B5FD;
    border-color:rgba(124,92,255,.45); }
  .onu-chips .chip.ok.on    { background:rgba(34,197,94,.18); color:#34D399; border-color:rgba(34,197,94,.45); }
  .onu-chips .chip.warn.on  { background:rgba(245,158,11,.18); color:#FBBF24; border-color:rgba(245,158,11,.45); }
  .onu-chips .chip.crit.on  { background:rgba(239,68,68,.18); color:#F87171; border-color:rgba(239,68,68,.45); }
  .onu-chips .chip.idle.on  { background:rgba(99,102,241,.18); color:#A5B4FC; border-color:rgba(99,102,241,.45); }
  .onu-chips .chip.down.on  { background:rgba(127,29,29,.36); color:#FCA5A5; border-color:rgba(239,68,68,.45); }

  table.onu-table th.sortable { cursor:pointer; user-select:none; }
  table.onu-table th.sortable:hover { color:var(--olt-cyan); }
  table.onu-table th i { font-size:9px; opacity:.55; margin-left:2px; }
  table.onu-table .actcell-action { min-width:140px; }

  .dev-details { line-height:1.55; }
  .dev-details .lbl { color:var(--olt-mute); font-size:10.5px;
    letter-spacing:.5px; text-transform:uppercase; margin-right:4px; }
  .dev-details .val { font-family:monospace; font-size:11.5px; color:var(--olt-fg); }
  .dev-details .val.sn { background:rgba(0,229,255,.08); padding:1px 6px;
    border-radius:6px; font-weight:700; color:#67E8F9; }
  .dev-details .val.id { background:rgba(124,92,255,.08); padding:1px 6px;
    border-radius:6px; color:#C4B5FD; }
  .dev-details .val.mac { color:#94A3B8; }
  .dev-details .val.wan { color:#34D399; font-weight:600; }

  .rx-big { display:inline-flex; align-items:center; gap:5px;
    padding:6px 14px; border-radius:99px; font-weight:800; font-size:14px;
    border:1px solid; min-width:84px; justify-content:center; }
  .rx-big::before { content:""; width:7px; height:7px; border-radius:50%;
    background:currentColor; }
  .rx-big.good { color:#34D399; background:rgba(34,197,94,.10); border-color:rgba(34,197,94,.30); }
  .rx-big.warn { color:#FBBF24; background:rgba(245,158,11,.10); border-color:rgba(245,158,11,.30); }
  .rx-big.bad  { color:#F87171; background:rgba(239,68,68,.10); border-color:rgba(239,68,68,.30); }
  .rx-big.none { color:#8A93A6; background:rgba(138,147,166,.08); border-color:rgba(138,147,166,.20); }

  .cust-cell { line-height:1.5; }
  .cust-cell .pillc {
    display:inline-block; padding:3px 9px; border-radius:6px;
    background:rgba(0,229,255,.08); color:#67E8F9; font-weight:700;
    font-size:12px; margin-bottom:4px; }
  .cust-cell .phone { display:flex; gap:4px; align-items:center;
    color:#94A3B8; font-size:11.5px; }
  .cust-cell .phone i { color:#475569; }
  .cust-cell .add-loc { display:inline-flex; align-items:center; gap:3px;
    color:#7C5CFF; cursor:pointer; font-size:11px; margin-top:3px; }
  .cust-cell .add-loc:hover { color:#A78BFA; }

  .fl-cell .fl-status { font-weight:700; font-size:11.5px; }
  .fl-cell .fl-status.linked   { color:#34D399; }
  .fl-cell .fl-status.unlinked { color:#94A3B8; }
  .fl-cell .fl-dist { color:#8A93A6; font-size:11px; margin-top:2px; }
  .fl-cell .link-btn { display:inline-flex; align-items:center; gap:3px;
    color:#67E8F9; cursor:pointer; font-size:11px; margin-top:3px;
    background:none; border:0; padding:0; }
  .fl-cell .link-btn:hover { color:#22D3EE; }

  .act-icons { display:flex; gap:6px; }
  .act-icons .icobtn { width:32px; height:32px; border-radius:8px;
    border:1px solid var(--olt-line); background:rgba(255,255,255,.02);
    color:#94A3B8; display:flex; align-items:center; justify-content:center;
    cursor:pointer; transition:all .15s; font-size:13px; }
  .act-icons .icobtn:hover { border-color:var(--olt-cyan); color:var(--olt-cyan);
    background:rgba(0,229,255,.08); }
  .act-icons .icobtn.wifi  { color:#FBBF24; border-color:rgba(245,158,11,.25); }
  .act-icons .icobtn.wifi:hover { background:rgba(245,158,11,.10); }
  .act-icons .icobtn.wan   { color:#7C5CFF; border-color:rgba(124,92,255,.25); }
  .act-icons .icobtn.wan:hover { background:rgba(124,92,255,.10); }
  .act-icons .icobtn.menu  { color:#67E8F9; border-color:rgba(0,229,255,.25); }

  .tr-pill { padding:4px 12px; border-radius:6px; font-weight:700;
    font-size:11px; letter-spacing:.4px; display:inline-block; }
  .tr-pill.on  { background:rgba(34,197,94,.14); color:#34D399; border:1px solid rgba(34,197,94,.30); }
  .tr-pill.off { background:rgba(138,147,166,.08); color:#94A3B8; border:1px solid rgba(138,147,166,.20); }

  .ls-cell .t { font-weight:700; color:var(--olt-fg); font-size:12.5px; }
  .ls-cell .d { color:#8A93A6; font-size:11px; }

  .st-pill { padding:4px 14px; border-radius:99px; font-weight:700;
    font-size:11.5px; letter-spacing:.3px; display:inline-block; }
  .st-pill.on  { background:rgba(34,197,94,.14); color:#34D399; }
  .st-pill.off { background:rgba(239,68,68,.16); color:#F87171; }

  .port-tag { color:#67E8F9; font-family:monospace; font-size:12px;
    font-weight:700; padding:3px 10px; border-radius:6px;
    background:rgba(0,229,255,.08); display:inline-block; }

  /* Row-context menu (3rd icon in ACTION cell) */
  .ctx-menu { position:fixed; background:#0B0F1A; border:1px solid var(--olt-line);
    border-radius:10px; padding:6px; min-width:200px; z-index:9999;
    box-shadow:0 10px 40px rgba(0,0,0,.5); }
  .ctx-menu button { display:block; width:100%; text-align:left; background:none;
    border:0; padding:8px 10px; border-radius:6px; color:var(--olt-fg);
    font-size:12px; cursor:pointer; }
  .ctx-menu button:hover { background:rgba(0,229,255,.08); color:var(--olt-cyan); }
  .ctx-menu .sep { height:1px; background:var(--olt-line); margin:4px 0; }
</style>


<section class="ws" data-testid="olt-onus-page">
  <h1>ONU / ONT Manager</h1>
  <p class="sub">Filter, monitor and remotely control every ONT on your network — Wi-Fi, WAN (PPPoE / Static / DHCP / Bridge), reboot &amp; reset.</p>

  <nav class="tabs">
    <a href="{{ olt_url_prefix or '/admin/olt' }}/dashboard">Dashboard</a>
    <a class="on" href="{{ olt_url_prefix or '/admin/olt' }}/onus">ONU / ONT Manage</a>
    <a href="{{ olt_url_prefix or '/admin/olt' }}/alerts">Alerts</a>
    {% if scope and scope.role == "admin" %}<a href="/admin/olt/system-config">System Config</a>{% endif %}
  </nav>

  <div class="filterbar" data-testid="onu-filters">
    <label>OLT
      <select id="f_olt" data-testid="filter-olt">
        <option value="">All OLTs</option>
        {% for o in olts %}<option value="{{o.id}}">{{o.name}} ({{o.vendor}})</option>{% endfor %}
      </select></label>
    <label>Status
      <select id="f_status" data-testid="filter-status">
        <option value="">All</option><option value="online">Online</option>
        <option value="offline">Offline</option></select></label>
    <label>PON Port
      <select id="f_pon" data-testid="filter-pon">
        <option value="">All ports (select an OLT)</option>
      </select></label>
    <label>RX ≤ dBm
      <input id="f_rx" type="number" step="0.5" placeholder="-25"
        data-testid="filter-rx"></label>
    <label>Search
      <input id="f_q" type="text" placeholder="serial / mac / customer"
        data-testid="filter-q"></label>
    <!-- _S46F_  aspbilling-style action buttons -->
    <div style="margin-left:auto;display:flex;gap:8px;">
      {# __BUTTONS_ADD_IMPORT_REMOVED__ Add ONU removed #}
      {# Import Excel removed #}
      <button class="btn primary" type="button"
              onclick="openBulkRepush()"
              data-testid="bulk-repush-btn"
              title="Force every linked ONU to re-sync Wi-Fi/PPPoE settings to ACS">
        <i class="bi bi-broadcast-pin"></i> Re-push All to ACS
      </button>
      <button class="btn" type="button" data-testid="refresh-btn"
        onclick="loadOnus()" title="Refresh">
        <i class="bi bi-arrow-clockwise"></i>
      </button>
    </div>
  </div>

  <!-- _S46F_  aspbilling-style status filter chips -->
  <div class="onu-chips" data-testid="onu-chip-bar">
    <button class="chip on" data-status="" onclick="setChipFilter(this,'')">
      <i class="bi bi-grid-3x3-gap-fill"></i></button>
    <button class="chip ok" data-status="online" onclick="setChipFilter(this,'online')"
      title="Online ONUs"><i class="bi bi-wifi"></i></button>
    <button class="chip warn" data-status="warn" onclick="setChipFilter(this,'warn')"
      title="High RX (warning)"><i class="bi bi-shield-exclamation"></i></button>
    <button class="chip crit" data-status="critical" onclick="setChipFilter(this,'critical')"
      title="Critical RX (link loss imminent)"><i class="bi bi-thermometer-high"></i></button>
    <button class="chip idle" data-status="idle" onclick="setChipFilter(this,'idle')"
      title="Idle (no traffic)"><i class="bi bi-moon-stars-fill"></i></button>
    <button class="chip down" data-status="offline" onclick="setChipFilter(this,'offline')"
      title="Offline ONUs"><i class="bi bi-wifi-off"></i></button>
  </div>

  <div class="panel">
    <table class="olt onu-table">
      <thead><tr>
        <th class="sortable" data-sort="device">DEVICE DETAILS <i class="bi bi-arrow-down-up"></i></th>
        <th class="sortable rx-h" data-sort="rx">RX(DBM) <i class="bi bi-arrow-down-up"></i></th>
        <th>CUSTOMER INFO</th>
        <th>FIBER LINK</th>
        <th class="actcell-action">ACTION</th>
        <th class="sortable" data-sort="tr069">TR069 <i class="bi bi-arrow-down-up"></i></th>
        <th class="sortable" data-sort="last_register_time">LAST REGISTER</th>
        <th class="sortable" data-sort="last_offline">LAST DEREGISTER</th>
        <th>DEREGISTER REASON</th>
        <th>STATUS</th>
      </tr></thead>
      <tbody id="onu_tbody" data-testid="onu-tbody">
        <tr><td colspan="10" class="empty">Loading…</td></tr>
      </tbody>
    </table>
  </div>

<!-- ONU Edit modal (OLT-3.4) -->
<div id="edit_modal" class="modal-back" data-testid="edit-modal">
  <div class="modal-card">
    <div class="modal-h"><h3>Edit ONU</h3>
      <button class="modal-x" onclick="closeModal('edit_modal')">×</button></div>
    <div class="ctx-info" id="edit_ctx"></div>
    <form id="edit_form" onsubmit="event.preventDefault(); saveEdit();">
      <input type="hidden" name="onu_id"/>
      <div class="row2">
        <div class="field"><label>ONU Name (label)</label>
          <input name="name" placeholder="e.g. Hemlata-Home"
            data-testid="edit-name"/></div>
        <div class="field"><label>Vendor</label>
          <input name="vendor" placeholder="Huawei / Nokia / VSOL …"
            data-testid="edit-vendor"/></div>
      </div>
      <div class="row2">
        <div class="field"><label>Model</label>
          <input name="model" placeholder="HG8310M / G-1425 / V2802 …"
            data-testid="edit-model"/></div>
        <div class="field"><label>&nbsp;</label>
          <div style="font-size:11px;color:var(--olt-mute);
               background:rgba(245,158,11,.06);
               border:1px solid rgba(245,158,11,.2);
               border-radius:8px;padding:8px 10px;">
             Vendor / Model will <b>persist</b> across polls (manual override).
          </div></div>
      </div>
      <div class="field"><label>Customer</label>
        <input name="customer_search" id="cust_search"
          placeholder="Type customer name / phone / id / username …"
          autocomplete="off"
          oninput="custSearch(this.value)"
          data-testid="edit-customer-search"/>
        <div id="cust_results"
          style="position:relative;"></div>
        <input type="hidden" name="customer_id" id="cust_id_hidden"/>
        <div id="cust_chosen" style="margin-top:6px;font-size:12px;
             color:#67E8F9;"></div>
      </div>
      <div class="field"><label>Notes</label>
        <input name="notes" placeholder="Internal note (optional)"
          data-testid="edit-notes"/></div>
      <div style="display:flex;gap:8px;justify-content:space-between;
                  align-items:center;margin-top:14px">
        <button type="button" class="btn"
          onclick="clearCustomer()"
          style="border-color:rgba(239,68,68,.3);color:#F87171;"
          data-testid="edit-unlink-customer">Unlink customer</button>
        <div style="display:flex;gap:8px">
          <button type="button" class="btn" onclick="closeModal('edit_modal')">Cancel</button>
          <button type="submit" class="btn primary" data-testid="edit-save">Save</button>
        </div>
      </div>
    </form>
  </div>
</div>

<style>
  .cust-result-list {
    background:#0B0F1A;border:1px solid var(--olt-line);
    border-radius:10px;margin-top:6px;max-height:200px;overflow:auto;
    box-shadow:0 8px 24px rgba(0,0,0,.4);
  }
  .cust-result {
    display:flex;justify-content:space-between;align-items:center;
    padding:10px 12px;border-bottom:1px solid var(--olt-line);
    cursor:pointer;font-size:12.5px;
  }
  .cust-result:hover { background:rgba(0,229,255,.08); }
  .cust-result:last-child { border-bottom:0; }
</style>

<script>
let _custTimer = null;
async function custSearch(q){
  clearTimeout(_custTimer);
  _custTimer = setTimeout(async ()=>{
    const box = document.getElementById('cust_results');
    if (!q || q.length < 2){ box.innerHTML = ''; return; }
    const r = await fetch('/api/admin/olt/customers/search?q='+encodeURIComponent(q));
    const j = await r.json();
    if (!j.items || j.items.length === 0){
      box.innerHTML = '<div class="cust-result-list"><div class="cust-result" style="color:#8A93A6">No matches</div></div>';
      return;
    }
    let html = '<div class="cust-result-list">';
    for (const c of j.items){
      html += `<div class="cust-result" data-testid="cust-pick-${c.customer_id}"
        onclick="pickCustomer('${c.customer_id}','${(c.customer_name||'').replace(/'/g,'&#39;')}','${(c.phone||'').replace(/'/g,'&#39;')}')">
        <div><b>${c.customer_name||'(no name)'}</b><br>
          <span style="color:#8A93A6;font-size:11px">${c.customer_id} · ${c.username||''}</span></div>
        <div style="color:#8A93A6;font-size:11px">${c.phone||''}</div>
      </div>`;
    }
    html += '</div>';
    box.innerHTML = html;
  }, 250);
}
function pickCustomer(id, name, phone){
  document.getElementById('cust_id_hidden').value = id;
  document.getElementById('cust_chosen').innerHTML =
    `Linked: <b>${name}</b> (${id}) ${phone ? '· '+phone : ''}`;
  document.getElementById('cust_results').innerHTML = '';
  document.getElementById('cust_search').value = `${name} (${id})`;
}
function clearCustomer(){
  if (!confirm('Unlink customer from this ONU?')) return;
  document.getElementById('cust_id_hidden').value = '';
  document.getElementById('cust_chosen').innerHTML =
    '<span style="color:#F87171">Will be unlinked on save.</span>';
  document.getElementById('cust_search').value = '';
}

async function openEdit(onuId){
  const r = await fetch(`/api/admin/olt/onus/${onuId}`);
  const j = await r.json();
  if (!j.ok){ alert('Cannot load ONU'); return; }
  const o = j.onu;
  const f = document.getElementById('edit_form');
  f.onu_id.value = onuId;
  f.name.value   = o.name   || '';
  f.vendor.value = o.vendor || '';
  f.model.value  = o.model  || '';
  f.notes.value  = o.notes  || '';
  document.getElementById('cust_id_hidden').value = o.customer_id || '';
  document.getElementById('cust_search').value = '';
  document.getElementById('cust_results').innerHTML = '';
  document.getElementById('cust_chosen').innerHTML = '';
  // Pre-fill customer info if linked
  if (o.customer_id){
    const cr = await fetch('/api/admin/olt/customers/search?q=' +
                            encodeURIComponent(o.customer_id));
    const cj = await cr.json();
    const match = (cj.items || []).find(x => x.customer_id == o.customer_id);
    if (match){
      pickCustomer(match.customer_id, match.customer_name, match.phone);
    } else {
      document.getElementById('cust_chosen').innerHTML =
        `Currently linked: <b>${o.customer_id}</b>`;
      document.getElementById('cust_search').value = o.customer_id;
    }
  }
  document.getElementById('edit_ctx').innerHTML =
    `<b>${o.serial||'—'}</b> · ${o.olt_name||('#'+o.olt_id)} · PON ${o.pon_port_index}/${o.onu_index}`;
  document.getElementById('edit_modal').classList.add('show');
}

async function saveEdit(){
  const f = document.getElementById('edit_form');
  const id = f.onu_id.value;
  const body = {
    name:   f.name.value || null,
    vendor: f.vendor.value || null,
    model:  f.model.value || null,
    notes:  f.notes.value || null,
    customer_id: document.getElementById('cust_id_hidden').value || null,
  };
  // If user typed in search but didn't pick + didn't have prior id, send null.
  const r = await fetch(`/api/admin/olt/onus/${id}`,
    {method:'PATCH', headers:{'Content-Type':'application/json'},
     body: JSON.stringify(body)});
  if (r.ok){ closeModal('edit_modal'); loadOnus(); }
  else { alert('Save failed: '+await r.text()); }
}
</script>

