  display: inline-block;
  animation: e1Spin 1s linear infinite;
}
@keyframes e1Spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
/* Bigger header / chip icons for better visibility */
.onu-chips .chip i.bi { font-size: 18px !important; }
.onu-chips .chip {
  min-width: 44px; min-height: 38px;
  padding: 0 12px !important;
}
.btn i.bi { font-size: 15px; vertical-align: -1px; margin-right: 4px; }
