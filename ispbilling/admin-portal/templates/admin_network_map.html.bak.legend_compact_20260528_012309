/* _S40zt_  Lazy-load + render fiber-cut history. Idempotent toggle. */
async function nmToggleCutHistory(hwId) {
  const panel = document.getElementById(`nm-cut-hist-${hwId}`);
  if (!panel) return;
  if (panel.style.display === "block") {
    panel.style.display = "none";
    return;
  }
  panel.style.display = "block";
  panel.innerHTML = `<div style="color:#94a3b8;padding:6px 0">Loading…</div>`;
  try {
    const r = await fetch(`${NM_API}/hardware/${hwId}/cut-history`,
                            {credentials:"include"});
    if (!r.ok) throw new Error("HTTP " + r.status);
    const j = await r.json();
    const items = (j && j.items) || [];
    if (!items.length) {
      panel.innerHTML = `<div style="color:#64748b;padding:6px 0;font-style:italic">
        No fiber cuts logged at this node.<br>
        <span style="font-size:10px">Drop this pin on a live fiber to auto-cut + audit.</span></div>`;
      return;
    }
    panel.innerHTML = items.map(it => {
      /* Use global IST formatter if available (_S40zg_), fallback to raw. */
      /* _S40zt_  cut_at is SQL format "YYYY-MM-DD HH:MM:SS" (UTC, no TZ).
         Convert to ISO so fmtIST can render it as IST. Fall back to raw. */
      let when = it.cut_at || "—";
      try {
        if (it.cut_at) {
          const iso = String(it.cut_at).replace(" ", "T") + "Z";
          if (typeof window.fmtIST === "function") {
            const f = window.fmtIST(iso);
            if (f && f !== "null" && f !== "NaN") when = f;
          } else {
            const d = new Date(iso);
            if (!isNaN(d)) when = d.toLocaleString("en-GB",
              {timeZone:"Asia/Kolkata", day:"2-digit", month:"2-digit",
               year:"numeric", hour:"2-digit", minute:"2-digit", hour12:false})
              .replace(/\//g,"-").replace(",","");
          }
        }
      } catch(_){}
      const fNm = (f) => `<span style="background:#1e293b;color:#e2e8f0;
                              padding:1px 6px;border-radius:4px;font-size:10px">
                              ${(f && f.name) || "—"}</span>`;
      const findBtn = (fid) => fid
        ? `<button onclick="nmHighlightFiber(${fid})"
             title="Highlight this fiber on the map"
             style="background:transparent;border:none;color:#a5b4fc;
                    cursor:pointer;font-size:11px;padding:0 2px">🔍</button>`
        : "";
      /* _S40zu_  Notes section: read-only paragraph + edit toggle */
      const noteHtml = it.notes
        ? `<div style="margin-top:6px;padding:5px 7px;background:rgba(99,102,241,.12);
                       border-radius:4px;color:#e2e8f0;font-size:11px;white-space:pre-wrap"
                  data-testid="cut-note-text-${it.id}">📝 ${
              String(it.notes).replace(/&/g,"&amp;").replace(/</g,"&lt;")
            }</div>`
        : "";
      const editBtn = `<button onclick="nmEditCutNote(${hwId},${it.id})"
            data-testid="cut-note-edit-${it.id}"
            style="background:transparent;border:1px solid #6366f1;color:#a5b4fc;
                   cursor:pointer;font-size:10px;padding:2px 8px;border-radius:4px;
                   margin-top:6px">📝 ${it.notes ? "Edit note" : "Add note"}</button>`;
      const editor = `<div id="nm-cut-note-edit-${it.id}" style="display:none;margin-top:6px">
          <textarea data-testid="cut-note-textarea-${it.id}"
            style="width:100%;min-height:48px;background:#0f172a;color:#e2e8f0;
                   border:1px solid #334155;border-radius:4px;padding:5px;
                   font-size:11px;font-family:inherit;resize:vertical"
            placeholder="e.g. moved to new pole after road work"
          >${(it.notes || "").replace(/</g,"&lt;")}</textarea>
          <div style="display:flex;gap:6px;margin-top:4px">
            <button onclick="nmSaveCutNote(${hwId},${it.id})"
                    data-testid="cut-note-save-${it.id}"
                    style="background:#10b981;border:none;color:#fff;
                           padding:3px 10px;border-radius:4px;cursor:pointer;
                           font-size:10px;font-weight:600">Save</button>
            <button onclick="nmCancelCutNote(${it.id})"
                    style="background:#475569;border:none;color:#fff;
                           padding:3px 10px;border-radius:4px;cursor:pointer;
                           font-size:10px">Cancel</button>
          </div>
        </div>`;
      return `<div style="margin-bottom:8px;padding:6px 8px;
                            background:rgba(30,41,59,.6);border-radius:6px;
                            border-left:2px solid #6366f1">
                <div style="font-weight:600;color:#a5b4fc">${when}</div>
                <div style="color:#cbd5e1;margin-top:2px">
                  by ${it.cut_by || "—"}
                </div>
                <div style="margin-top:4px;color:#94a3b8;font-size:10px">
                  Original ${fNm(it.original_fiber)}${findBtn(it.original_fiber && it.original_fiber.id)}
                  was cut into:
                </div>
                <div style="margin-top:2px">
                  → ${fNm(it.first_half)}${findBtn(it.first_half && it.first_half.id)}
                  &nbsp;+&nbsp;
                  ${fNm(it.second_half)}${findBtn(it.second_half && it.second_half.id)}
                </div>
                ${noteHtml}
                ${editBtn}
                ${editor}
              </div>`;
    }).join("");
  } catch(err) {
    panel.innerHTML = `<div style="color:#f87171;padding:6px 0">
      Failed to load history: ${(err && err.message) || err}</div>`;
  }
}

/* _S40zt_  Briefly highlight a fiber by its id — pulse weight/colour and
   pan the map to its midpoint. Falls back gracefully if the fiber isn't
   currently rendered. */
function nmHighlightFiber(fiberId) {
  if (!fiberId) return;
  const f = (window.__nmFibers || []).find(x => x.id === fiberId);
  if (!f || !f.polyline || !f.polyline.length) {
    try { nmShowBanner(`Fiber #${fiberId} no longer on map`,
                          "rgba(245,158,11,.95)", "#1a1a1a");
          setTimeout(() => nmHideBanner(), 2200); } catch(_){}
    return;
  }
  const mid = f.polyline[Math.floor(f.polyline.length / 2)];
  try { nmMap.panTo(mid); } catch(_){}
  /* Draw an ephemeral overlay polyline so we don't have to mutate the
     real fiber's style (which would also reset on the next refresh). */
  const overlay = L.polyline(f.polyline,
                  { color:"#fbbf24", weight:9, opacity:.95,
                    dashArray:"10 6" }).addTo(nmMap);
  let on = true;
  const blink = setInterval(() => {
    on = !on;
    overlay.setStyle({opacity: on ? 0.95 : 0.25});
  }, 250);
  setTimeout(() => { clearInterval(blink);
                       try { nmMap.removeLayer(overlay); } catch(_){} }, 4000);
}

