// ═══ _S40zη_  Clustered ONU worst-RX heat-map (low zoom) ═══════════════
// At zoom ≤ NM_CLUSTER_ZOOM individual ONU pins collapse into circles
// sized by count and coloured by the *worst* RX in the bucket. Click a
// cluster to zoom in.
window.nmClusterLayer = window.nmClusterLayer || null;
const NM_CLUSTER_ZOOM = 13;
const NM_CLUSTER_GRID = 0.012;   // ≈ 1.3 km @ equator

function _nmRxColor(rx, status) {
  if (status && status !== 'online') return '#dc2626';
  if (rx === null || rx === undefined) return '#94a3b8';
  if (rx <= -28) return '#dc2626';
  if (rx <= -25) return '#f59e0b';
  return '#22c55e';
}

function nmRebuildClusters() {
  if (!window.nmMap || !window.nmHwById || !window.nmHwLayer) return;
  if (!window.nmClusterLayer)
    window.nmClusterLayer = L.layerGroup().addTo(window.nmMap);
  window.nmClusterLayer.clearLayers();
  const isClusterZoom = window.nmMap.getZoom() <= NM_CLUSTER_ZOOM;

  // Toggle individual ONU markers + their heat rings + tooltips
  Object.values(window.nmHwById).forEach(({h, marker}) => {
    if (h.kind !== 'onu' || !marker) return;
    if (isClusterZoom) {
      if (window.nmHwLayer.hasLayer(marker)) window.nmHwLayer.removeLayer(marker);
      if (marker.__heatRing && window.nmHwLayer.hasLayer(marker.__heatRing))
        window.nmHwLayer.removeLayer(marker.__heatRing);
    } else {
      if (!window.nmHwLayer.hasLayer(marker)) window.nmHwLayer.addLayer(marker);
      if (marker.__heatRing && !window.nmHwLayer.hasLayer(marker.__heatRing))
        window.nmHwLayer.addLayer(marker.__heatRing);
    }
  });
  if (!isClusterZoom) return;

  // Bucket ONUs into a coarse grid
  const buckets = {};
  Object.values(window.nmHwById).forEach(({h}) => {
    if (h.kind !== 'onu' || h.lat == null || h.lng == null) return;
    const gy = Math.floor(h.lat / NM_CLUSTER_GRID);
    const gx = Math.floor(h.lng / NM_CLUSTER_GRID);
    const key = gy + '_' + gx;
    if (!buckets[key]) buckets[key] = {
      onus: [], sumLat: 0, sumLng: 0,
      worstRx: null, online: 0, offline: 0
    };
    const b = buckets[key];
    b.onus.push(h);
    b.sumLat += h.lat; b.sumLng += h.lng;
    const rx = h.props && h.props.rx_power;
    const st = (h.props && h.props.status) || '';
    if (st && st !== 'online') b.offline++; else b.online++;
    if (rx !== undefined && rx !== null) {
      if (b.worstRx === null || rx < b.worstRx) b.worstRx = rx;
    }
  });

  Object.values(buckets).forEach(b => {
    const lat = b.sumLat / b.onus.length;
    const lng = b.sumLng / b.onus.length;
    const col = _nmRxColor(b.worstRx, b.offline ? 'offline' : 'online');
    const radius = Math.min(42, 14 + Math.sqrt(b.onus.length) * 4.5);
    const m = L.circleMarker([lat, lng], {
      radius, color: '#fff', weight: 2.5,
      fillColor: col, fillOpacity: .85, className: 'nm-onu-cluster',
    });
    const rxStr = (b.worstRx !== null) ? b.worstRx.toFixed(1) + ' dBm' : '—';
    const offMsg = b.offline
      ? '<br><span style="color:#fca5a5">⚠ ' + b.offline + ' offline</span>'
      : '';
    m.bindTooltip(
      '<div style="font-size:14px"><b>' + b.onus.length + '</b></div>' +
      '<div>worst ' + rxStr + '</div>' + offMsg,
      { permanent: true, direction: 'center', className: 'nm-cluster-tip',
        offset: [0, 0] });
    m.bindPopup(
      '<b>' + b.onus.length + ' ONUs in this area</b><br>' +
      'Online: ' + b.online + ' &nbsp;·&nbsp; Offline: ' + b.offline + '<br>' +
      'Worst RX: <b style="color:' + col + '">' + rxStr + '</b><br>' +
      '<small>Click to zoom in</small>');
    m.on('click', () => window.nmMap.setView([lat, lng], 16));
    m.addTo(window.nmClusterLayer);
  });
}

// Re-cluster on zoom change
(function _nmHookZoomCluster() {
  // nmMap is created during DOMContentLoaded init; bind once available.
  const tryBind = () => {
    if (window.nmMap) {
      window.nmMap.on('zoomend', () => {
        try { nmRebuildClusters(); } catch(_){}
      });
      try { nmRebuildClusters(); } catch(_){}
    } else {
      setTimeout(tryBind, 500);
    }
  };
  tryBind();
})();

// Hook into refresh so clusters rebuild on data change
const __nmRefreshOrigCluster = window.nmRefreshAll;
window.nmRefreshAll = async function _cluster_refresh() {
  await __nmRefreshOrigCluster();
  setTimeout(() => { try { nmRebuildClusters(); } catch(_){} }, 600);
};


// ═══ _S40zη_  NOC Full-Screen Mode + audio alerts via SSE ═══════════════
window.__nocActive = false;
window.__nocSSE = null;
window.__nocAlerts = [];
window.__nocAudioCtx = null;
window.__nocLastSnap = { olts: [], onus: [] };
window.__nocClockTimer = null;

function _nocChime(critical) {
  try {
    if (!window.__nocAudioCtx)
      window.__nocAudioCtx = new (window.AudioContext
                                   || window.webkitAudioContext)();
    const ctx = window.__nocAudioCtx;
    if (ctx.state === 'suspended') ctx.resume();
    const now = ctx.currentTime;
    const f1 = critical ? 880 : 660;
    const f2 = critical ? 1320 : 880;
    const dur = critical ? 0.18 : 0.14;
    [f1, f2, critical ? f1 : null].filter(Boolean).forEach((f, i) => {
      const o = ctx.createOscillator();
      const g = ctx.createGain();
      o.type = 'sine'; o.frequency.value = f;
      g.gain.setValueAtTime(0, now + i * dur);
      g.gain.linearRampToValueAtTime(0.35, now + i * dur + 0.02);
      g.gain.linearRampToValueAtTime(0, now + i * dur + dur);
      o.connect(g).connect(ctx.destination);
      o.start(now + i * dur);
      o.stop(now + i * dur + dur + 0.05);
    });
  } catch(_) {}
}

function _nocFlashScreen() {
  document.body.classList.add('noc-flash');
  setTimeout(() => document.body.classList.remove('noc-flash'), 1300);
}

function _nocPushAlert(level, title, message) {
  const ts = new Date();
  window.__nocAlerts.unshift({ ts, level, title, message });
  if (window.__nocAlerts.length > 40) window.__nocAlerts.pop();
  _nocRenderAlerts();
  if (!window.__nocActive) return;   // don't chime when not in NOC mode
  if (level === 'critical') { _nocChime(true); _nocFlashScreen(); }
  else if (level === 'warn') { _nocChime(false); }
}

function _nocRenderAlerts() {
  const panel = document.getElementById('noc-alerts-list');
  if (!panel) return;
  if (!window.__nocAlerts.length) {
    panel.innerHTML =
      '<div style="color:#64748b;padding:14px;text-align:center;font-size:12px">'
      + 'No alerts yet. Network healthy.</div>';
    return;
  }
  const fmt = d => d.toLocaleTimeString('en-GB', { hour12: false });
  const colMap = { critical:'#dc2626', warn:'#f59e0b', info:'#3b82f6' };
  panel.innerHTML = window.__nocAlerts.map(a => {
    const col = colMap[a.level] || '#64748b';
    return '<div style="border-left:4px solid ' + col +
           ';padding:8px 12px;margin-bottom:6px;background:rgba(15,23,42,.7);' +
           'border-radius:6px;font-size:12px" data-testid="noc-alert-row">' +
             '<div style="display:flex;justify-content:space-between;align-items:baseline">' +
               '<b style="color:' + col + '">' + a.title + '</b>' +
               '<span style="color:#64748b;font-size:10px">' + fmt(a.ts) + '</span>' +
             '</div>' +
             '<div style="color:#cbd5e1;margin-top:2px">' + a.message + '</div>' +
           '</div>';
  }).join('');
}

function _nocOpenSSE() {
  if (window.__nocSSE) return;
  try {
    const es = new EventSource('/api/admin/olt/stream');
    es.addEventListener('snapshot', e => {
      try {
        window.__nocLastSnap = JSON.parse(e.data) || { olts:[], onus:[] };
      } catch(_) {}
    });
    es.addEventListener('delta', e => {
      try {
        const d = JSON.parse(e.data);
        const prev = window.__nocLastSnap || { olts:[], onus:[] };
        const prevOlts = {}; (prev.olts||[]).forEach(o => prevOlts[o.id] = o);
        const prevOnus = {}; (prev.onus||[]).forEach(u => prevOnus[u.id] = u);
        // OLT events
        (d.olts || []).forEach(o => {
          const p = prevOlts[o.id];
          if (p && p.status !== o.status) {
            if (o.status !== 'online')
              _nocPushAlert('critical', 'OLT DOWN',
                (o.name || '#' + o.id) + ' — status ' + o.status);
            else
              _nocPushAlert('info', 'OLT recovered',
                (o.name || '#' + o.id) + ' is back online');
          }
        });
        // ONU events
        (d.onus || []).forEach(u => {
          const p = prevOnus[u.id];
          if (p && p.status !== u.status) {
            if (u.status !== 'online')
              _nocPushAlert('warn', 'ONU offline',
                (u.name || '#' + u.id) + ' — went ' + u.status);
            else
              _nocPushAlert('info', 'ONU back online', (u.name || '#' + u.id));
          }
          if (u.rx_power !== null && u.rx_power !== undefined && u.rx_power <= -28) {
            const wasCritical = p && p.rx_power !== null
                                && p.rx_power !== undefined && p.rx_power <= -28;
            if (!wasCritical)
              _nocPushAlert('critical', 'CRITICAL RX',
                (u.name || '#' + u.id) + ' — RX ' + Number(u.rx_power).toFixed(1) + ' dBm');
          }
        });
        // Merge into last snapshot for next diff
        (d.onus || []).forEach(u => prevOnus[u.id] = u);
        (d.olts || []).forEach(o => prevOlts[o.id] = o);
        window.__nocLastSnap = {
          olts: Object.values(prevOlts),
          onus: Object.values(prevOnus),
        };
      } catch(_) {}
    });
    es.onerror = function() { /* EventSource auto-retries */ };
    window.__nocSSE = es;
  } catch(e) {
    console.warn('NOC SSE failed:', e);
    _nocPushAlert('warn', 'SSE error', 'Live stream unavailable: ' + e.message);
  }
}

function _nocCloseSSE() {
  if (window.__nocSSE) {
    try { window.__nocSSE.close(); } catch(_){}
    window.__nocSSE = null;
  }
}

function _nocStartClock() {
  const el = document.getElementById('noc-clock');
  if (!el) return;
  const tick = () => {
    const d = new Date();
    el.textContent = d.toLocaleTimeString('en-GB', { hour12: false }) +
                     '  ·  ' + d.toLocaleDateString('en-GB');
  };
  tick();
  if (window.__nocClockTimer) clearInterval(window.__nocClockTimer);
  window.__nocClockTimer = setInterval(tick, 1000);
}
function _nocStopClock() {
  if (window.__nocClockTimer) clearInterval(window.__nocClockTimer);
  window.__nocClockTimer = null;
}

window.nmToggleNocMode = function() {
  const shell = document.getElementById('netmap-shell');
  const btn = document.getElementById('nm-noc-btn');
  if (!window.__nocActive) {
    // Enter NOC mode using the native Fullscreen API so the browser
    // sizes the shell against the screen — bypasses any parent CSS
    // layout/transform that was clipping #netmap-shell to ~80%.
    if (shell && shell.requestFullscreen) {
      shell.requestFullscreen().then(() => {
        // The fullscreenchange handler below toggles state.
      }).catch(err => {
        // Fallback: fixed-positioned overlay if Fullscreen API blocked.
        console.warn('Fullscreen failed, using overlay fallback:', err);
        _nocApplyState(true, /* fallback */ true);
      });
    } else {
      _nocApplyState(true, true);
    }
  } else {
    if (document.fullscreenElement) {
      document.exitFullscreen().catch(() => {});
    } else {
      _nocApplyState(false, true);   // fallback path
    }
  }
};

// _S40zη.d_  Apply / clear all NOC styling, alerts, SSE in one place
// regardless of whether we entered via Fullscreen API or fallback.
function _nocApplyState(active, fallback) {
  window.__nocActive = active;
  const shell = document.getElementById('netmap-shell');
  const mapEl = document.getElementById('netmap');
  const btn = document.getElementById('nm-noc-btn');
  if (active) {
    document.body.classList.add('noc-mode');
    document.documentElement.classList.add('noc-html');
    if (btn) { btn.classList.add('noc-on'); btn.textContent = '✕ EXIT NOC'; }
    if (fallback && shell) {
      // Overlay fallback (when Fullscreen API isn't available)
      shell.__nocOrigParent = shell.parentNode;
      shell.__nocOrigNext   = shell.nextSibling;
      try { document.body.appendChild(shell); } catch(_){}
      shell.style.cssText =
        'position:fixed!important;top:0!important;left:0!important;' +
        'right:0!important;bottom:0!important;' +
        'width:' + window.innerWidth + 'px!important;' +
        'height:' + window.innerHeight + 'px!important;' +
        'z-index:9999!important;background:#0f172a!important;' +
        'margin:0!important;padding:0!important;';
    }
    if (mapEl) {
      mapEl.style.cssText =
        'position:absolute!important;top:0!important;left:0!important;' +
        'right:0!important;bottom:0!important;width:100%!important;' +
        'height:100%!important;';
    }
    _nocOpenSSE();
    _nocStartClock();
    if (!window.__nocAudioCtx) {
      try {
        window.__nocAudioCtx = new (window.AudioContext
                                     || window.webkitAudioContext)();
      } catch(_) {}
    }
    if (window.__nocAudioCtx && window.__nocAudioCtx.state === 'suspended')
      window.__nocAudioCtx.resume();
    _nocPushAlert('info', 'NOC mode active', 'Live SSE + audio alerts on');
  } else {
    document.body.classList.remove('noc-mode');
    document.documentElement.classList.remove('noc-html');
    if (btn) { btn.classList.remove('noc-on'); btn.textContent = '📺 NOC MODE'; }
    if (shell) {
      shell.style.cssText = '';
      if (shell.__nocOrigParent) {
        try {
          if (shell.__nocOrigNext)
            shell.__nocOrigParent.insertBefore(shell, shell.__nocOrigNext);
          else
            shell.__nocOrigParent.appendChild(shell);
        } catch(_) {}
      }
      shell.__nocOrigParent = null;
      shell.__nocOrigNext = null;
    }
    if (mapEl) mapEl.style.cssText = '';
    _nocCloseSSE();
    _nocStopClock();
  }
  // Re-fit Leaflet across multiple frames so it catches the new size.
  const fix = () => {
    try { window.nmMap && window.nmMap.invalidateSize(true); } catch(_){}
  };
  requestAnimationFrame(fix);
  setTimeout(fix, 100);
  setTimeout(fix, 350);
  setTimeout(fix, 800);
}

// Sync state with the browser's fullscreen lifecycle (ESC, F11, etc.)
document.addEventListener('fullscreenchange', () => {
  const shell = document.getElementById('netmap-shell');
  const inFs = (document.fullscreenElement === shell);
  if (inFs && !window.__nocActive) _nocApplyState(true, false);
  else if (!inFs && window.__nocActive) _nocApplyState(false, false);
});

// Re-fit map on any viewport resize while NOC is active
window.addEventListener('resize', () => {
  if (!window.__nocActive) return;
  try { window.nmMap && window.nmMap.invalidateSize(true); } catch(_){}
});

// ESC exits NOC mode (separate from fiber-audit ESC)
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && window.__nocActive) {
    const m = document.getElementById('nmFiberAuditModal');
    if (m && m.style.display !== 'none') return;   // let audit modal handle
    window.nmToggleNocMode();
  }
});
</script>


