          </div>
          <div style="font-weight:700;color:${c};font-size:12px">
            ${h.cum_dbm >= 0 ? "+" : ""}${h.cum_dbm.toFixed(2)} dBm
          </div>
        </div>`;
    } else {  // fiber
      html += `
        <div data-testid="path-trace-hop-${idx}"
             onclick="nmPanToHop(${h.polyline[0][0]},${h.polyline[0][1]})"
             style="display:flex;align-items:center;gap:8px;padding:4px 8px;
                    margin-bottom:3px;cursor:pointer;
                    border-left:3px solid ${c}">
          <div style="width:20px;height:3px;background:${c};border-radius:2px"></div>
          <div style="flex:1;color:#94a3b8;font-size:11px">
            <i>fiber</i> ${h.name}
            &nbsp;<span style="color:#cbd5e1">${h.length_m}m</span>
            &nbsp;<span>-${h.loss_db.toFixed(2)} dB</span>
          </div>
          <div style="color:${c};font-size:11px;font-weight:600">
            ${h.cum_dbm >= 0 ? "+" : ""}${h.cum_dbm.toFixed(2)}
          </div>
        </div>`;
    }
  });
  html += `</div>`;
  body.innerHTML = html;

  /* Draw fiber overlays — one per fiber hop, color graded by health */
  j.hops.forEach(h => {
    if (h.type !== "fiber" || !h.polyline || h.polyline.length < 2) return;
    const c = _nmHopColorForCum(h.cum_dbm);
    const overlay = L.polyline(h.polyline, {
      color: c, weight: 8, opacity: 0.85,
      dashArray: "12 6"
    }).addTo(nmMap);
    let on = true;
    overlay._nmBlink = setInterval(() => {
      on = !on;
      overlay.setStyle({opacity: on ? 0.85 : 0.35});
    }, 600);
    window.__nmPathOverlays.push(overlay);
  });

  /* Pan to fit the whole route */
  const allPts = [];
  j.hops.forEach(h => {
    if (h.type === "fiber" && h.polyline) allPts.push(...h.polyline);
    else if (h.type === "node") allPts.push([h.lat, h.lng]);
  });
  if (allPts.length) {
    try { nmMap.fitBounds(L.latLngBounds(allPts).pad(0.15)); } catch(_){}
  }
}

function nmPanToHop(lat, lng) {
  if (typeof lat === "number" && typeof lng === "number") {
    nmMap.panTo([lat, lng]);
  }
}

function nmClearPathTrace() {
  (window.__nmPathOverlays || []).forEach(o => {
    try { clearInterval(o._nmBlink); } catch(_){}
    try { nmMap.removeLayer(o); } catch(_){}
  });
  window.__nmPathOverlays = [];
}

function nmClosePathTracePanel() {
  nmClearPathTrace();
  const sb = document.getElementById("nm-path-trace-panel");
  if (sb) sb.style.display = "none";
}
</script>

