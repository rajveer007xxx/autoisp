<!-- _S40zl_ _S40zo_ -->
{% extends layout_template %}
{# _S40k_  Network GIS Map — full redesign:
   • Tiles with road/POI labels (ESRI Hybrid + CartoDB Voyager)
   • Nominatim search box
   • OLT in deploy panel; splitter prompts for output legs
   • Draggable hardware + draggable fiber endpoints/vertices
   • ONU pins show name + live RX power label
   • Fiber snaps to nearest hardware on click (≤ 30 m)
   • CANCEL fully resets all listeners and modes
#}

{% block title %}Network Map

{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<style>
  /* _S40zm_  Fill all remaining viewport, no gap to footer */
  #netmap-shell{position:relative; width:100%; height:calc(100vh - 60px);
                background:#0f172a; color:#e2e8f0; overflow:hidden;
                margin:0; padding:0;}
  /* _S40zn_  Collapse the wrapper around the map. The base layout
     reserves min-height for content-wrapper which leaves a white gap
     between the map and the footer. Force it to match the shell. */
  body.has-netmap{margin-bottom:0!important; padding-bottom:0!important;}
  body.has-netmap > footer, body.has-netmap .footer{margin-top:0!important;}
  body.has-netmap .content-wrapper,
  body.has-netmap .main-content,
  body.has-netmap .page-content{
      min-height:0!important; padding-bottom:0!important; margin-bottom:0!important;}
  body.has-netmap .content-wrapper > div:not(#netmap-shell){
      display:none!important;}  /* Hide any sibling padding-bearing divs */
  /* Final safeguard: glue footer to bottom edge regardless */
  /* _S40zp_  Aggressive footer collapse */
  body.has-netmap{display:flex; flex-direction:column; min-height:100vh;
                   margin:0!important; padding:0!important;}
  body.has-netmap footer, body.has-netmap .footer,
  body.has-netmap .copyright, body.has-netmap .footer-text{
      padding:8px 12px!important; margin:0!important;
      min-height:auto!important; height:auto!important;}
  body.has-netmap > *:last-child{margin-bottom:0!important;}
  /* _S40zr_  Final footer collapse — kill EVERY whitespace-bearing wrapper. */
  body.has-netmap{overflow:hidden!important;}
  /* _S40zr4_  Fixed-position the netmap-shell so it ignores the buggy
     base_admin content-wrapper sizing entirely. The shell occupies the
     viewport space between topbar and footer; content-wrapper collapses
     to 0 height so the footer naturally sits at the bottom. */
  body.has-netmap{height:100vh!important; max-height:100vh!important;
                    overflow:hidden!important;}
  body.has-netmap .wrapper > .content-wrapper{
      min-height:0!important; height:auto!important; padding-top:0!important;
      padding-bottom:0!important; margin-bottom:0!important;}
  body.has-netmap #netmap-shell{
      position:fixed!important;
      top:var(--topbar-h, 56px)!important;
      left:var(--sidebar-w, 280px)!important;
      right:0!important; bottom:36px!important;
      width:auto!important; height:auto!important;}
  body.has-netmap.sidebar-collapse #netmap-shell{
      left:68px!important;}
  body.has-netmap .wrapper > .main-footer{
      position:fixed!important; bottom:0!important; left:var(--sidebar-w, 280px)!important;
      right:0!important; height:36px!important; min-height:auto!important;
      padding:8px 16px!important; line-height:20px!important; z-index:50!important;
      background:var(--bg, #0f172a)!important;}
  body.has-netmap.sidebar-collapse .wrapper > .main-footer{left:68px!important;}
  body.has-netmap .container, body.has-netmap .container-fluid,
  body.has-netmap main, body.has-netmap section{
      padding:0!important; margin:0!important; min-height:0!important;}
  body.has-netmap .footer-container, body.has-netmap .copyright-block,
  body.has-netmap .footer-bottom, body.has-netmap .bottom-spacer{
      padding:6px 12px!important; margin:0!important;}
  body.has-netmap #footer, body.has-netmap #site-footer{
      padding:6px 12px!important; margin:0!important; min-height:auto!important;}
  /* If the host layout sneaks in a trailing whitespace div, hide it. */
  body.has-netmap > div:empty, body.has-netmap > section:empty{display:none!important;}
  #netmap{position:absolute; inset:0; z-index:1;}
  /* Top control row */
  .nm-ctrls{position:absolute; top:14px; left:14px; z-index:600;
            display:flex; gap:8px; flex-wrap:wrap;}
  .nm-btn{padding:10px 16px; border-radius:10px; border:none;
          background:rgba(15,23,42,.85); color:#fff; font-weight:600;
          font-size:13px; cursor:pointer; backdrop-filter:blur(8px);
          box-shadow:0 4px 14px rgba(0,0,0,.35);}
  .nm-btn.active{background:#6366f1;}
  .nm-btn.satellite{background:#4f46e5;}
  .nm-btn.danger{background:#dc2626;}
  .nm-btn.warn{background:#f59e0b; color:#1a1a1a;}
  .nm-btn.success{background:#10b981;}
  /* Search box */
  .nm-search{position:absolute; top:14px; left:50%; transform:translateX(-50%);
             z-index:600; width:380px; max-width:50vw;
             display:flex; gap:0; align-items:center;
             background:rgba(15,23,42,.92); border-radius:9999px;
             padding:4px 4px 4px 16px; backdrop-filter:blur(8px);
             box-shadow:0 4px 14px rgba(0,0,0,.35);
             border:1px solid rgba(99,102,241,.3);}
  .nm-search input{flex:1; background:transparent; border:none; outline:none;
                    color:#fff; font-size:14px; padding:8px 4px;}
  .nm-search input::placeholder{color:#94a3b8;}
  .nm-search button{padding:7px 16px; border:none; border-radius:9999px;
                     background:#6366f1; color:#fff; cursor:pointer;
                     font-weight:600; font-size:13px;}
  .nm-search-results{position:absolute; top:54px; left:0; right:0;
                      background:#0f172a; border:1px solid rgba(99,102,241,.3);
                      border-radius:10px; max-height:280px; overflow-y:auto;
                      box-shadow:0 6px 22px rgba(0,0,0,.4); display:none;}
  .nm-search-results.show{display:block;}
  .nm-search-results .row{padding:9px 14px; cursor:pointer;
                            border-bottom:1px solid #1e293b; font-size:13px;}
  .nm-search-results .row:hover{background:rgba(99,102,241,.18);}
  /* Hardware deploy panel */
  /* _S40zm_  Make panel scrollable and capped to viewport */
  .nm-hw-panel{position:absolute; top:74px; left:14px; z-index:600;
               width:240px; background:rgba(15,23,42,.92); padding:14px;
               border-radius:14px; box-shadow:0 6px 22px rgba(0,0,0,.4);
               backdrop-filter:blur(8px); color:#e2e8f0;
               border:1px solid rgba(99,102,241,.25);
               max-height:calc(100vh - 110px); overflow-y:auto;
               scrollbar-width:thin; scrollbar-color:#6366f1 #1e293b;}
  .nm-hw-panel::-webkit-scrollbar{width:8px;}
  .nm-hw-panel::-webkit-scrollbar-track{background:#1e293b; border-radius:4px;}
  .nm-hw-panel::-webkit-scrollbar-thumb{background:#6366f1; border-radius:4px;}
  .nm-hw-panel h4{margin:0 0 10px; font-size:11px; font-weight:700;
                  letter-spacing:.12em; color:#94a3b8; text-transform:uppercase;}
  .nm-hw-btn{display:flex; align-items:center; gap:10px; width:100%;
             padding:9px 12px; margin:6px 0; border-radius:8px;
             border:1px solid rgba(99,102,241,.18);
             background:rgba(30,41,59,.6); color:#e2e8f0; cursor:pointer;
             font-size:13px; transition:transform .12s, background .12s;}
  .nm-hw-btn:hover{background:rgba(99,102,241,.22); transform:translateX(2px);}
  .nm-hw-btn.deploy{background:#dc2626; color:#fff; font-weight:700;
                    justify-content:center; padding:11px;}
  .nm-hw-btn.deploy:hover{background:#b91c1c;}
  .nm-hw-icon{width:22px; height:22px; display:inline-flex; align-items:center;
              justify-content:center; border-radius:5px; flex-shrink:0;
              color:#fff; font-weight:700; font-size:13px;}
  .nm-banner{position:absolute; top:74px; left:50%; transform:translateX(-50%);
             z-index:601; background:rgba(245,158,11,.95); color:#1a1a1a;
             padding:9px 18px; border-radius:9999px; font-weight:700;
             font-size:13px; box-shadow:0 4px 16px rgba(0,0,0,.4); display:none;}
  .nm-banner.show{display:block;}
  .nm-legend{position:absolute; bottom:14px; right:14px; z-index:600;
             background:rgba(15,23,42,.9); padding:10px 14px;
             border-radius:10px; font-size:12px; color:#e2e8f0;
             border:1px solid rgba(99,102,241,.25);}
  .nm-legend .row{display:flex; align-items:center; gap:8px; margin:3px 0;}
  .nm-legend .dot{width:12px; height:12px; border-radius:50%;}
  /* Tooltip-style live label on ONU pins */
  .nm-onu-label{background:rgba(0,0,0,.78)!important; color:#fff!important;
                 border:1px solid rgba(99,102,241,.6)!important;
                 padding:3px 8px!important; font-size:11px!important;
                 font-weight:600!important; border-radius:6px!important;
                 box-shadow:0 2px 8px rgba(0,0,0,.4)!important;
                 pointer-events:none!important;   /* _S40x_ */ }
  .nm-onu-label.bad{border-color:#fca5a5!important; color:#fecaca!important;}
  .nm-onu-label::before{display:none!important;}
  /* _S40zg_  Zoom-aware label density: hide hardware leg/PON tooltips at zoom < 17 */
  body.nm-zoom-low .nm-hw-tip{display:none!important;}
/* Ensure search box never overlaps the locate FAB */
  .nm-search{z-index:700;}

  /* _S40o_  Power-budget heatmap ring around ONU pins */
  .nm-heat-ring{position:absolute; pointer-events:none;
                 width:48px; height:48px; border-radius:50%;
                 left:-10px; top:-10px;
                 box-shadow:0 0 0 4px var(--ring),
                            0 0 16px var(--ring);
                 opacity:.85;}

  /* _S40zη_  Worst-RX cluster bubble label */
  .nm-cluster-tip{background:transparent!important; border:none!important;
                   box-shadow:none!important; color:#fff!important;
                   font-size:11px!important; font-weight:700!important;
                   text-shadow:0 1px 3px rgba(0,0,0,.85)!important;
                   text-align:center!important; padding:0!important;
                   white-space:nowrap;}
  .nm-cluster-tip::before{display:none!important;}

  /* _S40zη_  NOC full-screen mode — hides every chrome element so the
     map fills the wall display. */
  body.noc-mode header, body.noc-mode .main-header,
  body.noc-mode .topbar, body.noc-mode .navbar,
  body.noc-mode .sidebar, body.noc-mode .main-sidebar,
  body.noc-mode aside, body.noc-mode nav.sidebar,
  body.noc-mode .main-footer, body.noc-mode footer,
  body.noc-mode .footer, body.noc-mode .copyright,
  body.noc-mode .breadcrumbs, body.noc-mode .breadcrumb,
  body.noc-mode .wrapper > nav, body.noc-mode #header,
  body.noc-mode .layout-topbar, body.noc-mode .page-topbar{
    display:none!important;}
  /* _S40zη.b_  Clamp body to viewport so the fixed netmap-shell doesn't
     leave whitespace below/right when the host wrapper is taller. */
  html.noc-html, body.noc-mode{
    overflow:hidden!important;
    height:100vh!important; max-height:100vh!important;
    width:100vw!important; max-width:100vw!important;
    margin:0!important; padding:0!important;
    background:#0f172a!important;}
  body.noc-mode #netmap-shell{
    position:fixed!important; top:0!important; left:0!important;
    right:0!important; bottom:0!important;
    width:100vw!important; height:100vh!important; z-index:9999!important;}
  body.noc-mode .wrapper, body.noc-mode .content-wrapper,
  body.noc-mode .main-content, body.noc-mode .page-content,
  body.noc-mode .container, body.noc-mode .container-fluid,
  body.noc-mode main, body.noc-mode section{
    margin:0!important; padding:0!important;
    height:auto!important; min-height:0!important;}
  body.noc-mode .nm-hw-panel{display:none!important;}

  /* NOC alerts panel — only visible in NOC mode */
  .noc-alerts-panel{position:absolute; top:14px; right:14px;
                     width:340px; max-height:calc(100vh - 100px);
                     background:rgba(15,23,42,.94);
                     border:1px solid rgba(99,102,241,.4);
                     border-radius:14px; padding:14px;
                     z-index:700; display:none;
                     backdrop-filter:blur(10px);
                     box-shadow:0 14px 44px rgba(0,0,0,.7);}
  body.noc-mode .noc-alerts-panel{display:block;}
  .noc-alerts-panel h4{margin:0 0 12px; color:#fff; font-size:13px;
                        letter-spacing:.12em; text-transform:uppercase;
                        display:flex; align-items:center; gap:8px;
                        font-weight:700;}
  .noc-alerts-panel h4::before{content:''; width:9px; height:9px;
                                 background:#22c55e; border-radius:50%;
                                 box-shadow:0 0 8px #22c55e;
                                 animation:nocPulse 1.6s infinite;}
  @keyframes nocPulse{0%,100%{opacity:1; transform:scale(1);}
                       50%{opacity:.3; transform:scale(.7);}}
  #noc-alerts-list{max-height:calc(100vh - 220px); overflow-y:auto;
                    padding-right:4px;}
  #noc-alerts-list::-webkit-scrollbar{width:6px;}
  #noc-alerts-list::-webkit-scrollbar-thumb{background:#475569;
                                               border-radius:3px;}
  .nm-btn.noc-on{background:#ec4899!important; color:#fff!important;}
  /* _S40zη.b_  Floating NOC button at top-right corner — never overlaps
     with the centered search bar. */
  .nm-noc-fab{position:absolute; top:14px; right:14px; z-index:701;
              background:#ec4899; color:#fff; font-weight:700;
              padding:10px 18px; border-radius:10px; border:none;
              cursor:pointer; backdrop-filter:blur(8px);
              box-shadow:0 4px 14px rgba(0,0,0,.35);
              font-size:13px; transition:transform .12s, background .12s;}
  .nm-noc-fab:hover{background:#db2777; transform:translateY(-1px);}
  /* In NOC mode, move the FAB to bottom-right (next to the legend which
     we relocate to bottom-left to make room) and lift z-index so it
     stays clickable above the alerts panel. */
  body.noc-mode .nm-noc-fab{top:auto; right:14px; bottom:14px;
                              z-index:9999;}
  body.noc-mode .nm-legend{right:auto; left:14px;}
  .noc-clock{position:absolute; top:14px; left:14px; z-index:700;
              display:none; background:rgba(15,23,42,.92); color:#fff;
              padding:10px 18px; border-radius:12px;
              font:700 18px/1 ui-monospace,monospace; letter-spacing:.06em;
              border:1px solid rgba(99,102,241,.3);
              box-shadow:0 4px 16px rgba(0,0,0,.4);}
  body.noc-mode .noc-clock{display:block;}
  body.noc-mode .nm-ctrls{top:auto; bottom:14px; left:50%;
                            transform:translateX(-50%);}
  body.noc-mode .nm-search{display:none;}
  /* Critical-flash overlay for big alerts */
  body.noc-mode.noc-flash::after{content:''; position:fixed; inset:0;
                                   background:rgba(220,38,38,.16);
                                   pointer-events:none; z-index:9998;
                                   animation:nocFlash 1.2s 1;}
  @keyframes nocFlash{0%,80%{opacity:1;} 100%{opacity:0;}}

  /* _S40zη.d_  Native Fullscreen API support — when #netmap-shell is
     fullscreen, render every overlay/alerts/legend/clock inside it
     since that's the only element the browser is rendering. */
  #netmap-shell:fullscreen{
    width:100vw!important; height:100vh!important;
    background:#0f172a!important; padding:0!important; margin:0!important;}
  #netmap-shell:fullscreen #netmap{
    position:absolute!important; inset:0!important;
    width:100%!important; height:100%!important;}
  #netmap-shell:fullscreen .nm-search,
  #netmap-shell:fullscreen .nm-hw-panel{display:none!important;}
  #netmap-shell:fullscreen .noc-alerts-panel{display:block!important;}
  #netmap-shell:fullscreen .noc-clock{display:block!important;}
  #netmap-shell:fullscreen .nm-noc-fab{position:absolute!important;
                                         top:auto!important; right:14px!important;
                                         bottom:14px!important;
                                         z-index:9999!important;}
  #netmap-shell:fullscreen .nm-legend{right:auto!important;
                                        left:14px!important;}
  #netmap-shell:fullscreen .nm-ctrls{top:auto!important; bottom:14px!important;
                                       left:50%!important;
                                       transform:translateX(-50%)!important;}

  /* __S55C_NETMAP_MOBILE__ — collapsible deploy-hardware panel on phones */
  .nm-hw-toggle{display:none; position:absolute; top:14px; left:14px; z-index:710;
                background:#dc2626; color:#fff; border:none; border-radius:999px;
                padding:9px 14px; font-size:13px; font-weight:700; cursor:pointer;
                box-shadow:0 4px 16px rgba(0,0,0,.4);}
  .nm-hw-toggle i{margin-right:6px;}
  @media (max-width: 767px){
    .nm-hw-toggle{display:inline-flex; align-items:center;}
    .nm-hw-panel{
      position:fixed !important;
      left:0 !important; right:0 !important; bottom:0 !important; top:auto !important;
      width:100% !important; max-width:100% !important;
      max-height:55vh !important; min-height:auto !important;
      border-radius:18px 18px 0 0 !important;
      transform: translateY(100%);
      transition: transform .25s ease;
      z-index:700 !important;
    }
    .nm-hw-panel.is-open{ transform: translateY(0); }
    .nm-hw-panel::before{
      content:''; display:block; width:42px; height:4px; margin:-4px auto 8px;
      background:#475569; border-radius:99px;
    }
    .nm-legend{
      bottom:auto !important; top:14px !important; right:14px !important;
      font-size:10px !important; padding:6px 10px !important;
    }
    .nm-banner{
      top:62px !important; font-size:11px !important; padding:6px 12px !important;
      max-width:calc(100vw - 30px) !important;
    }
  }

  /* __S55D_NETMAP_MOBILE_V2__ — phone-friendly netmap.
     On ≤767px, COLLAPSE all floating controls into a single hamburger,
     hide the legend, and ensure the map fills the viewport. */
  @media (max-width: 767px){
    /* Hide the top-left control bar buttons by default. */
    .nm-ctrls{ display: none !important; }
    .nm-ctrls.is-open{
      display: flex !important; flex-direction: column !important;
      gap: 6px !important;
      position: fixed !important; left: 12px !important; top: 60px !important;
      background: rgba(15,23,42,.95) !important;
      padding: 10px !important; border-radius: 12px !important;
      border: 1px solid rgba(99,102,241,.30) !important;
      max-height: 70vh !important; overflow-y: auto !important; z-index: 720 !important;
    }
    .nm-ctrls.is-open .nm-btn{ width: 100% !important; justify-content: flex-start !important; }
    /* NOC button gets reduced to icon-only at the far right. */
    .nm-noc-fab{
      padding: 8px 10px !important; font-size: 0 !important;
      width: 38px !important; height: 38px !important;
      border-radius: 50% !important;
    }
    .nm-noc-fab::before{ content: '📺'; font-size: 18px !important; }
    /* Legend collapses to a single dot/menu icon on mobile. */
    .nm-legend{
      bottom: 78px !important; right: 10px !important;
      max-width: 200px !important; font-size: 10.5px !important;
      padding: 8px 10px !important;
    }
    /* My existing toggle button gets fixed top-left as a hamburger that
       opens .nm-ctrls instead. Keep deploy alongside. */
    #nmCtrlsBurger{
      display: inline-flex !important; position: absolute;
      top: 12px; left: 12px; z-index: 715;
      background:#1e293b; border:1px solid rgba(99,102,241,.35);
      color:#cbd5e1; border-radius:50%; width:38px; height:38px;
      align-items:center; justify-content:center; cursor:pointer;
      box-shadow: 0 3px 12px rgba(0,0,0,.5);
    }
    .nm-hw-toggle{
      top: 12px !important; left: 56px !important;
      padding: 8px 12px !important; font-size: 12px !important;
    }
  }
  /* Always-hidden burger on desktop */
  #nmCtrlsBurger{ display: none; }

  /* __S55E_NETMAP_FULLWIDTH__ — Force the netmap to occupy 100vw on phones, eliminating
     any blank area created by leftover AdminLTE margin-left or by Leaflet
     not realising the viewport size changed. */
  @media (max-width: 991px){
    body.has-netmap .main-sidebar,
    body.has-netmap .left-side {
      transform: translateX(-100%) !important;
    }
    body.has-netmap .wrapper,
    body.has-netmap .content-wrapper {
      margin-left: 0 !important;
      padding-left: 0 !important;
      width: 100% !important;
    }
    body.has-netmap #netmap-shell {
      position: fixed !important;
      left: 0 !important; right: 0 !important;
      top: 56px !important;        /* below the top bar */
      bottom: 0 !important;
      width: 100vw !important;
      max-width: 100vw !important;
      height: calc(100vh - 56px) !important;
    }
    /* Leaflet's tile container must also be 100% */
    body.has-netmap #netmap-shell > div,
    body.has-netmap .leaflet-container {
      width: 100% !important;
      height: 100% !important;
    }
  }

  /* __S55F_NETMAP_CTRLS_SHEET__ — compact bottom-sheet for the mobile
     controls popup, with proper close button. */
  @media (max-width: 991px){
    .nm-ctrls{ display: none !important; }
    .nm-ctrls.is-open{
      display: flex !important; flex-wrap: wrap !important;
      flex-direction: row !important;
      gap: 8px !important;
      position: fixed !important;
      left: 12px !important; right: 12px !important;
      bottom: 88px !important;  /* above the bottom-nav */
      top: auto !important;
      width: auto !important; max-height: 38vh !important;
      overflow-y: auto !important;
      background: rgba(15,23,42,.97) !important;
      padding: 38px 14px 14px !important;
      border-radius: 16px !important;
      border: 1px solid rgba(99,102,241,.35) !important;
      box-shadow: 0 -10px 30px rgba(0,0,0,.55) !important;
      animation: nmSlideUp .25s ease;
      z-index: 720 !important;
    }
    .nm-ctrls.is-open::before{
      content: 'Map Controls';
      position: absolute; top: 10px; left: 14px;
      font-size: 12px; font-weight: 700; letter-spacing: 0.05em;
      color: #93C5FD; text-transform: uppercase;
    }
    /* Close button — generated via ::after pseudo isn't clickable in
       all browsers, so we inject a real <button> via JS below. */
    .nm-ctrls-close{
      position: absolute !important; top: 6px !important; right: 8px !important;
      width: 30px !important; height: 30px !important;
      border-radius: 50% !important;
      background: rgba(239,68,68,.25) !important;
      color: #FCA5A5 !important;
      border: 1px solid rgba(239,68,68,.45) !important;
      font-size: 18px !important; font-weight: 700 !important;
      line-height: 1 !important; cursor: pointer !important;
      display: flex !important; align-items: center !important; justify-content: center !important;
      padding: 0 !important;
    }
    .nm-ctrls-close:hover{ background: rgba(239,68,68,.45) !important; color: #FEE2E2 !important; }
    /* Make each button compact: pill, fits 2 per row */
    .nm-ctrls.is-open .nm-btn{
      flex: 1 1 calc(50% - 4px) !important;
      min-width: 0 !important;
