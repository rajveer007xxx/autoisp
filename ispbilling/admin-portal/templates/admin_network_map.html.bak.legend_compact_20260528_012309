function nmHwTooltip(h) {
  if (h.kind !== "onu") return null;
  const props = h.props || {};
  const rx = props.rx_power;
  const cls = (rx !== undefined && rx !== null && rx <= -25) ? "nm-onu-label bad"
                                                                : "nm-onu-label";
  const rxStr = (rx !== undefined && rx !== null) ? rx.toFixed(1)+" dBm" : "—";
  /* _S40zβ_  Pin label uses customer name first, then pin name,
     then serial, then ONU#id — matches popup title chain. */
  const label = props.customer_name || h.name || props.serial || "ONU";
  return { html:`<b>${label}</b> <span style="opacity:.85">${rxStr}</span>`,
            cls };
