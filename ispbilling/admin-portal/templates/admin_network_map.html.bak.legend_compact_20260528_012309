<script>
/* __S55E_NETMAP_INVALIDATE_SIZE__ — Call leaflet's invalidateSize() whenever
   the viewport resizes so the map redraws to fill the container. */
(function(){
  function tryInvalidate(){
    try{
      var candidates = [window.map, window.netmap, window.NMMAP, window.nmMap];
      for (var i = 0; i < candidates.length; i++){
        var m = candidates[i];
        if (m && typeof m.invalidateSize === 'function'){ m.invalidateSize(true); }
      }
      // Fallback: find via leaflet container DOM
      var el = document.querySelector('.leaflet-container');
      if (el && el._leaflet_id && window.L){
        var maps = (window.L && L._allMaps) || [];
        maps.forEach(function(mm){ if (mm && mm.invalidateSize) mm.invalidateSize(true); });
      }
    } catch(e){}
  }
  window.addEventListener('resize', function(){
    clearTimeout(window.__nmResizeT);
    window.__nmResizeT = setTimeout(tryInvalidate, 100);
  });
  window.addEventListener('orientationchange', function(){ setTimeout(tryInvalidate, 350); });
  // Initial nudge after page load — covers the case where #netmap-shell
  // resizes after our mobile CSS applies.
  setTimeout(tryInvalidate, 800);
  setTimeout(tryInvalidate, 2000);
})();
</script>
