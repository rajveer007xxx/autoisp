<script>
(function(){
  function init(){
    if (typeof L === 'undefined' || typeof nmMap === 'undefined' || !nmMap){
      return setTimeout(init, 500);
    }
    const onuLayer = L.layerGroup().addTo(nmMap);
    let _onuMarkers = {};

    function pinHtml(status, source){
      const c = (status === 'online') ? '#10b981'
              : (status === 'offline') ? '#ef4444'
              : '#94a3b8';
      const ring = (source === 'gps')    ? '3px solid #10b981'
                : (source === 'manual') ? '3px solid #3b82f6'
                :                          '3px dashed #f59e0b';
      return '<div style="width:18px;height:18px;border-radius:50%;background:'+c+
             ';border:'+ring+';box-shadow:0 1px 4px rgba(0,0,0,.3);"></div>';
    }

    async function loadOnuPins(){
      try {
        const r = await fetch('/api/admin/network-map/onus', {credentials:'include'});
        const d = await r.json();
        if(!d.success){ console.warn('onu pins err', d); return; }
        onuLayer.clearLayers(); _onuMarkers = {};
        d.items.forEach(o => {
          // _v4734_  Skip rendering the minimal-popup pin when a
          // network_hardware pin with ref_onu_id == o.id already exists —
          // avoids duplicate markers at the same coords. The hw pin's
          // rich popup (Connect/Trace Path/Open OLT Mgmt/Delete) supersedes.
          if (window._nmHwOnuRefs && window._nmHwOnuRefs.has(o.id)) {
            return;
          }
          const m = L.marker([o.lat, o.lng], {
            icon: L.divIcon({html: pinHtml(o.status, o.location_source),
                              iconSize:[18,18], iconAnchor:[9,9], className:'onu-pin'}),
            draggable: true
          });
          const statusBg = (o.status==='online') ? '#dcfce7' : '#fee2e2';
          const statusFg = (o.status==='online') ? '#15803d' : '#b91c1c';
          const html = '<div style="font-size:13px;line-height:1.6;min-width:220px;">'+
            '<b>'+(o.customer_name||'(unassigned)')+'</b><br>'+
            '<small style="color:#64748b">'+o.serial+' · '+(o.locality||'-')+'</small><br>'+
            '<span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;background:'+statusBg+';color:'+statusFg+';">'+
            (o.status||'').toUpperCase()+'</span>'+
            (o.rx_dbm ? '<span style="margin-left:6px;font-size:11px;color:#475569;">RX '+o.rx_dbm+' dBm</span>' : '')+
            '<br><small>OLT-'+o.olt_id+' / PON '+o.pon_port+'</small>'+
            '<br><small style="color:#94a3b8">Source: '+o.location_source+'</small>'+
            '<br><a href="'+(window.OLT_PORTAL_PREFIX || '/admin/olt')+'/onus?focus_onu='+o.id+'" target="_blank" style="color:#6366f1;font-weight:600;font-size:12px;" data-testid="olt-manager-link-'+o.id+'">Open in OLT Manager &rarr;</a>'+
            '</div>';
          m.bindPopup(html);
          m.on('dragend', async function(ev){
            const ll = ev.target.getLatLng();
            if(!confirm('Move '+(o.customer_name||o.serial)+' pin to '+ll.lat.toFixed(6)+', '+ll.lng.toFixed(6)+'?')){
              ev.target.setLatLng([o.lat, o.lng]); return;
            }
            const resp = await fetch('/api/admin/onus/'+o.id+'/location',{
              method:'PUT', credentials:'include',
              headers:{'Content-Type':'application/json'},
              body:JSON.stringify({lat:ll.lat, lng:ll.lng, source:'manual'})});
            const dd = await resp.json();
            if(dd.success){
              o.lat=ll.lat; o.lng=ll.lng; o.location_source='manual';
              ev.target.setIcon(L.divIcon({html:pinHtml(o.status,'manual'),
                iconSize:[18,18], iconAnchor:[9,9], className:'onu-pin'}));
            } else {
              alert('Save failed: '+(dd.message||'unknown'));
              ev.target.setLatLng([o.lat,o.lng]);
            }
          });
          m.addTo(onuLayer);
          _onuMarkers[o.id] = m;
        });
        console.log('[onu-pins] loaded', d.count);
        const u = new URLSearchParams(location.search);
        const f = u.get('focus_onu');
        if(f && _onuMarkers[f]){
          nmMap.flyTo(_onuMarkers[f].getLatLng(), 18, {duration:0.8});
          setTimeout(()=>_onuMarkers[f].openPopup(), 1000);
        }
      } catch(e){ console.error('onu pins fetch', e); }
    }
    setTimeout(loadOnuPins, 1500);
    window.nmReloadOnuPins = loadOnuPins;
    setInterval(loadOnuPins, 60000);
  }
  init();
})();
</script>


<script>
/* __S55F_NETMAP_CTRLS_SHEET__ — close button + outside-click dismiss */
(function(){
  function ensureClose(){
    var pnl = document.querySelector('.nm-ctrls');
    if (!pnl) return;
    if (pnl.querySelector('.nm-ctrls-close')) return;
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'nm-ctrls-close';
    btn.setAttribute('aria-label', 'Close map controls');
    btn.setAttribute('data-testid', 'nm-ctrls-close');
    btn.innerHTML = '×';
    btn.addEventListener('click', function(ev){
      ev.stopPropagation();
      pnl.classList.remove('is-open');
    });
    pnl.appendChild(btn);
  }
  document.addEventListener('DOMContentLoaded', ensureClose);
  setTimeout(ensureClose, 800);
  // Outside-click close (mobile)
  document.addEventListener('click', function(ev){
    if (window.innerWidth > 991) return;
    var pnl = document.querySelector('.nm-ctrls.is-open');
    if (!pnl) return;
    if (pnl.contains(ev.target)) return;
    var burger = document.getElementById('nmCtrlsBurger');
    if (burger && burger.contains(ev.target)) return;
    pnl.classList.remove('is-open');
  });
  // ESC closes
  document.addEventListener('keydown', function(ev){
    if (ev.key === 'Escape') {
      var pnl = document.querySelector('.nm-ctrls.is-open');
      if (pnl) pnl.classList.remove('is-open');
    }
  });
})();
</script>

