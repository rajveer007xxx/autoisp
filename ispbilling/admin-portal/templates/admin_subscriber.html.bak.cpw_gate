}
function copyInstall(checked){
    if (!checked) return;
    var f = document.getElementById('addressForm');
    if (!f) return;
    f.billing_address.value = f.address.value || '';
    f.billing_city.value    = f.city.value || '';
    f.billing_state.value   = f.state.value || '';
    f.billing_pincode.value = f.pincode.value || '';
}
function saveAddressModal(){
    var form = document.getElementById('addressForm');
    if (!form) { alert('Address form not found'); return; }
    var obj = {};
    Array.from(form.elements).forEach(function(el){ if (el.name) obj[el.name] = el.value; });
    fetch('/api/subscribers/' + CUST_ID + '/details-save', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify(obj)
    }).then(function(r){return r.json();}).then(function(d){
        if (d.success) { alert('\u2713 Saved'); location.reload(); }
        else { alert('\u2717 ' + (d.message || 'error')); }
    }).catch(function(e){ alert('Network error: ' + e); });
}

// --- Change Package Modal --------------------------------------------------
function openChangePackage(){
    var sel = document.getElementById('cpkg_plan');
    var msg = document.getElementById('cpkg_msg');
    sel.innerHTML = '<option>Loading plans...</option>';
    msg.innerText = '';
    fetch('/api/plans/list')
      .then(function(r){return r.json();})
      .then(function(d){
        var plans = (d && d.plans) ? d.plans : (Array.isArray(d) ? d : []);
        if (!plans.length) { sel.innerHTML = '<option value="">No plans available</option>'; return; }
        sel.innerHTML = '';
        plans.forEach(function(p){
          var opt = document.createElement('option');
          opt.value = p.id;
          var speed = p.speed ? (' - ' + p.speed) : '';
          var amt   = (p.base_amount != null) ? (' \u20b9' + p.base_amount) : '';
          opt.textContent = (p.plan_name || p.name || ('Plan #' + p.id)) + speed + amt;
          sel.appendChild(opt);
        });
      })
      .catch(function(e){ sel.innerHTML = '<option value="">Failed to load plans</option>'; });
    $('#changePackageModal').modal('show');
}
function savChangePackage(){
    var sel = document.getElementById('cpkg_plan');
    var msg = document.getElementById('cpkg_msg');
    var plan_id = sel.value;
    if (!plan_id) { msg.innerText = 'Please select a plan.'; return; }
    msg.style.color = '#64748b';
    msg.innerText = 'Saving...';
    var _mode = document.querySelector('input[name="cpkg_inv_mode"]:checked');
    var _withInv = _mode ? (_mode.value === 'with_invoice') : false;
    fetch('/api/subscribers/' + CUST_ID + '/change-plan', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({plan_id: parseInt(plan_id, 10), with_invoice: _withInv})
    }).then(function(r){return r.json();}).then(function(d){
        if (d.success) {
            msg.style.color = '#16a34a';
            msg.innerText = '\u2713 ' + (d.message || 'Plan changed');
            setTimeout(function(){ $('#changePackageModal').modal('hide'); location.reload(); }, 900);
        } else {
            msg.style.color = '#dc2626';
            msg.innerText = '\u2717 ' + (d.message || 'error');
        }
    }).catch(function(e){
        msg.style.color = '#dc2626';
        msg.innerText = 'Network error: ' + e;
    });
}

// --- Renew In Advance Modal ------------------------------------------------
function openRenew(){
    var msg = document.getElementById('rnw_msg');
    msg.innerText = '';
    // default start_date = today
    var t = new Date();
    var iso = t.getFullYear() + '-' +
              ('0'+(t.getMonth()+1)).slice(-2) + '-' +
              ('0'+t.getDate()).slice(-2);
    document.getElementById('rnw_start_date').value = iso;
    // __S43K_RNW_MAXTODAY__ : Renew-In-Advance start date can never be in the
    // future — operator is recording a real-world collection, not scheduling.
    document.getElementById('rnw_start_date').max = iso;
    document.getElementById('rnw_start').value  = 'today';
    document.getElementById('rnw_months').value = '1';
    document.getElementById('rnw_invoice').checked = false;
    $('#renewModal').modal('show');
}
function saveRenew(){
    var msg = document.getElementById('rnw_msg');
    var start_from  = document.getElementById('rnw_start').value;
    var start_date  = document.getElementById('rnw_start_date').value;
    var months      = parseInt(document.getElementById('rnw_months').value, 10);
    var with_invoice = document.getElementById('rnw_invoice').checked;
    if (!months) { msg.innerText = 'Please select a period.'; return; }
    if (start_from === 'date' && !start_date) { msg.innerText = 'Start date is required.'; return; }
    // __S43K_RNW_MAXTODAY__: client-side guard — reject future dates.
    if (start_from === 'date') {
        var _t = new Date(); _t.setHours(0,0,0,0);
        var _sd = new Date(start_date + 'T00:00:00');
        if (_sd > _t) { msg.innerText = 'Start date cannot be in the future.'; return; }
    }
    var payload = {start_from: start_from, period_months: months, with_invoice: with_invoice};
    if (start_from === 'date') payload.start_date = start_date;
    msg.style.color = '#64748b';
    msg.innerText = 'Renewing...';
    fetch('/api/customers/' + encodeURIComponent(CUST_CODE) + '/renew', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify(payload)
    }).then(function(r){return r.json();}).then(function(d){
        if (d.success) {
            msg.style.color = '#16a34a';
            msg.innerText = '\u2713 ' + (d.message || 'Renewed');
            setTimeout(function(){ $('#renewModal').modal('hide'); location.reload(); }, 900);
        } else {
            msg.style.color = '#dc2626';
            msg.innerText = '\u2717 ' + (d.message || 'error');
        }
    }).catch(function(e){
        msg.style.color = '#dc2626';
        msg.innerText = 'Network error: ' + e;
    });
}

// --- Change Expiry Date Modal ----------------------------------------------
function openChangeExpiry(){
    document.getElementById('cexp_msg').innerText = '';
    document.getElementById('cexp_date').value = '';
    $('#changeExpiryModal').modal('show');
}
function saveChangeExpiry(){
    var msg = document.getElementById('cexp_msg');
    var raw = (document.getElementById('cexp_date').value || '').trim();
    if (!raw) { msg.innerText = 'Please enter a date (DD-MM-YYYY).'; return; }
    var m = raw.match(/^(\d{2})-(\d{2})-(\d{4})$/);
    if (!m) { msg.innerText = 'Format must be DD-MM-YYYY (e.g. 31-12-2026).'; return; }
    var di=parseInt(m[1],10), mi=parseInt(m[2],10), yi=parseInt(m[3],10);
    if (di<1||di>31||mi<1||mi>12||yi<2020||yi>2100) { msg.innerText='Invalid date.'; return; }
    var d = m[3] + '-' + m[2] + '-' + m[1];  // ISO
    msg.style.color = '#64748b';
    msg.innerText = 'Saving...';
    fetch('/api/customers/' + encodeURIComponent(CUST_CODE) + '/end-date', {
        method: 'PATCH', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({end_date: d})
    }).then(function(r){return r.json();}).then(function(d2){
        if (d2.success) {
            msg.style.color = '#16a34a';
            msg.innerText = '\u2713 ' + (d2.message || 'Updated');
            setTimeout(function(){ $('#changeExpiryModal').modal('hide'); location.reload(); }, 900);
        } else {
            msg.style.color = '#dc2626';
            msg.innerText = '\u2717 ' + (d2.message || 'error');
        }
    }).catch(function(e){
        msg.style.color = '#dc2626';
        msg.innerText = 'Network error: ' + e;
    });
}

// --- Override Speed Modal --------------------------------------------------
function openOverrideSpeed(){
    document.getElementById('ovUpload').value = '';
    document.getElementById('ovDownload').value = '';
    $('#overrideSpeedModal').modal('show');
}
function saveOverrideSpeed(remove){
    var up = document.getElementById('ovUpload').value;
    var dn = document.getElementById('ovDownload').value;
    var payload;
    if (remove) {
        if (!confirm('Remove speed override and fall back to plan default?')) return;
        payload = {remove: true};
    } else {
        if (!up || !dn) { alert('Enter both Upload and Download Mbps'); return; }
        payload = {upload_mbps: parseInt(up,10), download_mbps: parseInt(dn,10)};
    }
    fetch('/api/subscribers/' + CUST_ID + '/override-speed', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify(payload)
    }).then(function(r){return r.json();}).then(function(d){
        alert((d.success ? '\u2713 ' : '\u2717 ') + (d.message || 'done'));
        if (d.success) {
            $('#overrideSpeedModal').modal('hide');
            setTimeout(function(){ location.reload(); }, 500);
        }
    }).catch(function(e){ alert('Network error: ' + e); });
}

// --- Direct Message / Ticket submit ----------------------------------------
function submitAlert(){
    var kind     = document.getElementById('alertKind').value;
    var subject  = document.getElementById('alertSubject').value.trim();
    var body     = document.getElementById('alertBody').value.trim();
    var priority = document.getElementById('alertPriority').value;
    if (!subject || !body) { alert('Subject and message are required'); return; }
    fetch('/api/subscribers/' + CUST_ID + '/create-message', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({kind: kind, subject: subject, body: body, priority: priority})
    }).then(function(r){return r.json();}).then(function(d){
        alert((d.success ? '\u2713 ' : '\u2717 ') + (d.message || 'done'));
        if (d.success) {
            $('#alertModal').modal('hide');
            document.getElementById('alertSubject').value = '';
            document.getElementById('alertBody').value = '';
        }
    }).catch(function(e){ alert('Network error: ' + e); });
}

// --- Clear Access Logs -----------------------------------------------------
function clearAccessLogs(){
    if (!confirm('Delete all stored RADIUS access-request logs for this subscriber?')) return;
    fetch('/api/subscribers/' + CUST_ID + '/clear-access-logs', {method:'POST'})
      .then(function(r){return r.json();})
      .then(function(d){
          alert((d.success ? '\u2713 ' : '\u2717 ') + (d.message || 'done'));
          if (d.success && typeof openAccessLogs === 'function') openAccessLogs();
      }).catch(function(e){ alert('Network error: ' + e); });
}
// === /s26.1 ===

</script>

<!-- ===== Address & Contact Modal (Session 25.12) ===== -->
<div class="modal fade" id="addressModal" tabindex="-1" role="dialog" aria-hidden="true" data-backdrop="static">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header" style="background:#f8fafc;">
        <h5 class="modal-title"><i class="fa fa-map-marker"></i> Edit Address &amp; Contact</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <form id="addressForm">
      <div class="modal-body" style="padding:20px;">
        <h6 style="color:#2563eb;border-bottom:1px solid #e5e7eb;padding-bottom:6px;margin-bottom:12px;">
          <i class="fa fa-home"></i> Installation Address</h6>
        <div class="form-row">
          <div class="form-group col-md-12"><label>Installation Address</label>
            <input class="form-control" name="address" value="{{ cust.address or '' }}"></div>
        </div>
        <div class="form-row">
          <div class="form-group col-md-4"><label>City</label>
            <input class="form-control" name="city" value="{{ cust.city or '' }}"></div>
          <div class="form-group col-md-4"><label>State</label>
            <input class="form-control" name="state" value="{{ cust.state or '' }}"></div>
          <div class="form-group col-md-4"><label>Pincode</label>
            <input class="form-control" name="pincode" value="{{ cust.pincode or '' }}"></div>
        </div>

        <h6 style="color:#2563eb;border-bottom:1px solid #e5e7eb;padding-bottom:6px;margin:18px 0 12px;">
          <i class="fa fa-file-invoice"></i> Billing Address
          <label style="float:right;font-weight:400;font-size:12px;cursor:pointer;">
            <input type="checkbox" id="sameAsInstall" onchange="copyInstall(this.checked)">
            Same as installation</label></h6>
        <div class="form-row">
          <div class="form-group col-md-12"><label>Billing Address</label>
            <input class="form-control" name="billing_address" value="{{ cust.billing_address or '' }}"></div>
        </div>
        <div class="form-row">
          <div class="form-group col-md-4"><label>City</label>
            <input class="form-control" name="billing_city" value="{{ cust.billing_city or '' }}"></div>
          <div class="form-group col-md-4"><label>State</label>
            <input class="form-control" name="billing_state" value="{{ cust.billing_state or '' }}"></div>
          <div class="form-group col-md-4"><label>Pincode</label>
            <input class="form-control" name="billing_pincode" value="{{ cust.billing_pincode or '' }}"></div>
        </div>

        <h6 style="color:#2563eb;border-bottom:1px solid #e5e7eb;padding-bottom:6px;margin:18px 0 12px;">
          <i class="fa fa-phone"></i> Contact &amp; ID</h6>
        <div class="form-row">
          <div class="form-group col-md-4"><label>Mobile1</label>
            <input class="form-control" name="customer_phone" value="{{ cust.customer_phone or '' }}"></div>
          <div class="form-group col-md-4"><label>Phone1</label>
            <input class="form-control" name="alt_mobile" value="{{ cust.alt_mobile or '' }}"></div>
          <div class="form-group col-md-4"><label>Email</label>
            <input class="form-control" type="email" name="customer_email" value="{{ cust.customer_email or '' }}"{% if user_type in ('sub_lco','employee') %} disabled title='Admin only — contact-of-record locked' {% endif %} {# _RESTRICTED_FIELD_HINT_ #}></div>
        </div>
        <div class="form-row">
          <div class="form-group col-md-4"><label>ID Proof</label>
            <select class="form-control" name="id_proof">
              {% for o in ['Aadhar card','PAN','Driving License','Voter ID','Passport'] %}
              <option value="{{ o }}" {% if cust.id_proof == o %}selected{% endif %}>{{ o }}</option>{% endfor %}
            </select></div>
          <div class="form-group col-md-4"><label>ID Proof Number</label>
            <input class="form-control" name="id_proof_no" value="{{ cust.id_proof_no or '' }}"></div>
          <div class="form-group col-md-4"><label>GST Number</label>
            <input class="form-control" name="customer_gst_no" value="{{ cust.customer_gst_no or '' }}"></div>
        </div>
        <div class="form-row">
          <div class="form-group col-md-12"><label>Skip Invoice Generation</label>
            <select class="form-control" name="gst_invoice_needed">
              <option value="Yes" {% if cust.gst_invoice_needed != 'No' %}selected{% endif %}>No (generate invoice)</option>
              <option value="No"  {% if cust.gst_invoice_needed == 'No' %}selected{% endif %}>Yes (skip invoice)</option>
            </select></div>
        </div>
      </div>
      <div class="modal-footer" style="background:#f8fafc;">
        <button type="button" class="btn" data-dismiss="modal" style="background:#e5e7eb;">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="saveAddressModal()"
                data-testid="sub-address-modal-save" style="background:#059669;color:#fff;border:none;">
          <i class="fa fa-check"></i> Save Address &amp; Contact</button>
      </div>
      </form>
    </div>
  </div>
</div>

<!-- ===== Override Speed Modal ===== -->
<div class="modal fade" id="overrideSpeedModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header" style="background:#f8fafc;">
        <h5 class="modal-title"><i class="fa fa-tachometer"></i> Override Speed</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body" style="padding:20px;">
        <div style="margin-bottom:12px;font-size:12px;color:#64748b;">
          Set a custom rate-limit for this subscriber. Leave blank to remove override
          and fall back to the plan's default speed.
          Current: <strong>{{ cust.custom_rate_limit or 'plan default' }}</strong>
        </div>
        <div class="form-row">
          <div class="form-group col-md-6"><label>Upload (Mbps)</label>
            <input class="form-control" id="ovUpload" type="number" min="1" max="1000" placeholder="e.g. 50"></div>
          <div class="form-group col-md-6"><label>Download (Mbps)</label>
            <input class="form-control" id="ovDownload" type="number" min="1" max="1000" placeholder="e.g. 100"></div>
        </div>
      </div>
      <div class="modal-footer" style="background:#f8fafc;">
        <button type="button" class="btn" onclick="saveOverrideSpeed(true)" style="background:#b91c1c;color:#fff;">Remove Override</button>
        <button type="button" class="btn btn-primary" onclick="saveOverrideSpeed(false)"
                data-testid="sub-override-save" style="background:#059669;color:#fff;border:none;">Apply Override</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== Direct Message / Ticket Modal ===== -->
<div class="modal fade" id="alertModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header" style="background:#f8fafc;">
        <h5 class="modal-title" id="alertModalTitle">Direct Message</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body" style="padding:20px;">
        <input type="hidden" id="alertKind" value="alert">
        <div class="form-group"><label>Subject</label>
          <input class="form-control" id="alertSubject" placeholder="Short subject line"
                 data-testid="alert-modal-subject"></div>
        <div class="form-group"><label>Priority</label>
          <select class="form-control" id="alertPriority">
            <option value="Low">Low</option>
            <option value="Medium" selected>Medium</option>
            <option value="High">High</option>
          </select></div>
        <div class="form-group"><label>Message</label>
          <textarea class="form-control" id="alertBody" rows="4"
                    placeholder="Describe the issue or write a message"
                    data-testid="alert-modal-body"></textarea></div>
      </div>
      <div class="modal-footer" style="background:#f8fafc;">
        <button type="button" class="btn" data-dismiss="modal" style="background:#e5e7eb;">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="submitAlert()"
                data-testid="alert-modal-submit" style="background:#059669;color:#fff;border:none;">Submit</button>
      </div>
    </div>
  </div>
</div>


<!-- ===== Change Package Modal (s25.15) ===== -->
<div class="modal fade" id="changePackageModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header" style="background:#f8fafc;">
        <h5 class="modal-title"><i class="fa fa-cubes"></i> Change Package</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body" style="padding:20px;">
        <div class="form-group">
          <label>Current Plan</label>
          <input class="form-control" readonly value="{{ plan.plan_name if plan else '—' }} ({{ plan.speed if plan else '' }})"
                 style="background:#f1f5f9;">
        </div>
        <div class="form-group">
          <label>New Plan *</label>
          <select class="form-control" id="cpkg_plan" data-testid="cpkg-plan"></select>
        </div>
        <!-- s26.17b: subscriber-action-rewire — billing mode radios -->
        <div class="form-group" style="margin-top:10px;">
          <label style="font-size:12px;color:#334155;font-weight:600;">Billing behaviour</label>
          <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px 12px;">
            <div style="margin-bottom:8px;"><label style="cursor:pointer;font-weight:500;margin:0;">
              <input type="radio" name="cpkg_inv_mode" value="with_invoice" data-testid="cpkg-with-invoice"
                     {% if (path_prefix == '/sub-lco') or (request.url.path.startswith('/employee/')) %}checked disabled{% endif %}>
              <strong>Change Plan with Invoice</strong>
              <span style="color:#64748b;font-size:11px;display:block;margin-left:20px;">
                Generates an invoice for the new plan amount + carries previous balance,
                updates the balance due, and emails the invoice to the customer.
              </span>
            </label></div>
            <div><label style="cursor:pointer;font-weight:500;margin:0;">
              {# _S39R5FIX12_ — sub-LCO and employees cannot use "Without Invoice" #}
              {% if (path_prefix != '/sub-lco') and (not request.url.path.startswith('/employee/')) %}
              <input type="radio" name="cpkg_inv_mode" value="without_invoice" checked data-testid="cpkg-without-invoice">
              {% else %}
              <input type="radio" name="cpkg_inv_mode" value="without_invoice" data-testid="cpkg-without-invoice" disabled style="display:none">
              {% endif %}
              <strong>Change Plan without Invoice</strong>
              <span style="color:#64748b;font-size:11px;display:block;margin-left:20px;">
                Updates plan + Mikrotik rate-limit only. No invoice raised, no email sent.
              </span>
            </label></div>
          </div>
        </div>
        <div id="cpkg_msg" style="color:#b91c1c;font-size:13px;margin-top:6px;"></div>
      </div>
      <div class="modal-footer" style="background:#f8fafc;">
        <button class="btn" data-dismiss="modal" style="background:#e5e7eb;">Cancel</button>
        <button class="btn btn-primary" onclick="savChangePackage()" data-testid="cpkg-save"
                style="background:#059669;color:#fff;border:none;"><i class="fa fa-check"></i> Save</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== Renew In Advance Modal (s25.15) ===== -->
<div class="modal fade" id="renewModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header" style="background:#f8fafc;">
        <h5 class="modal-title"><i class="fa fa-refresh"></i> Renew In Advance</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body" style="padding:20px;">
        <div class="form-row">
          <div class="form-group col-md-6">
            <label>Start From *</label>
            <select class="form-control" id="rnw_start" data-testid="rnw-start-from">
              <option value="today">Today</option>
              <option value="date">Specific date</option>
            </select>
          </div>
          <div class="form-group col-md-6">
            <label>Start Date</label>
            <input type="date" class="form-control" id="rnw_start_date" data-testid="rnw-start-date">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group col-md-6">
            <label>Period (Months) *</label>
            <select class="form-control" id="rnw_months" data-testid="rnw-months">
              <option value="1">1 month</option>
              <option value="2">2 months</option>
              <option value="3">3 months</option>
              <option value="6">6 months</option>
              <option value="12">12 months</option>
            </select>
          </div>
          <div class="form-group col-md-6" style="padding-top:26px;">
            <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-weight:400;">
              {# _S39R5FIX12_ — sub-LCO/employee: invoice always generated, locked on #}
              <input type="checkbox" id="rnw_invoice" data-testid="rnw-with-invoice"
                     {% if (path_prefix == '/sub-lco') or (request.url.path.startswith('/employee/')) %}checked disabled onclick="return false;"{% endif %}>
              Generate invoice &amp; email it
            </label>
          </div>
        </div>
        <div id="rnw_msg" style="color:#b91c1c;font-size:13px;margin-top:6px;"></div>
      </div>
      <div class="modal-footer" style="background:#f8fafc;">
        <button class="btn" data-dismiss="modal" style="background:#e5e7eb;">Cancel</button>
        <button class="btn btn-primary" onclick="saveRenew()" data-testid="rnw-save"
                style="background:#059669;color:#fff;border:none;"><i class="fa fa-check"></i> Renew</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== Change Expiry Modal (s25.15) ===== -->
<div class="modal fade" id="changeExpiryModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content" style="border-radius:12px;">
      <div class="modal-header" style="background:#f8fafc;">
        <h5 class="modal-title"><i class="fa fa-calendar"></i> Change Expiry Date</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body" style="padding:20px;">
        <div class="form-group">
          <label>Current Expiry</label>
          <input class="form-control" readonly value="{{ cust.end_date or 'Not set' }}"
                 style="background:#f1f5f9;">
        </div>
        <div class="form-group">
          <label>New Expiry Date * <small class="text-muted" style="font-weight:normal;">(DD-MM-YYYY)</small></label>
          <input type="text" class="form-control" id="cexp_date" placeholder="DD-MM-YYYY" maxlength="10" pattern="\d{2}-\d{2}-\d{4}" data-testid="cexp-date">
        </div>
        <div class="form-group" style="font-size:12px;color:#64748b;">
          Only updates the expiry date stored on the subscriber record. Does NOT
          create a renewal invoice and does NOT reset any balance. For full renewal
          use "Renew In Advance" instead.
        </div>
        <div id="cexp_msg" style="color:#b91c1c;font-size:13px;margin-top:6px;"></div>
      </div>
      <div class="modal-footer" style="background:#f8fafc;">
        <button class="btn" data-dismiss="modal" style="background:#e5e7eb;">Cancel</button>
        <button class="btn btn-primary" onclick="saveChangeExpiry()" data-testid="cexp-save"
                style="background:#059669;color:#fff;border:none;"><i class="fa fa-check"></i> Save</button>
      </div>
    </div>
  </div>
</div>

<script>
// __S38O_CONN_TAB__ -- unified pool dropdown + Capture MAC + send_* toggles
(function(){
  function qs(id){ return document.getElementById(id); }
  function currentFixVal(){
    var sel = document.querySelector('select[name="fix_ip_address"]');
    return sel ? sel.value : 'No';
  }
  function setFieldEnabled(el, on){
    el.disabled = !on;
    el.style.opacity = on ? '1' : '0.6';
  }
  var POOL_INDEX = {};  // key => {source, pool_name}
  function loadPools(keepSelection){
    var pool = qs('s36i_pool');
    var keep = keepSelection || pool.value || (window.CUST_POOL_PREF || '');
    fetch('/api/fix-ip/pools').then(r=>r.json()).then(function(j){
      pool.innerHTML = '';
      POOL_INDEX = {};
      if (!j.ok || !j.rows.length) {
        pool.innerHTML = '<option value="">(no pools — go to Sidebar → IP Pools / Public IPs)</option>';
        return;
      }
      j.rows.forEach(function(p){
        var key = p.source + '::' + p.pool_name;
        POOL_INDEX[key] = p;
        var o = document.createElement('option');
        o.value = key;
        var tag = p.source === 'public' ? '[Public]' : (p.source === 'pppoe' ? '[PPPoE]' : '[Hotspot]');
        o.textContent = tag + ' ' + p.pool_name + '  (' + p.free + '/' + p.total + ' free)';
        pool.appendChild(o);
      });
      if (keep && POOL_INDEX[keep]) pool.value = keep;
      if (currentFixVal() === 'Yes') window.s36iLoadIps();
    });
  }
  window.s36iLoadIps = function(){
    var key = qs('s36i_pool').value;
    var ipSel = qs('s36i_ip');
    if (!key || !POOL_INDEX[key]) { ipSel.innerHTML = '<option value="">— choose pool first —</option>'; return; }
    var meta = POOL_INDEX[key];
    var curIp = window.CUST_STATIC_IP || '';
    var url = '/api/fix-ip/available?pool=' + encodeURIComponent(meta.pool_name)
            + '&source=' + encodeURIComponent(meta.source)
            + (curIp ? '&include_current=' + encodeURIComponent(curIp) : '');
    fetch(url).then(r=>r.json()).then(function(j){
      ipSel.innerHTML = '';
      if (!j.ok || !j.rows.length){
        ipSel.innerHTML = '<option value="">(no free IPs in this pool)</option>';
        return;
      }
      j.rows.forEach(function(r){
        var o = document.createElement('option');
        o.value = r.ip;
        o.textContent = r.ip + (r.label ? '  · ' + r.label : '') +
                        (r.ip === curIp ? '  (current)' : '');
        ipSel.appendChild(o);
      });
      if (curIp) ipSel.value = curIp;
    });
  };
  function syncEnable(){
    var on = currentFixVal() === 'Yes';
    setFieldEnabled(qs('s36i_pool'), on);
    setFieldEnabled(qs('s36i_ip'), on);
    if (on) { loadPools(); }
  }
  window._s37_syncFixIp = syncEnable;
  function _s37_init(){
    var sel = document.querySelector('select[name="fix_ip_address"]');
    if (sel && !sel.__s37Hooked) {
      sel.addEventListener('change', syncEnable);
      sel.__s37Hooked = true;
    }
    syncEnable();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', _s37_init);
  } else {
    _s37_init();
  }

  // Capture MAC -------------------------------------------------------
  window.s38oCaptureMac = function(){
    var msg = qs('s38o_capture_msg');
    var fld = qs('s38o_mac_display');
    var btn = qs('s38o_capture_btn');
    if (!window.CUST_PK) { alert('No customer id'); return; }
    btn.disabled = true;
    msg.textContent = 'Capturing…';
    msg.style.color = '#64748b';
    fetch('/api/customers/' + window.CUST_PK + '/capture-mac', {method:'POST'})
      .then(r => r.json()).then(function(d){
        btn.disabled = false;
        if (d.success && d.mac) {
          fld.value = (d.mac || '').toUpperCase();
          msg.textContent = '✓ Captured from ' + (d.source || 'session');
          msg.style.color = '#16a34a';
        } else {
          msg.textContent = '✗ ' + (d.message || 'no active session yet — ask customer to reconnect');
          msg.style.color = '#dc2626';
        }
      }).catch(function(){
        btn.disabled = false;
        msg.textContent = '✗ network error'; msg.style.color = '#dc2626';
      });
  };

  // Save ---------------------------------------------------------------
  window.saveConnection = function(){
    var payload = window._formToObj('connForm');
    var poolKey = payload._s36i_pool; var ip = payload._s36i_ip;
    delete payload._s36i_pool; delete payload._s36i_ip;

    // Persist connection-tab fields (fix_ip toggle, bind_mac, mac_address,
    // send_sms/whatsapp/email). Backend translates send_* to do_not_send_*.
    fetch('/api/subscribers/' + window.CUST_ID + '/connection-save', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    }).then(r=>r.json()).then(function(d){
      if (!d.success) { alert('✗ ' + (d.message||'error')); return; }
      if (payload.fix_ip_address === 'Yes' && ip) {
        var meta = POOL_INDEX[poolKey] || {source:'public', pool_name:''};
        fetch('/api/customers/' + window.CUST_PK + '/fix-ip', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({pool_name: meta.pool_name, ip_address: ip,
                                source: meta.source})
        }).then(r=>r.json()).then(function(d2){
          alert((d2.success ? '✓ ' : '✗ ') + d2.message);
          if (d2.success) location.reload();
        });
      } else if (payload.fix_ip_address === 'No' && window.CUST_STATIC_IP) {
        fetch('/api/customers/' + window.CUST_PK + '/fix-ip/clear', {method: 'POST'})
          .then(r=>r.json()).then(function(d2){
            alert((d2.success ? '✓ ' : '✗ ') + d2.message);
            location.reload();
          });
      } else {
        alert('✓ Connection settings saved');
        location.reload();
      }
    });
  };
})();
</script>


<!-- _S40f_ — Block Websites modal -->
<div class="modal fade" id="blockWebsitesModal" data-testid="block-websites-modal"
     tabindex="-1" role="dialog">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header" style="background:#fef2f2;border-bottom:1px solid #fecaca;">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <h4 class="modal-title" style="color:#b91c1c;">
          <i class="fa fa-ban"></i> Block Websites for
          <span id="bw_cust_name"></span>
        </h4>
      </div>
      <div class="modal-body">
        <div style="background:#fff7ed;border:1px solid #fed7aa;color:#7c2d12;
                    padding:10px 12px;border-radius:6px;font-size:13px;
                    margin-bottom:14px;">
          Domains entered below will be blocked <strong>only for this
          subscriber</strong>. Push happens immediately on the chosen
          MikroTik device — no global rule changes. Add one domain per
          line (e.g. <code>facebook.com</code>, <code>youtube.com</code>).
        </div>

        <div class="row">
          <div class="col-sm-6">
            <label>MikroTik / NAS device</label>
            <select id="bw_nas_id" class="form-control" data-testid="bw-nas-select">
              <option value="">Loading…</option>
            </select>
          </div>
          <div class="col-sm-6">
            <label>Block name <small>(optional)</small></label>
            <input type="text" id="bw_block_name" class="form-control"
                   placeholder="e.g. Social media block — Ali Cement"
                   data-testid="bw-block-name" />
          </div>
        </div>

        <div style="margin-top:14px;">
          <label>Domains to block (one per line)</label>
          <textarea id="bw_domains" class="form-control" rows="5"
                    data-testid="bw-domains"
                    placeholder="facebook.com&#10;youtube.com&#10;tiktok.com"></textarea>
        </div>

        <hr/>
        <h5 style="margin:8px 0 6px;font-size:14px;font-weight:600;color:#475569;">
          Existing blocks for this subscriber
        </h5>
        <div id="bw_existing_list" data-testid="bw-existing-list"
             style="font-size:12.5px;color:#64748b;font-family:monospace;
                    line-height:1.7;max-height:140px;overflow-y:auto;
                    background:#f8fafc;border:1px solid #e2e8f0;
                    border-radius:6px;padding:8px 12px;">
          Loading…
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" onclick="submitBlockWebsites()"
                id="bw_save_btn" data-testid="bw-save-btn">
          <i class="fa fa-ban"></i> Save & Push to MikroTik
        </button>
      </div>
    </div>
  </div>
</div>

<script>
async function openBlockWebsites() {
  // Reset state
  document.getElementById("bw_block_name").value = "";
  document.getElementById("bw_domains").value = "";
  const list = document.getElementById("bw_existing_list");
  list.innerText = "Loading…";
  document.getElementById("bw_cust_name").innerText = "{{ (cust.customer_name or cust.username or '') }}";
  // Open modal (Bootstrap 3 / 4 compatible)
  if (typeof $ !== "undefined" && $.fn && $.fn.modal) {
    $("#blockWebsitesModal").modal("show");
  } else {
    document.getElementById("blockWebsitesModal").classList.add("show","in");
    document.getElementById("blockWebsitesModal").style.display = "block";
  }
  // Fetch NAS list + existing blocks
  try {
    const r = await fetch("/api/website-blocks/for-customer/{{ cust.id }}");
    const j = await r.json();
    if (!j.ok) throw new Error(j.error || "load failed");
    const sel = document.getElementById("bw_nas_id");
    if (!j.nas_devices.length) {
      sel.innerHTML = '<option value="">No active MikroTik configured</option>';
    } else {
      sel.innerHTML = j.nas_devices.map(n =>
        `<option value="${n.id}" ${n.id===j.default_nas_id ? "selected" : ""}>${n.name} (${n.ip_address})</option>`
      ).join("");
    }
    if (!j.blocks.length) {
      list.innerHTML = '<span style="color:#94a3b8;">No active blocks for this subscriber yet.</span>';
    } else {
      list.innerHTML = j.blocks.map(b =>
        `<div data-testid="bw-existing-row-${b.id}" style="margin-bottom:6px;">
           <strong style="color:#0f172a;">${b.name || ('Block #'+b.id)}</strong>
           — ${b.domains.length} domain(s) on <em>${b.nas_name || 'NAS#'+b.nas_id}</em>
           <span style="color:#94a3b8;">· ${b.status}</span>
           <div style="color:#64748b;font-size:11px;">${b.domains.join(", ")}</div>
         </div>`).join("");
    }
  } catch (e) {
    document.getElementById("bw_existing_list").innerText = "Error: " + (e.message || e);
  }
}

async function submitBlockWebsites() {
  const nas_id = parseInt(document.getElementById("bw_nas_id").value, 10);
  const name = document.getElementById("bw_block_name").value.trim();
  const raw = document.getElementById("bw_domains").value || "";
  const domains = raw.split(/[\n,]+/).map(s => s.trim()).filter(Boolean);
  if (!nas_id) { alert("Please select a MikroTik device."); return; }
  if (!domains.length) { alert("Enter at least one domain."); return; }
  const btn = document.getElementById("bw_save_btn");
  btn.disabled = true; btn.innerText = "Saving…";
  try {
    const r = await fetch("/api/website-blocks/save", {
      method: "POST",
      headers: {"Content-Type": "application/json"},
      body: JSON.stringify({
        nas_id: nas_id,
        domains: domains,
        customer_pks: [{{ cust.id }}],
        name: name || null,
      }),
    });
    const j = await r.json();
    if (!r.ok || !j.ok) throw new Error(j.error || j.detail || "save failed");
    alert("Block saved. Pushed to MikroTik: " +
          (j.pushed_summary || (domains.length + " domain(s) for this subscriber")));
    if (typeof $ !== "undefined" && $.fn && $.fn.modal) {
      $("#blockWebsitesModal").modal("hide");
    } else {
      document.getElementById("blockWebsitesModal").style.display = "none";
    }
  } catch (e) {
    alert("Failed: " + (e.message || e));
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fa fa-ban"></i> Save & Push to MikroTik';
  }
}
</script>


<style>
  /* s41d: Park Now button + universal hover-tooltip */
  /* s41e: red/orange Park Now button — visually distinct, danger-tone */
  .qa-btn.qa-park {
    background: linear-gradient(135deg,#dc2626,#ea580c) !important;
    color: #fff !important;
    border-color: #dc2626 !important;
    font-weight: 600;
    box-shadow: 0 2px 6px rgba(220,38,38,.25);
  }
  .qa-btn.qa-park:hover {
    background: linear-gradient(135deg,#b91c1c,#c2410c) !important;
    box-shadow: 0 3px 10px rgba(220,38,38,.35);
    transform: translateY(-1px);
  }
  .qa-btn.qa-park:active { transform: translateY(0); }
  /* s41f: Unpark button — green/blue gradient (positive action). */
  .qa-btn.qa-unpark {
    background: linear-gradient(135deg,#059669,#0284c7) !important;
    color: #fff !important;
    border-color: #059669 !important;
    font-weight: 600;
    box-shadow: 0 2px 6px rgba(5,150,105,.25);
  }
  .qa-btn.qa-unpark:hover {
    background: linear-gradient(135deg,#047857,#0369a1) !important;
    box-shadow: 0 3px 10px rgba(5,150,105,.35);
    transform: translateY(-1px);
  }
  .qa-btn.qa-unpark:active { transform: translateY(0); }
  .ais-tip {
    display: none;
    position: fixed; z-index: 99999; pointer-events: none;
    background: #0f172a; color: #e2e8f0; font-size: 12px;
    line-height: 1.45; padding: 10px 12px; border-radius: 8px;
    max-width: 320px; box-shadow: 0 8px 24px rgba(0,0,0,.35);
    opacity: 0; transition: opacity .15s ease;
    border: 1px solid rgba(255,255,255,.10);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }
  .ais-tip.show { opacity: 1; }
  .ais-tip:before {
    content:''; position:absolute; left:14px; bottom:-6px;
    border-left:6px solid transparent; border-right:6px solid transparent;
    border-top:6px solid #0f172a;
  }
</style>
<script>
// s41d: generic data-tip hover popup (admin/sub-lco/employee — anywhere
// the customer subscriber page is reused). Works on any element with
// . Uses a single shared <div>.
(function(){
  var tip = document.createElement('div');
  tip.className = 'ais-tip';
  tip.setAttribute('data-testid', 'ais-tooltip');
  document.body.appendChild(tip);
  function show(el){
    var t = el.getAttribute('data-tip');
    if(!t) return;
    tip.textContent = t;
    // s41e: tooltip must be visible (or at least laid out) BEFORE we read
    // offsetHeight/offsetWidth, otherwise the very-first hover lands the
    // tooltip at top=-10 (off-screen). Setting visibility:hidden +
    // display:block forces layout without flashing.
    tip.style.visibility = 'hidden';
    tip.style.display = 'block';
    tip.classList.add('show');
    // Force reflow
    void tip.offsetHeight;
    var r = el.getBoundingClientRect();
    var h = tip.offsetHeight, w = tip.offsetWidth;
    var top = r.top - h - 10;
    if (top < 6) top = r.bottom + 10;  // fallback below
    var left = r.left;
    var maxLeft = window.innerWidth - w - 12;
    if (left > maxLeft) left = maxLeft;
    if (left < 6) left = 6;
    tip.style.top = top + 'px';
    tip.style.left = left + 'px';
    tip.style.visibility = 'visible';
  }
  function hide(){ tip.classList.remove('show'); tip.style.display = 'none'; }
  document.addEventListener('mouseover', function(e){
    var el = e.target.closest && e.target.closest('[data-tip]');
    if (el) show(el, e);
  });
  document.addEventListener('mouseout', function(e){
    var el = e.target.closest && e.target.closest('[data-tip]');
    if (el) hide();
  });
  document.addEventListener('focusin', function(e){
    var el = e.target.closest && e.target.closest('[data-tip]');
    if (el) show(el, e);
  });
  document.addEventListener('focusout', hide);
  // keep tip aligned during scroll
  window.addEventListener('scroll', hide, true);
})();
// s41d: Park Now — backend handles status flip + session kick + RADIUS resync.
function parkNow(){
  var msg = 'PARK this subscriber NOW?\n\n' +
            '• Status will be flipped to Parked\n' +
            '• Active PPPoE session will be dropped\n' +
            '• RADIUS resync → parking-pool IP on next dial\n' +
            '• Their device will auto-redirect to the pay page\n\n' +
            'Continue?';
  if(!confirm(msg)) return;
  var btn = document.querySelector('[data-testid="sub-park-now-btn"]');
  if (btn){ btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Parking…'; }
  fetch('/api/subscribers/' + CUST_ID + '/park-now',
        {method:'POST', headers:{'Content-Type':'application/json'}, body:'{}'})
    .then(function(r){return r.json();})
    .then(function(d){
      if (d.success){
        alert('OK — Subscriber parked.\n' +
              'Kicked: ' + (d.kicked || 'no live session') + '\n' +
              'RADIUS users written: ' + (d.users_written || 0));
        setTimeout(function(){ location.reload(); }, 800);
      } else {
        alert('FAIL — ' + (d.message || 'unknown error'));
        if (btn){ btn.disabled = false; btn.innerHTML = '<i class="fa fa-bolt"></i> Park Now'; }
      }
    })
    .catch(function(e){
      alert('Request error: ' + e);
      if (btn){ btn.disabled = false; btn.innerHTML = '<i class="fa fa-bolt"></i> Park Now'; }
    });
}
// s41f: Unpark — reactivate a Parked subscriber.
function unparkNow(){
  var msg = 'UNPARK this subscriber (reactivate)?\n\n' +
            '• Status will be flipped to Active\n' +
            '• Parking-pool session will be dropped\n' +
            '• On next dial they get a real-pool IP\n\n' +
            'Continue?';
  if(!confirm(msg)) return;
  var btn = document.querySelector('[data-testid="sub-unpark-btn"]');
  if (btn){ btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Unparking\u2026'; }
  fetch('/api/subscribers/' + CUST_ID + '/unpark',
        {method:'POST', headers:{'Content-Type':'application/json'}, body:'{}'})
    .then(function(r){return r.json();})
    .then(function(d){
      if (d.success){
        alert('OK \u2014 Subscriber reactivated.\n' +
              'Kicked: ' + (d.kicked || 'no live session') + '\n' +
              'RADIUS users written: ' + (d.users_written || 0));
        setTimeout(function(){ location.reload(); }, 800);
      } else {
        alert('FAIL \u2014 ' + (d.message || 'unknown error'));
        if (btn){ btn.disabled = false; btn.innerHTML = '<i class="fa fa-undo"></i> Unpark (Reactivate)'; }
      }
    })
    .catch(function(e){
      alert('Request error: ' + e);
      if (btn){ btn.disabled = false; btn.innerHTML = '<i class="fa fa-undo"></i> Unpark (Reactivate)'; }
    });
}
</script>

{% endblock %}
