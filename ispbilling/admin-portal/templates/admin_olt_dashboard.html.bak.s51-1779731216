    var rxStr = (p.rx_power_avg !== null && p.rx_power_avg !== undefined)
                 ? p.rx_power_avg.toFixed(2)+' dBm' : '\u2014';
    var txStr = (p.tx_power !== null && p.tx_power !== undefined)
                 ? p.tx_power.toFixed(2)+' dBm' : '\u2014';
    var isAdmin = !!window.IS_ADMIN_OLT;
    var tgt = !p.admin_up;   // we offer the opposite
    var togglebtn = isAdmin
      ? '<button onclick="ponToggle('+oltId+','+p.port_index+','+tgt+')" style="padding:6px 12px;border-radius:6px;border:none;cursor:pointer;font-weight:600;font-size:11px;background:'+(tgt?'#10b981':'#dc2626')+';color:#fff">'+(tgt?'Enable':'Disable')+' Port</button>'
      : '<span style="font-size:11px;color:#94a3b8">Read-only role</span>';
    var html =
      '<div style="background:#1e293b;border-radius:10px;padding:14px;border:1px solid rgba(99,102,241,.15)">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">' +
          '<div><b style="color:#a5b4fc;font-size:14px">'+p.name+'</b>' +
            '<span style="'+upClass+';margin-left:8px;padding:3px 9px;border-radius:9999px;font-size:11px;font-weight:700">'+upTxt+'</span></div>' +
          togglebtn +
        '</div>' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:12px">' +
          '<div style="background:#0f172a;padding:8px 10px;border-radius:6px">RX POWER <span style="float:right;color:#34d399;font-weight:700">'+rxStr+'</span></div>' +
          '<div style="background:#0f172a;padding:8px 10px;border-radius:6px">TX POWER <input id="pon-tx-'+oltId+'-'+p.port_index+'" type="number" step="0.1" placeholder="'+txStr+'" style="width:60px;background:#1e293b;border:1px solid #334155;color:#fff;border-radius:4px;padding:2px 4px;font-size:11px;margin-left:4px"/><button onclick="ponSetTx('+oltId+', '+p.port_index+')" style="margin-left:4px;background:#7c3aed;color:#fff;border:none;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:10px;font-weight:600">SET</button></div>' +
          '<div style="background:#0f172a;padding:8px 10px;border-radius:6px">Voltage <span style="float:right;color:#67e8f9;font-weight:700">'+(p.voltage?p.voltage.toFixed(2)+' V':'\u2014')+'</span></div>' +
          '<div style="background:#0f172a;padding:8px 10px;border-radius:6px">Bias curr <span style="float:right;color:#67e8f9;font-weight:700">'+(p.bias_curr_ma?p.bias_curr_ma.toFixed(1)+' mA':'\u2014')+'</span></div>' +
          '<div style="background:#0f172a;padding:8px 10px;border-radius:6px;grid-column:1/-1">LOAD <span style="float:right;color:#7dd3fc;font-weight:700">'+p.online_onus+'/'+p.total_onus+' ONU</span></div>' +
        '</div>' +
      '</div>';
    list.insertAdjacentHTML('beforeend', html);
