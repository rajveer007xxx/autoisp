<script>
// _S40q_  Populate the TX Power column on the OLT fleet table.
//        Calls /api/admin/olt/olts/{id}/pon-status for each row and
//        renders the comma-joined TX list. Refreshes every 30 s.
(function _populateTxColumn() {
  async function tick() {
    const cells = document.querySelectorAll('[data-olt-tx]');
    for (const cell of cells) {
      const oltId = cell.getAttribute('data-olt-tx');
      try {
        const r = await fetch('/api/admin/olt/olts/' + oltId + '/pon-status',
                              { credentials:'include' });
        if (!r.ok) { cell.textContent = '—'; continue; }
        const j = await r.json();
        const ports = j.ports || [];
        if (!ports.length) { cell.textContent = 'no ports'; continue; }
        const parts = ports.map(p => {
          const tx = p.tx_power;
          const isUp = !!p.admin_up;
          const dim = isUp ? '' : ';opacity:.4;text-decoration:line-through';
          if (tx === null || tx === undefined)
            return '<span style="color:#94a3b8;font-size:10px' + dim + '">P'
                    + p.port_index + ':—</span>';
          return '<span style="color:#fbbf24;font-size:10px' + dim + '">P'
                  + p.port_index + ':+' + tx.toFixed(1) + '</span>';
        });
        cell.innerHTML = parts.join('&nbsp;|&nbsp;');
      } catch(_) { cell.textContent = '—'; }
    }
  }
  document.addEventListener('DOMContentLoaded', tick);
  if (document.readyState !== 'loading') tick();
  setInterval(tick, 30000);
})();
</script>


<script>
// _S40r_SSE_  Live OLT telemetry stream — replaces 30-s polling.
async function ponAutoDetect(oltId) {
  if (!confirm('Run SNMP walk on this OLT to detect actual PON port count?\n\n'
                + 'OLT must have host + snmp_community configured.')) return;
  const r = await fetch('/api/admin/olt/olts/' + oltId + '/auto-detect-pon',
                          { method:'POST', credentials:'include' });
  const j = await r.json();
  if (j.ok) {
    alert('Detected ' + j.detected + ' PON ports (was ' + j.previous + ').\n'
          + 'Reloading…');
    location.reload();
  } else alert('Failed: ' + (j.reason || 'unknown'));
}

// SSE stream — updates TX column + drives heatmap via custom events
(function _sseConsume() {
  if (!window.EventSource) return;     // very old browsers
  let es;
  function connect() {
    es = new EventSource('/api/admin/olt/stream');
    es.addEventListener('snapshot', e => {
      const data = JSON.parse(e.data);
      _applyTxToColumn(data.olts || []);
    });
    es.addEventListener('delta', e => {
      const data = JSON.parse(e.data);
      if (data.olts && data.olts.length) _applyTxToColumn(data.olts);
      // Fire a custom event so the network-map page (if open) can react
      window.dispatchEvent(new CustomEvent('olt-delta', { detail: data }));
    });
    es.onerror = () => {
      // Auto-reconnect with backoff
      try { es.close(); } catch(_) {}
      setTimeout(connect, 5000);
    };
  }
  function _applyTxToColumn(olts) {
    olts.forEach(o => {
      const cell = document.querySelector('[data-olt-tx="' + o.id + '"]');
      if (!cell) return;
      const tx = o.tx_per_port || {};
      const keys = Object.keys(tx).sort((a, b) => +a - +b);
      if (!keys.length) { cell.textContent = '—'; return; }
      cell.innerHTML = keys.map(k => {
        const v = tx[k];
        if (v === null || v === undefined)
          return '<span style="color:#94a3b8;font-size:10px">P' + k + ':—</span>';
        return '<span style="color:#fbbf24;font-size:10px">P' + k
                + ':+' + (+v).toFixed(1) + '</span>';
      }).join('&nbsp;|&nbsp;');
    });
  }
  // Wait for DOM to settle then connect
  if (document.readyState === 'loading')
    document.addEventListener('DOMContentLoaded', () => setTimeout(connect, 800));
  else
    setTimeout(connect, 800);
})();
</script>

