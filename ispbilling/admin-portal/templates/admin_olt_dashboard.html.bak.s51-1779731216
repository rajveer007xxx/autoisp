  let r;
  try { r = await fetch('/api/admin/olt/olts/' + oltId + '/pon-status', {credentials:'include'}); }
  catch(e){ document.getElementById('ponPortList').innerHTML = '<div style="color:#fca5a5">Network error.</div>'; return; }
  if (!r.ok) { document.getElementById('ponPortList').innerHTML = '<div style="color:#fca5a5">Failed: HTTP '+r.status+'</div>'; return; }
  const j = await r.json();
  const list = document.getElementById('ponPortList');
  list.innerHTML = '';
