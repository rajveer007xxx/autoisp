  j.ports.forEach(function(p) {
    var upClass = p.admin_up
      ? 'background:rgba(16,185,129,.2);color:#34d399;border:1px solid rgba(16,185,129,.4)'
      : 'background:rgba(220,38,38,.2);color:#fca5a5;border:1px solid rgba(220,38,38,.4)';
