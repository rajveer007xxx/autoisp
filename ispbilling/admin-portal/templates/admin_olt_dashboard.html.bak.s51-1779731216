}
async function ponToggle(oltId, portIdx, enable) {
  var msg = (enable ? 'Enable' : 'Disable') + ' PON port ' + portIdx + '?\n\n' +
             (enable ? 'ONUs on this port will reconnect.'
                     : 'All ONUs on this port will go offline immediately.');
  if (!confirm(msg)) return;
  var r = await fetch('/api/admin/olt/olts/' + oltId + '/pon/' + portIdx + '/toggle', {
    method:'POST', credentials:'include',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({enable: !!enable}) });
  var j = await r.json();
  if (j.ok) {
    alert((enable ? 'Enabled' : 'Disabled') + ' OK.\n\n' + (j.message || ''));
    var t = document.getElementById('ponModalTitle').textContent.replace(/^PON Port Status \u2014 /, '');
    oltPonStatus(oltId, t);
  } else alert('Failed: ' + JSON.stringify(j));
}
function closePon(){ document.getElementById('ponModal').style.display='none'; }
window.addEventListener('keydown', function(e){ if (e.key === 'Escape') closePon(); });
async function ponSetTx(oltId, portIdx) {
  var el = document.getElementById('pon-tx-' + oltId + '-' + portIdx);
  if (!el) return;
  var v = parseFloat(el.value);
  if (isNaN(v)) return alert('Enter a valid TX value (e.g. +5.0)');
  var r = await fetch('/api/admin/olt/olts/' + oltId + '/pon/' + portIdx + '/set-tx', {
    method:'POST', credentials:'include',
    headers:{'Content-Type':'application/json'},
    body: JSON.stringify({tx_power: v}) });
  var j = await r.json();
  if (j.ok) {
    el.placeholder = v.toFixed(2) + ' dBm';
    el.value = '';
    var t = document.getElementById('ponModalTitle').textContent
              .replace(/^PON Port Status \u2014 /, '');
    oltPonStatus(oltId, t);     // reload modal to show new TX
  } else alert('Failed: ' + JSON.stringify(j));
}
