<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Payment Successful - {{ company.company_name if company else "Auto ISP Billing" }}</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  body { background: #0f172a; color: #e2e8f0; font-family: -apple-system, BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
         display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; padding:20px; }
  .ok-wrap { max-width:520px; width:100%; text-align:center; }
  .ok-card { background:#111827; border:1px solid #1f2937; border-radius:16px;
             padding:40px 32px; box-shadow:0 10px 40px rgba(0,0,0,.4); }
  .logo-sm { height:40px; margin-bottom:16px; }
  .ok-circle { width:110px; height:110px; border-radius:50%; margin:0 auto 26px;
               background:linear-gradient(135deg,#059669,#10b981);
               display:flex; align-items:center; justify-content:center;
               box-shadow:0 6px 28px rgba(16,185,129,.45);
               animation:popIn .6s cubic-bezier(.34,1.56,.64,1) both; }
  .ok-circle i { font-size:52px; color:#fff; animation:tickPop .45s .25s ease-out both; transform:scale(0); }
  @keyframes popIn { from { transform:scale(0); opacity:0 } to { transform:scale(1); opacity:1 } }
  @keyframes tickPop { from { transform:scale(0); opacity:0 } to { transform:scale(1); opacity:1 } }
  h1 { font-size:26px; margin:6px 0 8px; color:#f1f5f9; font-weight:700; }
  .subtitle { color:#94a3b8; font-size:14px; margin-bottom:26px; line-height:1.5; }
  .detail-box { background:#0b1220; border-radius:10px; padding:16px 18px;
                text-align:left; margin:18px 0; font-size:13px; }
  .detail-box div { margin:5px 0; }
  .detail-box strong { color:#94a3b8; display:inline-block; min-width:100px; }
  .detail-box .val { color:#f1f5f9; font-family:'SF Mono',Menlo,monospace; }
  .cta { display:inline-block; padding:14px 28px; background:linear-gradient(135deg,#059669,#10b981);
         color:#fff; border:none; border-radius:8px; font-size:15px; font-weight:600;
         text-decoration:none; margin-top:10px; cursor:pointer;
         transition:transform .08s ease, box-shadow .2s ease;
         box-shadow:0 4px 14px rgba(16,185,129,.35); }
  .cta:hover { color:#fff; transform:translateY(-1px); box-shadow:0 6px 18px rgba(16,185,129,.5); }
  .countdown { color:#64748b; font-size:12px; margin-top:20px; }
  .countdown b { color:#10b981; }
</style>
</head>
<body>
<div class="ok-wrap">
  <div class="ok-card">
    {% if company and company.logo_path %}
      <img src="{{ company.logo_path if company.logo_path.startswith('/') else '/' + company.logo_path }}"
           class="logo-sm" alt="{{ company.company_name }}">
    {% endif %}
    <div class="ok-circle"><i class="fa fa-check"></i></div>
    <h1>Payment Successful</h1>
    <div class="subtitle">
      Thank you <strong>{{ customer.customer_name or customer.customer_id }}</strong>!<br>
      Your service is being reactivated and should come back online within <strong>1-2 minutes</strong>.
    </div>

    <div class="detail-box">
      <div><strong>Amount Paid:</strong> <span class="val">&#8377; {{ "%.0f"|format(amount) }}</span></div>
      {% if payment_id %}
      <div><strong>Payment ID:</strong> <span class="val">{{ payment_id }}</span></div>
      {% endif %}
      <div><strong>Customer:</strong> <span class="val">{{ customer.customer_id }}</span></div>
      {% if customer.username %}
      <div><strong>PPPoE:</strong> <span class="val">{{ customer.username }}</span></div>
      {% endif %}
      <div><strong>Date:</strong> <span class="val">{{ now_ist }}</span></div>
    </div>

    <a href="{{ main_login_url }}" class="cta" data-testid="pay-success-login">
      <i class="fa fa-sign-in-alt"></i> Go to Customer Login
    </a>

    <div class="countdown">
      Redirecting to login in <b id="cd">10</b> seconds&hellip;
    </div>
  </div>
</div>

<script>
  var n = 10;
  var el = document.getElementById('cd');
  var t = setInterval(function(){
    n -= 1;
    if (el) el.innerText = n;
    if (n <= 0) { clearInterval(t); window.location.href = '{{ main_login_url }}'; }
  }, 1000);
</script>
</body>
</html>
