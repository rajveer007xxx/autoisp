<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Account Suspended · Pay Now · {{ company.company_name if company else "Pay" }}</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  body { background: #0f172a; color: #e2e8f0; font-family: -apple-system, BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; min-height:100vh; margin:0; }
  .pay-wrap { max-width: 880px; margin: 24px auto; padding: 0 16px; }
  .pay-card { background: #111827; border: 1px solid #1f2937; border-radius: 12px;
              padding: 28px; margin-bottom: 18px; box-shadow: 0 4px 20px rgba(0,0,0,.35); }
  .pay-status { display:inline-block; padding:6px 14px; border-radius:999px;
                background:#7f1d1d; color:#fecaca; font-weight:600; font-size:12px;
                letter-spacing:.5px; text-transform:uppercase; }
  .pay-balance { font-size:40px; font-weight:700; color:#fca5a5; margin:18px 0; letter-spacing:-1px; }
  .pay-balance .rupee { font-size:28px; vertical-align:top; margin-right:6px; }
  .pay-label { color:#94a3b8; font-size:12px; text-transform:uppercase; letter-spacing:1px; margin-bottom:6px; }
  .pay-value { color:#f1f5f9; font-size:16px; font-weight:500; font-family:'SF Mono',Menlo,monospace; }
  .pay-row { display:grid; grid-template-columns:1fr 1fr; gap:24px; margin:18px 0; }
  @media (max-width:600px) { .pay-row { grid-template-columns:1fr; } }
  .pay-qr { display:block; max-width:240px; margin:10px auto; border:3px solid #e2e8f0;
            border-radius:8px; background:#fff; padding:6px; }
  .pay-btn { display:inline-block; padding:14px 32px; border-radius:8px; font-size:16px;
             font-weight:600; cursor:pointer;
             background:linear-gradient(135deg,#059669,#10b981); color:#fff; border:none;
             transition:transform .08s ease, box-shadow .2s ease;
             box-shadow:0 4px 14px rgba(16,185,129,.35); }
  .pay-btn:hover { transform:translateY(-1px); box-shadow:0 6px 18px rgba(16,185,129,.5); }
  .pay-btn:disabled { background:#334155; box-shadow:none; cursor:not-allowed; opacity:.7; }
  .pay-hero { text-align:center; }
  .pay-cust { font-size:22px; font-weight:600; color:#f1f5f9; margin-top:4px; }
  .bank-info { background:#0b1220; border-radius:8px; padding:16px; }
  .bank-info div { margin:6px 0; }
  .logo-sm { height:40px; margin-bottom:12px; filter:brightness(1.05); }
  .muted { color:#64748b; font-size:12px; }
  a { color:#10b981; }
</style>
</head>
<body>
<div class="pay-wrap">
  <div class="pay-card pay-hero">
    {% if company and company.logo_path %}
      <img src="{{ company.logo_path if company.logo_path.startswith('/') or company.logo_path.startswith('http') else '/' + company.logo_path }}" class="logo-sm" alt="{{ company.company_name }}">
    {% endif %}
    <div class="pay-label">{{ company.company_name if company else "Your Internet Provider" }}</div>
    <span class="pay-status" data-testid="pay-status">{{ status_label }}</span>
    <div class="pay-cust" data-testid="pay-cust-name">{{ customer.customer_name or customer.customer_id }}</div>
    <div class="muted">Customer ID: <strong>{{ customer.customer_id }}</strong>{% if customer.username %} &middot; PPPoE: <strong>{{ customer.username }}</strong>{% endif %}</div>

    <div class="pay-balance" data-testid="pay-balance">
      <span class="rupee">&#8377;</span>{{ "%.0f"|format(balance) }}
    </div>
    <div class="muted">{{ status_message }}</div>

    <div style="margin-top:22px;">
      {% if razorpay_ready %}
        <button class="pay-btn" id="rzpBtn" onclick="startRazorpay()" data-testid="pay-razorpay-btn">
          <i class="fa fa-bolt"></i> Pay &#8377;{{ "%.0f"|format(balance) }} Now
        </button>
      {% else %}
        <button class="pay-btn" disabled title="Online payment not yet configured; use UPI / QR / Bank transfer below" data-testid="pay-razorpay-btn">
          <i class="fa fa-lock"></i> Online Payment (Coming Soon)
        </button>
      {% endif %}
    </div>
  </div>

  <div class="pay-card">
    <div class="pay-label">Pay via UPI / QR</div>
    <div class="pay-row">
      <div>
        {% if company.bank_qr_code %}
          <img src="{{ company.bank_qr_code if company.bank_qr_code.startswith('/') or company.bank_qr_code.startswith('http') else '/' + company.bank_qr_code }}" alt="UPI QR" class="pay-qr" data-testid="pay-qr">
        {% else %}
          <div class="muted" style="padding:20px; text-align:center; border:1px dashed #334155; border-radius:8px;">
            QR code not yet uploaded by your ISP.
          </div>
        {% endif %}
      </div>
      <div>
        <div class="pay-label">UPI ID</div>
        <div class="pay-value" data-testid="pay-upi">{{ company.upi_id or "Not configured" }}</div>
        {% if company.upi_id %}
          <div class="muted" style="margin-top:8px;">Tap-to-copy, paste into GPay / PhonePe / Paytm / any UPI app.</div>
          <button class="pay-btn" style="padding:8px 16px; font-size:13px; margin-top:12px;"
                  onclick="navigator.clipboard.writeText('{{ company.upi_id }}');this.innerText='Copied!';"
                  data-testid="pay-copy-upi">
            <i class="fa fa-copy"></i> Copy UPI ID
          </button>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="pay-card">
    <div class="pay-label">Bank Transfer (NEFT / IMPS / RTGS)</div>
    <div class="bank-info">
      <div><strong>Bank:</strong> <span class="pay-value" data-testid="pay-bank-name">{{ company.bank_name or "-" }}</span></div>
      <div><strong>Account Number:</strong> <span class="pay-value" data-testid="pay-bank-acct">{{ company.account_number or "-" }}</span></div>
      <div><strong>IFSC Code:</strong> <span class="pay-value" data-testid="pay-bank-ifsc">{{ company.branch_ifsc or "-" }}</span></div>
      <div><strong>Branch:</strong> <span class="pay-value">{{ company.branch_location or "-" }}</span></div>
      <div><strong>Account Name:</strong> <span class="pay-value">{{ company.company_name }}</span></div>
    </div>
    <div class="muted" style="margin-top:14px;">
      After payment please mention <strong>{{ customer.customer_id }}</strong> in the transaction remarks
      so your ISP can reconcile faster. Reconnection is usually automatic within minutes of a confirmed payment.
    </div>
  </div>

  <div class="pay-card">
    <div class="pay-label">Need Help?</div>
    <div>
      Contact your ISP:
      {% if company.company_phone %}
        <a href="tel:{{ company.company_phone }}" data-testid="pay-contact-phone">
          <i class="fa fa-phone"></i> {{ company.company_phone }}
        </a>
      {% endif %}
      {% if company.company_email %}
        &nbsp;|&nbsp;
        <a href="mailto:{{ company.company_email }}" data-testid="pay-contact-email">
          <i class="fa fa-envelope"></i> {{ company.company_email }}
        </a>
      {% endif %}
    </div>
  </div>

  <div style="text-align:center; color:#475569; font-size:11px; margin-top:30px;">
    Powered by Auto ISP Billing &middot; Secure Payment Page
  </div>
</div>

{% if razorpay_ready %}
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
{% endif %}
<script>
function startRazorpay() {
  var btn = document.getElementById('rzpBtn');
  btn.disabled = true; btn.innerText = 'Creating order...';
  fetch('/api/pay/{{ customer.customer_id }}/razorpay-order', {
    method: 'POST', headers: {'Content-Type':'application/json'}
  }).then(function(r){return r.json();}).then(function(d){
    if (!d.success || !d.order_id) {
      btn.disabled = false;
      btn.innerHTML = '<i class="fa fa-bolt"></i> Pay Now';
      alert(d.message || 'Could not create order. Please try UPI / QR.');
      return;
    }
    var options = {
      "key": d.key_id, "amount": d.amount, "currency": "INR",
      "name": "{{ company.company_name|e }}",
      "description": "Internet dues - {{ customer.customer_id }}",
      "image": "{{ company.logo_path or '' }}",
      "order_id": d.order_id,
      "prefill": {
        "name": "{{ (customer.customer_name or customer.customer_id)|e }}",
        "contact": "{{ customer.mobile or '' }}",
        "email": "{{ customer.email or '' }}"
      },
      "theme": {"color": "#10b981"},
      "handler": function(resp) {
        fetch('/api/pay/{{ customer.customer_id }}/razorpay-verify', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify(resp)
        }).then(function(r){return r.json();}).then(function(v){
          if (v.success) {
            // redirect to success page with payment details
            var qs = '?payment_id=' + encodeURIComponent(resp.razorpay_payment_id || '') +
                     '&amount={{ balance }}';
            window.location.href = '/pay/success/{{ customer.customer_id }}' + qs;
          } else {
            alert('Payment verification failed: ' + (v.message || 'unknown'));
          }
        });
      }
    };
    var rzp = new Razorpay(options);
    rzp.on('payment.failed', function(resp) {
      var err = resp.error || {};
      var qs = '?code=' + encodeURIComponent(err.code || '') +
               '&description=' + encodeURIComponent(err.description || 'Payment failed') +
               '&payment_id=' + encodeURIComponent((err.metadata || {}).payment_id || '') +
               '&amount={{ balance }}';
      window.location.href = '/pay/failed/{{ customer.customer_id }}' + qs;
    });
    rzp.open();
    btn.disabled = false; btn.innerHTML = '<i class="fa fa-bolt"></i> Pay Now';
  }).catch(function(e){
    btn.disabled = false;
    btn.innerHTML = '<i class="fa fa-bolt"></i> Pay Now';
    alert('Request error: ' + e);
  });
}
</script>
</body>
</html>
