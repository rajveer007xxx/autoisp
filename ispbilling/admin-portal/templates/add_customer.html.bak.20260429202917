            <ul class="nav nav-tabs" role="tablist" style="margin-bottom: 20px;">
                <li role="presentation" class="active">
                    <a href="#general" aria-controls="general" role="tab" data-toggle="tab">
                        <i class="fa fa-info-circle"></i> General Information
                    </a>
                </li>
                <li role="presentation">
                    <a href="#address" aria-controls="address" role="tab" data-toggle="tab">
                        <i class="fa fa-map-marker"></i> Address Detail
                    </a>
                </li>
                <li role="presentation">
                    <a href="#billing" aria-controls="billing" role="tab" data-toggle="tab">
                        <i class="fa fa-file-text"></i> Billing Detail
                    </a>
                </li>
                <li role="presentation">
                    <a href="#payment" aria-controls="payment" role="tab" data-toggle="tab">
                        <i class="fa fa-credit-card"></i> Payment Detail
                    </a>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content">
                <!-- General Information Tab -->
                <div role="tabpanel" class="tab-pane active" id="general">
                    <form id="customerForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Customer Registration Type *</label>
                                    <select class="form-control" name="registration_type" id="registration_type">
                                        <option value="New Customer" selected>New Customer</option>
                                        <option value="Existing Customer Migration">Existing Customer Migration</option>
                                    </select>
                                    <small class="form-text text-muted" style="font-size: 11px; color: #666;">
                                        Choose Existing Customer Migration if you are shifting this customer from other billing website
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Service Type *</label>
                                    <select class="form-control" name="service_type" id="service_type">
                                        <option value="Broadband" selected>Broadband</option>
                                        <option value="Cable">Cable</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Customer Type *</label>
                                    <select class="form-control" name="customer_type" id="customer_type" required>
                                        <option value="Prepaid" selected>Prepaid</option>
                                        <option value="Postpaid">Postpaid</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Customer ID *</label>
                                    <input type="text" class="form-control" name="customer_id" id="customer_id" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Name *</label>
                                    <input type="text" class="form-control" name="name" id="name" placeholder="Customer Name" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>User Name *</label>
                                    <!-- s26.17a: bs3-inline-prefix -->
                                    <div class="input-group">
                                        <span class="input-group-addon" id="username-prefix-display"
                                              data-prefix=""
                                              style="font-weight:600;background:#f4f6fa;">...</span>
                                        <input type="text" class="form-control" id="username_suffix"
                                               placeholder="e.g. raj" required
                                               autocomplete="off"
                                               data-testid="cust-username-suffix">
                                        <input type="hidden" name="username" id="username">
                                    </div>
                                    <small class="form-text" id="username-feedback"></small>
                                    <small class="form-text text-muted">
                                        Final PPPoE username:
                                        <strong id="username-full-preview">—</strong>.
                                        Prefix is auto-derived from your company name.
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="row" id="auth_type_row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Auth Type</label>
                                    <select class="form-control" name="auth_type" id="auth_type" data-testid="cust-auth-type" onchange="toggleAuthTypeFields()">
                                        <option value="pppoe" selected>PPPoE (dial-up username/password)</option>
                                        <option value="static_ip">Static-IP (fixed IP, no PPPoE)</option>
                                        <option value="hotspot">Hotspot (captive portal login)</option>
                                    </select>
                                    <small class="form-text text-muted">Determines what FreeRADIUS sends back to the NAS.</small>
                                </div>
                            </div>
                            <div class="col-md-6 auth-static-field" style="display:none;">
                                <div class="form-group">
                                    <label>IP Pool *</label>
                                    <select class="form-control" id="static_ip_pool" data-testid="cust-static-pool" onchange="loadStaticIpAvailable('add')">
                                        <option value="">-- select a pool --</option>
                                    </select>
                                    <small class="form-text text-muted">Pick the subnet the customer'''s CPE lives on.</small>
                                </div>
                            </div>
                            <div class="col-md-6 auth-static-field" style="display:none;">
                                <div class="form-group">
                                    <label>Static IP address *</label>
                                    <select class="form-control" name="static_ip_address" id="static_ip_address" data-testid="cust-static-ip">
                                        <option value="">-- pick a pool first --</option>
                                    </select>
                                    <small class="form-text text-muted"><span id="static_ip_count" class="text-muted">0</span> available (pool excludes already-assigned IPs).</small>
                                </div>
                            </div>
                            <div class="col-md-6 auth-static-field" style="display:none;">
                                <div class="form-group">
                                    <label>Netmask</label>
                                    <input type="text" class="form-control" name="static_netmask" id="static_netmask" value="255.255.255.0" data-testid="cust-static-netmask">
                                </div>
                            </div>
                            <div class="col-md-6 auth-static-field" style="display:none;">
                                <div class="form-group">
                                    <label>MAC address <small class="text-muted">(optional)</small></label>
                                    <input type="text" class="form-control" name="mac_address" id="mac_address" placeholder="AA:BB:CC:DD:EE:FF" data-testid="cust-mac">
                                </div>
                            </div>
                            <div class="col-md-6 auth-hotspot-field" style="display:none;">
                                <div class="form-group">
                                    <label>Session Timeout (seconds)</label>
                                    <input type="number" class="form-control" name="hotspot_session_timeout" id="hotspot_session_timeout" value="0" min="0" data-testid="cust-sess-to">
                                    <small class="form-text text-muted">0 = no timeout.</small>
                                </div>
                            </div>
                            <div class="col-md-6 auth-hotspot-field" style="display:none;">
                                <div class="form-group">
                                    <label>Idle Timeout (seconds)</label>
                                    <input type="number" class="form-control" name="hotspot_idle_timeout" id="hotspot_idle_timeout" value="600" min="0" data-testid="cust-idle-to">
                                </div>
                            </div>
                        </div>
                        <script>
                        function toggleAuthTypeFields(){
                            var at = (document.getElementById('auth_type') || {}).value || 'pppoe';
                            document.querySelectorAll('.auth-static-field').forEach(function(e){ e.style.display = (at === 'static_ip') ? '' : 'none'; });
                            document.querySelectorAll('.auth-hotspot-field').forEach(function(e){ e.style.display = (at === 'hotspot') ? '' : 'none'; });
                            if (at === 'static_ip') { loadStaticIpPools('add'); }
                        }
                        document.addEventListener('DOMContentLoaded', toggleAuthTypeFields);

                        // __S38T_STATIC_POOL_UX__
                        // Populate the IP-pool dropdown (only PPPoE/Hotspot sources
                        // — Public IPs are for "Fix IP" flow, not static CPEs).
                        window._staticPoolsLoaded = window._staticPoolsLoaded || {};
                        function loadStaticIpPools(scope){
                            var poolSel = (scope === 'edit') ? '#edit_static_ip_pool' : '#static_ip_pool';
                            var $sel = $(poolSel);
                            if (!$sel.length) return;
                            // Preserve the currently-picked option when re-toggling.
                            var pre = $sel.data('preset') || $sel.val() || '';
                            $.get('/api/fix-ip/pools').then(function(res){
                                if (!res || !res.ok) return;
                                $sel.empty().append('<option value="">-- select a pool --</option>');
                                (res.rows || []).forEach(function(p){
                                    if (p.source === 'public') return;   // only PPPoE / Hotspot subnets
                                    var lbl = p.pool_name + '  (' + (p.free||0) + ' free / ' + (p.total||0) + ')';
                                    $sel.append($('<option>').val(p.pool_name + '|' + p.source).text(lbl));
                                });
                                if (pre) { $sel.val(pre); loadStaticIpAvailable(scope); }
                            });
                        }

                        function loadStaticIpAvailable(scope){
                            var poolSel = (scope === 'edit') ? '#edit_static_ip_pool' : '#static_ip_pool';
                            var ipSel   = (scope === 'edit') ? '#edit_static_ip_address' : '#static_ip_address';
                            var countEl = (scope === 'edit') ? '#edit_static_ip_count' : '#static_ip_count';
                            var val = $(poolSel).val() || '';
                            var $ip = $(ipSel);
                            if (!val) {
                                $ip.empty().append('<option value="">-- pick a pool first --</option>');
                                $(countEl).text('0');
                                return;
                            }
                            var parts = val.split('|');
                            var poolName = parts[0], source = parts[1] || 'pppoe';
                            // Preserve preset (edit form passes the customer'''s existing IP
                            // via data-preset so it stays selected even if marked Assigned).
                            var preset = $ip.data('preset') || '';
                            $ip.empty().append('<option value="">-- loading... --</option>');
                            $.get('/api/fix-ip/available', {pool: poolName, source: source, include_current: preset}).then(function(res){
                                $ip.empty().append('<option value="">-- select an IP --</option>');
                                var rows = (res && res.ok) ? (res.rows || []) : [];
                                rows.forEach(function(r){
                                    var tag = (r.status && r.status !== 'Free') ? (' [' + r.status + ']') : '';
                                    $ip.append($('<option>').val(r.ip).text(r.ip + tag));
                                });
                                $(countEl).text(rows.length);
                                if (preset) $ip.val(preset);
                            });
                        }
                        </script>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Password *</label>
                                    <input type="password" class="form-control" name="password" id="password" placeholder="Password" required minlength="6">
