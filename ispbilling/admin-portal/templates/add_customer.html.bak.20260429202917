{% extends base_template|default("base_admin.html") %}

{% block title %}Add Customer - Auto ISP Billing{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css">
<style>
.field-error {
    border-color: #dc3545 !important;
    background-color: #fff5f5 !important;
}
.error-message {
    color: #dc3545;
    font-size: 12px;
    margin-top: 5px;
    display: none;
}
</style>
{% endblock %}

{% block content %}
<section class="content-header">
    <h1>
        Add Customer
        <small>Add new customer</small>
        <button type="button" class="btn btn-primary pull-right" id="downloadCafBtn" style="display: none;">
            <i class="fa fa-download"></i> Download CAF
