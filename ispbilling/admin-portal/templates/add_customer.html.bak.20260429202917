<script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>

<script>
// Validate fields and highlight errors
function validateFields(fields) {
    let isValid = true;
    let firstInvalidField = null;
    
    fields.forEach(fieldId => {
        const field = $('#' + fieldId);
        const value = field.val().trim();
        
        // Remove previous error styling
        field.removeClass('field-error');
        
        // Check if field is required and empty
        if (field.prop('required') && !value) {
            field.addClass('field-error');
            isValid = false;
            if (!firstInvalidField) firstInvalidField = field;
        }
        // Check pattern validation for email and mobile
        else if (field.attr('pattern') && value) {
            const pattern = new RegExp(field.attr('pattern'));
            if (!pattern.test(value)) {
                field.addClass('field-error');
                isValid = false;
                if (!firstInvalidField) firstInvalidField = field;
            }
        }
    });
    
    // Focus on first invalid field
    if (firstInvalidField) {
        firstInvalidField.focus();
        
        // Show alert with specific error message
        let errorMsg = 'Please fill all required fields correctly:\n\n';
        $('.field-error').each(function() {
            const label = $(this).closest('.form-group').find('label').text();
            errorMsg += '• ' + label + '\n';
        });
        alert(errorMsg);
    }
    
    return isValid;
}

// Validate password match
function validatePasswordMatch() {
    const password = $('#password').val();
    const confirmPassword = $('#confirm_password').val();
    
    if (password && confirmPassword && password !== confirmPassword) {
        $('#confirm_password').addClass('field-error');
        alert('Password and Confirm Password do not match!');
        return false;
    }
    
    return true;
}

function nextTab(tabId) {
    $('.nav-tabs a[href="#' + tabId + '"]').tab('show');
}

function prevTab(tabId) {
    $('.nav-tabs a[href="#' + tabId + '"]').tab('show');
}

// Generate random 8-digit Customer ID (no prefix)
function generateCustomerId() {
    const randomNum = Math.floor(10000000 + Math.random() * 90000000);
    return randomNum.toString();
}

// Generate random CAF NO with CAF prefix
function generateCafNo() {
    const randomNum = Math.floor(10000000 + Math.random() * 90000000);
    return 'CAF' + randomNum;
}

// Calculate end date based on start date and period
function calculateEndDate(startDate, periodMonths) {
    if (!startDate || !periodMonths) return '';
    
    const parts = startDate.split('-');
    if (parts.length !== 3) return '';
    
    const day = parseInt(parts[0]);
    const month = parseInt(parts[1]) - 1;
    const year = parseInt(parts[2]);
    
    const start = new Date(year, month, day);
    const end = new Date(year, month + parseInt(periodMonths), day);
    end.setDate(end.getDate() - 1);
    
    const endDay = String(end.getDate()).padStart(2, '0');
    const endMonth = String(end.getMonth() + 1).padStart(2, '0');
    const endYear = end.getFullYear();
    
    return endDay + '-' + endMonth + '-' + endYear;
}

// Calculate payment amounts based on plan and period
// _S39R5FIX11_ — expose the company's state to the tax calculator
window.AISP_COMPANY_STATE = "{{ (company.state if company and company.state else '')|escape }}";
$(function () {
    $('#billing_state, #state').on('change', function () {
        if (typeof calculatePaymentAmounts === 'function') calculatePaymentAmounts();
    });
});

function calculatePaymentAmounts() {
    const planSelect = $('#plan');
    const periodSelect = $('#period');
    
    if (!planSelect.val() || !periodSelect.val()) return;
    
    const selectedOption = planSelect.find('option:selected');
    const baseAmount = parseFloat(selectedOption.data('base-amount')) || 0;
    let cgstRate = parseFloat(selectedOption.data('cgst')) || 0;
    let sgstRate = parseFloat(selectedOption.data('sgst')) || 0;
    let igstRate = parseFloat(selectedOption.data('igst')) || 0;
    const period = parseInt(periodSelect.val());

    // _S39R5FIX11_ — apply intra/inter-state rule: only one set of tax applies
    //   intra (billing-state == company-state) → CGST + SGST, IGST = 0
    //   inter (billing-state != company-state) → IGST only, CGST = SGST = 0
    // If IGST rate is 0 in plan but tax should be IGST, derive it as CGST + SGST.
    const _companyState = (window.AISP_COMPANY_STATE || '').toString().trim().toLowerCase();
    const _billingState = ($('#billing_state').val() || $('#state').val() || '').toString().trim().toLowerCase();
    const _isIntra = (!_companyState) || (!_billingState) || (_companyState === _billingState);
    if (_isIntra) {
        igstRate = 0;
    } else {
        // inter-state — collapse to IGST. If plan has explicit IGST use it; else
        // fall back to CGST+SGST sum.
        if (!igstRate) igstRate = cgstRate + sgstRate;
        cgstRate = 0;
        sgstRate = 0;
    }

    let cgstAmount = (cgstRate <= 100) ? (baseAmount * cgstRate / 100) : cgstRate;
    let sgstAmount = (sgstRate <= 100) ? (baseAmount * sgstRate / 100) : sgstRate;
    let igstAmount = (igstRate <= 100) ? (baseAmount * igstRate / 100) : igstRate;

    // For postpaid, always use period=1 for display and Total Due calculation
    const customerType = $('#customer_type').val();
    const periodForCalc = (customerType === 'Postpaid') ? 1 : period;
    
    // Calculate monthly amounts
    const billAmount = baseAmount * periodForCalc;
    const totalCgst = cgstAmount * periodForCalc;
    const totalSgst = sgstAmount * periodForCalc;
    const totalIgst = igstAmount * periodForCalc;
    
    // Calculate total plan amount (base + taxes for the period)
    const totalAmount = billAmount + totalCgst + totalSgst + totalIgst;
    
    // Update fields
    $('#bill_amount').val('₹' + billAmount.toFixed(2));
    $('#cgst_tax').val('₹' + totalCgst.toFixed(2));
    $('#sgst_tax').val('₹' + totalSgst.toFixed(2));
    $('#igst_tax').val('₹' + totalIgst.toFixed(2));
    $('#total_bill_amount').val('₹' + totalAmount.toFixed(2));
    
    // Trigger Total Due Balance calculation
    calculateTotalDueBalance();
}

// Calculate Total Due Balance
function calculateTotalDueBalance() {
    // Get values and strip currency formatting
    // Always include plan amount for both prepaid and postpaid
    const totalPlanAmount = parseFloat($('#total_bill_amount').val().replace('₹', '').replace(',', '').trim()) || 0;
    
    const routerCharges = parseFloat($('#router_charges').val()) || 0;
    const installationCharges = parseFloat($('#installation_charges').val()) || 0;
    const discountCredit = parseFloat($('#discount_credit').val()) || 0;
    const receivedAmount = parseFloat($('#received_amount').val()) || 0;
    
    // Formula: Total Plan Amount + Router + Installation - Discount - Received Amount
    // (Security deposit removed as per user request)
    const totalDueBalance = totalPlanAmount + routerCharges + installationCharges - discountCredit - receivedAmount;
    
    // Update field
    $('#total_due_balance').val(totalDueBalance.toFixed(2));
}

// Generate Transaction ID based on payment mode and received amount
function generateTransactionId() {
    const paymentMode = $('#payment_mode').val();
    const receivedAmountRaw = $('#received_amount').val() || '';
    
    // Strip non-numeric characters (like ₹) and parse as number
    const receivedAmount = Number(String(receivedAmountRaw).replace(/[^0-9.]/g, ''));
    
    // Only generate if both payment mode is selected and received amount is entered
    if (!paymentMode || !receivedAmount || receivedAmount <= 0) {
        $('#transaction_id').val('');
        return;
    }
    
    // Generate 5 random digits
    const randomDigits = Math.floor(10000 + Math.random() * 90000);
    
    // Map payment modes to prefixes (using both value and text for robustness)
    const prefixes = {
        'Cash': 'CSH',
        'cash': 'CSH',
        'Paytm': 'PAYTM',
        'paytm': 'PAYTM',
        'Google Pay': 'GPAY',
        'google pay': 'GPAY',
        'gpay': 'GPAY',
        'Phone Pay': 'PHNP',
        'phone pay': 'PHNP',
        'phonepe': 'PHNP',
        'Cheque': 'CHQ',
        'cheque': 'CHQ',
        'Netbanking': 'NETB',
        'netbanking': 'NETB',
        'net banking': 'NETB',
        'Online Portal': 'PORTL',
        'online portal': 'PORTL',
        'portal': 'PORTL'
    };
    
    const prefix = prefixes[paymentMode] || prefixes[paymentMode.toLowerCase()] || 'TXN';
    $('#transaction_id').val(prefix + randomDigits);
}

