$(document).ready(function() {
    // Auto-generate Customer ID on page load
    $('#customer_id').val(generateCustomerId());
    
    // Auto-generate CAF NO on page load
    $('#caf_no').val(generateCafNo());
    
    // Load locations from database and populate locality dropdown
    function loadLocations() {
        $.ajax({
            url: '/api/locations/list',
            method: 'GET',
            success: function(response) {
                if (response.success && response.locations) {
                    const localitySelect = $('#locality');
                    localitySelect.empty();
                    
                    // Filter to only Active locations
                    const activeLocations = response.locations.filter(loc => loc.status === 'Active');
                    
                    if (activeLocations.length === 0) {
                        localitySelect.append('<option value="">No locations available</option>');
                        localitySelect.prop('disabled', true);
                        $('#locality-error').show();
                    } else {
                        localitySelect.append('<option value="">Select Locality</option>');
                        
                        // Sort locations by name
                        activeLocations.sort((a, b) => a.name.localeCompare(b.name));
                        
                        activeLocations.forEach(function(location) {
                            localitySelect.append($('<option>', {
                                value: location.name,
                                text: location.name
                            }));
                        });
                        
                        localitySelect.prop('disabled', false);
                        $('#locality-error').hide();
                    }
                } else {
                    $('#locality').empty().append('<option value="">Error loading locations</option>').prop('disabled', true);
                    $('#locality-error').show();
                }
            },
            error: function(xhr, status, error) {
                console.error('Failed to load locations:', error);
                $('#locality').empty().append('<option value="">Error loading locations</option>').prop('disabled', true);
                $('#locality-error').show();
            }
        });
    }
    
    // Load locations on page load
    loadLocations();
    
    // Load Indian states (populate both installation + billing state dropdowns)
    $.getJSON('/static/data/states_IN.json', function(states) {
        states.forEach(function(state) {
            $('#state').append('<option value="' + state.code + '">' + state.name + '</option>');
            $('#billing_state').append('<option value="' + state.code + '">' + state.name + '</option>');
        });
    });

    // Billing address toggle — reveal / hide + toggle required on billing fields
    $('#billing_address_different').on('change', function() {
        var isChecked = $(this).is(':checked');
        $('#billingAddressFields').toggle(isChecked);
        $('#billing_address, #billing_locality, #billing_state, #billing_city, #billing_pincode').each(function() {
            $(this).prop('required', isChecked);
            if (!isChecked) {
                $(this).removeClass('field-error').val('');
            }
        });
    });
    
    // Populate Period dropdown (1-36 months) - will be filtered based on customer type
    function populatePeriodDropdown() {
        const customerType = $('#customer_type').val();
        $('#period').empty().append('<option value="">Select Period</option>');
        
        if (customerType === 'Postpaid') {
            // For postpaid, only show 1 month
            $('#period').append('<option value="1">1 Month</option>');
        } else {
            // For prepaid, show 1-36 months
            for (let i = 1; i <= 36; i++) {
                $('#period').append('<option value="' + i + '">' + i + ' Month' + (i > 1 ? 's' : '') + '</option>');
            }
        }
    }
    
    // Initial population
    populatePeriodDropdown();
    
    // Initialize Flatpickr for Start Date with restrictions based on customer type
    let startDatePicker = flatpickr('#start_date', {
        dateFormat: 'd-m-Y',
        maxDate: 'today', // Default for postpaid - only today or past dates
        onChange: function(selectedDates, dateStr) {
            const period = $('#period').val();
            if (period) {
                $('#end_date').val(calculateEndDate(dateStr, period));
            }
            checkRequiredFields();
        }
    });
    
    // Update start date restrictions and period when customer type changes
    $('#customer_type').on('change', function() {
        const customerType = $(this).val();
        
        // Update period dropdown
        populatePeriodDropdown();
        
        // Update start date calendar restrictions
        if (customerType === 'Postpaid') {
            // For postpaid: only today or past dates
            startDatePicker.set('maxDate', 'today');
        } else {
            // For prepaid: no restrictions
            startDatePicker.set('maxDate', null);
        }
        
        // Update amount display logic
        updateAmountDisplay();
        
        // Recalculate if plan is already selected
        if ($('#plan').val()) {
            calculatePaymentAmounts();
        }
    });
    
    // Initialize Flatpickr for Installation/Creation Date with today's date as default
    flatpickr('#installation_date', {
        dateFormat: 'd-m-Y',
        defaultDate: new Date()
    });
    
    // Load plans from database based on service type
    function loadPlans() {
        const serviceType = $('#service_type').val();
        $.ajax({
            url: '/api/plans/list',
            method: 'GET',
            data: { service: serviceType },
            success: function(data) {
                $('#plan').empty().append('<option value="">Select Plan</option>');
                if (data.plans && data.plans.length > 0) {
                    data.plans.forEach(function(plan) {
                        const option = $('<option></option>')
                            .val(plan.id)
                            .text(plan.plan_name + ' - ' + plan.speed + ' (₹' + plan.after_tax_amount + '/month)')
                            .data('base-amount', plan.base_amount)
                            .data('cgst', plan.cgst_tax)
                            .data('sgst', plan.sgst_tax)
                            .data('igst', plan.igst_tax)
                            .data('after-tax-amount', plan.after_tax_amount);
                        $('#plan').append(option);
                    });
                }
            },
            error: function() {
                console.log('Error loading plans');
            }
        });
    }
    
    // Load plans on page load
    loadPlans();
    
    // Reload plans when service type changes
    function updateAuthTypeVisibility() {
        var st = ($('#service_type').val() || '').toLowerCase();
        var isCable = (st === 'cable');
        $('#auth_type_row').toggle(!isCable);
        if (isCable) {
            // Cable TV customers never go through RADIUS — force auth_type
            // to a sane default so the stored row is consistent, and hide
            // the static-IP + hotspot-specific sub-fields too.
            $('#auth_type').val('pppoe');
            if (typeof toggleAuthTypeFields === 'function') toggleAuthTypeFields();
        }
    }
    $('#service_type').on('change', function() {
        loadPlans();
        $('#monthly_amount').val('');
        $('#bill_amount').val('');
        $('#cgst_tax').val('');
        $('#sgst_tax').val('');
        $('#igst_tax').val('');
        $('#total_bill_amount').val('');
        checkRequiredFields();
        updateAuthTypeVisibility();
    });
    // Run once on load for the server-rendered initial value.
    updateAuthTypeVisibility();
    
    // Function to update amount display based on customer type
    function updateAmountDisplay() {
        const customerType = $('#customer_type').val();
        
        // Always show total plan amount for both prepaid and postpaid
        $('#total_bill_amount').closest('.form-group').parent().show();
    }
    
    // Update monthly amount when plan is selected
    $('#plan').on('change', function() {
        const selectedOption = $(this).find('option:selected');
        const afterTaxAmount = selectedOption.data('after-tax-amount');
        if (afterTaxAmount) {
            $('#monthly_amount').val('₹' + afterTaxAmount.toFixed(2));
        } else {
            $('#monthly_amount').val('');
        }
        calculatePaymentAmounts();
        updateAmountDisplay();
        checkRequiredFields();
    });
    
    // Calculate end date when period changes
    $('#period').on('change', function() {
        const startDate = $('#start_date').val();
        if (startDate) {
            $('#end_date').val(calculateEndDate(startDate, $(this).val()));
        }
        calculatePaymentAmounts();
        checkRequiredFields();
    });
    
    // Validation for General Information tab -> Address tab
    $('#nextToAddress').on('click', function() {
        const generalFields = ['name', 'username', 'password', 'confirm_password', 'email', 'mobile', 'id_proof', 'id_proof_no'];
        
        // Validate password match first
        if (!validatePasswordMatch()) {
            return false;
        }
        
        // Validate all required fields
        if (validateFields(generalFields)) {
            nextTab('address');
        }
    });
    
    // Validation for Address tab -> Billing tab
    $('#nextToBilling').on('click', function() {
        const addressFields = ['address', 'locality', 'state', 'city', 'pincode'];
        const billingFields = $('#billing_address_different').is(':checked')
            ? ['billing_address', 'billing_locality', 'billing_state', 'billing_city', 'billing_pincode']
            : [];
        const fieldsToCheck = addressFields.concat(billingFields);

        if (validateFields(fieldsToCheck)) {
            nextTab('billing');
        }
    });
    
    // Validation for Billing tab -> Payment tab
    $('#nextToPayment').on('click', function() {
        const billingFields = ['plan', 'start_date', 'period', 'end_date'];
        
        if (validateFields(billingFields)) {
            nextTab('payment');
        }
    });
    
    // Remove error styling on input change
    $('input, select, textarea').on('input change', function() {
        $(this).removeClass('field-error');
        checkRequiredFields();
    });
    
    // Password validation - highlight if less than 6 characters
    $('#password, #confirm_password').on('keyup input', function() {
        const field = $(this);
        const value = field.val();
        const helperId = field.attr('id') === 'password' ? '#password-helper' : '#confirm-password-helper';
        
        if (value.length > 0 && value.length < 6) {
            field.addClass('is-invalid');
            $(helperId).removeClass('text-muted').addClass('text-danger');
        } else {
            field.removeClass('is-invalid');
            $(helperId).removeClass('text-danger').addClass('text-muted');
        }
    });
    
    // --- Session 19: auto-prefix username with first-4-of-company-name
    //     (lowercase, alphanumeric only). The visible input is the SUFFIX
    //     only; the hidden #username field holds "<prefix><suffix>" and
    //     is what actually submits + drives the live uniqueness check.
    const rawCompany = {{ company_name|tojson }};
    function derivePrefix(name) {
        const clean = (name || '').toLowerCase().replace(/[^a-z0-9]/g, '');
        return (clean.slice(0, 4) || 'user') + '.';
    }
    const usernamePrefix = derivePrefix(rawCompany);
    $('#username-prefix-display').text(usernamePrefix).attr('data-prefix', usernamePrefix);
    function recomputeFullUsername() {
        const suffix = ($('#username_suffix').val() || '').trim()
            .toLowerCase().replace(/[^a-z0-9._-]/g, '');
        if (suffix !== $('#username_suffix').val()) {
            $('#username_suffix').val(suffix);  // live-sanitise
        }
        const full = suffix ? (usernamePrefix + suffix) : '';
        $('#username').val(full);
        $('#username-full-preview').text(full || '—');
        return full;
    }
    $('#username_suffix').on('keyup input', recomputeFullUsername);
    recomputeFullUsername();

    // Username uniqueness check with debouncing
    let usernameCheckTimeout;
    let isUsernameValid = false;
    $('#username_suffix').on('keyup input', function() {
        const username = recomputeFullUsername().trim();
        const feedback = $('#username-feedback');
        
        // Clear previous timeout
        clearTimeout(usernameCheckTimeout);
        
        if (username.length < 3) {
            feedback.text('').removeClass('text-success text-danger');
            isUsernameValid = false;
            return;
        }
        
        // Show checking message
        feedback.text('Checking...').removeClass('text-success text-danger').addClass('text-muted');
        
        // Debounce: wait 500ms after user stops typing
        usernameCheckTimeout = setTimeout(function() {
            $.ajax({
                url: '/api/customers/check-username',
                method: 'GET',
                data: { username: username },
                success: function(response) {
                    if (response.exists) {
                        feedback.text('Username already exists! Please choose another.').removeClass('text-muted text-success').addClass('text-danger');
                        $('#username').addClass('is-invalid');
                        isUsernameValid = false;
                    } else {
                        feedback.text('Username available ✓').removeClass('text-muted text-danger').addClass('text-success');
                        $('#username').removeClass('is-invalid');
                        isUsernameValid = true;
                    }
                },
                error: function() {
                    feedback.text('Could not verify username. Please try again.').removeClass('text-muted text-success').addClass('text-danger');
                    isUsernameValid = false;
                }
            });
        }, 500);
    });
    
    // Auto-generate Transaction ID when payment mode or received amount changes
    $('#payment_mode, #received_amount').on('change keyup input', function() {
        generateTransactionId();
    });
    
    // Recalculate Total Due Balance when relevant fields change
    $('#router_charges, #installation_charges, #discount_credit, #received_amount').on('change keyup', function() {
        calculateTotalDueBalance();
    });
    
    // Download CAF button click
    $('#downloadCafBtn').on('click', function() {
        alert('CAF download functionality will be implemented soon.');
    });
    
    // Form validation and submission
    $('#customerForm').on('submit', function(e) {
        e.preventDefault();
        
        // Check username validity
        recomputeFullUsername();
        if (!isUsernameValid && ($('#username').val() || '').trim().length >= (usernamePrefix.length + 3)) {
            alert('Please wait for username validation to complete or choose a different username.');
            return false;
        }
        
        // Validate password match
        const password = $('#password').val();
        const confirmPassword = $('#confirm_password').val();
        if (password !== confirmPassword) {
            alert('Passwords do not match!');
            return false;
        }
        
        // Validate password length
        if (password.length < 6) {
            alert('Password must be at least 6 characters long!');
            return false;
        }
        
        // Fallback: Generate transaction ID if not already generated
        if (!$('#transaction_id').val()) {
            generateTransactionId();
        }
        
        // Show processing popup
        showProcessingPopup();
        
        // Collect all form data from all tabs
        const formData = {};
        $('input, select, textarea').each(function() {
            const name = $(this).attr('name');
            if (name) {
                formData[name] = $(this).val();
            }
        });
        
        // Drop the checkbox-only + file fields from JSON — files go via multipart after success.
        delete formData.billing_address_different;
        delete formData.photograph;
        delete formData.address_proof;
        delete formData.id_proof_doc;

        // If the checkbox is unchecked, don't send billing_* at all.
        if (!$('#billing_address_different').is(':checked')) {
            delete formData.billing_address;
            delete formData.billing_locality;
            delete formData.billing_state;
            delete formData.billing_city;
            delete formData.billing_pincode;
        }

        // Submit to backend
        console.log('Submitting customer form with data:', formData);
        $.ajax({
            url: '/api/customers/create',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(formData),
            success: function(response) {
                console.log('Success response:', response);
                if (!response.success) {
                    hideProcessingPopup();
                    alert('Error: ' + (response.message || 'Failed to add customer'));
                    console.error('Server returned error:', response);
                    return;
                }

                // Upload any optional document files *after* the customer is saved.
                var customerId = formData.customer_id;
                var photograph = $('#photograph')[0] && $('#photograph')[0].files[0];
                var addressProof = $('#address_proof')[0] && $('#address_proof')[0].files[0];
                var idProofDoc = $('#id_proof_doc')[0] && $('#id_proof_doc')[0].files[0];

                function goToUsers() {
                    hideProcessingPopup();
                    alert('Customer added successfully!');
                    window.location.href = '{{ path_prefix|default("/admin") }}/users';
                }

                if (!photograph && !addressProof && !idProofDoc) {
                    goToUsers();
                    return;
                }

                var fd = new FormData();
                if (photograph)   fd.append('photograph',   photograph);
                if (addressProof) fd.append('address_proof', addressProof);
                if (idProofDoc)   fd.append('id_proof_doc',  idProofDoc);

                $.ajax({
                    url: '/api/customers/' + encodeURIComponent(customerId) + '/documents',
                    method: 'POST',
                    data: fd,
                    processData: false,
                    contentType: false,
                    success: function(docResp) {
                        if (!docResp.success) {
                            console.warn('Document upload returned:', docResp);
                            alert('Customer saved, but document upload failed: ' + (docResp.message || 'unknown error'));
                        }
                        goToUsers();
                    },
                    error: function(xhr) {
                        console.error('Document upload error:', xhr);
                        alert('Customer saved, but document upload failed. You can edit the customer to retry.');
                        goToUsers();
                    }
                });
            },
            error: function(xhr, status, error) {
                hideProcessingPopup();
                console.error('AJAX error:', {xhr: xhr, status: status, error: error});
                console.error('Response text:', xhr.responseText);
                alert('Error adding customer: ' + (xhr.responseJSON?.message || xhr.responseText || 'Unknown error'));
            }
        });
    });
});
</script>
{% endblock %}
