// Check if all required fields are filled
function checkRequiredFields() {
    const requiredFields = [
        'service_type', 'customer_id', 'name', 'username', 'password', 'confirm_password',
        'mobile', 'address', 'locality', 'state', 'city', 'pincode',
        'plan', 'caf_no', 'start_date', 'period', 'payment_mode'
    ];
    
    let allFilled = true;
    for (let field of requiredFields) {
        const value = $('[name="' + field + '"]').val();
        if (!value || value === '') {
            allFilled = false;
            break;
        }
    }
    
    // Show/hide Download CAF button based on required fields
    if (allFilled) {
        $('#downloadCafBtn').show();
