                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>ID Proof *</label>
                                    <select class="form-control" name="id_proof" id="id_proof" required>
                                        <option value="">Select ID Proof</option>
                                        <option>Voter ID</option>
