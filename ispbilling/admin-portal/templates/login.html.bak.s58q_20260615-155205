<!-- _S40zκ_ Forgot WiFi password (WhatsApp recovery) -->
<div id="fwModal" style="display:none;position:fixed;inset:0;background:rgba(11,17,32,.55);z-index:9999;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:24px 26px;width:380px;max-width:92vw;box-shadow:0 20px 50px rgba(0,0,0,.25);">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">
      <i class="bi bi-wifi" style="color:#6366f1;font-size:24px;"></i>
      <h3 style="margin:0;font-size:18px;font-weight:700;color:#0b1120;">Forgot WiFi password?</h3>
    </div>
    <p style="color:#475569;font-size:13.5px;line-height:1.5;margin:0 0 14px;">
      Enter your registered phone number. We'll send a one-time WhatsApp link
      to view your current WiFi password &amp; QR code (valid for 15 minutes).
    </p>
    <input id="fwPhone" data-testid="fw-phone" type="tel" class="form-control"
           placeholder="e.g. 9876543210" style="width:100%;padding:11px 14px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:15px;" />
    <div id="fwMsg" style="font-size:13px;margin:10px 0 0;min-height:18px;"></div>
    <div style="display:flex;gap:8px;margin-top:14px;">
      <button type="button" id="fwSend" data-testid="fw-send-btn"
              style="flex:1;background:linear-gradient(135deg,#25d366,#128c7e);color:#fff;border:none;padding:11px 16px;border-radius:10px;font-weight:700;cursor:pointer;font-size:14px;">
        <i class="bi bi-whatsapp"></i> Send WhatsApp Link
      </button>
      <button type="button" id="fwCancel"
              style="background:#e2e8f0;color:#475569;border:none;padding:11px 16px;border-radius:10px;font-weight:600;cursor:pointer;">Cancel</button>
    </div>
  </div>
</div>
<script>
(function(){
  const link = document.getElementById('forgotWifi');
  const modal = document.getElementById('fwModal');
  const cancel = document.getElementById('fwCancel');
  const send = document.getElementById('fwSend');
  const phone = document.getElementById('fwPhone');
  const msg = document.getElementById('fwMsg');
  if(!link) return;
  link.addEventListener('click', e=>{
    e.preventDefault();
    modal.style.display='flex';
    setTimeout(()=>phone && phone.focus(), 50);
    msg.textContent=''; phone.value='';
  });
  cancel.addEventListener('click', ()=>{ modal.style.display='none'; });
  modal.addEventListener('click', e=>{ if(e.target===modal) modal.style.display='none'; });
  send.addEventListener('click', async ()=>{
    const p = (phone.value||'').trim();
    if(p.replace(/[^0-9]/g,'').length < 10){ msg.style.color='#ef4444'; msg.textContent='Enter a valid 10-digit phone number'; return; }
    send.disabled=true; const orig=send.innerHTML; send.innerHTML='Sending…';
    try {
      const r = await fetch('/api/wifi-recover/request', {method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({phone: p})});
      const d = await r.json();
      msg.style.color = d.success ? '#15803d' : '#ef4444';
      msg.textContent = d.message || 'Done.';
      if(d.success){
        phone.disabled = true; send.style.display='none';
        setTimeout(()=>{
          modal.style.display='none';
          phone.disabled=false; send.style.display=''; send.innerHTML=orig;
        }, 4500);
      } else {
        send.disabled=false; send.innerHTML=orig;
      }
    } catch(err){
      msg.style.color='#ef4444'; msg.textContent='Network error';
      send.disabled=false; send.innerHTML=orig;
    }
  });
})();
</script>

</body>
