<body>
<div class="page">
    <!-- LEFT BRANDING PANEL -->
    <aside class="panel" aria-hidden="true">
        <div class="p-inner">
            <a class="brand" href="/" data-tag="_S39R5D_LOGO">
                <img src="/static/img/autoispbilling-logo-wide.png" alt="Auto ISP Billing"
                     style="height:38px;width:auto;display:block">
            </a>
            <div class="p-headline">
                <span class="p-eyebrow"><span class="dot"></span> Operate your ISP smarter</span>
                <h2>Welcome back.<br>Let&rsquo;s get you signed in.</h2>
                <p>One unified workspace for your billing, customers, tickets, and analytics &mdash; built for fiber, wireless and broadband providers.</p>

                <div class="stat-row">
                    <div class="stat-card"><strong>99.9%</strong><span>Uptime</span></div>
                    <div class="stat-card"><strong>24/7</strong><span>Support</span></div>
                    <div class="stat-card"><strong>256-bit</strong><span>SSL security</span></div>
                </div>

                <ul class="feature-list">
                    <li><i class="bi bi-check-circle-fill"></i> Automated billing, invoicing &amp; renewals</li>
                    <li><i class="bi bi-check-circle-fill"></i> Online payments &amp; auto-reconciliation</li>
                    <li><i class="bi bi-check-circle-fill"></i> SMS &amp; WhatsApp notifications out of the box</li>
                    <li><i class="bi bi-check-circle-fill"></i> MikroTik, RADIUS &amp; pfSense integrations</li>
                </ul>

                <div class="int-row">
                    <span class="int-chip"><i class="bi bi-router"></i> MikroTik</span>
                    <span class="int-chip"><i class="bi bi-hdd-network"></i> Cisco</span>
                    <span class="int-chip"><i class="bi bi-broadcast"></i> Ubiquiti</span>
                    <span class="int-chip"><i class="bi bi-shield-lock"></i> RADIUS</span>
                    <span class="int-chip"><i class="bi bi-diagram-3"></i> pfSense</span>
                </div>
            </div>
        </div>
    </aside>

    <!-- RIGHT FORM PANEL -->
    <main class="form-side">
        <div class="form-wrap">
            <div class="form-top">
                <a href="/"><i class="bi bi-arrow-left"></i> Back to home</a>
                <a href="#" title="Need help?"><i class="bi bi-question-circle"></i> Help</a>
            </div>

            <h1>Sign in to your portal</h1>
            <p class="subtitle">Choose your account type and enter your credentials.</p>

            <div class="role-grid" role="tablist">
                <div class="role active" data-type="superadmin" role="tab" aria-selected="true">
                    <i class="bi bi-shield-lock"></i>
                    <span>Superadmin</span>
                </div>
                <div class="role" data-type="admin" role="tab">
                    <i class="bi bi-person-badge"></i>
                    <span>Admin</span>
                </div>
                <div class="role" data-type="sub_lco" role="tab" data-testid="role-sub-lco" data-tag="_S39R5T_REORDER_">
                    <i class="bi bi-building-fill-gear"></i>
                    <span>Sub-LCO</span>
                </div>
                <div class="role" data-type="employee" role="tab">
                    <i class="bi bi-person-workspace"></i>
                    <span>Employee</span>
                </div>
                <div class="role" data-type="customer" role="tab">
                    <i class="bi bi-person-circle"></i>
                    <span>Customer</span>
                </div>
            </div>

            <div class="alert-err" id="loginErr" role="alert"></div>

            <form id="loginForm" autocomplete="on" novalidate>
                <input type="hidden" id="userType" name="userType" value="superadmin">

                <div class="field" id="companyIdField" style="display:none;">
                    <label for="companyId">Company ID</label>
                    <i class="bi bi-building field-ico"></i>
                    <input type="text" class="form-control" id="companyId" name="companyId" placeholder="e.g. 12345678" autocomplete="organization">
                </div>

                <div class="field">
                    <label for="userId"><span id="userIdLabel">Superadmin ID</span></label>
                    <i class="bi bi-person field-ico"></i>
                    <input type="text" class="form-control" id="userId" name="userId" placeholder="Enter your ID" autocomplete="username" required>
                </div>

                <div class="field">
                    <label for="password">Password</label>
                    <i class="bi bi-lock field-ico"></i>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password" autocomplete="current-password" required>
                <div id="s36d-totp-row" class="form-group" style="display:none;">
                    <label><i class="bi bi-shield-lock"></i> 2FA Code</label>
                    <input name="totp" id="s36d-totp" class="form-control" maxlength="6" placeholder="6-digit code" autocomplete="one-time-code" data-testid="login-totp">
                </div>
                    <button type="button" class="toggle-pw" id="togglePw" aria-label="Show password"><i class="bi bi-eye"></i></button>
                </div>

                <div class="row-inline">
                    <label><input type="checkbox" name="remember"> Remember me</label>
                    <a href="#" id="forgot">Forgot password?</a>
                </div>
                <div id="forgot-wifi-row" style="display:none;margin-top:6px;text-align:right;">
                    <a href="#" id="forgotWifi" data-testid="forgot-wifi-link" style="font-size:13px;color:#6366f1;text-decoration:none;font-weight:600;">
                        <i class="bi bi-wifi"></i> Forgot WiFi password?
                    </a>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="bi bi-box-arrow-in-right"></i> Sign in
                </button>

                <div class="form-footer">
                    New to Auto ISP Billing? <a href="/#demo">Request a demo</a>
                </div>
            </form>

            <div class="secure"><i class="bi bi-shield-check"></i> Secured with 256-bit SSL encryption</div>
        </div>
    </main>
</div>

<!-- Blocked-login modal -->
<div class="block-overlay" id="blockOverlay" role="dialog" aria-modal="true" aria-labelledby="blockTitle">
    <div class="block-card">
        <div class="block-head">
            <i class="bi bi-shield-exclamation"></i>
            <div>
                <h3 id="blockTitle">Access blocked</h3>
                <p id="blockSubtitle">Your admin account cannot sign in right now.</p>
            </div>
        </div>
        <div class="block-body">
            <div class="block-due" id="blockDueWrap" style="display:none">
                <div class="lbl">Amount due</div>
                <div class="amt" id="blockAmount">&#8377;0.00</div>
                <ul class="block-reasons" id="blockReasons"></ul>
            </div>

            <div class="block-pay" id="blockPayWrap" style="display:none">
                <div class="row"><span class="lbl">Pay to UPI ID</span><span class="val" id="blockUpi">Not set</span></div>
                <div class="row" id="blockBankNameRow" style="display:none"><span class="lbl">Bank name</span><span class="val" id="blockBankName"></span></div>
                <div class="row" id="blockAcctRow" style="display:none"><span class="lbl">Account no.</span><span class="val" id="blockAcct"></span></div>
                <div class="row" id="blockIfscRow" style="display:none"><span class="lbl">IFSC</span><span class="val" id="blockIfsc"></span></div>
                <div class="row" id="blockBranchRow" style="display:none"><span class="lbl">Branch</span><span class="val" id="blockBranch"></span></div>
            </div>

            <div class="block-pay" id="blockSupportWrap">
                <div class="row" id="blockCompanyRow"><span class="lbl">Company ID</span><span class="val" id="blockCompany"></span></div>
                <div class="row" id="blockContactEmailRow" style="display:none"><span class="lbl">Support email</span><span class="val" id="blockContactEmail"></span></div>
                <div class="row" id="blockContactPhoneRow" style="display:none"><span class="lbl">Support phone</span><span class="val" id="blockContactPhone"></span></div>
            </div>

            <div class="block-qr" id="blockQrWrap" style="display:none">
                <img id="blockQrImg" alt="UPI QR code">
                <div class="cap">Scan this QR in any UPI app to pay the due amount.</div>
            </div>
        </div>
        <div class="block-actions">
            <button type="button" class="btn-copy-upi" id="blockCopyUpi" style="display:none"><i class="bi bi-clipboard"></i> Copy UPI ID</button>
            <button type="button" class="btn-close-block" id="blockClose">Close</button>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(function(){
        var labelByType = {
            superadmin: 'Superadmin ID',
            admin: 'Admin ID',
            employee: 'Employee ID',
            customer: 'Customer ID',
            sub_lco: 'Sub-LCO Code'
        };
        var placeholderByType = {
            superadmin: 'Enter your Superadmin ID',
            admin: 'Enter your Admin ID',
            employee: 'Enter your Employee ID',
            customer: 'Enter your Customer ID',
            sub_lco: 'Enter your Sub-LCO code (e.g. SLCO123456)'
        };

        $('.role').on('click', function(){
            $('.role').removeClass('active').attr('aria-selected','false');
            $(this).addClass('active').attr('aria-selected','true');
            var t = $(this).data('type');
            $('#userType').val(t);
            if (t === 'admin' || t === 'employee' || t === 'sub_lco') {
                $('#companyIdField').show();
                $('#companyId').prop('required', true);
            } else {
                $('#companyIdField').hide();
                $('#companyId').prop('required', false);
            }
            $('#userIdLabel').text(labelByType[t] || 'User ID');
            $('#userId').attr('placeholder', placeholderByType[t] || 'Enter your ID');
            // _S40zκ_ Show "Forgot WiFi password?" only on Customer tab
            $('#forgot-wifi-row').toggle(t === 'customer');
        });

        /* __REMEMBER_ME_RESTORE__ — prefill from localStorage. */
        try {
            var stored = localStorage.getItem('aispLoginRemember');
            if (stored) {
                var cr = JSON.parse(stored);
                if (cr && cr.v === 1) {
                    var dec = function(b){
                        try { return decodeURIComponent(escape(atob(b||''))); }
                        catch (e) { return ''; }
                    };
                    var t = dec(cr.u) || 'superadmin';
                    var cid = dec(cr.c);
                    var uid = dec(cr.i);
                    var pw  = dec(cr.p);
                    /* Click the matching role tab so all the show/hide
                       logic + labels update naturally. */
                    var $tab = $('.role[data-type="' + t + '"]');
                    if ($tab.length) { $tab.trigger('click'); }
                    if (cid) { $('#companyId').val(cid); }
                    if (uid) { $('#userId').val(uid); }
                    if (pw)  { $('#password').val(pw); }
                    $('input[name="remember"]').prop('checked', true);
                }
            }
        } catch (e) { /* localStorage unavailable — ignore. */ }

        $('#togglePw').on('click', function(){
            var $pw = $('#password');
            var isPw = $pw.attr('type') === 'password';
            $pw.attr('type', isPw ? 'text' : 'password');
            $(this).find('i').attr('class', isPw ? 'bi bi-eye-slash' : 'bi bi-eye');
        });

        function showErr(msg){
            var $e = $('#loginErr');
            $e.text(msg).addClass('show');
            setTimeout(function(){ $e.removeClass('show'); }, 6000);
        }

        function rowIf(rowId, valId, val){
            if (val) { $('#' + valId).text(val); $('#' + rowId).show(); }
            else { $('#' + rowId).hide(); }
        }

        function showBlocked(data){
            var hasDue = !!data.has_due || Number(data.due_amount || 0) > 0;
            if (hasDue) {
                var amount = Number(data.due_amount || 0);
                $('#blockAmount').text('\u20B9' + amount.toLocaleString('en-IN', {minimumFractionDigits:2, maximumFractionDigits:2}));
                var $rs = $('#blockReasons').empty();
                (data.reasons || []).forEach(function(r){ $rs.append($('<li>').text(r)); });
                $('#blockDueWrap').show();
                $('#blockPayWrap').show();
                $('#blockUpi').text(data.upi_id || 'Not set');
                rowIf('blockBankNameRow','blockBankName', data.bank_name);
                rowIf('blockAcctRow','blockAcct', data.account_no);
                rowIf('blockIfscRow','blockIfsc', data.ifsc_code);
                var branch = data.branch_location || data.branch_code;
                rowIf('blockBranchRow','blockBranch', branch);
                if (data.qr_code_path) {
                    $('#blockQrImg').attr('src', data.qr_code_path);
                    $('#blockQrWrap').show();
                } else { $('#blockQrWrap').hide(); }
                $('#blockCopyUpi').toggle(!!data.upi_id);
            } else {
                $('#blockDueWrap').hide();
                $('#blockPayWrap').hide();
                $('#blockQrWrap').hide();
                $('#blockCopyUpi').hide();
            }

            if (data.company_id) {
                $('#blockCompany').text((data.company_name ? data.company_name + ' (' + data.company_id + ')' : data.company_id));
                $('#blockCompanyRow').show();
            } else { $('#blockCompanyRow').hide(); }
            rowIf('blockContactEmailRow','blockContactEmail', data.superadmin_contact_email);
            rowIf('blockContactPhoneRow','blockContactPhone', data.superadmin_contact_phone);

            $('#blockTitle').text(hasDue ? 'Payment required' : 'Account ' + (data.status || 'inactive'));
            $('#blockSubtitle').text(data.message || 'Your admin account cannot sign in right now.');
            $('#blockOverlay').addClass('show');
        }

        $('#blockClose').on('click', function(){ $('#blockOverlay').removeClass('show'); });
        $('#blockOverlay').on('click', function(e){ if (e.target === this) $(this).removeClass('show'); });
        $('#blockCopyUpi').on('click', function(){
            var txt = $('#blockUpi').text();
            if (!txt || txt === 'Not set') return;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(txt);
            } else {
                var ta = document.createElement('textarea'); ta.value = txt; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
            }
            var $b = $(this); var html = $b.html();
            $b.html('<i class="bi bi-check2"></i> Copied');
            setTimeout(function(){ $b.html(html); }, 1500);
        });

        $('#loginForm').on('submit', function(e){
            e.preventDefault();
            var userType = $('#userType').val();
            var userId = $.trim($('#userId').val());
            var password = $('#password').val();
            var companyId = $.trim($('#companyId').val());

            if (!userId || !password) { showErr('Please enter your User ID and Password.'); return; }
            if ((userType === 'admin' || userType === 'employee' || userType === 'sub_lco') && !companyId) { showErr('Please enter your Company ID.'); return; }

            var $btn = $('#submitBtn');
            var original = $btn.html();
            $btn.prop('disabled', true).html('<i class="bi bi-arrow-repeat"></i> Signing in...');

            var formData = new FormData();
            formData.append('userType', userType);
            formData.append('userId', userId);
            formData.append('password', password);
            if (companyId) formData.append('companyId', companyId);
            // __S39D__ Remember-me — send '1' if checkbox ticked
            /* __REMEMBER_ME_PERSIST__ */
            try {
                var rememberOn = $('input[name="remember"]').is(':checked');
                if (rememberOn) {
                    formData.append('remember', '1');
                    var creds = {
                        u: btoa(unescape(encodeURIComponent(userType))),
                        c: btoa(unescape(encodeURIComponent(companyId || ''))),
                        i: btoa(unescape(encodeURIComponent(userId))),
                        p: btoa(unescape(encodeURIComponent(password))),
                        v: 1
                    };
                    localStorage.setItem('aispLoginRemember', JSON.stringify(creds));
                } else {
                    localStorage.removeItem('aispLoginRemember');
                }
            } catch (e) {}

            $.ajax({
                url: '/api/auth/login',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(response){
                    if (response && response.success) {
                        window.location.href = response.redirect;
                    } else if (response && response.blocked) {
                        showBlocked(response);
                        $btn.prop('disabled', false).html(original);
                    } else {
                        showErr((response && response.message) || 'Login failed. Please check your credentials.');
                        $btn.prop('disabled', false).html(original);
                    }
                },
                error: function(xhr){
                    var data = xhr && xhr.responseJSON ? xhr.responseJSON : null;
                    if (data && data.blocked) {
                        showBlocked(data);
                    } else {
                        var msg = (data && data.message) ? data.message : 'Login failed. Please check your credentials.';
                        showErr(msg);
                    }
                    $btn.prop('disabled', false).html(original);
                }
            });
        });

        /* S38j: forgot-password modal with portal-specific fields + captcha */
        window.__s38j_captcha_id = null;
        function s38jLoadCaptcha() {
            var box = document.getElementById('s38j_captcha_svg');
            if (box) box.innerHTML = '<span style=\"color:#94a3b8;font-size:12px;\">Loading...</span>';
            fetch('/api/auth/captcha/new').then(function(r){ return r.json(); })
              .then(function(d){
                  window.__s38j_captcha_id = d.captcha_id;
                  if (box) box.innerHTML = d.svg;
                  $('#s38j_captcha_text').val('');
              })
              .catch(function(){
                  if (box) box.innerHTML = '<span style=\"color:#c0392b;font-size:12px;\">Captcha load failed</span>';
              });
        }
        function s38jApplyFields() {
            var ut = $('#s38h_reset_user_type').val();
            var show = {
                'superadmin': {company:false, username:false, email:true,  userLabel:'Username'},
                'admin':      {company:true,  username:true,  email:true,  userLabel:'Admin Username'},
                'employee':   {company:true,  username:true,  email:true,  userLabel:'Employee Username'},
                'sub_lco':    {company:true,  username:true,  email:true,  userLabel:'Sub-LCO Username'},  /* _S39R5I_RESET_SUBLCO */
                'customer':   {company:false, username:true,  email:true,  userLabel:'Username'}
            }[ut] || {company:false, username:false, email:true, userLabel:'Username'};
            $('.s38j_fld_company').toggle(show.company);
            $('.s38j_fld_username').toggle(show.username);
            $('.s38j_fld_email').toggle(show.email);
            $('#s38j_reset_username_lbl').text(show.userLabel);
        }
        $('#forgot').on('click', function(e){
            e.preventDefault();
            $('#s38h_reset_modal').css('display', 'flex');
            $('#s38h_reset_user_type').val(window.s38h_currentTab || $('input[name=\"userType\"]').val() || 'admin');
            s38jApplyFields();
            $('#s38j_reset_company_id').val($('input[name=\"companyId\"]').val() || '');
            $('#s38j_reset_username').val($('input[name=\"userId\"]').val() || '');
            $('#s38j_reset_email').val('');
            $('#s38h_reset_msg').hide().removeClass('ok err').text('');
            s38jLoadCaptcha();
        });
        $('#s38h_reset_user_type').on('change', s38jApplyFields);
        $('#s38j_captcha_refresh').on('click', s38jLoadCaptcha);
        $('#s38h_reset_close, #s38h_reset_cancel').on('click', function(){
            $('#s38h_reset_modal').hide();
        });
        window.s38h_currentTab = 'admin';
        $(document).on('click', '.login-tab, [data-tab], [role=tab]', function(){
            var ut = $(this).attr('data-tab') || $(this).data('tab') || '';
            if (ut) window.s38h_currentTab = ut;
        });
        $('#s38h_reset_submit').on('click', function(){
            var ut   = $('#s38h_reset_user_type').val();
            var cid  = ($('#s38j_reset_company_id').val()||'').trim();
            var un   = ($('#s38j_reset_username').val()||'').trim();
            var em   = ($('#s38j_reset_email').val()||'').trim();
            var cap  = ($('#s38j_captcha_text').val()||'').trim();
            var $msg = $('#s38h_reset_msg').removeClass('ok err').hide();
            if (ut === 'superadmin' && !em) return $msg.addClass('err').text('Please enter your email.').show();
            if ((ut === 'admin' || ut === 'employee' || ut === 'sub_lco') && !(cid && un && em))
                return $msg.addClass('err').text('Please enter Company ID, Username and Email.').show();
            if (ut === 'customer' && !(un && em))
                return $msg.addClass('err').text('Please enter Username and Email.').show();
            if (!cap || cap.length < 4)
                return $msg.addClass('err').text('Please enter the captcha text.').show();
            if (!window.__s38j_captcha_id)
                return $msg.addClass('err').text('Captcha not loaded - click the refresh icon.').show();

            var $b = $(this); var orig = $b.html();
            $b.prop('disabled', true).html('<i class=\"bi bi-hourglass-split\"></i> Sending...');
            fetch('/api/auth/password-reset/request', {
                method: 'POST', headers: {'Content-Type':'application/json'},
                body: JSON.stringify({
                    userType: ut, companyId: cid, username: un, email: em,
                    captcha_id: window.__s38j_captcha_id, captcha_text: cap
                })
            }).then(function(r){ return r.json().then(function(d){return {s:r.status, d:d};}); })
              .then(function(o){
                  var cls = o.d && o.d.success ? 'ok' : 'err';
                  $msg.addClass(cls).text(o.d.message || 'Request submitted.').show();
                  if (o.d && o.d.refresh_captcha) { s38jLoadCaptcha(); }
                  if (o.d && o.d.success) { s38jLoadCaptcha(); }
              })
              .catch(function(e){ $msg.addClass('err').text('Request failed: '+e).show(); s38jLoadCaptcha(); })
              .then(function(){ $b.prop('disabled', false).html(orig); });
        });
    });
</script>

<!-- __S38H_PASSWORD_RESET__ -->
<div id="s38h_reset_modal" role="dialog" aria-modal="true"
     style="display:none;position:fixed;inset:0;z-index:12000;
            background:rgba(15,23,42,0.72);backdrop-filter:blur(4px);
            align-items:center;justify-content:center;padding:20px;">
  <div style="background:#fff;border-radius:14px;width:100%;max-width:440px;
              box-shadow:0 30px 60px -15px rgba(0,0,0,0.35);
              overflow:hidden;font-family:inherit;">
    <div style="padding:18px 22px;border-bottom:1px solid #eef2f6;display:flex;
                justify-content:space-between;align-items:center;">
      <h4 style="margin:0;font-weight:600;color:#0f172a;">
        <i class="bi bi-key"></i> Reset your password
      </h4>
      <button id="s38h_reset_close" type="button" aria-label="Close"
              style="background:none;border:none;font-size:22px;color:#64748b;
                     cursor:pointer;line-height:1;">&times;</button>
    </div>
    <div style="padding:18px 22px;">
      <p style="margin:0 0 12px;color:#475569;font-size:13px;">
        Select your portal and fill in the details - we'll email a secure
        reset link that expires in 60 minutes.
      </p>
      <div class="form-group">
        <label style="font-size:12px;color:#64748b;">Portal</label>
        <select id="s38h_reset_user_type" class="form-control">
          <option value="superadmin">Superadmin</option>
          <option value="admin" selected>Admin</option>
          <option value="sub_lco" data-tag="_S39R5I_RESET_SUBLCO _S39R5T_REORDER_">Sub-LCO</option>
          <option value="employee">Employee</option>
          <option value="customer">Customer</option>
        </select>
      </div>
      <div class="form-group s38j_fld_company" style="margin-top:10px;">
        <label style="font-size:12px;color:#64748b;">Company ID</label>
        <input id="s38j_reset_company_id" type="text" class="form-control"
               placeholder="e.g. 14150129" data-testid="reset-company-id">
      </div>
      <div class="form-group s38j_fld_username" style="margin-top:10px;">
        <label style="font-size:12px;color:#64748b;"
               id="s38j_reset_username_lbl">Username</label>
        <input id="s38j_reset_username" type="text" class="form-control"
               placeholder="your login username" data-testid="reset-username">
      </div>
      <div class="form-group s38j_fld_email" style="margin-top:10px;">
        <label style="font-size:12px;color:#64748b;">Registered Email</label>
        <input id="s38j_reset_email" type="email" class="form-control"
               placeholder="you@company.com" data-testid="reset-email">
