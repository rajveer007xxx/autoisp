<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/png" href="/static/favicon.png">
    <link rel="apple-touch-icon" href="/static/favicon.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in &middot; Auto ISP Billing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Space+Grotesk:wght@500;600;700&amp;display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root{
            --brand-500:#3d5afe;--accent-400:#22e1c2;
            --ink-900:#0b1224;--ink-700:#2b3552;--ink-500:#5c6785;--ink-300:#aab2c8;
            --line:#e4e8f3;--surface:#f6f8fc;
            --radius-lg:20px;--radius-md:12px;
            --shadow-lg:0 25px 60px rgba(11,18,36,.18);
        }
        *{box-sizing:border-box}
        html,body{margin:0;padding:0;min-height:100%;font-family:'Inter',system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:var(--ink-900);background:#f2f4fb;-webkit-font-smoothing:antialiased}
        a{text-decoration:none;color:inherit}
        h1,h2,h3,h4{font-family:'Space Grotesk','Inter',sans-serif;font-weight:700;letter-spacing:-.02em;margin:0}
        p{margin:0;line-height:1.6;color:var(--ink-500)}
        img{max-width:100%;display:block}

        .page{min-height:100vh;display:grid;grid-template-columns:1.05fr 1fr}
        /* LEFT PANEL */
        .panel{position:relative;color:#fff;overflow:hidden;padding:40px 56px;display:flex;flex-direction:column;justify-content:space-between;background:radial-gradient(900px 500px at 85% 0%,rgba(124,58,255,.45),transparent 60%),radial-gradient(700px 400px at 0% 100%,rgba(0,212,180,.35),transparent 60%),linear-gradient(135deg,#06102e 0%,#0b1a4a 45%,#1a2d7d 100%)}
        .panel::before{content:"";position:absolute;inset:0;background-image:url('https://images.unsplash.com/photo-1544197150-b99a580bb7a8?auto=format&fit=crop&w=1600&q=70');background-size:cover;background-position:center;opacity:.22;mix-blend-mode:screen;pointer-events:none}
        .panel::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 0%,rgba(6,16,46,.0) 40%,rgba(6,16,46,.55) 100%);pointer-events:none}
        .p-inner{position:relative;z-index:2;display:flex;flex-direction:column;height:100%}
        .brand{display:flex;align-items:center;gap:10px;color:#fff;font-weight:700;font-size:1.15rem}
        .brand-logo{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--brand-500),#7c3aff);display:grid;place-items:center;color:#fff;box-shadow:0 10px 30px rgba(61,90,254,.35)}
        .p-headline{margin-top:auto;padding-top:40px}
        .p-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:#d5dcff;padding:.4rem .9rem;border-radius:999px;font-size:.82rem;font-weight:500}
        .p-eyebrow .dot{width:8px;height:8px;background:var(--accent-400);border-radius:50%;box-shadow:0 0 0 4px rgba(34,225,194,.18)}
        .p-headline h2{font-size:clamp(1.8rem,3vw,2.5rem);margin-top:18px;line-height:1.15;background:linear-gradient(180deg,#fff,#cfd6ff);-webkit-background-clip:text;background-clip:text;color:transparent}
        .p-headline p{color:rgba(255,255,255,.78);margin-top:14px;max-width:44ch}

        .stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:32px 0 16px}
        .stat-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:14px;backdrop-filter:blur(6px)}
        .stat-card strong{display:block;font-family:'Space Grotesk';font-size:1.35rem}
        .stat-card span{font-size:.78rem;color:rgba(255,255,255,.7)}
        .int-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:18px}
        .int-chip{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#dfe4ff;padding:.3rem .7rem;border-radius:999px;font-size:.8rem;font-weight:500;display:inline-flex;gap:6px;align-items:center}
        .int-chip i{color:var(--accent-400)}

        .feature-list{list-style:none;padding:0;margin:28px 0 0;display:grid;gap:12px}
        .feature-list li{display:flex;gap:12px;align-items:flex-start;color:rgba(255,255,255,.88);font-size:.95rem}
        .feature-list li i{color:var(--accent-400);margin-top:3px;font-size:1.05rem}

        /* RIGHT PANEL */
        .form-side{display:flex;align-items:center;justify-content:center;padding:40px 24px;background:#f6f8fc}
        .form-wrap{width:100%;max-width:460px;background:#fff;border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);padding:40px 36px;border:1px solid #ecf0f7;position:relative}
        .form-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
        .form-top a{font-size:.88rem;color:var(--ink-500);display:inline-flex;gap:6px;align-items:center}
        .form-top a:hover{color:var(--brand-500)}
        .form-wrap h1{font-size:1.55rem}
        .form-wrap .subtitle{color:var(--ink-500);margin-top:6px;font-size:.95rem}

        .role-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:22px 0 10px;background:#f2f4fb;padding:6px;border-radius:14px;border:1px solid #e4e8f3}
        .role{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:10px 6px;border-radius:10px;cursor:pointer;font-size:.78rem;font-weight:600;color:var(--ink-500);transition:background .15s ease,color .15s ease,box-shadow .15s ease,transform .15s ease}
        .role i{font-size:1.1rem}
        .role:hover{color:var(--ink-900)}
        .role.active{background:#fff;color:var(--ink-900);box-shadow:0 2px 8px rgba(11,18,36,.08)}
        .role.active i{color:var(--brand-500)}

        .form-control{border-radius:12px;padding:14px 14px 14px 44px;border:1.5px solid var(--line);font-size:.95rem;height:auto;background:#fff}
        .form-control:focus{border-color:var(--brand-500);box-shadow:0 0 0 4px rgba(61,90,254,.15)}
        .field{position:relative;margin-bottom:14px}
        .field i.field-ico{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:var(--ink-500);font-size:1.02rem;pointer-events:none}
        .field .toggle-pw{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:transparent;border:0;color:var(--ink-500);font-size:1rem;cursor:pointer;padding:4px}
        .field .toggle-pw:hover{color:var(--brand-500)}
        .field label{font-size:.82rem;font-weight:600;color:var(--ink-700);margin-bottom:6px;display:block}

        .row-inline{display:flex;align-items:center;justify-content:space-between;margin:6px 0 18px;font-size:.88rem}
        .row-inline label{display:flex;align-items:center;gap:6px;color:var(--ink-700);cursor:pointer;margin:0}
        .row-inline a{color:var(--brand-500);font-weight:600}

        .btn-submit{width:100%;border:0;border-radius:999px;padding:14px 20px;font-weight:700;color:#fff;background:linear-gradient(135deg,var(--brand-500),#7c3aff);box-shadow:0 14px 30px rgba(61,90,254,.35);cursor:pointer;transition:transform .15s ease,box-shadow .2s ease;display:inline-flex;gap:8px;align-items:center;justify-content:center}
        .btn-submit:hover{transform:translateY(-1px);box-shadow:0 20px 40px rgba(61,90,254,.4)}
        .btn-submit[disabled]{opacity:.7;cursor:not-allowed;transform:none}

        .form-footer{margin-top:18px;text-align:center;font-size:.88rem;color:var(--ink-500)}
        .form-footer a{color:var(--brand-500);font-weight:600}

        .secure{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:18px;font-size:.8rem;color:var(--ink-500)}
        .secure i{color:var(--accent-400)}

        .alert-err{display:none;margin-bottom:14px;padding:10px 14px;border-radius:10px;background:#fff1f2;color:#b42330;border:1px solid #fecdd3;font-size:.88rem}
        .alert-err.show{display:block}

        /* Blocked-login modal */
        .block-overlay{display:none;position:fixed;inset:0;background:rgba(11,18,36,.65);backdrop-filter:blur(4px);z-index:1000;align-items:center;justify-content:center;padding:20px}
        .block-overlay.show{display:flex}
        .block-card{background:#fff;border-radius:20px;max-width:520px;width:100%;box-shadow:0 30px 80px rgba(11,18,36,.35);overflow:hidden;max-height:92vh;overflow-y:auto}
        .block-head{padding:22px 26px;background:linear-gradient(135deg,#b42330,#7a1420);color:#fff;display:flex;gap:14px;align-items:center}
        .block-head i{font-size:1.9rem}
        .block-head h3{font-size:1.25rem;margin:0}
        .block-head p{margin:4px 0 0;color:rgba(255,255,255,.85);font-size:.85rem}
        .block-body{padding:22px 26px;display:grid;gap:14px}
        .block-due{background:#fff7ed;border:1px solid #fed7aa;border-radius:14px;padding:14px 16px}
        .block-due .lbl{color:#9a3412;font-weight:600;font-size:.8rem;text-transform:uppercase;letter-spacing:.04em}
        .block-due .amt{color:#7c2d12;font-size:1.7rem;font-weight:800;font-family:'Space Grotesk',sans-serif;margin-top:2px}
        .block-reasons{margin:0;padding-left:18px;color:var(--ink-700);font-size:.88rem;display:grid;gap:4px}
        .block-pay{background:#f6f8fc;border:1px solid var(--line);border-radius:14px;padding:14px 16px;display:grid;gap:10px}
        .block-pay .row{display:flex;justify-content:space-between;gap:10px;align-items:center;font-size:.9rem}
        .block-pay .row .lbl{color:var(--ink-500);font-size:.78rem;text-transform:uppercase;letter-spacing:.04em;font-weight:600}
        .block-pay .row .val{color:var(--ink-900);font-weight:600;word-break:break-all;text-align:right}
        .block-qr{text-align:center;padding:12px;background:#fff;border:1px dashed var(--line);border-radius:14px}
        .block-qr img{max-width:220px;margin:0 auto;border-radius:8px}
        .block-qr .cap{margin-top:8px;font-size:.8rem;color:var(--ink-500)}
        .block-actions{display:flex;gap:10px;justify-content:flex-end;padding:14px 26px 22px}
        .block-actions button{border:0;border-radius:999px;padding:10px 18px;font-weight:600;cursor:pointer}
        .block-actions .btn-close-block{background:#e4e8f3;color:var(--ink-700)}
        .block-actions .btn-copy-upi{background:linear-gradient(135deg,var(--brand-500),#7c3aff);color:#fff;display:inline-flex;gap:6px;align-items:center}

        @media (max-width:991px){
            .page{grid-template-columns:1fr}
            .panel{display:none}
            .form-side{padding:32px 16px;background:radial-gradient(900px 500px at 85% 0%,rgba(124,58,255,.2),transparent 60%),radial-gradient(700px 400px at 0% 100%,rgba(0,212,180,.16),transparent 60%),linear-gradient(135deg,#f2f4fb 0%,#eef1fb 100%)}
        }
        @media (max-width:420px){
            .form-wrap{padding:30px 22px}
            .role-grid{grid-template-columns:repeat(4,1fr)}
            .role{font-size:.7rem;padding:8px 4px}
            .role i{font-size:1rem}
        }
    

/* ═════ S55K · Telecom Cloud OS dark login redesign ═════ */
:root{
  --t-bg-0:#050810; --t-bg-1:#0a0f1c; --t-bg-2:#101826;
  --t-surface:rgba(16,24,38,.72); --t-surface-elev:rgba(20,30,48,.88);
  --t-border:rgba(99,102,241,.20); --t-border-strong:rgba(99,102,241,.40);
  --t-cyan:#22d3ee; --t-indigo:#6366f1; --t-violet:#a855f7;
  --t-fg:#F1F5F9; --t-fg-soft:#CBD5E1; --t-fg-mute:#94A3B8;
}
html, body{
  background:
    radial-gradient(1100px 600px at 15% -10%, rgba(99,102,241,.22), transparent 60%),
    radial-gradient(900px 700px at 90% 5%,   rgba(34,211,238,.14),  transparent 60%),
    radial-gradient(700px 500px at 50% 110%, rgba(168,85,247,.10),  transparent 65%),
    linear-gradient(180deg,#050810 0%,#070b14 100%) !important;
  background-attachment: fixed !important;
  color: var(--t-fg) !important;
}
body::before{
  content:''; position:fixed; inset:0; pointer-events:none; z-index:0;
  background-image:
    linear-gradient(rgba(99,102,241,.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(99,102,241,.045) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
}

.page{ position: relative; z-index: 1; min-height: 100vh; }

/* LEFT PANEL — full dark with fiber lines and floating blobs */
.panel{
  background:
    radial-gradient(900px 500px at 85% 0%,  rgba(168,85,247,.30), transparent 60%),
    radial-gradient(700px 400px at 0% 100%, rgba(34,211,238,.22), transparent 60%),
    linear-gradient(135deg,#050810 0%,#0a1024 45%,#0a1530 100%) !important;
  border-right: 1px solid var(--t-border);
}
.panel::before{
  background-image: none !important;
  background:
    radial-gradient(circle at 30% 20%, rgba(99,102,241,.20), transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(34,211,238,.18), transparent 50%) !important;
  opacity: .9 !important;
  mix-blend-mode: normal !important;
}
.panel::after{ background: none !important; }

/* Animated fiber stripes overlaid on left panel */
.panel .p-inner::before{
  content:''; position:absolute; inset:0; pointer-events:none; z-index:0;
  background:
    linear-gradient(90deg, transparent 0%, var(--t-cyan) 50%, transparent 100%) no-repeat;
  background-size: 60% 1px;
  background-position: -60% 22%;
  filter: drop-shadow(0 0 6px var(--t-cyan));
  animation: s55k-fiber 7s linear infinite;
}
.panel .p-inner::after{
  content:''; position:absolute; inset:0; pointer-events:none; z-index:0;
  background:
    linear-gradient(90deg, transparent 0%, var(--t-violet) 50%, transparent 100%) no-repeat;
  background-size: 80% 1px;
  background-position: -80% 64%;
  filter: drop-shadow(0 0 6px var(--t-violet));
  animation: s55k-fiber 9s linear infinite;
  animation-delay: -3s;
}
@keyframes s55k-fiber{
  0%   { background-position: -60% var(--p, 22%); opacity: 0; }
  10%  { opacity: .8; }
  90%  { opacity: .8; }
  100% { background-position: 160% var(--p, 22%); opacity: 0; }
}
.p-inner{ position: relative; z-index: 2; }
.p-inner > * { position: relative; z-index: 2; }

.brand img{ filter: brightness(1.2) drop-shadow(0 4px 12px rgba(99,102,241,.4)); }

.p-eyebrow{
  background: rgba(34,211,238,.10) !important;
  border: 1px solid rgba(34,211,238,.32) !important;
  color: var(--t-cyan) !important;
  font-family: 'JetBrains Mono','SF Mono',monospace;
  text-transform: uppercase; letter-spacing: .10em; font-size: 11px !important;
}
.p-eyebrow .dot{ background: var(--t-cyan) !important; box-shadow: 0 0 8px var(--t-cyan) !important; }

.p-headline h2{
  font-family: 'Plus Jakarta Sans','Space Grotesk',sans-serif !important;
  font-weight: 800 !important;
  color: #ffffff !important;
  background: none !important;
  -webkit-background-clip: initial !important; background-clip: initial !important;
  text-shadow: 0 2px 20px rgba(99,102,241,.35);
}
.p-headline p{ color: var(--t-fg-soft) !important; }

.stat-card{
  background: var(--t-surface) !important;
  border: 1px solid var(--t-border) !important;
  backdrop-filter: blur(20px) saturate(140%) !important;
  -webkit-backdrop-filter: blur(20px) saturate(140%) !important;
}
.stat-card strong{
  font-family: 'Plus Jakarta Sans',sans-serif !important;
  background: linear-gradient(135deg,#fff,#94a3b8);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.stat-card span{ color: var(--t-fg-mute) !important; font-family: 'JetBrains Mono',monospace; font-size: 11px !important; text-transform: uppercase; letter-spacing: .08em; }

.int-chip{
  background: rgba(255,255,255,.04) !important;
  border: 1px solid var(--t-border) !important;
  color: var(--t-fg-soft) !important;
}
.int-chip i{ color: var(--t-cyan) !important; }

.feature-list li{ color: var(--t-fg-soft) !important; }
.feature-list li i{ color: var(--t-cyan) !important; }

/* RIGHT PANEL — dark glass form */
.form-side{
  background: transparent !important;
  position: relative; z-index: 1;
}
.form-wrap{
  background: var(--t-surface-elev) !important;
  border: 1px solid var(--t-border-strong) !important;
  border-radius: 24px !important;
  box-shadow:
    0 30px 80px rgba(0,0,0,.55),
    0 10px 24px rgba(0,0,0,.35),
    inset 0 1px 0 rgba(255,255,255,.06) !important;
  backdrop-filter: blur(24px) saturate(160%) !important;
  -webkit-backdrop-filter: blur(24px) saturate(160%) !important;
}
.form-top a{ color: var(--t-fg-mute) !important; }
.form-top a:hover{ color: var(--t-cyan) !important; }
.form-wrap h1{
  color: #fff !important;
  font-family: 'Plus Jakarta Sans',sans-serif !important;
  font-weight: 800 !important;
}
.form-wrap .subtitle{ color: var(--t-fg-mute) !important; }

/* Role tabs — single row of 5, glass dark */
.role-grid{
  display: grid !important;
  grid-template-columns: repeat(5, 1fr) !important;
  gap: 6px !important;
  background: rgba(8,12,22,.7) !important;
  border: 1px solid var(--t-border) !important;
  padding: 6px !important;
  border-radius: 14px !important;
}
.role{
  color: var(--t-fg-mute) !important;
  padding: 12px 4px !important;
  font-size: 11.5px !important;
  font-weight: 600 !important;
  border-radius: 10px !important;
}
.role i{ font-size: 18px !important; color: var(--t-fg-soft) !important; }
.role:hover{
  color: #fff !important;
  background: rgba(99,102,241,.10) !important;
}
.role:hover i{ color: var(--t-cyan) !important; }
.role.active{
  background: linear-gradient(135deg,rgba(99,102,241,.20),rgba(34,211,238,.12)) !important;
  color: #fff !important;
  border: 1px solid var(--t-border-strong) !important;
  box-shadow: 0 4px 14px rgba(99,102,241,.35), inset 0 1px 0 rgba(255,255,255,.10) !important;
}
.role.active i{ color: var(--t-cyan) !important; }

/* Fields */
.field label{ color: var(--t-fg-soft) !important; font-size: 12.5px !important; font-weight: 600 !important; }
.field i.field-ico{ color: var(--t-fg-mute) !important; }
.form-control{
  background: rgba(8,12,22,.6) !important;
  border: 1px solid var(--t-border) !important;
  color: #fff !important;
  border-radius: 12px !important;
}
.form-control::placeholder{ color: var(--t-fg-mute) !important; opacity: 1 !important; }
.form-control:focus{
  background: rgba(8,12,22,.85) !important;
  border-color: var(--t-cyan) !important;
  box-shadow: 0 0 0 4px rgba(34,211,238,.18) !important;
  color: #fff !important;
}
.field .toggle-pw{ color: var(--t-fg-mute) !important; }
.field .toggle-pw:hover{ color: var(--t-cyan) !important; }

.row-inline label{ color: var(--t-fg-soft) !important; }
.row-inline a{ color: var(--t-cyan) !important; }
.row-inline input[type=checkbox]{ accent-color: var(--t-indigo); }

.btn-submit{
  background: linear-gradient(135deg, var(--t-indigo) 0%, #4f46e5 100%) !important;
  border-radius: 12px !important;
  box-shadow: 0 12px 30px rgba(99,102,241,.45), inset 0 1px 0 rgba(255,255,255,.18) !important;
  font-weight: 700 !important;
  padding: 14px 22px !important;
}
.btn-submit:hover{ box-shadow: 0 18px 40px rgba(99,102,241,.55), inset 0 1px 0 rgba(255,255,255,.22) !important; transform: translateY(-2px) !important; }

.form-footer{ color: var(--t-fg-mute) !important; }
.form-footer a{ color: var(--t-cyan) !important; }
.secure{ color: var(--t-fg-mute) !important; }
.secure i{ color: var(--t-cyan) !important; }

.alert-err{
  background: rgba(248,113,113,.10) !important;
  color: #fda4af !important;
  border: 1px solid rgba(248,113,113,.30) !important;
  border-radius: 10px !important;
}

/* Mobile: stack but keep all 5 visible (smaller text) */
@media (max-width: 991px){
  .form-side{ background:
    radial-gradient(900px 500px at 85% 0%, rgba(168,85,247,.18), transparent 60%),
    radial-gradient(700px 400px at 0% 100%, rgba(34,211,238,.14), transparent 60%),
    linear-gradient(180deg, #050810 0%, #070b14 100%) !important; }
}
@media (max-width: 480px){
  .role-grid{ grid-template-columns: repeat(5, 1fr) !important; gap: 4px !important; padding: 4px !important; }
  .role{ font-size: 9.5px !important; padding: 8px 2px !important; }
  .role i{ font-size: 14px !important; }
  .form-wrap{ padding: 28px 20px !important; }
}

/* Blocked-login modal — keep dark */
.block-card{ background: var(--t-bg-2) !important; border: 1px solid var(--t-border-strong) !important; }
.block-pay{ background: rgba(8,12,22,.6) !important; border-color: var(--t-border) !important; }
.block-pay .row .lbl{ color: var(--t-fg-mute) !important; }
.block-pay .row .val{ color: #fff !important; }
.block-reasons{ color: var(--t-fg-soft) !important; }
/* ═════ /S55K ═════ */

</style>
