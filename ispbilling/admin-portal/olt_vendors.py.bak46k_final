def _reachable(host: str, timeout: float = 1.0) -> bool:
    if not host:
        return False
    try:
        socket.setdefaulttimeout(timeout)
        socket.gethostbyname(host)
        return True
    except Exception:
        return False


_VAL_RE = re.compile(r"^(?P<oid>\S+)\s*=\s*(?:\S+:\s*)?(?P<val>.*)$")


def _parse_line(line: str) -> Optional[Tuple[str, str]]:
    m = _VAL_RE.match(line)
    if not m:
        return None
    raw = m.group("val").strip()
    if raw.startswith('"') and raw.endswith('"'):
        raw = raw[1:-1]
    return m.group("oid"), raw


def _snmp_get(host: str, community: str, port: int, oid: str,
              version: str = "v2c", timeout: float = 2.0) -> Optional[str]:
    if not _SNMPGET:
        return None
    cmd = [_SNMPGET, "-v", "2c" if version != "v3" else "3", "-c", community,
           "-On", "-Ovq", "-t", str(int(timeout)), "-r", "0",
           f"{host}:{int(port)}", oid]
    try:
        out = subprocess.run(cmd, capture_output=True, text=True,
                             timeout=timeout + 1.5)
        if out.returncode != 0:
            return None
        return out.stdout.strip().strip('"')
    except Exception:
        return None


def _snmp_walk(host: str, community: str, port: int, base_oid: str,
               version: str = "v2c", timeout: float = 3.0
               ) -> List[Tuple[str, str]]:
    if not _SNMPWALK:
        return []
    # _S45F_SNMPWALK_FIX — Remove invalid '-Cr20' flag (that's a snmpbulkwalk
    # option). Normalize OID prefix matching so both '.1.3.6...' (output of
    # snmpwalk -On) and '1.3.6...' (config-supplied base_oid) match. This was
    # silently returning 0 rows for every poll.
    cmd = [_SNMPWALK, "-v", "2c" if version != "v3" else "3", "-c", community,
           "-On", "-t", str(int(timeout)), "-r", "1",
           f"{host}:{int(port)}", base_oid]
    try:
        out = subprocess.run(cmd, capture_output=True, text=True,
                             timeout=timeout + 8.0)
        if out.returncode != 0 and not out.stdout.strip():
            return []
        rows: List[Tuple[str, str]] = []
        nbase = base_oid.lstrip(".")
        for line in out.stdout.splitlines():
            p = _parse_line(line)
            if not p:
                continue
            full, val = p
            nfull = full.lstrip(".")
            if not nfull.startswith(nbase):
                continue
            suffix = nfull[len(nbase):].lstrip(".")
            rows.append((suffix, val))
        return rows
    except Exception:
        return []


def poll_real(olt: dict) -> Tuple[bool, Optional[str], dict, list]:
    vendor = (olt.get("vendor") or "").lower()
    profile = VENDOR_PROFILES.get(vendor)
    if not profile:
        return False, f"No SNMP profile for vendor '{vendor}'", {}, []
    if not _SNMP_AVAILABLE:
        return False, ("net-snmp tools not installed (`apt install snmp`) "
                       "— required for live SNMP polling."), {}, []
    host = olt.get("host") or ""
    if not _reachable(host):
        return False, f"Host {host} not resolvable / unreachable", {}, []
    community = olt.get("snmp_community") or "public"
    port = int(olt.get("snmp_port") or 161)
    version = (olt.get("snmp_version") or "v2c").lower()

    sys_descr = _snmp_get(host, community, port, profile["sys_descr"], version)
    if sys_descr is None:
        return False, (f"SNMP timeout against {host}:{port} (community "
                       f"'{community}'). Verify the OLT allows SNMP from "
                       "this server's IP and the community matches."), {}, []

    def _f(oid_key: str, default: float = 0.0) -> float:
        oid = profile.get(oid_key)
        if not oid:
            return default
        v = _snmp_get(host, community, port, oid, version)
        try:
            f = float(v) if v is not None else default
            return f
        except Exception:
            return default

    olt_meta = {
        "status": "online",
        "uptime_sec": int(_f("sys_uptime") / 100),
        "cpu_pct": _f("cpu"),
        "mem_pct": _f("mem"),
        "temp_c": _f("temp"),
        "sys_descr": sys_descr,
    }

    serials  = dict(_snmp_walk(host, community, port, profile["onu_serial"], version))
    statuses = dict(_snmp_walk(host, community, port, profile["onu_status"], version))
    rxs      = dict(_snmp_walk(host, community, port, profile["onu_rx"], version)) if profile.get("onu_rx") else {}
    txs      = dict(_snmp_walk(host, community, port, profile["onu_tx"], version)) if profile.get("onu_tx") else {}
    dists    = dict(_snmp_walk(host, community, port,
                               profile.get("onu_distance") or
                               profile["onu_status"], version)) if profile.get("onu_distance") else {}
    # _S46A_  Separate MAC walk when vendor exposes it (EPON V1600D uses
    # the same OID for canonical id AND mac — both ok).
    macs     = dict(_snmp_walk(host, community, port, profile["onu_mac"], version))                if profile.get("onu_mac") else {}

    # _S45F_PON_INDEX — when the profile defines a separate onu_pon OID
    # (PON-port lookup), use it instead of guessing from the OID suffix.
    pons_lookup = {}
    if profile.get("onu_pon"):
        pons_lookup = dict(_snmp_walk(host, community, port,
                                       profile["onu_pon"], version))
    onus: List[Dict[str, Any]] = []
    # _S46K_  Walk the global ONU-id column (.1.X) — used to join
    # telnet running-config (which references `onu N` by global id).
    onu_global = dict(_snmp_walk(host, community, port,
                                 "1.3.6.1.4.1.37950.1.1.5.12.1.9.1.1",
                                 version, timeout=3.0)) or {}

    # _S46E_  Walk ifDescr ONCE — VSOL/Netlink/Syrotech EPON OLTs all
    # expose ONU sub-interfaces as `EPON<PON>ONU<N> <LABEL>`. Extract
    # an ordered positional list of (pon, onu_idx, label) tuples; we
    # then zip it with the serials/MACs walk (both enumerate ONUs in
    # registration order so a positional join is reliable).
    ifdescr = dict(_snmp_walk(host, community, port,
                              "1.3.6.1.2.1.2.2.1.2", version,
                              timeout=3.0)) or {}
    import re as _re
    _epon_pat = _re.compile(
        r"^(?:epon|gpon)(\d+)(?:/|onu)(\d+)(?:[\s_].*)?$", _re.I)
    def _sort_key(item):
        try: return int(item[0])
        except Exception: return 0
    name_list: List[tuple] = []
    for suf, name in sorted(ifdescr.items(), key=_sort_key):
        m_ = _epon_pat.match((name or "").strip())
        if m_:
            try:
                tail = (name or "").split(None, 1)
                label = tail[1] if len(tail) > 1 else ""
                name_list.append(
                    (int(m_.group(1)), int(m_.group(2)), label))
            except Exception:
                pass

    # PON upper bound: prefer ifDescr-derived list (most authoritative)
    if name_list:
        try:
            _pon_upper = max(1, min(8, max(p for (p, _i, _l) in name_list)))
        except Exception:
            _pon_upper = 8
    else:
        _pon_upper = 16

    _per_pon_counter: Dict[int, int] = {}
    _serials_sorted = sorted(serials.items(), key=lambda kv: _sort_key(kv))
    _name_iter = iter(name_list)
    for suffix, serial in _serials_sorted:
        hit = next(_name_iter, None)
        if hit is not None:
            pon, idx, _label = hit
            pon = max(1, min(_pon_upper, pon))
            _onu_label = _label
        elif pons_lookup:
            # _S46I2_  Clamp into the discovered PON range and use a
            # per-PON sequential counter so we never land outside
            # [1, _pon_upper]. Outliers from .3.X get bucket-9 mapped
            # into PON 1 (typical pattern: PON 1 has stragglers).
            try:
                raw_pon = int(pons_lookup.get(suffix, "0"))
            except Exception:
                raw_pon = 0
            if raw_pon < 0 or raw_pon >= _pon_upper:
                # stale / out-of-range value — assign to PON 1
                pon = 1
            else:
                pon = max(1, raw_pon + 1)
            _per_pon_counter[pon] = _per_pon_counter.get(pon, 0) + 1
            idx = _per_pon_counter[pon]
            _onu_label = ""
        else:
            _onu_label = ""
            parts = suffix.split(".")
            try:
                pon = int(parts[0])
                idx = int(parts[1]) if len(parts) > 1 else int(parts[0])
            except Exception:
                pon, idx = 1, len(onus) + 1
        st_raw = (statuses.get(suffix) or "").strip()
        kws = profile.get("online_keywords") or []
        st_low = st_raw.lower()
        if any(kw.lower() in st_low for kw in kws):
            status = "online"
        elif st_raw and ("1" in st_raw[:2] or "online" in st_low or "active" in st_low):
            status = "online"
        else:
            status = "offline"
        try:
            rx = float(rxs.get(suffix) or 0)
            if rx and abs(rx) > 100:
                rx = rx / 100.0
        except Exception:
            rx = None
        try:
            tx = float(txs.get(suffix) or 0)
            if tx and abs(tx) > 100:
                tx = tx / 100.0
        except Exception:
            tx = None
        try:
            dist = int(dists.get(suffix) or 0)
        except Exception:
            dist = 0
        mac_val = (macs.get(suffix) or "").strip()
        ser_val = str(serial)[:64]
        if re.match(r"^[0-9a-fA-F]{2}([:\-][0-9a-fA-F]{2}){5}$", ser_val) and not mac_val:
            mac_val = ser_val
        # _S46I_  No PON 0 / ONU 0 ever — the user's UI starts from 1.
        pon = max(1, int(pon))
        idx = max(1, int(idx))
        onus.append({
            "pon_port_index": pon, "onu_index": idx,
            "serial": ser_val, "mac": mac_val,
            "vendor": vendor, "model": profile.get("label", ""),
            "rx_power": rx, "tx_power": tx, "distance_m": dist,
            "status": status, "uptime_sec": 0,
            "name_hint": _onu_label or None,
            "last_seen": time.strftime("%Y-%m-%dT%H:%M:%SZ",
                                        time.gmtime()),
        })
    return True, None, olt_meta, onus


# _S46J_  Telnet-based RX/TX + running-config scraper for VSOL EPON.
def poll_via_telnet(olt: dict) -> dict:
    """Returns {"optical": {(pon,idx):(rx,tx)}, "config": {idx: {…}}}.
    Best-effort — empty results on any failure. Uses CLI credentials
    from `olt['cli_username']/['cli_password']` (set per-OLT in System
    Config) and enable-pwd defaults to the user password."""
    host = (olt.get("host") or "").strip()
    user = (olt.get("cli_username") or "admin").strip()
    pwd  = (olt.get("cli_password") or olt.get("snmp_community") or "admin").strip()
    enable_pwd = (olt.get("cli_enable_pwd") or pwd).strip()
    port = int(olt.get("telnet_port") or 23)
    result = {"optical": {}, "config": {}}
    if not host or not pwd:
        return result
    try:
        import telnetlib, time as _t, re as _re
        tn = telnetlib.Telnet(host, port, timeout=10)
        tn.read_until(b"login:", timeout=4)
        tn.write((user + "\n").encode())
        tn.read_until(b"assword:", timeout=4)
        tn.write((pwd + "\n").encode())
        _t.sleep(1.5)
        banner = tn.read_very_eager().decode("utf-8", errors="ignore")
        if "Bad" in banner or "Failed" in banner:
            tn.close(); return result
        # Try to enter privileged mode (best-effort — many commands work
        # at user level too).
        tn.write(b"enable\n"); _t.sleep(0.6)
        tn.read_very_eager()
        tn.write((enable_pwd + "\n").encode()); _t.sleep(1.5)
        tn.read_very_eager()
        tn.write(b"terminal length 0\n"); _t.sleep(0.5)
        tn.read_very_eager()

        # 1) Try various optical-info commands (some vendors do expose them).
        out = b""
        for cmd in (b"show onu opt-info\n",
                    b"show onu opt-power\n",
                    b"show onu information all\n",
                    b"show pon onu opt-info\n",
                    b"show interface epon0/1 onu info\n"):
            tn.write(cmd); _t.sleep(1.2)
            try: out += tn.read_very_eager()
            except Exception: pass
        rx_pat = _re.compile(
            r"(?:e?pon)\s*0?[/\s]?(\d+)[:\s/]+(\d+).{0,200}?"
            r"(-?\d+(?:\.\d+)?)\s*dBm.{0,40}?(-?\d+(?:\.\d+)?)\s*dBm",
            _re.I | _re.S)
        for m in rx_pat.finditer(out.decode("utf-8", errors="ignore")):
            try:
                pon = int(m.group(1)); idx = int(m.group(2))
                rx  = float(m.group(3)); tx = float(m.group(4))
                if -45 <= rx <= 5 and -45 <= tx <= 10:
                    result["optical"][(pon, idx)] = (rx, tx)
            except Exception: pass

        # 2) Scrape running-config for ONU metadata.
        tn.write(b"show running-config\n"); _t.sleep(3.5)
        cfg_blob = b""
        for _ in range(8):
            try: cfg_blob += tn.read_very_eager()
            except Exception: break
            if not cfg_blob.endswith(b" ") and b"#" in cfg_blob[-30:]:
                pass
            _t.sleep(0.4)
        cfg = cfg_blob.decode("utf-8", errors="ignore")
        # Per-ONU description
        for m in _re.finditer(r"^onu\s+(\d+)\s+description\s+(\S+)",
                                cfg, _re.M):
            idx = int(m.group(1))
            result["config"].setdefault(idx, {})["name"] = m.group(2).strip()
        # Wi-Fi SSID (first SSID name only)
        for m in _re.finditer(
            r"^onu\s+(\d+)\s+pri\s+wifi_ssid\s+\d+\s+name\s+(\S+)",
            cfg, _re.M):
            idx = int(m.group(1))
            result["config"].setdefault(idx, {})["wifi_ssid"] = m.group(2).strip()
        # WAN PPPoE
        for m in _re.finditer(
            r"^onu\s+(\d+)\s+pri\s+wan_adv\s+index\s+\d+\s+route\s+ipv4\s+pppoe[^\n]*user\s+(\S+)",
            cfg, _re.M):
            idx = int(m.group(1))
            d = result["config"].setdefault(idx, {})
            d["wan_mode"] = "pppoe"
            d["wan_username"] = m.group(2).strip()
        # WAN static IP
        for m in _re.finditer(
            r"^onu\s+(\d+)\s+pri\s+wan_conn\s+index\s+\d+\s+route\s+internet[^\n]*static\s+ip\s+(\S+)",
            cfg, _re.M):
            idx = int(m.group(1))
            d = result["config"].setdefault(idx, {})
            d["wan_mode"] = "static"
            d["wan_static_ip"] = m.group(2).strip()

        try: tn.write(b"exit\n"); tn.close()
        except Exception: pass
    except Exception:
        pass
    return result


# Backwards-compatible alias for the older callsite (returns optical only).
def poll_optical_via_telnet(olt: dict) -> Dict[tuple, tuple]:
    return (poll_via_telnet(olt) or {}).get("optical", {}) or {}
