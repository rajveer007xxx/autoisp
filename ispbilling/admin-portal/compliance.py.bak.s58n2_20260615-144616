            fname = f"audit_logs_{stamp}.{ 'xlsx' if fmt=='xlsx' else 'csv'}"
            return (_xlsx_response(fname, [("Audit", hdr, rows)])
                    if fmt == "xlsx" else _csv_response(fname, hdr, rows))

        if kind == "ipnat":
            hdr = ["Username", "Framed IP", "Calling Station (MAC)", "NAS IP",
                   "Start", "Stop", "Duration (sec)", "Input Octets",
                   "Output Octets", "Terminate Cause"]
            from database import Customer
            uns = {c.username for c in db.query(Customer).filter(
                Customer.company_id == company_id).all() if c.username}
            _, rows = _fetch_ipnat_rows(company_id, uns, dt_from, dt_to, q, limit=100000, db=db)
            fname = f"ipnat_logs_{stamp}.{ 'xlsx' if fmt=='xlsx' else 'csv'}"
            return (_xlsx_response(fname, [("IPNAT", hdr, rows)])
                    if fmt == "xlsx" else _csv_response(fname, hdr, rows))

        if kind == "blocklist":
            _ensure_blocklist_table(db)
            rows_d = _blocklist_rows(db, company_id)
            hdr = ["ID", "Target", "DoT Ref", "Notes", "Added By", "Added At"]
            rows = [(r["id"], r["target"], r["dot_ref"] or "",
                     r["notes"] or "", r["added_by"] or "",
                     r["added_at"]) for r in rows_d]
            fname = f"blocklist_{stamp}.{ 'xlsx' if fmt=='xlsx' else 'csv'}"
            return (_xlsx_response(fname, [("Blocklist", hdr, rows)])
                    if fmt == "xlsx" else _csv_response(fname, hdr, rows))

        if kind == "qos":
            # recompute qos export inline
            from database import Customer
            uns = {c.username for c in db.query(Customer).filter(
                Customer.company_id == company_id).all() if c.username}
            hdr = ["NAS IP", "Inbound (GB)", "Outbound (GB)", "Total (GB)",
                   "Unique Users", "Sessions", "Avg vs 1Gbps %", "Alert"]
            rows = []
            if uns:
                try:
                    # S42J — fence via company_id column.
                    try:
                        from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa3
                        _rp_bfa3(db, radacct_path=_RADACCT_DB, limit=2000)
                    except Exception:
                        pass
                    con = sqlite3.connect(_RADACCT_DB)
                    cur = con.cursor()
                    cutoff = int((datetime.utcnow() - timedelta(days=30)).timestamp())
                    plist = ",".join(["?"] * len(uns))
                    cur.execute(
                        f"SELECT nasipaddress, "
                        f"COALESCE(SUM(acctinputoctets),0), COALESCE(SUM(acctoutputoctets),0), "
                        f"COUNT(DISTINCT username), COUNT(*) FROM radacct "
                        f"WHERE company_id = ? AND username IN ({plist}) AND acctstarttime>=? GROUP BY nasipaddress",
                        [str(company_id)] + list(uns) + [cutoff])
                    for nas_ip, inp, out, uu, sess in cur.fetchall():
                        gb_in  = (inp or 0) / (1024**3)
                        gb_out = (out or 0) / (1024**3)
                        total_gb = gb_in + gb_out
                        avg_bps = ((inp or 0) + (out or 0)) * 8 / (30*86400)
                        avg_pct = round(avg_bps / 1e9 * 100, 2)
                        alert = "CRITICAL" if avg_pct >= 90 else "WARN" if avg_pct >= 80 else "OK"
                        rows.append((nas_ip, f"{gb_in:.2f}", f"{gb_out:.2f}",
                                     f"{total_gb:.2f}", uu, sess, avg_pct, alert))
                    con.close()
                except Exception:
                    pass
            fname = f"qos_report_{stamp}.{ 'xlsx' if fmt=='xlsx' else 'csv'}"
            return (_xlsx_response(fname, [("QoS", hdr, rows)])
                    if fmt == "xlsx" else _csv_response(fname, hdr, rows))

        raise HTTPException(400, f"unknown kind {kind}")

    # --- ZIP bundle -------------------------------------------------------
    @app.get("/admin/compliance/regulatory-bundle.zip")
    async def compliance_bundle(request: Request, db: Session = Depends(get_db)):
        auth = require_admin(request)
        if auth: return auth
        company_id = request.session.get("company_id")
        qp = request.query_params
        dt_from = _parse_date(qp.get("from"))
        dt_to   = _parse_date(qp.get("to"))
        stamp = datetime.now(IST).strftime("%Y%m%d_%H%M")

        from database import Customer
        uns = {c.username for c in db.query(Customer).filter(
            Customer.company_id == company_id).all() if c.username}

        buf = io.BytesIO()
        with zipfile.ZipFile(buf, "w", zipfile.ZIP_DEFLATED) as z:
            # Audit
            hdr_a = ["When (UTC)", "Customer ID", "Username", "Old Status",
                     "New Status", "Actor Type", "Actor ID", "Actor Name",
                     "Reason", "Balance"]
            _, rows_a = _fetch_audit_rows(db, company_id, dt_from, dt_to, None, 100000)
            s = io.StringIO(); w = csv.writer(s); w.writerow(hdr_a); [w.writerow(r) for r in rows_a]
            z.writestr("audit_logs.csv", s.getvalue())
            # IP/NAT
            hdr_i = ["Username", "Framed IP", "MAC", "NAS IP", "Start", "Stop",
                     "Duration (s)", "In Octets", "Out Octets", "Cause"]
            _, rows_i = _fetch_ipnat_rows(company_id, uns, dt_from, dt_to, None, 500000, db=db)
            s = io.StringIO(); w = csv.writer(s); w.writerow(hdr_i); [w.writerow(r) for r in rows_i]
            z.writestr("ip_nat_logs.csv", s.getvalue())
            # Blocklist
            _ensure_blocklist_table(db)
            rows_b = _blocklist_rows(db, company_id)
            s = io.StringIO(); w = csv.writer(s)
            w.writerow(["ID", "Target", "DoT Ref", "Notes", "Added By", "Added At"])
            for r in rows_b:
                w.writerow([r["id"], r["target"], r["dot_ref"] or "",
                            r["notes"] or "", r["added_by"] or "", r["added_at"]])
            z.writestr("dot_blocklist.csv", s.getvalue())
            # README
            z.writestr("README.txt", (
                f"Auto ISP Billing — DoT/TRAI Compliance Bundle\n"
                f"Company: {company_id}\n"
                f"Generated: {datetime.now(IST).strftime('%Y-%m-%d %H:%M:%S IST')}\n"
                f"Range: {qp.get('from') or '(all)'} to {qp.get('to') or '(now)'}\n"
                "\nContents:\n"
                "  audit_logs.csv     Customer status change + admin action log\n"
                "  ip_nat_logs.csv    RADIUS accounting — user ↔ IP mapping\n"
                "  dot_blocklist.csv  Currently active DoT-ordered site blocks\n"
            ))
        buf.seek(0)
        return StreamingResponse(iter([buf.getvalue()]),
            media_type="application/zip",
            headers={"Content-Disposition":
                     f'attachment; filename="compliance_bundle_{company_id}_{stamp}.zip"'})
