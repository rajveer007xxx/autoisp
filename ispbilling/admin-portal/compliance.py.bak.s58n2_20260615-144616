            try:
                stats["blocklist"] = c.execute(
                    "SELECT COUNT(*) FROM dot_blocklist WHERE "
                    "company_id=? AND active=1", (cid,)).fetchone()[0]
            except Exception:
                stats["blocklist"] = 0
        return {"ok": True, "stats": stats}
