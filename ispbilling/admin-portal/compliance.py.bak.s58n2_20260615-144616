    @app.get("/api/compliance/dot-stats")
    async def api_dot_stats(request: Request):
        gate = require_admin(request)
        if gate: return _JSON_li({"error": "auth"}, status_code=401)
        cid = request.session.get("company_id")
        with _li_conn() as c:
            stats = {}
            stats["customers_total"] = c.execute(
                "SELECT COUNT(*) FROM customers WHERE company_id=?",
                (cid,)).fetchone()[0]
            try:
                stats["customers_kyc"] = c.execute(
                    "SELECT COUNT(*) FROM customers WHERE company_id=? "
                    "AND (aadhaar_no IS NOT NULL AND aadhaar_no!='')",
                    (cid,)).fetchone()[0]
            except Exception:
                stats["customers_kyc"] = 0
            stats["li_active"] = c.execute(
                "SELECT COUNT(*) FROM li_orders WHERE company_id=? "
                "AND status='active'", (cid,)).fetchone()[0]
            stats["li_pending_destroy"] = c.execute(
                "SELECT COUNT(*) FROM li_orders WHERE company_id=? "
