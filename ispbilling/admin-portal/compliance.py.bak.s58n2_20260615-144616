def _wire_li(app, templates, get_db, require_admin):
    @app.get("/admin/compliance/li-orders", response_class=_HTML_li)
    async def li_orders_page(request: Request):
        gate = require_admin(request)
        if gate: return gate
        return templates.TemplateResponse(
            "compliance_li_orders.html",
            {"request": request, "active_page": "compliance"})

    @app.get("/api/compliance/li-orders")
    async def api_li_list(request: Request):
        gate = require_admin(request)
        if gate: return _JSON_li({"error": "auth"}, status_code=401)
        cid = request.session.get("company_id")
        with _li_conn() as c:
            rows = c.execute(
                "SELECT * FROM li_orders WHERE company_id=? "
                "ORDER BY id DESC", (cid,)).fetchall()
        # Auto-flag expired
        today = _dt_li.utcnow().date().isoformat()
        items = []
        for r in rows:
            d = dict(r)
            if d.get("status") == "active" and d.get("destroy_at") and d["destroy_at"] < today:
                d["status"] = "destroyed"
            items.append(d)
        return {"ok": True, "items": items}

    @app.post("/api/compliance/li-orders")
    async def api_li_add(request: Request,
                         order_no: str = _Form_li(...),
                         agency: str = _Form_li(...),
                         target_username: str = _Form_li(...),
                         ordered_on: str = _Form_li(""),
                         ends_on: str = _Form_li(""),
                         notes: str = _Form_li("")):
        gate = require_admin(request)
        if gate: return _JSON_li({"error": "auth"}, status_code=401)
        cid = request.session.get("company_id")
        # Auto-destroy = ends_on + 60 days (DoT 2-month rule)
        destroy_at = ""
        if ends_on:
            try:
                end = _dt_li.strptime(ends_on, "%Y-%m-%d").date()
                destroy_at = (end + _td_li(days=60)).isoformat()
            except Exception:
                destroy_at = ""
        with _li_conn() as c:
            c.execute("""INSERT INTO li_orders
                (company_id,order_no,agency,target_username,ordered_on,ends_on,
                 destroy_at,status,notes,created_by)
                VALUES (?,?,?,?,?,?,?,?,?,?)""",
                (cid, order_no.strip(), agency.strip(),
                 target_username.strip(),
                 ordered_on or None, ends_on or None, destroy_at or None,
                 "active", notes or "",
                 request.session.get("user_id", "")))
            c.commit()
        return {"ok": True}

    @app.delete("/api/compliance/li-orders/{oid}")
    async def api_li_destroy(oid: int, request: Request):
        gate = require_admin(request)
        if gate: return _JSON_li({"error": "auth"}, status_code=401)
        cid = request.session.get("company_id")
        with _li_conn() as c:
            c.execute("UPDATE li_orders SET status='destroyed' "
                      "WHERE id=? AND company_id=?", (oid, cid))
