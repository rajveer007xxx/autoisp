    @app.get("/admin/compliance/qos", response_class=HTMLResponse)
    async def compliance_qos(request: Request, db: Session = Depends(get_db)):
        auth = require_admin(request)
        if auth: return auth
        from main import get_admin_context
        ctx = get_admin_context(request, db, "compliance")
        company_id = request.session.get("company_id")
        # Compute 30-day per-NAS totals & peak utilisation alerts.
        from radius_network import NasDevice
        from database import Customer
        uns = {c.username for c in db.query(Customer).filter(
            Customer.company_id == company_id).all() if c.username}
        rows_out = []
        if uns:
            try:
                # S42J — fence via company_id column.
                try:
                    from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa2
                    _rp_bfa2(db, radacct_path=_RADACCT_DB, limit=2000)
                except Exception:
                    pass
                con = sqlite3.connect(_RADACCT_DB)
                cur = con.cursor()
                cutoff = int((datetime.utcnow() - timedelta(days=30)).timestamp())
                plist = ",".join(["?"] * len(uns))
                cur.execute(
                    f"SELECT nasipaddress, "
                    f"COALESCE(SUM(acctinputoctets),0), "
                    f"COALESCE(SUM(acctoutputoctets),0), "
                    f"COALESCE(COUNT(DISTINCT username),0), "
                    f"COALESCE(COUNT(*),0) "
                    f"FROM radacct WHERE company_id = ? "
                    f"AND username IN ({plist}) "
                    f"AND acctstarttime >= ? GROUP BY nasipaddress",
                    [str(company_id)] + list(uns) + [cutoff])
                for nas_ip, inp, out, uu, sess in cur.fetchall():
                    gb_in  = (inp or 0) / (1024**3)
                    gb_out = (out or 0) / (1024**3)
                    total_gb = gb_in + gb_out
                    # naive utilisation estimate: bytes over 30d vs. 1 Gbps link
                    seconds = 30 * 86400
                    avg_bps = ((inp or 0) + (out or 0)) * 8 / seconds
                    avg_pct = round(avg_bps / 1e9 * 100, 2)  # vs 1 Gbps
                    alert = "OK"
                    if avg_pct >= 90:
                        alert = "CRITICAL (30d avg ≥ 90%)"
                    elif avg_pct >= 80:
                        alert = "WARN (30d avg ≥ 80%)"
                    rows_out.append((nas_ip or "?", f"{gb_in:,.2f}", f"{gb_out:,.2f}",
                                     f"{total_gb:,.2f}", str(uu), str(sess),
                                     f"{avg_pct}%", alert))
                con.close()
            except Exception:
                pass
        return templates.TemplateResponse("compliance_list.html", {
            "request": request, **ctx,
            "title": "QoS / Bandwidth Utilisation (30 days)",
            "subtitle": "Per-NAS traffic summary — TRAI thresholds 80% warn / 90% critical",
            "kind": "qos",
            "columns": ["NAS IP", "Inbound (GB)", "Outbound (GB)", "Total (GB)",
                        "Unique Users", "Sessions", "Avg vs 1Gbps", "Alert"],
            "rows": rows_out, "total_rows": len(rows_out),
            "dt_from": "", "dt_to": "", "q": "",
            "query_string": "", "extra_filter_label": "Filter",
        })

