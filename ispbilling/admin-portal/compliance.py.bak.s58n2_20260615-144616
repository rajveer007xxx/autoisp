        c.execute("""CREATE TABLE IF NOT EXISTS li_orders (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id  TEXT NOT NULL,
            order_no    TEXT NOT NULL,
            agency      TEXT NOT NULL,
            target_username TEXT NOT NULL,
            ordered_on  TEXT,
