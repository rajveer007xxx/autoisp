def _fetch_audit_rows(db, company_id: str,
                      dt_from: Optional[datetime] = None,
                      dt_to: Optional[datetime] = None,
                      q: Optional[str] = None,
                      limit: int = 2000):
    from radius_network import CustomerStatusLog
    qry = db.query(CustomerStatusLog).filter(CustomerStatusLog.company_id == company_id)
    if dt_from:
        qry = qry.filter(CustomerStatusLog.created_at >= dt_from)
    if dt_to:
        qry = qry.filter(CustomerStatusLog.created_at < (dt_to + timedelta(days=1)))
    if q:
        from sqlalchemy import or_
        like = f"%{q}%"
        qry = qry.filter(or_(CustomerStatusLog.username.like(like),
                             CustomerStatusLog.customer_id.like(like),
                             CustomerStatusLog.actor_id.like(like),
                             CustomerStatusLog.actor_name.like(like),
                             CustomerStatusLog.reason.like(like)))
    total = qry.count()
    rows = qry.order_by(CustomerStatusLog.id.desc()).limit(limit).all()
    return total, [(r.created_at.strftime("%Y-%m-%d %H:%M:%S") if r.created_at else "",
                    r.customer_id or "",
                    r.username or "",
                    r.old_status or "",
                    r.new_status or "",
                    r.actor_type or "",
                    r.actor_id or "",
                    r.actor_name or "",
                    r.reason or "",
                    str(r.balance_at_change or "")) for r in rows]


_RADACCT_DB = "/var/lib/freeradius/radacct.db"

def _fetch_ipnat_rows(company_id: str, usernames: Optional[set] = None,
                      dt_from: Optional[datetime] = None,
                      dt_to: Optional[datetime] = None,
                      q: Optional[str] = None,
                      limit: int = 2000,
                      db=None):
    """Read RADIUS accounting. S42J — primary fence is the dedicated
    `company_id` column on radacct (resolved deterministically by
    radpostauth_tenant). Username filter is kept as a UX scope, not as
    a security boundary."""
    try:
        con = sqlite3.connect(_RADACCT_DB)
        cur = con.cursor()
    except Exception:
        return 0, []
    # S42J — make sure recent radacct rows have company_id mapped before query.
    try:
        if db is not None:
            from radpostauth_tenant import backfill_radacct_company_id as _rp_bfa
            _rp_bfa(db, radacct_path=_RADACCT_DB, limit=2000)
    except Exception:
        pass
    where = ["company_id = ?"]
    args = [str(company_id)]
    if usernames:
        plist = ",".join(["?"] * len(usernames))
        where.append(f"username IN ({plist})")
        args += list(usernames)
    if dt_from:
        where.append("acctstarttime >= ?")
        args.append(int(dt_from.timestamp()))
    if dt_to:
        where.append("acctstarttime < ?")
        args.append(int((dt_to + timedelta(days=1)).timestamp()))
    if q:
        where.append("(username LIKE ? OR framedipaddress LIKE ? OR nasipaddress LIKE ? OR callingstationid LIKE ?)")
        like = f"%{q}%"
        args += [like, like, like, like]
    wsql = " WHERE " + " AND ".join(where)
    total_sql = f"SELECT COUNT(*) FROM radacct{wsql}"
    data_sql = (f"SELECT username, framedipaddress, callingstationid, nasipaddress, "
                f"acctstarttime, acctstoptime, acctsessiontime, "
                f"acctinputoctets, acctoutputoctets, acctterminatecause "
                f"FROM radacct{wsql} ORDER BY acctstarttime DESC LIMIT ?")
    try:
        cur.execute(total_sql, args)
        total = int(cur.fetchone()[0])
        cur.execute(data_sql, args + [limit])
        def fmt_ts(t):
            if not t:
                return ""
            try:
                return datetime.fromtimestamp(int(t)).strftime("%Y-%m-%d %H:%M:%S")
            except Exception:
                return str(t)
        rows = [(r[0], r[1] or "", r[2] or "", r[3] or "",
                 fmt_ts(r[4]), fmt_ts(r[5]),
                 str(r[6] or 0),
                 str(r[7] or 0), str(r[8] or 0),
                 r[9] or "") for r in cur.fetchall()]
    finally:
        con.close()
    return total, rows


# ------------------------------------------------------------------ Blocklist storage
def _ensure_blocklist_table(db):
    from sqlalchemy import text
    db.execute(text("""
        CREATE TABLE IF NOT EXISTS dot_blocklist (
            id         INTEGER PRIMARY KEY AUTOINCREMENT,
            company_id VARCHAR(40) NOT NULL,
            target     VARCHAR(255) NOT NULL,
            dot_ref    VARCHAR(120),
            notes      TEXT,
            added_by   VARCHAR(120),
            added_at   DATETIME DEFAULT CURRENT_TIMESTAMP
        )
    """))
    db.commit()


def _blocklist_rows(db, company_id):
    from sqlalchemy import text
    res = db.execute(text(
        "SELECT id, target, dot_ref, notes, added_by, added_at "
        "FROM dot_blocklist WHERE company_id = :c ORDER BY id DESC"),
        {"c": company_id}).fetchall()
    return [{"id": r[0], "target": r[1], "dot_ref": r[2], "notes": r[3],
             "added_by": r[4], "added_at": str(r[5] or "")} for r in res]


def _sync_blocklist_to_nas(db, company_id):
    """Push the current blocklist to every Active NAS as a Mikrotik
    address-list named `dot-blocklist`."""
    from database import NasDevice
    import routeros_provision as rp
    nas_rows = db.query(NasDevice).filter(
        NasDevice.company_id == company_id,
        NasDevice.status == "Active").all()
    entries = _blocklist_rows(db, company_id)
    synced = 0
    for nas in nas_rows:
        try:
            with rp.RouterOSClient(nas, dry_run=False) as rc:
                # Clear existing entries then re-add
                for row in list(rc._api.path("ip/firewall/address-list")):
                    if row.get("list") == "dot-blocklist":
                        try:
                            rc._api.path("ip/firewall/address-list").remove(row[".id"])
                        except Exception:
                            pass
                for e in entries:
                    try:
                        rc._api.path("ip/firewall/address-list").add(
                            list="dot-blocklist",
                            address=e["target"],
                            comment=(e.get("dot_ref") or "DoT block")[:60],
                        )
                    except Exception as _ex:
                        # If domain, Mikrotik will resolve it; IP passes directly.
                        pass
            synced += 1
        except Exception:
            continue
    return synced, len(entries)


