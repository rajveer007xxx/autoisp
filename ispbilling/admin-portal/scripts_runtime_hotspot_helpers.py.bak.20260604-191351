"""scripts_runtime_hotspot_helpers — pluggable Mikrotik hotspot extras
called by /api/nas-devices/{id}/oneclick-auth when the admin opts into
the Hotspot mode. All functions are idempotent.

Public:
  push_branded_captive_portal(nas) -> dict
  ensure_hotspot_user_profiles(nas) -> dict
  ensure_hotspot_bypass_bindings(nas) -> dict
"""
from __future__ import annotations
import sqlite3
from typing import Any, Dict, List

from librouteros import connect
from librouteros.login import plain as login_plain


