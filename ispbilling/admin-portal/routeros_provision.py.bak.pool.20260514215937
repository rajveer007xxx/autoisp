def provision_customer_pppoe(nas, customer: Dict, plan: Dict, password: str,
                             remote_address: Optional[str] = None,
                             dry_run: bool = False,
                             pool_name: Optional[str] = None) -> Dict:
    """One-shot: ensure a plan-profile exists with correct rate-limit + pool
    (for client IP handout), then create the customer's PPPoE secret on that
    profile. On re-provision (secret already exists) the profile assignment
    is updated so the new plan takes effect.

    `pool_name` → /ip/pool to attach as profile `remote-address` (critical:
    without this, customers connect but never get a framed IP).
    """
    try:
        with RouterOSClient(nas, dry_run=dry_run) as c:
            profile_res = c.configure_plan_profile(plan, pool_name=pool_name)
            profile_name = profile_res.get("profile_name")
            secret_res = c.create_pppoe_secret(
                name=customer["username"],
                password=password,
                profile=profile_name,
                remote_address=remote_address,
            )
        return {
            "success": True, "dry_run": dry_run,
            "profile_name": profile_name,
            "rate_limit": profile_res.get("rate_limit"),
            "pool_name": (pool_name or plan.get("pool_name") or "pppoe-pool"),
            "profile_result": profile_res,
            "secret_result": secret_res,
            "commands": c.commands,
        }
    except Exception as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


def provision_customer_hotspot(nas, customer: Dict, plan: Dict,
                               password: str = "",
                               mac_address: str = "",
                               dry_run: bool = False) -> Dict:
    """Push a /ip/hotspot/user entry for the customer. RADIUS (FreeRADIUS)
    still authoritatively serves the rate-limit + session-timeout via
    Access-Accept; this local entry is a safety net when RADIUS is
    unreachable. Returns success=True even if the router has no hotspot
    configured yet — caller should ensure hotspot-server is up first.
    """
    plan_name = (plan.get("plan_name") or "default").strip() or "default"
    dl = (plan.get("download_speed") or "").strip()
    ul = (plan.get("upload_speed") or "").strip()
    rate_limit = f"{ul or dl}/{dl or ul}" if (dl or ul) else ""
    try:
        with RouterOSClient(nas, dry_run=dry_run) as c:
            res = c.create_hotspot_user(
                name=customer["username"],
                password=password,
                mac_address=mac_address,
                rate_limit=rate_limit,
                profile="default",
                comment=f"plan={plan_name}",
            )
        return {
            "success": True, "dry_run": dry_run,
            "auth_type": "hotspot",
            "rate_limit": rate_limit,
            "user_result": res,
            "commands": c.commands,
        }
    except Exception as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


def provision_customer_static(nas, customer: Dict, plan: Dict, password: str,
                              static_ip: str,
                              dry_run: bool = False,
                              pool_name: Optional[str] = None) -> Dict:
    """__S38T_TRUE_STATIC_IP__ — True static-IP customer provisioning.

    The customer's CPE is manually configured with `static_ip` + gateway
    + DNS. Mikrotik just adds the IP to the MASQUERADE + ALLOW address
    lists and attaches a per-IP simple queue at the plan's rate-limit.
    NO PPPoE secret is created — the customer never dials PPPoE.

    `password` and `pool_name` kwargs are accepted (and ignored) for
    signature compatibility with the pre-__S38T__ call-sites.
    """
    ip = (static_ip or "").strip()
    if not ip:
        return {"success": False,
                "message": "static_ip required for auth_type=static_ip"}
    rate_limit = _rate_limit_from_plan(plan)
    try:
        with RouterOSClient(nas, dry_run=dry_run) as c:
            res = c.create_static_ip_binding(
                ip_address=ip,
                rate_limit=rate_limit,
                username=(customer or {}).get("username", ""),
                comment=f"user={(customer or {}).get('username','')} "
                        f"plan={(plan or {}).get('plan_name','')}".strip(),
            )
        return {
            "success": bool(res.get("success")), "dry_run": dry_run,
            "auth_type": "static_ip",
            "rate_limit": rate_limit,
            "binding_result": res,
            "commands": c.commands,
        }
    except Exception as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


def _rate_limit_from_plan(plan: Dict) -> str:
    """Build a RouterOS-compatible rate string "<upload>/<download>" from
    a plan dict — reused for pure static-IP queues (same convention as
    `_render_users_file` in freeradius_manager)."""
    if not plan:
        return ""
    dl = str(plan.get("download_speed") or "").strip()
    ul = str(plan.get("upload_speed") or "").strip()
    if not dl and not ul:
        return ""
    def _norm(v):
        v = v.strip()
        if not v:
            return "0"
        # Accept "100", "100M", "100Mbps" — strip units, add M suffix.
        import re as _re
        m = _re.match(r"^([0-9]+(?:\.[0-9]+)?)\s*([kKmMgG]?)", v)
        if not m:
            return v
        num, unit = m.group(1), (m.group(2) or "M").upper()
        if unit == "K": unit = "k"
        elif unit in ("", "M"): unit = "M"
        elif unit == "G": unit = "G"
        return f"{num}{unit}"
    return f"{_norm(ul)}/{_norm(dl)}"


def unprovision_customer_static(nas, customer: Dict,
                                  static_ip: str,
                                  dry_run: bool = False) -> Dict:
    """__S38T_TRUE_STATIC_IP__ — Remove firewall + queue entries so the
    customer loses internet. Called on suspend/terminate/delete."""
    ip = (static_ip or "").strip()
    if not ip:
        return {"success": False, "message": "static_ip required"}
    try:
        with RouterOSClient(nas, dry_run=dry_run) as c:
            res = c.delete_static_ip_binding(
                ip_address=ip,
                username=(customer or {}).get("username", ""),
            )
        return {"success": bool(res.get("success")), "dry_run": dry_run,
                "binding_result": res, "commands": c.commands}
    except Exception as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


def provision_customer_dhcp_static(nas, customer: Dict, plan: Dict,
                                   static_ip: str, mac_address: str,
                                   dry_run: bool = False,
                                   dhcp_server: str = "") -> Dict:
    """Pure-DHCP static reservation (no PPPoE). Binds customer's MAC to
    the reserved IP so every DHCP lease request returns the same IP.
    Queue-type rate-limit must be applied separately via a simple-queue
    (we do NOT bind a queue here — keep the function small; operators
    bind queues via the regular per-plan queue sync)."""
    if not (static_ip or "").strip() or not (mac_address or "").strip():
        return {"success": False,
                "message": "static_ip and mac_address required for dhcp-static"}
    try:
        with RouterOSClient(nas, dry_run=dry_run) as c:
            res = c.create_dhcp_lease(
                mac_address=mac_address, address=static_ip,
                server=dhcp_server,
                comment=f"user={customer.get('username','')} plan={plan.get('plan_name','')}",
            )
        return {
            "success": True, "dry_run": dry_run,
            "auth_type": "static_ip_dhcp",
            "lease_result": res,
            "commands": c.commands,
        }
    except Exception as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


def provision_customer(nas, customer: Dict, plan: Dict, password: str = "",
                       auth_type: str = "pppoe",
                       static_ip: str = "",
                       mac_address: str = "",
                       dry_run: bool = False,
                       pool_name: Optional[str] = None,
                       remote_address: Optional[str] = None) -> Dict:
    """Top-level dispatcher. Routes to the right per-customer provision
    flow based on `auth_type` from the customers table:

      • `pppoe`     → classic PPPoE secret + plan-profile.
      • `static_ip` → PPPoE secret with fixed `remote-address` (when
                       password given), else DHCP static lease (when
                       only mac_address given).
      • `hotspot`   → /ip/hotspot/user entry (router-local fallback).
    """
    at = (auth_type or "pppoe").strip().lower()
    if at == "hotspot":
        return provision_customer_hotspot(
            nas=nas, customer=customer, plan=plan,
            password=password, mac_address=mac_address, dry_run=dry_run,
        )
    if at in ("static_ip", "static-ip", "static"):
        # __S38T_TRUE_STATIC_IP__ — auth_type=static_ip means the customer'''s
        # CPE carries the static IP natively. NO PPPoE secret, NO RADIUS.
        # Mikrotik just firewall-allow + simple-queue the IP at plan rate.
        return provision_customer_static(
            nas=nas, customer=customer, plan=plan, password=password,
            static_ip=static_ip, dry_run=dry_run, pool_name=pool_name,
        )
    # Default: classic PPPoE.
    return provision_customer_pppoe(
        nas=nas, customer=customer, plan=plan, password=password,
        remote_address=remote_address,
        dry_run=dry_run, pool_name=pool_name,
    )


