def sync_radius_secret(nas, radius_server_ip: str) -> Dict:
    """Public helper — force-UPDATE the router's `/radius` entry secret to
    match the NAS DB row's `secret` column. This fixes the classic
    "router times out waiting for RADIUS reply" loop that happens when
    the router's stored secret drifts from our clients.conf (reply is
    signed with our secret; router can't validate signature; discards
    reply; retries forever)."""
    try:
        with RouterOSClient(nas, dry_run=False) as c:
            res = c.sync_radius_secret(
                radius_server_ip=radius_server_ip,
                secret=(nas.secret or "testing123"),
            )
        return {"success": True, "transport": c.transport_used, **res}
    except Exception as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


