def generate_rsc_script(nas, options: Dict, plans: List[Dict],
                         ip_pools: List[Dict], radius_server_ip: str,
                         radius_secret: str,
                         pppoe_interface: str = "ether2",
                         hotspot_interface: str = "ether3",
                         wan_interface: str = "ether1",
                         pppoe_pool_name: str = "pppoe-pool",
                         pppoe_pool_ranges: str = "192.168.100.10-192.168.100.250",
                         pppoe_local_address: str = "192.168.100.1",
                         dns_servers: str = "8.8.8.8,1.1.1.1",
                         enable_ppp_use_radius: bool = False,
                         enable_pppoe_server: bool = False,
                         enable_hotspot: bool = False,
                         parking_pool_name: str = "parking-pool",
                         parking_pool_ranges: str = "10.255.0.0/16",
                         parking_landing_ip: str = "",
                         lan_subnets: Optional[List[str]] = None,
                         management_sources: Optional[List[str]] = None,
                         management_ports: Optional[List[int]] = None,
                         api_username: str = "autoisp",
                         with_wan_drop: bool = False,
                         with_audit_log: bool = False) -> Dict:
    """Render a full RouterOS `.rsc` import script — admin imports once
    on the router with `/import file=autoisp-setup.rsc` and every piece
    is wired (user group + permissions, API service, firewall with our
    VPS whitelisted, RADIUS client + CoA listener, PPPoE server, parking
    pool, queue types). ZERO terminal copy-paste dance.

    Generated via dry-run against a simulated client so we reuse all the
    existing per-task logic (no duplication) and just capture the CLI
    commands."""
    # Run a dry-run to collect commands
    dry_report = auto_configure(
        nas=nas, options=options, ip_pools=ip_pools, plans=plans,
        radius_server_ip=radius_server_ip, radius_secret=radius_secret,
        dry_run=True,
        pppoe_interface=pppoe_interface, hotspot_interface=hotspot_interface,
        wan_interface=wan_interface,
        enable_pppoe_server=enable_pppoe_server, enable_hotspot=enable_hotspot,
        pppoe_pool_name=pppoe_pool_name, pppoe_pool_ranges=pppoe_pool_ranges,
        pppoe_local_address=pppoe_local_address,
        dns_servers=dns_servers, enable_ppp_use_radius=enable_ppp_use_radius,
        lan_subnets=lan_subnets,
        parking_pool_name=parking_pool_name,
        parking_pool_ranges=parking_pool_ranges,
        parking_landing_ip=parking_landing_ip,
        management_sources=management_sources,
        management_ports=management_ports,
        with_wan_drop=with_wan_drop,
        with_audit_log=with_audit_log,
    )

    # Preamble: fix permissions + open API service restricted to our IP
    allow_csv = ",".join(management_sources or ["0.0.0.0/0"])
    preamble = [
        "# ================================================================",
        "# Auto ISP Billing — one-shot setup script",
        f"# Generated at {datetime.datetime.utcnow().isoformat()}Z",
        f"# Target NAS: {getattr(nas, 'name', '?')} ({getattr(nas, 'ip_address', '?')})",
        "# Import with:  /import file=autoisp-setup.rsc",
        "# ================================================================",
        "",
        "# 1. Ensure the API user has full policies (idempotent).",
        f'/user group add name=autoisp-full policy=read,write,api,sensitive,policy,test,!local,!telnet,!ssh,!winbox,!web,!ftp,!reboot comment="auto-isp-billing"',
        f'/user set [find name="{api_username}"] group=autoisp-full',
        "",
        "# 2. Lock the API service to our billing server only.",
        f'/ip service set api address={allow_csv} disabled=no port=8728',
        "",
        "# 3. Apply the full auto-config:",
        "",
    ]

    body = dry_report.get("commands", [])
    footer = [
        "",
        "# 4. Done. On the router run:",
        "#      /log print where topics~\"radius\"    to watch incoming auth",
        "#      /ip firewall filter print            to confirm order (MANAGEMENT before WAN-drop!)",
        "#      /radius print                        to confirm our billing server",
    ]

    script = "\n".join(preamble + body + footer) + "\n"
    return {"success": True, "filename": "autoisp-setup.rsc",
            "content": script, "line_count": len(script.splitlines())}

