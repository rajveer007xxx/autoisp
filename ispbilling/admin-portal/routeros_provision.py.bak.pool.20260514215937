    def configure_plan_profile(self, plan: Dict, pool_name: Optional[str] = None) -> Dict:
        """Create/update a /ppp/profile whose rate-limit matches the plan's DL/UL.

        CRITICAL: `remote-address` MUST reference a valid `/ip/pool` name or
        clients will connect but never receive an IP (symptom: PPPoE session
        up on the router but the customer's laptop shows "connected, no
        internet" because there's no framed-IP). `pool_name` defaults to the
        plan's dedicated `pool_name`, else the server-wide `pppoe-pool`.
        """
        profile_name = (plan.get("profile_name")
                        or f"plan-{(plan.get('plan_name') or 'unnamed').lower().replace(' ', '-')}")
        dl = (plan.get("download_speed") or "").strip()
        ul = (plan.get("upload_speed") or "").strip()
        rate_limit = ""
        if dl or ul:
            rate_limit = f"{ul or dl}/{dl or ul}"  # RouterOS: <tx>/<rx>
        effective_pool = (pool_name or plan.get("pool_name") or "pppoe-pool").strip()
        dns_servers = (plan.get("dns_servers") or "8.8.8.8,1.1.1.1").strip()
        params = {
            "name": profile_name,
            "only-one": "yes",
            "local-address": plan.get("local_address", "192.168.100.1"),
            "remote-address": effective_pool,
            "change-tcp-mss": "yes",
        }
        if dns_servers:
            params["dns-server"] = dns_servers
        if rate_limit:
            params["rate-limit"] = rate_limit

        cli = self._cli("ppp/profile", "add/set", **params)
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli, "profile_name": profile_name, "rate_limit": rate_limit}
        if self._ssh:
            # add if not exists; ignore error if it does; then set
            out1, _, _ = self._ssh.exec(f"/ppp profile add name={profile_name}")
            set_kv = " ".join(f"{k}={v}" for k, v in params.items() if k != "name")
            out2, err2, rc2 = self._ssh.exec(f"/ppp profile set [find name={profile_name}] {set_kv}")
            return {"profile_name": profile_name, "rate_limit": rate_limit,
                    "ssh_rc": rc2, "ssh_err": err2.strip()}
        path_obj = self._api.path("ppp/profile")
        for row in list(path_obj):
            if row.get("name") == profile_name:
                path_obj.update(**{".id": row[".id"],
                                   **{k: v for k, v in params.items() if k != "name"}})
                return {"updated": True, "profile_name": profile_name, "rate_limit": rate_limit}
        path_obj.add(**params)
        return {"added": True, "profile_name": profile_name, "rate_limit": rate_limit}

