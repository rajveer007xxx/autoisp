            "/interface pppoe-server server remove [find service-name=isp-pppoe]",
            "/ppp profile remove [find name~\"^(plan-|isp-default)\"]",
            "/ppp secret remove [find service=pppoe]",
            "/ip hotspot remove [find name=isp-hotspot]",
            "/ip hotspot profile remove [find name=isp-hotspot]",
            "/ip address remove [find comment~\"^auto-isp-billing-pool-\"]",
            "/ip firewall address-list remove [find list=MASQUERADE comment~\"^auto-isp-billing\"]",
            "/ip firewall address-list remove [find list=blocked comment~\"^auto-isp-billing\"]",
            "/ip pool remove [find name~\"^(pppoe-pool|hotspot-pool|parking-pool|Home-Pool|Business-Pool|Hotspot-Pool)\"]",
            "/queue simple remove [find name~\"^plan-\"]",
            "/queue type remove [find name~\"^pcq-\"]",
            "/radius remove [find comment=auto-isp-billing]",
            "/ip firewall filter remove [find comment~\"^auto-isp-billing\"]",
