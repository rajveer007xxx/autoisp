def test_connection(nas) -> Dict:
    try:
        with RouterOSClient(nas, dry_run=False) as c:
            return {"success": True, **c.test()}
    except (socket.timeout, OSError, Exception) as e:  # noqa: BLE001
        return {"success": False, "message": str(e)}


def auto_configure(nas, options: Dict[str, bool], ip_pools: List[Dict],
                   plans: List[Dict], radius_server_ip: str, radius_secret: str,
                   dry_run: bool = True,
                   pppoe_interface: str = "ether2",
                   hotspot_interface: str = "ether3",
                   wan_interface: str = "ether1",
                   enable_pppoe_server: bool = False,
                   enable_hotspot: bool = False,
                   pppoe_pool_name: str = "pppoe-pool",
                   pppoe_pool_ranges: str = "192.168.100.10-192.168.100.250",
                   pppoe_local_address: str = "192.168.100.1",
                   dns_servers: str = "8.8.8.8,1.1.1.1",
                   enable_ppp_use_radius: bool = False,
                   lan_subnets: Optional[List[str]] = None,
                   parking_pool_name: str = "parking-pool",
                   parking_pool_ranges: str = "10.255.0.0/16",
                   parking_landing_ip: str = "",
                   management_sources: Optional[List[str]] = None,
                   management_ports: Optional[List[int]] = None,
                   with_wan_drop: bool = False,
                   with_audit_log: bool = False,
                   pppoe_service_name: str = "isp-pppoe",
                   pppoe_vlan_id: int = 0) -> Dict:
    """Run selected tasks and return commands + per-task results. Each task
    runs in isolation — if one fails, the report captures the error and the
    other tasks still execute. This matters because real routers have
    existing config that can trip up a single task (e.g. a stale `/radius`
    entry with a duplicate comment) without preventing the rest of the
    auto-config from being useful."""
    report: Dict[str, Any] = {"dry_run": dry_run, "tasks": {},
                               "commands": [], "task_errors": {}}
    c = None
    try:
        c = RouterOSClient(nas, dry_run=dry_run).__enter__()
        if not dry_run:
            try:
                report["connection"] = c.test()
            except Exception as e:  # noqa: BLE001
                report["connection"] = {"error": str(e)}
        report["transport"] = c.transport_used or ("simulated" if dry_run else "n/a")

        def _run(task_name, fn, *args, **kwargs):
            """Wrap one task so exceptions don't kill the whole run. Also
            scan the task's return value for inline errors (e.g. RouterOS
            'not enough permissions (9)' is returned as
            {"error": "..."} by `_do_add` / `_do_set_single`, not raised)
            and surface them as `task_errors[task_name]` so the permission
            hint can trigger."""
            try:
                result = fn(*args, **kwargs)
                report["tasks"][task_name] = result
                inline_errs = []
                rows = result if isinstance(result, list) else [result] if isinstance(result, dict) else []
                for r in rows:
                    if isinstance(r, dict) and r.get("error"):
                        inline_errs.append(r["error"])
                if inline_errs:
                    # Dedupe while preserving order
                    seen = set(); uniq = []
                    for e in inline_errs:
                        if e not in seen:
                            seen.add(e); uniq.append(e)
                    report["task_errors"][task_name] = "; ".join(uniq)
            except Exception as e:  # noqa: BLE001
                report["task_errors"][task_name] = str(e)
                report["tasks"][task_name] = {"error": str(e)}

        if options.get("queue_types"):
            _run("queue_types", c.create_queue_types)
        if options.get("ip_pools") and ip_pools:
            _run("ip_pools", c.sync_ip_pools_to_router, ip_pools)
        if options.get("pppoe_server"):
            _run("pppoe_server", c.configure_pppoe_server,
                 interface=pppoe_interface, local_address=pppoe_local_address,
                 pool_name=pppoe_pool_name, pool_ranges=pppoe_pool_ranges,
                 dns_servers=dns_servers, disabled=not enable_pppoe_server,
                 service_name=pppoe_service_name,
                 vlan_id=int(pppoe_vlan_id or 0))
        if options.get("hotspot"):
            _run("hotspot", c.configure_hotspot,
                 interface=hotspot_interface, disabled=not enable_hotspot)
        if options.get("simple_queues_from_plans") and plans:
            _run("simple_queues", c.sync_plans_to_queues, plans)
        if options.get("radius_client") and radius_server_ip:
            _run("radius_client", c.setup_radius_client,
                 radius_server_ip=radius_server_ip, secret=radius_secret,
                 enable_ppp_use_radius=enable_ppp_use_radius)
        if options.get("firewall_nat_baseline") and wan_interface:
            _run("firewall_nat_baseline", c.configure_firewall_nat_baseline,
                 wan_interface=wan_interface, lan_subnets=lan_subnets,
                 management_sources=management_sources,
                 management_ports=management_ports,
                 with_wan_drop=with_wan_drop,
                 with_audit_log=with_audit_log)
        if options.get("parking_pool"):
            _run("parking_pool", c.configure_parking_pool,
                 parking_pool_name=parking_pool_name,
                 parking_ranges=parking_pool_ranges,
                 landing_page_ip=parking_landing_ip)

        report["commands"] = list(c.commands)
        report["transport"] = c.transport_used or ("simulated" if dry_run else "n/a")
        report["unprovision_commands"] = c.unprovision_commands()
        # Consider the whole run a success if at least one task executed
        # without throwing — task_errors are surfaced separately so admin
        # can see exactly which task(s) hit trouble on the router side.
        report["success"] = len(report["tasks"]) > 0
        if report["task_errors"]:
            # Map common RouterOS permission errors to the policy the
            # admin needs to grant their API user.
            perm_hints = []
            needs_policies = set()
            policy_map = {
                "radius_client":          {"write", "sensitive", "policy"},
                "firewall_nat_baseline":  {"write", "policy"},
                "parking_pool":           {"write", "policy"},
                "pppoe_server":           {"write", "policy"},
                "hotspot":                {"write", "policy"},
                "simple_queues":          {"write"},
                "ip_pools":               {"write"},
                "queue_types":            {"write"},
            }
            for task_name, err in report["task_errors"].items():
                if "not enough permissions" in err.lower() or "permission" in err.lower():
                    policies = policy_map.get(task_name, {"write"})
                    needs_policies |= policies
                    perm_hints.append(f"{task_name}: needs policies {sorted(policies)}")
            if needs_policies:
                report["permission_hint"] = {
                    "issue": "Your RouterOS API user doesn't have all required policies.",
                    "missing_policies": sorted(needs_policies),
                    "fix": ("On the Mikrotik: /user group add name=autoisp-full "
                            "policy=api," + ",".join(sorted(needs_policies | {"read", "write",
                                                                                "api", "sensitive"})) +
                            ",!local,!telnet,!ssh,!winbox,!web,!ftp ; "
                            "then /user set autoisp group=autoisp-full"),
                    "per_task": perm_hints,
                }
            report["message"] = (f"{len(report['task_errors'])} task(s) reported errors — "
                                 "see 'task_errors' / 'permission_hint' for details. "
                                 "Other tasks completed.")
    except Exception as e:  # noqa: BLE001
        report["success"] = False
        report["message"] = str(e)
        if c is not None:
            try:
                report["commands"] = list(getattr(c, "commands", []))
                report["transport"] = c.transport_used or ("simulated" if dry_run else "n/a")
            except Exception:
                pass
    finally:
        if c is not None:
            try:
                c.__exit__(None, None, None)
            except Exception:
                pass
    return report


