    def detect_wan(self) -> Dict:
        """Detect the WAN interface by reading the active default route
        (dst-address=0.0.0.0/0). Falls back to resolving gateway via
        /ip/address if the route row doesn't carry an interface name.

        Returns {"interface": str|None, "gateway": str|None,
                 "source": "route"|"gateway-lookup"|"none",
                 "candidates": [...]}  — UI uses `candidates` to offer a
        dropdown with the resolved interface pre-selected.
        """
        if self.dry_run:
            return {"interface": None, "gateway": None, "source": "none", "candidates": []}
        if self._ssh:
            out, _, _ = self._ssh.exec('/ip route print terse where dst-address="0.0.0.0/0" active=yes')
            return {"interface": None, "gateway": None, "source": "ssh-raw",
                    "raw": out.strip(), "candidates": []}

        # Collect default routes (active only)
        default_routes = []
        for r in self._api.path("ip/route"):
            dst = r.get("dst-address") or ""
            active = (r.get("active") in (True, "true", "yes"))
            if dst == "0.0.0.0/0" and active:
                default_routes.append(r)
        if not default_routes:
            # try without active filter (some v6 routers)
            for r in self._api.path("ip/route"):
                if (r.get("dst-address") or "") == "0.0.0.0/0":
                    default_routes.append(r)

        gateway = None
        iface = None
        source = "none"
        if default_routes:
            route = default_routes[0]
            gateway = route.get("gateway") or None
            # RouterOS v7 sometimes exposes gateway resolved as "IP%interface"
            if gateway and "%" in gateway:
                gateway, iface = gateway.split("%", 1)
                source = "route"
            # Some rows carry an explicit interface hint
            if not iface:
                iface = (route.get("gateway-status") or "").split(" ")[-1] or None
                if iface:
                    source = "route"
            if not iface:
                # Resolve gateway IP -> interface via /ip/address subnet match
                try:
                    import ipaddress as _ip
                    gw_ip = _ip.ip_address(gateway) if gateway else None
                except Exception:
                    gw_ip = None
                if gw_ip is not None:
                    for a in self._api.path("ip/address"):
                        addr = a.get("address") or ""
                        if "/" not in addr:
                            continue
                        try:
                            net = _ip.ip_network(addr, strict=False)
                            if gw_ip in net:
                                iface = a.get("interface")
                                source = "gateway-lookup"
                                break
                        except Exception:
                            continue

        # Build candidate list (running interfaces first)
        candidates = []
        for r in self._api.path("interface"):
            candidates.append({
                "name": r.get("name"), "type": r.get("type"),
                "running": r.get("running") in (True, "true", "yes"),
                "disabled": r.get("disabled") in (True, "true", "yes"),
            })
        candidates.sort(key=lambda x: (not x["running"], x["disabled"], x["name"] or ""))
        return {"interface": iface, "gateway": gateway, "source": source,
                "candidates": candidates, "default_routes": [dict(r) for r in default_routes]}

    def run_unprovision(self) -> Dict:
        """Execute the recovery commands produced by `unprovision_commands()`
        against the router via whichever transport is active. Each command
        is best-effort — errors on individual lines don't abort the run."""
        cmds = self.unprovision_commands()
        executed = []
        errors = []
        if self.dry_run:
            for c in cmds:
                self.commands.append(c)
            return {"dry_run": True, "commands": cmds, "executed": [], "errors": []}

        for c in cmds:
            if c.startswith("#") or not c.strip():
                continue
            self.commands.append(c)
            try:
                if self._ssh:
                    out, err, rc = self._ssh.exec(c)
                    executed.append({"cmd": c, "rc": rc, "stderr": (err or "").strip()})
                    if rc != 0 and (err or "").strip():
                        errors.append({"cmd": c, "stderr": err.strip()})
                else:
                    # Translate the CLI line into an API call
                    parts = c.strip().split()
                    # Find path until first verb (remove/add/set)
                    verbs = {"remove", "add", "set", "print"}
                    path_tokens = []
                    verb = None
                    rest = []
                    for tok in parts[1:]:  # skip leading /
                        if verb is None and tok in verbs:
                            verb = tok
                        elif verb is None:
                            path_tokens.append(tok)
                        else:
                            rest.append(tok)
                    api_path = "/".join(path_tokens)
                    po = self._api.path(api_path)
                    if verb == "remove":
                        # Parse [find ...] filter — rest ≈ ['[find', 'key=val]'] or similar.
                        filter_str = " ".join(rest).strip("[]")
                        # Extract pattern e.g. "find service-name=isp-pppoe" or "find name~\"^plan-\""
                        filters = {}
                        for piece in filter_str.replace("find", "", 1).strip().split():
                            if "=" in piece:
                                k, v = piece.split("=", 1)
                                filters[k] = v.strip('"')
                        removed = 0
                        for row in list(po):
                            match = True
                            for k, v in filters.items():
                                val = row.get(k, "")
                                if v.startswith("~"):
                                    # regex-ish — skip strict matching, approximate contains
                                    import re as _re
                                    pat = v.lstrip("~").strip('"')
                                    if not _re.search(pat, str(val)):
                                        match = False; break
                                elif "~" in k:
                                    # comment~"^..." style
                                    import re as _re
                                    real_key = k.split("~")[0]
                                    pat = v.strip('"')
                                    if not _re.search(pat, str(row.get(real_key, ""))):
                                        match = False; break
                                elif str(val) != v:
                                    match = False; break
                            if match:
                                po.remove(row[".id"])
                                removed += 1
                        executed.append({"cmd": c, "removed": removed})
                    elif verb == "set":
                        # /ppp aaa set use-radius=no
                        params = {}
                        for piece in rest:
                            if "=" in piece:
                                k, v = piece.split("=", 1)
                                params[k] = v
                        # aaa is a "single-row" config item
                        try:
                            po.update(**params)
                            executed.append({"cmd": c, "updated": True})
                        except Exception as _e:
                            errors.append({"cmd": c, "error": str(_e)})
                    else:
                        executed.append({"cmd": c, "skipped": True})
            except Exception as e:  # noqa: BLE001
                errors.append({"cmd": c, "error": str(e)})
        return {"dry_run": False, "commands": cmds, "executed": executed, "errors": errors}

    def switch_to_radius_only(self, radius_server_ip: str = "",
                              radius_secret: str = "",
                              clear_local: bool = False,
                              dry_run_internal: bool = False) -> Dict:
        """Force the router into RADIUS-only authentication mode.

        Rationale:
          Mikrotik checks LOCAL /ppp/secret BEFORE consulting RADIUS.
          As long as any local secret exists, Mikrotik will accept OR
          reject the user locally — RADIUS (and therefore our
          Framed-Pool/walled-garden logic) is never consulted. This
          helper removes that shortcut so every PPPoE auth flows
          through FreeRADIUS, which is the prerequisite for the
          parking-pool / suspension captive-portal feature.

        Steps (each idempotent, safe to re-run):
          A. /ppp/aaa  -> use-radius=yes, accounting=yes,
                         interim-update=0s
          B. /radius   -> ensure an auto-isp-billing entry exists.
                         If not, add (caller must pass radius_server_ip
                         + radius_secret; for an existing correct row
                         they may be empty).
          C. /ppp/secret -> if `clear_local=True`, REMOVE every row.
                             A text backup is returned in the report
                             so the admin can reinstate them.
                             Otherwise leave them untouched; the admin
                             can clean up later or let RADIUS shadow
                             them (Mikrotik will still check local
                             first, so this mode is mainly useful if
                             there are only a couple legacy rows).

        Returns a dict with `success`, `stages`, and `secrets_before`
        (the pre-purge snapshot). NEVER raises — callers check `success`.
        """
        report = {
            "success": False,
            "stages": [],
            "secrets_before": [],
            "cleared_count": 0,
            "aaa": {},
            "radius_row": {},
        }
        if not self._api and not self._ssh:
            report["stages"].append("no-transport")
            report["message"] = "router unreachable (no API / SSH session)"
            return report
        try:
            # A. /ppp/aaa
            if self._api:
                aaa_params = {
                    "use-radius": "yes",
                    "accounting": "yes",
                    "interim-update": "0s",
                }
                if not dry_run_internal:
                    self._api.path("ppp/aaa").update(**aaa_params)
                report["stages"].append("set /ppp/aaa use-radius=yes")
                # snapshot
                for row in self._api.path("ppp/aaa"):
                    report["aaa"] = {k: v for k, v in row.items()
                                     if k in ("use-radius", "accounting",
                                              "interim-update")}
            else:
                report["stages"].append("A: skipped (api only)")

            # B. /radius ensure auto-isp-billing row
            if self._api:
                found = None
                for row in self._api.path("radius"):
                    if (row.get("comment") or "") == "auto-isp-billing":
                        found = row
                        break
                if not found and radius_server_ip and radius_secret:
                    if not dry_run_internal:
                        self._api.path("radius").add(
                            address=radius_server_ip,
                            secret=radius_secret,
                            service="ppp,hotspot",
                            **{"authentication-port": "1812",
                               "accounting-port": "1813"},
                            timeout="3s",
                            comment="auto-isp-billing",
                        )
                        # also CoA listener
                        self._api.path("radius/incoming").set(
                            **{"accept": "yes", "port": "3799"})
                    report["stages"].append("added /radius auto-isp-billing")
                elif found:
                    report["radius_row"] = {
                        "address": found.get("address"),
                        "service": found.get("service"),
                        "comment": found.get("comment"),
                    }
                    report["stages"].append("/radius entry already present")
                else:
                    report["stages"].append(
                        "WARNING: no /radius auto-isp-billing row and no "
                        "radius_server_ip/secret supplied -- Mikrotik will "
                        "now use-radius=yes but has no server to ask; users "
                        "will get Access-Reject until admin adds one.")

            # C. snapshot + optional purge of /ppp/secret
            if self._api:
                for row in self._api.path("ppp/secret"):
                    report["secrets_before"].append({
                        "name": row.get("name"),
                        "service": row.get("service"),
                        "profile": row.get("profile"),
                        "disabled": row.get("disabled"),
                    })
                if clear_local and not dry_run_internal:
                    cnt = 0
                    for row in list(self._api.path("ppp/secret")):
                        try:
                            self._api.path("ppp/secret").remove(row[".id"])
                            cnt += 1
                        except Exception as e:
                            report["stages"].append(f"remove-err {row.get('name')}: {e}")
                    report["cleared_count"] = cnt
                    report["stages"].append(f"removed {cnt} /ppp/secret rows")
                elif clear_local and dry_run_internal:
                    report["stages"].append(
                        f"DRY-RUN would remove {len(report['secrets_before'])} "
                        "/ppp/secret rows")
                else:
                    report["stages"].append(
                        f"kept {len(report['secrets_before'])} /ppp/secret "
                        "rows (Mikrotik will still check local first; pass "
                        "clear_local=true to truly force RADIUS-only)")

            report["success"] = True
            return report
        except Exception as e:
            report["stages"].append(f"error: {e}")
            report["message"] = str(e)
            return report

    def create_pppoe_secret(self, name: str, password: str, profile: str = "isp-default",
                            remote_address: Optional[str] = None) -> Dict:
        params = {"name": name, "password": password, "service": "pppoe", "profile": profile}
        if remote_address:
            params["remote-address"] = remote_address

        cli = self._cli("ppp/secret", "add/set", **params)
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli}
        if self._ssh:
            # add, then set (idempotent)
            self._ssh.exec(f"/ppp secret add name={name} password={password} service=pppoe")
            set_kv = " ".join(f"{k}={v}" for k, v in params.items() if k != "name")
            out, err, rc = self._ssh.exec(f"/ppp secret set [find name={name}] {set_kv}")
            return {"ssh_rc": rc, "ssh_err": err.strip()}
        path_obj = self._api.path("ppp/secret")
        for row in list(path_obj):
            if row.get("name") == name:
                path_obj.update(**{".id": row[".id"],
                                   **{k: v for k, v in params.items() if k != "name"}})
                return {"updated": True, "id": row[".id"]}
        path_obj.add(**params)
        return {"added": True}

    def delete_pppoe_secret(self, name: str) -> Dict:
        cli = self._cli("ppp/secret", "remove", **{"where": f"name={name}"})
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli}
        if self._ssh:
            out, err, rc = self._ssh.exec(f"/ppp secret remove [find name={name}]")
            return {"rc": rc, "stdout": out.strip(), "stderr": err.strip()}
        path_obj = self._api.path("ppp/secret")
        for row in list(path_obj):
            if row.get("name") == name:
                path_obj.remove(row[".id"])
                return {"removed": True}
        return {"not_found": True}


    # ================================================================
    # Multi-scenario: Hotspot & Static-IP per-customer provisioning
    # (Session 19). FreeRADIUS already carries the authoritative per-
    # user attributes (via isp-users). These router-side entries are
    # for cases where RADIUS is down AND for DHCP static-lease bindings
    # (pure-DHCP static IP without PPPoE).
    # ================================================================
    def create_hotspot_user(self, name: str, password: str = "",
                            mac_address: str = "",
                            rate_limit: str = "",
                            profile: str = "default",
                            comment: str = "") -> Dict:
        """Add or update a /ip/hotspot/user entry. Works alongside the
        hotspot RADIUS login — the local user is a fallback if RADIUS
        ever goes down (real-ISP convention)."""
        params = {"name": name, "profile": profile}
        if password:
            params["password"] = password
        if mac_address:
            params["mac-address"] = mac_address.upper()
        if rate_limit:
            params["rate-limit"] = rate_limit
        if comment:
            params["comment"] = comment

        cli = self._cli("ip/hotspot/user", "add/set", **params)
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli}
        if self._ssh:
            self._ssh.exec(f"/ip hotspot user add name={name}")
            set_kv = " ".join(f'{k}={v}' for k, v in params.items() if k != "name")
            out, err, rc = self._ssh.exec(
                f"/ip hotspot user set [find name={name}] {set_kv}")
            return {"ssh_rc": rc, "ssh_err": err.strip()}
        path_obj = self._api.path("ip/hotspot/user")
        for row in list(path_obj):
            if row.get("name") == name:
                path_obj.update(**{".id": row[".id"],
                                   **{k: v for k, v in params.items() if k != "name"}})
                return {"updated": True, "id": row[".id"]}
        path_obj.add(**params)
        return {"added": True}

    def create_dhcp_lease(self, mac_address: str, address: str,
                          server: str = "", comment: str = "") -> Dict:
        """Add a STATIC DHCP reservation so a specific MAC always gets
        the given IP. Used for the `static_ip` auth-type when the
        customer is NOT on PPPoE (pure-DHCP static binding, common on
        business leased-line customers).
        """
        mac = mac_address.upper().strip()
        params = {
            "mac-address": mac,
            "address": address.strip(),
            "lease-time": "0s",     # permanent
        }
        if server:
            params["server"] = server
        if comment:
            params["comment"] = comment

        cli = self._cli("ip/dhcp-server/lease", "add/set", **params)
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli}
        if self._ssh:
            self._ssh.exec(
                f"/ip dhcp-server lease add mac-address={mac} address={address}")
            set_kv = " ".join(f'{k}={v}' for k, v in params.items()
                              if k != "mac-address")
            out, err, rc = self._ssh.exec(
                f"/ip dhcp-server lease set [find mac-address={mac}] {set_kv}")
            return {"ssh_rc": rc, "ssh_err": err.strip()}
        path_obj = self._api.path("ip/dhcp-server/lease")
        for row in list(path_obj):
            if (row.get("mac-address") or "").upper() == mac:
                path_obj.update(**{".id": row[".id"],
                                   **{k: v for k, v in params.items()
                                      if k != "mac-address"}})
                return {"updated": True, "id": row[".id"]}
        path_obj.add(**params)
        return {"added": True}

    def delete_hotspot_user(self, name: str) -> Dict:
        cli = self._cli("ip/hotspot/user", "remove", **{"where": f"name={name}"})
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli}
        if self._ssh:
            out, err, rc = self._ssh.exec(
                f"/ip hotspot user remove [find name={name}]")
            return {"rc": rc, "stdout": out.strip(), "stderr": err.strip()}
        path_obj = self._api.path("ip/hotspot/user")
        for row in list(path_obj):
            if row.get("name") == name:
                path_obj.remove(row[".id"])
                return {"removed": True}
        return {"not_found": True}


    # __S38T_TRUE_STATIC_IP__ -------------------------------------------------
    # True "Static IP" customers do NOT use PPPoE and do NOT use RADIUS.
    # The customer's CPE is manually configured with the static IP +
    # gateway + DNS. Mikrotik just:
    #   (a) allows the IP through srcnat masquerade (MASQUERADE list)
    #   (b) allows the IP through forward firewall           (ALLOW list)
    #   (c) applies a per-IP simple queue with the plan's rate-limit
    # When the customer is Suspended/Deleted we remove those entries so the
    # IP stops forwarding + masquerading — i.e. loses internet.
    def _ensure_static_blocked_rule(self) -> Dict:
        """Idempotently create the firewall filter rule that drops ALL
        traffic from sources in the `STATIC-BLOCKED` address-list.

        We place it at the TOP of the forward chain via `place-before` so
        disabled static-IP customers are blocked before any accept rules
        can match them. Safe to call repeatedly — if the rule already
        exists (matched by comment) we just re-confirm its position.
        """
        tag = "auto-isp-billing-static-blocked-drop"
        try:
            if self._ssh:
                # SSH path — use CLI directly.
                cli = (f"/ip firewall filter add chain=forward "
                       f"src-address-list=STATIC-BLOCKED action=drop "
                       f"comment={tag}")
                self.commands.append(cli)
                if self.dry_run:
                    return {"dry_run": True, "cli": cli}
                # Only add if no rule with this comment exists yet.
                out, _, _ = self._ssh.exec(
                    f"/ip firewall filter print count-only where comment={tag}")
                if out.strip() in ("0", ""):
                    self._ssh.exec(cli)
                return {"ensured": True, "via": "ssh"}
            # API path.
            p = self._api.path("ip/firewall/filter")
            existing = None
            for row in p:
                if row.get("comment") == tag:
                    existing = row
                    break
            if existing:
                return {"ensured": True, "existing_id": existing.get(".id")}
            if self.dry_run:
                return {"dry_run": True, "would_add": tag}
            # Find the first rule in forward chain so we can `place-before` it
            # (Mikrotik evaluates rules top-down; we want block FIRST).
            target_id = None
            for row in p:
                if row.get("chain") == "forward":
                    target_id = row.get(".id")
                    break
            params = {
                "chain": "forward",
                "src-address-list": "STATIC-BLOCKED",
                "action": "drop",
                "comment": tag,
            }
            if target_id:
                params["place-before"] = target_id
            p.add(**params)
            return {"added": True}
        except Exception as e:  # noqa: BLE001
            return {"error": str(e)}

    def flush_conntrack_for_ip(self, ip_address: str) -> Dict:
        """Kill all live conntrack entries whose src OR dst matches `ip`
        so any masqueraded sessions die immediately instead of lingering
        until the TCP timeout expires."""
        ip = (ip_address or "").strip()
        if not ip:
            return {"skipped": True}
        try:
            if self._ssh:
                cli = (f"/ip firewall connection remove "
                       f"[find src-address~\"{ip}:\" or dst-address~\"{ip}:\"]")
                self.commands.append(cli)
                if self.dry_run:
                    return {"dry_run": True, "cli": cli}
                self._ssh.exec(cli)
                return {"via": "ssh"}
            p = self._api.path("ip/firewall/connection")
            removed = 0
            for row in list(p):
                sa = (row.get("src-address") or "").split(":")[0]
                da = (row.get("dst-address") or "").split(":")[0]
                if ip in (sa, da):
                    try:
                        p.remove(row[".id"])
                        removed += 1
                    except Exception:
                        pass
            return {"removed": removed}
        except Exception as e:  # noqa: BLE001
            return {"error": str(e)}

    def _static_queue_name(self, username: str, ip_address: str) -> str:
        """Build a deterministic simple-queue name so we can find+remove
        it later. Falls back to the IP when the username is empty."""
        key = (username or ip_address or "").strip()
        for bad in ("/", " ", "\t", "\n"):
            key = key.replace(bad, "-")
        return f"static-{key}"

    def create_static_ip_binding(self, ip_address: str, rate_limit: str = "",
                                  username: str = "", comment: str = "") -> Dict:
        """Add/refresh firewall address-list rows + simple queue so a
        statically-addressed customer gets internet at the plan rate.

        Idempotent — existing rows (matched by address/name) are updated in
        place, never duplicated."""
        ip = (ip_address or "").strip()
        if not ip:
            return {"success": False, "message": "ip_address required"}
        note = comment or f"auto-isp-billing static {username or ip}".strip()
        results = []
        # (a) MASQUERADE (srcnat rule already exists, we just add this IP).
        # Composite match on BOTH (list, address) so the same IP can live
        # in MASQUERADE and ALLOW simultaneously — single-key `_do_add`
        # would treat them as the same row and skip the second one.
        results.append(self._do_add_composite(
            "ip/firewall/address-list", ["list", "address"],
            {"list": "MASQUERADE", "address": ip, "comment": note}))
        # (b) ALLOW (forward accept rule already exists).
        results.append(self._do_add_composite(
            "ip/firewall/address-list", ["list", "address"],
            {"list": "ALLOW", "address": ip, "comment": note}))
        # (c) Simple queue — one per IP, named so we can find + delete it.
        if rate_limit:
            qname = self._static_queue_name(username, ip)
            results.append(self._do_add("queue/simple", "name", {
                "name": qname,
                "target": f"{ip}/32",
                "max-limit": rate_limit,
                "comment": note,
            }))
        # Ensure the universal STATIC-BLOCKED drop rule exists, then REMOVE
        # this IP from the blocklist (in case it was disabled previously).
        results.append(self._ensure_static_blocked_rule())
        try:
            if self._ssh:
                self._ssh.exec(
                    f"/ip firewall address-list remove [find list=STATIC-BLOCKED address={ip}]")
                results.append({"blocklist_removed": True, "via": "ssh"})
            else:
                p = self._api.path("ip/firewall/address-list")
                removed = 0
                for row in list(p):
                    if (row.get("list") == "STATIC-BLOCKED"
                            and row.get("address") == ip):
                        p.remove(row[".id"])
                        removed += 1
                results.append({"blocklist_removed": removed})
        except Exception as _e:
            results.append({"blocklist_error": str(_e)})
        return {"success": True, "ip": ip, "operations": results}

    def delete_static_ip_binding(self, ip_address: str,
                                  username: str = "") -> Dict:
        """Remove the MASQUERADE + ALLOW + simple-queue rows for this IP so
        the customer loses internet on the router side. Safe no-op if the
        rows were never created."""
        ip = (ip_address or "").strip()
        if not ip:
            return {"success": False, "message": "ip_address required"}
        results = []
        for lst in ("MASQUERADE", "ALLOW"):
            cli = self._cli("ip/firewall/address-list", "remove",
                            **{"where": f"list={lst} address={ip}"})
            self.commands.append(cli)
            if self.dry_run:
                results.append({"dry_run": True, "cli": cli})
                continue
            if self._ssh:
                out, err, rc = self._ssh.exec(
                    f"/ip firewall address-list remove [find list={lst} address={ip}]")
                results.append({"list": lst, "rc": rc,
                                "stdout": out.strip(), "stderr": err.strip()})
            else:
                path_obj = self._api.path("ip/firewall/address-list")
                removed = 0
                for row in list(path_obj):
                    if (row.get("list") == lst and row.get("address") == ip):
                        path_obj.remove(row[".id"])
                        removed += 1
                results.append({"list": lst, "removed": removed})
        # Simple queue by name (we always use static-<username-or-ip>).
        qname = self._static_queue_name(username, ip)
        cli = self._cli("queue/simple", "remove", **{"where": f"name={qname}"})
        self.commands.append(cli)
        if not self.dry_run:
            if self._ssh:
                out, err, rc = self._ssh.exec(
                    f"/queue simple remove [find name={qname}]")
                results.append({"queue": qname, "rc": rc,
                                 "stdout": out.strip(), "stderr": err.strip()})
            else:
                path_obj = self._api.path("queue/simple")
                removed = 0
                for row in list(path_obj):
                    if row.get("name") == qname:
                        path_obj.remove(row[".id"])
                        removed += 1
                results.append({"queue": qname, "removed": removed})
        # ACTIVELY block the IP: ensure drop rule + add IP to STATIC-BLOCKED
        # + flush any live conntrack entries so existing TCP sessions die.
        results.append(self._ensure_static_blocked_rule())
        results.append(self._do_add_composite(
            "ip/firewall/address-list", ["list", "address"],
            {"list": "STATIC-BLOCKED", "address": ip,
             "comment": f"auto-isp-billing blocked {username or ip}".strip()}))
        results.append(self.flush_conntrack_for_ip(ip))
        return {"success": True, "ip": ip, "operations": results}
    # -------------------------------------------------------------- /S38T_TRUE_STATIC_IP

    def delete_dhcp_lease(self, mac_address: str) -> Dict:
        mac = (mac_address or "").upper().strip()
        cli = self._cli("ip/dhcp-server/lease", "remove",
                        **{"where": f"mac-address={mac}"})
        self.commands.append(cli)
        if self.dry_run:
            return {"dry_run": True, "cli": cli}
        if self._ssh:
            out, err, rc = self._ssh.exec(
                f"/ip dhcp-server lease remove [find mac-address={mac}]")
            return {"rc": rc, "stdout": out.strip(), "stderr": err.strip()}
        path_obj = self._api.path("ip/dhcp-server/lease")
        for row in list(path_obj):
            if (row.get("mac-address") or "").upper() == mac:
                path_obj.remove(row[".id"])
                return {"removed": True}
        return {"not_found": True}


