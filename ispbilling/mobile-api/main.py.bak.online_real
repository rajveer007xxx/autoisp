                         (cid,)).fetchall()]
    return {"ok": True, "admins": admins, "sub_lcos": sublcos, "employees": employees}

@app.post("/api/mobile/v1/complaints")
def create_complaint(body: ComplaintIn,
                     authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    customer_id = body.customer_id
    if s["user_type"] == "customer":
        with _conn() as c:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE company_id=? AND (username=? OR customer_id=?) LIMIT 1",
                (cid, s["username"], s["username"])).fetchone()
            if cust: customer_id = cust["customer_id"]
    if not customer_id:
        # _S40zπ_MOBILE_FIX_  Allow admin/staff to file an internal ticket
        # without selecting a customer. Use a synthetic 'INTERNAL' ID.
        customer_id = "INTERNAL"
    import time
    ticket = f"MOB{int(time.time())}"
    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")  # _S40zπ_MOBILE_FIX_
    with _conn() as c:
        c.execute(
            "INSERT INTO complaints (company_id, customer_id, ticket_no, "
            " complaint_type, priority, subject, description, status, "
            " created_at, updated_at, kind, source, target_role) "
            "VALUES (?,?,?,?,?,?,?, 'Open', ?, ?, 'Complaint', 'mobile', 'admin')",
            (cid, customer_id, ticket, body.complaint_type, body.priority,
             body.subject, body.description, now, now))
        c.commit()
    return {"ok": True, "ticket_no": ticket}

# ---- record payment + return receipt JSON ----
@app.post("/api/mobile/v1/subscribers/{cust_pk}/payment")
def record_payment(cust_pk: int, body: PaymentIn,
                   authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    if s["user_type"] not in ("admin", "employee", "sub_lco"):
        raise HTTPException(403, "forbidden")
    cid = s["company_id"] or ""
    if body.amount <= 0:
        raise HTTPException(400, "amount_must_be_positive")
    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")  # _S40zπ_MOBILE_FIX_
    with _conn() as c:
        cust = c.execute(
            "SELECT id, customer_id, customer_name, customer_phone, customer_email, "
            "       total_bill_amount, received_amount, plan_id, end_date "
            "  FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not cust:
            raise HTTPException(404, "not_found")
        # 1) Insert transaction row
        c.execute(
            "INSERT INTO transactions (company_id, customer_id, transaction_type, "
            "  amount, invoice_id, period_months, remarks, created_at, "
            "  payment_method, reference_no, note, transaction_date) "
            "VALUES (?,?, 'Payment', ?, NULL, NULL, ?, ?, ?, ?, ?, ?)",
            (cid, cust["customer_id"], body.amount,
             body.note or "Mobile-app payment", now,
             body.payment_mode, body.reference_no or "", body.note or "", now))
        tx_id = c.lastrowid
        # 2) Reduce dues on customer row
        new_recv = (cust["received_amount"] or 0) + body.amount
        new_bill = max(0.0, (cust["total_bill_amount"] or 0) - body.amount)
        c.execute(
            "UPDATE customers SET received_amount=?, total_bill_amount=?, "
            "   payment_mode=?, transaction_id=?, updated_at=? WHERE id=?",
            (new_recv, new_bill, body.payment_mode,
             body.reference_no or "", now, cust_pk))
        # 3) Company / superadmin name for receipt header
        comp = c.execute(
            "SELECT company_name, gst_number, company_address, company_phone "
            "  FROM companies WHERE company_id=?", (cid,)).fetchone()
        c.commit()

    receipt = {
        "receipt_no":   f"R{tx_id:06d}",
        "datetime":     now,
        "company_id":   cid,
        "company_name": (comp["company_name"] if comp else "AutoISP Billing"),
        "company_gst":  (comp["gst_number"]   if comp else ""),
        "company_addr": (comp["company_address"] if comp else ""),
        "company_phone":(comp["company_phone"]   if comp else ""),
        "customer": {
            "id":    cust["customer_id"],
            "name":  cust["customer_name"],
            "phone": cust["customer_phone"],
            "email": cust["customer_email"],
        },
        "amount":        body.amount,
        "payment_mode":  body.payment_mode,
        "reference_no":  body.reference_no or "",
        "note":          body.note or "",
        "balance_due":   new_bill,
        "received_by":   s["username"],
    }
    return {"ok": True, "transaction_id": tx_id, "receipt": receipt}

# ---- create subscriber ----
@app.post("/api/mobile/v1/subscribers")
def create_subscriber(body: SubscriberCreateIn,
                      authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    if s["user_type"] not in ("admin", "employee", "sub_lco"):
        raise HTTPException(403, "forbidden")
    cid = s["company_id"] or ""
    import secrets as _se, time as _t
    cust_id = str(int(_t.time()))[-8:]   # 8-digit numeric customer id
    username = (body.username or f"u{cust_id}").strip().lower()
    password = body.password or _se.token_urlsafe(8)

    pw_hash = ""
    if _bcrypt:
        try: pw_hash = _bcrypt.hash(password)
        except Exception: pw_hash = ""

    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")  # _S40zπ_MOBILE_FIX_
    with _conn() as c:
        plan = c.execute(
            "SELECT id, after_tax_amount, validity, validity_unit "
            "  FROM plans WHERE id=? AND company_id=?",
            (body.plan_id, cid)).fetchone()
        if not plan:
            raise HTTPException(400, "invalid_plan_id")
        amt = float(plan["after_tax_amount"] or 0)
        period = max(1, int(body.period or 1))
        bill = amt * period
        # Compute end_date
        from datetime import timedelta as _td
        days = period * (30 if (plan["validity_unit"] or "days").lower().startswith("month") else int(plan["validity"] or 30))
        end_date = (datetime.now(timezone.utc) + _td(days=days)).date().isoformat()

        c.execute(
            "INSERT INTO customers (company_id, customer_id, username, "
            " password_hash, registration_type, service_type, customer_name, "
            " customer_phone, customer_email, address, locality, city, state, "
            " pincode, plan_id, monthly_amount, period, end_date, bill_amount, "
            " total_bill_amount, received_amount, payment_mode, status, "
            " auth_type, static_ip_address, sub_lco_id, location_id, "
            " created_at, updated_at, start_date) "
            "VALUES (?,?,?,?, 'Online', 'Broadband', ?,?,?,?,?,?,?,?,?,?,?,?, "
            "        ?, ?, ?, 'Active', ?,?,?,?, ?, ?, ?)",
            (cid, cust_id, username, pw_hash,
             body.customer_name, body.customer_phone, body.customer_email or "",
             body.address, body.locality or "", body.city or "",
             body.state or "", body.pincode or "",
             body.plan_id, amt, period, end_date,
             bill, max(0.0, bill - (body.received_amount or 0)),
             body.received_amount or 0,
             body.payment_mode or "",
             body.auth_type or "pppoe", body.static_ip_address or "",
             body.sub_lco_id, body.location_id,
             now, now, datetime.now(timezone.utc).date().isoformat()))
        new_pk = c.lastrowid
        # If they paid something at install — log a transaction
        if body.received_amount and body.received_amount > 0:
            c.execute(
                "INSERT INTO transactions (company_id, customer_id, "
                " transaction_type, amount, period_months, remarks, "
                " payment_method, transaction_date, created_at) "
                "VALUES (?,?, 'Payment', ?, ?, ?, ?, ?, ?)",
                (cid, cust_id, body.received_amount, period,
                 "Initial payment at signup",
                 body.payment_mode or "Cash", now, now))
        c.commit()
    return {"ok": True, "id": new_pk, "customer_id": cust_id,
            "username": username, "password": password,
            "end_date": end_date, "bill_amount": bill}

# ---- customer self: profile + billing ----
@app.get("/api/mobile/v1/me/billing")
def me_billing(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    if s["user_type"] != "customer":
        raise HTTPException(403, "customer_only")
    cid = s["company_id"] or ""
    with _conn() as c:
        row = c.execute(
            f"SELECT {id, customer_id, username, customer_name, customer_email, customer_phone, alt_mobile, address, locality, city, state, pincode, plan_id, monthly_amount, auto_renew, customer_type, mac_address, ip_address, vendor, modem_no, start_date, end_date, period, bill_amount, total_bill_amount, received_amount, security_deposit, installation_charges, router_charges, discount_credit, status, payment_mode, transaction_id, payment_notes, service_type, sub_lco_id, location_id, auth_type, static_ip_address, zone, node, allow_devices, custom_rate_limit, created_at, updated_at, installation_date, id_proof, id_proof_no} FROM customers "
            f" WHERE company_id=? AND (username=? OR customer_id=?) LIMIT 1",
            (cid, s["username"], s["username"])).fetchone()
        if not row:
            raise HTTPException(404, "not_found")
        r = {k: row[k] for k in row.keys()}
        if r.get("plan_id"):
            p = c.execute(
                "SELECT plan_name, speed, after_tax_amount, validity, validity_unit "
                "  FROM plans WHERE id=?", (r["plan_id"],)).fetchone()
            if p:
                r["plan_name"] = p["plan_name"]; r["plan_speed"] = p["speed"]
                r["plan_amount"] = p["after_tax_amount"]
                r["plan_validity"] = f"{p['validity'] or ''} {p['validity_unit'] or ''}".strip()
        rows = c.execute(
            "SELECT id, transaction_type, amount, payment_method, reference_no, "
            "       created_at FROM transactions "
            " WHERE company_id=? AND customer_id=? "
            " ORDER BY id DESC LIMIT 20", (cid, r["customer_id"])).fetchall()
        r["payments"] = [dict(x) for x in rows]
    return {"ok": True, "subscriber": r}




