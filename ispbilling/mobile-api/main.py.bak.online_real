#                            S39R5N — NEW ENDPOINTS
# ============================================================================

@app.get("/api/mobile/v1/transactions")
def transactions(authorization: Optional[str] = Header(None),
                 q: str = "", customer_type: str = "",
                 locality_id: Optional[int] = None,
                 limit: int = Query(100, ge=1, le=500)):
    """List recent transactions, scoped by role + filterable by user-type
    and locality. Times are returned in ISO8601 — the mobile UI converts
    to DD-MM-YYYY HH:MM in Asia/Kolkata."""
    s = _require_auth(authorization)
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # Join customers to apply scope; transactions table has no scope of its own.
        sql = ("SELECT t.id, t.transaction_date, t.amount, t.transaction_type, "
               "        t.payment_method, t.reference_no, t.start_date, t.end_date, "
               "        t.period_months, t.remarks, t.created_at, "
               "        c.customer_name, c.customer_id, c.username, c.customer_type, "
               "        c.location_id "
               "   FROM transactions t "
               "   JOIN customers c ON c.customer_id = t.customer_id "
               + scope_sql.replace("WHERE company_id=?", "AND c.company_id=?"))
        sql = sql.replace(" WHERE company_id=?", " AND c.company_id=?")
        # The scope_sql starts with " WHERE company_id=? "; we just made it conjunctive.
        # Re-prefix with WHERE 1=1.
        sql = sql.replace(" AND c.company_id=?", " WHERE 1=1 AND c.company_id=?", 1)
        params = list(scope_params)
        if customer_type and customer_type.lower() not in ("all", ""):
            sql += " AND LOWER(IFNULL(c.customer_type,\'\'))=LOWER(?) "
            params.append(customer_type)
        if locality_id:
            sql += " AND c.location_id=? "
            params.append(int(locality_id))
        if q:
            sql += (" AND (c.customer_name LIKE ? OR c.customer_id LIKE ? "
                    " OR c.username LIKE ? OR t.reference_no LIKE ?) ")
            like = f"%{q}%"
            params += [like]*4
        sql += " ORDER BY t.id DESC LIMIT ? "
        params.append(limit)
        rows = c.execute(sql, params).fetchall()
        items = []
        for r in rows:
            d = {k: r[k] for k in r.keys()}
            items.append(d)
        return {"ok": True, "count": len(items), "items": items}


@app.get("/api/mobile/v1/transactions/{txn_id}")
def transaction_detail(txn_id: int, authorization: Optional[str] = Header(None)):
    """Detailed transaction view including the customer's plan + period."""
    s = _require_auth(authorization)
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        sql = ("SELECT t.*, c.customer_name, c.customer_id AS cust_id, c.username, "
               "        c.customer_type, c.mobile, c.email, c.address, "
               "        p.plan_name, p.speed, p.monthly_amount AS plan_amount "
               "   FROM transactions t "
               "   JOIN customers c ON c.customer_id = t.customer_id "
               "   LEFT JOIN plans p ON p.id = c.plan_id "
               "  WHERE t.id=? AND c.company_id=? LIMIT 1")
        params = [txn_id, scope_params[0]]
        row = c.execute(sql, params).fetchone()
    if not row:
        raise HTTPException(404, "Transaction not found")
    d = {k: row[k] for k in row.keys()}
    sd = (d.get("start_date") or "").strip()
    ed = (d.get("end_date") or "").strip()
    def _fmt(x):
        if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
            return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
        return x or ""
    if sd and ed:
        d["formatted_period"] = f"{_fmt(sd)} to {_fmt(ed)}"
    else:
        d["formatted_period"] = ""
    return {"ok": True, "transaction": d}


@app.get("/api/mobile/v1/staff")
def staff_list(authorization: Optional[str] = Header(None)):
    """Return Admins + Sub-LCOs + Employees for the ticket-assign dropdown."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    out = []
    with _conn() as c:
        try:
            for r in c.execute(
                "SELECT id, admin_name AS name, admin_id AS user_id "
                "  FROM admins WHERE company_id=? ORDER BY admin_name", (cid,)
            ).fetchall():
                out.append({"id": r["id"], "name": r["name"],
                            "user_id": r["user_id"], "role": "admin"})
        except Exception:
            pass
        try:
            for r in c.execute(
                "SELECT id, name, sub_lco_id AS user_id "
                "  FROM sub_lcos WHERE company_id=? ORDER BY name", (cid,)
            ).fetchall():
                out.append({"id": r["id"], "name": r["name"],
                            "user_id": r["user_id"], "role": "sub_lco"})
        except Exception:
            pass
        try:
            for r in c.execute(
                "SELECT id, employee_name AS name, employee_id AS user_id "
                "  FROM employees WHERE company_id=? ORDER BY employee_name", (cid,)
            ).fetchall():
                out.append({"id": r["id"], "name": r["name"],
                            "user_id": r["user_id"], "role": "employee"})
        except Exception:
            pass
    return {"ok": True, "items": out}


@app.get("/api/mobile/v1/localities")
def localities(authorization: Optional[str] = Header(None)):
    """Locality / area dropdown."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    with _conn() as c:
        rows = c.execute(
            "SELECT id, locality_name, city, state "
            "  FROM locations WHERE company_id=? ORDER BY locality_name", (cid,)
        ).fetchall()
    return {"ok": True, "items": [
        {"id": r["id"], "name": r["locality_name"], "city": r["city"], "state": r["state"]}
        for r in rows
    ]}


@app.get("/api/mobile/v1/invoices")
def invoices(authorization: Optional[str] = Header(None),
             q: str = "", user_type: str = "",
             locality_id: Optional[int] = None,
             limit: int = Query(100, ge=1, le=500)):
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        sql = ("SELECT i.id, i.invoice_no, i.total_amount, i.created_at, "
               "        i.due_date, i.status, "
               "        c.customer_name, c.customer_id, c.customer_type, "
               "        c.location_id, "
               "        IFNULL(c.total_bill_amount,0) - IFNULL(c.received_amount,0) AS due_amount "
               "   FROM invoices i "
               "   JOIN customers c ON c.customer_id = i.customer_id "
               "  WHERE 1=1 ")
        params = []
        # Re-add scope
        sub = scope_sql.replace(" WHERE company_id=?", " AND c.company_id=?", 1)
        sql += sub
        params += list(scope_params)
        if user_type and user_type.lower() not in ("all", ""):
            sql += " AND LOWER(IFNULL(c.customer_type,\'\'))=LOWER(?) "
            params.append(user_type)
        if locality_id:
            sql += " AND c.location_id=? "
            params.append(int(locality_id))
        if q:
            sql += (" AND (i.invoice_no LIKE ? OR c.customer_name LIKE ? "
                    " OR c.customer_id LIKE ?) ")
            like = f"%{q}%"
            params += [like]*3
        sql += " ORDER BY i.id DESC LIMIT ? "
        params.append(limit)
        rows = c.execute(sql, params).fetchall()
        items = [{k: r[k] for k in r.keys()} for r in rows]
    return {"ok": True, "count": len(items), "items": items}
