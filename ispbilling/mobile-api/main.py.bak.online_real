        sublcos = [{"id": r["sub_lco_code"], "name": r["name"], "code": r["sub_lco_code"]}
                   for r in c.execute(
                       "SELECT sub_lco_code, name FROM sub_lcos WHERE company_id=?",
                       (cid,)).fetchall()]
        employees = [{"id": r["employee_code"], "name": r["employee_name"], "code": r["employee_code"]}
                     for r in c.execute(
