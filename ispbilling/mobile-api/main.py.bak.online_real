# ---- list complaints ----
@app.get("/api/mobile/v1/complaints")
def list_complaints(authorization: Optional[str] = Header(None),
                    status: Optional[str] = None,
                    page: int = Query(1, ge=1), per: int = Query(20, ge=1, le=100)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    sql = ("SELECT id, ticket_no, customer_id, complaint_type, priority, subject, "
           "       description, status, created_at, resolved_at, resolved_by "
           "  FROM complaints WHERE company_id=?")
    params: list = [cid]
    # If user is a customer, scope to own
    if s["user_type"] == "customer":
        # username = customer_id or username; fetch their customer_id
        with _conn() as c:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE company_id=? AND (username=? OR customer_id=?) LIMIT 1",
                (cid, s["username"], s["username"])).fetchone()
        if cust:
            sql += " AND customer_id=?"; params.append(cust["customer_id"])
        else:
            return {"ok": True, "items": [], "page": page, "per": per}
    if status:
        sql += " AND IFNULL(status,'') = ?"; params.append(status)
    sql += " ORDER BY id DESC LIMIT ? OFFSET ?"
    params += [per, (page - 1) * per]
    with _conn() as c:
        rows = c.execute(sql, params).fetchall()
    return {"ok": True, "items": [dict(r) for r in rows],
            "page": page, "per": per}

# ---- raise complaint ----

# _S40zπ_MOBILE_FIX_  Tickets endpoint — alias of complaints with relaxed schema
class _TicketIn(BaseModel):
    subject: str
    description: str
    complaint_type: Optional[str] = "Other"
    priority: Optional[str] = "Medium"
    customer_id: Optional[str] = None
    target_type: Optional[str] = None     # "admin" / "sub_lco" / "employee"
    target_id: Optional[str] = None       # admin_id / sub_lco_code / employee_code

@app.post("/api/mobile/v1/tickets")
def create_ticket(body: _TicketIn,
                  authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    customer_id = body.customer_id or "INTERNAL"
    import time as _t
    ticket = f"TKT{int(_t.time())}"
    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
    target_role = (body.target_type or "admin").lower()
    if target_role not in ("admin", "sub_lco", "employee"):
        target_role = "admin"
    with _conn() as c:
        c.execute(
            "INSERT INTO complaints (company_id, customer_id, ticket_no, "
            " complaint_type, priority, subject, description, status, "
            " created_at, updated_at, kind, source, target_role, resolved_by) "
            "VALUES (?,?,?,?,?,?,?,'Open',?,?,'Ticket','mobile',?,?)",
            (cid, customer_id, ticket, body.complaint_type, body.priority,
             body.subject, body.description, now, now, target_role,
             body.target_id or ""))
        c.commit()
    return {"ok": True, "ticket_no": ticket, "id": ticket}

@app.get("/api/mobile/v1/tickets/targets")
def ticket_targets(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
