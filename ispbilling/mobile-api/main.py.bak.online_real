# ---- list subscriber payments ----
@app.get("/api/mobile/v1/subscribers/{cust_pk}/payments")
def subscriber_payments(cust_pk: int, authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        cust = c.execute(
            "SELECT customer_id FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not cust:
            raise HTTPException(404, "not_found")
        rows = c.execute(
            "SELECT id, transaction_type, amount, payment_method, reference_no, "
            "       note, remarks, start_date, end_date, period_months, created_at "
            "  FROM transactions "
            " WHERE company_id=? AND customer_id=? "
            " ORDER BY id DESC LIMIT 100", (cid, cust["customer_id"])).fetchall()
    return {"ok": True, "items": [dict(r) for r in rows]}

# ---- usage (last 7 days from radacct) ----
@app.get("/api/mobile/v1/subscribers/{cust_pk}/usage")
def subscriber_usage(cust_pk: int, authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        cust = c.execute(
            "SELECT id, username, customer_id FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not cust:
            raise HTTPException(404, "not_found")
        un = cust["username"] or ""
    days = []
    total_in = 0
    total_out = 0
    if un:
        try:
            with _ra_conn() as rc:
                # Daily sum for last 7 days (UTC)
                rows = rc.execute(
                    "SELECT DATE(acctstarttime) AS d, "
                    "       SUM(acctinputoctets)  AS bin, "
                    "       SUM(acctoutputoctets) AS bout, "
                    "       COUNT(*) AS sess "
                    "  FROM radacct "
                    " WHERE username=? "
                    "   AND acctstarttime >= DATETIME('now','-7 days') "
                    " GROUP BY DATE(acctstarttime) "
                    " ORDER BY d ASC", (un,)).fetchall()
                for r in rows:
                    days.append({
                        "date": r["d"],
                        "bytes_in": int(r["bin"] or 0),
                        "bytes_out": int(r["bout"] or 0),
                        "sessions": int(r["sess"] or 0),
                    })
                tot = rc.execute(
                    "SELECT SUM(acctinputoctets) AS bin, SUM(acctoutputoctets) AS bout "
                    "  FROM radacct WHERE username=?", (un,)).fetchone()
                if tot:
                    total_in  = int(tot["bin"]  or 0)
                    total_out = int(tot["bout"] or 0)
        except Exception:
            pass
    return {"ok": True, "days": days,
            "total_bytes_in": total_in, "total_bytes_out": total_out}

