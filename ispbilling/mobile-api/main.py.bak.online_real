"""
AutoISP Billing — Mobile API Service (FastAPI)

Separate service from admin-portal. Listens on 0.0.0.0:8005.
Reads/writes the same SQLite DB as the main portal.

Endpoints (v1):
  POST  /api/mobile/v1/auth/login          # 5 roles: customer/admin/employee/sub_lco/superadmin
  POST  /api/mobile/v1/auth/logout
  GET   /api/mobile/v1/auth/me
  GET   /api/mobile/v1/login/banners       # promo/popup carousel for login page
  GET   /api/mobile/v1/dashboard/summary   # tile counts (subscribers, dues, online, complaints)
  GET   /api/mobile/v1/subscribers         # ?q=&type=Broadband|Cable&page=&per=
  GET   /api/mobile/v1/subscribers/online  # currently-online customers (radacct open sessions)
  GET   /api/mobile/v1/subscribers/{id}    # detail
  GET   /api/mobile/v1/health
"""
import os
import sys
import sqlite3
import secrets
from zoneinfo import ZoneInfo
from datetime import datetime, timedelta, timezone
from typing import Optional, List

from fastapi import FastAPI, HTTPException, Header, Query, Body
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse
from pydantic import BaseModel

# Reuse the existing main DB + bcrypt verifier from admin-portal.
sys.path.insert(0, "/opt/ispbilling/admin-portal")
DB_PATH = "/var/lib/autoispbilling/autoispbilling.db"
RADACCT_PATH = "/var/lib/freeradius/radacct.db"

try:
    from passlib.hash import bcrypt as _bcrypt
except Exception:
    _bcrypt = None

app = FastAPI(title="AutoISP Mobile API", version="1.0.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],   # mobile clients only — use Authorization header
    allow_credentials=False,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ---------------- DB helper ----------------
def _conn():
    c = sqlite3.connect(DB_PATH, timeout=10)
    c.row_factory = sqlite3.Row
    return c

def _ra_conn():
    return sqlite3.connect(f"file:{RADACCT_PATH}?mode=ro", uri=True, timeout=5)

# ---------------- Bootstrap mobile tables ----------------
def _bootstrap():
    with _conn() as c:
        c.executescript("""
            CREATE TABLE IF NOT EXISTS mobile_login_banners (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                title       TEXT NOT NULL,
                message     TEXT,
                image_url   TEXT,
                link_url    TEXT,
                is_popup    INTEGER NOT NULL DEFAULT 0,
                start_date  TEXT,
                end_date    TEXT,
                active      INTEGER NOT NULL DEFAULT 1,
                created_at  TEXT NOT NULL DEFAULT (datetime('now')),
                created_by  TEXT
            );

            CREATE TABLE IF NOT EXISTS mobile_sessions (
                token       TEXT PRIMARY KEY,
                user_type   TEXT NOT NULL,
                company_id  TEXT,
                user_pk     TEXT,
                username    TEXT,
                created_at  TEXT NOT NULL DEFAULT (datetime('now')),
                last_seen   TEXT,
                expires_at  TEXT,
                device_info TEXT
            );
        """)
        c.commit()
_bootstrap()

# ---------------- Auth helpers ----------------
def _verify_pwd(stored_hash: Optional[str], plain: str) -> bool:
    if not stored_hash or not plain:
        return False
    if not _bcrypt:
        return False
    try:
        return _bcrypt.verify(plain, stored_hash)
    except Exception:
        return False

def _new_token(user_type: str, company_id: str, user_pk: str,
               username: str, device_info: str = "") -> str:
    tok = secrets.token_urlsafe(32)
    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")  # _S40zπ_MOBILE_FIX_
    exp = (datetime.now(timezone.utc) + timedelta(days=30)).isoformat()
    with _conn() as c:
        c.execute(
            "INSERT INTO mobile_sessions (token,user_type,company_id,user_pk,"
            " username,created_at,last_seen,expires_at,device_info) "
            "VALUES (?,?,?,?,?,?,?,?,?)",
            (tok, user_type, company_id, str(user_pk), username,
             now, now, exp, device_info or ""))
        c.commit()
    return tok

def _resolve_token(authorization: Optional[str]) -> Optional[dict]:
    if not authorization:
        return None
    if not authorization.lower().startswith("bearer "):
        return None
    tok = authorization.split(None, 1)[1].strip()
    if not tok:
        return None
    with _conn() as c:
        row = c.execute(
            "SELECT * FROM mobile_sessions WHERE token=?", (tok,)).fetchone()
        if not row:
            return None
        # Update last_seen, expire if too old
        if row["expires_at"] and row["expires_at"] < datetime.now(timezone.utc).isoformat():
            return None
        c.execute("UPDATE mobile_sessions SET last_seen=? WHERE token=?",
                  (datetime.now(timezone.utc).isoformat(), tok))
        c.commit()
        return dict(row)

def _require_auth(authorization: Optional[str]) -> dict:
    s = _resolve_token(authorization)
    if not s:
        raise HTTPException(401, "auth_required")
    return s

# ---------------- Models ----------------
class LoginIn(BaseModel):
    user_type: str            # customer | admin | employee | sub_lco | superadmin
    company_id: Optional[str] = None
    username: str
    password: str
    device_info: Optional[str] = ""

class BannerIn(BaseModel):
    title: str
    message: Optional[str] = ""
    image_url: Optional[str] = ""
    link_url: Optional[str] = ""
    is_popup: bool = False
    start_date: Optional[str] = None
    end_date: Optional[str] = None
    active: bool = True

# ---------------- Health ----------------
class SsoMintIn(BaseModel):
    target: Optional[str] = None  # e.g. "/admin/add-customer?mobile=1"


@app.post("/api/mobile/v1/auth/sso-mint")
def sso_mint(body: SsoMintIn,
             authorization: Optional[str] = Header(default=None)):
    """_S40g_ — Mint a short-lived (5 min) one-time SSO token from the
    caller's mobile session. The web side consumes this at /auth/sso?token=…,
    sets a normal web session cookie, and redirects to the requested
    target. Caller passes a valid `Authorization: Bearer <mobile-token>`."""
    s = _require_auth(authorization)
    tok = secrets.token_urlsafe(32)
    exp = (datetime.now(timezone.utc) + timedelta(minutes=5)).isoformat()
    with _conn() as c:
        c.execute(
            "INSERT INTO mobile_sso_tokens "
            "(token,user_type,company_id,user_pk,username,target,expires_at) "
            "VALUES (?,?,?,?,?,?,?)",
            (tok, s["user_type"], s["company_id"], s["user_pk"],
             s["username"], (body.target or ""), exp))
        c.commit()
    return {"ok": True, "sso_token": tok,
            "expires_at": exp,
            "url": f"/auth/sso?token={tok}"}


@app.get("/api/mobile/v1/health")
def health():
    return {"ok": True, "service": "mobile-api", "version": "1.0.0",
            "ts": datetime.now(timezone.utc).isoformat()}

# ---------------- Login banners (public) ----------------
@app.get("/api/mobile/v1/login/banners")
def list_banners():
    today = datetime.now(timezone.utc).date().isoformat()
    with _conn() as c:
        rows = c.execute(
            "SELECT id,title,message,image_url,link_url,is_popup,"
            "       start_date,end_date "
            "  FROM mobile_login_banners "
            " WHERE active=1 "
            "   AND (start_date IS NULL OR start_date='' OR start_date<=?) "
            "   AND (end_date   IS NULL OR end_date  ='' OR end_date  >=?) "
            " ORDER BY id DESC LIMIT 50", (today, today)).fetchall()
    items = [dict(r) for r in rows]
    return {"ok": True, "items": items, "popups":
            [x for x in items if x.get("is_popup")]}

# ---------------- Auth ----------------
@app.post("/api/mobile/v1/auth/login")
def login(body: LoginIn):
    ut = (body.user_type or "").strip().lower()
    cid = (body.company_id or "").strip()
    un = (body.username or "").strip()
    pw = body.password or ""

    if ut not in ("customer","admin","employee","sub_lco"):
        raise HTTPException(400, "invalid_user_type")
    if not un or not pw:
        raise HTTPException(400, "missing_credentials")

    with _conn() as c:
        if ut == "admin":
            row = c.execute(
                "SELECT id,admin_id,company_id,password_hash,admin_name AS name "
                "  FROM admins WHERE admin_id=? AND company_id=?",
                (un, cid)).fetchone()
            if not row or not _verify_pwd(row["password_hash"], pw):
                raise HTTPException(401, "invalid_credentials")
            tok = _new_token("admin", row["company_id"], row["id"],
                             row["admin_id"], body.device_info or "")
            return {"ok": True, "token": tok,
                    "user": {"id": row["id"], "name": row["name"],
                              "company_id": row["company_id"],
                              "username": row["admin_id"], "role": "admin"}}

        if ut == "customer":
            # username can be username/customer_id; company narrows scope
            q = ("SELECT id,customer_id,username,company_id,password_hash,"
                 "       customer_name,customer_phone AS mobile_no,status "
                 "  FROM customers "
                 " WHERE (username=? OR customer_id=?) ")
            params = [un, un]
            if cid:
                q += " AND company_id=?"; params.append(cid)
            row = c.execute(q + " LIMIT 1", params).fetchone()
            if not row or not _verify_pwd(row["password_hash"], pw):
                raise HTTPException(401, "invalid_credentials")
            tok = _new_token("customer", row["company_id"], row["id"],
                             row["username"] or row["customer_id"],
                             body.device_info or "")
            return {"ok": True, "token": tok,
                    "user": {"id": row["id"], "name": row["customer_name"],
                              "company_id": row["company_id"],
                              "username": row["username"] or row["customer_id"],
                              "mobile": row["mobile_no"],
                              "status": row["status"], "role": "customer"}}

        if ut == "employee":
            row = c.execute(
                "SELECT id,employee_code,company_id,password_hash,employee_name AS name "
                "  FROM employees WHERE employee_code=? AND company_id=?",
                (un, cid)).fetchone()
            if not row or not _verify_pwd(row["password_hash"], pw):
                raise HTTPException(401, "invalid_credentials")
            tok = _new_token("employee", row["company_id"], row["id"],
                             row["employee_code"], body.device_info or "")
            return {"ok": True, "token": tok,
                    "user": {"id": row["id"], "name": row["name"],
                              "company_id": row["company_id"],
                              "username": row["employee_code"], "role": "employee"}}

        if ut == "sub_lco":
            row = c.execute(
                "SELECT id,sub_lco_code,company_id,password_hash,name "
                "  FROM sub_lcos WHERE sub_lco_code=? AND company_id=?",
                (un, cid)).fetchone()
            if not row or not _verify_pwd(row["password_hash"], pw):
                raise HTTPException(401, "invalid_credentials")
            tok = _new_token("sub_lco", row["company_id"], row["id"],
                             row["sub_lco_code"], body.device_info or "")
            return {"ok": True, "token": tok,
                    "user": {"id": row["id"], "name": row["name"],
                              "company_id": row["company_id"],
                              "username": row["sub_lco_code"], "role": "sub_lco"}}

        if ut == "superadmin":
            row = c.execute(
                "SELECT id,superadmin_id,password_hash,superadmin_name AS name "
                "  FROM superadmins WHERE superadmin_id=?",
                (un,)).fetchone()
            if not row or not _verify_pwd(row["password_hash"], pw):
                raise HTTPException(401, "invalid_credentials")
            tok = _new_token("superadmin", "", row["id"],
                             row["superadmin_id"], body.device_info or "")
            return {"ok": True, "token": tok,
                    "user": {"id": row["id"], "name": row["name"],
                              "username": row["superadmin_id"], "role": "superadmin"}}

    raise HTTPException(401, "invalid_credentials")

@app.post("/api/mobile/v1/auth/logout")
def logout(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    with _conn() as c:
        c.execute("DELETE FROM mobile_sessions WHERE token=?",
                  (authorization.split(None,1)[1].strip(),))
        c.commit()
    return {"ok": True}

@app.get("/api/mobile/v1/auth/me")
def me(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    ut  = s.get("user_type") or ""
    # _S39R5N — Enrich /me with full_name + profile_image + company info so
    # the mobile sidebar header shows the right user + brand instead of
    # "ADMIN 14150129".
    user = {"id": s.get("user_pk"), "user_type": ut,
            "company_id": cid, "username": s.get("username")}
    company = {"company_id": cid}
    with _conn() as c:
        try:
            comp = c.execute(
                "SELECT company_name, company_phone, company_email, company_address, "
                "       gst_number, upi_id, logo_path "
                "  FROM companies WHERE company_id=?", (cid,)
            ).fetchone()
            if comp:
                company.update({
                    "company_name":    comp["company_name"],
                    "company_phone":   comp["company_phone"],
                    "company_email":   comp["company_email"],
                    "company_address": comp["company_address"],
                    "gst_number":      comp["gst_number"],
                    "upi_id":          comp["upi_id"],
                    "logo_url":        _file_url(comp["logo_path"]) if comp["logo_path"] else None,
                })
        except Exception:
            pass
        try:
            if ut == "admin":
                r2 = c.execute(
                    "SELECT admin_name AS name, admin_mobile AS mobile, "
                    "       admin_email AS email, profile_image_path AS img "
                    "  FROM admins WHERE id=?", (s.get("user_pk"),)
                ).fetchone()
            elif ut == "sub_lco":
                r2 = c.execute(
                    "SELECT name, mobile, email, "
                    "       profile_image AS img "
                    "  FROM sub_lcos WHERE id=?", (s.get("user_pk"),)
                ).fetchone()
            elif ut == "employee":
                r2 = c.execute(
                    "SELECT employee_name AS name, mobile, email, "
                    "       profile_image_path AS img "
                    "  FROM employees WHERE id=?", (s.get("user_pk"),)
                ).fetchone()
            else:
                r2 = None
            if r2:
                user["full_name"]     = r2["name"]
                user["mobile"]        = r2["mobile"]
                user["email"]         = r2["email"]
                if r2["img"]:
                    user["profile_image_url"] = _file_url(r2["img"])
        except Exception:
            pass
    return {"ok": True, "user": user, "company": company,
            # legacy flat fields kept for back-compat
            "user_type": ut, "company_id": cid,
            "username": s.get("username")}


def _file_url(p):
    """Return absolute https URL to a path stored under /uploads/... ."""
    if not p:
        return None
    p = p.strip()
    if p.startswith("http"):
        return p
    if not p.startswith("/"):
        p = "/" + p
    return f"https://www.autoispbilling.com{p}"


def _scope_clause(s):
    """Return (sql_fragment, params) restricting the customer query to
    the caller's tenant + role scope. Used by /subscribers, /online,
    /dashboard/summary so sub_lco / employee can NEVER see customers
    outside their hierarchy."""
    cid = s.get("company_id") or ""
    ut  = s.get("user_type") or ""
    pk  = s.get("user_pk")
    frag = " WHERE company_id=? "
    params = [cid]
    if ut == "sub_lco":
        # Only customers explicitly belonging to this sub_lco OR created
        # by employees that report to this sub_lco.
        frag += (" AND (sub_lco_id=? OR sub_lco_id IN "
                 "       (SELECT id FROM sub_lcos WHERE parent_sub_lco_id=?)) ")
        params += [pk, pk]
    elif ut == "employee":
        # Only customers in localities this employee is assigned to OR
        # whose `created_by_employee_id` equals self.
        try:
            with _conn() as cx:
                allowed = [r[0] for r in cx.execute(
                    "SELECT location_id FROM employee_locality_assignments "
                    "WHERE employee_id=? AND company_id=?", (pk, cid)
                ).fetchall()]
        except Exception:
            allowed = []
        if allowed:
            qmarks = ",".join("?" * len(allowed))
            frag += f" AND (location_id IN ({qmarks}) OR created_by_employee_id=?) "
            params += allowed + [pk]
        else:
            frag += " AND created_by_employee_id=? "
            params += [pk]
    return frag, params

# ---------------- Dashboard summary ----------------
@app.get("/api/mobile/v1/dashboard/summary")
def summary(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    out = {"ok": True}
    # _S39R5N — Apply role scope so sub_lco / employee see only their
    # own customer counts, never the whole company.
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # _S40zπ_MOBILE_FIX_  Exclude soft-deleted customers from the count
        _del_ex = " AND COALESCE(status,'') NOT IN ('Deleted','deleted','Terminated','terminated') "
        out["subscribers_total"]  = c.execute(
            "SELECT COUNT(*) FROM customers " + scope_sql + _del_ex, scope_params
        ).fetchone()[0]
        out["subscribers_active"] = c.execute(
            "SELECT COUNT(*) FROM customers " + scope_sql + " AND status='Active'" + _del_ex,
            scope_params
        ).fetchone()[0]
        # Complaints scoped by company only (sub_lco/employee can see customer
        # complaints in their scope — TODO: add scope filter if requested).
        out["complaints_open"] = c.execute(
            "SELECT COUNT(*) FROM complaints WHERE company_id=? "
            "AND IFNULL(status,'')!='Resolved'",(cid,)
        ).fetchone()[0]
        # _S39R5N — bill_dues was returning row count (always 0 because the
        # field is total_due_balance, not total_bill_amount). Fix: SUM the
        # actual balance owed.
        try:
            # _S39R5N — Real "amount due" = total_bill_amount - received_amount,
            # only count customers where that delta is > 0.
            row = c.execute(
                "SELECT IFNULL(SUM("
                "  CASE WHEN (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) > 0 "
                "       THEN (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) "
                "       ELSE 0 END), 0), "
                " SUM(CASE WHEN (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) > 0 "
                "          THEN 1 ELSE 0 END) "
                " FROM customers " + scope_sql, scope_params
            ).fetchone()
            out["bill_dues_amount"] = float(row[0] or 0)
            out["bill_dues_count"]  = int(row[1] or 0)
            out["bill_dues"]        = int(row[1] or 0)
        except Exception as _e:
            out["bill_dues_amount"] = 0.0
            out["bill_dues_count"]  = 0
            out["bill_dues"]        = 0

    # online count from radacct (rows with no acctstoptime)
    try:
        with _ra_conn() as rc:
            usernames = [r[0] for r in
                         _conn().execute("SELECT username FROM customers WHERE company_id=? AND IFNULL(username,'')!=''",(cid,)).fetchall()]
            online = 0
            if usernames:
                chunk=400
                for i in range(0,len(usernames),chunk):
                    batch = usernames[i:i+chunk]
                    p = ",".join("?"*len(batch))
                    online += rc.execute(
                        f"SELECT COUNT(*) FROM radacct WHERE acctstoptime IS NULL AND username IN ({p})", batch
                    ).fetchone()[0]
            out["online_now"] = online
    except Exception:
        out["online_now"] = 0
    return out

# ---------------- Subscribers ----------------
@app.get("/api/mobile/v1/subscribers")
def subscribers(authorization: Optional[str] = Header(None),
                q: str = "",
                page: int = Query(1, ge=1),
                per: int = Query(20, ge=1, le=100),
                only_online: bool = False,
                service_type: Optional[str] = None,
                locality_id: Optional[int] = None,
                user_type: Optional[str] = None):
    """_S39R5N — supports service_type / locality_id / user_type filters
    plus role scope so sub_lco/employee never sees out-of-scope rows."""
    s = _require_auth(authorization)
    scope_sql, scope_params = _scope_clause(s)
    sql = ("SELECT id,customer_id,username,customer_name,customer_phone AS mobile_no,"
           "        address,locality,location_id,plan_id,status,end_date,start_date,"
           "        total_bill_amount,received_amount,"
           "        (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) AS due_balance,"
           "        service_type,customer_type "
           "   FROM customers " + scope_sql +
           "  AND COALESCE(status,'') NOT IN ('Deleted','deleted','Terminated','terminated') ")
    params = list(scope_params)
    if q:
        sql += (" AND (customer_id LIKE ? OR customer_name LIKE ? "
                "      OR username LIKE ? OR customer_phone LIKE ? "
                "      OR locality LIKE ?) ")
        like = f"%{q}%"
        params += [like]*5
    if service_type and service_type.lower() not in ("all", ""):
        # Match case-insensitively: "Broadband" / "broadband" / "BroadBand"
        sql += " AND LOWER(IFNULL(service_type,''))=LOWER(?) "
        params.append(service_type)
    if user_type and user_type.lower() not in ("all", ""):
        sql += " AND LOWER(IFNULL(customer_type,''))=LOWER(?) "
        params.append(user_type)
    if locality_id:
        sql += " AND location_id=? "
        params.append(int(locality_id))
    sql += " ORDER BY id DESC LIMIT ? OFFSET ? "
    params += [per, (page-1)*per]

    with _conn() as c:
        rows = [dict(r) for r in c.execute(sql, params).fetchall()]

    # Online lookup
    user_set = {r["username"] for r in rows if r.get("username")}
    online_set = set()
    if user_set:
        try:
            with _ra_conn() as rc:
                p = ",".join("?"*len(user_set))
                for u, in rc.execute(
                    f"SELECT DISTINCT username FROM radacct WHERE acctstoptime IS NULL AND username IN ({p})",
                    list(user_set)).fetchall():
                    online_set.add(u)
        except Exception:
            pass
    for r in rows:
        r["online"] = bool(r.get("username") and r["username"] in online_set)

    if only_online:
        rows = [r for r in rows if r.get("online")]

    return {"ok": True, "page": page, "per": per,
            "count": len(rows), "items": rows}

@app.get("/api/mobile/v1/subscribers/online")
def subscribers_online(authorization: Optional[str] = Header(None),
                        page: int = 1, per: int = 50):
    return subscribers(authorization, q="", page=page, per=per, only_online=True)

@app.get("/api/mobile/v1/subscribers/{cust_pk}")
def subscriber_detail(cust_pk: int,
                      authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        row = c.execute(
            "SELECT id, customer_id, username, customer_name, customer_email, customer_phone, alt_mobile, address, locality, city, state, pincode, plan_id, monthly_amount, auto_renew, customer_type, mac_address, ip_address, vendor, modem_no, start_date, end_date, period, bill_amount, total_bill_amount, received_amount, security_deposit, installation_charges, router_charges, discount_credit, status, payment_mode, transaction_id, payment_notes, service_type, sub_lco_id, location_id, auth_type, static_ip_address, zone, node, allow_devices, custom_rate_limit, created_at, updated_at, installation_date, id_proof, id_proof_no FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not row:
            raise HTTPException(404, "not_found")
        r = {k: row[k] for k in row.keys()}
        # Plan name lookup
        pname = None
        if r.get("plan_id"):
            prow = c.execute(
                "SELECT plan_name, speed, after_tax_amount, validity, validity_unit "
                "  FROM plans WHERE id=?", (r["plan_id"],)).fetchone()
            if prow:
                r["plan_name"] = prow["plan_name"]
                r["plan_speed"] = prow["speed"]
                r["plan_amount"] = prow["after_tax_amount"]
                r["plan_validity"] = f'{prow["validity"] or ""} {prow["validity_unit"] or ""}'.strip()
    # online + last session bytes
    r["online"] = False
    r["session_bytes_in"] = 0
    r["session_bytes_out"] = 0
    if r.get("username"):
        try:
            with _ra_conn() as rc:
                act = rc.execute(
                    "SELECT acctstarttime, acctinputoctets, acctoutputoctets, "
                    "       framedipaddress, callingstationid "
                    "  FROM radacct WHERE acctstoptime IS NULL AND username=? "
                    "  ORDER BY radacctid DESC LIMIT 1",
                    (r["username"],)).fetchone()
                if act:
                    r["online"] = True
                    r["session_started_at"] = act["acctstarttime"]
                    r["session_bytes_in"] = act["acctinputoctets"] or 0
                    r["session_bytes_out"] = act["acctoutputoctets"] or 0
                    r["session_ip"] = act["framedipaddress"]
                    r["session_mac"] = act["callingstationid"]
        except Exception:
            pass
    # _S39R5N — Compute formatted_period "DD-MM-YYYY to DD-MM-YYYY" so the
    # mobile detail screen shows the real billing window instead of "1 mo".
    try:
        sd = (r.get("start_date") or "").strip()
        ed = (r.get("end_date") or "").strip()
        def _fmt(d):
            if d and len(d) >= 10 and d[4] == "-" and d[7] == "-":
                return f"{d[8:10]}-{d[5:7]}-{d[0:4]}"
            return d or ""
        if sd and ed:
            r["formatted_period"] = f"{_fmt(sd)} to {_fmt(ed)}"
        elif ed:
            r["formatted_period"] = _fmt(ed)
        else:
            r["formatted_period"] = ""
    except Exception:
        r["formatted_period"] = ""
    # Real "balance / current dues" — what the user actually owes today.
    try:
        # _S39R5N — Real outstanding = total_bill_amount - received_amount
        bill = float(r.get("total_bill_amount") or 0)
        recv = float(r.get("received_amount") or 0)
        due  = bill - recv
        r["current_dues"] = max(0.0, due)
        r["balance"]      = max(0.0, due)
    except Exception:
        r["current_dues"] = 0.0
        r["balance"]      = 0.0
    return {"ok": True, "subscriber": r}


# ---------------- Employee GPS tracking ----------------
class TrackIn(BaseModel):
    latitude: float
    longitude: float
    accuracy: Optional[float] = None
    battery: Optional[float] = None

@app.post("/api/mobile/v1/employee/track")
def employee_track(body: TrackIn,
                   authorization: Optional[str] = Header(None)):
    """Mobile app pushes employee live GPS here.
    Updates employees.last_latitude/last_longitude/last_seen_at so the
    admin Track Employees Google-Maps page picks it up immediately.
    """
    s = _require_auth(authorization)
    if s["user_type"] != "employee":
        # Only employees push location; other roles get a noop ack.
        return {"ok": True, "noop": True, "reason": "not_employee"}
    pk = int(s["user_pk"])
    cid = s["company_id"] or ""
    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")  # _S40zπ_MOBILE_FIX_
    with _conn() as c:
        c.execute(
            "UPDATE employees SET last_latitude=?, last_longitude=?, "
            " last_seen_at=? WHERE id=? AND company_id=?",
            (body.latitude, body.longitude, now, pk, cid))
        # _S39EMP_TRACK_HISTORY — append to the history table so the admin
        # Track Employees page can plot a polyline trail.
        c.execute(
            "INSERT INTO employee_location_history "
            " (employee_id, company_id, latitude, longitude, accuracy, recorded_at) "
            "VALUES (?,?,?,?,?,?)",
            (pk, cid, body.latitude, body.longitude,
             body.accuracy, now))
        c.commit()
    # _S39R5B_GEOFENCE_HOOK — evaluate enter/exit transitions
    try:
        import sys as _sys
        if "/opt/ispbilling/admin-portal" not in _sys.path:
            _sys.path.insert(0, "/opt/ispbilling/admin-portal")
        from geofences import evaluate_position as _gf_eval
        _gf_eval(cid, pk, body.latitude, body.longitude)
    except Exception as _gf_err:
        print(f"[geofence] eval skipped: {_gf_err}")
    return {"ok": True, "updated_at": now}


