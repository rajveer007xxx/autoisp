class _PwIn(BaseModel):
    old_password: str
    new_password: str

@app.post("/api/mobile/v1/auth/change-password")
def change_password_v4721(body: _PwIn,
                          authorization: Optional[str] = Header(None)):
    """_v4721_  Change password for the logged-in user. Verifies the current
    password against the same hash scheme used by /auth/login (bcrypt + a
    legacy sha256 fallback for older accounts)."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    pk  = s.get("user_pk") or ""
    ut  = (s.get("user_type") or "").lower()
    new_pw = (body.new_password or "").strip()
    old_pw = body.old_password or ""
    if len(new_pw) < 6:
        raise HTTPException(400, "password_too_short")
    table_col = {
        "admin":    ("admins",    "password_hash"),
        "sub_lco":  ("sub_lcos",  "password_hash"),
        "employee": ("employees", "password_hash"),
        "customer": ("customers", "password_hash"),
    }.get(ut)
    if not table_col:
        raise HTTPException(400, "unsupported_role")
    tbl, col = table_col
    with _conn() as c:
        row = c.execute(
            f"SELECT {col} AS h FROM {tbl} WHERE id=? AND company_id=?",
            (pk, cid)).fetchone()
        if not row:
            raise HTTPException(404, "user_not_found")
        stored = row["h"] or ""
        # Verify old password
        ok = False
        try:
            import bcrypt
            if stored.startswith("$2"):
                ok = bcrypt.checkpw(old_pw.encode(), stored.encode())
        except Exception:
            ok = False
        if not ok:
            # Legacy sha256 fallback
            try:
                import hashlib
                if hashlib.sha256(old_pw.encode()).hexdigest() == stored:
                    ok = True
            except Exception:
                pass
        if not ok and stored and stored == old_pw:
            ok = True  # plaintext legacy
        if not ok:
            raise HTTPException(401, "wrong_password")
        # Hash new
        try:
            import bcrypt
            new_hash = bcrypt.hashpw(new_pw.encode(), bcrypt.gensalt()).decode()
        except Exception:
            import hashlib
            new_hash = hashlib.sha256(new_pw.encode()).hexdigest()
        c.execute(
            f"UPDATE {tbl} SET {col}=? WHERE id=? AND company_id=?",
            (new_hash, pk, cid))
        c.commit()
    return {"ok": True}


@app.post("/api/mobile/v1/auth/profile/image")
async def upload_profile_image_v4721(
        file: UploadFile = File(...),
        authorization: Optional[str] = Header(None)):
    """_v4721_  Upload + persist a profile picture for the logged-in user.
    Saves to /opt/ispbilling/static/uploads/<company_id>/avatars/<id>.<ext>
    and writes the relative path back to the user's row."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    pk  = s.get("user_pk") or ""
    ut  = (s.get("user_type") or "").lower()
    table_col = {
        "admin":    ("admins",    "profile_image_path"),
        "sub_lco":  ("sub_lcos",  "profile_image"),
        "employee": ("employees", "profile_image_path"),
        "customer": ("customers", "photograph_path"),
    }.get(ut)
    if not table_col:
        raise HTTPException(400, "unsupported_role")
    tbl, col = table_col
    # Sniff extension
    fname = (file.filename or "image.jpg").lower()
    ext = "jpg"
    for cand in ("png", "jpg", "jpeg", "webp", "heic"):
        if fname.endswith("." + cand):
            ext = cand if cand != "jpeg" else "jpg"
            break
    # Storage path
    rel_dir = f"static/uploads/{cid}/avatars"
    abs_dir = f"/opt/ispbilling/admin-portal/{rel_dir}"
    try:
        _os_v4721.makedirs(abs_dir, exist_ok=True)
    except Exception:
        pass
    fn = f"{ut}-{pk}-{int(time.time())}.{ext}"
    abs_path = f"{abs_dir}/{fn}"
    rel_path = f"/{rel_dir}/{fn}"
    data = await file.read()
    if len(data) > 8 * 1024 * 1024:
        raise HTTPException(413, "file_too_large")
    with open(abs_path, "wb") as out:
        out.write(data)
    with _conn() as c:
        c.execute(
            f"UPDATE {tbl} SET {col}=? WHERE id=? AND company_id=?",
            (rel_path, pk, cid))
        c.commit()
    return {"ok": True,
            "profile_image_url": f"https://www.autoispbilling.com{rel_path}",
            "path": rel_path}
