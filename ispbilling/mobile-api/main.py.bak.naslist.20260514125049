@app.post("/api/mobile/v1/subscribers")
def create_subscriber(body: SubscriberCreateIn,
                      authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    if s["user_type"] not in ("admin", "employee", "sub_lco"):
        raise HTTPException(403, "forbidden")
    cid = s["company_id"] or ""
    import secrets as _se, time as _t
    cust_id = str(int(_t.time()))[-8:]   # 8-digit numeric customer id
    username = (body.username or f"u{cust_id}").strip().lower()
    password = body.password or _se.token_urlsafe(8)

    pw_hash = ""
    if _bcrypt:
        try: pw_hash = _bcrypt.hash(password)
        except Exception: pw_hash = ""

    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")  # _S40zπ_MOBILE_FIX_
    with _conn() as c:
        plan = c.execute(
            "SELECT id, after_tax_amount, validity, validity_unit "
            "  FROM plans WHERE id=? AND company_id=?",
            (body.plan_id, cid)).fetchone()
        if not plan:
            raise HTTPException(400, "invalid_plan_id")
        amt = float(plan["after_tax_amount"] or 0)
        period = max(1, int(body.period or 1))
        bill = amt * period
        # Compute end_date
        from datetime import timedelta as _td
        days = period * (30 if (plan["validity_unit"] or "days").lower().startswith("month") else int(plan["validity"] or 30))
        end_date = (datetime.now(timezone.utc) + _td(days=days)).date().isoformat()

        c.execute(
            "INSERT INTO customers (company_id, customer_id, username, "
            " password_hash, registration_type, service_type, customer_name, "
            " customer_phone, customer_email, address, locality, city, state, "
            " pincode, plan_id, monthly_amount, period, end_date, bill_amount, "
            " total_bill_amount, received_amount, payment_mode, status, "
            " auth_type, static_ip_address, sub_lco_id, location_id, "
            " created_at, updated_at, start_date) "
            "VALUES (?,?,?,?, 'Online', 'Broadband', ?,?,?,?,?,?,?,?,?,?,?,?, "
            "        ?, ?, ?, 'Active', ?,?,?,?, ?, ?, ?)",
            (cid, cust_id, username, pw_hash,
             body.customer_name, body.customer_phone, body.customer_email or "",
             body.address, body.locality or "", body.city or "",
             body.state or "", body.pincode or "",
             body.plan_id, amt, period, end_date,
             bill, max(0.0, bill - (body.received_amount or 0)),
             body.received_amount or 0,
             body.payment_mode or "",
             body.auth_type or "pppoe", body.static_ip_address or "",
             body.sub_lco_id, body.location_id,
             now, now, datetime.now(timezone.utc).date().isoformat()))
        new_pk = c.lastrowid
        # _S40zπ_PHASEC_  Persist GPS coords on customers row so
        # ONU 'Use Customer Address' auto-placement works without
        # an extra geocoding round-trip.
        if body.latitude is not None and body.longitude is not None:
            try:
                c.execute(
                    "UPDATE customers SET lat=?, lng=?, latitude=?, "
                    "       geocoded_at=datetime('now'), "
                    "       geocode_confidence=1.0 "
                    " WHERE id=?",
                    (float(body.latitude), float(body.longitude),
                     float(body.latitude), new_pk))
            except Exception:
                pass
                # If they paid something at install — log a transaction
        if body.received_amount and body.received_amount > 0:
            c.execute(
                "INSERT INTO transactions (company_id, customer_id, "
                " transaction_type, amount, period_months, remarks, "
                " payment_method, transaction_date, created_at) "
                "VALUES (?,?, 'Payment', ?, ?, ?, ?, ?, ?)",
                (cid, cust_id, body.received_amount, period,
                 "Initial payment at signup",
                 body.payment_mode or "Cash", now, now))
        c.commit()
    return {"ok": True, "id": new_pk, "customer_id": cust_id,
            "username": username, "password": password,
            "end_date": end_date, "bill_amount": bill}

