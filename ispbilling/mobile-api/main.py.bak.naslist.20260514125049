def me_billing(authorization: Optional[str] = Header(None)):
    """_v4721_  Live customer billing snapshot used by Dashboard +
    Subscribers screens. Returns flat fields (plan_name, end_date,
    due_amount, balance, status, online) plus a `subscriber` envelope
    for back-compat."""
    s = _require_auth(authorization)
    if s.get("user_type") != "customer":
        raise HTTPException(403, "customer_only")
    cid = s.get("company_id") or ""
    pk  = s.get("user_pk") or ""
    uname = s.get("username") or ""
    with _conn() as c:
        row = c.execute(
            "SELECT id, customer_id, username, customer_name, "
            "       customer_email, customer_phone, alt_mobile, address, "
            "       locality, city, state, pincode, plan_id, monthly_amount, "
            "       customer_type, mac_address, ip_address, vendor, "
            "       modem_no, start_date, end_date, period, bill_amount, "
            "       total_bill_amount, received_amount, security_deposit, "
            "       status, payment_mode, service_type, sub_lco_id, "
            "       location_id, photograph_path, created_at, updated_at "
            "  FROM customers "
            " WHERE company_id=? AND (id=? OR username=? OR customer_id=?) "
            " LIMIT 1",
            (cid, pk, uname, uname)).fetchone()
        if not row:
            raise HTTPException(404, "not_found")
        r = {k: row[k] for k in row.keys()}
        plan_name = ""; plan_amount = float(r.get("monthly_amount") or 0)
        if r.get("plan_id"):
            p = c.execute(
                "SELECT plan_name, speed, after_tax_amount, validity, validity_unit "
                "  FROM plans WHERE id=?", (r["plan_id"],)).fetchone()
            if p:
                plan_name = p["plan_name"] or ""
                plan_amount = float(p["after_tax_amount"] or plan_amount)
                r["plan_name"]     = plan_name
                r["plan_speed"]    = p["speed"]
                r["plan_amount"]   = plan_amount
                r["plan_validity"] = f"{p['validity'] or ''} {p['validity_unit'] or ''}".strip()
        # Live ledger calc (same approach as /me)
        try:
            inv_total = c.execute(
                "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                " WHERE company_id=? AND customer_id=?",
                (cid, r["customer_id"])).fetchone()[0] or 0
        except Exception:
            inv_total = 0
        try:
            pay_total = c.execute(
                "SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) "
                "  FROM payments WHERE company_id=? AND customer_id=?",
                (cid, r["customer_id"])).fetchone()[0] or 0
        except Exception:
            pay_total = 0
        due = max(0.0, round(float(inv_total) - float(pay_total), 2))
        # Recent transactions
        try:
            txns = c.execute(
                "SELECT id, transaction_no AS reference_no, amount, "
                "       payment_mode AS payment_method, paid_at AS created_at, "
                "       'Payment' AS transaction_type "
                "  FROM payments "
                " WHERE company_id=? AND customer_id=? "
                " ORDER BY id DESC LIMIT 20",
                (cid, r["customer_id"])).fetchall()
            r["payments"] = [dict(x) for x in txns]
        except Exception:
            r["payments"] = []
    # Friendly date format (DD-MM-YYYY) for the UI card
    ed = r.get("end_date") or ""
    if ed and len(ed) >= 10 and ed[4] == "-":
        ed_disp = f"{ed[8:10]}-{ed[5:7]}-{ed[0:4]}"
    else:
        ed_disp = ed
    # Profile image absolute URL
    img_url = None
    p = (r.get("photograph_path") or "").strip()
    if p:
        if p.startswith("http"):
            img_url = p
        else:
            img_url = f"https://www.autoispbilling.com/{p.lstrip('/')}"
    return {
        "ok": True,
        # Flat fields the Dashboard reads directly
        "customer_id":   r["customer_id"],
        "customer_name": r["customer_name"],
        "plan_name":     plan_name or None,
        "plan_amount":   plan_amount,
        "end_date":      ed_disp,
        "status":        r.get("status") or "Active",
        "due_amount":    due,
        "balance":       due,
        "online":        False,
        "profile_image_url": img_url,
        # Full envelope for legacy callers (subscribers.tsx, /me/pay etc.)
        "subscriber": r,
    }

