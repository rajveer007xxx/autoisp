@app.get("/api/mobile/v1/transactions")
def transactions(authorization: Optional[str] = Header(None),
                 q: str = "", customer_type: str = "",
                 locality_id: Optional[int] = None,
                 limit: int = Query(100, ge=1, le=500)):
    """List recent transactions, scoped by role + filterable by user-type
    and locality. Times are returned in ISO8601 — the mobile UI converts
    to DD-MM-YYYY HH:MM in Asia/Kolkata."""
    s = _require_auth(authorization)
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # Join customers to apply scope; transactions table has no scope of its own.
        sql = ("SELECT t.id, "
               "        t.paid_at AS transaction_date, "
               "        t.amount, "
               "        'Payment' AS transaction_type, "
               "        t.payment_mode AS payment_method, "
               "        t.transaction_no AS reference_no, "
               "        c.start_date, c.end_date, "
               "        c.period AS period_months, "
               "        t.remarks, t.created_at, "
               "        c.customer_name, c.customer_id, c.username, c.customer_type, "
               "        c.location_id "
               "   FROM payments t "
               "   JOIN customers c ON c.customer_id = t.customer_id "
               + scope_sql.replace("WHERE company_id=?", "AND c.company_id=?"))
        sql = sql.replace(" WHERE company_id=?", " AND c.company_id=?")
        # The scope_sql starts with " WHERE company_id=? "; we just made it conjunctive.
        # Re-prefix with WHERE 1=1.
        sql = sql.replace(" AND c.company_id=?", " WHERE 1=1 AND c.company_id=?", 1)
        params = list(scope_params)
        if customer_type and customer_type.lower() not in ("all", ""):
            ut = customer_type.strip().lower().replace(" ", "_")
            sql += (" AND ("
                    "  LOWER(REPLACE(IFNULL(c.service_type,''),' ','_'))=? "
                    "OR LOWER(REPLACE(IFNULL(c.customer_type,''),' ','_'))=? )")
            params += [ut, ut]
        if locality_id:
            sql += " AND c.location_id=? "
            params.append(int(locality_id))
        if q:
            sql += (" AND (c.customer_name LIKE ? OR c.customer_id LIKE ? "
                    " OR c.username LIKE ? OR t.transaction_no LIKE ?) ")
            like = f"%{q}%"
            params += [like]*4
        sql += " ORDER BY t.id DESC LIMIT ? "
        params.append(limit)
        rows = c.execute(sql, params).fetchall()
        items = []
        for r in rows:
            d = {k: r[k] for k in r.keys()}
            items.append(d)
        return {"ok": True, "count": len(items), "items": items}


@app.get("/api/mobile/v1/transactions/{txn_id}")
def transaction_detail(txn_id: int, authorization: Optional[str] = Header(None)):
    """Detailed transaction view including the customer's plan + period."""
    s = _require_auth(authorization)
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        sql = ("SELECT t.id, t.amount, t.discount, t.payment_mode AS payment_method, "
               "        t.transaction_no AS reference_no, "
               "        t.paid_at AS transaction_date, "
               "        t.remarks, t.created_at, t.employee_id, "
               "        c.customer_name, c.customer_id AS cust_id, c.username, "
               "        c.customer_type, c.customer_phone AS mobile, "
               "        c.customer_email AS email, c.address, "
               "        c.start_date, c.end_date, c.period AS period_months, "
               "        p.plan_name, p.speed, p.after_tax_amount AS plan_amount "
               "   FROM payments t "
               "   JOIN customers c ON c.customer_id = t.customer_id "
               "   LEFT JOIN plans p ON p.id = c.plan_id "
               "  WHERE t.id=? AND c.company_id=? LIMIT 1")
        params = [txn_id, scope_params[0]]
        row = c.execute(sql, params).fetchone()
    if not row:
        raise HTTPException(404, "Transaction not found")
    d = {k: row[k] for k in row.keys()}
    sd = (d.get("start_date") or "").strip()
    ed = (d.get("end_date") or "").strip()
    def _fmt(x):
        if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
            return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
        return x or ""
    if sd and ed:
        d["formatted_period"] = f"{_fmt(sd)} to {_fmt(ed)}"
    else:
        d["formatted_period"] = ""

    # _S40zπ_v462_  Receipt-grade breakdown so the mobile UI shows
    # Renewal period / Previous due / Current due / Balance after / Last payment
    # consistent with what the receipt looked like at issue time.
    try:
        with _conn() as _c2:
            cust_id = d.get("cust_id") or d.get("customer_id")
            scope_args = scope_params  # (cid,)
            cid = scope_args[0]

            # The most recent invoice OLDER OR EQUAL to this txn date,
            # which is the one the user paid against.
            inv = _c2.execute(
                "SELECT total_amount, due_at_issue, issue_date "
                "  FROM invoices "
                " WHERE company_id=? AND customer_id=? "
                "   AND DATE(issue_date) <= DATE(?) "
                " ORDER BY id DESC LIMIT 1",
                (cid, cust_id, d.get("transaction_date") or "")).fetchone()
            if inv:
                cur = float(inv["total_amount"] or 0)
                due = float(inv["due_at_issue"] or 0)
                d["renewal_period"]   = d["formatted_period"]
                d["previous_balance"] = round(max(0.0, due - cur), 2)
                d["current_due"]      = round(cur, 2)
            # Balance immediately after this payment
            up_to = _c2.execute(
                "SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) "
                "  FROM payments WHERE company_id=? AND customer_id=? "
                "   AND id<=?",
                (cid, cust_id, d.get("id"))).fetchone()
            inv_total = _c2.execute(
                "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                " WHERE company_id=? AND customer_id=? "
                "   AND DATE(issue_date) <= DATE(?)",
                (cid, cust_id, d.get("transaction_date") or "")).fetchone()
            d["balance_after"] = round(max(0.0,
                float(inv_total[0] or 0) - float(up_to[0] or 0)), 2)
            # Previous payment to this one
            prev = _c2.execute(
                "SELECT amount, paid_at FROM payments "
                " WHERE company_id=? AND customer_id=? AND id<? "
                " ORDER BY id DESC LIMIT 1",
                (cid, cust_id, d.get("id"))).fetchone()
            d["last_payment_amount"] = round(float(prev["amount"]),2) if prev else 0.0
            try:
                if prev and prev["paid_at"]:
                    raw = str(prev["paid_at"]).strip()
                    for pf in ("%Y-%m-%d %H:%M:%S.%f","%Y-%m-%d %H:%M:%S"):
                        try:
                            d["last_paid_at"] = datetime.strptime(raw[:26], pf)\
                                .strftime("%d-%m-%Y %H:%M")
                            break
                        except Exception: pass
                else:
                    d["last_paid_at"] = ""
            except Exception:
                d["last_paid_at"] = ""

            # Format this transaction's own paid_at to IST DD-MM-YYYY HH:MM
            try:
                raw = str(d.get("transaction_date") or "").strip()
                for pf in ("%Y-%m-%d %H:%M:%S.%f","%Y-%m-%d %H:%M:%S"):
                    try:
                        d["paid_at_fmt"] = datetime.strptime(raw[:26], pf)\
                            .strftime("%d-%m-%Y %H:%M")
                        break
                    except Exception: pass
            except Exception:
                d["paid_at_fmt"] = d.get("transaction_date") or ""
    except Exception:
        pass

    return {"ok": True, "transaction": d}


