# ---------------- Real-time online detection ----------------
# A radacct row with acctstoptime IS NULL is "open", but if the NAS crashed
# without sending an Acct-Stop the row stays open forever. To return a
# trustworthy `online_now`, we additionally require:
#   1. The session's last update happened within RADACCT_STALE_SECONDS.
#   2. The session's NAS is NOT marked as down/unreachable in nas_devices.
import os as _os_for_radacct
RADACCT_STALE_SECONDS = int(_os_for_radacct.environ.get("RADACCT_STALE_SECONDS", "600"))

def _down_nas_ips(company_id: str = None) -> set:
    """Return set of NAS IPs whose last_status indicates they are down/unreachable.
    These are excluded when computing real online users."""
    bad = set()
    try:
        with _conn() as c:
            sql = "SELECT ip_address FROM nas_devices WHERE LOWER(IFNULL(last_status,''))"                   " IN ('down','unreachable','offline','error','timeout')"
            params = ()
            if company_id:
                sql += " AND company_id=?"
                params = (company_id,)
            for r in c.execute(sql, params).fetchall():
                if r[0]:
                    bad.add(str(r[0]).strip())
    except Exception:
        pass
    return bad

def _online_set_real(usernames=None, company_id: str = None) -> set:
    """Return set of usernames that are *really* online right now.

    _MOBILE_ONLINE_FIX_V2_ : The admin portal maintains an
    `online_users` table populated by /api/online-users/sync-from-nas
    (which talks to MikroTik /ppp/active directly).  That is the
    ground-truth and is far fresher than FreeRADIUS radacct
    (which can lag for days if accounting packets get lost).

    Strategy:
      1. Primary  : `online_users` table where status='Online'
                    AND updated_at within ONLINE_USERS_STALE_SECONDS.
      2. Fallback : radacct (old logic) if `online_users` cache is empty.
    """
    online = set()
    online_users_cutoff = 1800  # 30 minutes
    try:
        with _conn() as c:
            sql = ("SELECT DISTINCT username FROM online_users "
                   " WHERE LOWER(IFNULL(status,''))='online' "
                   "   AND IFNULL(username,'')!='' "
                   "   AND (updated_at IS NULL "
                   "        OR CAST((julianday('now') - julianday(updated_at))*86400 AS INTEGER) <= ?)")
            params = [online_users_cutoff]
            if company_id:
                sql += " AND company_id=?"
                params.append(company_id)
            rows = c.execute(sql, params).fetchall()
            for r in rows:
                un = r[0]
                if un:
                    online.add(un)
    except Exception:
        pass

    # Scope to requested usernames if given
    if usernames:
        usernames = set(usernames)
        online = online & usernames

    # Fallback: radacct if primary returned empty
    if not online:
        cutoff = 0
        try:
            import time as _time
            cutoff = int(_time.time()) - RADACCT_STALE_SECONDS
        except Exception:
            pass
        bad_ips = _down_nas_ips(company_id)
        try:
            with _ra_conn() as rc:
                base = (
                    "SELECT DISTINCT username, nasipaddress FROM radacct "
                    " WHERE acctstoptime IS NULL "
                    "   AND CAST(COALESCE(acctupdatetime, acctstarttime) AS INTEGER) >= ? "
                )
                if usernames:
                    u = list(usernames)
                    CHUNK = 400
                    for i in range(0, len(u), CHUNK):
                        batch = u[i:i+CHUNK]
                        p = ",".join("?"*len(batch))
                        rows = rc.execute(
                            base + f" AND username IN ({p})",
                            [cutoff] + batch
                        ).fetchall()
                        for un, nip in rows:
                            if nip and nip in bad_ips:
                                continue
                            if un:
                                online.add(un)
                else:
                    rows = rc.execute(base, (cutoff,)).fetchall()
                    for un, nip in rows:
                        if nip and nip in bad_ips:
                            continue
                        if un:
                            online.add(un)
        except Exception:
            pass
    return online

def _online_session_real(username: str, company_id: str = None):
    """Return session info for a single user. _MOBILE_ONLINE_FIX_V2_:
    primary source is `online_users` table; falls back to radacct."""
    if not username:
        return None
    # Primary: online_users table (fresh, NAS-direct)
    try:
        with _conn() as c:
            sql = ("SELECT username, ip_address, mac_address, nas_ip, "
                   "        started_at, uptime_seconds, bytes_in, bytes_out, "
                   "        updated_at "
                   "   FROM online_users "
                   "  WHERE username=? AND LOWER(IFNULL(status,''))='online' "
                   "   AND (updated_at IS NULL OR "
                   "        CAST((julianday('now') - julianday(updated_at))*86400 AS INTEGER) <= 1800) ")
            params = [username]
            if company_id:
                sql += " AND company_id=?"
                params.append(company_id)
            sql += " ORDER BY id DESC LIMIT 1"
            row = c.execute(sql, params).fetchone()
            if row:
                return {
                    "username": row["username"],
                    "framedipaddress": row["ip_address"] or "",
                    "callingstationid": row["mac_address"] or "",
                    "nasipaddress": row["nas_ip"] or "",
                    "acctstarttime": row["started_at"] or "",
                    "acctsessiontime": row["uptime_seconds"] or 0,
                    "acctinputoctets": row["bytes_in"] or 0,
                    "acctoutputoctets": row["bytes_out"] or 0,
                    "_source": "online_users",
                }
    except Exception:
        pass

    # Fallback: radacct
    cutoff = 0
    try:
        import time as _time
        cutoff = int(_time.time()) - RADACCT_STALE_SECONDS
    except Exception:
        pass
    bad_ips = _down_nas_ips(company_id)
    try:
        with _ra_conn() as rc:
            rc.row_factory = sqlite3.Row
            row = rc.execute(
                "SELECT username, acctstarttime, acctupdatetime, acctsessiontime,"
                "       acctinputoctets, acctoutputoctets, "
                "       framedipaddress, callingstationid, nasipaddress "
                "  FROM radacct "
                " WHERE username=? AND acctstoptime IS NULL "
                "   AND CAST(COALESCE(acctupdatetime, acctstarttime) AS INTEGER) >= ? "
                " ORDER BY radacctid DESC LIMIT 1",
                (username, cutoff)).fetchone()
            if row:
                if row["nasipaddress"] and row["nasipaddress"] in bad_ips:
                    return None
                return dict(row)
    except Exception:
        pass
    return None

