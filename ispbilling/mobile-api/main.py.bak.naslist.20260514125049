           "       cp.priority, cp.subject, cp.description, cp.status, "
           "       cp.created_at, cp.resolved_at, cp.resolved_by, "
           "       cu.customer_name, cu.username, cu.address, "
           "       COALESCE(NULLIF(cu.locality,''), lo.name) AS locality, "
           "       cu.customer_phone AS mobile, cu.customer_type "
           "  FROM complaints cp "
           "  LEFT JOIN customers cu "
           "    ON cu.customer_id=cp.customer_id AND cu.company_id=cp.company_id "
           "  LEFT JOIN locations lo "
           "    ON lo.id=cu.location_id AND lo.company_id=cu.company_id "
           " WHERE cp.company_id=?")
    params: list = [cid]
    # If user is a customer, scope to own
    if s["user_type"] == "customer":
        # username = customer_id or username; fetch their customer_id
        with _conn() as c:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE company_id=? AND (username=? OR customer_id=?) LIMIT 1",
                (cid, s["username"], s["username"])).fetchone()
        if cust:
            sql += " AND cp.customer_id=?"; params.append(cust["customer_id"])
        else:
            return {"ok": True, "items": [], "page": page, "per": per}
# _v4729b_CMP_SCOPE  sub_lco / employee see complaints from customers
    # in their scope (via canonical _scope_clause, now also locality-aware
    # for sub_lco). Admin sees all.
    elif s["user_type"] in ("sub_lco", "employee"):
        _scope_sql, _scope_params = _scope_clause(s)
        with _conn() as c:
            in_ids = [r[0] for r in c.execute(
                "SELECT customer_id FROM customers " + _scope_sql,
                _scope_params).fetchall()]
        if in_ids:
            qm = ",".join("?" * len(in_ids))
            sql += f" AND cp.customer_id IN ({qm}) "
            params += in_ids
        else:
            return {"ok": True, "items": [], "page": page, "per": per}
    if status and status.strip().lower() not in ("all", ""):
        # _v4714_  Normalize ' ' and '_' so 'in_progress' matches 'In Progress'.
        # Group Pending under In Progress (matches /complaints-list semantics).
        _norm = status.strip().lower().replace(' ', '').replace('_', '')
        if _norm in ('inprogress', 'pending'):
            sql += (" AND LOWER(REPLACE(REPLACE(IFNULL(cp.status,''),' ',''),'_','')) "
                    "     IN ('inprogress','pending')")
        else:
            sql += (" AND LOWER(REPLACE(REPLACE(IFNULL(cp.status,''),' ',''),'_','')) "
                    "      = ?")
            params.append(_norm)
    sql += " ORDER BY cp.id DESC LIMIT ? OFFSET ?"
    params += [per, (page - 1) * per]
    with _conn() as c:
        rows = c.execute(sql, params).fetchall()
    out_items = [dict(r) for r in rows]
    # _v4720_LIST_RAISER  When a ticket has no customer row (INTERNAL tickets
    # or rows where customer_id points to admin/sub_lco/employee code), look
    # up the raiser so the card shows a name instead of a blank row.
    raiser_cache: dict = {}
    def _lookup_raiser(code):
        if not code: return None
        if code in raiser_cache: return raiser_cache[code]
        if code.upper() == "INTERNAL":
            raiser_cache[code] = None
            return None
        with _conn() as c2:
            r = c2.execute(
                "SELECT admin_id AS code, admin_name AS name, 'admin' AS role, "
                "       admin_mobile AS mobile FROM admins "
                " WHERE company_id=? AND admin_id=?", (cid, code)).fetchone()
            if not r:
                r = c2.execute(
                    "SELECT sub_lco_code AS code, name, 'sub_lco' AS role, mobile "
                    "  FROM sub_lcos WHERE company_id=? AND sub_lco_code=?",
                    (cid, code)).fetchone()
            if not r:
                r = c2.execute(
                    "SELECT employee_code AS code, employee_name AS name, "
                    "       'employee' AS role, mobile FROM employees "
                    " WHERE company_id=? AND employee_code=?",
                    (cid, code)).fetchone()
        raiser_cache[code] = (dict(r) if r else None)
        return raiser_cache[code]
    for it in out_items:
        if not it.get("customer_name"):
            r = _lookup_raiser(it.get("customer_id") or "")
            if r:
                it["raised_by_name"]   = r["name"]
                it["raised_by_role"]   = r["role"]
                it["raised_by_mobile"] = r.get("mobile") or ""
                it["customer_name"] = f"{r['name']} ({r['role'].replace('_',' ')})"
                if not it.get("mobile"):
                    it["mobile"] = r.get("mobile") or ""
            elif (it.get("customer_id") or "").upper() == "INTERNAL":
                it["customer_name"] = "Internal ticket"
    return {"ok": True, "items": out_items, "page": page, "per": per}

