@app.get("/api/mobile/v1/dashboard/summary")
def summary(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    out = {"ok": True}
    # _v4719_CUST_SUMMARY  Customer logins get their OWN summary (due, plan,
    # expiry, status) — the staff branch below is for admin/sub_lco/employee.
    if (s.get("user_type") or "") == "customer":
        try:
            # _v4720_BY_PK  Look up by the session's `user_pk` (= customers.id)
            # — guarantees we resolve THIS customer no matter what they typed
            # at login.  Falls back to username only if user_pk is missing.
            pk_raw = s.get("user_pk") or ""
            try:
                pk_int = int(str(pk_raw)) if str(pk_raw).strip() else 0
            except Exception:
                pk_int = 0
            uname = s.get("username") or ""
            with _conn() as c:
                cust = None
                if pk_int:
                    cust = c.execute(
                        "SELECT c.customer_id, c.customer_name, c.status, "
                        "       c.end_date, p.plan_name, "
                        "       IFNULL(c.total_bill_amount,0) - IFNULL(c.received_amount,0) AS due "
                        "  FROM customers c LEFT JOIN plans p ON p.id=c.plan_id "
                        " WHERE c.id=? AND c.company_id=? LIMIT 1",
                        (pk_int, cid)).fetchone()
                if cust is None:
                    cust = c.execute(
                        "SELECT c.customer_id, c.customer_name, c.status, "
                        "       c.end_date, p.plan_name, "
                        "       IFNULL(c.total_bill_amount,0) - IFNULL(c.received_amount,0) AS due "
                        "  FROM customers c LEFT JOIN plans p ON p.id=c.plan_id "
                        " WHERE c.company_id=? AND (c.username=? OR c.customer_id=?) LIMIT 1",
                        (cid, uname, uname)).fetchone()
            if cust:
                # Format end_date as DD-MM-YYYY for the screen.
                ed = (cust["end_date"] or "")
                if len(ed) >= 10 and ed[4] == '-' and ed[7] == '-':
                    ed = f"{ed[8:10]}-{ed[5:7]}-{ed[:4]}"
                # _v4720_LIVE_DUE  Use the same live ledger calc as /me:
                # sum(invoices.total_amount) − sum(payments.amount+discount).
                # The cached `total_bill_amount`/`received_amount` columns on
                # `customers` can be stale (showed 6622 while the real ledger
                # was 350).  Always compute fresh.
                try:
                    with _conn() as c2:
                        inv_tot = c2.execute(
                            "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                            " WHERE company_id=? AND customer_id=?",
                            (cid, cust["customer_id"])).fetchone()[0]
                        pay_tot = c2.execute(
                            "SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) "
                            " FROM payments WHERE company_id=? AND customer_id=?",
                            (cid, cust["customer_id"])).fetchone()[0]
                    due_val = max(round(float(inv_tot or 0) - float(pay_tot or 0), 2), 0.0)
                except Exception:
                    due_val = max(float(cust["due"] or 0), 0.0)
                out.update({
                    "customer_id":   cust["customer_id"],
                    "customer_name": cust["customer_name"],
                    "status":        cust["status"] or "Active",
                    "plan_name":     cust["plan_name"] or "—",
                    "end_date":      ed or "—",
                    "due_amount":    round(due_val, 2),
                    "balance":       round(due_val, 2),
                    "online":        False,   # filled below if RADIUS confirms
                })
                try:
                    online_set = _online_set_real([cust["customer_id"]], company_id=cid)
                    out["online"] = bool(online_set)
                except Exception:
                    pass
        except Exception:
            pass
        return out
    # _S39R5N — Apply role scope so sub_lco / employee see only their
    # own customer counts, never the whole company.
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # _S40zπ_MOBILE_FIX_  Exclude soft-deleted customers from the count
        _del_ex = " AND COALESCE(status,'') NOT IN ('Deleted','deleted','Terminated','terminated') "
        out["subscribers_total"]  = c.execute(
            "SELECT COUNT(*) FROM customers " + scope_sql + _del_ex, scope_params
        ).fetchone()[0]
        out["subscribers_active"] = c.execute(
            "SELECT COUNT(*) FROM customers " + scope_sql + " AND status='Active'" + _del_ex,
            scope_params
        ).fetchone()[0]
        # Complaints scoped by company only (sub_lco/employee can see customer
        # complaints in their scope — TODO: add scope filter if requested).
        out["complaints_open"] = c.execute(
            "SELECT COUNT(*) FROM complaints WHERE company_id=? "
            "AND IFNULL(status,'')!='Resolved'",(cid,)
        ).fetchone()[0]
        # _S39R5N — bill_dues was returning row count (always 0 because the
        # field is total_due_balance, not total_bill_amount). Fix: SUM the
        # actual balance owed.
        try:
            # _S39R5N — Real "amount due" = total_bill_amount - received_amount,
            # only count customers where that delta is > 0.
            row = c.execute(
                "SELECT IFNULL(SUM("
                "  CASE WHEN (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) > 0 "
                "       THEN (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) "
                "       ELSE 0 END), 0), "
                " SUM(CASE WHEN (IFNULL(total_bill_amount,0) - IFNULL(received_amount,0)) > 0 "
                "          THEN 1 ELSE 0 END) "
                " FROM customers " + scope_sql, scope_params
            ).fetchone()
            out["bill_dues_amount"] = float(row[0] or 0)
            out["bill_dues_count"]  = int(row[1] or 0)
            out["bill_dues"]        = int(row[1] or 0)
        except Exception as _e:
            out["bill_dues_amount"] = 0.0
            out["bill_dues_count"]  = 0
            out["bill_dues"]        = 0

    # online count from radacct — real-time (stale + NAS-down filtered)
    try:
        usernames = [r[0] for r in
                     _conn().execute("SELECT username FROM customers WHERE company_id=? AND IFNULL(username,'')!=''",(cid,)).fetchall()]
        if usernames:
            out["online_now"] = len(_online_set_real(usernames, company_id=cid))
        else:
            out["online_now"] = 0
    except Exception:
        out["online_now"] = 0
    return out

