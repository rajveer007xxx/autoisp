@app.get("/api/mobile/v1/invoices")
def invoices(authorization: Optional[str] = Header(None),
             q: str = "", user_type: str = "",
             locality_id: Optional[int] = None,
             limit: int = Query(100, ge=1, le=500)):
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # _v467_INV — alias total_amount as amount; ledger-correct due_balance.
        sql = ("SELECT i.id, i.invoice_no, i.total_amount AS amount, "
               "        i.total_amount, i.start_date, i.end_date, "
               "        i.created_at, i.issue_date, i.due_date, i.status, "
               "        c.customer_name, c.customer_id, c.customer_type, "
               "        c.customer_phone AS mobile, c.location_id, c.locality, "
               "        ( (SELECT COALESCE(SUM(total_amount),0) FROM invoices ii WHERE ii.customer_id=c.customer_id AND ii.company_id=c.company_id) "
               "          - (SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) FROM payments pp WHERE pp.customer_id=c.customer_id AND pp.company_id=c.company_id) "
               "        ) AS due_balance, "
               "        ( (SELECT COALESCE(SUM(total_amount),0) FROM invoices ii WHERE ii.customer_id=c.customer_id AND ii.company_id=c.company_id) "
               "          - (SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) FROM payments pp WHERE pp.customer_id=c.customer_id AND pp.company_id=c.company_id) "
               "        ) AS current_due "
               "   FROM invoices i "
               "   JOIN customers c ON c.customer_id = i.customer_id "
               "  WHERE 1=1 ")
        params = []
        # Re-add scope
        sub = scope_sql.replace(" WHERE company_id=?", " AND c.company_id=?", 1)
        sql += sub
        params += list(scope_params)
        if user_type and user_type.lower() not in ("all", ""):
            # _v467_FILT — DB has 'Postpaid'/'Prepaid'/'broadband'. Mobile UI sends
            # 'broadband' or 'cable_tv'. Map both correctly:
            #   broadband → matches Postpaid + Prepaid + broadband (any PPP user)
            #   cable_tv  → matches cable_tv / Cable TV / CableTV
            v = user_type.lower().replace("_", "")
            if v == "broadband":
                sql += (" AND LOWER(REPLACE(IFNULL(c.customer_type,''),' ','')) "
                        "   IN ('broadband','postpaid','prepaid','ppp') ")
            elif v in ("cabletv", "cable"):
                sql += (" AND LOWER(REPLACE(IFNULL(c.customer_type,''),' ','')) "
                        "   IN ('cabletv','cable','catv') ")
            else:
                sql += " AND LOWER(IFNULL(c.customer_type,''))=LOWER(?) "
                params.append(user_type)
        if locality_id:
            sql += " AND c.location_id=? "
            params.append(int(locality_id))
        if q:
            sql += (" AND (i.invoice_no LIKE ? OR c.customer_name LIKE ? "
                    " OR c.customer_id LIKE ?) ")
            like = f"%{q}%"
            params += [like]*3
        sql += " ORDER BY i.id DESC LIMIT ? "
        params.append(limit)
        rows = c.execute(sql, params).fetchall()
        items = [{k: r[k] for k in r.keys()} for r in rows]
    return {"ok": True, "count": len(items), "items": items}


