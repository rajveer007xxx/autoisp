# _S40zπ_MOBILE_FIX_  Tickets endpoint — alias of complaints with relaxed schema
class _TicketIn(BaseModel):
    # _v464_ — All fields optional with safe defaults; UI 422 errors
    # caused by missing 'subject' or 'description' now degrade gracefully.
    subject: Optional[str] = "Mobile complaint"
    description: Optional[str] = ""
    complaint_type: Optional[str] = "Other"
    priority: Optional[str] = "Medium"
    customer_id: Optional[str] = None
    target_type: Optional[str] = None     # "admin" / "sub_lco" / "employee"
    target_id: Optional[str] = None       # admin_id / sub_lco_code / employee_code

@app.post("/api/mobile/v1/tickets")
def create_ticket(body: _TicketIn,
                  authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    # _v4721_TKT_CUST — customers must always raise tickets under their
    # OWN customer_id, ignoring whatever the client sent. Other roles
    # (admin/sub_lco/employee) may target a specific customer or leave
    # blank for an INTERNAL ticket.
    if (s.get("user_type") or "").lower() == "customer":
        cust_id = s.get("customer_id")
        if not cust_id:
            with _conn() as _cc:
                _cust = _cc.execute(
                    "SELECT customer_id FROM customers "
                    " WHERE company_id=? AND (id=? OR username=? OR customer_id=?) "
                    " LIMIT 1",
                    (cid, s.get("user_pk") or "",
                     s.get("username") or "",
                     s.get("username") or "")).fetchone()
            cust_id = _cust["customer_id"] if _cust else ""
        customer_id = cust_id or "INTERNAL"
    else:
        customer_id = body.customer_id or "INTERNAL"
    import time as _t, secrets as _sec
    ticket = f"TKT{int(_t.time())}{_sec.token_hex(2).upper()}"
    now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
    target_role = (body.target_type or "admin").lower()
    if target_role not in ("admin", "sub_lco", "employee"):
        target_role = "admin"
    with _conn() as c:
        c.execute(
            "INSERT INTO complaints (company_id, customer_id, ticket_no, "
            " complaint_type, priority, subject, description, status, "
            " created_at, updated_at, kind, source, target_role, resolved_by) "
            "VALUES (?,?,?,?,?,?,?,'Open',?,?,'Ticket','mobile',?,?)",
            (cid, customer_id, ticket, body.complaint_type, body.priority,
             body.subject, body.description, now, now, target_role,
             body.target_id or ""))
        c.commit()
    return {"ok": True, "ticket_no": ticket, "id": ticket}

