@app.get("/api/mobile/v1/subscribers/{cust_pk}")
def subscriber_detail(cust_pk: int,
                      authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        row = c.execute(
            "SELECT id, customer_id, username, customer_name, customer_email, customer_phone, alt_mobile, address, locality, city, state, pincode, plan_id, monthly_amount, auto_renew, customer_type, mac_address, ip_address, vendor, modem_no, start_date, end_date, period, bill_amount, total_bill_amount, received_amount, security_deposit, installation_charges, router_charges, discount_credit, status, payment_mode, transaction_id, payment_notes, service_type, sub_lco_id, location_id, auth_type, static_ip_address, zone, node, allow_devices, custom_rate_limit, created_at, updated_at, installation_date, id_proof, id_proof_no FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not row:
            raise HTTPException(404, "not_found")
        r = {k: row[k] for k in row.keys()}
        # Plan name lookup
        pname = None
        if r.get("plan_id"):
            prow = c.execute(
                "SELECT plan_name, speed, after_tax_amount, validity, validity_unit "
                "  FROM plans WHERE id=?", (r["plan_id"],)).fetchone()
            if prow:
                r["plan_name"] = prow["plan_name"]
                r["plan_speed"] = prow["speed"]
                r["plan_amount"] = prow["after_tax_amount"]
                r["plan_validity"] = f'{prow["validity"] or ""} {prow["validity_unit"] or ""}'.strip()
    # online + last session bytes
    r["online"] = False
    r["session_bytes_in"] = 0
    r["session_bytes_out"] = 0
    if r.get("username"):
        act = _online_session_real(r["username"], company_id=cid)
        if act:
            r["online"] = True
            r["session_started_at"] = act["acctstarttime"]
            r["session_bytes_in"] = act["acctinputoctets"] or 0
            r["session_bytes_out"] = act["acctoutputoctets"] or 0
            r["session_ip"] = act["framedipaddress"]
            r["session_mac"] = act["callingstationid"]
    # _S39R5N — Compute formatted_period "DD-MM-YYYY to DD-MM-YYYY" so the
    # mobile detail screen shows the real billing window instead of "1 mo".
    try:
        sd = (r.get("start_date") or "").strip()
        ed = (r.get("end_date") or "").strip()
        def _fmt(d):
            if d and len(d) >= 10 and d[4] == "-" and d[7] == "-":
                return f"{d[8:10]}-{d[5:7]}-{d[0:4]}"
            return d or ""
        if sd and ed:
            r["formatted_period"] = f"{_fmt(sd)} to {_fmt(ed)}"
        elif ed:
            r["formatted_period"] = _fmt(ed)
        else:
            r["formatted_period"] = ""
    except Exception:
        r["formatted_period"] = ""
    # _S40zπ_v462_  Real outstanding — match the web portal's logic.
    # Web shows latest invoice's `due_at_issue` (= prev_balance + this_period)
    # MINUS payments made AFTER that invoice was issued. This stays consistent
    # with what the user sees on the receipt and on the subscriber-detail page
    # of the desktop admin.
    try:
        with _conn() as _c2:
            inv = _c2.execute(
                "SELECT total_amount, due_at_issue, issue_date "
                "  FROM invoices "
                " WHERE company_id=? AND customer_id=? "
                " ORDER BY id DESC LIMIT 1",
                (cid, r.get("customer_id"))).fetchone()
            current_period   = float(inv["total_amount"] or 0) if inv else 0.0
            due_at_issue     = float(inv["due_at_issue"] or 0) if inv else 0.0
            previous_balance = round(due_at_issue - current_period, 2)
            # Subtract payments AFTER the issue_date so the live "payable_due"
            # actually reflects what the user owes RIGHT NOW.
            paid_since = 0.0
            if inv and inv["issue_date"]:
                ps = _c2.execute(
                    "SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) "
                    "  FROM payments "
                    " WHERE company_id=? AND customer_id=? "
                    "   AND DATE(paid_at) >= DATE(?)",
                    (cid, r.get("customer_id"), inv["issue_date"])).fetchone()
                paid_since = float(ps[0] or 0)
            payable_due = round(max(0.0, due_at_issue - paid_since), 2)
            r["previous_balance"]   = round(max(0.0, previous_balance), 2)
            r["current_period_due"] = round(current_period, 2)
            r["current_dues"]       = round(current_period, 2)  # legacy alias
            r["payable_due"]        = payable_due
            r["balance"]            = payable_due

            # Last payment shown on receipts
            lp = _c2.execute(
                "SELECT amount, paid_at FROM payments "
                " WHERE company_id=? AND customer_id=? "
                " ORDER BY id DESC LIMIT 1",
                (cid, r.get("customer_id"))).fetchone()
            if lp:
                r["last_payment_amount"] = round(float(lp["amount"] or 0), 2)
                # Format paid_at as IST DD-MM-YYYY HH:MM (DB stores naive IST)
                try:
                    raw = str(lp["paid_at"] or "").strip()
                    for fmt_in in ("%Y-%m-%d %H:%M:%S.%f","%Y-%m-%d %H:%M:%S"):
                        try:
                            r["last_paid_at"] = datetime.strptime(raw[:26], fmt_in)\
                                .strftime("%d-%m-%Y %H:%M")
                            break
                        except Exception: pass
                except Exception:
                    r["last_paid_at"] = lp["paid_at"]
            else:
                r["last_payment_amount"] = 0.0
                r["last_paid_at"]        = ""
    except Exception:
        r["previous_balance"]    = 0.0
        r["current_period_due"]  = 0.0
        r["current_dues"]        = 0.0
        r["payable_due"]         = 0.0
        r["balance"]             = 0.0
        r["last_payment_amount"] = 0.0
        r["last_paid_at"]        = ""
    return {"ok": True, "subscriber": r}


