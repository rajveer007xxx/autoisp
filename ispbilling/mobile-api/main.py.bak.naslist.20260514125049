@app.get("/api/mobile/v1/notifications")
def notifications_list(authorization: Optional[str] = Header(None),
                       page: int = Query(1, ge=1),
                       per: int = Query(25, ge=1, le=25)):
    """_v471_NOTIF_SCOPE — Aggregated notifications feed.
    Sub-LCO / Employee see only their own customers' complaints + payments.
    Customer role sees only their own complaints + payments."""
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    ut  = (s.get("user_type") or "").lower()
    cust_self = s.get("customer_id") or ""
    items = []
    # Build the customer_id whitelist when role is sub_lco/employee/customer
    in_scope_ids = None  # None = no scope filter (admin)
    with _conn() as c:
        if ut == "customer" and cust_self:
            in_scope_ids = [cust_self]
        elif ut in ("sub_lco", "employee"):
            scope_sql, scope_params = _scope_clause(s)
            try:
                rows = c.execute("SELECT customer_id FROM customers " + scope_sql,
                                 scope_params).fetchall()
                in_scope_ids = [r["customer_id"] for r in rows if r["customer_id"]]
            except Exception:
                in_scope_ids = []
        # Open complaints
        try:
            base_q = ("SELECT id, ticket_no, subject, status, customer_id, created_at "
                      "  FROM complaints WHERE company_id=? AND IFNULL(status,'')!='Resolved' ")
            qparams = [cid]
            if in_scope_ids is not None:
                if in_scope_ids:
                    qm = ",".join("?" * len(in_scope_ids))
                    base_q += f" AND customer_id IN ({qm}) "
                    qparams += in_scope_ids
                else:
                    base_q += " AND 1=0 "
            base_q += " ORDER BY id DESC LIMIT 30"
            for r in c.execute(base_q, qparams).fetchall():
                items.append({
                    "id": f"cmp_{r['id']}", "kind": "complaint",
                    "title": f"Ticket {r['ticket_no'] or r['id']}",
                    "body":  r["subject"] or "Complaint open",
                    "ref":   r["ticket_no"] or "",
                    "ts":    r["created_at"] or "",
                    "unread": True,
                })
        except Exception: pass
        # Recent payments (last 30)
        try:
            base_q = ("SELECT id, transaction_no, amount, paid_at, customer_id "
                      "  FROM payments WHERE company_id=? ")
            qparams = [cid]
            if in_scope_ids is not None:
                if in_scope_ids:
                    qm = ",".join("?" * len(in_scope_ids))
                    base_q += f" AND customer_id IN ({qm}) "
                    qparams += in_scope_ids
                else:
                    base_q += " AND 1=0 "
            base_q += " ORDER BY id DESC LIMIT 30"
            for r in c.execute(base_q, qparams).fetchall():
                items.append({
                    "id": f"pay_{r['id']}", "kind": "payment",
                    "title": f"Payment received \u20b9{int(float(r['amount'] or 0))}",
                    "body":  f"{r['customer_id'] or ''} \u00b7 {r['transaction_no'] or ''}",
                    "ref":   r["transaction_no"] or "",
                    "ts":    r["paid_at"] or "",
                    "unread": False,
                })
        except Exception: pass
        # V4728_NOTIF_INVOICES — Recent invoices (last 30) so customers see
        # the invoice in their notification feed the moment it is generated.
        try:
            base_q = ("SELECT id, invoice_no, total_amount, due_at_issue, issue_date, "
                      "       created_at, customer_id "
                      "  FROM invoices WHERE company_id=? ")
            qparams = [cid]
            if in_scope_ids is not None:
                if in_scope_ids:
                    qm = ",".join("?" * len(in_scope_ids))
                    base_q += f" AND customer_id IN ({qm}) "
                    qparams += in_scope_ids
                else:
                    base_q += " AND 1=0 "
            base_q += " ORDER BY id DESC LIMIT 30"
            for r in c.execute(base_q, qparams).fetchall():
                _t = float(r["total_amount"] or 0)
                _d = float(r["due_at_issue"] or 0)
                _amt = _d if _d > 0 else _t
                items.append({
                    "id":    f"inv_{r['id']}",
                    "kind":  "invoice",
                    "title": f"New invoice ₹{int(round(_amt))}",
                    "body":  f"{r['invoice_no'] or ''}".strip() or "Invoice generated",
                    "ref":   r["invoice_no"] or "",
                    "ts":    r["created_at"] or r["issue_date"] or "",
                    "unread": True,
                })
        except Exception: pass
                # OLT/ONU unacked alerts (staff roles only — customers never see
        # global network alerts on their personal feed).
        try:
            if ut == "customer":
                raise StopIteration
            for r in c.execute(
                "SELECT id, severity, title, message, created_at "
                "  FROM olt_alerts WHERE company_id=? "
                "   AND COALESCE(acked,0)=0 "
                " ORDER BY id DESC LIMIT 30", (cid,)).fetchall():
                items.append({
                    "id": f"alt_{r['id']}", "kind": "alert",
                    "title": r["title"] or "Network alert",
                    "body":  r["message"] or "",
                    "ts":    r["created_at"] or "",
                    "unread": True,
                })
        except Exception: pass

    items.sort(key=lambda x: x.get("ts") or "", reverse=True)
    # _v4723_  Hard cap at 25 latest items (matches new UX requirement)
    per = min(per, 25)
    items = items[(page-1)*per:(page-1)*per + per]
    return {"ok": True, "items": items, "page": page, "per": per,
            "count": len(items)}

