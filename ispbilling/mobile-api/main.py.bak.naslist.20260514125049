class _UpgradeIn(BaseModel):
    plan_id: int
    note: Optional[str] = ""

@app.post("/api/mobile/v1/me/upgrade-request")
def me_upgrade_request(body: _UpgradeIn,
                       authorization: Optional[str] = Header(None)):
    """_v4722_  The customer picks a plan from /plans (higher than their
    current) and asks for it. We create a Ticket on their behalf, addressed
    to their account's primary admin, with sub_lco/employee receipts set so
    the right operator dashboards see it."""
    s = _require_auth(authorization)
    if (s.get("user_type") or "").lower() != "customer":
        raise HTTPException(403, "customer_only")
    cid = s.get("company_id") or ""
    cust_id = s.get("customer_id") or ""
    with _conn() as c:
        # Resolve the customer row
        cust = c.execute(
            "SELECT id, customer_id, customer_name, plan_id, monthly_amount, "
            "       sub_lco_id, location_id, created_by_employee_id "
            "  FROM customers "
            " WHERE company_id=? AND (id=? OR customer_id=? OR username=?) "
            " LIMIT 1",
            (cid, s.get("user_pk") or "", cust_id, s.get("username") or "")
        ).fetchone()
        if not cust:
            raise HTTPException(404, "customer_not_found")
        plan = c.execute(
            "SELECT id, plan_name, speed, after_tax_amount FROM plans "
            " WHERE id=?", (body.plan_id,)).fetchone()
        if not plan:
            raise HTTPException(404, "plan_not_found")
        # Friendly current-plan name
        cur_plan_name = ""
        if cust["plan_id"]:
            cur = c.execute(
                "SELECT plan_name, after_tax_amount FROM plans WHERE id=?",
                (cust["plan_id"],)).fetchone()
            if cur:
                cur_plan_name = (cur["plan_name"] or "") +                     (f" (₹{int(float(cur['after_tax_amount'] or 0))})" if cur else "")
        # Build subject / body
        subject = f"Plan upgrade request: {plan['plan_name']}"
        body_txt = (
            f"Customer {cust['customer_name']} (#{cust['customer_id']}) "
            f"requests upgrade to plan '{plan['plan_name']}' "
            f"@ ₹{int(float(plan['after_tax_amount'] or 0))} "
            f"({plan['speed'] or ''}). "
            f"Current plan: {cur_plan_name or 'None'}. "
        )
        if body.note:
            body_txt += f"Customer note: {body.note.strip()}"
        # Pick a target: prefer assigned sub_lco, else first admin
        target_role = "admin"
        target_id = ""
        if cust["sub_lco_id"]:
            sl = c.execute(
                "SELECT sub_lco_code FROM sub_lcos WHERE id=? AND company_id=?",
                (cust["sub_lco_id"], cid)).fetchone()
            if sl and sl["sub_lco_code"]:
                target_role = "sub_lco"; target_id = sl["sub_lco_code"]
        if not target_id:
            ad = c.execute(
                "SELECT admin_id FROM admins WHERE company_id=? "
                "ORDER BY id LIMIT 1", (cid,)).fetchone()
            if ad and ad["admin_id"]:
                target_role = "admin"; target_id = ad["admin_id"]
        # Insert ticket
        import time as _t, secrets as _sec
        ticket = f"UPG{int(_t.time())}{_sec.token_hex(2).upper()}"
        now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
        c.execute(
            "INSERT INTO complaints (company_id, customer_id, ticket_no, "
            " complaint_type, priority, subject, description, status, "
            " created_at, updated_at, kind, source, target_role, resolved_by) "
            "VALUES (?,?,?,?,?,?,?,'Open',?,?,'Ticket','mobile',?,?)",
            (cid, cust["customer_id"], ticket, "Plan Upgrade", "Medium",
             subject, body_txt, now, now, target_role, target_id))
        c.commit()
    return {"ok": True, "ticket_no": ticket,
            "message": "Your upgrade request has been submitted. Our team will contact you shortly."}
# === end _v4722_  Plan upgrade request ===


