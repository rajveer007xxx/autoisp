# _v4719_ME_INVOICES  Customer transactions page — combined chronological feed
# of invoices + payments with DD-MM-YYYY dates and per-row download URLs.
def _v4719_fmt_d(raw):
    s = str(raw or "").strip()
    if len(s) >= 10 and s[4] == '-' and s[7] == '-':
        return f"{s[8:10]}-{s[5:7]}-{s[:4]}"
    return s


@app.get("/api/mobile/v1/me/invoices")
def me_invoices(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    if (s.get("user_type") or "") != "customer":
        raise HTTPException(403, "customer_only")
    cid   = s.get("company_id") or ""
    uname = s.get("username") or ""
    with _conn() as c:
        # _v4720_INV_PK  Resolve THIS customer by id (user_pk).
        pk_raw = s.get("user_pk") or ""
        try:
            pk_int = int(str(pk_raw)) if str(pk_raw).strip() else 0
        except Exception:
            pk_int = 0
        cust = None
        if pk_int:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE id=? AND company_id=? LIMIT 1",
                (pk_int, cid)).fetchone()
        if cust is None:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE company_id=? AND (username=? OR customer_id=?) LIMIT 1",
                (cid, uname, uname)).fetchone()
        if not cust:
            return {"ok": True, "items": [], "invoices": []}
        cust_id = cust["customer_id"]
        invoices = c.execute(
            # V4728_INV_AMT_DUE_AT_ISSUE — also fetch due_at_issue so the mobile app can
            # show TOTAL due (running balance incl. previous dues), not just
            # the current period's charge.
            "SELECT id, invoice_no, issue_date AS dt, total_amount, "
            "       due_at_issue, IFNULL(status,'Unpaid') AS status "
            "  FROM invoices WHERE company_id=? AND customer_id=? "
            " ORDER BY id DESC LIMIT 200",
            (cid, cust_id)).fetchall()
        payments = c.execute(
            "SELECT id, transaction_no, paid_at AS dt, amount, "
            "       IFNULL(payment_mode,'') AS mode "
            "  FROM payments WHERE company_id=? AND customer_id=? "
            " ORDER BY id DESC LIMIT 200",
            (cid, cust_id)).fetchall()
    items = []
    for r in invoices:
        # V4728_INV_AMT_DUE_AT_ISSUE — amount shown to customer = total due at
        # issue (running balance incl. any previous dues carried forward).
        # Fall back to period total when due_at_issue is missing (legacy rows).
        _total_amt = float(r["total_amount"] or 0)
        _due_run   = float(r["due_at_issue"] or 0)
        _shown_amt = _due_run if _due_run > 0 else _total_amt
        items.append({
            "kind": "invoice",
            "id": r["id"],
            "ref": r["invoice_no"] or f"INV-{r['id']}",
            "date": _v4719_fmt_d(r["dt"]),
            "amount":           round(_shown_amt, 2),
            "total_due":        round(_shown_amt, 2),
            "period_amount":    round(_total_amt, 2),
            "previous_balance": round(max(0.0, _shown_amt - _total_amt), 2),
            "status": r["status"],
            "_sort": str(r["dt"] or ""),
            "download_url": f"/api/mobile/v1/me/invoices/{r['id']}/pdf",
        })
    for r in payments:
        items.append({
            "kind": "payment",
            "id": r["id"],
            "ref": r["transaction_no"] or f"PAY-{r['id']}",
            "date": _v4719_fmt_d(r["dt"]),
            "amount": round(float(r["amount"] or 0), 2),
            "status": "Paid",
            "mode": r["mode"],
            "_sort": str(r["dt"] or ""),
            "download_url": f"/api/mobile/v1/me/payments/{r['id']}/pdf",
        })
    items.sort(key=lambda x: x["_sort"], reverse=True)
    for it in items:
        it.pop("_sort", None)
    # Back-compat: legacy clients read `.invoices`.
    return {"ok": True, "items": items,
            "invoices": [i for i in items if i["kind"] == "invoice"]}

def _v4719_fetch_pdf(url: str):
    """Stream a PDF response from the localhost admin-portal.  Returns
    a 200 with the PDF on success, or a structured JSON error otherwise."""
    import requests as _r, json as _json
    from fastapi.responses import Response as _Resp
    try:
        r = _r.get(url, timeout=30)
        if r.status_code == 200 and (r.headers.get("content-type") or "").startswith(
                ("application/pdf", "application/octet-stream")):
            return _Resp(content=r.content, media_type="application/pdf")
        # _v4720_PDF_ERR  Surface whatever the admin portal said as JSON.
        detail = "pdf_unavailable"
        try:
            j = r.json(); detail = j.get("detail") or detail
        except Exception:
            detail = (r.text or "")[:300] or detail
        return _Resp(
            content=_json.dumps({"ok": False, "status": r.status_code,
                                  "detail": detail}).encode(),
            status_code=502, media_type="application/json")
    except Exception as e:
        return _Resp(
            content=_json.dumps({"ok": False, "detail": f"pdf_error: {e}"}).encode(),
            status_code=502, media_type="application/json")

@app.get("/api/mobile/v1/me/payments/{pay_id}/pdf")
