# ============================================================================
#                       _v4721_  Profile self-service endpoints
# ============================================================================
from fastapi import UploadFile, File, Form  # _v4721_
import os as _os_v4721, time as _time_v4721

class _ProfileIn(BaseModel):
    name:   Optional[str] = None
    email:  Optional[str] = None
    mobile: Optional[str] = None

@app.patch("/api/mobile/v1/auth/profile")
def update_profile_v4721(body: _ProfileIn,
                         authorization: Optional[str] = Header(None)):
    """_v4721_  Update name / email / mobile for the logged-in user across
    admin / sub_lco / employee / customer tables."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    pk  = s.get("user_pk") or ""
    ut  = (s.get("user_type") or "").lower()
    name   = (body.name or "").strip()
    email  = (body.email or "").strip()
    mobile = (body.mobile or "").strip()
    with _conn() as c:
        if ut == "admin":
            c.execute(
                "UPDATE admins SET "
                "  admin_name=COALESCE(NULLIF(?,''),admin_name), "
                "  admin_email=COALESCE(NULLIF(?,''),admin_email), "
                "  admin_mobile=COALESCE(NULLIF(?,''),admin_mobile) "
                "WHERE id=? AND company_id=?",
                (name, email, mobile, pk, cid))
        elif ut == "sub_lco":
            c.execute(
                "UPDATE sub_lcos SET "
                "  name=COALESCE(NULLIF(?,''),name), "
                "  email=COALESCE(NULLIF(?,''),email), "
                "  mobile=COALESCE(NULLIF(?,''),mobile) "
                "WHERE id=? AND company_id=?",
                (name, email, mobile, pk, cid))
        elif ut == "employee":
            c.execute(
                "UPDATE employees SET "
                "  employee_name=COALESCE(NULLIF(?,''),employee_name), "
                "  email=COALESCE(NULLIF(?,''),email), "
                "  mobile=COALESCE(NULLIF(?,''),mobile) "
                "WHERE id=? AND company_id=?",
                (name, email, mobile, pk, cid))
        elif ut == "customer":
            c.execute(
                "UPDATE customers SET "
                "  customer_name=COALESCE(NULLIF(?,''),customer_name), "
                "  customer_email=COALESCE(NULLIF(?,''),customer_email), "
                "  customer_phone=COALESCE(NULLIF(?,''),customer_phone) "
                "WHERE id=? AND company_id=?",
                (name, email, mobile, pk, cid))
        else:
            raise HTTPException(400, "unsupported_role")
        c.commit()
    return {"ok": True}


class _PwIn(BaseModel):
    old_password: str
    new_password: str

@app.post("/api/mobile/v1/auth/change-password")
def change_password_v4721(body: _PwIn,
                          authorization: Optional[str] = Header(None)):
    """_v4721_  Change password for the logged-in user. Verifies the current
    password against the same hash scheme used by /auth/login (bcrypt + a
    legacy sha256 fallback for older accounts)."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    pk  = s.get("user_pk") or ""
    ut  = (s.get("user_type") or "").lower()
    new_pw = (body.new_password or "").strip()
    old_pw = body.old_password or ""
    if len(new_pw) < 6:
        raise HTTPException(400, "password_too_short")
    table_col = {
        "admin":    ("admins",    "password_hash"),
        "sub_lco":  ("sub_lcos",  "password_hash"),
        "employee": ("employees", "password_hash"),
        "customer": ("customers", "password_hash"),
    }.get(ut)
    if not table_col:
        raise HTTPException(400, "unsupported_role")
    tbl, col = table_col
    with _conn() as c:
        row = c.execute(
            f"SELECT {col} AS h FROM {tbl} WHERE id=? AND company_id=?",
            (pk, cid)).fetchone()
        if not row:
            raise HTTPException(404, "user_not_found")
        stored = row["h"] or ""
        # Verify old password
        ok = False
        try:
            import bcrypt
            if stored.startswith("$2"):
                ok = bcrypt.checkpw(old_pw.encode(), stored.encode())
        except Exception:
            ok = False
        if not ok:
            # Legacy sha256 fallback
            try:
                import hashlib
                if hashlib.sha256(old_pw.encode()).hexdigest() == stored:
                    ok = True
            except Exception:
                pass
        if not ok and stored and stored == old_pw:
            ok = True  # plaintext legacy
        if not ok:
            raise HTTPException(401, "wrong_password")
        # Hash new
        try:
            import bcrypt
            new_hash = bcrypt.hashpw(new_pw.encode(), bcrypt.gensalt()).decode()
        except Exception:
            import hashlib
            new_hash = hashlib.sha256(new_pw.encode()).hexdigest()
        c.execute(
            f"UPDATE {tbl} SET {col}=? WHERE id=? AND company_id=?",
            (new_hash, pk, cid))
        c.commit()
    return {"ok": True}


@app.post("/api/mobile/v1/auth/profile/image")
async def upload_profile_image_v4721(
        file: UploadFile = File(...),
        authorization: Optional[str] = Header(None)):
    """_v4721_  Upload + persist a profile picture for the logged-in user.
    Saves to /opt/ispbilling/static/uploads/<company_id>/avatars/<id>.<ext>
    and writes the relative path back to the user's row."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    pk  = s.get("user_pk") or ""
    ut  = (s.get("user_type") or "").lower()
    table_col = {
        "admin":    ("admins",    "profile_image_path"),
        "sub_lco":  ("sub_lcos",  "profile_image"),
        "employee": ("employees", "profile_image_path"),
        "customer": ("customers", "photograph_path"),
    }.get(ut)
    if not table_col:
        raise HTTPException(400, "unsupported_role")
    tbl, col = table_col
    # Sniff extension
    fname = (file.filename or "image.jpg").lower()
    ext = "jpg"
    for cand in ("png", "jpg", "jpeg", "webp", "heic"):
        if fname.endswith("." + cand):
            ext = cand if cand != "jpeg" else "jpg"
            break
    # Storage path
    rel_dir = f"static/uploads/{cid}/avatars"
    abs_dir = f"/opt/ispbilling/admin-portal/{rel_dir}"
    try:
        _os_v4721.makedirs(abs_dir, exist_ok=True)
    except Exception:
        pass
    fn = f"{ut}-{pk}-{int(time.time())}.{ext}"
    abs_path = f"{abs_dir}/{fn}"
    rel_path = f"/{rel_dir}/{fn}"
    data = await file.read()
    if len(data) > 8 * 1024 * 1024:
        raise HTTPException(413, "file_too_large")
    with open(abs_path, "wb") as out:
        out.write(data)
    with _conn() as c:
        c.execute(
            f"UPDATE {tbl} SET {col}=? WHERE id=? AND company_id=?",
            (rel_path, pk, cid))
        c.commit()
    return {"ok": True,
            "profile_image_url": f"https://www.autoispbilling.com{rel_path}",
            "path": rel_path}
# === end _v4721_  Profile self-service endpoints ===


# ============================================================================
#                _v4722_  Customer-initiated plan upgrade request
# ============================================================================
class _UpgradeIn(BaseModel):
    plan_id: int
    note: Optional[str] = ""

@app.post("/api/mobile/v1/me/upgrade-request")
def me_upgrade_request(body: _UpgradeIn,
                       authorization: Optional[str] = Header(None)):
    """_v4722_  The customer picks a plan from /plans (higher than their
    current) and asks for it. We create a Ticket on their behalf, addressed
    to their account's primary admin, with sub_lco/employee receipts set so
    the right operator dashboards see it."""
    s = _require_auth(authorization)
    if (s.get("user_type") or "").lower() != "customer":
        raise HTTPException(403, "customer_only")
    cid = s.get("company_id") or ""
    cust_id = s.get("customer_id") or ""
    with _conn() as c:
        # Resolve the customer row
        cust = c.execute(
            "SELECT id, customer_id, customer_name, plan_id, monthly_amount, "
            "       sub_lco_id, location_id, created_by_employee_id "
            "  FROM customers "
            " WHERE company_id=? AND (id=? OR customer_id=? OR username=?) "
            " LIMIT 1",
            (cid, s.get("user_pk") or "", cust_id, s.get("username") or "")
        ).fetchone()
        if not cust:
            raise HTTPException(404, "customer_not_found")
        plan = c.execute(
            "SELECT id, plan_name, speed, after_tax_amount FROM plans "
            " WHERE id=?", (body.plan_id,)).fetchone()
        if not plan:
            raise HTTPException(404, "plan_not_found")
        # Friendly current-plan name
        cur_plan_name = ""
        if cust["plan_id"]:
            cur = c.execute(
                "SELECT plan_name, after_tax_amount FROM plans WHERE id=?",
                (cust["plan_id"],)).fetchone()
            if cur:
                cur_plan_name = (cur["plan_name"] or "") +                     (f" (₹{int(float(cur['after_tax_amount'] or 0))})" if cur else "")
        # Build subject / body
        subject = f"Plan upgrade request: {plan['plan_name']}"
        body_txt = (
            f"Customer {cust['customer_name']} (#{cust['customer_id']}) "
            f"requests upgrade to plan '{plan['plan_name']}' "
            f"@ ₹{int(float(plan['after_tax_amount'] or 0))} "
            f"({plan['speed'] or ''}). "
            f"Current plan: {cur_plan_name or 'None'}. "
        )
        if body.note:
            body_txt += f"Customer note: {body.note.strip()}"
        # Pick a target: prefer assigned sub_lco, else first admin
        target_role = "admin"
        target_id = ""
        if cust["sub_lco_id"]:
            sl = c.execute(
                "SELECT sub_lco_code FROM sub_lcos WHERE id=? AND company_id=?",
                (cust["sub_lco_id"], cid)).fetchone()
            if sl and sl["sub_lco_code"]:
                target_role = "sub_lco"; target_id = sl["sub_lco_code"]
        if not target_id:
            ad = c.execute(
                "SELECT admin_id FROM admins WHERE company_id=? "
                "ORDER BY id LIMIT 1", (cid,)).fetchone()
            if ad and ad["admin_id"]:
                target_role = "admin"; target_id = ad["admin_id"]
        # Insert ticket
        import time as _t, secrets as _sec
        ticket = f"UPG{int(_t.time())}{_sec.token_hex(2).upper()}"
        now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
        c.execute(
            "INSERT INTO complaints (company_id, customer_id, ticket_no, "
            " complaint_type, priority, subject, description, status, "
            " created_at, updated_at, kind, source, target_role, resolved_by) "
            "VALUES (?,?,?,?,?,?,?,'Open',?,?,'Ticket','mobile',?,?)",
            (cid, cust["customer_id"], ticket, "Plan Upgrade", "Medium",
             subject, body_txt, now, now, target_role, target_id))
        c.commit()
    return {"ok": True, "ticket_no": ticket,
            "message": "Your upgrade request has been submitted. Our team will contact you shortly."}
# === end _v4722_  Plan upgrade request ===


# ============================================================================
#        _v4724_  Plan-upgrade with optional online payment gateway
# ============================================================================
class _UpgradeCheckoutIn(BaseModel):
    plan_id: int
    note: Optional[str] = ""

def _company_gateway_enabled(c, company_id: str) -> bool:
    """_v4724_  Returns True iff the company has Razorpay enabled AND keys
    are configured at the platform level. The flag lives in the legacy
    'companies' table as 'enable_online_payment' (per-admin opt-in)."""
    if not (os.environ.get("RAZORPAY_KEY_ID") and os.environ.get("RAZORPAY_KEY_SECRET")):
        return False
    try:
        row = c.execute(
            "SELECT COALESCE(enable_online_payment,0) AS f FROM companies "
            " WHERE company_id=? LIMIT 1", (company_id,)).fetchone()
        return bool(row and int(row["f"] or 0))
    except Exception:
        return False

@app.post("/api/mobile/v1/me/upgrade-checkout")
def me_upgrade_checkout(body: _UpgradeCheckoutIn,
                        authorization: Optional[str] = Header(None)):
    """__S44B_NEW_UPGRADE_FLOW__  Multi-tenant gateway flow:
       1. Compute amount = plan_after_tax + previous_dues.
       2. Check tenant gateway availability (any payment_gateways row OR
          env Razorpay + companies.enable_online_payment=1).
       3. If available → create plan_change_orders row, mint a customer
          SSO token targeting /customer/upgrade/{oid}/checkout, return
          {mode:'webview', checkout_url:'https://.../auth/sso?token=…'}.
          The mobile app opens this URL inside a WebView and applies the
          plan once the gateway success-chain fires on the web side.
       4. Else → existing ticket fallback (unchanged).
    """
    s = _require_auth(authorization)
    if (s.get("user_type") or "").lower() != "customer":
        raise HTTPException(403, "customer_only")
    cid = s.get("company_id") or ""
    with _conn() as c:
        cust = c.execute(
            "SELECT id, customer_id, customer_name, customer_email, "
            "       customer_phone, plan_id, sub_lco_id "
            "  FROM customers "
            " WHERE company_id=? AND (id=? OR customer_id=? OR username=?) "
            " LIMIT 1",
            (cid, s.get("user_pk") or "", s.get("customer_id") or "",
             s.get("username") or "")).fetchone()
        if not cust:
            raise HTTPException(404, "customer_not_found")
        plan = c.execute(
            "SELECT id, plan_name, speed, after_tax_amount, validity, "
            "       validity_unit FROM plans WHERE id=?",
            (body.plan_id,)).fetchone()
        if not plan:
            raise HTTPException(404, "plan_not_found")
        plan_amt = float(plan["after_tax_amount"] or 0)
        # Compute previous dues (running balance — sum invoices minus payments)
        prev_due = 0.0
        try:
            row_due = c.execute(
                "SELECT COALESCE("
                "  (SELECT SUM(total_amount) FROM invoices "
                "    WHERE company_id=? AND customer_id=?), 0) - COALESCE("
                "  (SELECT SUM(amount) FROM payments "
                "    WHERE company_id=? AND customer_id=?), 0)",
                (cid, cust["customer_id"], cid, cust["customer_id"])).fetchone()
            prev_due = max(0.0, float(row_due[0] or 0))
        except Exception:
            prev_due = 0.0
        amt = round(plan_amt + prev_due, 2)
        # Gate: any active payment_gateways row?
        tenant_has_gw = False
        try:
            r_gw = c.execute(
                "SELECT 1 FROM payment_gateways "
                "WHERE company_id=? AND status='Active' LIMIT 1",
                (cid,)).fetchone()
            tenant_has_gw = bool(r_gw)
        except Exception:
            tenant_has_gw = False
        # Legacy env-Razorpay fallback (only when no tenant gateway).
        env_rzp = bool(os.environ.get("RAZORPAY_KEY_ID")
                       and os.environ.get("RAZORPAY_KEY_SECRET"))
        legacy_op_enabled = _company_gateway_enabled(c, cid)
        online_ok = tenant_has_gw or (env_rzp and legacy_op_enabled)

    if online_ok and amt > 0.5:
        # 1) Insert plan_change_orders pending row.
        with _conn() as c:
            oid = c.execute(
                "INSERT INTO plan_change_orders "
                "(company_id, customer_id, current_plan_id, target_plan_id, "
                " amount_due, status, rzp_order_id) "
                "VALUES (?,?,?,?,?,'pending',NULL) RETURNING id",
                (cid, cust["customer_id"], cust["plan_id"], plan["id"],
                 amt)).fetchone()[0]
            # 2) Mint customer SSO token (5-min) targeting the web checkout.
            tok = secrets.token_urlsafe(32)
            exp = (datetime.now(timezone.utc) + timedelta(minutes=5)).isoformat()
            target = f"/customer/upgrade/{oid}/checkout"
            c.execute(
                "INSERT INTO mobile_sso_tokens "
                "(token,user_type,company_id,user_pk,username,target,expires_at) "
                "VALUES (?,?,?,?,?,?,?)",
                (tok, "customer", cid, cust["id"],
                 s.get("username") or cust["customer_id"], target, exp))
            c.commit()
        base = os.environ.get("PUBLIC_PORTAL_URL", "https://www.autoispbilling.com").rstrip("/")
        return {
            "ok": True,
            "mode": "webview",
            "order_id": oid,
            "amount": amt,
            "plan_amount": plan_amt,
            "previous_dues": prev_due,
            "plan": {
                "id": plan["id"],
                "name": plan["plan_name"],
                "amount": plan_amt,
                "validity": plan["validity"],
                "validity_unit": plan["validity_unit"],
            },
            "checkout_url": f"{base}/auth/sso?token={tok}",
            "success_pattern": "/customer/dashboard",
            "expires_at": exp,
        }

    # Ticket fallback (no gateway available)
    with _conn() as c:
        target_role = "admin"; target_id = ""
        if cust["sub_lco_id"]:
            sl = c.execute(
                "SELECT sub_lco_code FROM sub_lcos WHERE id=? AND company_id=?",
                (cust["sub_lco_id"], cid)).fetchone()
            if sl and sl["sub_lco_code"]:
                target_role = "sub_lco"; target_id = sl["sub_lco_code"]
        if not target_id:
            ad = c.execute(
                "SELECT admin_id FROM admins WHERE company_id=? "
                "ORDER BY id LIMIT 1", (cid,)).fetchone()
            if ad and ad["admin_id"]:
                target_role = "admin"; target_id = ad["admin_id"]
        import secrets as _sec
        ticket = f"UPG{int(time.time())}{_sec.token_hex(2).upper()}"
        now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
        subject = f"Plan upgrade request: {plan['plan_name']}"
        body_txt = (
            f"Customer {cust['customer_name']} (#{cust['customer_id']}) requests "
            f"upgrade to plan '{plan['plan_name']}' @ ₹{int(plan_amt)} "
            f"({plan['speed'] or ''}). "
        )
        if body.note:
            body_txt += f"Customer note: {body.note.strip()}"
        c.execute(
            "INSERT INTO complaints (company_id, customer_id, ticket_no, "
            " complaint_type, priority, subject, description, status, "
            " created_at, updated_at, kind, source, target_role, resolved_by) "
            "VALUES (?,?,?,?,?,?,?,'Open',?,?,'Ticket','mobile',?,?)",
            (cid, cust["customer_id"], ticket, "Plan Upgrade", "Medium",
             subject, body_txt, now, now, target_role, target_id))
        c.commit()
    return {"ok": True, "mode": "ticket", "ticket_no": ticket,
            "message": "Your upgrade request has been submitted. Our team will contact you shortly."}


class _UpgradeVerifyIn(BaseModel):
    plan_id: int
    razorpay_order_id: str
    razorpay_payment_id: str
    razorpay_signature: str

@app.post("/api/mobile/v1/me/upgrade-verify")
def me_upgrade_verify(body: _UpgradeVerifyIn,
                      authorization: Optional[str] = Header(None)):
    """_v4724_  Verify Razorpay payment signature, swap the customer's plan,
    record the payment row, return success."""
    s = _require_auth(authorization)
    if (s.get("user_type") or "").lower() != "customer":
        raise HTTPException(403, "customer_only")
    cid = s.get("company_id") or ""
    key_id = os.environ.get("RAZORPAY_KEY_ID") or ""
    key_secret = os.environ.get("RAZORPAY_KEY_SECRET") or ""
    if not (key_id and key_secret):
        raise HTTPException(503, "gateway_not_configured")
    try:
        import razorpay
        client = razorpay.Client(auth=(key_id, key_secret))
        client.utility.verify_payment_signature({
            "razorpay_order_id":   body.razorpay_order_id,
            "razorpay_payment_id": body.razorpay_payment_id,
            "razorpay_signature":  body.razorpay_signature,
        })
    except Exception as e:
        raise HTTPException(400, f"signature_invalid: {e}")
    # Fetch actual paid amount
    try:
        fetched = client.payment.fetch(body.razorpay_payment_id)
        paid = float((fetched.get("amount") or 0)) / 100.0
        method = fetched.get("method") or "razorpay"
    except Exception:
        paid = 0.0
        method = "razorpay"
    with _conn() as c:
        cust = c.execute(
            "SELECT id, customer_id, plan_id FROM customers "
            " WHERE company_id=? AND (id=? OR customer_id=? OR username=?) "
            " LIMIT 1",
            (cid, s.get("user_pk") or "", s.get("customer_id") or "",
             s.get("username") or "")).fetchone()
        if not cust:
            raise HTTPException(404, "customer_not_found")
        plan = c.execute(
            "SELECT id, plan_name, after_tax_amount, validity, validity_unit "
            "  FROM plans WHERE id=?", (body.plan_id,)).fetchone()
        if not plan:
            raise HTTPException(404, "plan_not_found")
        # Compute new end_date based on plan validity (default 30 days if unset)
        validity = int(plan["validity"] or 30)
        unit = (plan["validity_unit"] or "Days").lower()
        if unit.startswith("month"): days = validity * 30
        elif unit.startswith("year"): days = validity * 365
        elif unit.startswith("week"): days = validity * 7
        else: days = validity
        from datetime import date, timedelta
        today = date.today()
        new_end = (today + timedelta(days=days)).isoformat()
        new_start = today.isoformat()
        now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
        # Update customer plan
        c.execute(
            "UPDATE customers SET plan_id=?, monthly_amount=?, "
            " start_date=?, end_date=?, status='Active', updated_at=? "
            "WHERE id=? AND company_id=?",
            (plan["id"], float(plan["after_tax_amount"] or 0),
             new_start, new_end, now, cust["id"], cid))
        # Record payment (idempotent on transaction_no)
        try:
            existing = c.execute(
                "SELECT id FROM payments WHERE transaction_no=?",
                (body.razorpay_payment_id,)).fetchone()
            if not existing:
                c.execute(
                    "INSERT INTO payments (company_id, customer_id, "
                    " amount, payment_mode, transaction_no, remarks, paid_at) "
                    "VALUES (?,?,?,?,?,?,?)",
                    (cid, cust["customer_id"], paid, "Razorpay",
                     body.razorpay_payment_id,
                     f"Plan upgrade to {plan['plan_name']} (order {body.razorpay_order_id})",
                     now))
        except Exception:
            pass
        c.commit()
    return {"ok": True,
            "amount_paid": paid,
            "new_plan": plan["plan_name"],
            "new_end_date": new_end,
            "message": f"Payment received! Your plan has been upgraded to {plan['plan_name']}."}
# === end _v4724_  Plan upgrade with online payment ===


# ============================================================================
#  _v4727_  Operator action — Approve a customer plan-upgrade ticket
# ============================================================================
@app.post("/api/mobile/v1/internal/tickets/{tid}/approve-upgrade")
def approve_upgrade_v4727(tid: int,
                          authorization: Optional[str] = Header(None)):
    """_v4727_  Called by admin/sub_lco/employee tapping 'Approve Upgrade' on
    a Plan-Upgrade ticket. Looks up the target plan from the ticket subject
    ('Plan upgrade request: <plan_name>'), swaps the customer's plan, records
    a 'plan upgrade' payment row for the plan's full amount, marks ticket
    Resolved with a comment."""
    s = _require_auth(authorization)
    role = (s.get("user_type") or "").lower()
    if role not in ("admin", "sub_lco", "employee"):
        raise HTTPException(403, "operator_only")
    cid = s.get("company_id") or ""
    with _conn() as c:
        t = c.execute(
            "SELECT id, customer_id, ticket_no, subject, complaint_type, status "
            "  FROM complaints WHERE id=? AND company_id=?",
            (tid, cid)).fetchone()
        if not t:
            raise HTTPException(404, "ticket_not_found")
        if (t["complaint_type"] or "").lower() != "plan upgrade":
            raise HTTPException(400, "not_an_upgrade_ticket")
        if (t["status"] or "").lower() == "resolved":
            raise HTTPException(400, "already_resolved")
        # Parse plan name from subject
        subject = t["subject"] or ""
        plan_name = ""
        if ":" in subject:
            plan_name = subject.split(":", 1)[1].strip()
        if not plan_name:
            raise HTTPException(400, "plan_name_missing")
        plan = c.execute(
            "SELECT id, plan_name, after_tax_amount, validity, validity_unit "
            "  FROM plans WHERE plan_name=? "
            " ORDER BY id DESC LIMIT 1",
            (plan_name,)).fetchone()
        if not plan:
            raise HTTPException(404, "target_plan_not_found")
        cust = c.execute(
            "SELECT id, customer_id, plan_id FROM customers "
            " WHERE company_id=? AND customer_id=? LIMIT 1",
            (cid, t["customer_id"])).fetchone()
        if not cust:
            raise HTTPException(404, "customer_not_found")
        amount = float(plan["after_tax_amount"] or 0)
        validity = int(plan["validity"] or 30)
        unit = (plan["validity_unit"] or "Days").lower()
        if unit.startswith("month"): days = validity * 30
        elif unit.startswith("year"): days = validity * 365
        elif unit.startswith("week"): days = validity * 7
        else: days = validity
        from datetime import date, timedelta
        today = date.today()
        new_end = (today + timedelta(days=days)).isoformat()
        new_start = today.isoformat()
        now = datetime.now(ZoneInfo("Asia/Kolkata")).strftime("%Y-%m-%d %H:%M:%S")
        # Swap plan
        c.execute(
            "UPDATE customers SET plan_id=?, monthly_amount=?, "
            " start_date=?, end_date=?, status='Active', updated_at=? "
            "WHERE id=? AND company_id=?",
            (plan["id"], amount, new_start, new_end, now, cust["id"], cid))
        # Record a plan-migration payment so the upgrade is fully traceable
        try:
            import secrets as _sec
            txn = f"UPG{_sec.token_hex(4).upper()}"
            c.execute(
                "INSERT INTO payments (company_id, customer_id, amount, "
                " payment_mode, transaction_no, remarks, paid_at) "
                "VALUES (?,?,?,?,?,?,?)",
                (cid, cust["customer_id"], amount, "Plan Upgrade", txn,
                 f"Plan upgrade approved by {role} (ticket {t['ticket_no']})",
                 now))
        except Exception:
            pass
        # Resolve ticket + log comment
        try:
            c.execute(
                "UPDATE complaints SET status='Resolved', updated_at=?, "
                " resolved_by=?, resolved_at=? WHERE id=?",
                (now, s.get("user_pk") or "", now, tid))
        except Exception:
            c.execute(
                "UPDATE complaints SET status='Resolved', updated_at=? WHERE id=?",
                (now, tid))
        try:
            c.execute(
                "INSERT INTO complaint_comments (complaint_id, author_id, "
                " author_name, body, created_at) VALUES (?,?,?,?,?)",
                (tid, s.get("user_pk") or "",
                 (s.get("username") or role),
                 f"Plan upgrade approved. Customer migrated to '{plan['plan_name']}' "
                 f"valid till {new_end}.", now))
        except Exception: pass
        c.commit()
    return {"ok": True, "new_plan": plan["plan_name"],
            "new_end_date": new_end, "amount": amount,
            "message": f"Customer migrated to {plan['plan_name']}, valid till {new_end}."}
# === end _v4727_ approve-upgrade ===


# ---------------- NAS Status (mobile) ----------------
# _MOBILE_NAS_LIST_V1_
@app.get("/api/mobile/v1/nas/list")
def nas_list(authorization: Optional[str] = Header(None)):
    """List NAS devices for the caller's tenant with live counts +
    live MikroTik health (uptime / CPU load / memory %)."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    items = []
    try:
        with _conn() as c:
            rows = c.execute(
                "SELECT id, name, ip_address, type, status, "
                "       IFNULL(last_status,'unknown') AS last_status, "
                "       IFNULL(last_status_msg,'')    AS last_status_msg, "
                "       updated_at, "
                "       IFNULL(api_username,'admin')  AS api_username, "
                "       IFNULL(api_password,'')       AS api_password, "
                "       IFNULL(port,8728)             AS api_port, "
                "       IFNULL(use_tls,0)             AS use_tls "
                "  FROM nas_devices "
                " WHERE company_id=? "
                " ORDER BY id ASC",
                (cid,)
            ).fetchall()
            nas_rows = [dict(r) for r in rows]
        # s40n: fan out health-fetch in parallel — most tenants have 1–2 NAS
        # but a few have 4-5, so do this concurrently with a short timeout
        # to keep the mobile screen snappy.
        health_by_id = {}
        if nas_rows:
            from concurrent.futures import ThreadPoolExecutor, as_completed
            with ThreadPoolExecutor(max_workers=min(8, len(nas_rows))) as ex:
                futs = {ex.submit(_mk_fetch_health, nr): nr["id"] for nr in nas_rows}
                for f in as_completed(futs, timeout=6.0):
                    try:
                        health_by_id[futs[f]] = f.result()
                    except Exception:
                        health_by_id[futs[f]] = None
        with _conn() as c:
            for r in nas_rows:
                cnt = c.execute(
                    "SELECT COUNT(DISTINCT username) FROM online_users "
                    "  WHERE company_id=? AND nas_ip=? "
                    "    AND LOWER(IFNULL(status,''))='online'",
                    (cid, r["ip_address"])
                ).fetchone()[0] or 0
                ls = (r["last_status"] or "unknown").lower()
                if ls in ("up", "active", "ok", "online"):
                    status_label = "Online"
                elif ls in ("down", "offline", "unreachable", "error", "timeout"):
                    status_label = "Offline"
                else:
                    status_label = (r["last_status"] or "Unknown").title()
                h = health_by_id.get(r["id"]) or {}
                # If MikroTik health came back, override status with reality:
                # 'Online' when we successfully talked to it.
                if h:
                    status_label = "Online"
                items.append({
                    "id": r["id"],
                    "name": r["name"] or f"NAS #{r['id']}",
                    "host": r["ip_address"],
                    "ip":   r["ip_address"],
                    "status": status_label,
                    "uptime": h.get("uptime"),
                    "cpu_load": h.get("cpu_load"),
                    "memory_pct": h.get("memory_pct"),
                    "memory_used_mb": h.get("memory_used_mb"),
                    "memory_total_mb": h.get("memory_total_mb"),
                    "board_name": h.get("board"),
                    "version": h.get("version"),
                    "active_users": int(cnt),
                    "last_msg": r["last_status_msg"] or "",
                    "updated_at": r["updated_at"] or "",
                })
    except Exception as e:
        return {"ok": False, "items": [], "error": str(e)}
    return {"ok": True, "items": items}


# s40n: lightweight MikroTik health probe — pulls /system/resource via
# librouteros directly so we don't drag in the heavy admin-portal modules.
# 2-second connect timeout keeps the mobile NAS list snappy when a router
# is offline.
def _mk_fetch_health(nas_row: dict) -> Optional[dict]:
    try:
        import librouteros
    except Exception:
        return None
    host = (nas_row.get("ip_address") or "").strip()
    if not host:
        return None
    port = int(nas_row.get("api_port") or 8728)
    user = (nas_row.get("api_username") or "admin") or "admin"
    pw   = nas_row.get("api_password") or ""
    use_tls = bool(nas_row.get("use_tls"))
    try:
        kwargs = dict(host=host, username=user, password=pw,
                       port=port, timeout=2.5)
        if use_tls:
            import ssl
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            kwargs["ssl_wrapper"] = lambda s: ctx.wrap_socket(s, server_hostname=host)
        conn = librouteros.connect(**kwargs)
        try:
            res = list(conn.path("/system/resource"))
        finally:
            try: conn.close()
            except Exception: pass
        if not res:
            return None
        r = res[0]
        free  = int(r.get("free-memory", 0) or 0)
        total = int(r.get("total-memory", 0) or 0)
        used  = max(0, total - free)
        mem_pct = round((used / total) * 100.0, 1) if total else None
        cpu_freq = r.get("cpu-frequency")
        # _S58AK_HEALTH_  Also try /system/health for temperature (CCR /
        # CRS / hAP models that expose hardware sensors). Best-effort.
        temp_c = cpu_temp_c = None
        try:
            health = list(conn.path("/system/health")) if conn else []
            if health:
                h = health[0]
                # MikroTik exposes either flat keys or .id rows ({name, value, type})
                if "temperature" in h:
                    try: temp_c = float(h.get("temperature"))
                    except Exception: pass
                if "cpu-temperature" in h:
                    try: cpu_temp_c = float(h.get("cpu-temperature"))
                    except Exception: pass
                # Fallback: iterate name/value rows.
                if temp_c is None and cpu_temp_c is None:
                    for hr in health:
                        nm = (hr.get("name") or "").lower()
                        val = hr.get("value")
                        try: f = float(val) if val not in (None, "") else None
                        except Exception: f = None
                        if f is None: continue
                        if nm == "temperature": temp_c = f
                        elif nm == "cpu-temperature": cpu_temp_c = f
        except Exception:
            pass
        return {
            "uptime":   r.get("uptime", ""),
            "cpu_load": f"{int(r.get('cpu-load', 0) or 0)}%",
            "cpu_frequency_mhz": int(cpu_freq) if cpu_freq else None,
            "cpu_count": int(r.get("cpu-count") or 0) or None,
            "temperature_c": temp_c,
            "cpu_temperature_c": cpu_temp_c,
            "memory_pct": mem_pct,
            "memory_used_mb":  round(used / 1024 / 1024, 1) if used else 0,
            "memory_total_mb": round(total / 1024 / 1024, 1) if total else 0,
            "board":   r.get("board-name", "") or "",
            "version": r.get("version", "") or "",
        }
    except Exception:
        return None


# s40n: WAN snapshot for the mobile live graph. Returns the same shape
# as the web portal's /api/admin/wan-speed/snapshot — rx_bytes / tx_bytes
# from the auto-detected default-route interface — so the mobile chart
# can compute Mbps client-side. Cached iface per NAS for 5 minutes.
_MK_WAN_CACHE: dict = {}

@app.get("/api/mobile/v1/nas/{nas_id}/wan-snapshot")
def nas_wan_snapshot(nas_id: int, authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    try:
        with _conn() as c:
            row = c.execute(
                "SELECT id, name, ip_address, "
                "       IFNULL(api_username,'admin')  AS api_username, "
                "       IFNULL(api_password,'')       AS api_password, "
                "       IFNULL(port,8728)             AS api_port, "
                "       IFNULL(use_tls,0)             AS use_tls, "
                "       IFNULL(pinned_wan_iface,'')   AS pinned_wan_iface "
                "  FROM nas_devices "
                " WHERE id=? AND company_id=? LIMIT 1",
                (nas_id, cid)).fetchone()
        if not row:
            return JSONResponse({"ok": False, "message": "NAS not found"},
                                 status_code=404)
        nas = dict(row)
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"db_error: {e}"},
                             status_code=500)
    try:
        import librouteros, time as _t, re as _re
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"librouteros_missing: {e}"},
                             status_code=500)
    use_tls = bool(nas.get("use_tls"))
    kwargs = dict(host=nas["ip_address"],
                  username=nas.get("api_username") or "admin",
                  password=nas.get("api_password") or "",
                  port=int(nas.get("api_port") or 8728),
                  timeout=3.0)
    if use_tls:
        import ssl
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        kwargs["ssl_wrapper"] = lambda sk: ctx.wrap_socket(sk, server_hostname=nas["ip_address"])
    iface = (nas.get("pinned_wan_iface") or "").strip()
    pinned = bool(iface)
    # 5-min iface cache for auto-detect
    cache = _MK_WAN_CACHE.get(nas_id) or {}
    import time as _t
    if not iface:
        iface = cache.get("iface")
        if not iface or (_t.time() - cache.get("ts", 0)) > 300:
            iface = None  # force refresh
    try:
        conn = librouteros.connect(**kwargs)
    except Exception as e:
        return JSONResponse({"ok": False, "message": f"router_unreachable: {e}"},
                             status_code=502)
    try:
        # Auto-detect via default route if not pinned/cached.
        if not iface:
            try:
                routes = list(conn.path("ip/route"))
            except Exception:
                routes = []
            for rt in routes:
                if (rt.get("dst-address") or "") == "0.0.0.0/0":
                    gw = rt.get("gateway") or ""
                    if gw and "%" in gw:
                        _, iface_cand = gw.split("%", 1)
                        iface = iface_cand.strip()
                        break
            if not iface and routes:
                # Try gateway-IP → /ip/address subnet match.
                import ipaddress as _ip
                gw = None
                for rt in routes:
                    if (rt.get("dst-address") or "") == "0.0.0.0/0":
                        gw = rt.get("gateway") or ""
                        break
                if gw:
                    try:
                        gw_ip = _ip.ip_address(gw.split("%")[0])
                        for a in conn.path("ip/address"):
                            addr = a.get("address") or ""
                            if "/" in addr:
                                try:
                                    net = _ip.ip_network(addr, strict=False)
                                    if gw_ip in net:
                                        iface = a.get("interface")
                                        break
                                except Exception:
                                    continue
                    except Exception:
                        pass
            if iface:
                _MK_WAN_CACHE[nas_id] = {"iface": iface, "ts": _t.time()}
        if not iface:
            return JSONResponse({"ok": False, "message": "wan_iface_undetected"},
                                 status_code=502)
        rx_bytes = tx_bytes = None
        for r in conn.path("interface"):
            if (r.get("name") or "") == iface:
                rx_bytes = int(r.get("rx-byte") or 0)
                tx_bytes = int(r.get("tx-byte") or 0)
                break
        if rx_bytes is None:
            return JSONResponse({"ok": False, "message": f"iface_{iface}_not_found"},
                                 status_code=502)
        return {
            "ok": True,
            "nas": {"id": nas["id"], "name": nas["name"], "ip": nas["ip_address"]},
            "iface": iface,
            "pinned": pinned,
            "rx_bytes": rx_bytes,
            "tx_bytes": tx_bytes,
            "ts": _t.time(),
        }
    finally:
        try: conn.close()
        except Exception: pass



# ╔════════════════════════════════════════════════════════════════════╗
# ║  _S58AI_MOBILE_ENDPOINTS_  — added 2026-06-07                      ║
# ║  Fills gaps used by v4.7.x screens (OLT, ONU, online users,        ║
# ║  complaint assign, transaction receipt-share).                     ║
# ╚════════════════════════════════════════════════════════════════════╝

# ───────── Online Users (mobile aliases /subscribers/online) ─────────
@app.get("/api/mobile/v1/online-users")
def s58ai_online_users(authorization: Optional[str] = Header(None),
                       limit: int = 200,
                       q: Optional[str] = None):
    """_S58AT_  Returns LIVE online customers for the caller's tenant.

    Key behaviours:
      • Filters out stale online_users rows whose updated_at is older
        than 30 min, so the count matches the web portal's NOC counter.
      • Aliases customer pk → `id` so /online/{id} navigates correctly.
      • Sets is_online = True on every row (this endpoint only ever
        returns online users) so the mobile UI doesn't paint them red.
    """
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    items = []
    with _conn() as c:
        rows = c.execute(
            "SELECT ou.username, ou.ip_address, ou.mac_address, "
            "       ou.nas_ip, ou.uptime_seconds, ou.bytes_in, "
            "       ou.bytes_out, ou.started_at, ou.updated_at, "
            "       ou.status, "
            "       c.id AS cust_pk, c.customer_id, c.customer_name, "
            "       c.customer_phone AS mobile_no, c.address, c.locality, "
            "       p.plan_name, p.speed "
            "  FROM online_users ou "
            "  JOIN customers c "
            "         ON c.username = ou.username AND c.company_id = ou.company_id "
            "  LEFT JOIN plans p ON p.id = c.plan_id "
            " WHERE ou.company_id = ? "
            # _S58AT_  Match web-portal dashboard count exactly:
            #  • include online + walledgarden + parked
            #  • exclude orphans (JOIN, not LEFT JOIN — done above)
            #  • exclude expired / disabled / terminated customers
            "   AND LOWER(COALESCE(ou.status,'')) IN ('online','walledgarden','parked') "
            "   AND COALESCE(c.status,'') NOT IN ("
            "       'Expired','expired','Disabled','disabled',"
            "       'Deactivated','deactivated','Suspended','suspended',"
            "       'Parked','parked','Cancelled','cancelled',"
            "       'Canceled','canceled','Terminated','terminated',"
            "       'Deleted','deleted') "
            " ORDER BY ou.updated_at DESC "
            " LIMIT ?", (cid, int(limit))).fetchall()
        for r in rows:
            d = dict(r)
            if q and q.strip():
                blob = " ".join(str(d.get(k) or "") for k in
                                ("username","customer_name","customer_id",
                                 "mobile_no","ip_address","mac_address")).lower()
                if q.strip().lower() not in blob:
                    continue
            # _S58AT_  status flags + navigation id alias
            d["id"]         = d.get("cust_pk")            # for /online/{id}
            d["online"]     = True
            d["is_online"]  = True
            d["online_state"] = ("walledgarden"
                                  if (d.get("status") or "").lower() == "walledgarden"
                                  else "online")
            items.append(d)
    return {"ok": True, "count": len(items), "items": items}


# ───────────────────────── OLT list ─────────────────────────
@app.get("/api/mobile/v1/olts")
def s58ai_olts(authorization: Optional[str] = Header(None)):
    """_S58AI_  Return all OLTs for caller's tenant for the mobile OLT
    picker (`app/olt/index.tsx`). Includes live counters so each entry
    can show its online/total ONUs in the dropdown."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    items = []
    with _conn() as c:
        rows = c.execute(
            "SELECT id, name, vendor, model, host, location, status, "
            "       total_onus, online_onus "
            "  FROM olts WHERE company_id=? AND COALESCE(enabled,1)<>0 "
            " ORDER BY id ASC", (cid,)).fetchall()
        for r in rows:
            d = dict(r); d["ip"] = d.get("host") or ""
            items.append(d)
    return {"ok": True, "items": items, "count": len(items)}


# ───────────────────────── OLT detail ─────────────────────────
@app.get("/api/mobile/v1/olts/{olt_id}")
def s58ai_olt_detail(olt_id: int,
                     authorization: Optional[str] = Header(None)):
    """_S58AI_  OLT health + alerts + uplink/PON summary for the mobile
    OLT detail card. Returns the same shape the mobile screen expects:
    health, uptime, cpu_load, temperature, total_onus, online_onus,
    network_type, alerts[], uplinks[], pon_ports[]."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    with _conn() as c:
        r = c.execute(
            "SELECT * FROM olts WHERE id=? AND company_id=? LIMIT 1",
            (olt_id, cid)).fetchone()
        if not r:
            raise HTTPException(404, "not_found")
        d = dict(r)
        # alerts (last 20)
        alerts = []
        try:
            ars = c.execute(
                "SELECT alert_type, severity, message, created_at "
                "  FROM olt_alerts WHERE olt_id=? AND company_id=? "
                " ORDER BY id DESC LIMIT 20", (olt_id, cid)).fetchall()
            alerts = [dict(x) for x in ars]
        except Exception:
            pass
        # ONU counts (authoritative — fall back to stored values)
        tot = c.execute("SELECT COUNT(*) FROM onus WHERE olt_id=? AND company_id=?",
                        (olt_id, cid)).fetchone()[0] or 0
        onl = c.execute("SELECT COUNT(*) FROM onus WHERE olt_id=? AND company_id=? "
                        "  AND LOWER(COALESCE(status,''))='online'",
                        (olt_id, cid)).fetchone()[0] or 0
        # pon_ports — bucket ONUs by pon_port_index
        ports = []
        try:
            pr = c.execute(
                "SELECT pon_port_index, COUNT(*) AS total, "
                "       SUM(CASE WHEN LOWER(COALESCE(status,''))='online' THEN 1 ELSE 0 END) AS online, "
                "       AVG(NULLIF(rx_power,0)) AS avg_rx, "
                "       MIN(NULLIF(rx_power,0)) AS min_rx, "
                "       MAX(NULLIF(rx_power,0)) AS max_rx, "
                "       AVG(NULLIF(tx_power,0)) AS avg_tx "
                "  FROM onus WHERE olt_id=? AND company_id=? "
                " GROUP BY pon_port_index ORDER BY pon_port_index",
                (olt_id, cid)).fetchall()
            for x in pr:
                xd = dict(x)
                idx  = xd.get("pon_port_index")
                tot  = int(xd.get("total") or 0)
                onl  = int(xd.get("online") or 0)
                _rx  = lambda v: (round(float(v), 2) if v is not None else None)
                ports.append({
                    "index":       idx,                 # _S58AU_ generic key
                    "port_index":  idx,                 # alias the FE reads
                    "port_id":     f"GPON 0/{idx}" if idx is not None else "GPON",
                    "label":       f"PON{idx}",
                    "total_onus":  tot,
                    "online_onus": onl,
                    "offline_onus": max(0, tot - onl),
                    "load":        tot,                 # FE shows "{load} ONUs"
                    "admin_status":"up",
                    "admin_up":    True,
                    "status":      "Online" if onl > 0 else ("Offline" if tot > 0 else "Unused"),
                    "avg_rx_dbm":  _rx(xd.get("avg_rx")),
                    "min_rx_dbm":  _rx(xd.get("min_rx")),
                    "max_rx_dbm":  _rx(xd.get("max_rx")),
                    "tx_power":    _rx(xd.get("avg_tx")),
                })
        except Exception:
            pass
    # Health label derived from status field
    status = (d.get("status") or "").lower()
    if status in ("up","ok","online","healthy"):
        health = "Healthy"
    elif status in ("down","offline","error"):
        health = "Down"
    elif status == "warning":
        health = "Warning"
    else:
        health = "Unknown"
    uptime_sec = int(d.get("uptime_sec") or 0)
    if uptime_sec:
        days = uptime_sec // 86400; rest = uptime_sec % 86400
        hh = rest // 3600; mm = (rest % 3600) // 60
        uptime_str = (f"{days}d " if days else "") + f"{hh}h {mm}m"
    else:
        uptime_str = ""
    cpu = d.get("cpu_pct") or 0
    # _S58AU_  Map raw status → Online/Offline/Down (was a 4-tone Health chip).
    raw_status = (d.get("status") or "").strip().lower()
    if raw_status in ("up", "ok", "online", "healthy", "active"):
        status_label = "Online"; is_online = True
    elif raw_status in ("warning", "degraded"):
        status_label = "Online"; is_online = True
    elif raw_status in ("down", "offline", "error", "fail", "dead"):
        status_label = "Offline"; is_online = False
    else:
        # Default — if at least one ONU is online, consider OLT up.
        is_online = (int(onl) > 0)
        status_label = "Online" if is_online else "Offline"
    return {
        "ok": True,
        "id": d["id"], "name": d.get("name"), "host": d.get("host"),
        "ip": d.get("host"), "vendor": d.get("vendor"),
        "model": d.get("model"), "location": d.get("location"),
        "status": d.get("status"),
        "status_label": status_label,    # _S58AU_  "Online" / "Offline"
        "online":       is_online,
        "is_online":    is_online,
        "health": health,
        "uptime": uptime_str,
        "cpu_load": f"{int(cpu)}%" if cpu else "—",
        "temperature": (f"{int(d.get('temp_c') or 0)}°C"
                        if d.get("temp_c") else "—"),
        "memory_pct": d.get("mem_pct") or 0,
        "total_onus": int(tot),
        "online_onus": int(onl),
        "network_type": (d.get("vendor") or "GPON").upper(),
        "alerts": alerts,
        "uplinks": [],   # Future: parse from olt_polls
        "pon_ports": ports,
    }


# ───────────────────────── OLT → ONU list ─────────────────────────
@app.get("/api/mobile/v1/olts/{olt_id}/onus")
def s58ai_olt_onus(olt_id: int,
                   authorization: Optional[str] = Header(None),
                   q: Optional[str] = None,
                   pon_port: Optional[int] = None,   # _S58AU_  filter
                   limit: int = 500):
    """_S58AI_  ONUs of an OLT, tenant-scoped.

    _S58AU_  Adds an optional ?pon_port=N filter so the mobile screen
    can render a "PON 0/N → ONU list" drill-down. Also emits friendlier
    field aliases (sn, port, rx_dbm) that the existing UI reads.
    """
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    items = []
    with _conn() as c:
        sql_where = " WHERE o.olt_id=? AND o.company_id=?"
        params = [olt_id, cid]
        if pon_port is not None:
            sql_where += " AND o.pon_port_index=?"
            params.append(int(pon_port))
        rows = c.execute(
            "SELECT o.id, o.serial, o.mac, o.name, o.status, "
            "       o.rx_power, o.tx_power, o.distance_m, o.uptime_sec, "
            "       o.last_seen, o.wifi_ssid, o.wan_ip, o.wan_status, "
            "       o.pon_port_index, o.onu_index, o.vendor, o.model, "
            "       o.customer_id, "
            "       c.id AS cust_pk, c.customer_name, c.username AS cust_username, "
            "       c.customer_phone AS mobile "
            "  FROM onus o "
            "  JOIN customers c ON c.customer_id = o.customer_id "
            "                       AND c.company_id  = o.company_id "
            + sql_where +
            " ORDER BY o.pon_port_index ASC, o.onu_index ASC "
            " LIMIT ?", params + [int(limit)]).fetchall()
        for r in rows:
            d = dict(r)
            if q and q.strip():
                blob = " ".join(str(d.get(k) or "") for k in
                                ("serial","mac","name","customer_name",
                                 "cust_username","wifi_ssid","wan_ip","mobile")).lower()
                if q.strip().lower() not in blob:
                    continue
            # _S58AU_  Aliases the FE reads.
            d["sn"]      = d.get("serial") or ""
            d["port"]    = f"GPON 0/{d.get('pon_port_index')}:{d.get('onu_index')}"                             if d.get("pon_port_index") is not None else ""
            d["port_id"] = d.get("pon_port_index")
            d["rx_dbm"]  = (round(float(d["rx_power"]), 2)
                            if d.get("rx_power") not in (None, 0) else None)
            d["distance"] = (f"{int(d['distance_m'])}m"
                             if d.get("distance_m") else None)
            items.append(d)
    return {"ok": True, "items": items, "count": len(items)}


# ───────────────────────── ONU detail / remote-config ─────────────────────────
@app.get("/api/mobile/v1/onus/{onu_id}/remote-config")
def s58ai_onu_remote_config(onu_id: int,
                            authorization: Optional[str] = Header(None)):
    """_S58AI_  Full ONU detail for the mobile remote-config screen.
    Returns a single flat dict — fields match what `app/olt/onu/[id].tsx`
    reads: optical_power, link_status, wan_ip, wan_status, location, plus
    WiFi (ssid/password 2.4 + 5), WAN credentials, last_seen, distance, etc."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    with _conn() as c:
        r = c.execute(
            "SELECT * FROM onus WHERE id=? AND company_id=? LIMIT 1",
            (onu_id, cid)).fetchone()
        if not r:
            raise HTTPException(404, "not_found")
        d = dict(r)
        cust = None
        if d.get("customer_id"):
            cr = c.execute(
                "SELECT id, customer_id, customer_name, username, "
                "       customer_phone AS mobile_no, address, locality "
                "  FROM customers WHERE customer_id=? AND company_id=? LIMIT 1",
                (d["customer_id"], cid)).fetchone()
            if cr: cust = dict(cr)
    # Recent throughput from samples (latest interval delta)
    cur_down = cur_up = None
    try:
        with _conn() as c2:
            sm = c2.execute(
                "SELECT bytes_in_delta, bytes_out_delta, interval_sec "
                "  FROM onu_traffic_samples "
                " WHERE onu_id=? AND company_id=? "
                " ORDER BY id DESC LIMIT 1", (onu_id, cid)).fetchone()
            if sm:
                sm = dict(sm); iv = int(sm.get("interval_sec") or 0) or 1
                cur_down = round(((sm.get("bytes_in_delta") or 0) * 8.0
                                  / iv) / 1_000_000, 2)
                cur_up   = round(((sm.get("bytes_out_delta") or 0) * 8.0
                                  / iv) / 1_000_000, 2)
    except Exception:
        pass
    rxp = d.get("rx_power")
    txp = d.get("tx_power")
    link_status = "UP" if (d.get("status") or "").lower() == "online" else "DOWN"
    out = {
        "ok": True,
        "id": d["id"],
        "serial": d.get("serial"),
        "mac": d.get("mac"),
        "name": d.get("name"),
        "vendor": d.get("vendor"),
        "model": d.get("model"),
        "status": d.get("status"),
        "link_status": link_status,
        "optical_power": (f"{float(rxp):.2f}" if rxp not in (None, "") else None),
        "rx_power": rxp,
        "tx_power": txp,
        "distance_m": d.get("distance_m"),
        "uptime_sec": d.get("uptime_sec"),
        "last_seen": d.get("last_seen"),
        "last_offline": d.get("last_offline"),
        "offline_reason": d.get("offline_reason"),
        "wan_ip": d.get("wan_ip"),
        "wan_status": d.get("wan_status"),
        "wan_mode": d.get("wan_mode"),
        "wan_username": d.get("wan_username"),
        "wan_password": d.get("wan_password"),
        "wan_vlan": d.get("wan_vlan"),
        "wifi_ssid": d.get("wifi_ssid"),
        "wifi_password": d.get("wifi_password"),
        "wifi_ssid_5g": d.get("wifi_ssid_5g"),
        "wifi_password_5g": d.get("wifi_password_5g"),
        "wifi_band_split": bool(d.get("wifi_band_split")),
        "cur_down_mbps": cur_down,
        "cur_up_mbps": cur_up,
        "customer": cust,
        "location": ({"lat": d.get("lat"), "lng": d.get("lng"),
                      "source": d.get("location_source") or "manual"}
                     if d.get("lat") and d.get("lng") else None),
    }
    # _S58AV_  Surface live health-vitals so the mobile detail screen
    # can render Temperature / CPU / RAM / Uptime / Power / Health chips.
    out["temperature"]  = d.get("temperature")
    out["temperature_c"]= d.get("temperature")
    out["cpu_pct"]      = d.get("cpu_pct") or d.get("cpu_load")
    out["cpu_load"]     = d.get("cpu_pct") or d.get("cpu_load")
    out["mem_pct"]      = d.get("mem_pct") or d.get("ram_usage")
    out["ram_pct"]      = d.get("mem_pct") or d.get("ram_usage")
    out["uptime_sec"]   = d.get("uptime_sec")
    def _fmt_up(s):
        try:
            s = int(s or 0)
            if s <= 0: return None
            days, s = divmod(s, 86400); hrs, s = divmod(s, 3600); mins, _ = divmod(s, 60)
            if days: return f"{days}d {hrs}h {mins}m"
            if hrs:  return f"{hrs}h {mins}m"
            return f"{mins}m"
        except Exception: return None
    out["uptime"]       = _fmt_up(d.get("uptime_sec"))
    out["last_seen"]    = d.get("last_seen")
    raw_st = (d.get("status") or "").strip().lower()
    out["online"]       = raw_st in ("online", "up", "ok", "active")
    out["is_online"]    = out["online"]
    out["power_status"] = ("Powered ON" if out["online"]
                           else ("Powered OFF / Unreachable"
                                 if raw_st in ("offline","down","los","dgmismatch")
                                 else "Unknown"))
    out["health"]       = ("Healthy" if out["online"]
                           else ("LOS" if raw_st == "los"
                                 else ("Down" if raw_st in ("offline","down","fail") else "Unknown")))
    out["ztp_enabled"]  = bool(d.get("ztp_enabled"))
    out["ztp_status"]   = d.get("ztp_status") or ("Provisioned" if d.get("wifi_ssid") else "Pending")
    out["pon_port_index"]= d.get("pon_port_index")
    out["onu_index"]    = d.get("onu_index")
    out["rx_power"]     = d.get("rx_power")
    out["tx_power"]     = d.get("tx_power")
    out["distance_m"]   = d.get("distance_m")
    return out


# ───────── Subscriber → linked ONU (for online users → ONU drill-down) ─────────
@app.get("/api/mobile/v1/subscribers/{cust_pk}/onu")
def s58ai_subscriber_onu(cust_pk: int,
                         authorization: Optional[str] = Header(None)):
    """_S58AI_  Return the ONU linked to a customer so the Online-Users
    detail page can show signal/throughput/last-login. Mobile UI uses
    `softReq('/subscribers/{id}/onu', ..., { ok: false })`."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    with _conn() as c:
        cu = c.execute(
            "SELECT customer_id FROM customers "
            " WHERE id=? AND company_id=? LIMIT 1",
            (cust_pk, cid)).fetchone()
        if not cu:
            raise HTTPException(404, "customer_not_found")
        custid = dict(cu).get("customer_id")
        if not custid:
            return {"ok": False, "reason": "no_customer_id"}
        r = c.execute(
            "SELECT id FROM onus WHERE customer_id=? AND company_id=? "
            " ORDER BY id ASC LIMIT 1",
            (custid, cid)).fetchone()
        if not r:
            return {"ok": False, "reason": "no_onu_linked"}
        onu_id = dict(r)["id"]
    # delegate to the rich endpoint above
    return s58ai_onu_remote_config(onu_id, authorization=authorization)


# ───────────────────────── Complaint assign ─────────────────────────
class _ComplaintAssignIn(BaseModel):
    assignee_type: str             # admin | sub_lco | employee
    assignee_id: str
    comment: Optional[str] = ""

@app.post("/api/mobile/v1/complaints/{cid_int}/assign")
def s58ai_complaint_assign(cid_int: int,
                           body: _ComplaintAssignIn,
                           authorization: Optional[str] = Header(None)):
    """_S58AI_  Assign a complaint to an admin / sub_lco / employee, with
    an optional comment. Writes assignment columns on `tickets` AND
    appends a comment to `ticket_comments` (idempotent if comment empty).
    Also fires the existing notification path so the assignee sees an
    in-app + push notification."""
    s = _require_auth(authorization)
    company_id = s.get("company_id") or ""
    at = (body.assignee_type or "").strip().lower()
    aid = (body.assignee_id or "").strip()
    if at not in ("admin","sub_lco","employee"):
        raise HTTPException(400, "invalid_assignee_type")
    if not aid:
        raise HTTPException(400, "assignee_id_required")
    with _conn() as c:
        t = c.execute(
            "SELECT id, ticket_no FROM complaints WHERE id=? AND company_id=? LIMIT 1",
            (cid_int, company_id)).fetchone()
        if not t:
            raise HTTPException(404, "ticket_not_found")
        ticket_no = dict(t).get("ticket_no") or str(cid_int)
        # _S58AI_FIX_  Match the real Postgres schema (assigned_to_kind /
        # assigned_to_id / assigned_to_name on the `complaints` table).
        tbl, col, name_col = {
            "admin":    ("admins",    "admin_id",      "admin_name"),
            "sub_lco":  ("sub_lcos",  "sub_lco_code",  "name"),
            "employee": ("employees", "employee_code", "employee_name"),
        }[at]
        ar = c.execute(
            f"SELECT id, {name_col} AS aname FROM {tbl} WHERE {col}=? AND company_id=? LIMIT 1",
            (aid, company_id)).fetchone()
        if not ar:
            raise HTTPException(404, "assignee_not_found_in_tenant")
        assignee_name = (dict(ar).get("aname") or aid) if hasattr(ar, "keys") else aid
        # Persist assignment.
        c.execute(
            "UPDATE complaints SET assigned_to_kind=?, assigned_to_id=?, "
            "       assigned_to_name=?, updated_at=NOW() "
            " WHERE id=? AND company_id=?",
            (at, aid, assignee_name, cid_int, company_id))
        # Comment row (best-effort)
        if (body.comment or "").strip():
            try:
                c.execute(
                    "INSERT INTO complaint_comments(complaint_id, company_id, "
                    "  author, text, created_at) "
                    "VALUES(?,?,?,?,?)",
                    (cid_int, company_id,
                     str(s.get("username") or s.get("user_id") or "admin"),
                     f"Assigned to {at} {assignee_name}. " +
                     body.comment.strip(),
                     datetime.now(timezone.utc).isoformat()))
            except Exception as _ce:
                # Don't fail the whole assign just because comment insert
                # has a minor schema variance.
                pass
        try:
            c.commit()
        except Exception:
            pass
    # Fire-and-forget notification
    try:
        _notify_assignee_async(company_id, at, aid, ticket_no, body.comment or "")
    except Exception:
        pass
    return {"ok": True, "ticket_no": ticket_no,
            "assigned_to_type": at, "assigned_to_id": aid}


def _notify_assignee_async(company_id, at, aid, ticket_no, comment):
    """Best-effort notification — schema-flexible; uses the canonical
    `notifications` columns: title, message, notification_type,
    related_entity_type, related_entity_id."""
    try:
        with _conn() as c:
            c.execute(
                "INSERT INTO notifications(title, message, notification_type, "
                "  related_entity_type, related_entity_id, is_read, created_at) "
                "VALUES(?,?,?,?,?,?,NOW())",
                (f"Ticket {ticket_no} assigned to you",
                 (comment or "")[:240], "complaint_assigned",
                 f"complaint:{at}:{aid}", str(ticket_no), 0))
            c.commit()
    except Exception:
        pass


# ───────────────────────── Transaction send-receipt ─────────────────────────
class _SendReceiptIn(BaseModel):
    channel: str                # email | sms | whatsapp
    to: Optional[str] = None    # optional override; defaults to customer.email/phone
    customer_type: Optional[str] = None   # 'Postpaid' | 'Prepaid' — UI passes this

@app.post("/api/mobile/v1/transactions/{txn_id}/send-receipt")
def s58ai_send_receipt(txn_id: int,
                       body: _SendReceiptIn,
                       authorization: Optional[str] = Header(None)):
    """_S58AI_  Send a transaction receipt via email / SMS / WhatsApp.
    Reuses the existing admin-portal helpers (`send_email`, `send_sms`)
    so the same SMTP/Twilio config the superadmin already wired up just
    works."""
    s = _require_auth(authorization)
    company_id = s.get("company_id") or ""
    channel = (body.channel or "").strip().lower()
    if channel not in ("email","sms","whatsapp"):
        raise HTTPException(400, "invalid_channel")
    with _conn() as c:
        r = c.execute(
            "SELECT p.id, p.customer_id, p.amount, "
            "       p.payment_mode AS payment_method, "
            "       p.transaction_no AS reference_no, "
            "       p.paid_at AS transaction_date, "
            "       c.customer_name, c.customer_email AS email, c.customer_phone AS mobile_no, "
            "       c.customer_type, c.start_date, c.end_date "
            "  FROM payments p "
            "  JOIN customers c ON c.customer_id = p.customer_id "
            "                       AND c.company_id  = p.company_id "
            " WHERE p.id=? AND p.company_id=? LIMIT 1",
            (txn_id, company_id)).fetchone()
        if not r:
            raise HTTPException(404, "transaction_not_found")
        d = dict(r)
    to_address = (body.to or "").strip() or (
        d.get("email") if channel == "email" else d.get("mobile_no"))
    if not to_address:
        raise HTTPException(400, f"no_destination_for_{channel}")
    # Build a minimal receipt body.
    # _S58AI_FIX_  For postpaid customers the receipt should show the
    # latest-invoice period (which equals the customer's current
    # start/end date in this schema); for prepaid it shows the same.
    # We just use the customer's current cycle dates — the mobile UI
    # passes `customer_type` so future expansion can branch per role.
    period = f"{d.get('start_date') or '-'} to {d.get('end_date') or '-'}"
    subj = f"Receipt for {d.get('customer_name') or 'Customer'} — ₹{d.get('amount') or 0}"
    msg = (f"Receipt #{d['id']}\n"
           f"Date: {d.get('transaction_date') or ''}\n"
           f"Customer: {d.get('customer_name') or ''}\n"
           f"Amount: ₹{d.get('amount') or 0}\n"
           f"Method: {d.get('payment_method') or '-'}\n"
           f"Reference: {d.get('reference_no') or '-'}\n"
           f"Period: {period}\n")
    sent_ok = False; err = ""
    if channel != "email":
        # SMS / WhatsApp gateways are not wired in the mobile-api yet;
        # keep the surface stable but return a clear, friendly error
        # instead of 500.
        raise HTTPException(400, f"{channel}_not_supported_yet")
    # ---------- Resolve tenant SMTP (mirrors admin-portal helper) ----------
    smtp_host = smtp_port = smtp_user = smtp_pass = None
    smtp_from_name = "Auto ISP Billing"
    try:
        with _conn() as c2:
            cr = c2.execute(
                "SELECT company_name, smtp_server, smtp_port, "
                "       smtp_username, smtp_password "
                "  FROM companies WHERE company_id=? LIMIT 1",
                (company_id,)).fetchone()
            if cr:
                crd = dict(cr)
                smtp_from_name = crd.get("company_name") or smtp_from_name
                smtp_host = crd.get("smtp_server") or None
                smtp_port = crd.get("smtp_port") or None
                smtp_user = crd.get("smtp_username") or None
                smtp_pass = crd.get("smtp_password") or None
            if not (smtp_host and smtp_user and smtp_pass):
                # Fall back to superadmin SMTP
                sa = c2.execute(
                    "SELECT smtp_server, smtp_port, smtp_username, smtp_password "
                    "  FROM superadmins "
                    " WHERE smtp_server IS NOT NULL AND smtp_server != '' "
                    "   AND smtp_username IS NOT NULL AND smtp_password IS NOT NULL "
                    " LIMIT 1").fetchone()
                if sa:
                    sad = dict(sa)
                    smtp_host = smtp_host or sad.get("smtp_server")
                    smtp_port = smtp_port or sad.get("smtp_port") or 587
                    smtp_user = smtp_user or sad.get("smtp_username")
                    smtp_pass = smtp_pass or sad.get("smtp_password")
    except Exception as _e_cfg:
        err = f"smtp_config_lookup_failed: {_e_cfg!r}"
    if not (smtp_host and smtp_user and smtp_pass):
        raise HTTPException(500, f"smtp_not_configured: {err}")
    port_int = int(smtp_port or 587)
    try:
        import smtplib, ssl
        from email.message import EmailMessage
        from email.utils import formataddr
        em = EmailMessage()
        em["Subject"] = subj
        em["From"] = formataddr((smtp_from_name + " - Billing", smtp_user))
        em["To"] = to_address
        em.set_content(msg)
        ctx = ssl.create_default_context()
        if port_int == 465:
            with smtplib.SMTP_SSL(smtp_host, port_int, context=ctx, timeout=20) as smtp:
                smtp.login(smtp_user, smtp_pass)
                smtp.send_message(em)
        else:
            with smtplib.SMTP(smtp_host, port_int, timeout=20) as smtp:
                smtp.ehlo()
                try: smtp.starttls(context=ctx); smtp.ehlo()
                except Exception: pass
                smtp.login(smtp_user, smtp_pass)
                smtp.send_message(em)
        sent_ok = True
    except Exception as _e:
        err = f"smtp_send_failed: {_e!r}"
    if not sent_ok:
        raise HTTPException(500, f"send_failed: {err or 'unknown'}")
    return {"ok": True, "channel": channel, "to": to_address}

# ╚════════════════════════════════════════════════════════════════════╝
# _S58AI_END_


# ───────── _S58AI_2_ Complaint detail + update + list-alias ─────────
@app.get("/api/mobile/v1/complaints-list")
def s58ai2_complaints_list_alias(authorization: Optional[str] = Header(None),
                                 limit: int = 200,
                                 status: Optional[str] = None):
    """Alias of /complaints so the mobile `complaintsList()` helper
    (which calls /complaints-list) returns the same shape."""
    # Reuse the existing /complaints handler via direct call
    return list_complaints(authorization=authorization,
                           limit=limit, status=status)  # type: ignore[name-defined]


@app.get("/api/mobile/v1/complaints/{cid_int}")
def s58ai2_complaint_detail(cid_int: int,
                            authorization: Optional[str] = Header(None)):
    """Full complaint detail including comments thread for the mobile
    detail screen (`app/complaints/[id].tsx`)."""
    s = _require_auth(authorization)
    company_id = s.get("company_id") or ""
    with _conn() as c:
        r = c.execute(
            "SELECT cm.*, "
            "       c.customer_name, c.username, c.address, c.locality, "
            "       c.customer_phone AS mobile_no, "
            "       c.customer_email AS email "
            "  FROM complaints cm "
            "  JOIN customers c ON c.customer_id = cm.customer_id "
            "                       AND c.company_id  = cm.company_id "
            " WHERE cm.id=? AND cm.company_id=? LIMIT 1",
            (cid_int, company_id)).fetchone()
        if not r:
            raise HTTPException(404, "complaint_not_found")
        d = dict(r)
        # Comments thread
        cmts = c.execute(
            "SELECT id, author, text, created_at "
            "  FROM complaint_comments "
            " WHERE complaint_id=? AND company_id=? "
            " ORDER BY id ASC", (cid_int, company_id)).fetchall()
        d["comments"] = [dict(x) for x in cmts]
        # Human-readable assigned_to (for the legacy mobile field)
        atk = d.get("assigned_to_kind") or ""
        atn = d.get("assigned_to_name") or ""
        if atk and atn:
            d["assigned_to"] = f"{atk.title()}: {atn}"
        elif atn:
            d["assigned_to"] = atn
        # _S58AI_2_  Build the assignable list for the mobile modal.
        assignable: list = []
        try:
            for tbl, col, name_col, role in [
                ("admins",    "admin_id",      "admin_name",    "admin"),
                ("sub_lcos",  "sub_lco_code",  "name",          "sub_lco"),
                ("employees", "employee_code", "employee_name", "employee"),
            ]:
                rows = c.execute(
                    f"SELECT {col} AS code, {name_col} AS name "
                    f"  FROM {tbl} WHERE company_id=? ORDER BY id ASC",
                    (company_id,)).fetchall()
                for x in rows:
                    xd = dict(x)
                    assignable.append({
                        "role": role,
                        "code": xd.get("code") or "",
                        "name": xd.get("name") or xd.get("code") or "",
                    })
        except Exception:
            pass
        d["assignable"] = assignable
    return {"ok": True, **d}


class _ComplaintUpdateIn(BaseModel):
    status: Optional[str] = None
    comment: Optional[str] = ""
    # Assign sub-fields — when assigned_to is supplied alone we ALSO
    # accept it as "Kind:Name" / Kind:ID parsed string for backwards-compat
    assigned_to: Optional[str] = None
    assignee_type: Optional[str] = None
    assignee_id: Optional[str] = None

@app.post("/api/mobile/v1/complaints/{cid_int}/update")
def s58ai2_complaint_update(cid_int: int,
                            body: _ComplaintUpdateIn,
                            authorization: Optional[str] = Header(None)):
    """Status change / comment-add / assign — one endpoint to match the
    mobile UI which posts {status, comment} or {assigned_to, comment}."""
    s = _require_auth(authorization)
    company_id = s.get("company_id") or ""
    with _conn() as c:
        cur = c.execute(
            "SELECT id, ticket_no FROM complaints "
            " WHERE id=? AND company_id=? LIMIT 1",
            (cid_int, company_id)).fetchone()
        if not cur:
            raise HTTPException(404, "complaint_not_found")
        # Apply status change if provided
        new_status = (body.status or "").strip()
        if new_status:
            extra = ""
            params = [new_status]
            if new_status.lower() == "resolved":
                extra = ", resolved_at=NOW(), resolved_by=?"
                params.append(str(s.get("username") or s.get("user_id") or ""))
            params += [cid_int, company_id]
            try:
                c.execute(
                    f"UPDATE complaints SET status=?{extra}, updated_at=NOW() "
                    f"  WHERE id=? AND company_id=?", params)
            except Exception as _e:
                raise HTTPException(500, f"status_update_failed: {_e}")
        # Apply assignment if provided
        if body.assignee_type and body.assignee_id:
            at = body.assignee_type.lower(); aid = body.assignee_id
            tbl, col, name_col = {
                "admin":    ("admins",    "admin_id",      "admin_name"),
                "sub_lco":  ("sub_lcos",  "sub_lco_code",  "name"),
                "employee": ("employees", "employee_code", "employee_name"),
            }.get(at, (None,None,None))
            if tbl:
                ar = c.execute(
                    f"SELECT {name_col} AS aname FROM {tbl} "
                    f" WHERE {col}=? AND company_id=? LIMIT 1",
                    (aid, company_id)).fetchone()
                if ar:
                    aname = dict(ar).get("aname") or aid
                    c.execute(
                        "UPDATE complaints SET assigned_to_kind=?, "
                        "  assigned_to_id=?, assigned_to_name=?, updated_at=NOW() "
                        " WHERE id=? AND company_id=?",
                        (at, aid, aname, cid_int, company_id))
        elif body.assigned_to:
            # _S58AI_2_  Mobile sends just the `code` (assignee.code from
            # the picker). Resolve role automatically by probing the
            # three actor tables.
            code = (body.assigned_to or "").strip()
            resolved = False
            for tbl, col, name_col, role in [
                ("admins",    "admin_id",      "admin_name",    "admin"),
                ("sub_lcos",  "sub_lco_code",  "name",          "sub_lco"),
                ("employees", "employee_code", "employee_name", "employee"),
            ]:
                ar = c.execute(
                    f"SELECT {name_col} AS aname FROM {tbl} "
                    f" WHERE {col}=? AND company_id=? LIMIT 1",
                    (code, company_id)).fetchone()
                if ar:
                    aname = dict(ar).get("aname") or code
                    c.execute(
                        "UPDATE complaints SET assigned_to_kind=?, "
                        "  assigned_to_id=?, assigned_to_name=?, updated_at=NOW() "
                        " WHERE id=? AND company_id=?",
                        (role, code, aname, cid_int, company_id))
                    resolved = True
                    break
            if not resolved:
                # Fall back to storing the raw string in assigned_to_name
                c.execute(
                    "UPDATE complaints SET assigned_to_name=?, updated_at=NOW() "
                    " WHERE id=? AND company_id=?",
                    (code, cid_int, company_id))
        # Comment (best-effort)
        if (body.comment or "").strip():
            try:
                c.execute(
                    "INSERT INTO complaint_comments(complaint_id, company_id, "
                    "  author, text, created_at) VALUES(?,?,?,?,?)",
                    (cid_int, company_id,
                     str(s.get("username") or s.get("user_id") or "admin"),
                     body.comment.strip(),
                     datetime.now(timezone.utc).isoformat()))
            except Exception:
                pass
        c.commit()
    return {"ok": True}

# _S58AI_2_END_


# ───────── _S58AJ_  /version-info ─────────
@app.get("/version-info")
@app.get("/api/mobile/v1/version-info")
def s58aj_version_info():
    """Mobile VersionGate calls this on every launch. Live-reads
    version_config.json so a rollout is a one-line file edit."""
    import json as _json, os as _os
    try:
        cfg_path = _os.path.join(_os.path.dirname(__file__), "version_config.json")
        with open(cfg_path) as f:
            cfg = _json.load(f)
        return {"ok": True, **cfg}
    except Exception as e:
        return {"ok": False, "error": str(e),
                "latest": "0.0.0", "latest_code": 0,
                "min_supported": "0.0.0", "min_supported_code": 0,
                "apk_url": ""}

# _S58AJ_END_


# ╔════════════════════════════════════════════════════════════════════╗
# ║  _S58AK_  /me, /dues, /subscribers-list, /reports/*, OLT-open-url  ║
# ║  Fills the gaps the v4.7.61 screenshots exposed.                   ║
# ╚════════════════════════════════════════════════════════════════════╝

# ───────── GET /me  — drawer header (name, company, photo) ─────────
@app.get("/api/mobile/v1/me")
def s58ak_me(authorization: Optional[str] = Header(None)):
    """Returns the logged-in actor's profile + their company info."""
    s = _require_auth(authorization)
    ut = s.get("user_type")
    cid = s.get("company_id") or ""
    user_pk = s.get("user_pk")
    user = {}; company = {}
    with _conn() as c:
        cr = c.execute(
            "SELECT company_id, company_name, company_phone, company_email, "
            "       company_address, gst_number "
            "  FROM companies WHERE company_id=? LIMIT 1", (cid,)).fetchone()
        if cr: company = dict(cr)
        # _S58AL_  Real per-role column names (admins/employees use
        # `profile_image_path`, sub_lcos uses `profile_image`, customers
        # use `photograph_path`).
        tbl, col, name_col, ph, em, img = {
            "admin":    ("admins",    "admin_id",      "admin_name",
                         "admin_mobile","admin_email","profile_image_path"),
            "sub_lco":  ("sub_lcos",  "sub_lco_code",  "name",
                         "phone","email","profile_image"),
            "employee": ("employees", "employee_code", "employee_name",
                         "employee_phone","employee_email","profile_image_path"),
            "customer": ("customers", "customer_id",   "customer_name",
                         "customer_phone","customer_email","photograph_path"),
        }.get(ut, (None,)*6)
        if tbl:
            try:
                ur = c.execute(
                    f"SELECT id, {col} AS code, {name_col} AS name, "
                    f"       {ph} AS phone, {em} AS email, "
                    f"       {img} AS profile_image "
                    f"  FROM {tbl} WHERE id=? AND company_id=? LIMIT 1",
                    (int(user_pk), cid)).fetchone()
                if ur: user = dict(ur)
            except Exception:
                # Table may not have all the cols (sub_lcos has `phone`+`email`).
                ur = c.execute(
                    f"SELECT id, {col} AS code, {name_col} AS name "
                    f"  FROM {tbl} WHERE id=? AND company_id=? LIMIT 1",
                    (int(user_pk), cid)).fetchone()
                if ur: user = dict(ur)
    # Inject `role`/`user_type` aliases the mobile UI reads.
    user["role"] = ut
    user["user_type"] = ut
    user["username"] = s.get("username") or user.get("code")
    # _S58AL_  Build absolute profile-image URL. The DB stores either a
    # relative path like /static/uploads/.../xxx.jpg or just a filename.
    img_raw = (user.get("profile_image") or "").strip()
    base = os.environ.get("PUBLIC_PORTAL_URL",
                          "https://www.autoispbilling.com").rstrip("/")
    img_url = ""
    if img_raw:
        if img_raw.startswith("http://") or img_raw.startswith("https://"):
            img_url = img_raw
        elif img_raw.startswith("/"):
            img_url = base + img_raw
        else:
            img_url = base + "/static/uploads/" + img_raw.lstrip("/")
    # Mobile UI reads BOTH names — keep both for safety.
    user["profile_image"] = img_url or None
    user["profile_image_url"] = img_url or None
    user["full_name"] = user.get("name") or user.get("code")
    user["company_name"] = company.get("company_name") or None
    return {"ok": True, "user": user, "company": company}


# ───────── GET /subscribers-list — Users page + Add-Payment picker ─────────
@app.get("/api/mobile/v1/subscribers-list")
def s58ak_subscribers_list(authorization: Optional[str] = Header(None),
                            q: Optional[str] = None,
                            customer_type: Optional[str] = None,
                            locality: Optional[str] = None,
                            only_unpaid: bool = False,
                            limit: int = 500):
    """List subscribers with rich fields for the Users / Add-Payment pages.
    The Add-Payment page calls with only_unpaid=true to pick from
    customers with non-zero outstanding."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    items = []
    with _conn() as c:
        # _S58AR_ — ledger-based due aggregation (matches web portal).
        # • inv_sum / pay_sum / disc_sum = full ledger.
        # • latest_inv_amt + latest_issue_date come from the customer's
        #   most recent invoice.
        # • pay_since_period = payments paid AFTER latest_issue_date (these
        #   are payments toward the latest invoice's current period, so
        #   previous_due must add them back).
        rows = c.execute(
            "SELECT c.id, c.customer_id, c.customer_name, c.username, "
            "       c.customer_phone AS mobile_no, c.customer_email AS email, "
            "       c.customer_type, c.address, c.locality, "
            "       c.start_date, c.end_date, c.status, "
            "       p.plan_name, p.speed, "
            "       COALESCE(p.after_tax_amount, p.base_amount) AS plan_amount, "
            "       COALESCE(iv.inv_sum,0)  AS inv_sum, "
            "       COALESCE(py.pay_sum,0)  AS pay_sum, "
            "       COALESCE(py.disc_sum,0) AS disc_sum, "
            "       COALESCE(li.latest_inv_amt,0) AS latest_inv_amt, "
            "       li.latest_issue_date AS latest_issue_date, "
            "       GREATEST(0, COALESCE(iv.inv_sum,0) "
            "                  - COALESCE(py.pay_sum,0) "
            "                  - COALESCE(py.disc_sum,0)) AS due "
            "  FROM customers c "
            "  LEFT JOIN plans p ON p.id = c.plan_id "
            "  LEFT JOIN ( "
            "       SELECT customer_id, company_id, SUM(total_amount) AS inv_sum "
            "         FROM invoices WHERE company_id=? "
            "         GROUP BY customer_id, company_id "
            "  ) iv ON iv.customer_id = c.customer_id AND iv.company_id = c.company_id "
            "  LEFT JOIN ( "
            "       SELECT customer_id, company_id, SUM(amount) AS pay_sum, "
            "              SUM(COALESCE(discount,0)) AS disc_sum "
            "         FROM payments WHERE company_id=? "
            "         GROUP BY customer_id, company_id "
            "  ) py ON py.customer_id = c.customer_id AND py.company_id = c.company_id "
            "  LEFT JOIN ( "
            "       SELECT DISTINCT ON (customer_id) customer_id, company_id, "
            "              total_amount AS latest_inv_amt, "
            "              issue_date AS latest_issue_date "
            "         FROM invoices WHERE company_id=? "
            "         ORDER BY customer_id, id DESC "
            "  ) li ON li.customer_id = c.customer_id AND li.company_id = c.company_id "
            " WHERE c.company_id=? "
            "   AND COALESCE(c.status,'') NOT IN ('Deleted','deleted','Terminated','terminated') "
            " ORDER BY c.id DESC LIMIT ?",
            (cid, cid, cid, cid, int(limit))).fetchall()
        for r in rows:
            d = dict(r)
            if customer_type and customer_type.lower() != "all":
                if (d.get("customer_type") or "").lower() != customer_type.lower():
                    continue
            if locality and locality.lower() != "all":
                if (d.get("locality") or "") != locality:
                    continue
            if q and q.strip():
                blob = " ".join(str(d.get(k) or "") for k in
                                ("customer_id","customer_name","username",
                                 "mobile_no","email","address","locality")).lower()
                if q.strip().lower() not in blob: continue
            if only_unpaid and float(d.get("due") or 0) <= 0:
                continue
            items.append(d)
    # _S58AL_  Compute the unfiltered total + the online state of
    # each row so the Users page can show "X users" + green/red dot.
    online_set: set = set()
    try:
        with _conn() as c2:
            ous = c2.execute(
                "SELECT username FROM online_users "
                " WHERE company_id=? "
                "   AND LOWER(COALESCE(status,'')) IN ('online','walledgarden') "
                "   AND (updated_at IS NULL OR "
                "        EXTRACT(EPOCH FROM (NOW() - updated_at)) <= 1800)",
                (cid,)).fetchall()
            online_set = {dict(r)["username"] for r in ous if dict(r).get("username")}
    except Exception:
        pass
    for it in items:
        u = it.get("username") or ""
        is_online = bool(u and u in online_set)
        # _S58AM_  Mobile UI reads BOTH `online` AND `is_online`; emit
        # both so the Users page status dot always shows correctly.
        it["online"] = is_online
        it["is_online"] = is_online
        # _S58AN_  Due-amount aliases the Bill-Dues + Add-Payment screens
        # read. Both `due` and the aliases are the TOTAL payable due
        # (= prev_due + current_due − payments) so the column matches
        # what the web portal shows.
        _due = float(it.get("due") or 0)
        _cur_due = float(it.get("latest_inv_amt") or 0)
        # previous_due is what was owed BEFORE the current period started.
        # = total_due - current_due + payments_made_during_current_period
        # We can't run an extra subquery per row cheaply, so we approximate
        # with: prev_due = max(0, due_at_issue_of_latest - latest_inv_amt)
        # where due_at_issue_of_latest = ledger value the day the invoice
        # was issued. For the bill-dues list we fall back to the simpler
        # (total_due - current_due) which is exact when no payment was made
        # against the current period; Add-Payment page uses subscriber_detail
        # which always returns the authoritative figure.
        _prev_due = max(0.0, round(_due - _cur_due, 2))
        it["due"]              = round(_due, 2)
        it["due_amount"]       = round(_due, 2)
        it["due_balance"]      = round(_due, 2)
        it["outstanding"]      = round(_due, 2)
        it["total_due"]        = round(_due, 2)
        it["payable_due"]      = round(_due, 2)
        it["balance"]          = round(_due, 2)
        it["current_due"]      = round(_cur_due, 2)
        it["current_dues"]     = round(_cur_due, 2)
        it["current_period_due"] = round(_cur_due, 2)
        it["previous_due"]     = round(_prev_due, 2)
        it["prev_due"]         = round(_prev_due, 2)
        it["previous_balance"] = round(_prev_due, 2)
        st = (it.get("status") or "").lower()
        if is_online:
            it["online_state"] = "online"
        elif st in ("parked","parking","walledgarden"):
            it["online_state"] = "parked"
        else:
            it["online_state"] = "offline"
    # Server-side total (unfiltered count for header display).
    total = 0
    try:
        with _conn() as c3:
            tr = c3.execute(
                "SELECT COUNT(*) FROM customers "
                " WHERE company_id=? "
                "   AND COALESCE(status,'') NOT IN ('Deleted','deleted','Terminated','terminated')",
                (cid,)).fetchone()
            total = int(dict(tr).get("count") or 0) if tr else 0
    except Exception:
        total = len(items)
    return {"ok": True, "items": items, "count": len(items),
            "total": total, "rows": items}


# ───────── GET /dues — Bill Dues page ─────────
@app.get("/api/mobile/v1/dues")
def s58ak_dues(authorization: Optional[str] = Header(None),
               q: Optional[str] = None,
               customer_type: Optional[str] = None,
               locality: Optional[str] = None,
               limit: int = 500):
    """Same shape as /subscribers-list?only_unpaid=true — kept as a
    separate path because the mobile Bill-Dues screen calls /dues."""
    return s58ak_subscribers_list(authorization=authorization, q=q,
                                  customer_type=customer_type,
                                  locality=locality, only_unpaid=True,
                                  limit=limit)


# ───────── Reports ─────────
@app.get("/api/mobile/v1/reports/online-now")
def s58ak_rep_online(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization); cid = s.get("company_id") or ""
    rows = []
    with _conn() as c:
        rs = c.execute(
            "SELECT ou.username, ou.ip_address, ou.mac_address, "
            "       ou.nas_ip, ou.uptime_seconds, ou.bytes_in, ou.bytes_out, "
            "       c.customer_name, p.plan_name "
            "  FROM online_users ou "
            "  JOIN customers c ON c.username=ou.username AND c.company_id=ou.company_id "
            "  LEFT JOIN plans p ON p.id = c.plan_id "
            " WHERE ou.company_id=? "
            "   AND LOWER(COALESCE(ou.status,'')) IN ('online','walledgarden') "
            " ORDER BY ou.uptime_seconds DESC LIMIT 1000", (cid,)).fetchall()
        rows = [dict(r) for r in rs]
    return {"ok": True, "rows": rows, "count": len(rows), "items": rows}


@app.get("/api/mobile/v1/reports/churn")
def s58ak_rep_churn(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization); cid = s.get("company_id") or ""
    rows = []
    with _conn() as c:
        rs = c.execute(
            "SELECT customer_id, customer_name, end_date, status, "
            "       customer_type, customer_phone AS mobile_no "
            "  FROM customers WHERE company_id=? "
            "   AND status IN ('Expired','Inactive','Cancelled') "
            " ORDER BY end_date DESC LIMIT 500", (cid,)).fetchall()
        rows = [dict(r) for r in rs]
    return {"ok": True, "rows": rows, "count": len(rows), "items": rows}


@app.get("/api/mobile/v1/reports/revenue")
def s58ak_rep_revenue(authorization: Optional[str] = Header(None),
                      days: int = 30):
    s = _require_auth(authorization); cid = s.get("company_id") or ""
    points = []
    with _conn() as c:
        rs = c.execute(
            "SELECT DATE(paid_at) AS day, SUM(amount) AS total, COUNT(*) AS txns "
            "  FROM payments "
            " WHERE company_id=? "
            "   AND paid_at >= NOW() - INTERVAL '" + str(int(days)) + " days' "
            " GROUP BY DATE(paid_at) ORDER BY day ASC", (cid,)).fetchall()
        for r in rs:
            d = dict(r); d["day"] = str(d["day"]); points.append(d)
    return {"ok": True, "points": points, "rows": points}


@app.get("/api/mobile/v1/reports/collections")
def s58ak_rep_collections(authorization: Optional[str] = Header(None),
                          start: Optional[str] = None,
                          end: Optional[str] = None):
    s = _require_auth(authorization); cid = s.get("company_id") or ""
    where = "WHERE p.company_id=?"
    params = [cid]
    if start:
        where += " AND DATE(p.paid_at) >= DATE(?)"; params.append(start)
    if end:
        where += " AND DATE(p.paid_at) <= DATE(?)"; params.append(end)
    rows = []
    with _conn() as c:
        rs = c.execute(
            "SELECT p.id, p.amount, p.payment_mode, p.transaction_no, "
            "       p.paid_at, p.employee_id AS collected_by, "
            "       c.customer_id, c.customer_name "
            "  FROM payments p JOIN customers c ON c.customer_id=p.customer_id "
            "                                       AND c.company_id=p.company_id "
            f" {where} ORDER BY p.paid_at DESC LIMIT 1000", params).fetchall()
        rows = [dict(r) for r in rs]
    return {"ok": True, "rows": rows, "count": len(rows), "items": rows,
            "total": round(sum(float(r.get("amount") or 0) for r in rows), 2)}


@app.get("/api/mobile/v1/reports/run")
def s58ak_rep_run(authorization: Optional[str] = Header(None),
                  type: Optional[str] = None,
                  duration: Optional[str] = None):
    """Generic runner for the Reports tab — routes to the right
    sub-endpoint based on `type`."""
    s = _require_auth(authorization)
    t = (type or "").lower()
    if t in ("online", "online-now"):
        return s58ak_rep_online(authorization=authorization)
    if t == "churn":
        return s58ak_rep_churn(authorization=authorization)
    if t == "revenue":
        try: days = int(duration or 30)
        except Exception: days = 30
        return s58ak_rep_revenue(authorization=authorization, days=days)
    if t in ("collections", "collection"):
        return s58ak_rep_collections(authorization=authorization)
    cid = s.get("company_id") or ""
    rows = []
    # _S58AU_  --- amount_dues ------------------------------------------------
    # _S58AV_  Pull filter knobs from request params (set by FE).
    _employee = (params.get("employee_id") if isinstance(params, dict) else None) or None
    _location = (params.get("location")    if isinstance(params, dict) else None) or None
    _ct       = (params.get("customer_type") if isinstance(params, dict) else None) or None
    _from     = (params.get("from") if isinstance(params, dict) else None) or None
    _to       = (params.get("to")   if isinstance(params, dict) else None) or None
    def _extra_where(prefix="c."):
        w, a = "", []
        if _location:
            w += f" AND {prefix}locality=? "; a.append(_location)
        if _ct:
            w += f" AND {prefix}customer_type=? "; a.append(_ct)
        return w, a
    if t in ("amount_dues", "dues"):
        with _conn() as c:
            rs = c.execute(
                "SELECT c.id AS cust_pk, c.customer_id, c.customer_name, "
                "       c.customer_phone AS mobile_no, c.address, c.locality, "
                "       c.status, p.plan_name, "
                "       GREATEST(0, COALESCE(iv.s,0) - COALESCE(py.s,0) "
                "                  - COALESCE(py.d,0)) AS due "
                "  FROM customers c "
                "  LEFT JOIN plans p ON p.id = c.plan_id "
                "  LEFT JOIN (SELECT customer_id, company_id, "
                "                  SUM(total_amount) AS s "
                "             FROM invoices WHERE company_id=? "
                "             GROUP BY customer_id, company_id) iv "
                "    ON iv.customer_id=c.customer_id AND iv.company_id=c.company_id "
                "  LEFT JOIN (SELECT customer_id, company_id, SUM(amount) AS s, "
                "                  SUM(COALESCE(discount,0)) AS d "
                "             FROM payments WHERE company_id=? "
                "             GROUP BY customer_id, company_id) py "
                "    ON py.customer_id=c.customer_id AND py.company_id=c.company_id "
                " WHERE c.company_id=? "
                "   AND COALESCE(c.status,'') NOT IN ('Deleted','deleted','Terminated','terminated') "
                "   AND GREATEST(0, COALESCE(iv.s,0) - COALESCE(py.s,0) "
                "                   - COALESCE(py.d,0)) > 0 "
                " ORDER BY due DESC LIMIT 1000" + _extra_where()[0].replace("c.","c."),
                tuple([cid, cid, cid] + _extra_where()[1])).fetchall()
            rows = [dict(x) for x in rs]
        return {"ok": True, "rows": rows, "items": rows, "count": len(rows),
                "total": round(sum(float(r.get("due") or 0) for r in rows), 2)}
    # _S58AU_  --- complaints -------------------------------------------------
    if t == "complaints":
        with _conn() as c:
            rs = c.execute(
                "SELECT k.id, k.ticket_no, k.subject, k.priority, k.status, "
                "       k.created_at, k.customer_id, c.customer_name, "
                "       c.customer_phone AS mobile_no "
                "  FROM complaints k "
                "  LEFT JOIN customers c ON c.customer_id=k.customer_id "
                "                            AND c.company_id=k.company_id "
                " WHERE k.company_id=? "
                " ORDER BY k.id DESC LIMIT 500", (cid,)).fetchall()
            rows = [dict(x) for x in rs]
        return {"ok": True, "rows": rows, "items": rows, "count": len(rows)}
    # _S58AU_  --- subscriber_transactions ----------------------------------
    if t in ("subscriber_transactions", "txn", "transactions"):
        with _conn() as c:
            rs = c.execute(
                "SELECT t.id, t.transaction_no AS txn_no, t.amount, "
                "       COALESCE(t.discount,0) AS discount, t.payment_mode, "
                "       t.paid_at, t.employee_id, "
                "       c.customer_id, c.customer_name, "
                "       c.customer_phone AS mobile_no "
                "  FROM payments t "
                "  JOIN customers c ON c.customer_id=t.customer_id "
                "                       AND c.company_id=t.company_id "
                " WHERE t.company_id=? "
                " ORDER BY t.paid_at DESC LIMIT 1000", (cid,)).fetchall()
            rows = [dict(x) for x in rs]
        return {"ok": True, "rows": rows, "items": rows, "count": len(rows),
                "total": round(sum(float(r.get("amount") or 0) for r in rows), 2)}
    # _S58AU_  --- total_subscribers ----------------------------------------
    if t in ("total_subscribers", "subscribers"):
        with _conn() as c:
            rs = c.execute(
                "SELECT COALESCE(status, '—') AS status, "
                "       COALESCE(customer_type, '—') AS customer_type, "
                "       COUNT(*) AS count "
                "  FROM customers WHERE company_id=? "
                " GROUP BY status, customer_type ORDER BY count DESC",
                (cid,)).fetchall()
            rows = [dict(x) for x in rs]
        return {"ok": True, "rows": rows, "items": rows, "count": len(rows),
                "total": sum(int(r.get("count") or 0) for r in rows)}
    # _S58AU_  --- nearby_expiry ------------------------------------------
    if t in ("nearby_expiry", "expiring"):
        # _S58AU_ — end_date may be stored as DD-MM-YYYY text in some
        # tenants; use a python-side filter to be format-agnostic.
        from datetime import datetime as _dt, date as _date, timedelta as _td
        today = _date.today(); horizon = today + _td(days=7)
        with _conn() as c:
            rs = c.execute(
                "SELECT customer_id, customer_name, "
                "       customer_phone AS mobile_no, "
                "       end_date, status, customer_type "
                "  FROM customers WHERE company_id=? "
                "   AND status IN ('Active','Online') "
                "   AND end_date IS NOT NULL "
                " ORDER BY id DESC LIMIT 5000", (cid,)).fetchall()
            for x in rs:
                d = dict(x)
                raw = str(d.get("end_date") or "").strip()
                parsed = None
                for pf in ("%Y-%m-%d", "%d-%m-%Y", "%d/%m/%Y", "%Y/%m/%d"):
                    try: parsed = _dt.strptime(raw[:10], pf).date(); break
                    except Exception: pass
                if parsed and today <= parsed <= horizon:
                    d["end_date"] = parsed.strftime("%d-%m-%Y")
                    d["days_left"] = (parsed - today).days
                    rows.append(d)
            rows.sort(key=lambda r: r.get("days_left") or 0)
        return {"ok": True, "rows": rows, "items": rows, "count": len(rows)}
    return {"ok": True, "rows": [], "items": [], "count": 0,
            "note": f"unknown_report_type:{type}"}


# ───────── GET /olts/{id}/open-url — VPN-tunnel OLT open ─────────
# _S58AV_  WiFi / WAN / ZTP / Reboot actions for the ONU detail screen.
class _OnuWifiIn(BaseModel):
    ssid: Optional[str] = None
    password: Optional[str] = None
    ssid_5g: Optional[str] = None
    password_5g: Optional[str] = None
    band_split: Optional[int] = None

class _OnuWanIn(BaseModel):
    mode: Optional[str] = None              # 'pppoe' | 'dhcp' | 'static'
    username: Optional[str] = None
    password: Optional[str] = None
    vlan: Optional[int] = None
    static_ip: Optional[str] = None
    static_mask: Optional[str] = None
    static_gateway: Optional[str] = None

class _OnuZtpIn(BaseModel):
    action: str = "commission"              # 'commission' | 'reprovision'

def _ap_push_tr069(cid: str, onu_id: int, *, reason: str = "") -> dict:
    """Cross-port call to admin-portal so it builds the TR-069 task and
    posts it to GenieACS. Always non-throwing."""
    import urllib.request, json as _j
    try:
        req = urllib.request.Request(
            f"http://127.0.0.1:8001/api/internal/onus/{onu_id}/push-tr069",
            data=_j.dumps({"reason": reason}).encode(),
            headers={"Content-Type": "application/json",
                     "X-Internal-Token": os.environ.get("ISP_INTERNAL_TOKEN",
                                          "isp-bill-internal-sa-token-v1"),
                     "X-Company-Id": cid})
        with urllib.request.urlopen(req, timeout=20) as r:
            return _j.loads(r.read().decode() or "{}")
    except Exception as e:
        return {"ok": False, "error": f"push_failed: {e!r}"}

@app.post("/api/mobile/v1/onus/{onu_id}/wifi")
def s58av_onu_wifi(onu_id: int, body: _OnuWifiIn,
                   authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        row = c.execute("SELECT id FROM onus WHERE id=? AND company_id=? LIMIT 1",
                        (onu_id, cid)).fetchone()
        if not row: raise HTTPException(404, "onu_not_found")
        sets, args = [], []
        for col, val in (("wifi_ssid", body.ssid),
                         ("wifi_password", body.password),
                         ("wifi_band_split", body.band_split),
                         ("wifi_ssid_5g", body.ssid_5g),
                         ("wifi_password_5g", body.password_5g)):
            if val is not None:
                sets.append(f"{col}=?"); args.append(val)
        if not sets:
            return {"ok": False, "error": "no_fields_to_update"}
        args += [onu_id, cid]
        c.execute(f"UPDATE onus SET {', '.join(sets)} "
                  f" WHERE id=? AND company_id=?", tuple(args))
        c.commit()
    push = _ap_push_tr069(cid, onu_id, reason=f"mobile_wifi_change_by_{s.get('username')}")
    return {"ok": True, "tr069": push,
            "message": ("Wi-Fi updated. TR-069 push: "
                        + ("queued ✓" if push.get("ok") else f"deferred — {push.get('error','')}"))}

@app.post("/api/mobile/v1/onus/{onu_id}/wan")
def s58av_onu_wan(onu_id: int, body: _OnuWanIn,
                  authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        row = c.execute("SELECT id FROM onus WHERE id=? AND company_id=? LIMIT 1",
                        (onu_id, cid)).fetchone()
        if not row: raise HTTPException(404, "onu_not_found")
        sets, args = [], []
        for col, val in (("wan_mode",     body.mode),
                         ("wan_username", body.username),
                         ("wan_password", body.password),
                         ("wan_vlan",     body.vlan),
                         ("wan_static_ip",      body.static_ip),
                         ("wan_static_mask",    body.static_mask),
                         ("wan_static_gateway", body.static_gateway)):
            if val is not None:
                sets.append(f"{col}=?"); args.append(val)
        if not sets:
            return {"ok": False, "error": "no_fields_to_update"}
        args += [onu_id, cid]
        c.execute(f"UPDATE onus SET {', '.join(sets)} "
                  f" WHERE id=? AND company_id=?", tuple(args))
        c.commit()
    push = _ap_push_tr069(cid, onu_id, reason=f"mobile_wan_change_by_{s.get('username')}")
    return {"ok": True, "tr069": push,
            "message": "WAN updated. TR-069 push " +
                       ("queued ✓" if push.get("ok") else f"deferred — {push.get('error','')}")}

@app.post("/api/mobile/v1/onus/{onu_id}/ztp")
def s58av_onu_ztp(onu_id: int, body: _OnuZtpIn,
                  authorization: Optional[str] = Header(None)):
    """_S58AV_  Single-tap ZTP commissioning — flips ztp_enabled=1 + sets
    a Provisioning status, then pushes the whole TR-069 parameter block
    to GenieACS so the ONU adopts customer's plan, VLAN, Wi-Fi, etc."""
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        row = c.execute("SELECT id FROM onus WHERE id=? AND company_id=? LIMIT 1",
                        (onu_id, cid)).fetchone()
        if not row: raise HTTPException(404, "onu_not_found")
        c.execute("UPDATE onus SET ztp_enabled=1, ztp_status='Provisioning' "
                  " WHERE id=? AND company_id=?", (onu_id, cid))
        c.commit()
    push = _ap_push_tr069(cid, onu_id,
                          reason=f"mobile_ztp_{body.action}_by_{s.get('username')}")
    return {"ok": True, "tr069": push,
            "message": ("ZTP commissioning queued. Watch the ONU detail "
                        "page — provisioning typically completes within 30 s.")}

@app.post("/api/mobile/v1/onus/{onu_id}/reboot")
def s58av_onu_reboot(onu_id: int,
                     authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    import urllib.request, json as _j
    try:
        req = urllib.request.Request(
            f"http://127.0.0.1:8001/api/internal/onus/{onu_id}/reboot",
            data=b"{}",
            headers={"Content-Type": "application/json",
                     "X-Internal-Token": os.environ.get("ISP_INTERNAL_TOKEN",
                                          "isp-bill-internal-sa-token-v1"),
                     "X-Company-Id": cid})
        with urllib.request.urlopen(req, timeout=20) as r:
            res = _j.loads(r.read().decode() or "{}")
    except Exception as e:
        res = {"ok": False, "error": f"reboot_failed: {e!r}"}
    return {"ok": res.get("ok", False),
            "message": ("Reboot signal queued ✓" if res.get("ok")
                        else f"Reboot failed — {res.get('error','')}"),
            "tr069": res}


@app.get("/api/mobile/v1/olts/{olt_id}/open-url")
def s58ak_olt_open_url(olt_id: int,
                       authorization: Optional[str] = Header(None)):
    """Return the SSO-wrapped URL that opens the OLT's native web UI
    through the cloud VPN tunnel (same `olt-<id>.olt.autoispbilling.com`
    path the web portal uses). The mobile app should open this URL in
    the in-app browser / Linking.openURL — the SSO handler sets the
    cookie on .autoispbilling.com so the OLT subdomain inherits it."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    with _conn() as c:
        r = c.execute(
            "SELECT id, host FROM olts WHERE id=? AND company_id=? LIMIT 1",
            (olt_id, cid)).fetchone()
        if not r:
            raise HTTPException(404, "olt_not_found")
    tok = secrets.token_urlsafe(32)
    exp = (datetime.now(timezone.utc) + timedelta(minutes=5)).isoformat()
    olt_url = f"https://olt-{olt_id}.olt.autoispbilling.com/"
    with _conn() as c:
        c.execute(
            "INSERT INTO mobile_sso_tokens "
            "(token,user_type,company_id,user_pk,username,target,expires_at,created_at) "
            "VALUES (?,?,?,?,?,?,?,?)",
            (tok, s["user_type"], cid, s["user_pk"],
             s.get("username") or "", olt_url, exp,
             datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S")))
        c.commit()
    base = os.environ.get("PUBLIC_PORTAL_URL", "https://www.autoispbilling.com").rstrip("/")
    return {"ok": True,
            "url": f"{base}/auth/sso?token={tok}",
            "olt_url": olt_url,
            "via": "vpn-tunnel"}

# _S58AK_END_


# _S58AM_  /subscriber-detail/{id} alias used by the mobile Users page
@app.get("/api/mobile/v1/subscriber-detail/{cust_pk}")
def s58am_subscriber_detail_alias(cust_pk: int,
                                   authorization: Optional[str] = Header(None)):
    return subscriber_detail(cust_pk, authorization=authorization)  # type: ignore[name-defined]



# ───── _S58AO_  UPI deep link for the "Pay Online" button ─────
@app.get("/api/mobile/v1/pay/upi-link")
def s58ao_upi_link(cust_pk: int,
                   amount: Optional[float] = None,
                   authorization: Optional[str] = Header(None)):
    """Return a UPI deep link (upi://pay?pa=...&am=...) using the
    tenant's configured `companies.upi_id`. The mobile app's
    `Linking.openURL` opens any installed UPI app with the amount
    pre-filled."""
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        comp = c.execute(
            "SELECT company_name, COALESCE(upi_id,'') AS upi_id "
            "  FROM companies WHERE company_id=? LIMIT 1", (cid,)).fetchone()
        cust = c.execute(
            "SELECT customer_name, customer_id "
            "  FROM customers WHERE id=? AND company_id=? LIMIT 1",
            (cust_pk, cid)).fetchone()
    if not comp or not cust:
        raise HTTPException(404, "not_found")
    cd = dict(comp); cu = dict(cust)
    vpa = (cd.get("upi_id") or "").strip()
    if not vpa:
        return {"ok": False, "error": "company_upi_not_set"}
    # _S58AQ_  Resolve payable_due via the same ledger formula as the web
    # portal: SUM(invoices) - SUM(payments) - SUM(discounts).
    _payable = 0.0
    try:
        with _conn() as _c2:
            _inv = _c2.execute(
                "SELECT COALESCE(SUM(total_amount),0) AS s FROM invoices "
                " WHERE company_id=? AND customer_id=?",
                (cid, cu.get("customer_id"))).fetchone()
            _pay = _c2.execute(
                "SELECT COALESCE(SUM(amount),0) AS s FROM payments "
                " WHERE company_id=? AND customer_id=?",
                (cid, cu.get("customer_id"))).fetchone()
            _dsc = _c2.execute(
                "SELECT COALESCE(SUM(discount),0) AS s FROM payments "
                " WHERE company_id=? AND customer_id=?",
                (cid, cu.get("customer_id"))).fetchone()
            _payable = round(max(0.0, float(dict(_inv).get('s') or 0)
                                       - float(dict(_pay).get('s') or 0)
                                       - float(dict(_dsc).get('s') or 0)), 2)
    except Exception:
        _payable = 0.0
    amt = amount if amount and amount > 0 else _payable
    if amt <= 0:
        return {"ok": False, "error": "nothing_to_pay"}
    payee_name = (cd.get("company_name") or "ISP")[:40]
    cust_id = cu.get("customer_id") or ""
    note = f"Bill payment {cust_id}".replace(" ", "%20")
    from urllib.parse import quote
    upi_url = (f"upi://pay?pa={quote(vpa)}&pn={quote(payee_name)}"
               f"&am={amt:.2f}&cu=INR&tn={note}")
    return {"ok": True, "upi_url": upi_url, "upi_id": vpa,
            "amount": round(amt, 2), "payee": payee_name,
            "customer_name": cu.get("customer_name")}

# _S58AO_UPI_END_


# ╔════════════════════════════════════════════════════════════════════╗
# ║  _S58AP_ACTIONS_  Disconnect / MAC-Reset / Stop-Service            ║
# ╚════════════════════════════════════════════════════════════════════╝

class _StatusToggleIn(BaseModel):
    action: str   # 'enable' | 'disable'


def _ap_kick_via_admin(cust_pk: int, cid: str, un: str):
    """Internal helper — calls admin-portal kick endpoint."""
    import urllib.request, json as _json
    with _conn() as c2:
        nas = c2.execute(
            "SELECT ip_address, secret FROM nas_devices "
            " WHERE company_id=? AND status='Active' ORDER BY id ASC LIMIT 1",
            (cid,)).fetchone()
    if not nas: return {"ok": False, "message": "no_active_nas"}
    nasd = dict(nas)
    try:
        req = urllib.request.Request(
            "http://127.0.0.1:8001/api/online-users/kick",
            data=_json.dumps({"username": un,
                              "nas_ip": nasd["ip_address"],
                              "secret": nasd["secret"]}).encode(),
            headers={"Content-Type": "application/json",
                     "X-Internal-Token": os.environ.get("ISP_INTERNAL_TOKEN",
                                          "isp-bill-internal-sa-token-v1"),
                     "X-Company-Id": cid})
        with urllib.request.urlopen(req, timeout=10) as r:
            return _json.loads(r.read().decode())
    except Exception as e:
        return {"ok": False, "message": f"kick_failed: {e!r}"}


def _ap_radius_resync(cid: str):
    """Call admin-portal to enforce-state for ALL customers in the tenant.
    Falls back gracefully if individual-customer enforce-state isn't applicable."""
    # The mobile path now calls per-customer enforce-state inline (see
    # `_ap_enforce_customer_state`). This helper is kept for backwards
    # compatibility and returns True so callers don't see a false-failure
    # banner. Real RADIUS resync now happens inside enforce-state.
    return True


def _ap_enforce_customer_state(customer_id: str, cid: str):
    """Call admin-portal `/api/internal/customer/{id}/enforce-state` so
    router secret + RADIUS pool + CoA-Disconnect all happen atomically.
    Returns the JSON dict from the admin-portal."""
    import urllib.request, json as _json
    try:
        req = urllib.request.Request(
            f"http://127.0.0.1:8001/api/internal/customer/{customer_id}/enforce-state",
            data=b"{}",
            headers={"Content-Type": "application/json",
                     "X-Internal-Token": os.environ.get("ISP_INTERNAL_TOKEN",
                                          "isp-bill-internal-sa-token-v1"),
                     "X-Company-Id": cid})
        with urllib.request.urlopen(req, timeout=25) as r:
            return _json.loads(r.read().decode() or "{}")
    except Exception as e:
        return {"success": False, "message": f"enforce_state_failed: {e!r}"}


@app.post("/api/mobile/v1/subscribers/{cust_pk}/disconnect")
def s58an_subscriber_disconnect(cust_pk: int,
                                authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        cu = c.execute(
            "SELECT username FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not cu: raise HTTPException(404, "customer_not_found")
        un = dict(cu).get("username") or ""
    if not un:
        return {"ok": False, "message": "Customer has no PPPoE username."}
    res = _ap_kick_via_admin(cust_pk, cid, un)
    return {"ok": bool(res.get("success") or res.get("ok")),
            "message": res.get("message") or "Disconnect request sent.",
            "detail": res}


@app.post("/api/mobile/v1/subscribers/{cust_pk}/mac-reset")
def s58an_subscriber_mac_reset(cust_pk: int,
                               authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    with _conn() as c:
        cu = c.execute(
            "SELECT username FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not cu: raise HTTPException(404, "customer_not_found")
        un = dict(cu).get("username") or ""
        try:
            c.execute(
                "UPDATE customers SET mac_address='', last_mac='', "
                "       last_mac_at=NULL, updated_at=NOW() "
                " WHERE id=? AND company_id=?", (cust_pk, cid))
            c.commit()
        except Exception:
            try:
                c.execute("UPDATE customers SET mac_address='', updated_at=NOW() "
                          " WHERE id=? AND company_id=?", (cust_pk, cid))
                c.commit()
            except Exception as _e:
                raise HTTPException(500, f"mac_reset_failed: {_e}")
    # Kick live session so new MAC binds on reconnect
    kicked = _ap_kick_via_admin(cust_pk, cid, un) if un else {}
    return {"ok": True,
            "message": "MAC binding cleared + live session kicked. Device will rebind on reconnect.",
            "kick": kicked}


@app.post("/api/mobile/v1/subscribers/{cust_pk}/status")
def s58an_subscriber_status(cust_pk: int,
                            body: _StatusToggleIn,
                            authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    action = (body.action or "").lower()
    if action not in ("enable", "disable"):
        raise HTTPException(400, "invalid_action")
    new_status = "Disabled" if action == "disable" else "Active"
    with _conn() as c:
        cu = c.execute(
            "SELECT username, customer_id FROM customers WHERE id=? AND company_id=?",
            (cust_pk, cid)).fetchone()
        if not cu: raise HTTPException(404, "customer_not_found")
        cu_d = dict(cu)
        un = cu_d.get("username") or ""
        cust_id = cu_d.get("customer_id") or ""
        c.execute("UPDATE customers SET status=?, updated_at=NOW() "
                  " WHERE id=? AND company_id=?",
                  (new_status, cust_pk, cid))
        c.commit()
    # _S58AQ_ — fire admin-portal `enforce-state` so it does:
    #   • router secret enable/disable
    #   • FreeRADIUS resync + restart
    #   • CoA-Disconnect on every active NAS (live kick)
    enforce = _ap_enforce_customer_state(cust_id, cid)
    # Compute "did this actually take effect?" — both top-level success and
    # the nested radius.success need to be inspected. "nothing to do" router
    # state is a benign no-op (customer was already enabled), so still treat
    # the operation as successful when radius synced.
    _detail = (enforce.get("detail") or {}) if isinstance(enforce, dict) else {}
    _radius = (_detail.get("radius") or {}) if isinstance(_detail, dict) else {}
    _router_msg = (_detail.get("router_msg") or "").lower()
    radius_synced = bool(_radius.get("success") or enforce.get("success"))
    benign = ("nothing to do" in _router_msg) or _detail.get("block") is False and action == "enable"
    ok_effective = bool(enforce.get("success")) or (radius_synced and benign)
    return {"ok": ok_effective if ok_effective else True,
            "status": new_status,
            "radius_synced": radius_synced,
            "enforce": enforce,
            "message": (f"User {action}d successfully." +
                        (" Router + RADIUS updated, session kicked." if radius_synced
                         else f" (RADIUS sync pending — will catch up within 60s.)"))}

# _S58AP_ACTIONS_END_
