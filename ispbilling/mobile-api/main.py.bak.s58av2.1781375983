# ============================================================================
#                            S39R5N — NEW ENDPOINTS
# ============================================================================

@app.get("/api/mobile/v1/transactions")
def transactions(authorization: Optional[str] = Header(None),
                 q: str = "", customer_type: str = "",
                 locality_id: Optional[int] = None,
                 limit: int = Query(100, ge=1, le=500)):
    """List recent transactions, scoped by role + filterable by user-type
    and locality. Times are returned in ISO8601 — the mobile UI converts
    to DD-MM-YYYY HH:MM in Asia/Kolkata."""
    s = _require_auth(authorization)
    # S42R-EMP-PERMS
    _emp_require_perm(s, "feat.transaction_history", "app.transaction")
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # Join customers to apply scope; transactions table has no scope of its own.
        sql = ("SELECT t.id, "
               "        t.paid_at AS transaction_date, "
               "        t.amount, "
               "        COALESCE(t.discount,0) AS discount, "
               "        'Payment' AS transaction_type, "
               "        t.payment_mode AS payment_method, "
               "        t.transaction_no AS reference_no, "
               "        c.start_date, c.end_date, "
               "        c.period AS period_months, "
               "        t.remarks, t.created_at, "
               "        c.customer_name, c.customer_id, c.username, c.customer_type, "
               "        c.location_id "
               "   FROM payments t "
               "   JOIN customers c ON c.customer_id = t.customer_id "
               + scope_sql.replace("WHERE company_id=?", "AND c.company_id=?"))
        sql = sql.replace(" WHERE company_id=?", " AND c.company_id=?")
        # The scope_sql starts with " WHERE company_id=? "; we just made it conjunctive.
        # Re-prefix with WHERE 1=1.
        sql = sql.replace(" AND c.company_id=?", " WHERE 1=1 AND c.company_id=?", 1)
        params = list(scope_params)
        if customer_type and customer_type.lower() not in ("all", ""):
            ut = customer_type.strip().lower().replace(" ", "_")
            sql += (" AND ("
                    "  LOWER(REPLACE(IFNULL(c.service_type,''),' ','_'))=? "
                    "OR LOWER(REPLACE(IFNULL(c.customer_type,''),' ','_'))=? )")
            params += [ut, ut]
        if locality_id:
            sql += " AND c.location_id=? "
            params.append(int(locality_id))
        if q:
            sql += (" AND (c.customer_name LIKE ? OR c.customer_id LIKE ? "
                    " OR c.username LIKE ? OR t.transaction_no LIKE ?) ")
            like = f"%{q}%"
            params += [like]*4
        sql += " ORDER BY t.id DESC LIMIT ? "
        params.append(limit)
        rows = c.execute(sql, params).fetchall()
        items = []
        for r in rows:
            d = {k: r[k] for k in r.keys()}
            # _S58AR_ — mobile UI reads these unified field names.
            d["txn_no"]         = d.get("reference_no")
            d["transaction_no"] = d.get("reference_no")
            d["paid_at"]        = d.get("transaction_date")
            d["payment_mode"]   = d.get("payment_method")
            # _S58AT_ — discount column is needed so UI can render
            # "₹100 + ₹10 Dis" on each row.
            try:
                d["discount"]  = float(d.get("discount") or 0)
            except Exception:
                d["discount"]  = 0.0
            items.append(d)
        return {"ok": True, "count": len(items), "items": items}


# _S58AR_ — combined chronological ledger for the per-user
# Transactions tab. Returns {items: [{kind: invoice|payment, date, amount,
# ref, period?, mode?}]} so the mobile UI can colour invoices RED and
# payments GREEN.
@app.get("/api/mobile/v1/subscribers/{cust_pk}/ledger")
def s58ar_subscriber_ledger(cust_pk: int,
                            authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    cid = s["company_id"] or ""
    items = []
    with _conn() as c:
        cu = c.execute(
            "SELECT customer_id FROM customers "
            " WHERE id=? AND company_id=? LIMIT 1",
            (cust_pk, cid)).fetchone()
        if not cu:
            raise HTTPException(404, "customer_not_found")
        cust_id = dict(cu).get("customer_id") or ""
        for r in c.execute(
            "SELECT id, transaction_no, amount, discount, payment_mode, "
            "       paid_at, remarks, employee_id "
            "  FROM payments "
            " WHERE company_id=? AND customer_id=? "
            " ORDER BY paid_at DESC, id DESC LIMIT 500",
            (cid, cust_id)).fetchall():
            d = dict(r)
            items.append({
                "id":           d.get("id"),
                "ref":          d.get("id"),    # numeric id — detail endpoint expects int
                "txn_no":       d.get("transaction_no"),
                "transaction_no": d.get("transaction_no"),
                "kind":         "payment",
                "type":         "Payment",
                "date":         str(d.get("paid_at") or ""),
                "paid_at":      str(d.get("paid_at") or ""),
                "amount":       float(d.get("amount") or 0),
                "discount":     float(d.get("discount") or 0),
                "payment_mode": d.get("payment_mode") or "",
                "mode":         d.get("payment_mode") or "",
                "remarks":      d.get("remarks") or "",
                "collected_by": d.get("employee_id") or "",
            })
        for r in c.execute(
            "SELECT id, invoice_no, total_amount, due_at_issue, issue_date, "
            "       start_date, end_date "
            "  FROM invoices "
            " WHERE company_id=? AND customer_id=? "
            " ORDER BY issue_date DESC, id DESC LIMIT 500",
            (cid, cust_id)).fetchall():
            d = dict(r)
            def _f(x):
                x = str(x or "")
                if len(x) >= 10 and x[4] == "-" and x[7] == "-":
                    return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                return x
            period = ""
            if d.get("start_date") and d.get("end_date"):
                period = f"{_f(d['start_date'])} to {_f(d['end_date'])}"
            items.append({
                "id":          f"inv-{d.get('id')}",
                "ref":         None,             # invoice rows aren't tappable
                "txn_no":      d.get("invoice_no"),
                "kind":        "invoice",
                "type":        "Invoice",
                "date":        str(d.get("issue_date") or ""),
                "paid_at":     str(d.get("issue_date") or ""),
                "amount":      float(d.get("total_amount") or 0),
                "due_at_issue": float(d.get("due_at_issue") or 0),
                "period":      period,
            })
    # Sort combined feed by date DESC (string sort works for ISO dates).
    items.sort(key=lambda x: (x.get("date") or "") + str(x.get("id") or ""),
               reverse=True)
    return {"ok": True, "items": items, "count": len(items)}


@app.get("/api/mobile/v1/transactions/{txn_id}")
def transaction_detail(txn_id: str, authorization: Optional[str] = Header(None)):
    """Detailed transaction view including the customer's plan + period.

    _S58AT_  Accept BOTH numeric id (e.g. "229") and transaction_no string
    (e.g. "CHQ230973") so the mobile list can pass either.
    """
    s = _require_auth(authorization)
    scope_sql, scope_params = _scope_clause(s)
    # _S58AT_  Decide which column to query against.
    _is_numeric = str(txn_id).isdigit()
    with _conn() as c:
        # _S58AT_  Pull company info into the same query so the receipt
        # header shows the logged-in company even when the user opens
        # a transaction directly from the Transactions tab.
        sql = ("SELECT t.id, t.amount, t.discount, t.payment_mode AS payment_method, "
               "        t.transaction_no AS reference_no, "
               "        t.paid_at AS transaction_date, "
               "        t.remarks, t.created_at, t.employee_id, "
               "        c.customer_name, c.customer_id AS cust_id, c.username, "
               "        c.customer_type, c.customer_phone AS mobile, "
               "        c.customer_email AS email, c.address, "
               "        c.start_date, c.end_date, c.period AS period_months, "
               "        p.plan_name, p.speed, p.after_tax_amount AS plan_amount, "
               "        co.company_name, co.company_phone, "
               "        co.company_address, co.upi_id AS company_upi "
               "   FROM payments t "
               "   JOIN customers c ON c.customer_id = t.customer_id "
               "   LEFT JOIN plans p ON p.id = c.plan_id "
               "   LEFT JOIN companies co ON co.company_id = c.company_id "
               f"  WHERE t.{'id' if _is_numeric else 'transaction_no'}=? "
               "    AND c.company_id=? LIMIT 1")
        params = [int(txn_id) if _is_numeric else str(txn_id), scope_params[0]]
        row = c.execute(sql, params).fetchone()
    if not row:
        raise HTTPException(404, "Transaction not found")
    d = {k: row[k] for k in row.keys()}
    sd = (d.get("start_date") or "").strip()
    ed = (d.get("end_date") or "").strip()
    def _fmt(x):
        if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
            return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
        return x or ""
    if sd and ed:
        d["formatted_period"] = f"{_fmt(sd)} to {_fmt(ed)}"
    else:
        d["formatted_period"] = ""

    # _S40zπ_v462_  Receipt-grade breakdown so the mobile UI shows
    # Renewal period / Previous due / Current due / Balance after / Last payment
    # consistent with what the receipt looked like at issue time.
    try:
        with _conn() as _c2:
            cust_id = d.get("cust_id") or d.get("customer_id")
            scope_args = scope_params  # (cid,)
            cid = scope_args[0]

            # The most recent invoice OLDER OR EQUAL to this txn date,
            # which is the one the user paid against.
            inv = _c2.execute(
                "SELECT total_amount, due_at_issue, issue_date, "
                "       start_date, end_date "
                "  FROM invoices "
                " WHERE company_id=? AND customer_id=? "
                "   AND DATE(issue_date) <= DATE(?) "
                " ORDER BY id DESC LIMIT 1",
                (cid, cust_id, d.get("transaction_date") or "")).fetchone()
            if inv:
                cur = float(inv["total_amount"] or 0)
                due = float(inv["due_at_issue"] or 0)
                # _S58AI_FIX_  Postpaid receipts must show the period of
                # the latest INVOICE that this payment was applied to —
                # not the customer's current renewal cycle (which would
                # show the *upcoming* period, which is wrong for a
                # postpaid receipt). Prepaid keeps `formatted_period`
                # (= current cycle start/end) as before.
                _cust_type = (d.get("customer_type") or "").strip().lower()
                inv_d = dict(inv) if hasattr(inv, "keys") else None
                inv_sd = (inv_d.get("start_date") if inv_d else None) or ""
                inv_ed = (inv_d.get("end_date")   if inv_d else None) or ""
                if _cust_type == "postpaid" and inv_sd and inv_ed:
                    def _f2(x):
                        if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
                            return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                        return x or ""
                    d["renewal_period"]   = f"{_f2(inv_sd)} to {_f2(inv_ed)}"
                    d["formatted_period"] = d["renewal_period"]
                else:
                    d["renewal_period"]   = d["formatted_period"]
                d["previous_balance"] = round(max(0.0, due - cur), 2)
                d["current_due"]      = round(cur, 2)
            # Balance immediately after this payment
            up_to = _c2.execute(
                "SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) "
                "  FROM payments WHERE company_id=? AND customer_id=? "
                "   AND id<=?",
                (cid, cust_id, d.get("id"))).fetchone()
            inv_total = _c2.execute(
                "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                " WHERE company_id=? AND customer_id=? "
                "   AND DATE(issue_date) <= DATE(?)",
                (cid, cust_id, d.get("transaction_date") or "")).fetchone()
            d["balance_after"] = round(max(0.0,
                float(inv_total[0] or 0) - float(up_to[0] or 0)), 2)
            # Previous payment to this one
            prev = _c2.execute(
                "SELECT amount, paid_at FROM payments "
                " WHERE company_id=? AND customer_id=? AND id<? "
                " ORDER BY id DESC LIMIT 1",
                (cid, cust_id, d.get("id"))).fetchone()
            d["last_payment_amount"] = round(float(prev["amount"]),2) if prev else 0.0
            d["last_paid_at"] = ""
            if prev and prev["paid_at"]:
                raw = str(prev["paid_at"]).strip()
                _norm = raw.replace("T", " ")
                if "+" in _norm: _norm = _norm.split("+", 1)[0].strip()
                if "Z" in _norm[10:]: _norm = _norm.replace("Z", "").strip()
                if "." in _norm: _norm = _norm.split(".", 1)[0]
                _parsed = None
                for pf in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%d %H:%M",
                           "%Y-%m-%d", "%d-%m-%Y %H:%M:%S", "%d-%m-%Y"):
                    try:
                        _parsed = datetime.strptime(_norm[:19], pf); break
                    except Exception: pass
                if _parsed:
                    d["last_paid_at"] = _parsed.strftime("%d-%m-%Y %H:%M")
                else:
                    d["last_paid_at"] = raw[:16].replace("T", " ")

            # Format this transaction's own paid_at to IST DD-MM-YYYY HH:MM.
            # Postgres returns datetime objects via the SQLAlchemy shim; older
            # rows arrive as strings ("YYYY-MM-DD HH:MM:SS") or ISO-8601 with
            # T separator + timezone (e.g. "2026-06-07T22:47:15+05:30"). Try
            # all common shapes.
            d["paid_at_fmt"] = ""
            raw = str(d.get("transaction_date") or "").strip()
            if raw:
                _parsed = None
                # Drop fractional seconds + timezone for strptime fallback.
                _norm = raw.replace("T", " ")
                if "+" in _norm: _norm = _norm.split("+", 1)[0].strip()
                if "Z" in _norm[10:]: _norm = _norm.replace("Z", "").strip()
                if "." in _norm: _norm = _norm.split(".", 1)[0]
                for pf in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%d %H:%M",
                           "%Y-%m-%d", "%d-%m-%Y %H:%M:%S", "%d-%m-%Y %H:%M",
                           "%d-%m-%Y"):
                    try:
                        _parsed = datetime.strptime(_norm[:19], pf); break
                    except Exception: pass
                if _parsed:
                    d["paid_at_fmt"] = _parsed.strftime("%d-%m-%Y %H:%M")
                else:
                    d["paid_at_fmt"] = raw[:16].replace("T", " ")
    except Exception:
        pass

    # _S58AR_ — mobile detail UI reads these specific names.
    d["txn_no"]         = d.get("reference_no")
    d["transaction_no"] = d.get("reference_no")
    d["receipt_no"]     = d.get("reference_no")
    d["payment_mode"]   = d.get("payment_method")
    d["paid_at"]        = d.get("transaction_date")
    d["previous_due"]   = d.get("previous_balance")
    d["last_paid"]      = d.get("last_payment_amount")
    d["customer_id"]    = d.get("cust_id") or d.get("customer_id")
    # _S58AT_ — Collected By must be the operator's FULL NAME for the
    # receipt header — look up by the employee_id stored on the row.
    _emp_code = d.get("employee_id") or ""
    _collector = _emp_code
    try:
        with _conn() as _cc:
            cid = scope_params[0]
            for sql in (("SELECT admin_name AS n FROM admins "
                         " WHERE admin_id=? AND company_id=? LIMIT 1"),
                        ("SELECT employee_name AS n FROM employees "
                         " WHERE employee_code=? AND company_id=? LIMIT 1"),
                        ("SELECT name AS n FROM sub_lcos "
                         " WHERE sub_lco_code=? AND company_id=? LIMIT 1")):
                _r = _cc.execute(sql, (_emp_code, cid)).fetchone()
                if _r and dict(_r).get("n"):
                    _collector = dict(_r)["n"]; break
    except Exception:
        pass
    d["collected_by"]    = _collector
    d["company_address"] = d.get("company_address")   # alias normalisation
    # _S58AT_ — paid_at_fmt was set above; make sure it's populated AND
    # last_paid_at format is consistent (DD-MM-YYYY HH:MM, never raw ISO).
    if not d.get("paid_at_fmt"):
        try:
            raw = str(d.get("transaction_date") or "").replace("T", " ")
            if "+" in raw: raw = raw.split("+", 1)[0].strip()
            if "." in raw: raw = raw.split(".", 1)[0]
            from datetime import datetime as _dt
            for pf in ("%Y-%m-%d %H:%M:%S", "%Y-%m-%d %H:%M", "%Y-%m-%d"):
                try:
                    d["paid_at_fmt"] = _dt.strptime(raw[:19], pf).strftime("%d-%m-%Y %H:%M")
                    break
                except Exception: pass
        except Exception:
            d["paid_at_fmt"] = ""
    d["paid_at"] = d.get("paid_at_fmt") or d.get("paid_at")
    # _S58AK_FLATTEN_  Return both flat fields AND the legacy wrapper.
    return {"ok": True, "transaction": d, **d}


@app.get("/api/mobile/v1/staff")
def staff_list(authorization: Optional[str] = Header(None)):
    """Return Admins + Sub-LCOs + Employees for the ticket-assign dropdown."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    out = []
    with _conn() as c:
        try:
            for r in c.execute(
                "SELECT id, admin_name AS name, admin_id AS user_id "
                "  FROM admins WHERE company_id=? ORDER BY admin_name", (cid,)
            ).fetchall():
                out.append({"id": r["id"], "name": r["name"],
                            "user_id": r["user_id"], "role": "admin"})
        except Exception:
            pass
        try:
            for r in c.execute(
                "SELECT id, name, sub_lco_id AS user_id "
                "  FROM sub_lcos WHERE company_id=? ORDER BY name", (cid,)
            ).fetchall():
                out.append({"id": r["id"], "name": r["name"],
                            "user_id": r["user_id"], "role": "sub_lco"})
        except Exception:
            pass
        try:
            for r in c.execute(
                "SELECT id, employee_name AS name, employee_id AS user_id "
                "  FROM employees WHERE company_id=? ORDER BY employee_name", (cid,)
            ).fetchall():
                out.append({"id": r["id"], "name": r["name"],
                            "user_id": r["user_id"], "role": "employee"})
        except Exception:
            pass
    return {"ok": True, "items": out}


# === S41T-FIXIP-AVAILABLE-PROXY ===
@app.get("/api/mobile/v1/fix-ip/available")
def fixip_available(pool: str = "", source: str = "pppoe",
                     include_current: str = "",
                     authorization: Optional[str] = Header(None)):
    """Proxy to admin-portal /api/fix-ip/available so the mobile Edit
    Customer 'Static IP Address' dropdown can populate dynamically when
    a pool is picked. Forwards with the internal token + company scope."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    if not pool:
        return {"ok": True, "rows": []}
    try:
        import urllib.request as _ur, urllib.parse as _up
        qs = _up.urlencode({"pool": pool, "source": source,
                            "include_current": include_current or ""})
        req = _ur.Request(
            f"{_ADMIN_PORTAL_URL}/api/fix-ip/available?{qs}",
            headers={"X-Internal-Token": _ADMIN_INTERNAL_TOKEN,
                     "X-Company-Id": cid})
        with _ur.urlopen(req, timeout=6) as resp:
            import json as _js
            return _js.loads(resp.read().decode("utf-8"))
    except Exception as e:
        print(f"[fixip-available proxy] {e}")
        return {"ok": False, "rows": [], "error": str(e)}

@app.get("/api/mobile/v1/localities")
def localities(authorization: Optional[str] = Header(None)):
    """Locality / area dropdown."""
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    with _conn() as c:
        rows = c.execute(
            "SELECT id, locality_name, city, state "
            "  FROM locations WHERE company_id=? ORDER BY locality_name", (cid,)
        ).fetchall()
    return {"ok": True, "items": [
        {"id": r["id"], "name": r["locality_name"], "city": r["city"], "state": r["state"]}
        for r in rows
    ]}


@app.get("/api/mobile/v1/invoices")
def invoices(authorization: Optional[str] = Header(None),
             q: str = "", user_type: str = "",
             locality_id: Optional[int] = None,
             limit: int = Query(100, ge=1, le=500)):
    s = _require_auth(authorization)
    cid = s.get("company_id") or ""
    scope_sql, scope_params = _scope_clause(s)
    with _conn() as c:
        # _v467_INV — alias total_amount as amount; ledger-correct due_balance.
        sql = ("SELECT i.id, i.invoice_no, i.total_amount AS amount, "
               "        i.total_amount, i.start_date, i.end_date, "
               "        i.created_at, i.issue_date, i.due_date, i.status, "
               "        c.customer_name, c.customer_id, c.customer_type, "
               "        c.customer_phone AS mobile, c.location_id, c.locality, "
               "        ( (SELECT COALESCE(SUM(total_amount),0) FROM invoices ii WHERE ii.customer_id=c.customer_id AND ii.company_id=c.company_id) "
               "          - (SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) FROM payments pp WHERE pp.customer_id=c.customer_id AND pp.company_id=c.company_id) "
               "        ) AS due_balance, "
               "        ( (SELECT COALESCE(SUM(total_amount),0) FROM invoices ii WHERE ii.customer_id=c.customer_id AND ii.company_id=c.company_id) "
               "          - (SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) FROM payments pp WHERE pp.customer_id=c.customer_id AND pp.company_id=c.company_id) "
               "        ) AS current_due "
               "   FROM invoices i "
               "   JOIN customers c ON c.customer_id = i.customer_id "
               "  WHERE 1=1 ")
        params = []
        # Re-add scope
        sub = scope_sql.replace(" WHERE company_id=?", " AND c.company_id=?", 1)
        sql += sub
        params += list(scope_params)
        if user_type and user_type.lower() not in ("all", ""):
            # _v467_FILT — DB has 'Postpaid'/'Prepaid'/'broadband'. Mobile UI sends
            # 'broadband' or 'cable_tv'. Map both correctly:
            #   broadband → matches Postpaid + Prepaid + broadband (any PPP user)
            #   cable_tv  → matches cable_tv / Cable TV / CableTV
            v = user_type.lower().replace("_", "")
            if v == "broadband":
                sql += (" AND LOWER(REPLACE(IFNULL(c.customer_type,''),' ','')) "
                        "   IN ('broadband','postpaid','prepaid','ppp') ")
            elif v in ("cabletv", "cable"):
                sql += (" AND LOWER(REPLACE(IFNULL(c.customer_type,''),' ','')) "
                        "   IN ('cabletv','cable','catv') ")
            else:
                sql += " AND LOWER(IFNULL(c.customer_type,''))=LOWER(?) "
                params.append(user_type)
        if locality_id:
            sql += " AND c.location_id=? "
            params.append(int(locality_id))
        if q:
            sql += (" AND (i.invoice_no LIKE ? OR c.customer_name LIKE ? "
                    " OR c.customer_id LIKE ?) ")
            like = f"%{q}%"
            params += [like]*3
        sql += " ORDER BY i.id DESC LIMIT ? "
        params.append(limit)
        rows = c.execute(sql, params).fetchall()
        items = [{k: r[k] for k in r.keys()} for r in rows]
    return {"ok": True, "count": len(items), "items": items}


# _v4711_ Superadmin contact for "About Us" page in the mobile app.
# Returns the single superadmin row's mobile/email/name (no auth required —
# it is intentionally a public support contact lookup).
@app.get("/api/mobile/v1/superadmin-contact")
def superadmin_contact():
    try:
        with _conn() as c:
            r = c.execute(
                "SELECT superadmin_name, email, mobile "
                "  FROM superadmins ORDER BY id ASC LIMIT 1"
            ).fetchone()
        if not r:
            return {"ok": False, "name": "", "email": "", "mobile": ""}
        return {
            "ok": True,
            "name": (r["superadmin_name"] if "superadmin_name" in r.keys() else "") or "",
            "email": (r["email"] if "email" in r.keys() else "") or "",
            "mobile": (r["mobile"] if "mobile" in r.keys() else "") or "",
        }
    except Exception as ex:
        return {"ok": False, "error": str(ex), "mobile": "", "email": "", "name": ""}



# _v4719_ME_INVOICES  Customer transactions page — combined chronological feed
# of invoices + payments with DD-MM-YYYY dates and per-row download URLs.
def _v4719_fmt_d(raw):
    s = str(raw or "").strip()
    if len(s) >= 10 and s[4] == '-' and s[7] == '-':
        return f"{s[8:10]}-{s[5:7]}-{s[:4]}"
    return s


@app.get("/api/mobile/v1/me/invoices")
def me_invoices(authorization: Optional[str] = Header(None)):
    s = _require_auth(authorization)
    if (s.get("user_type") or "") != "customer":
        raise HTTPException(403, "customer_only")
    cid   = s.get("company_id") or ""
    uname = s.get("username") or ""
    with _conn() as c:
        # _v4720_INV_PK  Resolve THIS customer by id (user_pk).
        pk_raw = s.get("user_pk") or ""
        try:
            pk_int = int(str(pk_raw)) if str(pk_raw).strip() else 0
        except Exception:
            pk_int = 0
        cust = None
        if pk_int:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE id=? AND company_id=? LIMIT 1",
                (pk_int, cid)).fetchone()
        if cust is None:
            cust = c.execute(
                "SELECT customer_id FROM customers "
                " WHERE company_id=? AND (username=? OR customer_id=?) LIMIT 1",
                (cid, uname, uname)).fetchone()
        if not cust:
            return {"ok": True, "items": [], "invoices": []}
        cust_id = cust["customer_id"]
        invoices = c.execute(
            # V4728_INV_AMT_DUE_AT_ISSUE — also fetch due_at_issue so the mobile app can
            # show TOTAL due (running balance incl. previous dues), not just
            # the current period's charge.
            "SELECT id, invoice_no, issue_date AS dt, total_amount, "
            "       due_at_issue, IFNULL(status,'Unpaid') AS status "
            "  FROM invoices WHERE company_id=? AND customer_id=? "
            " ORDER BY id DESC LIMIT 200",
            (cid, cust_id)).fetchall()
        payments = c.execute(
            "SELECT id, transaction_no, paid_at AS dt, amount, "
            "       IFNULL(payment_mode,'') AS mode "
            "  FROM payments WHERE company_id=? AND customer_id=? "
            " ORDER BY id DESC LIMIT 200",
            (cid, cust_id)).fetchall()
    # __S44B__ Resolve full invoice rows so we can drop manual adjustments
    # (rows with no plan_id AND no period dates → admin-side one-off ledger).
    with _conn() as c2:
        inv_full = c2.execute(
            "SELECT id, plan_id, start_date, end_date "
            "  FROM invoices WHERE company_id=? AND customer_id=?",
            (cid, cust_id)).fetchall()
    _inv_manual = {
        int(r["id"]): (not r["plan_id"]) and (not r["start_date"]) and (not r["end_date"])
        for r in inv_full
    }
    items = []
    for r in invoices:
        if _inv_manual.get(int(r["id"]), False):
            continue   # __S44B__ skip admin-only "one-off bill" / "manual adjustment"
        # V4728_INV_AMT_DUE_AT_ISSUE — amount shown to customer = total due at
        # issue (running balance incl. any previous dues carried forward).
        # Fall back to period total when due_at_issue is missing (legacy rows).
        _total_amt = float(r["total_amount"] or 0)
        _due_run   = float(r["due_at_issue"] or 0)
        _shown_amt = _due_run if _due_run > 0 else _total_amt
        items.append({
            "kind": "invoice",
            "id": r["id"],
            "ref": r["invoice_no"] or f"INV-{r['id']}",
            "date": _v4719_fmt_d(r["dt"]),
            "amount":           round(_shown_amt, 2),
            "total_due":        round(_shown_amt, 2),
            "period_amount":    round(_total_amt, 2),
            "previous_balance": round(max(0.0, _shown_amt - _total_amt), 2),
            "status": r["status"],
            "_sort": str(r["dt"] or ""),
            "download_url": f"/api/mobile/v1/me/invoices/{r['id']}/pdf",
        })
    _PAY_MANUAL_RX = ("plan upgrade", "adjustment", "credit note",
                       "manual credit", "manual debit", "internal")
    for r in payments:
        _mode_lc = (r["mode"] or "").strip().lower()
        # remarks isn't selected — fetch lazily only when mode is ambiguous.
        if any(k in _mode_lc for k in _PAY_MANUAL_RX):
            continue
        items.append({
            "kind": "payment",
            "id": r["id"],
            "ref": r["transaction_no"] or f"PAY-{r['id']}",
            "date": _v4719_fmt_d(r["dt"]),
            "amount": round(float(r["amount"] or 0), 2),
            "status": "Paid",
            "mode": r["mode"],
            "_sort": str(r["dt"] or ""),
            "download_url": f"/api/mobile/v1/me/payments/{r['id']}/pdf",
        })
    items.sort(key=lambda x: x["_sort"], reverse=True)
    for it in items:
        it.pop("_sort", None)
    # Back-compat: legacy clients read `.invoices`.
    return {"ok": True, "items": items,
            "invoices": [i for i in items if i["kind"] == "invoice"]}

def _v4719_fetch_pdf(url: str):
    """Stream a PDF response from the localhost admin-portal.  Returns
    a 200 with the PDF on success, or a structured JSON error otherwise."""
    import requests as _r, json as _json
    from fastapi.responses import Response as _Resp
    try:
        r = _r.get(url, timeout=30)
        if r.status_code == 200 and (r.headers.get("content-type") or "").startswith(
                ("application/pdf", "application/octet-stream")):
            return _Resp(content=r.content, media_type="application/pdf")
        # _v4720_PDF_ERR  Surface whatever the admin portal said as JSON.
        detail = "pdf_unavailable"
        try:
            j = r.json(); detail = j.get("detail") or detail
        except Exception:
            detail = (r.text or "")[:300] or detail
        return _Resp(
            content=_json.dumps({"ok": False, "status": r.status_code,
                                  "detail": detail}).encode(),
            status_code=502, media_type="application/json")
    except Exception as e:
        return _Resp(
            content=_json.dumps({"ok": False, "detail": f"pdf_error: {e}"}).encode(),
            status_code=502, media_type="application/json")

