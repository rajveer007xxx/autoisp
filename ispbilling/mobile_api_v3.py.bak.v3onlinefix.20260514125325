# _v4729_ADMIN_ONLY  Reject writes from sub_lco / employee on OLT/ONU.
def _v4729_require_admin(s):
    ut = (s.get("user_type") or "").lower()
    if ut == "admin":
        return
    raise HTTPException(403, "admin_only: OLT and ONU writes are restricted to admins.")


