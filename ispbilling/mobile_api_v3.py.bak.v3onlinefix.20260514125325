    # _v469_ME_UPI_LINK — Customer-self UPI deep-link + bank details + QR.
    @app.get("/api/mobile/v1/me/upi-link")
    def me_upi_link(authorization: Optional[str] = Header(None)):
        # _v473_UPI_FIX  Use the same id-resolution as /me.
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        cust_id = (s.get("customer_id") or s.get("username")
                   or s.get("user_id") or "")
        cust_pk = s.get("user_pk")
        if (s.get("user_type") or "").lower() != "customer" and not cust_id:
            return {"ok": False, "error": "not_a_customer"}
        with DB() as c:
            row = c.execute(
                "SELECT customer_id, customer_name, customer_phone AS mobile FROM customers "
                "WHERE company_id=? AND (customer_id=? OR username=? OR id=?) LIMIT 1",
                (cid, cust_id, cust_id, cust_pk)).fetchone()
            if not row: return {"ok": False, "error": "customer_not_found"}
            inv  = c.execute("SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                             "WHERE company_id=? AND customer_id=?",
                             (cid, row["customer_id"])).fetchone()[0]
            pay  = c.execute("SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) FROM payments "
                             "WHERE company_id=? AND customer_id=?",
                             (cid, row["customer_id"])).fetchone()[0]
            # _v473b_UPI_FALLBACK  company_settings table is optional in older
            # tenants — fall back to the canonical 'companies' row.
            comp = None
            try:
                comp = c.execute("SELECT upi_id, business_name, account_name, account_number, "
                                 "       ifsc_code, bank_name, branch_name, payment_qr_url, "
                                 "       checkout_url "
                                 "FROM company_settings WHERE company_id=? LIMIT 1",
                                 (cid,)).fetchone()
            except Exception:
                comp = None
            if not comp:
                try:
                    cr = c.execute(
                        "SELECT upi_id, company_name AS business_name, "
                        "       company_name AS account_name, "
                        "       account_number, branch_ifsc AS ifsc_code, "
                        "       bank_name, branch_location AS branch_name, "
                        "       bank_qr_code AS payment_qr_url, "
                        "       NULL AS checkout_url "
                        "FROM companies WHERE company_id=? LIMIT 1",
                        (cid,)).fetchone()
                    comp = cr
                except Exception:
                    comp = None
        amount = max(0.0, round(float(inv or 0) - float(pay or 0), 2))
        upi_id = (comp or {}).get("upi_id") if isinstance(comp, dict) else (comp["upi_id"] if comp else "")
        payee  = (comp or {}).get("business_name") if isinstance(comp, dict) else (comp["business_name"] if comp else "AutoISP")
        if not upi_id: upi_id = ""
        try:
            from urllib.parse import quote
            tr = f"AISPB{int(_now_ist_iso().replace('-','').replace(':','').replace(' ','')[:14])}"
        except Exception: tr = "AISPB"
        url = (f"upi://pay?pa={upi_id}&pn={quote(payee or 'AutoISP')[:40]}&am={amount:.2f}&cu=INR&tr={tr}"
               if upi_id else "")
        bank = None
        if comp:
            d = dict(comp) if not isinstance(comp, dict) else comp
            bank = {
                "account_name":  d.get("account_name"),
                "account_number":d.get("account_number"),
                "ifsc":          d.get("ifsc_code"),
                "bank_name":     d.get("bank_name"),
                "branch":        d.get("branch_name"),
            }
        qr_url = ((comp or {}).get("payment_qr_url")
                  if isinstance(comp, dict) else (comp["payment_qr_url"] if comp else None))
        # __QR_URL_ABS_FIX__  Mobile <Image> needs an absolute URL — if the DB
        # row stores a relative path (legacy uploads), prefix the public host.
        if qr_url and isinstance(qr_url, str) and not qr_url.lower().startswith(("http://", "https://")):
            qr_url = "https://www.autoispbilling.com/" + qr_url.lstrip("/")
        # _v470_ — build checkout URL with the customer's cust_id pre-filled
        # so they don't have to type it on the payment page.
        _co_base = ((comp or {}).get("checkout_url")
                    if isinstance(comp, dict) else (comp["checkout_url"] if comp else None))
        if not _co_base:
            _co_base = "https://www.autoispbilling.com/pay"
        sep = "&" if ("?" in _co_base) else "?"
        checkout_url = f"{_co_base}{sep}cust_id={row['customer_id']}&amount={amount:.2f}"
        checkout_url_old = ((comp or {}).get("checkout_url")
                        if isinstance(comp, dict) else (comp["checkout_url"] if comp else None))
        return {"ok": True, "upi_url": url, "upi_id": upi_id,
                "amount": amount, "qr_url": qr_url, "bank": bank,
                "checkout_url": checkout_url}

