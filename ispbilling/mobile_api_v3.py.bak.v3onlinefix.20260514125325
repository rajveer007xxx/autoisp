    @app.post("/api/mobile/v1/subscribers/{cust_pk}/status")
    def status_toggle2(cust_pk: int, body: dict = Body(...),
                       authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        action = (body or {}).get("action", "").lower()
        with DB() as c:
            cur = c.execute("SELECT status FROM customers WHERE company_id=? AND id=?",
                            (cid, cust_pk)).fetchone()
            current = (cur and cur["status"]) or "Active"
            # _S40zπ_MOBILE_FIX_  Toggle correctly even when called repeatedly.
            if action in ("disable", "deactivate"):
                new_status = "Disabled"
            elif action in ("enable", "activate"):
                new_status = "Active"
            else:
                # toggle
                new_status = "Active" if str(current).lower() == "disabled" else "Disabled"
            # _v465_ — When re-enabling an Expired account, extend end_date by
            # the customer's plan period so it doesn't immediately revert.
            extend_sql = ""
            extend_args = []
            if new_status == "Active" and (cur and (cur["status"] or "").lower() in ("expired", "disabled")):
                # Take period_months from the customer row (default 1).
                pr = c.execute("SELECT COALESCE(period,1) AS p FROM customers WHERE id=? AND company_id=?",
                               (cust_pk, cid)).fetchone()
                _months = int(pr["p"] or 1) if pr else 1
                extend_sql = ", start_date=date('now','localtime'), end_date=date('now','localtime','+'||?||' months')"
                extend_args = [_months]
            c.execute(f"UPDATE customers SET status=?, updated_at=?{extend_sql} "
                      " WHERE company_id=? AND id=?",
                      [new_status, _now_ist_iso()] + extend_args + [cid, cust_pk])
            c.commit()
        return {"ok": True, "status": new_status, "previous_status": current,
                "id": cust_pk, "is_active": new_status == "Active"}

