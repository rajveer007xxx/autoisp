                   location: str = "",
                   customer_type: str = "",
                   from_: str = Query("", alias="from"),
                   to:    str = "",
                   authorization: Optional[str] = Header(None)):
        """Generic 'run report' endpoint used by the mobile UI for every
        report type other than 'collections' (which has its own richer
        endpoint with chart data). Always returns:
            { ok: True, rows: [ {field: value, ...}, ... ] }

        Supported types:
          • amount_dues             — customers with positive bill_due
          • complaints              — tickets/complaints in the duration
          • subscriber_transactions — payments in the duration
          • total_subscribers       — all active subscribers (ignores duration)
          • nearby_expiry           — subscribers expiring in next 7 days
        """
        s = _require_auth(authorization)
        cid = s.get("company_id") or ""
        # ---- Date range (matches reports/collections semantics) ----
        now = datetime.now(_IST).replace(tzinfo=None)
        if duration == "today":
            d0 = now.strftime("%Y-%m-%d 00:00:00")
        elif duration == "yesterday":
            d0 = (now - timedelta(days=1)).strftime("%Y-%m-%d 00:00:00")
        elif duration == "this_week":
            d0 = (now - timedelta(days=now.weekday())).strftime("%Y-%m-%d 00:00:00")
        elif duration == "last_month":
            first = now.replace(day=1) - timedelta(days=1)
            d0 = first.strftime("%Y-%m-01 00:00:00")
        elif duration == "this_year":
            d0 = now.strftime("%Y-01-01 00:00:00")
        elif duration == "all":  # _v4713_  Whole-history bypass.
            d0 = "1970-01-01 00:00:00"
        else:  # this_month (default)
            d0 = now.strftime("%Y-%m-01 00:00:00")
        d1 = (now + timedelta(days=1)).strftime("%Y-%m-%d 00:00:00")
        # _v4715_RANGE_BE  Custom range overrides (d0, d1).
        if duration == "custom":
            _r = _v4715_parse_range(from_, to)
            if _r: d0, d1 = _r
        scope_sql, scope_args = _scope_and(s, cust_alias="c")
        utf, utp = _user_type_filter(customer_type)

        rows = []
