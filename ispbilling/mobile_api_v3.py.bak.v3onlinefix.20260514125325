    # ─────────── ONU location endpoint (Phase C — mobile) ───────────
    # POST /api/mobile/v1/onus/{onu_id}/location
    # Body:
    #   { "lat": float, "lng": float,                # explicit coords
    #     "accuracy_m": float?,
    #     "source": "gps" | "manual" }
    #  -- OR --
    #   { "use_customer_address": true }             # auto-place at
    #     # customer's geocoded coords (customers.lat/lng).
    @app.post("/api/mobile/v1/onus/{onu_id}/location")
    def onu_set_location(onu_id: int, body: dict = Body(default={}),
                         authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization)

        _v4729_require_admin(s)
        cid = s.get("company_id") or ""
        actor = (s.get("user_name") or s.get("user_id")
                 or s.get("username") or "mobile")
        with DB() as c:
            row = c.execute(
                "SELECT customer_id FROM onus WHERE id=? AND company_id=?",
                (onu_id, cid)).fetchone()
            if not row:
                raise HTTPException(404, "ONU not found")
            cust_id = row["customer_id"] or ""

            # Resolve coords
            lat = body.get("lat")
            lng = body.get("lng")
            source = (body.get("source") or "gps").lower()
            if body.get("use_customer_address"):
                if not cust_id:
                    raise HTTPException(400,
                        "ONU has no linked customer to copy address from")
                # _v4733_  Read both column families (legacy ORM writes
                # latitude/longitude, mobile schema uses lat/lng). Prefer
                # whichever is non-null. Backfill on read for self-heal.
                cr = c.execute(
                    "SELECT lat, lng, latitude, longitude FROM customers "
                    " WHERE company_id=? AND customer_id=?",
                    (cid, cust_id)).fetchone()
                _lat = cr["lat"] if cr and cr["lat"] is not None else (cr["latitude"] if cr else None)
                _lng = cr["lng"] if cr and cr["lng"] is not None else (cr["longitude"] if cr else None)
                if _lat is None or _lng is None:
                    raise HTTPException(400,
                        "Customer has no geocoded coordinates yet")
                # Self-heal: if only the legacy pair was populated, copy
                # over to lat/lng now so future reads don't need this fallback.
                if cr and (cr["lat"] is None or cr["lng"] is None):
                    try:
                        c.execute(
                            "UPDATE customers SET lat=?, lng=? "
                            " WHERE company_id=? AND customer_id=?",
                            (float(_lat), float(_lng), cid, cust_id))
                        c.commit()
                    except Exception: pass
                lat, lng, source = _lat, _lng, "address"
            try:
                lat = float(lat); lng = float(lng)
            except Exception:
                raise HTTPException(400, "lat/lng required (numeric)")
            if not (-90 <= lat <= 90) or not (-180 <= lng <= 180):
                raise HTTPException(400, "lat/lng out of range")
            try:
                accuracy = float(body.get("accuracy_m"))                     if body.get("accuracy_m") is not None else None
            except Exception:
                accuracy = None
            if source not in ("gps", "manual", "address"):
                source = "manual"

            c.execute(
                "UPDATE onus "
                "   SET lat=?, lng=?, location_accuracy_m=?, "
                "       location_source=?, location_set_at=datetime('now'), "
                "       location_set_by=? "
                " WHERE id=? AND company_id=?",
                (lat, lng, accuracy, source, str(actor), onu_id, cid))
            c.commit()

        # _v4734_inline_upsert_pin  Self-contained mirror (mobile-api lives in a
        # different process than admin-portal, so cross-module helper imports
        # are unreliable). Keeps logic identical to admin-portal's helper.
        try:
            import json as _jpin
            with DB() as _c2:
                _row = _c2.execute(
                    "SELECT o.id, o.olt_id, o.serial, o.mac, o.status, "
                    "       o.rx_power, o.tx_power, o.pon_port_index, "
                    "       o.customer_id, c.customer_name, c.customer_phone "
                    "  FROM onus o LEFT JOIN customers c "
                    "       ON c.customer_id=o.customer_id "
                    "      AND c.company_id=o.company_id "
                    " WHERE o.id=? AND o.company_id=? LIMIT 1",
                    (onu_id, cid)).fetchone()
                if _row:
                    _cust_id = _row[8] or ""
                    _cust_nm = _row[9] or _row[2] or ("ONU-" + str(onu_id))
                    if _cust_id:
                        _nm = _cust_nm + " (" + _cust_id + ")"
                    else:
                        _nm = "ONU-" + str(onu_id) + " (" + (_row[2] or "no-sn") + ")"
                    _props = {
                        "customer_id":    _cust_id,
                        "customer_name":  _row[9] or "",
                        "customer_phone": _row[10] or "",
                        "status":         _row[4] or "Pending",
                        "modem_no":       _row[2] or "",
                        "mac_address":    _row[3] or "",
                        "rx_power":       _row[5] or "",
                        "tx_power":       _row[6] or "",
                        "pon_port":       _row[7] or "",
                        "olt_id":         _row[1] or "",
                        "source":         source,
                        "auto":           True,
                    }
                    _hw_kind = "onu"
                    _ex = _c2.execute(
                        "SELECT id FROM network_hardware "
                        " WHERE company_id=? AND kind=? AND ref_onu_id=? LIMIT 1",
                        (cid, _hw_kind, onu_id)).fetchone()
                    if _ex:
                        _c2.execute(
                            "UPDATE network_hardware SET "
                            "  name=?, lat=?, lng=?, "
                            "  ref_olt_id=?, ref_onu_id=?, "
                            "  props_json=?, updated_at=CURRENT_TIMESTAMP "
                            " WHERE id=?",
                            (_nm, float(lat), float(lng),
                             _row[1], onu_id,
                             _jpin.dumps(_props, ensure_ascii=False),
                             _ex[0]))
                    else:
                        _c2.execute(
                            "INSERT INTO network_hardware "
                            " (company_id, kind, name, lat, lng, "
                            "  ref_olt_id, ref_onu_id, props_json, created_by) "
                            " VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)",
                            (cid, _hw_kind, _nm,
                             float(lat), float(lng),
                             _row[1], onu_id,
                             _jpin.dumps(_props, ensure_ascii=False),
                             str(actor)))
                    _c2.commit()
                    print("[mobile onu/location] hw pin upserted for ONU " + str(onu_id))
        except Exception as _ue:
            print("[mobile onu/location] hw-pin mirror failed (non-fatal): " + str(_ue))
        return {"ok": True, "lat": lat, "lng": lng,
                "source": source, "onu_id": onu_id}

