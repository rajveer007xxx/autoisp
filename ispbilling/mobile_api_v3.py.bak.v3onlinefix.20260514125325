    # _v471_TXN_EXPORT  Transactions export (xlsx / pdf) for the caller's scope
    @app.get("/api/mobile/v1/transactions-export")
    def transactions_export(fmt: str = Query("xlsx", pattern="^(xlsx|pdf)$"),
                            customer_id: str = "",
                            duration: str = "this_month",
                            # _v4713_  Honour the same filters as the list view.
                            q: str = "",
                            customer_type: str = "",
                            locality: str = "",
                            # _v4715_  Custom date range (DD-MM-YYYY).
                            from_: str = Query("", alias="from"),
                            to:    str = "",
                            t: Optional[str] = None,
                            authorization: Optional[str] = Header(None)):
        # Accept JWT via ?t= for plain browser downloads
        if not authorization and t:
            authorization = f"Bearer {t}"
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        ut  = (s.get("user_type") or "").lower()
        cust_self = s.get("customer_id") or ""
        # Date range
        now = datetime.now(_IST).replace(tzinfo=None)
        if duration == "today":
            d0 = now.strftime("%Y-%m-%d 00:00:00")
        elif duration == "this_week":
            d0 = (now - timedelta(days=now.weekday())).strftime("%Y-%m-%d 00:00:00")
        elif duration == "last_month":
            first = now.replace(day=1) - timedelta(days=1)
            d0 = first.strftime("%Y-%m-01 00:00:00")
        elif duration == "this_year":
            d0 = now.strftime("%Y-01-01 00:00:00")
        elif duration == "all":
            d0 = "1970-01-01 00:00:00"
        else:
            d0 = now.strftime("%Y-%m-01 00:00:00")
        d1 = (now + timedelta(days=1)).strftime("%Y-%m-%d 00:00:00")
        # _v4715_RANGE_BE
        if duration == "custom":
            _r = _v4715_parse_range(from_, to)
            if _r: d0, d1 = _r

        # Build query (customer scope by role)
        sql = ("SELECT p.transaction_no, p.amount, p.discount, p.payment_mode, "
               "       p.paid_at, c.customer_id, c.customer_name, c.customer_phone "
               "  FROM payments p "
               "  LEFT JOIN customers c ON c.customer_id=p.customer_id AND c.company_id=p.company_id "
               " WHERE p.company_id=? AND p.paid_at>=? AND p.paid_at<? ")
        args = [cid, d0, d1]
        if ut == "customer" and cust_self:
            sql += " AND p.customer_id=? "; args.append(cust_self)
        elif ut in ("sub_lco", "employee"):
            sc, sa = _scope_and(s, cust_alias="c")
            sql += sc; args += sa
        if customer_id:
            sql += " AND p.customer_id=? "; args.append(customer_id)
        # _v4713_  Apply the same filters the UI shows.
        if q:
            sql += (" AND (p.transaction_no LIKE ? OR c.customer_name LIKE ? "
                    "      OR c.customer_id LIKE ? OR c.customer_phone LIKE ?) ")
            like = f"%{q}%"
            args += [like, like, like, like]
        if customer_type:
            utf2, utp2 = _user_type_filter(customer_type)
            if utf2:
                sql += utf2; args += utp2
        if locality:
            sql += " AND c.locality=? "; args.append(locality)
        sql += " ORDER BY p.id DESC LIMIT 5000"
        with DB() as c:
            rows = [dict(r) for r in c.execute(sql, args).fetchall()]

        # Render
        if fmt == "xlsx":
            try:
                import openpyxl
                from openpyxl import Workbook
                wb = Workbook(); ws = wb.active; ws.title = "Transactions"
                ws.append(["Txn No", "Date", "Customer ID", "Customer Name",
                           "Mobile", "Amount", "Discount", "Mode"])
                for r in rows:
                    ws.append([
                        r.get("transaction_no") or "",
                        _fmt_paid_at(r.get("paid_at")),
                        r.get("customer_id") or "",
                        r.get("customer_name") or "",
                        r.get("customer_phone") or "",
                        float(r.get("amount") or 0),
                        float(r.get("discount") or 0),
                        r.get("payment_mode") or "",
                    ])
                from io import BytesIO
                buf = BytesIO(); wb.save(buf); buf.seek(0)
                from fastapi.responses import Response as _Resp
                return _Resp(content=buf.read(),
                    media_type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                    headers={"content-disposition": 'attachment; filename="transactions.xlsx"'})
            except Exception as e:
                raise HTTPException(500, f"xlsx_render_failed: {e}")
        # PDF
        try:
            from reportlab.lib.pagesizes import A4
            from reportlab.pdfgen import canvas as _canvas
            from io import BytesIO
            buf = BytesIO()
            c2 = _canvas.Canvas(buf, pagesize=A4)
            w, h = A4
            y = h - 40
            c2.setFont("Helvetica-Bold", 14)
            c2.drawString(40, y, "Transactions Report")
            y -= 20; c2.setFont("Helvetica", 9)
            c2.drawString(40, y, f"Period: {d0[:10]} to {d1[:10]}   Total: {len(rows)}")
            y -= 16; c2.setFont("Helvetica-Bold", 9)
            c2.drawString(40, y, "Date           Txn No         Customer                Amt    Disc  Mode")
            y -= 12; c2.setFont("Helvetica", 8)
            for r in rows:
                if y < 40:
                    c2.showPage(); y = h - 40; c2.setFont("Helvetica", 8)
                line = (
                    f"{(_fmt_paid_at(r.get('paid_at')) or '')[:16]:16s} "
                    f"{(r.get('transaction_no') or '')[:14]:14s} "
                    f"{(r.get('customer_name') or '')[:22]:22s} "
                    f"{float(r.get('amount') or 0):7.0f} "
                    f"{float(r.get('discount') or 0):5.0f} "
                    f"{(r.get('payment_mode') or '')[:6]:6s}"
                )
                c2.drawString(40, y, line); y -= 11
            c2.save(); buf.seek(0)
            from fastapi.responses import Response as _Resp
            return _Resp(content=buf.read(), media_type="application/pdf",
                headers={"content-disposition": 'attachment; filename="transactions.pdf"'})
        except Exception as e:
            raise HTTPException(500, f"pdf_render_failed: {e}")


