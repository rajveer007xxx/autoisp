                (cid, pk, uname, uname)).fetchone()
            if not cust:
                return {"success": True, "items": []}
            sub_lco_id = cust["sub_lco_id"] or 0
            emp_id     = cust["created_by_employee_id"] or 0

            # 1) Admin(s) of the customer's company.
            for r in c.execute(
                "SELECT admin_id, admin_name, admin_mobile, admin_email "
                "  FROM admins WHERE company_id=? ORDER BY id ASC",
                (cid,)).fetchall():
                items.append({
                    "role": "admin",
                    "role_label": "Service Provider",
                    "name": r["admin_name"] or r["admin_id"] or "Admin",
                    "phone": r["admin_mobile"] or "",
                    "email": r["admin_email"] or "",
                    "address": "",
                })

            # 2) Sub-LCO (if assigned).
            if sub_lco_id:
                r = c.execute(
                    "SELECT name, mobile, email, address, status "
                    "  FROM sub_lcos WHERE id=? AND company_id=?",
                    (sub_lco_id, cid)).fetchone()
                if r and (r["status"] or "Active") != "Inactive":
                    items.append({
                        "role": "sub_lco",
                        "role_label": "Sub-LCO / Local Partner",
                        "name": r["name"] or "Sub-LCO",
                        "phone": r["mobile"] or "",
                        "email": r["email"] or "",
                        "address": r["address"] or "",
                    })

            # 3) Employee who created the customer (if any).
            if emp_id:
                r = c.execute(
                    "SELECT employee_name, mobile, email, address "
                    "  FROM employees "
                    " WHERE id=? AND company_id=? "
                    "   AND COALESCE(is_deleted,0)=0",
                    (emp_id, cid)).fetchone()
                if r:
                    items.append({
                        "role": "employee",
                        "role_label": "Field Engineer",
                        "name": r["employee_name"] or "Employee",
                        "phone": r["mobile"] or "",
                        "email": r["email"] or "",
                        "address": r["address"] or "",
                    })

        return {"success": True, "items": items}

