    # _v4715_PWRESET  Forgot-password OTP flow (mobile-friendly, no captcha).
    # ──────────────────────────────────────────────────────────────────────
    # Step 1: POST /auth/forgot-password   { user_type, company_id?, identifier }
    #   → Looks up the user, sends a 6-digit OTP to the registered email
    #     via the superadmin/company SMTP (existing infra used by /api/auth/
    #     password-reset/request on the admin portal).  Always returns a
    #     generic message so we don't leak which IDs exist.
    # Step 2: POST /auth/reset-password    { user_type, company_id?, identifier,
    #                                       otp, new_password }
    #   → Verifies OTP (single-use, 30-minute TTL) and writes the new
    #     password back to the right table using each portal's existing hash.
    import hashlib as _hashlib_v4715
    import secrets as _sec_v4715
    import smtplib as _smtplib_v4715, ssl as _ssl_v4715
    from email.message import EmailMessage as _Em_v4715

    def _v4715_lookup_user(c, user_type: str, company_id: str, identifier: str):
        """Returns (row_dict, email, subject_id_for_otp_row) or None."""
        ut = (user_type or "").lower().strip()
        ident = (identifier or "").strip()
        if ut == "admin":
            r = c.execute(
                "SELECT id, admin_id AS code, admin_name AS name, "
                "       admin_email AS email FROM admins "
                " WHERE company_id=? AND admin_id=? LIMIT 1",
                (company_id, ident)).fetchone()
        elif ut == "sub_lco":
            r = c.execute(
                "SELECT id, sub_lco_code AS code, name, email FROM sub_lcos "
                " WHERE company_id=? AND sub_lco_code=? LIMIT 1",
                (company_id, ident)).fetchone()
        elif ut == "employee":
            r = c.execute(
                "SELECT id, employee_code AS code, employee_name AS name, email "
                "  FROM employees WHERE company_id=? AND employee_code=? LIMIT 1",
                (company_id, ident)).fetchone()
        elif ut == "customer":
            # Identifier may be customer_id OR username OR mobile OR email.
            r = c.execute(
                "SELECT id, customer_id AS code, customer_name AS name, "
                "       customer_email AS email FROM customers "
                " WHERE (customer_id=? OR username=? OR customer_phone=? "
                "        OR customer_email=?) LIMIT 1",
                (ident, ident, ident, ident)).fetchone()
        else:
            return None
        if not r: return None
        d = dict(r)
        return d, (d.get("email") or "").strip(), d.get("code") or ident

    def _v4715_send_otp_email(to_email: str, otp: str, name: str = "") -> str:
        """Send the OTP via SMTP (superadmin row).  Returns '' on success."""
        try:
            with DB() as c:
                sa = c.execute(
                    "SELECT smtp_server, smtp_port, smtp_username, smtp_password "
                    "  FROM superadmins WHERE COALESCE(smtp_server,'')!='' "
                    " ORDER BY id LIMIT 1").fetchone()
            if not sa or not sa["smtp_username"] or not sa["smtp_password"]:
                return "No SMTP configured on the superadmin profile."
            host = sa["smtp_server"]; port = int(sa["smtp_port"] or 587)
            user = sa["smtp_username"]; pwd  = sa["smtp_password"]
            m = _Em_v4715()
            m["Subject"] = "AutoISP Billing — Password reset OTP"
            m["From"]    = user
            m["To"]      = to_email
            m.set_content(
                f"Hi {name or 'there'},\n\n"
                f"Your AutoISP Billing password-reset OTP is:\n\n"
                f"    {otp}\n\n"
                f"It expires in 30 minutes.  If you didn't request this, ignore this email."
            )
            if port == 465:
                with _smtplib_v4715.SMTP_SSL(host, port, timeout=20) as srv:
                    srv.login(user, pwd); srv.send_message(m)
            else:
                with _smtplib_v4715.SMTP(host, port, timeout=20) as srv:
                    srv.starttls(context=_ssl_v4715.create_default_context())
                    srv.login(user, pwd); srv.send_message(m)
            return ""
        except Exception as e:
            return f"SMTP failed: {e}"

    @app.post("/api/mobile/v1/auth/forgot-password")
    def _v4715_forgot_password(body: dict = Body(...)):
        ut    = (body.get("user_type") or "").strip().lower()
        cid   = (body.get("company_id") or "").strip()
        ident = (body.get("identifier") or "").strip()
        if not ident or ut not in ("admin", "sub_lco", "employee", "customer"):
            raise HTTPException(400, "missing_fields")
        if ut != "customer" and not cid:
            raise HTTPException(400, "company_id_required")
        with DB() as c:
            res = _v4715_lookup_user(c, ut, cid, ident)
            generic = {"ok": True,
                "message": "If an account matches, an OTP was sent to the registered email."}
            if not res or not res[1]:
                return generic
            row, email, subject_id = res
            # Rate limit — 3 / hour per email.
            rc = c.execute(
                "SELECT COUNT(*) FROM password_resets "
                " WHERE email=? AND created_at >= datetime('now','-1 hour')",
                (email,)).fetchone()
            if rc and rc[0] >= 3:
                raise HTTPException(429, "too_many_otp_requests")
            otp = "".join(_sec_v4715.choice("0123456789") for _ in range(6))
            c.execute("INSERT INTO password_resets "
                      "(email, user_type, otp_code, expires_at, is_used, created_at, "
                      " company_id, subject_id) "
                      "VALUES (?,?,?, datetime('now','+30 minutes'), 0, datetime('now'), ?, ?)",
                      (email, ut, otp, cid, subject_id))
            c.commit()
        err = _v4715_send_otp_email(email, otp, name=row.get("name") or "")
        if err:
            # Don't leak which user — but DO tell the caller SMTP is broken.
            return {"ok": False, "message": err}
        # Mask the email for the UI.
        try:
            local, dom = email.split("@", 1)
            masked = (local[0] + "***" + local[-1] + "@" + dom) if len(local) >= 2 else email
        except Exception:
            masked = email
        return {"ok": True, "masked_email": masked,
                "message": f"OTP sent to {masked}.  It expires in 30 minutes."}

    @app.post("/api/mobile/v1/auth/reset-password")
    def _v4715_reset_password(body: dict = Body(...)):
        ut       = (body.get("user_type") or "").strip().lower()
        cid      = (body.get("company_id") or "").strip()
        ident    = (body.get("identifier") or "").strip()
        otp      = (body.get("otp") or "").strip()
        new_pw   = (body.get("new_password") or "").strip()
        if not (ident and otp and new_pw):
            raise HTTPException(400, "missing_fields")
        if len(new_pw) < 6:
            raise HTTPException(400, "password_too_short")
        with DB() as c:
            res = _v4715_lookup_user(c, ut, cid, ident)
            if not res or not res[1]:
                raise HTTPException(400, "invalid_otp_or_user")
            row, email, subject_id = res
            r = c.execute(
                "SELECT id FROM password_resets "
                " WHERE email=? AND user_type=? AND otp_code=? AND is_used=0 "
                "   AND expires_at >= datetime('now') "
                " ORDER BY id DESC LIMIT 1",
                (email, ut, otp)).fetchone()
            if not r:
                raise HTTPException(400, "invalid_otp_or_user")
            # Hash strategy per portal — match each table's existing convention.
            try:
                from passlib.hash import bcrypt as _bcrypt
                new_hash = _bcrypt.hash(new_pw)
            except Exception:
                new_hash = _hashlib_v4715.sha256(new_pw.encode()).hexdigest()
            if ut == "admin":
                c.execute("UPDATE admins SET password_hash=? "
                          " WHERE id=?", (new_hash, row["id"]))
            elif ut == "sub_lco":
                c.execute("UPDATE sub_lcos SET password_hash=? "
                          " WHERE id=?", (new_hash, row["id"]))
            elif ut == "employee":
                c.execute("UPDATE employees SET password_hash=? "
                          " WHERE id=?", (new_hash, row["id"]))
            elif ut == "customer":
                c.execute("UPDATE customers SET password_hash=? "
                          " WHERE id=?", (new_hash, row["id"]))
            c.execute("UPDATE password_resets SET is_used=1 WHERE id=?", (r["id"],))
            c.commit()
        return {"ok": True, "message": "Password updated.  Please sign in."}
