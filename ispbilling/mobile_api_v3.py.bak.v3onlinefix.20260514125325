    @app.post("/api/mobile/v1/pay")
    def pay(body: dict = Body(...),
            authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        cust_pk = int(body.get("customer_pk") or 0)
        amount  = float(body.get("amount") or 0)
        discount= float(body.get("discount") or 0)
        mode    = body.get("payment_mode") or "Cash"
        remarks = body.get("remarks") or body.get("note") or ""
        txn_no  = body.get("txn_no") or f"{mode[:3].upper()}-{int(time.time()*1000)}"
        if cust_pk <= 0 or amount <= 0:
            raise HTTPException(400, "missing_amount_or_customer")
        # Resolve collector full name from session role
        with DB() as c:
            cust = c.execute(
                "SELECT * FROM customers WHERE id=? AND company_id=?",
                (cust_pk, cid)).fetchone()
            if not cust: raise HTTPException(404, "customer_not_found")
            # collector full name
            role = s.get("user_type") or ""
            collector_full = s.get("username") or ""
            collector_code = collector_full
            if role == "admin":
                r = c.execute("SELECT admin_name, admin_id FROM admins "
                              " WHERE id=? AND company_id=?",
                              (s.get("user_pk") or s.get("user_id"), cid)).fetchone()
                if r: collector_full = r["admin_name"] or r["admin_id"]; collector_code = r["admin_id"]
            elif role == "sub_lco":
                r = c.execute("SELECT name, sub_lco_code FROM sub_lcos "
                              " WHERE id=? AND company_id=?",
                              (s.get("user_pk") or s.get("user_id"), cid)).fetchone()
                if r: collector_full = r["name"]; collector_code = r["sub_lco_code"]
            elif role == "employee":
                r = c.execute("SELECT employee_name, employee_code FROM employees "
                              " WHERE id=? AND company_id=?",
                              (s.get("user_pk") or s.get("user_id"), cid)).fetchone()
                if r: collector_full = r["employee_name"]; collector_code = r["employee_code"]
            now_iso = _now_ist_iso()
            # _S39R5O — Discount-as-credit semantics:
            #   Cash collected (payments.amount) = amount user entered (no
            #     reduction by discount). discount stored on the row.
            #   customers.received_amount   += amount   (what cash entered)
            #   customers.discount_credit   += discount (grace credit)
            #   So total balance reduction  = amount + discount.
            cash_paid = round(amount, 2)
            disc      = round(discount, 2)
            credit    = round(cash_paid + disc, 2)
            c.execute("""
                INSERT INTO payments(company_id, customer_id, employee_id, amount,
                       discount, payment_mode, transaction_no, paid_at, remarks,
                       created_at, updated_at)
                VALUES (?,?,?,?,?,?,?,?,?,?,?)
            """, (cid, cust["customer_id"], collector_code, cash_paid, disc, mode,
                  txn_no, now_iso, remarks, now_iso, now_iso))
            # Update customer received_amount + discount_credit
            c.execute("UPDATE customers "
                      "   SET received_amount = COALESCE(received_amount,0) + ?, "
                      "       discount_credit = COALESCE(discount_credit,0) + ? "
                      " WHERE id=? AND company_id=?",
                      (cash_paid, disc, cust_pk, cid))
            c.commit()
            # _S40zM_ Auto-email receipt (best-effort; HTTP to admin helper).
            try:
                _pay_id_r = c.execute(
                    "SELECT id FROM payments WHERE transaction_no=?",
                    (txn_no,)).fetchone()
                if _pay_id_r:
                    import httpx as _httpx_R3
                    _httpx_R3.post(
                        f"http://127.0.0.1:8001/api/internal/payments/{_pay_id_r['id']}/send-receipt-email",
                        params={"company_id": cid}, timeout=8,
                    )
            except Exception as _eR3:
                print(f"[mobile-v3 receipt-email auto] txn={txn_no}: {_eR3}")

            company = _company_meta(cid)
            # Compute fresh balance after this txn
            row2 = c.execute("SELECT total_bill_amount, received_amount, "
                             " discount_credit, plan_id, "
                             " customer_name, customer_id, customer_phone, address, "
                             " locality, period, start_date, end_date "
                             " FROM customers WHERE id=?", (cust_pk,)).fetchone()
            # _S40zπ_MOBILE_FIX_  Use real invoice/payment ledger
            _signed_after = _balance_signed(c, cid, cust["customer_id"])
            balance_after = max(0, round(_signed_after, 2))
            previous_due  = round(_signed_after + cash_paid + disc, 2)
            # If the customer has overpayment, surface it as a credit (negative
            # balance_after_signed) so the receipt template can show "Credit ₹X".
            balance_after_signed = round(_signed_after, 2)
            plan = c.execute("SELECT plan_name FROM plans WHERE id=?",
                             (row2["plan_id"],)).fetchone()
            # Previous payment to this one
            prev = c.execute("SELECT amount, paid_at FROM payments "
                             " WHERE company_id=? AND customer_id=? AND transaction_no!=? "
                             " ORDER BY paid_at DESC LIMIT 1",
                             (cid, cust["customer_id"], txn_no)).fetchone()

        # _S39R5O — Format dates and period for receipt display
        def _to_ddmm(x):
            if not x:
                return ""
            x = str(x).strip()
            if len(x) >= 10 and x[4] == "-" and x[7] == "-":
                return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
            if len(x) >= 10 and x[2] == "-" and x[5] == "-":
                return x[:10]
            return x
        # Receipt-friendly DD-MM-YYYY HH:MM (UTC iso → IST shift +5:30)
        try:
            from datetime import datetime as _dt, timedelta as _td
            paid_at_fmt = _fmt_paid_at(now_iso)
        except Exception:
            paid_at_fmt = now_iso
        sd, ed = row2["start_date"], row2["end_date"]
        if sd and ed:
            period_str = f"{_to_ddmm(sd)} to {_to_ddmm(ed)}"
        elif row2["period"]:
            period_str = f"{row2['period']} mo"
        else:
            period_str = ""
        # Last paid datetime → IST DD-MM-YYYY HH:MM
        last_paid_at_fmt = ""
        if prev and prev["paid_at"]:
            try:
                from datetime import datetime as _dt, timedelta as _td
                last_paid_at_fmt = _fmt_paid_at(prev["paid_at"])
            except Exception:
                last_paid_at_fmt = prev["paid_at"]

        # _S39R5Q — Push notify customer (and the collector who recorded it).
        try:
            cust_tokens = _tokens_for(cid, "customer", cust_pk)
            staff_tokens = _tokens_for(
                cid, role, s.get("user_pk") or s.get("user_id"))
            company = _company_meta(cid)
            cname = company.get("company_name") or "AutoISP Billing"
            push_data = {"type": "payment", "txn_no": txn_no,
                         "customer_pk": cust_pk}
            if cust_tokens:
                _push_send(
                    cust_tokens,
                    f"Payment received · ₹{cash_paid:.0f}",
                    f"Receipt {txn_no} · Bal ₹{balance_after:.0f}. — {cname}",
                    push_data)
            if staff_tokens:
                _push_send(
                    staff_tokens,
                    f"Receipt logged · ₹{cash_paid:.0f}",
                    f"{row2['customer_name']} · Bal ₹{balance_after:.0f}",
                    push_data)
        except Exception:
            pass

        return {
            "ok": True,
            "receipt": {
                "company_name":    company.get("company_name") or "AutoISP Billing",
                "company_phone":   company.get("company_phone"),
                "company_address": company.get("company_address"),
                # _S40zπ_v462_  GST intentionally omitted on mobile receipts.
                "receipt_no":      txn_no,
                "txn_no":          txn_no,
                "paid_at":         paid_at_fmt,
                "customer_id":     row2["customer_id"],
                "customer_name":   row2["customer_name"],
                "mobile":          row2["customer_phone"],
                "address":         row2["address"],
                "locality":        row2["locality"],
                "plan_name":       plan["plan_name"] if plan else "",
                "period":          period_str,
                "amount":          cash_paid,
                "discount":        disc,
                "net_paid":        cash_paid,
                "total_credit":    credit,
                "payment_mode":    mode,
                "remarks":         remarks,
                "collected_by":    collector_full,
                "collector_code":  collector_code,
                "previous_due":    previous_due,
                "balance_after":   balance_after,
                "last_paid":       float(prev["amount"]) if prev else 0,
                "last_paid_at":    last_paid_at_fmt,
                # _v464_ALIASES — Payment Success screen fields.
                "cash_paid":        cash_paid,
                "credit_total":     credit,
                "balance_after_signed": balance_after_signed,
                "current_due":      max(0, round(_signed_after, 2)),
                "previous_balance": previous_due,
            },
        }

