    @app.get("/api/mobile/v1/invoices/{invoice_id}/download")
    def mobile_invoice_pdf(invoice_id: int, t: Optional[str] = None,
                           authorization: Optional[str] = Header(None)):
        # _v465_ — Linking.openURL on Android can't send Authorization header.
        # Accept the bearer token as ?t=... query param for browser-opened
        # invoice downloads. The token is the same JWT used by /auth/login.
        if t and not authorization:
            authorization = "Bearer " + t
        """Stream the PDF invoice straight back to the device (Linking.open
        will save / open it). Tenant-scoped: rejects cross-company access."""
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            row = c.execute(
                "SELECT id FROM invoices WHERE id=? AND company_id=?",
                (invoice_id, cid)).fetchone()
        if not row:
            raise HTTPException(404, "invoice_not_found")
        try:
            import requests as _rq
            r = _rq.get(
                f"http://127.0.0.1:8001/api/invoices/{invoice_id}/download",
                headers=_admin_proxy_headers(cid),
                timeout=20, stream=True)
            if r.status_code != 200:
                raise HTTPException(502, f"admin_pdf_status_{r.status_code}")
            from fastapi.responses import StreamingResponse
            return StreamingResponse(
                r.iter_content(chunk_size=64 * 1024),
                media_type="application/pdf",
                headers={
                    "Content-Disposition":
                        f'attachment; filename="invoice_{invoice_id}.pdf"',
                })
        except HTTPException: raise
        except Exception as e:
            raise HTTPException(502, f"admin_unreachable: {e}")

