    # _v465_LEDGER — Unified invoice + payment history for a customer.
    # Returns a sorted-by-date list with type='invoice' (red) or 'payment' (green)
    # so the mobile UI can show colored rows like the web admin's transaction
    # history popup.
    @app.get("/api/mobile/v1/subscribers/{cust_pk}/ledger")
    def subscriber_ledger(cust_pk: int,
                          authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            cust = c.execute("SELECT customer_id FROM customers "
                             "WHERE id=? AND company_id=?",
                             (cust_pk, cid)).fetchone()
            if not cust:
                raise HTTPException(404, "customer_not_found")
            cid_ext = cust["customer_id"]
            invs = c.execute(
                "SELECT id, invoice_no, total_amount, issue_date, start_date, end_date "
                "  FROM invoices WHERE company_id=? AND customer_id=? "
                " ORDER BY issue_date DESC, id DESC",
                (cid, cid_ext)).fetchall()
            pays = c.execute(
                "SELECT id, transaction_no, amount, discount, paid_at, payment_mode "
                "  FROM payments WHERE company_id=? AND customer_id=? "
                " ORDER BY paid_at DESC, id DESC",
                (cid, cid_ext)).fetchall()
        items = []
        for r in invs:
            d = dict(r)
            sd = (d.get("start_date") or "")[:10]
            ed = (d.get("end_date") or "")[:10]
            def _ddmm(x):
                if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
                    return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                return x
            items.append({
                "kind": "invoice",
                "id": f"INV{d['id']}",
                "ref": d.get("invoice_no"),
                "amount": float(d.get("total_amount") or 0),
                "sign": "+",   # adds to balance
                "color": "red",
                "date": d.get("issue_date") or "",
                "date_fmt": _ddmm(d.get("issue_date") or ""),
                "period": (f"{_ddmm(sd)} to {_ddmm(ed)}" if sd and ed else ""),
                "label": f"Invoice {d.get('invoice_no') or d['id']}",
            })
        for r in pays:
            d = dict(r)
            items.append({
                "kind": "payment",
                "id": f"PAY{d['id']}",
                "ref": d.get("transaction_no"),
                "amount": float(d.get("amount") or 0),
                "discount": float(d.get("discount") or 0),
                "sign": "-",   # reduces balance
                "color": "green",
                "date": d.get("paid_at") or "",
                "date_fmt": _fmt_paid_at(d.get("paid_at")),
                "mode": d.get("payment_mode") or "",
                "label": f"Payment · {d.get('payment_mode') or '—'}",
            })
        # Newest first
        items.sort(key=lambda x: (x.get("date") or ""), reverse=True)
        return {"ok": True, "items": items, "count": len(items)}

