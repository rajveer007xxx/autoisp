    @app.get("/api/mobile/v1/complaints-list")
    def complaints_list(status: str = "", priority: str = "",
                        complaint_type: str = "", q: str = "",
                        authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        # _v473b_CMP_CUST  Resolve customer_id (session has username/pk).
        _ut2 = (s.get("user_type") or "").lower()
        _cust_filter2 = ""
        if _ut2 == "customer":
            _u2  = s.get("username") or ""
            _pk2 = s.get("user_pk")
            try:
                with DB() as _cm2:
                    _r2 = _cm2.execute(
                        "SELECT customer_id FROM customers "
                        "WHERE company_id=? AND (id=? OR customer_id=? OR username=?) LIMIT 1",
                        (cid, _pk2, _u2, _u2)).fetchone()
                if _r2:
                    _cust_filter2 = _r2["customer_id"]
            except Exception:
                _cust_filter2 = _u2 or ""
        # _S40zπ_MOBILE_FIX_  Server-side filtering for status/priority/type/q.
        # _v4718_LIST  locations JOIN gives a locality fallback.
        sql = """
              SELECT cp.id, cp.ticket_no AS ticket_id, cp.complaint_type, cp.priority,
                     cp.subject, cp.description, cp.status, cp.created_at,
                     cp.updated_at, cp.resolved_by AS assigned_to,
                     cu.customer_id, cu.customer_name, cu.username,
                     cu.address,
                     COALESCE(NULLIF(cu.locality,''), lo.name) AS locality,
                     cu.customer_phone AS mobile,
                     cu.customer_type
                FROM complaints cp
                LEFT JOIN customers cu
                  ON cu.customer_id=cp.customer_id AND cu.company_id=cp.company_id
                LEFT JOIN locations lo
                  ON lo.id=cu.location_id AND lo.company_id=cu.company_id
               WHERE cp.company_id=? AND (? = '' OR cp.customer_id=?)
              """
        args = [cid, _cust_filter2, _cust_filter2]
        if status:
            # _v467_TICKET_STATUS — group Pending+In Progress under In Progress.
            v = status.strip().lower().replace(' ', '').replace('_', '')
            if v in ('inprogress', 'pending'):
                sql += (" AND LOWER(REPLACE(IFNULL(cp.status,''),' ','')) "
                        "   IN ('inprogress','pending') ")
            else:
                sql += " AND LOWER(IFNULL(cp.status,''))=LOWER(?)"
                args.append(status)
        if priority:
            sql += " AND LOWER(IFNULL(cp.priority,''))=LOWER(?)"
            args.append(priority)
        if complaint_type:
            sql += " AND LOWER(IFNULL(cp.complaint_type,''))=LOWER(?)"
            args.append(complaint_type)
        if q:
            sql += (" AND (cp.ticket_no LIKE ? OR cp.subject LIKE ? OR "
                    " cu.customer_name LIKE ? OR cu.customer_id LIKE ?)")
            args += [f"%{q}%"] * 4
        sql += " ORDER BY cp.id DESC LIMIT 300"
        with DB() as c:
            rows = c.execute(sql, args).fetchall()
        items = []
        for r in rows:
            d = dict(r)
            d["created_at_fmt"] = _fmt_paid_at(d.get("created_at"))
            d["updated_at_fmt"] = _fmt_paid_at(d.get("updated_at"))
            items.append(d)
        return {"ok": True, "items": items}

    @app.get("/api/mobile/v1/complaints/{cid_pk}")
    def complaint_detail(cid_pk: int, authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        with DB() as c:
            # _v4718_DETAIL  Enrich with locations.name fallback + customer_email +
            # customer_type.  Returns the most-complete subscriber identity we
            # have for this ticket.
            r = c.execute("""
              SELECT cp.*, cu.customer_id AS cust_code, cu.customer_name,
                     cu.username, cu.address,
                     COALESCE(NULLIF(cu.locality,''), lo.name) AS locality,
                     lo.name AS location_name,
                     cu.customer_phone AS mobile,
                     cu.customer_email,
                     cu.customer_type
                FROM complaints cp
                LEFT JOIN customers cu
                  ON cu.customer_id=cp.customer_id AND cu.company_id=cp.company_id
                LEFT JOIN locations lo
                  ON lo.id=cu.location_id AND lo.company_id=cu.company_id
               WHERE cp.id=? AND cp.company_id=?
            """, (cid_pk, cid)).fetchone()
            if not r: raise HTTPException(404, "not_found")
            d = dict(r); d["ticket_id"] = d.get("ticket_no")
            d["assigned_to"] = d.get("resolved_by")
            # _v4718_DETAIL  If the ticket has no matching customer (cust_code IS
            # NULL), look up whoever raised it — sub_lco / employee / admin —
            # and surface them as raised_by_* so the UI can still show a name.
            if not d.get("cust_code"):
                raiser_code = d.get("customer_id") or ""
                raiser = None
                if raiser_code:
                    raiser = c.execute(
                        "SELECT admin_id AS code, admin_name AS name, "
                        "       'admin' AS role, '' AS mobile, admin_email AS email "
                        "  FROM admins WHERE company_id=? AND admin_id=?",
                        (cid, raiser_code)).fetchone()
                    if not raiser:
                        raiser = c.execute(
                            "SELECT sub_lco_code AS code, name, "
                            "       'sub_lco' AS role, mobile, email "
                            "  FROM sub_lcos WHERE company_id=? AND sub_lco_code=?",
                            (cid, raiser_code)).fetchone()
                    if not raiser:
                        raiser = c.execute(
                            "SELECT employee_code AS code, employee_name AS name, "
                            "       'employee' AS role, mobile, email "
                            "  FROM employees WHERE company_id=? AND employee_code=?",
                            (cid, raiser_code)).fetchone()
                if raiser:
                    d["raised_by_code"]   = raiser["code"]
                    d["raised_by_name"]   = raiser["name"]
                    d["raised_by_role"]   = raiser["role"]
                    d["raised_by_mobile"] = raiser["mobile"] or ""
                    d["raised_by_email"]  = raiser["email"] or ""
        # _v473e_  Real comments + assignable users (admins/sub_lcos/employees).
        try:
            with DB() as _ck:
                _ck.execute("""CREATE TABLE IF NOT EXISTS complaint_comments (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    complaint_id INTEGER NOT NULL,
                    company_id   TEXT NOT NULL,
                    author       TEXT,
                    text         TEXT NOT NULL,
                    created_at   TEXT NOT NULL
                )""")
                cc = _ck.execute(
                    "SELECT author, text, created_at FROM complaint_comments "
                    " WHERE complaint_id=? AND company_id=? ORDER BY id ASC",
                    (cid_pk, cid)).fetchall()
                d["comments"] = [{"author": x["author"], "text": x["text"],
                                   "at": x["created_at"]} for x in cc]
        except Exception:
            d["comments"] = []
        # Assignable users dropdown (admins + sub_lcos + employees)
        try:
            with DB() as _ck2:
                pool = []
                for row in _ck2.execute(
                    "SELECT admin_id AS code, admin_name AS name, 'admin' AS role "
                    "  FROM admins WHERE company_id=?", (cid,)).fetchall():
                    pool.append(dict(row))
                for row in _ck2.execute(
                    "SELECT sub_lco_code AS code, name, 'sub_lco' AS role "
                    "  FROM sub_lcos WHERE company_id=?", (cid,)).fetchall():
                    pool.append(dict(row))
                for row in _ck2.execute(
                    "SELECT employee_code AS code, employee_name AS name, 'employee' AS role "
                    "  FROM employees WHERE company_id=?", (cid,)).fetchall():
                    pool.append(dict(row))
                d["assignable"] = pool
        except Exception:
            d["assignable"] = []
        return d

    @app.post("/api/mobile/v1/complaints/{cid_pk}/update")
    def complaint_update(cid_pk: int, body: dict = Body(...),
                         authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        # _v4723_  When the caller is a customer, restrict deletion to
        # tickets the customer themselves raised (matched by customer_id).
        # Customers cannot change status / assignee — only delete or comment.
        is_customer = (s.get("user_type") or "").lower() == "customer"
        with DB() as c:
            if is_customer:
                own = c.execute(
                    "SELECT customer_id FROM customers "
                    " WHERE company_id=? AND (id=? OR username=? OR customer_id=?) "
                    " LIMIT 1",
                    (cid, s.get("user_pk") or "", s.get("username") or "",
                     s.get("username") or "")).fetchone()
                cust_id = own["customer_id"] if own else ""
                row = c.execute(
                    "SELECT customer_id FROM complaints WHERE id=? AND company_id=?",
                    (cid_pk, cid)).fetchone()
                if not row or row["customer_id"] != cust_id:
                    raise HTTPException(403, "not_your_ticket")
                if not body.get("delete"):
                    # Customers can ONLY delete or add comment via this route
                    body = {k: v for k, v in body.items()
                            if k in ("comment",)}
            if body.get("delete"):
                c.execute("DELETE FROM complaints WHERE id=? AND company_id=?",
                          (cid_pk, cid)); c.commit()
                return {"ok": True, "deleted": True}
            sets = []; args = []
            if body.get("status"):
                sets.append("status=?"); args.append(body["status"])
            if body.get("assigned_to"):
                sets.append("resolved_by=?"); args.append(body["assigned_to"])
            if sets:
                args += [cid_pk, cid]
                c.execute(f"UPDATE complaints SET {', '.join(sets)}, "
                          " updated_at=CURRENT_TIMESTAMP "
                          " WHERE id=? AND company_id=?", args); c.commit()
            # _v4715_CMP_UPD_COMMENT  If the modal also passed a comment,
            # persist it into the timeline so it shows up immediately.
            _ctxt = (body.get('comment') or '').strip()
            if _ctxt:
                c.execute("""CREATE TABLE IF NOT EXISTS complaint_comments (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    complaint_id INTEGER NOT NULL,
                    company_id   TEXT NOT NULL,
                    author       TEXT,
                    text         TEXT NOT NULL,
                    created_at   TEXT NOT NULL
                )""")
                _author = s.get('username') or 'system'
                # Tag system events (status / assignment).
                _prefix = ''
                if body.get('status'):
                    _prefix += f"[status → {body['status']}] "
                if body.get('assigned_to'):
                    _prefix += f"[assigned → {body['assigned_to']}] "
                c.execute("INSERT INTO complaint_comments "
                          " (complaint_id, company_id, author, text, created_at) "
                          "VALUES (?,?,?,?,?)",
                          (cid_pk, cid, _author, _prefix + _ctxt, _now_ist_iso()))
                c.commit()
        return {"ok": True}

