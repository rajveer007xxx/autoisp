    # ─── Push Notifications (Expo) ───────────────────────────────────────
    # _S39R5Q — Send via Expo Push API. Tokens stored in `push_tokens`.
    def _push_send(tokens: list, title: str, body: str, data: dict = None):
        if not tokens: return
        try:
            import urllib.request, json as _json
            payload = [{
                "to": tk, "title": title, "body": body, "sound": "default",
                "data": data or {}, "priority": "high",
            } for tk in tokens]
            req = urllib.request.Request(
                "https://exp.host/--/api/v2/push/send",
                data=_json.dumps(payload).encode(),
                headers={"Content-Type": "application/json",
                         "Accept": "application/json",
                         "Accept-encoding": "gzip, deflate"},
                method="POST")
            urllib.request.urlopen(req, timeout=10).read()
        except Exception as e:
            try:
                import logging as _lg; _lg.warning(f"push_send_error: {e}")
            except Exception: pass

    def _tokens_for(cid: str, user_type: str = None,
                    user_pk: int = None) -> list:
        with DB() as c:
            sql = "SELECT expo_token FROM push_tokens WHERE company_id=?"
            args = [cid]
            if user_type:
                sql += " AND user_type=?"; args.append(user_type)
            if user_pk:
                sql += " AND user_pk=?"; args.append(user_pk)
            return [r["expo_token"] for r in c.execute(sql, args).fetchall()]

    @app.post("/api/mobile/v1/push/register")
    def push_register(body: dict = Body(...),
                      authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization); cid = s.get("company_id") or ""
        token = (body.get("expo_token") or "").strip()
        if not token: raise HTTPException(400, "missing_expo_token")
        ut  = s.get("user_type") or ""
        upk = s.get("user_pk") or s.get("user_id")
        with DB() as c:
            now = _now_ist_iso()
            c.execute(
                "INSERT INTO push_tokens(company_id, user_type, user_pk, "
                "  expo_token, device_id, platform, app_version, created_at, updated_at) "
                "VALUES (?,?,?,?,?,?,?,?,?) "
                "ON CONFLICT(expo_token) DO UPDATE SET "
                "  company_id=excluded.company_id, user_type=excluded.user_type, "
                "  user_pk=excluded.user_pk, device_id=excluded.device_id, "
                "  platform=excluded.platform, app_version=excluded.app_version, "
                "  updated_at=excluded.updated_at",
                (cid, ut, upk, token,
                 body.get("device_id"), body.get("platform"),
                 body.get("app_version"), now, now))
            c.commit()
        return {"ok": True}

    @app.post("/api/mobile/v1/push/unregister")
    def push_unregister(body: dict = Body(...),
                        authorization: Optional[str] = Header(None)):
        _require_auth(authorization)
        token = (body.get("expo_token") or "").strip()
        if not token: return {"ok": True}
        with DB() as c:
            c.execute("DELETE FROM push_tokens WHERE expo_token=?", (token,))
            c.commit()
        return {"ok": True}

    # ─── Due alert dispatcher (cron-callable) ────────────────────────────
    # _S39R5Q — Sends push to every customer whose end_date is within
    # `days_before` days. Designed to be hit daily from systemd timer.
    # Auth: requires X-Internal-Key matching env AUTOISPB_INTERNAL_KEY.
    @app.post("/api/mobile/v1/internal/dispatch-due-alerts")
    def dispatch_due_alerts(days_before: int = 3,
                            x_internal_key: Optional[str] = Header(None,
                                alias="X-Internal-Key")):
        import os as _os
        expected = _os.environ.get("AUTOISPB_INTERNAL_KEY", "autoispb-internal-key")
        if x_internal_key != expected:
            raise HTTPException(401, "internal_key_required")
        from datetime import date as _date, timedelta as _td
        target = (_date.today() + _td(days=days_before)).strftime("%Y-%m-%d")
        sent = 0; failed = 0
        with DB() as c:
            rows = c.execute(
                "SELECT c.id AS pk, c.company_id, c.customer_name, "
                "       c.total_bill_amount, c.received_amount, "
                "       c.discount_credit, c.end_date, "
                "       co.company_name "
                "  FROM customers c "
                "  LEFT JOIN companies co ON co.company_id=c.company_id "
                " WHERE substr(c.end_date,1,10)=? "
                "   AND COALESCE(c.status,'Active')='Active'", (target,)).fetchall()
            for r in rows:
                due = max(0, round(
                    float(r["total_bill_amount"] or 0) -
                    float(r["received_amount"] or 0) -
                    float(r["discount_credit"] or 0)))
                if due <= 0: continue
                tokens = _tokens_for(r["company_id"], "customer", r["pk"])
                if not tokens: continue
                try:
                    _push_send(
                        tokens,
                        f"Bill due in {days_before} days · ₹{due:.0f}",
                        f"Hi {r['customer_name']}, your AutoISP plan expires "
                        f"on {r['end_date'][:10]}. Pay ₹{due:.0f} to stay online.",
                        {"type": "due_alert", "customer_pk": r["pk"],
                         "amount": due})
                    sent += 1
                except Exception:
                    failed += 1
        return {"ok": True, "target_date": target, "sent": sent,
                "failed": failed}

    # ─── Role-scope helper (sub_lco / employee) ──────────────────────────
    # Returns (WHERE-fragment starting with " AND ...", params) intended to
    # be appended to a customer query that already has a base "WHERE
    # company_id=?" clause. Admin / superadmin pass through unscoped.
    def _scope_and(s: dict, cust_alias: str = "c") -> tuple:
        # _v4717_SCOPE  Canonical role scope used by every v3 mobile endpoint.
        # Sub_LCO  → own adds  OR child sub_lcos  OR employees-of-self adds
        # Employee → own adds  OR assigned localities
        ut  = s.get("user_type") or ""
        pk  = s.get("user_pk") or s.get("user_id")
        cid = s.get("company_id") or ""
        a   = cust_alias
        if ut == "sub_lco":
            return (
                f" AND ({a}.sub_lco_id=? OR "
                f"      {a}.created_by_employee_id IN ("
                f"           SELECT id FROM employees "
                f"            WHERE sub_lco_id=? AND company_id=?)) ",
                # _v4717_SCOPE  No child-sub_lco column in this schema.
                [pk, pk, cid],
            )
        if ut == "employee":
            try:
                with DB() as cx:
                    allowed = [r[0] for r in cx.execute(
                        "SELECT location_id FROM employee_locality_assignments "
                        " WHERE employee_id=? AND company_id=?", (pk, cid)
                    ).fetchall()]
            except Exception:
                allowed = []
            if allowed:
                qm = ",".join("?" * len(allowed))
                return (f" AND ({a}.location_id IN ({qm}) "
                        f"      OR {a}.created_by_employee_id=?) ",
                        list(allowed) + [pk])
            # No locality assignments → only their own adds.
            return (f" AND ({a}.created_by_employee_id=?) ", [pk])
        return ("", [])

    # ─── /me ─────────────────────────────────────────────────────────────
    @app.get("/api/mobile/v1/me")
    def me(authorization: Optional[str] = Header(None)):
        s = _require_auth(authorization)
        cid = s.get("company_id") or ""
        role = s.get("user_type") or ""
        uid  = s.get("user_pk") or s.get("user_id")
        # _v470_ME_CUSTOMER — when role=customer, return plan_name+end_date+due
        if role.lower() in ("customer", "customer_user", "end_user", "user") or s.get("customer_id"):
            # _v473_ME_FIX  Session row stores customer_id/username under the
            # 'username' column.  user_pk is the integer DB id.  Use both.
            cust_id_ext = (s.get("customer_id") or s.get("username")
                           or s.get("user_id") or "")
            cust_pk     = s.get("user_pk")
            try:
                with DB() as _cm:
                    _cust = _cm.execute(
                        "SELECT customer_name, customer_id, plan_id, end_date, "
                        "  start_date, status, customer_phone AS mobile, monthly_amount "
                        "  FROM customers "
                        "  WHERE company_id=? AND (customer_id=? OR username=? OR id=?) LIMIT 1",
                        (cid, cust_id_ext, cust_id_ext, cust_pk)).fetchone()
                if _cust:
                    _plan = None
                    with DB() as _cm:
                        if _cust["plan_id"]:
                            _plan = _cm.execute(
                                "SELECT plan_name, after_tax_amount FROM plans WHERE id=?",
                                (_cust["plan_id"],)).fetchone()
                        _inv = _cm.execute(
                            "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                            "  WHERE company_id=? AND customer_id=?",
                            (cid, _cust["customer_id"])).fetchone()[0]
                        _pay = _cm.execute(
                            "SELECT COALESCE(SUM(amount),0)+COALESCE(SUM(discount),0) "
                            "  FROM payments WHERE company_id=? AND customer_id=?",
                            (cid, _cust["customer_id"])).fetchone()[0]
                    _due = max(0.0, round(float(_inv or 0) - float(_pay or 0), 2))
                    ed = _cust["end_date"] or ""
                    if ed and len(ed) >= 10 and ed[4] == "-":
                        ed = f"{ed[8:10]}-{ed[5:7]}-{ed[0:4]}"
                    # _v4720_ME_USER  Also fetch image + email so the sidebar /
                    # dashboard avatar populate the same way they do for staff.
                    _extra = None
                    try:
                        with DB() as _cm2:
                            _extra = _cm2.execute(
                                "SELECT customer_email, photograph_path AS img, "
                                "       username FROM customers WHERE id=?",
                                (_cust["customer_id"] if False else cust_pk,)
                            ).fetchone()
                    except Exception:
                        _extra = None
                    _email = (_extra["customer_email"] if _extra else "") or ""
                    _img   = (_extra["img"]            if _extra else "") or ""
                    _uname = (_extra["username"]       if _extra else "") or ""
                    _img_url = None
                    if _img:
                        _ip = _img.strip()
                        if _ip.startswith("http"):
                            _img_url = _ip
                        else:
                            _img_url = f"https://www.autoispbilling.com/{_ip.lstrip('/')}"
                    return {
                        "ok": True, "role": role or "customer",
                        "customer_id":   _cust["customer_id"],
                        "customer_name": _cust["customer_name"],
                        "plan_name":     (_plan["plan_name"] if _plan else None),
                        "plan_amount":   (float(_plan["after_tax_amount"]) if _plan else float(_cust["monthly_amount"] or 0)),
                        "end_date":      ed,
                        "status":        _cust["status"],
                        "due_amount":    _due,
                        "balance":       _due,
                        "company_id":    cid,
                        # _v4720_ME_USER  Dashboard reads `user?.name` etc.
                        "user": {
                            "id":           cust_pk,
                            "user_type":    "customer",
                            "company_id":   cid,
                            "name":         _cust["customer_name"] or "",
                            "full_name":    _cust["customer_name"] or "",
                            "username":     _uname or s.get("username") or "",
                            "customer_id": _cust["customer_id"],
                            "mobile":       _cust["mobile"] or "",
                            "email":        _email,
                            "profile_image_url": _img_url,
                        },
                    }
            except Exception as _me_err:
                print(f"[me customer enrich] {_me_err}")
        full_name = ""; mobile = ""; email = ""; image_path = ""
        with DB() as c:
            if role == "admin":
                r = c.execute(
                    "SELECT admin_name, admin_id, admin_mobile AS mobile, "
                    "       admin_email AS email, profile_image_path AS img "
                    "  FROM admins WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["admin_name"] or r["admin_id"]
                    mobile = r["mobile"] or ""
                    email = r["email"] or ""
                    image_path = r["img"] or ""
            elif role == "sub_lco":
                r = c.execute(
                    "SELECT name, mobile, email, profile_image AS img "
                    "  FROM sub_lcos WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["name"]
                    mobile = r["mobile"] or ""
                    email = r["email"] or ""
                    image_path = r["img"] or ""
            elif role == "employee":
                r = c.execute(
                    "SELECT employee_name, mobile, email, profile_image_path AS img "
                    "  FROM employees WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["employee_name"]
                    mobile = r["mobile"] or ""
                    email = r["email"] or ""
                    image_path = r["img"] or ""
            elif role == "customer":
                r = c.execute(
                    "SELECT customer_name, customer_phone, customer_email, "
                    "       photograph_path AS img "
                    "  FROM customers WHERE id=? AND company_id=?",
                    (uid, cid)).fetchone()
                if r:
                    full_name = r["customer_name"]
                    mobile = r["customer_phone"] or ""
                    email = r["customer_email"] or ""
                    image_path = r["img"] or ""
        # Build absolute image URL
        img_url = None
        if image_path:
            p = image_path.strip()
            if p.startswith("http"):
                img_url = p
            else:
                if not p.startswith("/"):
                    p = "/" + p
                img_url = f"https://www.autoispbilling.com{p}"
        # _S40zπ_MOBILE_FIX_  Dashboard tiles: real counts excluding Deleted.
        # _S40zπ_MOBILE_FIX_  Schema-correct role scoping for /me counters
        scope_extra = ""
        sx_args = []
        if role == "sub_lco":
            # sub_lcos.id is what customers.sub_lco_id stores; uid here is the
            # sub_lco's PK id (string). No `parent_sub_lco_id` column exists.
            scope_extra = " AND sub_lco_id=?"
            sx_args = [uid]
        elif role == "employee":
            # Employees see customers in any locality they're assigned to OR
            # any customer they personally created.
            try:
                with DB() as _cx:
                    locs = [r[0] for r in _cx.execute(
                        "SELECT location_id FROM employee_locality_assignments "
                        " WHERE company_id=? AND employee_id=? AND COALESCE(active,1)=1",
                        (cid, uid)).fetchall()]
                if locs:
                    ph = ",".join("?" * len(locs))
                    scope_extra = f" AND (location_id IN ({ph}) OR created_by_employee_id=?)"
                    sx_args = list(locs) + [uid]
                else:
                    scope_extra = " AND created_by_employee_id=?"
                    sx_args = [uid]
            except Exception:
                scope_extra = " AND created_by_employee_id=?"
                sx_args = [uid]
        cnt = {"subscribers_total": 0, "subscribers_active": 0,
               "online_now": 0, "complaints_open": 0,
               "bill_dues_count": 0, "bill_dues_amount": 0.0,
               "notifications_unread": 0}
        try:
            with DB() as _cm:
                base = (" WHERE company_id=? AND COALESCE(status,'') NOT IN "
                        " ('Deleted','deleted','Terminated','terminated') ")
                # _S40zπ_v462_ exclude Deleted/Terminated from totals.
                cnt["subscribers_total"] = _cm.execute(
                    "SELECT COUNT(*) FROM customers" + base + scope_extra
                    + " AND COALESCE(status,'') NOT IN "
                      " ('Deleted','deleted','Terminated','terminated')",
                    [cid] + sx_args).fetchone()[0]
                cnt["subscribers_active"] = _cm.execute(
                    "SELECT COUNT(*) FROM customers" + base
                    + " AND status='Active'" + scope_extra,
                    [cid] + sx_args).fetchone()[0]
                cnt["complaints_open"] = _cm.execute(
                    "SELECT COUNT(*) FROM complaints "
                    " WHERE company_id=? AND IFNULL(status,'')!='Resolved'",
                    (cid,)).fetchone()[0]
            cnt["online_now"] = len(_online_set_real(cid))
            with DB() as _cm:
                # Bill dues: count + sum via real ledger
                rows = _cm.execute(
                    "SELECT customer_id FROM customers " + base + scope_extra,
                    [cid] + sx_args).fetchall()
                tot = 0.0; n = 0
                for rr in rows:
                    bal = _balance_signed(_cm, cid, rr[0])
                    if bal > 0:
                        tot += bal; n += 1
                cnt["bill_dues_count"]  = n
                cnt["bill_dues_amount"] = round(tot, 2)
                # Notifications = open complaints + unack alerts
                try:
                    cnt["notifications_unread"] = (
                        cnt["complaints_open"]
                        + (_cm.execute("SELECT COUNT(*) FROM olt_alerts "
                            " WHERE company_id=? AND COALESCE(acked,0)=0",
                            (cid,)).fetchone()[0] or 0))
                except Exception:
                    cnt["notifications_unread"] = cnt["complaints_open"]
        except Exception:
            pass
        return {
            "ok": True,
            "user": {
                "id": uid, "role": role,
                "company_id": cid, "username": s.get("username"),
                "full_name": full_name, "mobile": mobile, "email": email,
                "profile_image_url": img_url,
            },
            "company": _company_meta(cid),
            "counters": cnt,
            **cnt,
        }

    def _normalize_subscriber(row, plan_lookup, online_set, last_pay_lookup,
                              cid: str = "") -> dict:
        # _S40zπ_MOBILE_FIX_  Real ledger:
        #   balance     = SUM(invoices) - SUM(payments + discounts)  [signed]
        #   current_due = latest invoice amount (this period's bill)
        #   prev_due    = balance - current_due  (carry-forward)
        d = dict(row)
        plan = plan_lookup.get(d.get("plan_id")) or {}
        d["plan_name"]   = plan.get("plan_name")
        d["plan_amount"] = float(plan.get("after_tax_amount") or d.get("monthly_amount") or 0)
        d["period_months"] = d.get("period")
        d["mobile"]      = d.get("customer_phone")
        d["is_online"]   = (d.get("username") or "") in online_set
        try:
            with DB() as _c:
                signed = _balance_signed(_c, cid, d.get("customer_id"))
                cur_inv = _latest_invoice_amount(_c, cid, d.get("customer_id"))
        except Exception:
            signed = 0.0; cur_inv = float(d.get("monthly_amount") or 0)
        due_pos = max(0.0, round(signed, 2))   # what the customer OWES; credits → 0
        d["due_amount"]   = due_pos
        d["balance"]      = due_pos
        d["balance_signed"] = round(signed, 2)
        d["current_charge"] = round(cur_inv if cur_inv else float(d.get("monthly_amount") or 0), 2)
        d["current_due"]  = round(min(due_pos, d["current_charge"]), 2) if due_pos > 0 else 0.0
        d["prev_due"]     = round(max(0.0, due_pos - d["current_charge"]), 2)
        lp = last_pay_lookup.get(d.get("customer_id")) or {}
        d["last_paid"]    = float(lp.get("amount") or 0)
        d["last_paid_at"] = _fmt_paid_at(lp.get("paid_at"))
        d["status"]       = d.get("status") or "Active"
        # _S39R5O — formatted period DD-MM-YYYY to DD-MM-YYYY
        try:
            sd = (d.get("start_date") or "").strip()
            ed = (d.get("end_date") or "").strip()
            def _fmtd(x):
                if x and len(x) >= 10 and x[4] == "-" and x[7] == "-":
                    return f"{x[8:10]}-{x[5:7]}-{x[0:4]}"
                if x and len(x) >= 10 and x[2] == "-" and x[5] == "-":
                    return x[:10]
                return x or ""
            if sd and ed:
                d["formatted_period"] = f"{_fmtd(sd)} to {_fmtd(ed)}"
            elif ed:
                d["formatted_period"] = _fmtd(ed)
            else:
                d["formatted_period"] = ""
        except Exception:
            d["formatted_period"] = ""
        # _v464_ALIASES — extra field names some mobile screens read.
        d["previous_balance"]   = d.get("prev_due", 0)
        d["current_period_due"] = d.get("current_due", 0)
        d["payable_due"]        = d.get("balance", 0)
        d["current_dues"]       = d.get("current_due", 0)
        d["due_balance"]        = d.get("balance", 0)
        d["last_payment_amount"]= d.get("last_paid", 0)
        d["bill_amount"]        = d.get("plan_amount") or d.get("monthly_amount") or 0
        d["online"]             = d.get("is_online", False)
        return d

