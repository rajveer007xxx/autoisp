            plans = {p["id"]: dict(p) for p in c.execute(
                "SELECT id, plan_name, after_tax_amount FROM plans").fetchall()}
            lp_row = c.execute(
                "SELECT amount, paid_at FROM payments "
                " WHERE company_id=? AND customer_id=? "
                " ORDER BY paid_at DESC LIMIT 1",
                (cid, row["customer_id"])).fetchone()
            lp_lookup = {row["customer_id"]: dict(lp_row) if lp_row else {}}
        d = _normalize_subscriber(row, plans, _online_set_real(cid), lp_lookup, cid)
        # _v464_ALIASES — extra field names some mobile screens expect.
        d["previous_balance"]   = d.get("prev_due", 0)
        d["current_period_due"] = d.get("current_due", 0)
        d["payable_due"]        = d.get("balance", 0)
        d["current_dues"]       = d.get("current_due", 0)
        d["due_balance"]        = d.get("balance", 0)
        d["last_payment_amount"]= d.get("last_paid", 0)
        d["bill_amount"]        = d.get("plan_amount") or d.get("monthly_amount") or 0
        d["online"]             = d.get("is_online", False)
        return d

