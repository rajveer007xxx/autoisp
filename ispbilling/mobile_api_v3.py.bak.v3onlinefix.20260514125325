    # ─── _S40zπ_MOBILE_FIX_  Centralised IST timestamp + ledger helpers ───
    from zoneinfo import ZoneInfo as _ZI
    _IST = _ZI("Asia/Kolkata")

    def _now_ist_iso() -> str:
        """Return current IST naive 'YYYY-MM-DD HH:MM:SS' (matches web payments)."""
        return datetime.now(_IST).strftime("%Y-%m-%d %H:%M:%S")

    def _fmt_paid_at(raw, fmt: str = "%d-%m-%Y") -> str:
        """Parse a paid_at string (with or without microseconds) and format
        for receipt display.  No timezone shift — the DB now always stores IST."""
        if not raw:
            return ""
        raw = str(raw).strip()
        for parse_fmt in ("%Y-%m-%d %H:%M:%S.%f", "%Y-%m-%d %H:%M:%S",
                          "%Y-%m-%dT%H:%M:%S.%f", "%Y-%m-%dT%H:%M:%S"):
            try:
                return datetime.strptime(raw[:26], parse_fmt).strftime(fmt)
            except Exception:
                continue
        return raw

    def _balance_signed(cur, cid: str, customer_id: str) -> float:
        """Real ledger balance = SUM(invoices) - SUM(payments + discounts).
        Positive = customer owes; zero = clear; negative = credit/advance."""
        try:
            inv = cur.execute(
                "SELECT COALESCE(SUM(total_amount),0) FROM invoices "
                " WHERE company_id=? AND customer_id=?",
                (cid, customer_id)).fetchone()[0] or 0
        except Exception:
            inv = 0
        try:
            pay = cur.execute(
                "SELECT COALESCE(SUM(amount),0) + COALESCE(SUM(discount),0) "
                "  FROM payments WHERE company_id=? AND customer_id=?",
                (cid, customer_id)).fetchone()[0] or 0
        except Exception:
            pay = 0
        return round(float(inv) - float(pay), 2)

    def _latest_invoice_amount(cur, cid: str, customer_id: str) -> float:
        """Amount of the most recent invoice — used as 'current period charge'."""
        r = cur.execute(
            "SELECT total_amount FROM invoices "
            " WHERE company_id=? AND customer_id=? "
            " ORDER BY issue_date DESC, id DESC LIMIT 1",
            (cid, customer_id)).fetchone()
        return float(r[0] or 0) if r else 0.0

    # Real-time online detection.
    # An open radacct row alone is NOT proof a user is online: if the NAS
    # crashes without sending Acct-Stop, the row stays NULL forever. So we
    # additionally require:
    #   1. COALESCE(acctupdatetime, acctstarttime) within RADACCT_STALE_SECONDS
    #      (default 600s — i.e. an Interim-Update arrived in the last 10 min).
    #   2. The session's NAS is NOT marked as down/offline in nas_devices
    #      (last_status NOT IN down/unreachable/offline/error/timeout).
    import os as _os_radacct
    RADACCT_STALE_SECONDS = int(_os_radacct.environ.get("RADACCT_STALE_SECONDS", "600"))

    def _down_nas_ips(cid: str) -> set:
        bad = set()
        try:
            with DB() as _c:
                for r in _c.execute(
                    "SELECT ip_address FROM nas_devices "
                    " WHERE company_id=? "
                    "   AND LOWER(IFNULL(last_status,'')) "
                    "       IN ('down','unreachable','offline','error','timeout')",
                    (cid,)).fetchall():
                    if r[0]:
                        bad.add(str(r[0]).strip())
        except Exception:
            pass
        return bad

    def _online_set_real(cid: str) -> set:
        """Online usernames from radacct, scoped to THIS company's customers
        AND filtered for stale sessions / down NAS so the count is real-time."""
        try:
            with DB() as _c:
                # Only count NON-deleted customers from this tenant
                names = [r[0] for r in _c.execute(
                    "SELECT username FROM customers "
                    " WHERE company_id=? AND IFNULL(username,'')!='' "
                    "  AND COALESCE(status,'') NOT IN ('Deleted','deleted','Terminated','terminated')",
                    (cid,)).fetchall()]
            name_set = set(names)
            if not name_set:
                return set()
            cutoff = int(time.time()) - RADACCT_STALE_SECONDS
            bad_ips = _down_nas_ips(cid)
            ra = sqlite3.connect("file:/var/lib/freeradius/radacct.db?mode=ro",
                                 uri=True, timeout=5)
            ra.row_factory = sqlite3.Row
            online = set()
            chunk = 400
            names_list = list(name_set)
            for i in range(0, len(names_list), chunk):
                batch = names_list[i:i+chunk]
                ph = ",".join("?" * len(batch))
                rows = ra.execute(
                    "SELECT DISTINCT username, nasipaddress FROM radacct "
                    " WHERE acctstoptime IS NULL "
                    "   AND CAST(COALESCE(acctupdatetime, acctstarttime) AS INTEGER) >= ? "
                    f"  AND username IN ({ph})",
                    [cutoff] + batch).fetchall()
                for r in rows:
                    nip = r["nasipaddress"]
                    if nip and nip in bad_ips:
                        continue
                    if r["username"]:
                        online.add(r["username"])
            ra.close()
            # Final intersect (defensive — radacct is shared across tenants)
            return online & name_set
        except Exception:
            return set()



    # _S40zπ_MOBILE_FIX_  Smart user-type filter — routes 'broadband'/'cable'
    # /'fiber'/'wireless' to service_type; 'prepaid'/'postpaid' stay on
    # customer_type. The mobile UI's single 'User Type' dropdown sends mixed
    # values, so the API has to be liberal about both columns.
    _SVC_TYPES = {"broadband", "cable", "fiber", "wireless", "wifi", "leased_line"}
    _BILL_TYPES = {"prepaid", "postpaid"}


    # _v4715_RANGE_BE  Parse DD-MM-YYYY date range from request params.
    def _v4715_parse_range(from_s: str, to_s: str):
        """Return (d0, d1) as 'YYYY-MM-DD 00:00:00' / next-day strings, or None."""
        import re as _re_v
        m1 = _re_v.match(r'^(\d{2})-(\d{2})-(\d{4})$', (from_s or '').strip())
        m2 = _re_v.match(r'^(\d{2})-(\d{2})-(\d{4})$', (to_s   or '').strip())
        if not (m1 and m2):
            return None
        d0 = f"{m1.group(3)}-{m1.group(2)}-{m1.group(1)} 00:00:00"
        # to date is INCLUSIVE — bump to start of next day.
        import datetime as _dt_v
        try:
            base = _dt_v.datetime.strptime(
                f"{m2.group(3)}-{m2.group(2)}-{m2.group(1)}", "%Y-%m-%d")
            d1 = (base + _dt_v.timedelta(days=1)).strftime("%Y-%m-%d 00:00:00")
        except Exception:
            return None
        return d0, d1



    # _v4716_FMT_D  Format any backend date string (YYYY-MM-DD[ HH:MM:SS])
    # to DD-MM-YYYY for the Reports screen + CSV export.  Pure-string check
    # — avoids depending on `re` being in this nested scope.
    def _fmt_d(raw):
        if not raw: return ""
        s = str(raw).strip()
        if len(s) >= 10 and s[4] == '-' and s[7] == '-' \
           and s[:4].isdigit() and s[5:7].isdigit() and s[8:10].isdigit():
            return f"{s[8:10]}-{s[5:7]}-{s[:4]}"
        return s

    # _v4716_EMP_FILTER  Apply the "employee" dropdown across every report
    # type.  Accepts plain employee_code OR the special "sub_lco:<pk>" prefix
    # (sent when a Sub-LCO is selected).  Returns (sql_fragment, args) keyed
    # off the customer alias passed in.
    def _emp_filter_for_customers(c, cid, employee_id: str, alias: str = "c"):
        s = (employee_id or "").strip()
        if not s:
            return "", []
        if s.lower().startswith("sub_lco:"):
            try:
                pk = int(s.split(":", 1)[1])
                return f" AND {alias}.sub_lco_id=? ", [pk]
            except Exception:
                return " AND 1=0 ", []
        try:
            er = c.execute(
                "SELECT id FROM employees "
                " WHERE employee_code=? AND company_id=? LIMIT 1",
                (s, cid)).fetchone()
            if er:
                return f" AND {alias}.created_by_employee_id=? ", [er["id"]]
            return " AND 1=0 ", []
        except Exception:
            return "", []

    def _user_type_filter(val: str):
        """Return (sql_fragment, params) — joined with AND. Empty if val falsy."""
        v = (val or "").strip().lower().replace(" ", "_")
        if not v or v == "all":
            return "", []
        if v in _SVC_TYPES:
            return (" AND LOWER(REPLACE(IFNULL(c.service_type,''),' ','_'))=? ", [v])
        if v in _BILL_TYPES:
            return (" AND LOWER(REPLACE(IFNULL(c.customer_type,''),' ','_'))=? ", [v])
        # Unknown value — match either column for forward-compat
        return (" AND (LOWER(REPLACE(IFNULL(c.service_type,''),' ','_'))=? "
                "  OR LOWER(REPLACE(IFNULL(c.customer_type,''),' ','_'))=?) ",
                [v, v])

