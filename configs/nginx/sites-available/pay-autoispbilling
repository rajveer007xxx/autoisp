# pay.autoispbilling.com - dedicated host for the captive-portal / payment page.
# Point A-record for pay.autoispbilling.com -> 185.199.53.93 in your DNS.
server {
    server_name pay.autoispbilling.com;
    client_max_body_size 5M;

    # Redirect bare host to pay lookup
    location = / { return 302 /pay; }

    # Everything else -> admin-portal (serves /pay, /pay/<id>, /api/pay/...)
    location /pay  { proxy_pass http://127.0.0.1:8001; proxy_http_version 1.1;
                    proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr;
                    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                    proxy_set_header X-Forwarded-Proto $scheme; }
    location /api/pay { proxy_pass http://127.0.0.1:8001; proxy_http_version 1.1;
                    proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr;
                    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                    proxy_set_header X-Forwarded-Proto $scheme; }
    # Serve static assets (logo, QR) from admin-portal too
    location /static { proxy_pass http://127.0.0.1:8001; }
    location /uploads { proxy_pass http://127.0.0.1:8001; }

    # Default fallback -> lookup page
    location / { return 302 /pay; }

    listen [::]:443 ssl ipv6only=on; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/pay.autoispbilling.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/pay.autoispbilling.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


    # Friendly fallback when upstream is briefly unavailable (e.g. systemd restart).
    proxy_intercept_errors on;
    recursive_error_pages on;
    error_page 502 503 504 = @upstream_down;
    location @upstream_down {
        internal;
        root /opt/ispbilling/static_err;
        try_files /upstream_down.html =502;
        add_header Cache-Control "no-store";
        default_type text/html;
    }
}

server {
    if ($host = pay.autoispbilling.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name pay.autoispbilling.com;
    return 404; # managed by Certbot

}