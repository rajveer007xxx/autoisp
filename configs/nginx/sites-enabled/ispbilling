    # s26.8b: redirect-to-captive-https
    # Walled-garden users get dst-nat'd here from Mikrotik with foreign
    # Host headers (google.com, facebook.com, etc.). Redirect straight to
    # https://pay.autoispbilling.com/pay/captive so the browser gets a
    # VALID cert (no warning) AND the captive endpoint auto-identifies
    # the user via Mikrotik /ppp/active and pre-fills their ID.
    # Also makes OS captive-portal detectors (Android /generate_204,
    # Apple captive.apple.com, Windows msftconnecttest.com) see a
    # redirect and auto-prompt the user with "Sign in to network".
    # _S45E_CAPTIVE_GUARD — only redirect to captive when the visitor is
    # clearly NOT trying to reach a portal/API path. Without this guard the
    # rule blocks admins/employees/sub-LCOs from logging in via the bare IP.
    set $captive_redirect 0;
    if ($host !~* "^(www\.)?autoispbilling\.com$|^pay\.autoispbilling\.com$") {
        set $captive_redirect 1;
    }
    if ($request_uri ~* "^/(admin|employee|sub-lco|superadmin|customer|api|static|uploads|hotspot|login|logout|pay|password-reset|auth|ws)(/|$|\?)") {
        set $captive_redirect 0;
    }
    if ($captive_redirect = 1) {
        return 302 https://pay.autoispbilling.com/pay/captive;
    }

    # Long timeouts for PDF / export endpoints
    proxy_connect_timeout 60s;
    proxy_send_timeout    120s;
    proxy_read_timeout    120s;

    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Real-Port      $remote_port;  # X-Real-Port for captive conntrack lookup
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # --- Role-prefixed portals (path-based routing) ---
    location /superadmin { proxy_pass http://127.0.0.1:8004; }
    location /admin      { proxy_pass http://127.0.0.1:8001; }
    location /employee   { proxy_pass http://127.0.0.1:8001; }
    # customer dashboard lives on admin-portal
    location /customer   {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
    location /sub-lco    { proxy_pass http://127.0.0.1:8001; }
    location /api/mobile/ { proxy_pass http://127.0.0.1:8005; proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; }
    location /api/sub-lco/ { proxy_pass http://127.0.0.1:8001; }
    location /api/superadmin/ { proxy_pass http://127.0.0.1:8004; }

    # --- Login/logout + password-reset APIs: single portal that handles all 4 roles ---
    location = /login            { proxy_pass http://127.0.0.1:8001; }
    location = /logout           { proxy_pass http://127.0.0.1:8001; }
    location = /auth/sso         { proxy_pass http://127.0.0.1:8001; }
    location = /api/auth/login   { proxy_pass http://127.0.0.1:8001; }
    location /ws/ { proxy_pass http://127.0.0.1:8001; proxy_http_version 1.1; proxy_set_header Upgrade $http_upgrade; proxy_set_header Connection $connection_upgrade; proxy_set_header Host $host; proxy_read_timeout 3600s; proxy_send_timeout 3600s; }
    # __SITEMAP_PUBLIC_REPOINT__
    location = /sitemap.xml      { proxy_pass http://127.0.0.1:8000; }
    location = /robots.txt       { proxy_pass http://127.0.0.1:8000; }
    location = /sitemap          { proxy_pass http://127.0.0.1:8000; }
    # Per-role sitemaps still served by admin portal:
    location = /admin/sitemap    { proxy_pass http://127.0.0.1:8001; }
    location = /sub-lco/sitemap  { proxy_pass http://127.0.0.1:8001; }
    location = /employee/sitemap { proxy_pass http://127.0.0.1:8001; }
    location = /customer/sitemap { proxy_pass http://127.0.0.1:8001; }
    location ^~ /api/auth/       { proxy_pass http://127.0.0.1:8001; }

    # --- Shared assets: served from admin-portal (same static dir across portals) ---
    location /static  { proxy_pass http://127.0.0.1:8001; }
    location /hotspot { proxy_pass http://127.0.0.1:8001; }
    location /uploads { proxy_pass http://127.0.0.1:8001; }

    # Session 25.2: public pay / walled-garden routes go to admin-portal
    location /pay  { proxy_pass http://127.0.0.1:8001; }
    location /password-reset { proxy_pass http://127.0.0.1:8001; }
    location /api/pay { proxy_pass http://127.0.0.1:8001; }

    # _S39R5N_PUBLIC_API_ public-portal form endpoints
    location = /api/demo-request { proxy_pass http://127.0.0.1:8000; }
    location = /api/contact-form { proxy_pass http://127.0.0.1:8000; }
    location = /api/account-deletion-request { proxy_pass http://127.0.0.1:8000; }

    # --- Other /api/*: route by Referer to the portal that owns the UI page ---
    location /api/ { proxy_pass http://$api_backend; }

    # --- Marketing / homepage / contact / faq / privacy etc. ---
    location / { proxy_pass http://127.0.0.1:8000; }
}


